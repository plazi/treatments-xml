<subSubSection id="8ABF29EB32149E915D028A027C7CBCDD" pageId="null" pageNumber="281" type="description">
<paragraph id="06FB3882373275BEA32D016C4676E581" pageId="null" pageNumber="281">
Unterscheidet sich von der Gattung 
<taxonomicName id="21873AE5D6774D8EF8B99610DF34774E" class="Magnoliopsida" family="Rubiaceae" genus="Galium" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="281" phylum="Tracheophyta" rank="genus">
<emphasis id="5DAB28169149363CDC81C50D782B1169" italics="true" pageId="null" pageNumber="281">Galium</emphasis>
</taxonomicName>
(S. 286) durch folgende Merkmale: 
<emphasis id="89CDDB047AAA36C9E911724EC4C9037B" italics="true" pageId="null" pageNumber="281">
<normalizedToken id="521E8ABCDB9A8778C0FADAE5060261CC" originalValue="Blüten" pageId="null" pageNumber="281">Blueten</normalizedToken>
ungestielt
</emphasis>
, meist einzeln in der Achsel von 
<normalizedToken id="F686C02809484FFBFAF49B053F7680AD" originalValue="Tragblättern" pageId="null" pageNumber="281">Tragblaettern</normalizedToken>
und mit 
<normalizedToken id="F8C0AD19E4F39A990762036653C7EDBA" originalValue="Vorblättern" pageId="null" pageNumber="281">Vorblaettern</normalizedToken>
, 
<emphasis id="8AD3DA61C2CC2A29EFF8F0071EFB7DD4" italics="true" pageId="null" pageNumber="281">
zu 2- oder 4zeiligen, 
<normalizedToken id="A14B3D33223D24AF6191D0A2E6FF4EDC" originalValue="beblätterten" pageId="null" pageNumber="281">beblaetterten</normalizedToken>
<normalizedToken id="CFE5E626B76410E1A7899942A3B4AC83" originalValue="Ähren" pageId="null" pageNumber="281">Aehren</normalizedToken>
</emphasis>
angeordnet. Krone mit mindestens 2 mm langer 
<normalizedToken id="828CA676C2AF790B1F10DFD0B1099FBE" originalValue="Kronröhre" pageId="null" pageNumber="281">Kronroehre</normalizedToken>
und 4-5 flach ausgebreiteten, 
<emphasis id="B7DE3A7298D4A1EC30518182771290B7" italics="true" pageId="null" pageNumber="281">
an der Spitze 
<normalizedToken id="1D99C2278AA5289B0A78C9827524CB49" originalValue="einwärtsgebogenen" pageId="null" pageNumber="281">einwaertsgebogenen</normalizedToken>
Zipfeln;
</emphasis>
freier Teil der Krone bedeutend 
<normalizedToken id="52A193C11174068F36CB384AE65FE658" originalValue="kürzer" pageId="null" pageNumber="281">kuerzer</normalizedToken>
als der verwachsene Teil.
</paragraph>
<paragraph id="1D81BD2E42026F499683B96FE7380695" pageId="null" pageNumber="281">
Die Gattung 
<taxonomicName id="9999DCF40D3A374E860D4BE29CD9B588" class="Insecta" family="Muscidae" genus="Crucianella" kingdom="Animalia" order="Diptera" pageId="null" pageNumber="281" phylum="Arthropoda" rank="genus">
<emphasis id="B8635452C325F860AFD1DEEE607F8DED" italics="true" pageId="null" pageNumber="281">Crucianella</emphasis>
</taxonomicName>
<normalizedToken id="F76F3718A1DFF32F8FC86C735A214EB0" originalValue="umfaßt" pageId="null" pageNumber="281">umfasst</normalizedToken>
<emphasis id="D70AC7CEF778C2F0C85D271046FEFE27" italics="true" pageId="null" pageNumber="281">
etwa 30 vorwiegend mediterrane und 
<normalizedToken id="70BAC11183115386307AE95E61FCA752" originalValue="südwestasiatische" pageId="null" pageNumber="281">suedwestasiatische</normalizedToken>
Arten.
</emphasis>
</paragraph>
