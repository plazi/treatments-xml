<taxonomicName id="B55221F17458D9CC0D48B8C7A7F85E6D" authority="L." class="Magnoliopsida" family="Fabaceae" genus="Astragalus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="560" phylum="Tracheophyta" rank="species" species="exscapus">
Astragalus 
