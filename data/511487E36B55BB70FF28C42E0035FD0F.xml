sp. 1
</taxonomicName>
), where in the phylogeny of the family for the Greater Antilles it nested along with 
<taxonomicName id="1EBD4D766B53BB70FF60C0E10379FD47" authority="Urban (1923: 87)" authorityName="Urban" authorityPageNumber="87" authorityYear="1923" box="[192,563,662,688]" class="Magnoliopsida" family="Myrtaceae" genus="Myrcia" kingdom="Plantae" order="Myrtales" pageId="4" phylum="Tracheophyta" rank="species" species="apodocarpa">
<emphasis id="EBC9EAE76B53BB70FF60C0E10021FD47" box="[192,363,662,688]" italics="true" pageId="4">M. apodocarpa</emphasis>
<bibRefCitation id="BD2C4B046B53BB70FED1C0E00379FD47" author="Urban, I." box="[369,563,662,688]" pageId="4" pagination="55 - 176" refId="ref3302" refString="Urban, I. (1923) Plantae cubenses novae vel rariores a clo. Er. L. Ekman lectae. I. In: Urban, I. (Ed.) Symbolae antillanae 9. Leipzig, pp. 55 - 176." type="book chapter" year="1923">Urban (1923: 87)</bibRefCitation>
</taxonomicName>
, 
<taxonomicName id="1EBD4D766B53BB70FD9EC0E105CFFD46" authority="(C. Wright 1869: 433) Urban (1923: 86)" authorityName="Urban" authorityPageNumber="86" authorityYear="1923" baseAuthorityName="C. Wright" baseAuthorityPageNumber="433" baseAuthorityYear="1869" box="[574,1157,662,689]" class="Magnoliopsida" family="Myrtaceae" genus="Myrcia" kingdom="Plantae" order="Myrtales" pageId="4" phylum="Tracheophyta" rank="species" species="retivenia">
<emphasis id="EBC9EAE76B53BB70FD9EC0E1038FFD47" box="[574,709,663,688]" italics="true" pageId="4">M. retivenia</emphasis>
(C. 
<bibRefCitation id="BD2C4B046B53BB70FD52C0E002FDFD47" author="Wright, C." box="[754,951,662,688]" pageId="4" pagination="428 - 436" refId="ref3383" refString="Wright, C. (1869) Flora cubana. Anales de la Academia de Ciencias Medicas, Fisicas y Naturales de la Habana, Revista Cientifica 5: 428 - 436." type="journal article" year="1869">Wright 1869: 433</bibRefCitation>
) 
<bibRefCitation id="BD2C4B046B53BB70FC65C0E005CFFD46" author="Urban, I." box="[965,1157,662,689]" pageId="4" pagination="55 - 176" refId="ref3302" refString="Urban, I. (1923) Plantae cubenses novae vel rariores a clo. Er. L. Ekman lectae. I. In: Urban, I. (Ed.) Symbolae antillanae 9. Leipzig, pp. 55 - 176." type="book chapter" year="1923">Urban (1923: 86)</bibRefCitation>
</taxonomicName>
and 
<taxonomicName id="1EBD4D766B53BB70FB19C0E1009FFD23" authority="(Urban 1925: 341) Alain (1971: 138)" authorityName="Alain" authorityPageNumber="138" authorityYear="1971" baseAuthorityName="Urban" baseAuthorityPageNumber="341" baseAuthorityYear="1925" class="Magnoliopsida" family="Myrtaceae" genus="Myrcia" kingdom="Plantae" order="Myrtales" pageId="4" phylum="Tracheophyta" rank="species" species="abbottiana">
<emphasis id="EBC9EAE76B53BB70FB19C0E1041CFD47" box="[1209,1366,662,688]" italics="true" pageId="4">M. abbottiana</emphasis>
(Urban 1925: 341) 
<bibRefCitation id="BD2C4B046B53BB70FEA8C0CC009FFD23" author="Alain &amp; Bro" box="[264,469,698,724]" pageId="4" pagination="107 - 157" refId="ref2118" refString="Alain, Bro. (1971) Novitates antillanae. IV. Memoirs of the New York Botanical Garden 21 (2): 107 - 157." type="journal article" year="1971">Alain (1971: 138)</bibRefCitation>
</taxonomicName>
. Regarding the other species of the section in 
<collectingCountry id="A1AA76656B53BB70FC79C0CC055DFD23" box="[985,1047,698,724]" name="Cuba" pageId="4">Cuba</collectingCountry>
, 
<taxonomicName id="1EBD4D766B53BB70FB82C0CD05FEFD23" authorityName="Z. Acosta" authorityYear="2022" box="[1058,1204,698,724]" class="Magnoliopsida" family="Myrtaceae" genus="Myrcia" kingdom="Plantae" order="Myrtales" pageId="4" phylum="Tracheophyta" rank="species" species="urquiolae">
<emphasis id="EBC9EAE76B53BB70FB82C0CD05FEFD23" box="[1058,1204,698,724]" italics="true" pageId="4">M. urquiolae</emphasis>
