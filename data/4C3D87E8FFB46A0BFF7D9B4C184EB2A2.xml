<taxonomicName id="03944D7DFFB46A0BF6BF973217D9BABE" baseAuthorityName="Peters" baseAuthorityYear="1866" box="[2371,2521,363,396]" class="Mammalia" family="Vespertilionidae" genus="Scoteanax" kingdom="Animalia" order="Chiroptera" pageId="79" pageNumber="837" phylum="Chordata" rank="species" species="rueppellii">S. rueppellii</taxonomicName>
