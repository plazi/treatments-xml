<taxonomicName id="169981D11B09FFC5FC4EFFE0FB98FC06" authority="Thomas &amp; St. Leger" authorityYear="1926" class="Mammalia" family="Ctenomyidae" genus="Ctenomys" kingdom="Animalia" order="Rodentia" pageId="23" pageNumber="534" phylum="Chordata" rank="species" species="emilianus">Ctenomys emilianus Thomas &amp; St. Leger, 1926</taxonomicName>
, 
<materialsCitation id="61F1F00F1B09FFC5FB8BFFB0FC2EFBF4" ID-GBIF-Occurrence="3798388362" pageId="23" pageNumber="534">“Chos Malal, Prov. Neuquén. Altitude 805 m,” 37°23’ S, 70°16’ W, Argentina.</materialsCitation>
</paragraph>
<paragraph id="D126FA521B09FFC5FCBAF85EFB03FB42" blockId="23.[810,1404,913,1340]" pageId="23" pageNumber="534">
<taxonomicName id="169981D11B09FFC5FCBAF85EFBBBFB8C" authority="Thomas &amp; St. Leger" authorityYear="1926" box="[814,1067,1071,1104]" class="Mammalia" family="Ctenomyidae" genus="Ctenomys" kingdom="Animalia" order="Rodentia" pageId="23" pageNumber="534" phylum="Chordata" rank="species" species="emilianus">Ctenomys emilianus</taxonomicName>
