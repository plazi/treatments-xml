<subSubSection id="C3485ED60978B227EC95F967259D4BA0" lastPageId="45" lastPageNumber="496" pageId="44" pageNumber="495" type="etymology">
<paragraph id="8BED0D5D0978B226EC95F96722124CD0" blockId="44.[151,1436,1723,2038]" pageId="44" pageNumber="495">
<emphasis id="B926D14F0978B226EC95F96721294CFC" bold="true" box="[151,290,1723,1749]" pageId="44" pageNumber="495">Etymology:</emphasis>
<taxonomicName id="4C5276DE0978B226ED2AF96721D04CFC" authority=": Greek" authorityName="Greek" box="[296,475,1723,1750]" class="Actinopterygii" family="Poeciliidae" genus="Poecilia" kingdom="Animalia" order="Cyprinodontiformes" pageId="44" pageNumber="495" phylum="Chordata" rank="genus">
<emphasis id="B926D14F0978B226ED2AF967218E4CFC" box="[296,389,1723,1749]" italics="true" pageId="44" pageNumber="495">Poecilia</emphasis>
: Greek
</taxonomicName>
, 
<emphasis id="B926D14F0978B226EDE4F96722344CFC" box="[486,575,1723,1749]" italics="true" pageId="44" pageNumber="495">poikilos</emphasis>
= with a lot of colours; 
<taxonomicName id="4C5276DE0978B226EF46F96723A24CFC" baseAuthorityName="Lesueur" baseAuthorityYear="1821" box="[836,937,1723,1749]" class="Actinopterygii" family="Poeciliidae" genus="Poecilia" kingdom="Animalia" order="Cyprinodontiformes" pageId="44" pageNumber="495" phylum="Chordata" rank="species" species="latipinna">
<emphasis id="B926D14F0978B226EF46F96723A24CFC" box="[836,937,1723,1749]" italics="true" pageId="44" pageNumber="495">latipinna</emphasis>
</taxonomicName>
: from the Latin word 
<emphasis id="B926D14F0978B226E8A2F96724DD4CFC" box="[1184,1238,1723,1749]" italics="true" pageId="44" pageNumber="495">latus</emphasis>
(stem 
<emphasis id="B926D14F0978B226E920F967254B4CFC" box="[1314,1344,1723,1749]" italics="true" pageId="44" pageNumber="495">lat</emphasis>
), meaning wide, broad, and 
<emphasis id="B926D14F0978B226ED86F93C21CF4CD0" box="[388,452,1760,1785]" italics="true" pageId="44" pageNumber="495">pinna</emphasis>
for fin.
</paragraph>
<paragraph id="8BED0D5D0978B226ECC5F8DF22214D34" blockId="44.[151,1436,1723,2038]" box="[199,554,1795,1821]" pageId="44" pageNumber="495">
<emphasis id="B926D14F0978B226ECC5F8DF218C4D34" bold="true" box="[199,391,1795,1821]" pageId="44" pageNumber="495">Common name:</emphasis>
Sailfin Molly.
</paragraph>
<paragraph id="8BED0D5D0978B226ECC5F8FB20EF4DA0" blockId="44.[151,1436,1723,2038]" pageId="44" pageNumber="495">
<emphasis id="B926D14F0978B226ECC5F8FB21454D68" bold="true" box="[199,334,1831,1857]" pageId="44" pageNumber="495">Taxonomy:</emphasis>
<taxonomicName id="4C5276DE0978B226ED56F8FB22264D68" box="[340,557,1831,1857]" class="Actinopterygii" family="Poeciliidae" genus="Mollienesia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyprinodontiformes" pageId="44" pageNumber="495" phylum="Chordata" rank="species" species="tipinna">
