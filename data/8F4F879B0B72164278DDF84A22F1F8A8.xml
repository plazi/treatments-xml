Key to species of 
<taxonomicName id="C0E64D0E0B7216437900F84A26D2F80A" authorityName="Linnaeus" authorityYear="1753" box="[341,392,1928,1955]" class="Magnoliopsida" family="Malvaceae" genus="Sida" kingdom="Plantae" order="Malvales" pageId="2" pageNumber="107" phylum="Tracheophyta" rank="genus">
