<taxonomicName id="EC3B049D5DDC077C9134F09D0A87B35A" authorityName="Nees, Trans. Linn. Soc. London 17 (1): 48" authorityYear="1834" class="Magnoliopsida" family="Solanaceae" genus="Solanum" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Solanum vagum" order="Solanales" pageId="0" pageNumber="1" phylum="Tracheophyta" rank="species" species="vagum">
