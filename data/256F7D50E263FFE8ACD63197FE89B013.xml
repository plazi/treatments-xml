<bibRefCitation id="C957B1B7E263FFE8ADA93653FDCBB238" author="Duclos P. L." box="[488,626,1047,1071]" pageId="8" pageNumber="9" refId="ref56480" refString="Duclos P. L. (1840) Histoire naturelle generale et particuliere de tous les genres de coquilles univalves marines a l'etat vivant et fossile, publiee par monographie. Genre Colombelle. Didot, Paris, 13 pls. [http: // biodiversitylibrary. org / page / 45200570]" type="url" year="1840">Duclos, 1840</bibRefCitation>
