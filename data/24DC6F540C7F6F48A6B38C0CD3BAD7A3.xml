<subSubSection id="F659C0833AD27664E48F309277228F2E" pageId="null" pageNumber="590" type="description">
<paragraph id="C8A96433A9662FC9C73D6CE770857921" pageId="null" pageNumber="590">
Ausdauernd, mit schwarzer, holziger Pfahlwurzel; 20-50 cm hoch. Stengel aufrecht, im obern Teil meist verzweigt, 1-9 
<normalizedToken id="FE10C93F7A4656FE33E23E662C1343FE" originalValue="köpfig" pageId="null" pageNumber="590">koepfig</normalizedToken>
, behaart (kurze, 
<normalizedToken id="83FC1B3CCA50E586CBB8A7130F6412AF" originalValue="drüsige" pageId="null" pageNumber="590">druesige</normalizedToken>
Haare oder lange, gelbe oder kurze, 
<normalizedToken id="715F67F3FE6C9D8031B26A2568768A80" originalValue="weiße" pageId="null" pageNumber="590">weisse</normalizedToken>
<pageBreakToken id="D77B9E9E835B4C58664FFE36181F1FCA" pageId="null" pageNumber="590" start="start">Haare</pageBreakToken>
), entfernt 
<normalizedToken id="59E2468B097914191D9CA1552AB5756F" originalValue="beblättert" pageId="null" pageNumber="590">beblaettert</normalizedToken>
. 
<normalizedToken id="F79141B9D15EC5DBEE0A4BD20995CEC1" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
wie der Stengel behaart, oval bis lanzettlich, buchtig 
<normalizedToken id="02442261839873F4BDC954ACE95A339E" originalValue="gezähnt" pageId="null" pageNumber="590">gezaehnt</normalizedToken>
, seltener jederseits bis zur Mitte der 
<normalizedToken id="FC7BD4875B0EC6E503B838F7F9E84ED7" originalValue="Blatthälfte" pageId="null" pageNumber="590">Blatthaelfte</normalizedToken>
fiederteilig, die 
<normalizedToken id="F9D69EF21E9F4C3648471DB3A6923F3B" originalValue="grundständigen" pageId="null" pageNumber="590">grundstaendigen</normalizedToken>
<normalizedToken id="28ABC9318422EAA8D1B651D5E6128BC6" originalValue="allmählich" pageId="null" pageNumber="590">allmaehlich</normalizedToken>
in den 
<normalizedToken id="5F11868C1BDDE3818E954C89330A2BDD" originalValue="geflügelten" pageId="null" pageNumber="590">gefluegelten</normalizedToken>
Stiel 
<normalizedToken id="E0AD2004D1094CD4207D61F0474A1C91" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
, 
<emphasis id="1612B9CC6101BCFB605DAECD1D1C4C51" italics="true" pageId="null" pageNumber="590">
zur 
<normalizedToken id="99767AC8E837F3C0D4D389FE0B3CBE8E" originalValue="Blütezeit" pageId="null" pageNumber="590">Bluetezeit</normalizedToken>
noch vorhanden;
</emphasis>
die 
<normalizedToken id="D0064F0FC909A9D45A6A20A50954A92C" originalValue="stengelständigen" pageId="null" pageNumber="590">stengelstaendigen</normalizedToken>
sitzend und 
<emphasis id="422FF87DBE065395ACBCC0604C15F5C4" italics="true" pageId="null" pageNumber="590">den Stengel mit 2 spitzen Zipfeln umfassend.</emphasis>
<normalizedToken id="088CA2BFDE51905496CCB8F571450122" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
weit 
<normalizedToken id="EE6DBA7FB826337D5018AD4B6564AB78" originalValue="glockenförmig" pageId="null" pageNumber="590">glockenfoermig</normalizedToken>
, 10-16 mm lang, mit zahlreichen langen, gelben und oft auch kurzen, 
<normalizedToken id="5E0959856AAE516FF335A1AB05B5CC22" originalValue="weißen" pageId="null" pageNumber="590">weissen</normalizedToken>
und 
<emphasis id="C5E43406D5AA7DD709F9138642D1E413" italics="true" pageId="null" pageNumber="590">
kurzen, 
<normalizedToken id="E9F395628AA175DAE283ED41311A7A32" originalValue="drüsigen" pageId="null" pageNumber="590">druesigen</normalizedToken>
Haaren; 
<normalizedToken id="7E86A516289EC46EBFA736DA05A3E53F" originalValue="längste" pageId="null" pageNumber="590">laengste</normalizedToken>
<normalizedToken id="7E0BDEA9309D8BA2FE87FA4F77706713" originalValue="äußere" pageId="null" pageNumber="590">aeussere</normalizedToken>
<normalizedToken id="E61F61C52E3D81B6FA64F11D5E1F654A" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
<normalizedToken id="EB9481DC455E5D4DCEF73651B05C3BA8" originalValue="höchstens" pageId="null" pageNumber="590">hoechstens</normalizedToken>
</emphasis>
<normalizedToken id="405CC6F1D2AF600B18D366E735B59CD2" originalValue="½" pageId="null" pageNumber="590">1/2</normalizedToken>
<emphasis id="B9736376D25D6B787A9D508A58A9B620" italics="true" pageId="null" pageNumber="590">
so lang wie die innern; Innenseite der innern 
<normalizedToken id="7E4CFD532D660FF3FD278CE4870C53AD" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
kurz behaart.
</emphasis>
<pageBreakToken id="EE4B8A89E34A520257B22E0D781911E3" pageId="null" pageNumber="590">Boden</pageBreakToken>
des 
<normalizedToken id="9456EBF843067668CCEFEED380D24220" originalValue="Blütenkopfes" pageId="null" pageNumber="590">Bluetenkopfes</normalizedToken>
sehr kurz behaart. Kronen gelb, die 
<normalizedToken id="D38AE34F0BA801AF90702FE5D8818848" originalValue="äußern" pageId="null" pageNumber="590">aeussern</normalizedToken>
18-21 mm lang, 
<emphasis id="739AFB1F59E53C2197AE691D50715F4D" italics="true" pageId="null" pageNumber="590">
mit 
<normalizedToken id="D669FA98BD74F75950DB9C6A8B47A309" originalValue="außen" pageId="null" pageNumber="590">aussen</normalizedToken>
behaarter 
<normalizedToken id="6BD58879AE2306E3F914C6213189F5F0" originalValue="Kronröhre" pageId="null" pageNumber="590">Kronroehre</normalizedToken>
.
</emphasis>
<normalizedToken id="EBE2B31DDDE4D9A132B83CB3FA2A597E" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
15-20rippig, 5-10 mm lang, nach oben 
<normalizedToken id="FAA62DCE924CE5D70BF3700F9F49985A" originalValue="allmählich" pageId="null" pageNumber="590">allmaehlich</normalizedToken>
<normalizedToken id="1C9C35B445372628DCBE7F2B0060319B" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
. 
<taxonomicName id="4D5B3B084998B9DD42EBA87BC4984CAF" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
<normalizedToken id="1DC49D70169DD74009F9B055C90ADDB6" originalValue="weiß" pageId="null" pageNumber="590">weiss</normalizedToken>
, 2-4reihig, 5-9 mm lang. - 
<normalizedToken id="FA23049F28B8A2E9FBC4F688880F8A71" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="1BE1209E1D2F2B346E5B1AA36FF91008" pageId="null" pageNumber="590">
<emphasis id="B5B9E767CA3EBB63E27DBCB6D0CBE242" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="1C96B7A59AFEF6012D8E1E80A1CC7CFC" italics="true" pageId="null" pageNumber="590">8:</emphasis>
Material aus botanischen 
<normalizedToken id="0A8522CB638EAA8E7911275FE11368F4" originalValue="Gärten" pageId="null" pageNumber="590">Gaerten</normalizedToken>
(Babcock 1947, Wagenaar 1969), aus den Alpen (Wanner und Bruhin 1949), aus den Ostkarpaten (Chouksanova et al. 1968), von den Cevennen (Delay 1970a), aus Polen (Skalinska et al. 1971). 
<normalizedToken id="9C6382D4373426A1D8EA9376B85C453B" originalValue="Fröst" pageId="null" pageNumber="590">Froest</normalizedToken>
und Oestgren (1959) 
<normalizedToken id="5632EA618772D6E958F3E4CDE3CF3EDA" originalValue="zählten" pageId="null" pageNumber="590">zaehlten</normalizedToken>
auch B-Chromosomen; 
<normalizedToken id="4D487004F84C68D029B1037910804082" originalValue="Fröst" pageId="null" pageNumber="590">Froest</normalizedToken>
(1962) konstatierte an Material vom Gran Paradiso bei 27% der Pflanzen 1-4 B-Chromosomen, 
<normalizedToken id="92AE4FE9E333419F033457F909D7CC59" originalValue="während" pageId="null" pageNumber="590">waehrend</normalizedToken>
diese bei Pflanzen vom Unterengadin und von Innsbruck sehr selten waren oder fehlten.
</paragraph>
<paragraph id="1B6EE13177570C60EC6A915C9625E232" pageId="null" pageNumber="590">
<emphasis id="AFACE6B0C35053F5546936EBD4128CC4" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Subalpin, selten alpin oder montan. 
<normalizedToken id="DCBA54E4B9609B04D2869B5CC3B4B0B3" originalValue="Mäßig" pageId="null" pageNumber="590">Maessig</normalizedToken>
feuchte, kalk- und 
<normalizedToken id="819141506CC627BFF13CC5C5676A8079" originalValue="nährstoffarme" pageId="null" pageNumber="590">naehrstoffarme</normalizedToken>
, humose, tonreiche 
<normalizedToken id="505651915BD8C5A81F286AE391D8888B" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
. Magere Wiesen und Weiden.
</paragraph>
<paragraph id="8AD7AADE97E913D540B41F6807999F3E" pageId="null" pageNumber="590">
<emphasis id="532D14CD0121924D6427825A148B2447" italics="true" pageId="null" pageNumber="590">Verbreitung. Eurasiatische Gebirgspflanze:</emphasis>
<normalizedToken id="24E4BC7699D98591C9353CC415C0E3E8" originalValue="Pyrenäen" pageId="null" pageNumber="590">Pyrenaeen</normalizedToken>
, Alpen, 
<normalizedToken id="6E5FC7702A23F362C44A5A32C27FA21B" originalValue="nördlicher" pageId="null" pageNumber="590">noerdlicher</normalizedToken>
Apennin, Gebirge der Balkanhalbinsel, Karpaten; Gebirge des 
<normalizedToken id="CD56B0290981704E052BABCB2FDDCA45" originalValue="nördlichen" pageId="null" pageNumber="590">noerdlichen</normalizedToken>
Kleinasiens, Kaukasus, Transkaukasien, Altai. - Im Gebiet: Savoyen, Jura (Mont Clergeon); Zentral- und 
<normalizedToken id="24A43798E9FE31AA6FAA9DFFA3D90053" originalValue="Südalpen" pageId="null" pageNumber="590">Suedalpen</normalizedToken>
, ziemlich 
<normalizedToken id="9CC39256ED2FDBEC047527074E0C5844" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
; Nordalpen und Alpenvorland, ziemlich selten.
</paragraph>
</subSubSection>
