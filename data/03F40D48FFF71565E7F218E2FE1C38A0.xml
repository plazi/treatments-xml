<figureCitation id="1366A0DBFFF71566E7F218CEFEB23BD0" box="[151,276,187,213]" captionStart="FIGURE 3" captionStartId="12.[151,250,1915,1939]" captionTargetBox="[152,1434,1353,1890]" captionTargetId="figure-449@12.[151,1435,1353,1891]" captionTargetPageId="12" captionText="FIGURE 3. A–C. Pristonesia uvenil sp. nov.. A. Habitus, lateral view; B. Head, dorsal view; C. Mesosoma, dorsal view. Scale bars = 100 µm." figureDoi="http://doi.org/10.5281/zenodo.6411091" httpUri="https://zenodo.org/record/6411091/files/figure.png" pageId="12" pageNumber="333">Figs 3A–C</figureCitation>
