<subSubSection id="388DD63107AB9C7136734F696CDDE002" pageId="null" pageNumber="190" type="description">
<paragraph id="394FFA3A682FE7EB5BB4EA034411DEBA" pageId="null" pageNumber="190">
<normalizedToken id="11919B55F25434BBFA8035951EF996C5" originalValue="Früchte" pageId="null" pageNumber="190">Fruechte</normalizedToken>
7-10 mm lang (mit Schnabel), ⅓- 
<normalizedToken id="00C5AAA62728466450373E5E24EB2330" originalValue="½" pageId="null" pageNumber="190">1/2</normalizedToken>
so dick wie lang, 
<emphasis id="E7405551B0521EC4AA8C232E59BAB628" italics="true" pageId="null" pageNumber="190">
im obersten Drittel mit einem 
<normalizedToken id="860FB6DAD478D8594237239A7DFDD2D9" originalValue="zwiebelförmigen" pageId="null" pageNumber="190">zwiebelfoermigen</normalizedToken>
Aufsatz, darunter mit deutlicher 
<normalizedToken id="FE26F594698F2E4A5EDD729E746F1702" originalValue="Einschnürung" pageId="null" pageNumber="190">Einschnuerung</normalizedToken>
, nach dem Grunde 
<normalizedToken id="5252395F8FA40425141ADDE66468D341" originalValue="allmählich" pageId="null" pageNumber="190">allmaehlich</normalizedToken>
<normalizedToken id="F29D0EFE93C7CB791F11603BFAE1C17E" originalValue="verschmälert" pageId="null" pageNumber="190">verschmaelert</normalizedToken>
, 
<normalizedToken id="C301F4B4D82279D14AF743E73C8700FB" originalValue="pyramidenförmig" pageId="null" pageNumber="190">pyramidenfoermig</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="A2A9FF038368DDAB4A7A900054C91FD8" pageId="null" pageNumber="190">
<emphasis id="3413BEB90723857122F019E5AEED6229" italics="true" pageId="null" pageNumber="190">Zytologische Angaben.</emphasis>
Siehe unter Artengruppe.
</paragraph>
<paragraph id="89CED3A1418D179F1DBABA706F94A6E5" pageId="null" pageNumber="190">
<emphasis id="66B3E1811CFBEF7FB344D49B16354345" italics="true" pageId="null" pageNumber="190">Standort.</emphasis>
Wahrscheinlich wie 
<taxonomicName id="F3D0EF47140E0E3E0A89919BA780ED63" class="Liliopsida" family="Typhaceae" genus="Sparganium" kingdom="Plantae" order="Poales" pageId="null" pageNumber="190" phylum="Tracheophyta" rank="species" species="neglectum">
<emphasis id="295C9285EF1BF4407711F4B242A8572C" italics="true" pageId="null" pageNumber="190">S. neglectum</emphasis>
</taxonomicName>
(Nr. 1c).
</paragraph>
<paragraph id="AB71AB9D649FC2E2D6B82F416D0A6AFD" pageId="null" pageNumber="190">
<emphasis id="866CE14103961B2ECFD06BD3B0B3336D" italics="true" pageId="null" pageNumber="190">Verbreitung. Eurosibirische Pflanze:</emphasis>
In 
<taxonomicName id="0A1B7C2DF40A8A1BB75E9D2563B05828" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="190" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
vom Polarkreis 
<normalizedToken id="FE2DBE2FA747F760567FBC6F8F37C1E1" originalValue="südwärts" pageId="null" pageNumber="190">suedwaerts</normalizedToken>
bis Nordafrika, 
<normalizedToken id="8D8351F486747800DD434875F70A67B3" originalValue="ostwärts" pageId="null" pageNumber="190">ostwaerts</normalizedToken>
bis Sibirien (Cook 1961). - Im Gebiet wahrscheinlich ziemlich verbreitet; wenige Angaben, da bisher 
<normalizedToken id="9151FB270B8219FF1081C51732A98082" originalValue="übersehen" pageId="null" pageNumber="190">uebersehen</normalizedToken>
.
</paragraph>
