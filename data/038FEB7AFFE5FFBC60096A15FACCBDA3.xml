<taxonomicName id="4C2621EFFFE5FFBC67206D37FC04BD43" authorityName="Löbl" authorityYear="2022" box="[831,950,1034,1058]" class="Insecta" family="Staphylinidae" genus="Scaphoxium" kingdom="Animalia" order="Coleoptera" pageId="14" pageNumber="117" phylum="Arthropoda" rank="species" species="lobatum">
