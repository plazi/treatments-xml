<collectorName id="26D0537DEE0EFFCEFEBBFDA9FE6D5724" box="[348,455,612,635]" pageId="7" pageNumber="146">Memariani</collectorName>
&amp; 
<collectorName id="26D0537DEE0EFFCEFE00FDA9FDE85723" box="[487,578,612,636]" pageId="7" pageNumber="146">Arjmandi</collectorName>
44626
</emphasis>
(
<collectionCode id="ED34AE6EEE0EFFCEFD71FDA9FD4D5723" box="[662,743,612,636]" country="Iran" httpUri="http://biocol.org/urn:lsid:biocol.org:col:15384" lsid="urn:lsid:biocol.org:col:15384" name="Ferdowsi University" pageId="7" pageNumber="146" type="Herbarium">FUMH</collectionCode>
