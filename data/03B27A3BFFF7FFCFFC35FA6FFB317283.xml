<paragraph id="8BA4CB2DFFF7FFCFFCABF8AFFB317283" blockId="11.[811,1457,1811,2028]" pageId="11" pageNumber="124">
<bibRefCitation id="EF8AB6DCFFF7FFCFFCABF8AFFBCC7225" author="LECOMTE H." box="[813,1062,1842,1869]" pageId="11" pageNumber="124" pagination="99 - 121" refId="ref13173" refString="LECOMTE H. 1928 a. - Ebenacees nouvelles de l'Indochine. Notulae Systematicae 4 (4): 99 - 121. https: // www. biodiversitylibrary. org / page / 6463259" type="journal article" year="1928">Lecomte (1928a: 116)</bibRefCitation>
cited 
<emphasis id="B96F173FFFF7FFCFFBE8F8AEFB147224" box="[1134,1278,1842,1868]" italics="true" pageId="11" pageNumber="124">Poilane 4512</emphasis>
from Nhatrang as the original material. Then, 
<bibRefCitation id="EF8AB6DCFFF7FFCFFB15F8CFFA857204" author="NGUYEN T. H." box="[1171,1391,1874,1901]" pageId="11" pageNumber="124" pagination="63 - 74" refId="ref13500" refString="NGUYEN T. H. 1996. - Fam. Ebenaceae Gurke, in AVERYANOV L. V., NGUYEN T. B., NGUYEN T. H., PHAN K. L., SEROV V. P. &amp; AKIMOVA G. A. (eds), Vascular Plants Synopsis of Vietnamese Flora. Russian Academy of Sciences, Saint Petersburg, Russia and National Center for Natural Sciences and Technology of Vietnam: 63 - 74." type="book chapter" year="1996">Nguyen (1996: 70)</bibRefCitation>
cited 
<emphasis id="B96F173FFFF7FFCFFCA9F8EEFC2A72E4" box="[815,960,1906,1932]" italics="true" pageId="11" pageNumber="124">Poilane 4512</emphasis>
