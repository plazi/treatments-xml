<subSubSection id="79DA6524362FFC0DC482DFFDFCB3B13D" pageId="22" pageNumber="387" type="reference_group">
<paragraph id="317F36AF362FFC0DC482DFFDFCB3B13D" blockId="22.[178,1086,706,816]" pageId="22" pageNumber="387">
<taxonomicName id="F6C04D2C362FFC0DC482DFFDFEC4B0D5" authorityName="SCHEERPELTZ" authorityYear="1947" box="[178,363,706,728]" class="Insecta" family="Staphylinidae" genus="Cyrtonychochaeta" kingdom="Animalia" order="Coleoptera" pageId="22" pageNumber="387" phylum="Arthropoda" rank="genus">
<emphasis id="03B4EABD362FFC0DC482DFFDFEC4B0D5" box="[178,363,706,728]" italics="true" pageId="22" pageNumber="387">Cyrtonychochaeta</emphasis>
</taxonomicName>
was originally described as a genus by 
<bibRefCitation id="55514B5E362FFC0DC70DDFFDFBB5B0D5" author="SCHEERPELTZ O" box="[829,1050,706,728]" pageId="22" pageNumber="387" pagination="251 - 356" refId="ref20958" refString="SCHEERPELTZ O. (1947): Neue Staphyliniden (Coleoptera) aus Osterreich. I. - Sitzungsberichte der Osterreichischen Akademie der Wissenschaften, Mathematischnaturwissenschaftliche Klasse, Abteilung I 156 (5 / 6): 251 - 356." type="journal article" year="1947">SCHEERPELTZ (1947)</bibRefCitation>
to include only the 
<typeStatus id="EE7B880D362FFC0DC55EDFDFFE35B0F8" box="[366,410,736,757]" pageId="22" pageNumber="387">type</typeStatus>
species, 
<taxonomicName id="F6C04D2C362FFC0DC632DFDFFDDBB0F8" baseAuthorityName="Scheerpeltz" baseAuthorityYear="1947" box="[514,628,735,757]" class="Insecta" family="Staphylinidae" genus="Cyrtonychochaeta" kingdom="Animalia" order="Coleoptera" pageId="22" pageNumber="387" phylum="Arthropoda" rank="species" species="hoelzeli">
<emphasis id="03B4EABD362FFC0DC632DFDFFDDBB0F8" box="[514,628,735,757]" italics="true" pageId="22" pageNumber="387">C. hoelzeli</emphasis>
</taxonomicName>
, which was described in the same paper. 
<taxonomicName id="F6C04D2C362FFC0DC482DFC3FEC4B11F" authorityName="SCHEERPELTZ" authorityYear="1947" box="[178,363,764,786]" class="Insecta" family="Staphylinidae" genus="Cyrtonychochaeta" kingdom="Animalia" order="Coleoptera" pageId="22" pageNumber="387" phylum="Arthropoda" rank="genus">
<emphasis id="03B4EABD362FFC0DC482DFC3FEC4B11F" box="[178,363,764,786]" italics="true" pageId="22" pageNumber="387">Cyrtonychochaeta</emphasis>
</taxonomicName>
was subsequently attributed to 
<taxonomicName id="F6C04D2C362FFC0DC6F2DFC3FCB2B11F" authorityName="MANNERHEIM" authorityYear="1830" box="[706,797,764,786]" class="Insecta" family="Staphylinidae" genus="Oxypoda" kingdom="Animalia" order="Coleoptera" pageId="22" pageNumber="387" phylum="Arthropoda" rank="genus">
<emphasis id="03B4EABD362FFC0DC6F2DFC3FCB2B11F" box="[706,797,764,786]" italics="true" pageId="22" pageNumber="387">Oxypoda</emphasis>
</taxonomicName>
as a subgenus by 
<bibRefCitation id="55514B5E362FFC0DC7DCDFC2FF57B13D" author="ZERCHE L" pageId="22" pageNumber="387" pagination="307 - 336" refId="ref21311" refString="ZERCHE L. (1995): Revision der Oxypoda - Untergattung Cyrtonychochaeta SCHEERPELTZ, 1947, stat. n., und alpiner Arten der Untergattung Podoxya MULSANT &amp; REY, 1875 (Coleoptera, Staphylinidae, Aleocharinae). - Beitrage zur Entomologie, Berlin 45 (2): 307 - 336." type="journal article" year="1995">ZERCHE (1995)</bibRefCitation>
, according to whom the genus comprises two species.
</paragraph>
</subSubSection>
