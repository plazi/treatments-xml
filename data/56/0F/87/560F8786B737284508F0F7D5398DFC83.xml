<paragraph blockId="18.[1443,2650,283,830]" box="[1443,2379,283,316]" pageId="18" pageNumber="408">
<emphasis bold="true" box="[1443,1677,283,316]" pageId="18" pageNumber="408">Activity patterns.</emphasis>
