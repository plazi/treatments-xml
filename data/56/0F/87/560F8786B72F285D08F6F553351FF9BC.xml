<taxonomicName baseAuthorityName="Goldfuss" baseAuthorityYear="1809" box="[1083,1263,3085,3114]" class="Mammalia" family="Cebidae" genus="Cebus" kingdom="Animalia" order="Primates" pageId="10" pageNumber="399" phylum="Chordata" rank="species" species="nigritus">Cebus nigritus</taxonomicName>
