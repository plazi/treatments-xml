<taxonomicName box="[323,468,919,948]" class="Mammalia" family="Cebidae" genus="Cebus" kingdom="Animalia" order="Primates" pageId="22" pageNumber="412" phylum="Chordata" rank="species" species="albifrons">C. albifrons</taxonomicName>
