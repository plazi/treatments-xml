. 
<taxonomicName id="4C6D4D5EEEC33BA7FE86FC9BFE04FCAE" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[323,449,853,879]" class="Maxillopoda" family="Notodelphyidae" genus="Chelipygus" kingdom="Animalia" order="Cyclopoida" pageId="402" pageNumber="403" phylum="Arthropoda" rank="genus" status="gen. nov.">
