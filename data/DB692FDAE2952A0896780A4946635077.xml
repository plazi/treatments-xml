<subSubSection id="AE34E0D8EB6DDFBB5997E771047D7705" pageId="null" pageNumber="465" type="nomenclature">
<paragraph id="BAEAC6FE31B3AF2E21D40815C878F2C6" pageId="null" pageNumber="465">
<taxonomicName id="8DD55E8956D36B2A543F74321763656E" authority="Ehrh." class="Magnoliopsida" family="Rosaceae" genus="Prunus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="465" phylum="Tracheophyta" rank="species" species="cerasifera">
