<taxonomicName id="4C4F4D0774756558FD1EFC32A0D13392" box="[653,734,954,976]" class="Insecta" kingdom="Animalia" order="Diptera" pageId="3" pageNumber="744" phylum="Arthropoda" rank="order">Diptera</taxonomicName>
: 
<taxonomicName id="4C4F4D0774756558FD7AFC32A18B3392" box="[745,900,954,976]" class="Insecta" family="Cecidomyiidae" kingdom="Animalia" order="Diptera" pageId="3" pageNumber="744" phylum="Arthropoda" rank="family">Cecidomyiidae</taxonomicName>
) and (
<taxonomicName id="4C4F4D0774756558FC55FC32A6353392" authorityName="Linnaeus" authorityYear="1758" box="[966,1082,954,976]" class="Insecta" kingdom="Animalia" order="Coleoptera" pageId="3" pageNumber="744" phylum="Arthropoda" rank="order">Coleoptera</taxonomicName>
: 
<taxonomicName id="4C4F4D0774756558FF21FC5FA34C33AF" authorityName="Latreille" authorityYear="1802" box="[178,323,983,1005]" class="Insecta" family="Curculionidae" kingdom="Animalia" order="Coleoptera" pageId="3" pageNumber="744" phylum="Arthropoda" rank="family">Curculionidae</taxonomicName>
) (
<bibRefCitation id="EFDE4B7574756558FEC4FC5FA01833AF" author="NARENDRAN T" box="[343,535,983,1005]" pageId="3" pageNumber="744" pagination="73 - 75" refId="ref3981" refString="NARENDRAN T. C. (2007): Indian chalcidoid parasitoids of the Tetrastichinae (Hymenoptera: Eulophidae). - Records of the Zoological Survey of India, Occasional Zoological Survey of India, Kolkatha, 272 (33): 73 - 75." type="journal article" year="2007">NARENDRAN 2007</bibRefCitation>
).
</paragraph>
