<subSubSection id="1D5E19DEC51973F7DFF8A48089A8E51A" pageId="null" pageNumber="321" type="description">
<paragraph id="6A89AA051B3D2905BF34EEF75A5A1866" pageId="null" pageNumber="321">
<emphasis id="C5FD58400EE6277BFB9759DED5A051CE" italics="true" pageId="null" pageNumber="321">
1 
<normalizedToken id="3C4C6525F6698E8A9E6FDBB48364A25A" originalValue="jährig" pageId="null" pageNumber="321">jaehrig</normalizedToken>
</emphasis>
(meist im Herbst, seltener erst im 
<normalizedToken id="DA33F1DB11370F95A4629C55F11759CB" originalValue="Frühjahr" pageId="null" pageNumber="321">Fruehjahr</normalizedToken>
keimend), 3-20 cm lang, niederliegend oder bogig aufsteigend. Stengel einfach oder verzweigt, locker anliegend oder abstehend behaart. 
<normalizedToken id="00E67CAF032652D4B9657B7C7BCA3DA6" originalValue="Blätter" pageId="null" pageNumber="321">Blaetter</normalizedToken>
alle 
<normalizedToken id="55E7C1F9A7040A81A94C540439D518FB" originalValue="stengelständig" pageId="null" pageNumber="321">stengelstaendig</normalizedToken>
(
<emphasis id="E45A11D7D967DAFB4F8A34C17AC78073" italics="true" pageId="null" pageNumber="321">
keine 
<normalizedToken id="18F8DDB84202DA8ED7D45DDFCD5DC66F" originalValue="grundständige" pageId="null" pageNumber="321">grundstaendige</normalizedToken>
Rosette
</emphasis>
), 
<normalizedToken id="7D10FAC8EEF04FD9D0C6F015DCAC035C" originalValue="überall" pageId="null" pageNumber="321">ueberall</normalizedToken>
zerstreut und borstig behaart, untere bis 0,5 cm lang gestielt, obere sitzend; Spreite bis 0,8 cm lang, im 
<normalizedToken id="7838D8ABCAB481FEE8C2E12FBED3C681" originalValue="Umriß" pageId="null" pageNumber="321">Umriss</normalizedToken>
rhombisch, bis auf ⅓ 3teilig, jeder Abschnitt nochmals bis auf 
<normalizedToken id="EBA5B61A92DEE20D2CA5F79F80CB7BD6" originalValue="¾" pageId="null" pageNumber="321">3/4</normalizedToken>
2-5teilig oder nur grob 
<normalizedToken id="2D48AF5BFAA09166470D4538D438D3C5" originalValue="gezähnt" pageId="null" pageNumber="321">gezaehnt</normalizedToken>
; 
<normalizedToken id="C4235C9F11BC4CF98E3ED72DC54581D9" originalValue="Zähne" pageId="null" pageNumber="321">Zaehne</normalizedToken>
stumpf. 
<emphasis id="4A7798B2DD8E1197A5FB17FE47FB77B3" italics="true" pageId="null" pageNumber="321">
<normalizedToken id="05BCF2A44F2D61D019C8ADF23D9959D6" originalValue="Blüten" pageId="null" pageNumber="321">Blueten</normalizedToken>
in 10-20 
<normalizedToken id="178D3F4166DAF2029B7477364BD54C1C" originalValue="blütigen" pageId="null" pageNumber="321">bluetigen</normalizedToken>
<normalizedToken id="A5ECB9876232A39B80E8A2E181175BE7" originalValue="Knäueln" pageId="null" pageNumber="321">Knaeueln</normalizedToken>
, von 
<normalizedToken id="FC8E237247E724ABB387CC504A08BE5F" originalValue="Nebenblättern" pageId="null" pageNumber="321">Nebenblaettern</normalizedToken>
umschlossen, den 
<normalizedToken id="741762BF00F73D4F82B06CB0AE1ED14B" originalValue="Blättern" pageId="null" pageNumber="321">Blaettern</normalizedToken>
<normalizedToken id="DF6E279A7494D096B223ECAD21E44D64" originalValue="gegenüber" pageId="null" pageNumber="321">gegenueber</normalizedToken>
.
</emphasis>
<normalizedToken id="5A97453BC93FDADCAC571E827F346120" originalValue="Nebenblätter" pageId="null" pageNumber="321">Nebenblaetter</normalizedToken>
bis 0,5 cm lang, untereinander und mit dem Blattstiel zu einem Trichter verwachsen, mehrfach bis auf ⅔ geteilt oder nur 
<normalizedToken id="99BA86F302D043C2F80BEEFCDCA87B5C" originalValue="gezähnt" pageId="null" pageNumber="321">gezaehnt</normalizedToken>
; 
<normalizedToken id="4240F630B25E2E46EF9DAA280EEA6565" originalValue="Zähne" pageId="null" pageNumber="321">Zaehne</normalizedToken>
dreieckig, etwa so breit wie lang; Behaarung wie an den 
<normalizedToken id="6B36B87252458D9B3FF046AE97B4EC41" originalValue="Blättern" pageId="null" pageNumber="321">Blaettern</normalizedToken>
. 
<emphasis id="1D57E64035CA29C1E3E9C91AA79EC13D" italics="true" pageId="null" pageNumber="321">
Kelchbecher und 
<normalizedToken id="8E6EFE89A90BEB0028CFF69DA1136A1E" originalValue="Kelchblätter" pageId="null" pageNumber="321">Kelchblaetter</normalizedToken>
</emphasis>
(
<emphasis id="DEFCE412FB3E37D0C7193D003C07117B" italics="true" pageId="null" pageNumber="321">wenn Frucht reif</emphasis>
) 
<emphasis id="543DA4CDB2786CBF4275EBCC034FC81B" italics="true" pageId="null" pageNumber="321">
zusammen 2,3-2,7 mm lang, die 
<normalizedToken id="640EA5431572FA69930998EE659E5069" originalValue="Zähne" pageId="null" pageNumber="321">Zaehne</normalizedToken>
der 
<normalizedToken id="6B442C758D06819A9144D150FDA7DD48" originalValue="Nebenblätter" pageId="null" pageNumber="321">Nebenblaetter</normalizedToken>
meist 
<normalizedToken id="9277B6C01C665A1CBCC6043905D445E0" originalValue="überragend" pageId="null" pageNumber="321">ueberragend</normalizedToken>
, dicht mit 0,3-0,6 mm langen, borstigen Haaren besetzt und mit 8 deutlich vortretenden Nerven, am Grunde der 
<normalizedToken id="3857E8CD54404CD6BE1FEE5D258E1034" originalValue="Kelchblätter" pageId="null" pageNumber="321">Kelchblaetter</normalizedToken>
mit deutlicher, 
<normalizedToken id="33FB7583B245EE3F727FA7FAE71F5C94" originalValue="krugförmiger" pageId="null" pageNumber="321">krugfoermiger</normalizedToken>
<normalizedToken id="64E1CC8153D6F2436793DF742E842C3E" originalValue="Einschnürung" pageId="null" pageNumber="321">Einschnuerung</normalizedToken>
, 
<normalizedToken id="516EF0B23FD3071D6D23B82EFADCB5B5" originalValue="Kelchblätter" pageId="null" pageNumber="321">Kelchblaetter</normalizedToken>
oft etwas spreizend. 
<normalizedToken id="083768D350B440D049323BBA953C79B5" originalValue="Früchte" pageId="null" pageNumber="321">Fruechte</normalizedToken>
1,5-1,8 cm lang, braun. Staubblatt 1, vor einem Kelchblatt des Innenkelchs stehend
</emphasis>
(
<normalizedToken id="1364D629F57CE32BAAB6497C110693C4" originalValue="Außenkelchblätter" pageId="null" pageNumber="321">Aussenkelchblaetter</normalizedToken>
nur etwa 0,1 mm lang). - 
<normalizedToken id="10E35FAC953464A02E21776DAB2251B4" originalValue="Früchte" pageId="null" pageNumber="321">Fruechte</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="6D56CA5E5DE9D83EA659649D26B775B8" pageId="null" pageNumber="321">
<emphasis id="D2E0C99FAD6889A4E3D99485BF28A6C5" italics="true" pageId="null" pageNumber="321">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="183ACCB20F3479C6E308086EA88E7B64" italics="true" pageId="null" pageNumber="321">32:</emphasis>
Ohne Herkunftsangabe des Materials (Murbeck 1901, Strasburger 1904). 
<emphasis id="DFCA50C3006F97BAA21D726B60F03B46" italics="true" pageId="null" pageNumber="321">2n</emphasis>
= 
<emphasis id="A18B891F47AC0510DE060BA045DCEC1B" italics="true" pageId="null" pageNumber="321">48:</emphasis>
Material teilweise aus 
<normalizedToken id="8E090177B3E8714B9D29CDE8FB437E96" originalValue="Dänemark" pageId="null" pageNumber="321">Daenemark</normalizedToken>
(
<normalizedToken id="93CBB84F83299C89BE070F0E31A4F89E" originalValue="Böös" pageId="null" pageNumber="321">Boeoes</normalizedToken>
1924, Gentscheff und Gustafsson 1940, Gudjonsson 1941). 
<taxonomicName id="D3E21208866F5D73B709422442E74A03" class="Magnoliopsida" family="Rosaceae" genus="Aphanes" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="321" phylum="Tracheophyta" rank="species" species="arvensis">
<emphasis id="FD75EF1355FD1B025403F1B6EE7F1150" italics="true" pageId="null" pageNumber="321">A. arvensis</emphasis>
</taxonomicName>
ist apomiktisch (
<normalizedToken id="5B8B22408E3486AB8532DBD836B9F67C" originalValue="Böös" pageId="null" pageNumber="321">Boeoes</normalizedToken>
1917 
<normalizedToken id="DB667E441A6F880242C8775B023C69A4" originalValue="Böös" pageId="null" pageNumber="321">Boeoes</normalizedToken>
1920 
<normalizedToken id="F52AB3D208A8B6F31F440F9CAE2B8406" originalValue="Böös" pageId="null" pageNumber="321">Boeoes</normalizedToken>
1924, Walters 1949); nach eingehenden Untersuchungen von Hjelmqvist (1959) fakultativ apomiktisch.
</paragraph>
<paragraph id="2BB543FE3DD3760E623312C12E6C81DE" pageId="null" pageNumber="321">
<emphasis id="CBCADCACA836BA8A6C062458B30ACBFA" italics="true" pageId="null" pageNumber="321">Standort.</emphasis>
Kollin, selten montan. Sandige bis lehmige, kalkfreie bis kalkhaltige 
<normalizedToken id="AE078F4C3A2CD404B32C049B0AAFD008" originalValue="Böden" pageId="null" pageNumber="321">Boeden</normalizedToken>
. 
<normalizedToken id="024574310D18121CE19462E323A1F701" originalValue="Getreideäcker" pageId="null" pageNumber="321">Getreideaecker</normalizedToken>
in warmen Gegenden.
</paragraph>
<paragraph id="964F772C8971FA6D7948400B1DDFE137" pageId="null" pageNumber="321">
<emphasis id="9D1F3C52563CDD83EDC29BB85A27AFD9" italics="true" pageId="null" pageNumber="321">
Verbreitung. 
<normalizedToken id="B70445FE1F53FDDB4F2AC5DAD3118C0C" originalValue="Europäische" pageId="null" pageNumber="321">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="DE5CC78DF73F27FE7BB0D3DBD68BCBD6" originalValue="Nordwärts" pageId="null" pageNumber="321">Nordwaerts</normalizedToken>
bis zu den Shetlandinseln, 
<normalizedToken id="E7D1DA5436A78F484A916744E75F0D80" originalValue="Dänemark" pageId="null" pageNumber="321">Daenemark</normalizedToken>
und 
<normalizedToken id="78401CD34078FEF64B9829DA278A6235" originalValue="Südschweden" pageId="null" pageNumber="321">Suedschweden</normalizedToken>
, 
<normalizedToken id="ADB01E297F5CF37B851C21702D9128F2" originalValue="ostwärts" pageId="null" pageNumber="321">ostwaerts</normalizedToken>
bis Baltikum, Krim, Kaukasus und Kleinasien, 
<normalizedToken id="3C0D5A4A461CFC4511C943F790208B23" originalValue="südwärts" pageId="null" pageNumber="321">suedwaerts</normalizedToken>
bis Portugal, Nordspanien, Nordafrika, Italien, Sizilien, Balkanhalbinsel; in Nordamerika eingeschleppt (Neuschottland). Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: Niederschlagsarme Gegenden 
<normalizedToken id="6981F578FA06DA6D9EC38289C496A46F" originalValue="nördlich" pageId="null" pageNumber="321">noerdlich</normalizedToken>
der Alpen, zentral- und 
<normalizedToken id="29ADD7FE13742CFB91DCD872264D3F93" originalValue="südalpine" pageId="null" pageNumber="321">suedalpine</normalizedToken>
<normalizedToken id="920E453B0E011FB60F03C97D1DCEBA52" originalValue="Täler" pageId="null" pageNumber="321">Taeler</normalizedToken>
; nur im 
<normalizedToken id="05548B6B57237DAF2B1720FD682812D6" originalValue="Süden" pageId="null" pageNumber="321">Sueden</normalizedToken>
(z. B. Como, Bergamo) 
<normalizedToken id="BE86F3CAA71EBCFD59C0B161702D5913" originalValue="häufig" pageId="null" pageNumber="321">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
