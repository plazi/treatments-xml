<subSubSection id="787BA42CE31481AC2BC4E965C1D18011" pageId="null" pageNumber="512" type="vernacular_names">
<paragraph id="86FC0F167B4F31BBAC066CB1B8E63AE8" pageId="null" pageNumber="512">Nickender Zweizahn</paragraph>
</subSubSection>
</title>
<subSubSection id="87DE50B4FE58A819DA148EE1E22650F9" pageId="null" pageNumber="512" type="description">
<paragraph id="14EFBFE9EAED6D0448E94CCC6F8C46C3" pageId="null" pageNumber="512">
1 
<normalizedToken id="902066176B44E74B2A8F68508BF8E4D7" originalValue="jährig" pageId="null" pageNumber="512">jaehrig</normalizedToken>
, mit 
<normalizedToken id="65F3BDD5DC9DF09A2B44C13469C091A7" originalValue="dünner" pageId="null" pageNumber="512">duenner</normalizedToken>
Wurzel; 15-90 cm hoch. Stengel einfach oder verzweigt, 
<normalizedToken id="7AAD53E58748B1758DC90AAEF6794218" originalValue="hellgrün" pageId="null" pageNumber="512">hellgruen</normalizedToken>
, kahl oder zerstreut behaart, im untersten Teil oft mit Wurzeln. 
<emphasis id="C8F8DCD0E6D4A314102FF418952D502C" italics="true" pageId="null" pageNumber="512">
<normalizedToken id="A3DD7BC05F63699AFFA7698C51B85F50" originalValue="Blätter" pageId="null" pageNumber="512">Blaetter</normalizedToken>
mit 
<normalizedToken id="A13A2980225B5552691EA772F90F1621" originalValue="verschmälertem" pageId="null" pageNumber="512">verschmaelertem</normalizedToken>
Grunde sitzend
</emphasis>
, 
<normalizedToken id="ED2E64CB51F1BDE583B97A3E639ADDC2" originalValue="hellgrün" pageId="null" pageNumber="512">hellgruen</normalizedToken>
, sonst wie bei 
<taxonomicName id="AA129739284716BD496F29E207F5070B" class="Magnoliopsida" family="Asteraceae" genus="Bidens" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="512" phylum="Tracheophyta" rank="species" species="decipiens">
<emphasis id="0BF3E47F04129007B14E3EAE9DADAE28" italics="true" pageId="null" pageNumber="512">B. decipiens</emphasis>
</taxonomicName>
(Nr. 3). 
<emphasis id="11BB6BDEC20C5406263B83B230E07577" italics="true" pageId="null" pageNumber="512">
<normalizedToken id="196B5DDBB7A0F4A1A43268CE88CBB8BF" originalValue="Köpfe" pageId="null" pageNumber="512">Koepfe</normalizedToken>
zur Fruchtzeit nickend
</emphasis>
, zur 
<normalizedToken id="100EAAADF898696F5D4F2D012CAF2A03" originalValue="Blütezeit" pageId="null" pageNumber="512">Bluetezeit</normalizedToken>
im Durchmesser 1-5 cm, 
<emphasis id="A95C77FE4EB912A3E72D07B6A395E197" italics="true" pageId="null" pageNumber="512">meist mit 10</emphasis>
- 
<emphasis id="DE2BFEE26F8F9192B863DE0CC4E3CB33" italics="true" pageId="null" pageNumber="512">
15 mm langen und 5 mm breiten, gelben, 
<normalizedToken id="EC17ED2589E2EBBF2D2AEF6110BF0229" originalValue="zungenförmigen" pageId="null" pageNumber="512">zungenfoermigen</normalizedToken>
<normalizedToken id="341DE751398F59AD617B4AA010B61F07" originalValue="Randblüten" pageId="null" pageNumber="512">Randblueten</normalizedToken>
.
</emphasis>
<normalizedToken id="A0F3530F4DB956D4EE1CCC10B22EB131" originalValue="Äußere" pageId="null" pageNumber="512">Aeussere</normalizedToken>
<normalizedToken id="B16F23CD92940479FD86D9AD65851F56" originalValue="Hüllblätter" pageId="null" pageNumber="512">Huellblaetter</normalizedToken>
3-10, 10-35 mm lang und 2-10 mm breit, am Rande bewimpert; innere 
<normalizedToken id="DE3DFDBBFD3FB5623C8D124C8DF3F1C4" originalValue="Hüllblätter" pageId="null" pageNumber="512">Huellblaetter</normalizedToken>
wie bei 
<emphasis id="D5B5A58B2D65847AE22AAA00779019EC" italics="true" pageId="null" pageNumber="512">
<taxonomicName id="F39B5D9835AE2D0468EB3C969A0E22B8" class="Magnoliopsida" family="Asteraceae" genus="Bidens" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="512" phylum="Tracheophyta" rank="species" species="decipiens">B. decipiens</taxonomicName>
. 
<normalizedToken id="6E0A8352011CF6DC9BC9751B680B556E" originalValue="Früchte" pageId="null" pageNumber="512">Fruechte</normalizedToken>
flach, 4kantig, auf den Kanten mit vereinzelten 
<normalizedToken id="EBE57A0E78F16DEA478207B14C0EC747" originalValue="rückwärts" pageId="null" pageNumber="512">rueckwaerts</normalizedToken>
gerichteten Haaren
</emphasis>
, 
<normalizedToken id="9C81B2A2C3BFC7CF38B12139BD87F3FE" originalValue="±" pageId="null" pageNumber="512">+/-</normalizedToken>
<emphasis id="736D697093A34F592E2F9E94897E01F3" italics="true" pageId="null" pageNumber="512">glatt</emphasis>
, 4-7,5 mm lang und 2-3 mm dick. 
<emphasis id="DE8886B57EEEE9680E8F137283AB0CA7" italics="true" pageId="null" pageNumber="512">Borsten meist 4</emphasis>
, 2-4 mm lang. - 
<normalizedToken id="27C1E752CBA5CB2EFEBEE703D631DAB7" originalValue="Blüte" pageId="null" pageNumber="512">Bluete</normalizedToken>
: 
<normalizedToken id="B7453662EBA4C609EF0592FE0F43348D" originalValue="Später" pageId="null" pageNumber="512">Spaeter</normalizedToken>
Sommer und Herbst.
</paragraph>
<paragraph id="95DF6A42244F2163D3095FC6DD53A977" pageId="null" pageNumber="512">
<emphasis id="E2E1E9F08211D7480083CEAA23A5F0DC" italics="true" pageId="null" pageNumber="512">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="6BD759E3452C2CA31FC3418AB25B3DB3" italics="true" pageId="null" pageNumber="512">24:</emphasis>
Material unbekannter Herkunft (Levitzky aus Tischler 1950), aus Polen (Skalinska et al. 1959), aus Manitoba in Kanada (
<normalizedToken id="37CB11BB6A7E0A5FB048555E7664CA82" originalValue="Löve" pageId="null" pageNumber="512">Loeve</normalizedToken>
und 
<normalizedToken id="A2EF466FD04F30CF62F4D35F66CA9C81" originalValue="Löve" pageId="null" pageNumber="512">Loeve</normalizedToken>
1964), aus Holland (Gadella und Kliphuis 1966), aus den USA (Mangaly et al. in 
<normalizedToken id="9AEB06D2BC4C5B1A72A112D9CE5EFCA8" originalValue="Löve" pageId="null" pageNumber="512">Loeve</normalizedToken>
1967).
</paragraph>
<paragraph id="A72942A0353AAC98B33223E3D1BE6DC9" pageId="null" pageNumber="512">
<emphasis id="ABCF3665B80B4E52465421843B1AF6F2" italics="true" pageId="null" pageNumber="512">Standort.</emphasis>
Kollin, seltener montan. 
<normalizedToken id="C14FC0F14D5EF717C4899807A65E71C4" originalValue="Ähnlich" pageId="null" pageNumber="512">Aehnlich</normalizedToken>
wie 
<taxonomicName id="0DC15926E99934DF30430272217B2C7D" class="Magnoliopsida" family="Asteraceae" genus="Bidens" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="512" phylum="Tracheophyta" rank="species" species="decipiens">
<emphasis id="486195544F22B26338140081361697C6" italics="true" pageId="null" pageNumber="512">B. decipiens</emphasis>
</taxonomicName>
(Nr. 3). 
<emphasis id="72E377825F60601F24430C7D1AC6E8AC" italics="true" pageId="null" pageNumber="512">Bidention</emphasis>
Nordhagen 1940.
</paragraph>
<paragraph id="5F8BFC3BE4915C374B4F26DD7BA68F3D" pageId="null" pageNumber="512">
<emphasis id="CE2BBBCD63A2B0ED1027238CE2FB22AE" italics="true" pageId="null" pageNumber="512">Verbreitung. Eurasiatisch-nordamerikanische Pflanze:</emphasis>
In Eurasien 
<normalizedToken id="457AC815728B85923C1F03324C0AEC09" originalValue="nordwärts" pageId="null" pageNumber="512">nordwaerts</normalizedToken>
bis Schottland, 
<normalizedToken id="5161534064DD2A31FDFB08F7D38988CF" originalValue="Südskandinavien" pageId="null" pageNumber="512">Suedskandinavien</normalizedToken>
, Mittelfinnland; 
<normalizedToken id="7A36161EDD927A5FF6830B7DCA2F3704" originalValue="südwärts" pageId="null" pageNumber="512">suedwaerts</normalizedToken>
bis Nordspanien, 
<normalizedToken id="1C0ADEE8FA3C6FE1827BD61CA74E3C89" originalValue="Süditalien" pageId="null" pageNumber="512">Sueditalien</normalizedToken>
, Griechenland, 
<normalizedToken id="40692BA4592C6220E1064D9F7A8383D8" originalValue="Palästina" pageId="null" pageNumber="512">Palaestina</normalizedToken>
und Pakistan; in Nordamerika 
<normalizedToken id="C04C357931285B94ECB6720484EAF85C" originalValue="südwärts" pageId="null" pageNumber="512">suedwaerts</normalizedToken>
bis North Carolina und Kalifornien. Verbreitungskarte von 
<normalizedToken id="3F155CA60ED522A1DCDE44FE9353651B" originalValue="Hultén" pageId="null" pageNumber="512">Hulten</normalizedToken>
(1958). - Im Gebiet verbreitet und nicht 
<normalizedToken id="02C276F790DF0F92EBE913408C719865" originalValue="häufig" pageId="null" pageNumber="512">haeufig</normalizedToken>
(in den Alpen selten).
</paragraph>
</subSubSection>
