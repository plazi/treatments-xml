<subSubSection id="0B881F41FEAD15A2FF057773DFE304BA" pageId="null" pageNumber="519" type="description">
<paragraph id="33FBA8806D2C9F1BB3907B4614C55637" pageId="null" pageNumber="519">
Unterscheidet sich von 
<taxonomicName id="2A20067394E113143271E323431ABD34" class="Liliopsida" family="Juncaceae" genus="Luzula" kingdom="Plantae" order="Poales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="species" species="silvatica">
<emphasis id="9DD3FA7CBC01E620C8DA388922F6A47C" italics="true" pageId="null" pageNumber="519">
<authorityName id="51CF2881110AF200D106C0BA0CCFD322" pageId="null" pageNumber="519">L.</authorityName>
silvatica
</emphasis>
</taxonomicName>
(Nr. 9) durch folgende Merkmale: 
<emphasis id="E702336B1A245A1267D81B12E8F3E8CC" italics="true" pageId="null" pageNumber="519">
Pflanze kahl oder nur an der 
<normalizedToken id="2A4798240277640E0A2220003E72CB2A" originalValue="Scheidemündung" pageId="null" pageNumber="519">Scheidemuendung</normalizedToken>
mit einzelnen Haaren
</emphasis>
(bei den andern Arten der Gattung 
<normalizedToken id="B4C5A4ECCABA9ABB824C1AAA404EC353" originalValue="außer" pageId="null" pageNumber="519">ausser</normalizedToken>
<taxonomicName id="CA4605380F71D49F1E73F573F918522C" authority="Nr." authorityName="Nr." class="Liliopsida" family="Juncaceae" genus="Luzula" kingdom="Plantae" order="Poales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="species" species="glabrata">
<emphasis id="A4457C692C9944D25E3AF7F0DE47D321" italics="true" pageId="null" pageNumber="519">
<authorityName id="C392940A03B3906126E7430B25E8DCC5" pageId="null" pageNumber="519">L.</authorityName>
glabrata
</emphasis>
, Nr.
</taxonomicName>
4, sind Spreiten und 
<normalizedToken id="75B334758E71FEFE138B4E513284EF2B" originalValue="Scheidemündungen" pageId="null" pageNumber="519">Scheidemuendungen</normalizedToken>
<normalizedToken id="767758FEB57C41EBA64447AF4A54680D" originalValue="±" pageId="null" pageNumber="519">+/-</normalizedToken>
zerstreut und abstehend behaart). 
<normalizedToken id="795B53089806F84CF6E15D2A9816E50E" originalValue="Blütenstand" pageId="null" pageNumber="519">Bluetenstand</normalizedToken>
<normalizedToken id="71AF59A68E330C5EFA78A641252C34A7" originalValue="schmäler" pageId="null" pageNumber="519">schmaeler</normalizedToken>
, 
<emphasis id="A3A775A6B57B4135A6A6990E15D1B69E" italics="true" pageId="null" pageNumber="519">
meist nickend. 
<normalizedToken id="E3C03434C39CCD0702A1B559F1839508" originalValue="Perigonblätter" pageId="null" pageNumber="519">Perigonblaetter</normalizedToken>
2-2,5 mm lang
</emphasis>
, alle gleich lang, mit 
<normalizedToken id="ED1CEC6331B6A821AF45562B2AFF8F34" originalValue="häutigem" pageId="null" pageNumber="519">haeutigem</normalizedToken>
Rand und aufgesetzter Spitze. 
<emphasis id="62D2CE548EA84D088EC1689A6C64280C" italics="true" pageId="null" pageNumber="519">Samen ca. 1 mm lang.</emphasis>
- 
<normalizedToken id="E34364CDECD50272FB9E1CD7655EE9BF" originalValue="Blüte" pageId="null" pageNumber="519">Bluete</normalizedToken>
: 
<normalizedToken id="8FF5AC6AECD26C036E2E84B6FA6518C7" originalValue="Frühling" pageId="null" pageNumber="519">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="8F8E65C1DBB80B1186B07941BD7DA09A" pageId="null" pageNumber="519">
<emphasis id="5ADFD230B9138CC931AF0F0A8A033C9E" italics="true" pageId="null" pageNumber="519">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="192C9D16BDA03F80036D5745F662E029" pageId="null" pageNumber="519">
<emphasis id="EB154DBE2969CD0EF65329EA0FD728A7" italics="true" pageId="null" pageNumber="519">Standort.</emphasis>
Montan. Feuchte, lang mit Schnee bedeckte, kalkarme 
<normalizedToken id="C6D0403BB4DE646F6FCC3B627D8A3536" originalValue="Böden" pageId="null" pageNumber="519">Boeden</normalizedToken>
in Felsrinnen. Hochstaudenfluren, Quellfluren, speziell in der Assoziation des 
<taxonomicName id="7395CDF4FDF7D120CDF7CE84B9A39745" authority="Issler 1932" authorityName="Issler" authorityYear="1932" class="Liliopsida" family="Juncaceae" genus="Luzuletum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="species" species="desvauxii">
<emphasis id="457300ADAF9A9AD7C80EE9D9883B3013" italics="true" pageId="null" pageNumber="519">Luzuletum Desvauxii</emphasis>
Issler 1932
</taxonomicName>
.
</paragraph>
<paragraph id="75EAE541EEB02CA49A861577352BB710" pageId="null" pageNumber="519">
<emphasis id="5901555ACDB12E934F2E4CEB6B2F5583" italics="true" pageId="null" pageNumber="519">Verbreitung</emphasis>
(
<normalizedToken id="39B8D9DD249EB15470E3FEFBA7E53BFB" originalValue="ungenügend" pageId="null" pageNumber="519">ungenuegend</normalizedToken>
bekannt): 
<emphasis id="5C0219E1309C8789218FAB3C69885662" italics="true" pageId="null" pageNumber="519">
Mittel- und 
<normalizedToken id="7DBA2456CBB62CC4D894EBC134814BC2" originalValue="südeuropäische" pageId="null" pageNumber="519">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(westlich): 
<normalizedToken id="332EC4BBE274E64A06DB7F617826C713" originalValue="Pyrenäen" pageId="null" pageNumber="519">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="A737FD8D0A495E287D1837642B429E9B" originalValue="Corbière" pageId="null" pageNumber="519">Corbiere</normalizedToken>
, Cevennen, 
<normalizedToken id="9A00B545C10CD53BB8128184B244CFB8" originalValue="französisches" pageId="null" pageNumber="519">franzoesisches</normalizedToken>
Zentralplateau, Vogesen, 
<normalizedToken id="F4EB9D14EAFF2D2225F0A58F42266D2A" originalValue="südlicher" pageId="null" pageNumber="519">suedlicher</normalizedToken>
Schwarzwald (Belchen), Westalpen (nach Oberdorfer 1962, jedoch keine 
<normalizedToken id="ED365AB19A1577490ED6B4387C718E22" originalValue="näheren" pageId="null" pageNumber="519">naeheren</normalizedToken>
Angaben). - Im Gebiet: Vogesen, Schwarzwald; Angaben aus den Alpen (Grimsel, Rhonegletscher) 
<normalizedToken id="7A5D08EB06706A8D0A6592BA71EC04B8" originalValue="fragwürdig" pageId="null" pageNumber="519">fragwuerdig</normalizedToken>
.
</paragraph>
<paragraph id="D84334D5E5601D12D2DD856F92DD228D" pageId="null" pageNumber="519">
<emphasis id="E8B397ABF946A456D5F6198F54E71AB2" italics="true" pageId="null" pageNumber="519">
Bemerkungen. 
<taxonomicName id="8ABCEFE6CA2DC9A11AA954907FF3A023" class="Liliopsida" family="Juncaceae" genus="Luzuletum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="species" species="desvauxii">
<authorityName id="69F48607F3FCD54FF2889DFB24A63869" pageId="null" pageNumber="519">L.</authorityName>
Desvauxii
</taxonomicName>
</emphasis>
wird oft nicht oder nur als Rasse von 
<taxonomicName id="5AB31C115C928FA47462EEB038525A39" class="Liliopsida" family="Juncaceae" genus="Luzula" kingdom="Plantae" order="Poales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="species" species="glabrata">
<emphasis id="13BF40C3F12EFA10ED3B6ED5B371D816" italics="true" pageId="null" pageNumber="519">
<authorityName id="F90A41FD3FF6F02D4BF0D1F9D90C4758" pageId="null" pageNumber="519">L.</authorityName>
glabrata
</emphasis>
</taxonomicName>
(Nr. 4) unterschieden. 
<taxonomicName id="B67543FB5F7DD3D00AFE6F32FE9C0C21" class="Liliopsida" family="Juncaceae" genus="Luzuletum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="species" species="desvauxii">
<emphasis id="9CB755291B9CA3EF43474927C54A730A" italics="true" pageId="null" pageNumber="519">
<authorityName id="0DDBB0DF4C03624C61D3F85D36A8C9B1" pageId="null" pageNumber="519">L.</authorityName>
Desvauxii
</emphasis>
</taxonomicName>
unterscheidet sich durch 
<emphasis id="C9FEC5388E48780871E1B036A032B762" italics="true" pageId="null" pageNumber="519">
<normalizedToken id="982DFACB5A66DDAF0BC665705A3F2F7B" originalValue="mehrblütige" pageId="null" pageNumber="519">mehrbluetige</normalizedToken>
<normalizedToken id="9A9EAF178DF22748C0747328E0303756" originalValue="Blütenköpfe" pageId="null" pageNumber="519">Bluetenkoepfe</normalizedToken>
, kleinere 
<normalizedToken id="98A24CC11770397E489DF991C10061D5" originalValue="Blüten" pageId="null" pageNumber="519">Blueten</normalizedToken>
, verschiedenen Standort und wahrscheinlich auch getrennte geographische Verbreitung
</emphasis>
von 
<emphasis id="ABF4EF12609258FED5D697FCF88A52D1" italics="true" pageId="null" pageNumber="519">
<taxonomicName id="0A6A884C73497985A33111D6331FD511" class="Liliopsida" family="Juncaceae" genus="Luzula" kingdom="Plantae" order="Poales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="species" species="glabrata">
<authorityName id="180D14C29AFC2E4C4A1AE4BB564C0D8E" pageId="null" pageNumber="519">L.</authorityName>
glabrata
</taxonomicName>
. 
<taxonomicName id="891FFEC8703B61CB6F8BD3C86ADB1F18" class="Liliopsida" family="Juncaceae" genus="Luzuletum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="species" species="desvauxii">
<authorityName id="1EB179E9D2D306FB14DAF2B7AD8421B8" pageId="null" pageNumber="519">L.</authorityName>
Desvauxii
</taxonomicName>
</emphasis>
und 
<taxonomicName id="73A5460353104A8D36A6C9911CC5A94C" class="Liliopsida" family="Juncaceae" genus="Luzula" kingdom="Plantae" order="Poales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="species" species="glabrata">
<emphasis id="6361FD26F08F66D46BBEBFE153DB374C" italics="true" pageId="null" pageNumber="519">
<authorityName id="CE81C954E1FF2136E4F01CC6E3E0DBAA" pageId="null" pageNumber="519">L.</authorityName>
glabrata
</emphasis>
</taxonomicName>
sollten experimentell miteinander verglichen und ihre geographische Verbreitung 
<normalizedToken id="E548219B4E95247F862F8F4CA575F93E" originalValue="abgeklärt" pageId="null" pageNumber="519">abgeklaert</normalizedToken>
werden (vgl. Kunz 1960a).
</paragraph>
</subSubSection>
