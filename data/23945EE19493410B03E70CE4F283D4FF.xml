<subSubSection id="7A13E4D6BAB77D2D46E8D5358EF84724" pageId="null" pageNumber="779" type="description">
<paragraph id="02C4823E17EC055CB3276F42C77B3EEB" pageId="null" pageNumber="779">
Unterscheidet sich von 
<taxonomicName id="5E8166F8D084FBA0420B49523EAE21F1" class="Magnoliopsida" family="Caryophyllaceae" genus="Silene" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="779" phylum="Tracheophyta" rank="species" species="dioeca">
<emphasis id="73E64E27F8386936C97DFF845F6BF6FC" italics="true" pageId="null" pageNumber="779">S. dioeca</emphasis>
</taxonomicName>
(Nr. 6) durch folgende Merkmale: Haare nur bis 1 mm lang; 
<emphasis id="A5552670E8A52DF89E820DA70C3F660B" italics="true" pageId="null" pageNumber="779">
<normalizedToken id="0981F8DE952DC2D27DAC835F986F39F8" originalValue="Blätter" pageId="null" pageNumber="779">Blaetter</normalizedToken>
3-8
</emphasis>
(
<emphasis id="EF57EFD9DA99E7CBBBAEDC092198E807" italics="true" pageId="null" pageNumber="779">im Mittel 4</emphasis>
) 
<emphasis id="A480770FCE9F267ABDC35F5817DF9F4C" italics="true" pageId="null" pageNumber="779">mal so lang wie breit;</emphasis>
<normalizedToken id="70DAE77DA0D8B5B629034DF5E3BB09DD" originalValue="Blüten" pageId="null" pageNumber="779">Blueten</normalizedToken>
nachmittags und in der Nacht 
<normalizedToken id="DC98B4E893D637CA4EED83A4A1B15A3D" originalValue="geöffnet" pageId="null" pageNumber="779">geoeffnet</normalizedToken>
, etwas riechend; 
<emphasis id="A1F59C7AF24F00921CA826ADDDA8777F" italics="true" pageId="null" pageNumber="779">
Kelch 13-20 mm lang, 
<normalizedToken id="1E9DE654A9AD0D3E39D0728310A61B00" originalValue="grün" pageId="null" pageNumber="779">gruen</normalizedToken>
; 
<normalizedToken id="B437664760609BA312D0AA03650E7ABB" originalValue="Kelchzähne" pageId="null" pageNumber="779">Kelchzaehne</normalizedToken>
etwa
</emphasis>
⅓ 
<emphasis id="4AC98A0973C35B4E4218C3AFEEC8AB9C" italics="true" pageId="null" pageNumber="779">so lang wie der verwachsene Kelchteil</emphasis>
(
<emphasis id="12C56D96468286D32ABC70C115D33F54" italics="true" pageId="null" pageNumber="779">4-7 mm</emphasis>
)
<emphasis id="B800A08AADBFD0009E3AB6006B3DC18A" italics="true" pageId="null" pageNumber="779">
. 
<normalizedToken id="71F401AB1870EDEC167E6BB68174A06F" originalValue="Kronblätter" pageId="null" pageNumber="779">Kronblaetter</normalizedToken>
25-35 mm lang, 
<normalizedToken id="C0F8D80041ADC80D6469A026AA6FBD1C" originalValue="weiß" pageId="null" pageNumber="779">weiss</normalizedToken>
;
</emphasis>
Kapsel 12-16 mm lang; 
<normalizedToken id="33541B07DBEDADD6B2620669AF305833" originalValue="Kapselzähne" pageId="null" pageNumber="779">Kapselzaehne</normalizedToken>
aufrecht oder etwas 
<normalizedToken id="4065AE04A868C67C61C25192AD844FA9" originalValue="auswärts" pageId="null" pageNumber="779">auswaerts</normalizedToken>
gebogen.
</paragraph>
<paragraph id="232F2C7BDB1AE8DF99199A724A15AABD" pageId="null" pageNumber="779">
<emphasis id="A110C83F812057CB50AAB4794E30417A" italics="true" pageId="null" pageNumber="779">
<pageBreakToken id="D47DA3AADC6672FD498EA46E99D2E54B" pageId="null" pageNumber="779">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="66E704FA4CEC499BA36142060BD6D07D" italics="true" pageId="null" pageNumber="779">24</emphasis>
(♀ und ♂ Pflanzen): Material von vielen Orten Europas (Breslavetz 1929, Rohweder 1939, D. 
<normalizedToken id="204AB9DC6D091F1EB3716BA1A3664AB5" originalValue="Löve" pageId="null" pageNumber="779">Loeve</normalizedToken>
1944, 
<normalizedToken id="55F7048D7B775FD657C619A3A6FD60BB" originalValue="Löve" pageId="null" pageNumber="779">Loeve</normalizedToken>
und 
<normalizedToken id="8D9376450B1B36763F7C0D380EA24621" originalValue="Löve" pageId="null" pageNumber="779">Loeve</normalizedToken>
1956b, Blackburn und Morton 1957, Sorsa 1962, Skalinska et al. 1966; weitere Autoren bei 
<normalizedToken id="9C6B2CAE35BCF0698953CC76C8217796" originalValue="Löve" pageId="null" pageNumber="779">Loeve</normalizedToken>
und 
<normalizedToken id="A69402A93C39A2D2A8621C30AD7CFD05" originalValue="Löve" pageId="null" pageNumber="779">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="A46F66AB93D80E74B64D2DEF2ECA3AC1" pageId="null" pageNumber="779">
<emphasis id="808CB364DDC694F0397B46DBC23A9961" italics="true" pageId="null" pageNumber="779">Standort.</emphasis>
Kollin und montan, selten subalpin. Trockene, lockere, 
<normalizedToken id="730E19862AF02E06ED21BA8C2605EC09" originalValue="nährstoffreiche" pageId="null" pageNumber="779">naehrstoffreiche</normalizedToken>
<normalizedToken id="FAF463D83BB4AFDA481EB314616DE54A" originalValue="Böden" pageId="null" pageNumber="779">Boeden</normalizedToken>
in 
<normalizedToken id="B90520F12029695A570065B53B271AD8" originalValue="wärmeren" pageId="null" pageNumber="779">waermeren</normalizedToken>
Lagen. 
<normalizedToken id="7B2B083EBAED0248FCB3020F8CC110AF" originalValue="Wegränder" pageId="null" pageNumber="779">Wegraender</normalizedToken>
, 
<normalizedToken id="FA88C2352DBCD096D4A6DFC373E98480" originalValue="Äcker" pageId="null" pageNumber="779">Aecker</normalizedToken>
, Hecken, 
<normalizedToken id="299395DB24485700C0762CCDE3A4BA66" originalValue="Schuttplätze" pageId="null" pageNumber="779">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="72F9DFF5470F6D18A25BA52280D9DC4B" pageId="null" pageNumber="779">
<emphasis id="F527A297DD18A540E4F2AA3A06BF957C" italics="true" pageId="null" pageNumber="779">Verbreitung. Eurasiatische Pflanze:</emphasis>
<taxonomicName id="999BEDDCC8F1E135382267A6A918F44B" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="779" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
(ohne Island und ohne arktische Gebiete); Westasien (
<normalizedToken id="E2815CFE9A47AA285A298FE50B3F43CB" originalValue="ostwärts" pageId="null" pageNumber="779">ostwaerts</normalizedToken>
bis zum Baikalsee); Nordwestafrika (?); in Amerika eingeschleppt. - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="6C2B652962E3CD90DB21A2F46C76FFF5" originalValue="häufig" pageId="null" pageNumber="779">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
