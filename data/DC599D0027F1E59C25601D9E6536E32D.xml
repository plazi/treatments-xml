<subSubSection id="2D2AE30A32391FC23030C5C7BFACF160" pageId="null" pageNumber="755" type="description">
<paragraph id="83ED1ACECDD49543B09159B2E8D8919E" pageId="null" pageNumber="755">
<emphasis id="7CF96B25DA34EBBF04C90B93D30A3D4C" italics="true" pageId="null" pageNumber="755">
1 
<normalizedToken id="2CA8CF65C8A031224107333998098140" originalValue="jährig" pageId="null" pageNumber="755">jaehrig</normalizedToken>
</emphasis>
, mit 
<normalizedToken id="81BB990D9A249AAC147156667A5708FE" originalValue="dünner" pageId="null" pageNumber="755">duenner</normalizedToken>
Pfahlwurzel; 10-40 cm hoch. Stengel aufrecht, oft verzweigt, mit aufrechten 
<normalizedToken id="FCEE722E1DEBCDF96BAA30D08925EA2F" originalValue="Ästen" pageId="null" pageNumber="755">Aesten</normalizedToken>
, mit einzelnen, ca. 0,5 mm langen Haaren. 
<normalizedToken id="C4388494171BF6B4F5443DAA4356A52C" originalValue="Blätter" pageId="null" pageNumber="755">Blaetter</normalizedToken>
ungestielt, lanzettlich, bis 1,5 cm lang und 3-8mal so lang wie breit, kahl. 
<normalizedToken id="160FE2E33DAAEFE429224FFBAAAE5EB6" originalValue="Blüten" pageId="null" pageNumber="755">Blueten</normalizedToken>
ungestielt. 
<normalizedToken id="846712F142E2F405CB2C6D528190872C" originalValue="Kelchröhre" pageId="null" pageNumber="755">Kelchroehre</normalizedToken>
ca. 2 mm lang, mit 0,3-0,5 mm langen anliegenden Haaren. Kelchzipfel aufrecht, gelblich. Frucht ca. 3 mm lang, 
<emphasis id="EA4F63179F90BB5BE0BF4C849ED09BCE" italics="true" pageId="null" pageNumber="755">
vom Kelch 
<normalizedToken id="C2578647F723AC39B7C590825C8EEEE0" originalValue="umhüllt" pageId="null" pageNumber="755">umhuellt</normalizedToken>
und deshalb scheinbar 
<normalizedToken id="5F29CD134820C52BED5E159128216BC8" originalValue="geschnäbeit" pageId="null" pageNumber="755">geschnaebeit</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="8B07340BF7B3353359806D4F226B1C64" originalValue="Blüte" pageId="null" pageNumber="755">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="3E026A09035B2A876402F4619141CD43" pageId="null" pageNumber="755">
<emphasis id="6E34E35248DD3C908EF1C2B49BB08E7F" italics="true" pageId="null" pageNumber="755">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="784B08B4E202FA0CF12015A86C41F759" pageId="null" pageNumber="755">
<emphasis id="421B93FA06D69091F358B99B5D9302DB" italics="true" pageId="null" pageNumber="755">Standort.</emphasis>
Kollin, selten montan. Trockene, 
<normalizedToken id="04233559C66636D7E19E669246E7141E" originalValue="nährstoffreiche" pageId="null" pageNumber="755">naehrstoffreiche</normalizedToken>
, meist kalkhaltige, tonige 
<normalizedToken id="9A2BAFC22B33FF8DC95DFA15577B30FF" originalValue="Böden" pageId="null" pageNumber="755">Boeden</normalizedToken>
in 
<normalizedToken id="5663B42B0DD4FE93AC8AF66730C2CA58" originalValue="wärmeren" pageId="null" pageNumber="755">waermeren</normalizedToken>
Lagen. Getreidefelder, Brachland, Trocken wiesen.
</paragraph>
<paragraph id="95B3E640ED8236E748F9B5B218E5790D" pageId="null" pageNumber="755">
<emphasis id="BF219F15A38D9B95927F4DD83013EF83" italics="true" pageId="null" pageNumber="755">Verbreitung. Mediterran-westasiatische Pflanze:</emphasis>
<normalizedToken id="EB7B34BCABE98A87859D37FA8C90FF49" originalValue="Nordwärts" pageId="null" pageNumber="755">Nordwaerts</normalizedToken>
vereinzelt bis Mosel, Main und Mittelpolen, 
<normalizedToken id="2DA9C7E60A588BF527C56CEA0287FB14" originalValue="ostwärts" pageId="null" pageNumber="755">ostwaerts</normalizedToken>
bis zum Altai und Nordindien. - Im Gebiet: Gegend von Belfort, Sundgau, Oberrheinische Tiefebene, Schaffhausen, Hegau, Savoyen, Genf, Wallis, Aostatal, Veltlin, Gebiet von Bergamo; 
<normalizedToken id="5759DAED88E3CDD86185CE11260AED57" originalValue="überall" pageId="null" pageNumber="755">ueberall</normalizedToken>
selten geworden; sonst sehr selten und 
<normalizedToken id="20E63FE429A4C6ACDE1D608BC6CE1402" originalValue="unbeständig" pageId="null" pageNumber="755">unbestaendig</normalizedToken>
.
</paragraph>
</subSubSection>
