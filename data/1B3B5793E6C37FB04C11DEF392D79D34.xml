<subSubSection id="404F933196436474F66BCEFD3B276E24" pageId="null" pageNumber="759" type="description">
<paragraph id="067AD8FC5710002620E3EDCBAA8E7E6C" pageId="null" pageNumber="759">
Unterscheidet sich von der Gattung 
<taxonomicName id="18475DBF07D6F4A2AFEC10D4A29E5161" class="Magnoliopsida" family="Amaranthaceae" genus="Salsola" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="759" phylum="Tracheophyta" rank="genus">
<emphasis id="DE95F9F1AE5824867FEA2C70A4AAC109" italics="true" pageId="null" pageNumber="759">Salsola</emphasis>
</taxonomicName>
(S. 758) durch folgende Merkmale: 
<emphasis id="3E0F2449E41893B852D9DCBD0EC62B89" italics="true" pageId="null" pageNumber="759">
<normalizedToken id="988904C538A37A81AB97DAA6AC37E76A" originalValue="Blätter" pageId="null" pageNumber="759">Blaetter</normalizedToken>
nicht mit stacheliger Spitze; keine 
<normalizedToken id="BDA07A6FCB17CCEE43E61CBA5BE56ADB" originalValue="Vorblätter" pageId="null" pageNumber="759">Vorblaetter</normalizedToken>
vorhanden;
</emphasis>
neben den meist zwitterigen 
<normalizedToken id="2D6B6D99D0CF4DF184C5B59AA874027D" originalValue="Blüten" pageId="null" pageNumber="759">Blueten</normalizedToken>
durch 
<normalizedToken id="C3869A61C47601F80FD937FF46D13498" originalValue="Rückbildung" pageId="null" pageNumber="759">Rueckbildung</normalizedToken>
auch 1geschlechtige 
<normalizedToken id="BBC3D9A565FCD8DDB7FBA698715DF5BD" originalValue="Blüten" pageId="null" pageNumber="759">Blueten</normalizedToken>
vorhanden.
</paragraph>
<paragraph id="053FD0CA8928B3703E2BBC3EFEFFA431" pageId="null" pageNumber="759">
<pageBreakToken id="03BFDAF3EDB57D06C781A74BE6C357A9" pageId="null" pageNumber="759">Die</pageBreakToken>
Gattung 
<taxonomicName id="3280F095014CEDBC47D5290E99E17338" class="Magnoliopsida" family="Amaranthaceae" genus="Kochia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="759" phylum="Tracheophyta" rank="genus">
<emphasis id="96DC4C7A78B4AE6D0C32689A3F368F71" italics="true" pageId="null" pageNumber="759">Kochia</emphasis>
</taxonomicName>
<normalizedToken id="947E8FA32315037B275DAE8164A2C318" originalValue="umfaßt" pageId="null" pageNumber="759">umfasst</normalizedToken>
etwa 
<emphasis id="7FFE2FA2372FD7EAC1F7AD292BCB08F4" italics="true" pageId="null" pageNumber="759">80 Arten;</emphasis>
davon kommen 
<emphasis id="401F0D589FC7FE7C370AEFD251310190" italics="true" pageId="null" pageNumber="759">40 Arten in Australien vor; 9 Arten in Eurasien;</emphasis>
weitere Arten in Nord- und 
<normalizedToken id="69052C2779C6C2BA74FE887DADAA97FD" originalValue="Südafrika" pageId="null" pageNumber="759">Suedafrika</normalizedToken>
und im westlichen Nordamerika. Standorte wie 
<emphasis id="8025A4150BC7702B52551B42FB9920EF" italics="true" pageId="null" pageNumber="759">
<taxonomicName id="82C81363FBFE4A1664A1F3CDBA7E63BE" class="Magnoliopsida" family="Amaranthaceae" genus="Salsola" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="759" phylum="Tracheophyta" rank="genus">Salsola</taxonomicName>
.
</emphasis>
</paragraph>
