</title>
<subSubSection id="B89DFC2923B843108AD40ED0201C1279" pageId="null" pageNumber="206" type="description">
<paragraph id="0279089A7AB7EC5878E0BB71932B7CE2" pageId="null" pageNumber="206">
<emphasis id="AD8463C0498AF5AFF837EC5946CECC9D" italics="true" pageId="null" pageNumber="206">
<normalizedToken id="C250FAA1DF716302AB15D6F3DDC2970D" originalValue="Blätter" pageId="null" pageNumber="206">Blaetter</normalizedToken>
bis 1,5 mm breit, mit glattem Rand
</emphasis>
, 
<normalizedToken id="3DC35ABCE2D17D6DB384C9A91EE5E497" originalValue="gegenständig" pageId="null" pageNumber="206">gegenstaendig</normalizedToken>
oder 
<normalizedToken id="03E25FF3DA09B9659ADCD322AC3F5EED" originalValue="quirlständig" pageId="null" pageNumber="206">quirlstaendig</normalizedToken>
, mit 
<normalizedToken id="B73F8F69B7F6BD1B76050F93AA2E6B5D" originalValue="großem" pageId="null" pageNumber="206">grossem</normalizedToken>
<normalizedToken id="5B30DB2D77586AD7255FF42A9B855E07" originalValue="Blatthäutchen" pageId="null" pageNumber="206">Blatthaeutchen</normalizedToken>
und 2 kleinen Blattschuppen in der Blattachsel. 
<emphasis id="823A64CE3D9DD72CDE392ECFB8CCFB07" italics="true" pageId="null" pageNumber="206">1</emphasis>
♂ 
<emphasis id="CD56B74952C45F46234476BAF1E94AE0" italics="true" pageId="null" pageNumber="206">und 1-6</emphasis>
♀ 
<emphasis id="AC06DAE57951A7BDF06CF8B49AD05FC1" italics="true" pageId="null" pageNumber="206">
<normalizedToken id="A05497E5D697289F25FDDFE77D1E0972" originalValue="Blüten" pageId="null" pageNumber="206">Blueten</normalizedToken>
in einer Blattachsel, gemeinsam von 
<normalizedToken id="C52F3737A8C30FA32E05DA99A9A79DFD" originalValue="häutiger" pageId="null" pageNumber="206">haeutiger</normalizedToken>
<taxonomicName id="F8D212747D6BADBB6E506042EE67ED61" class="Bivalvia" family="Iridinidae" genus="Spatha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Unionida" pageId="null" pageNumber="206" phylum="Mollusca" rank="genus">Spatha</taxonomicName>
umgeben; keine 
<normalizedToken id="D8124EE1789D59735883ECD0465A2EEB" originalValue="Perigonblätter" pageId="null" pageNumber="206">Perigonblaetter</normalizedToken>
vorhanden.
</emphasis>
♂ 
<emphasis id="AAD3314F81A1ABD0D1125B08F22436F6" italics="true" pageId="null" pageNumber="206">
<normalizedToken id="7CF092F5D7EC419E3536065529A08C38" originalValue="Blüte" pageId="null" pageNumber="206">Bluete</normalizedToken>
meist mit 1
</emphasis>
, selten 
<emphasis id="E26221AFA7FBB76A7F12627F7FAD03DE" italics="true" pageId="null" pageNumber="206">
2 
<normalizedToken id="506F4044B5196A85E6A3461022CF640F" originalValue="Staubblättern" pageId="null" pageNumber="206">Staubblaettern</normalizedToken>
;
</emphasis>
Pollen kugelig. ♀ 
<emphasis id="892A8D88123CA5E1E53E3A6B1E8B2CAD" italics="true" pageId="null" pageNumber="206">
<normalizedToken id="5191538F317D4594B0A3C2C9A28E0E5B" originalValue="Blüte" pageId="null" pageNumber="206">Bluete</normalizedToken>
mit 1 Fruchtblatt
</emphasis>
, mit kurzem Griffel und 
<emphasis id="8E0C624446E4885819F9B1B51DF8C823" italics="true" pageId="null" pageNumber="206">
schildoder 
<normalizedToken id="EC232310187FBA613C3152B6AE6E1C4F" originalValue="spatelförmiger" pageId="null" pageNumber="206">spatelfoermiger</normalizedToken>
Narbe.
</emphasis>
<normalizedToken id="73A30569DAFEA13F8CA5642DFBC14D38" originalValue="Früchte" pageId="null" pageNumber="206">Fruechte</normalizedToken>
sitzend oder kurz gestielt, 
<emphasis id="B497BE77A75214D1AFF19BB31A4D1B37" italics="true" pageId="null" pageNumber="206">
flach, 
<normalizedToken id="CABC38236B02FD58EC61B56E776D8CEA" originalValue="sichelförmig" pageId="null" pageNumber="206">sichelfoermig</normalizedToken>
, warzig oder glatt
</emphasis>
, 2klappig, an den Verwachsungsstellen gelegentlich 
<emphasis id="1A5C7640F23C03423267DD1D248DE384" italics="true" pageId="null" pageNumber="206">
<normalizedToken id="7DC32AA9CFC999407AFC95EF0EC7FCD0" originalValue="geflügelt" pageId="null" pageNumber="206">gefluegelt</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="95A22B6F7478ADB1AAE2244ED2200D23" pageId="null" pageNumber="206">
Die Gattung 
<taxonomicName id="1227808EBC993C7D411BE333E0B00B6E" class="Liliopsida" family="Potamogetonaceae" genus="Zannichellia" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="206" phylum="Tracheophyta" rank="genus">
<emphasis id="159848B197A92EEDD61EDCBFA76C6216" italics="true" pageId="null" pageNumber="206">Zannichellia</emphasis>
</taxonomicName>
<normalizedToken id="44AF46F933417311D8927418334C7755" originalValue="umfaßt" pageId="null" pageNumber="206">umfasst</normalizedToken>
<emphasis id="B41885E43FE4F8CA0399ECD09B00684D" italics="true" pageId="null" pageNumber="206">2 Arten</emphasis>
, die noch wenig untersucht sind. 
<taxonomicName id="A5BF1DB57B4C4E8CC1F522561A80E1FC" class="Polypodiopsida" family="Thelypteridaceae" genus="Thelypteris" kingdom="Plantae" order="Polypodiales" pageId="null" pageNumber="206" phylum="Tracheophyta" rank="species" species="palustris">
<emphasis id="F3CED6FDA948EC5A1099D0325F185BCB" italics="true" pageId="null" pageNumber="206">Z. palustris</emphasis>
</taxonomicName>
ist 
<emphasis id="1A9A14308948D7AA7A5A6215FBC51766" italics="true" pageId="null" pageNumber="206">
fast 
<normalizedToken id="0DCD275724312F2575EA60F25F003209" originalValue="über" pageId="null" pageNumber="206">ueber</normalizedToken>
die ganze Erde verbreitet
</emphasis>
und ist wohl in mehrere Arten aufzuteilen; 1 weitere Art in 
<normalizedToken id="6893FB59031B596EC64A38B0EC4FC386" originalValue="Südafrika" pageId="null" pageNumber="206">Suedafrika</normalizedToken>
.
</paragraph>
</subSubSection>
