<quantity id="2E379B383F19FF8EFE65FDE3FE30FD61" box="[388,464,613,640]" metricMagnitude="-2" metricUnit="m" metricValue="6.6" pageId="44" pageNumber="45" unit="cm" value="6.6">6.6 cm</quantity>
