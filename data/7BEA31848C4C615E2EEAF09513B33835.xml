<subSubSection id="D17C923D4D8404D1A3183DC34CAE1E14" pageId="null" pageNumber="41" type="description">
<paragraph id="7F73E8FAC83EC5390057842A6473F814" pageId="null" pageNumber="41">
Ausdauernde 
<normalizedToken id="DBCCCA9F43F43917F681E85FC39B9A23" originalValue="Kräuter" pageId="null" pageNumber="41">Kraeuter</normalizedToken>
. 
<emphasis id="A1DD51F8E2659E57C4C286E5C8280340" italics="true" pageId="null" pageNumber="41">
<normalizedToken id="1B9BD03195D4C703BE17D32BCD8FCC15" originalValue="Blätter" pageId="null" pageNumber="41">Blaetter</normalizedToken>
nicht geteilt, 
<normalizedToken id="02C4F63CD57428B1F134F1961660E013" originalValue="nierenförmig" pageId="null" pageNumber="41">nierenfoermig</normalizedToken>
oder 
<normalizedToken id="362A71B90DE99A2BE98DCC06F9381457" originalValue="herzförmig" pageId="null" pageNumber="41">herzfoermig</normalizedToken>
, 
<normalizedToken id="0EDC70D0FAA2E68425B1E8444F57C4AF" originalValue="gezähnt" pageId="null" pageNumber="41">gezaehnt</normalizedToken>
.
</emphasis>
<normalizedToken id="2C0BCA8C31FB510C5EA4B62DD4809743" originalValue="Blüten" pageId="null" pageNumber="41">Blueten</normalizedToken>
aktinomorph, zwitterig. 
<normalizedToken id="BFD9DBABB36661D5E2E1418BC0ED47CF" originalValue="Perigonblätter" pageId="null" pageNumber="41">Perigonblaetter</normalizedToken>
5-9, gelb oder 
<normalizedToken id="C27C81FC3414D6B21727F1F06777E363" originalValue="weiß" pageId="null" pageNumber="41">weiss</normalizedToken>
, nach der 
<normalizedToken id="F46402AF3BD960F9A64D49020B562E0F" originalValue="Blüte" pageId="null" pageNumber="41">Bluete</normalizedToken>
sofort abfallend (Arten der 
<normalizedToken id="433D1237E147EC5C08A95E0C72030407" originalValue="außertropischen" pageId="null" pageNumber="41">aussertropischen</normalizedToken>
Gebiete der 
<normalizedToken id="F910A6A0192E87A2D2D72BC9EF1E6806" originalValue="Nordhemisphäre" pageId="null" pageNumber="41">Nordhemisphaere</normalizedToken>
) oder nach der 
<normalizedToken id="17D6B7821B11AC29AAEEA3ADC9759919" originalValue="Blüte" pageId="null" pageNumber="41">Bluete</normalizedToken>
bleibend (Arten der 
<normalizedToken id="673690E851368D65DA5CE039E17EFA13" originalValue="Südhemisphäre" pageId="null" pageNumber="41">Suedhemisphaere</normalizedToken>
). 
<normalizedToken id="0551E8D9A8514DC8320DBE0A72E6CD36" originalValue="Honigblätter" pageId="null" pageNumber="41">Honigblaetter</normalizedToken>
keine. 
<normalizedToken id="BECB7953D80772D15D8E99B6A408C6FF" originalValue="Staubblätter" pageId="null" pageNumber="41">Staubblaetter</normalizedToken>
10-40. Fruchtknoten 3-10, 
<emphasis id="0D6F7AF66AC8B629D145EEAF576B4307" italics="true" pageId="null" pageNumber="41">2- oder mehrsamig;</emphasis>
<normalizedToken id="602CFE9FE0A55E04370519AB5CA3765B" originalValue="Früchtchen" pageId="null" pageNumber="41">Fruechtchen</normalizedToken>
mit langem, schnabelartigem Griffel.
</paragraph>
<paragraph id="3A42CEB8463C9B3A9B838F64AF2152E5" pageId="null" pageNumber="41">
Die Gattung 
<taxonomicName id="CAD732FDFDCE07C4A67F6E9FEAE3EF9F" class="Magnoliopsida" family="Ranunculaceae" genus="Caltha" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="41" phylum="Tracheophyta" rank="genus">
<emphasis id="D94FABF34623449BD6A072C2800731BD" italics="true" pageId="null" pageNumber="41">Caltha</emphasis>
</taxonomicName>
<normalizedToken id="46227D6A3FCFE21B1157F27F77AC2311" originalValue="umfaßt" pageId="null" pageNumber="41">umfasst</normalizedToken>
etwa 
<emphasis id="EB0FA99ECEEB3266D650C45BCDAFDA39" italics="true" pageId="null" pageNumber="41">40 Arten</emphasis>
, davon sind 
<emphasis id="58DAD0F7BC75617B0D3198FA7C2C1974" italics="true" pageId="null" pageNumber="41">
28 Arten in den 
<normalizedToken id="CBF7446AE7CD32EBB3C8999756C6D129" originalValue="außertropischen" pageId="null" pageNumber="41">aussertropischen</normalizedToken>
Gebieten der 
<normalizedToken id="B4E07AF02E0E1163A9D5DF0ABD2D8372" originalValue="nördlichen" pageId="null" pageNumber="41">noerdlichen</normalizedToken>
<normalizedToken id="5BE504B8EA3DB07D7715A42EFD671E3A" originalValue="Hemisphäre" pageId="null" pageNumber="41">Hemisphaere</normalizedToken>
und 12 Arten in den 
<normalizedToken id="7BB708E396805D872F44ECA5F7B841CF" originalValue="außertropischen" pageId="null" pageNumber="41">aussertropischen</normalizedToken>
Gebieten der 
<normalizedToken id="290B54FD23E84038872AB742374F11E4" originalValue="südlichen" pageId="null" pageNumber="41">suedlichen</normalizedToken>
<normalizedToken id="010307921370387EC4FDB9893C069F64" originalValue="Hemisphäre" pageId="null" pageNumber="41">Hemisphaere</normalizedToken>
verbreitet
</emphasis>
.
</paragraph>
</subSubSection>
