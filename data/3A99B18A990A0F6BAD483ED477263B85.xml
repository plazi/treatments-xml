<subSubSection id="0EC5492CC599519EAFDFDFAB2E59BC57" pageId="null" pageNumber="528" type="description">
<paragraph id="9186EFAF043A6713D4FAEE6B076A4296" pageId="null" pageNumber="528">
1 
<normalizedToken id="3A1B90738ECFFA574C3276FC3E9ADA0E" originalValue="jährig" pageId="null" pageNumber="528">jaehrig</normalizedToken>
; 10-50 cm hoch. 
<normalizedToken id="8267C1BBC026B32E3305EB2EA4A196DA" originalValue="Blütenstand" pageId="null" pageNumber="528">Bluetenstand</normalizedToken>
1-3 cm lang (ohne Stiel), 10-50 
<normalizedToken id="088C044EC0E6B1AACA619DD4039E85CC" originalValue="blütig" pageId="null" pageNumber="528">bluetig</normalizedToken>
. 
<emphasis id="7C14AA8D54D989DF448205DA59184009" italics="true" pageId="null" pageNumber="528">Krone 2-3,5 mm lang</emphasis>
, gelb; 
<emphasis id="1D814DCCAE24D4DFD3C98FA02FC47195" italics="true" pageId="null" pageNumber="528">
Fahne und Schiffchen etwa gleich lang, 
<normalizedToken id="692A297D22539C5DF80EEC597A8D3D62" originalValue="Flügel" pageId="null" pageNumber="528">Fluegel</normalizedToken>
etwas 
<normalizedToken id="F994461B628362B66F3B45692BD169A9" originalValue="kürzer" pageId="null" pageNumber="528">kuerzer</normalizedToken>
. Frucht 2-3 mm lang
</emphasis>
, kahl, mit undeutlichen, netzartigen Rippen, 2samig. - 
<normalizedToken id="48ABF7FB05144D473D32B81884E307AA" originalValue="Blüte" pageId="null" pageNumber="528">Bluete</normalizedToken>
: 
<normalizedToken id="BA92D856C4AC0347F6520407C326DA22" originalValue="Später" pageId="null" pageNumber="528">Spaeter</normalizedToken>
<normalizedToken id="47DF093DD578279CD7246531616C1607" originalValue="Frühling" pageId="null" pageNumber="528">Fruehling</normalizedToken>
, Sommer und Herbst.
</paragraph>
<paragraph id="3080474A16F5F0533AEE28809D5A395A" pageId="null" pageNumber="528">
<emphasis id="5BAC0647B5A542B6B249A83252079C2A" italics="true" pageId="null" pageNumber="528">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="6C87980D0581E72951EE0389821B100E" italics="true" pageId="null" pageNumber="528">16:</emphasis>
Material aus Europa, Asien und Amerika (Fryer 1930, Clarke 1934, Tschechow aus Tischler 1950, Bhaskaran und Swaminathan 1958, Bhattacharyya 1958, Raven et al. 1965, Baquar und Husain 1967).
</paragraph>
<paragraph id="1E65275FFB10DC4BD16013991D105AB4" pageId="null" pageNumber="528">
<emphasis id="2EDB2285AE698D02B819D528A46F984A" italics="true" pageId="null" pageNumber="528">Standort.</emphasis>
Kollin. Trockene, steinige 
<normalizedToken id="F7028BE2C094B16D276BBDE457249AE4" originalValue="Böden" pageId="null" pageNumber="528">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="D89588D05102EEE8C63D397B723D2C19" originalValue="Schuttplätze" pageId="null" pageNumber="528">Schuttplaetze</normalizedToken>
, Bahnareale.
</paragraph>
<paragraph id="CEDA717B6E1FDF95F346D949E7B9AE86" pageId="null" pageNumber="528">
<emphasis id="C67E968A912E0621A98197A8A533FCF3" italics="true" pageId="null" pageNumber="528">Verbreitung. Eurasiatische Pflanz e:</emphasis>
Europa (im Westen und Norden verschleppt), 
<normalizedToken id="DAC8EBC3C2F156AE71F1EE1D258F8D2D" originalValue="Südwestasien" pageId="null" pageNumber="528">Suedwestasien</normalizedToken>
(
<normalizedToken id="39D5C9047BCC6A1C54ED63EB91FDCCF9" originalValue="ostwärts" pageId="null" pageNumber="528">ostwaerts</normalizedToken>
bis Indien); in weiten Gebieten der Erde eingeschleppt. - Im Gebiet zerstreut, nicht 
<normalizedToken id="3CC5FD3F2F6F2521FC94A8CB27ED67A2" originalValue="häufig" pageId="null" pageNumber="528">haeufig</normalizedToken>
und 
<normalizedToken id="33FF814EB92F98E1212045C7F2CEA2EE" originalValue="unbeständig" pageId="null" pageNumber="528">unbestaendig</normalizedToken>
.
</paragraph>
</subSubSection>
