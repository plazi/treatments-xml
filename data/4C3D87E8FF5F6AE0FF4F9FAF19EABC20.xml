<collectingRegion id="0650F81CFF5F6AE0FC579A521AA7B71A" box="[939,1191,3083,3112]" country="Canada" name="British Columbia" pageId="164" pageNumber="926">British Columbia</collectingRegion>
(
<collectingCountry id="BC83766EFF5F6AE0FB349A521B34B71A" box="[1224,1332,3083,3112]" name="Canada" pageId="164" pageNumber="926">Canada</collectingCountry>
) S through W &amp; C 
<collectingCountry id="BC83766EFF5F6AE0FE699A6B1FD4B77D" box="[405,468,3122,3151]" name="United States of America" pageId="164" pageNumber="926">USA</collectingCountry>
