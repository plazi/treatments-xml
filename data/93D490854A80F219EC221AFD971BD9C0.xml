<subSubSection id="E3A60D090576CB329814CE2A38556078" pageId="null" pageNumber="252" type="description">
<paragraph id="D64F491B95283C7D8562C5D9E768188F" pageId="null" pageNumber="252">
Die Gattung 
<taxonomicName id="9B26807CB734B2A414CB235D0544C7CF" class="Liliopsida" family="Poaceae" genus="Achnatherum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="252" phylum="Tracheophyta" rank="genus">
<emphasis id="6D2793FAF6499E7A7353A7FE85D70055" italics="true" pageId="null" pageNumber="252">Achnatherum</emphasis>
</taxonomicName>
unterscheidet sich von der Gattung 
<taxonomicName id="2E9CE4362F88FB0D95565C2AD53B238C" class="Liliopsida" family="Poaceae" genus="Stipa" kingdom="Plantae" order="Poales" pageId="null" pageNumber="252" phylum="Tracheophyta" rank="genus">
<emphasis id="ADE851707F8A3DD81B8CDB49FB65EC08" italics="true" pageId="null" pageNumber="252">Stipa</emphasis>
</taxonomicName>
(S. 250) durch folgende Merkmale: 
<emphasis id="AE1CDC82B2967D97D532F48D659DC55F" italics="true" pageId="null" pageNumber="252">
Triebe die 
<normalizedToken id="8DCF2439F17D649AB6582C04ECCEA42E" originalValue="grundständigen" pageId="null" pageNumber="252">grundstaendigen</normalizedToken>
Scheiden durchbrechend
</emphasis>
(extravaginal)
<emphasis id="89D77C6159D66FD930A00D72B9168078" italics="true" pageId="null" pageNumber="252">
; 
<normalizedToken id="E4D3E6338DA030389BFF30A39418CD13" originalValue="Blätter" pageId="null" pageNumber="252">Blaetter</normalizedToken>
in der Knospenlage eingerollt; Deckspelze 
<normalizedToken id="AFB2C3FD0B6EBFA6C43F4550150B46E0" originalValue="auβerseits" pageId="null" pageNumber="252">auβerseits</normalizedToken>
mit 3-6 mm langen, 
<normalizedToken id="8A97BC274DA96011BF567AC6D2823EE5" originalValue="weiβen" pageId="null" pageNumber="252">weiβen</normalizedToken>
Haaren; Granne der Deckspelze bis 1,5 cm lang
</emphasis>
.
</paragraph>
<paragraph id="78D0E20044A24660E7D71DDB6F58129D" pageId="null" pageNumber="252">
Die Gattung 
<taxonomicName id="CDC8E4EBBC5CE7DF360755EAE954DE12" class="Liliopsida" family="Poaceae" genus="Achnatherum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="252" phylum="Tracheophyta" rank="genus">
<emphasis id="4C0EB8CFA460BCD639607FE40962938D" italics="true" pageId="null" pageNumber="252">Achnatherum</emphasis>
</taxonomicName>
<normalizedToken id="CAFAE4F6FD014F37A391C4AF36768CF1" originalValue="umfaßt" pageId="null" pageNumber="252">umfasst</normalizedToken>
<emphasis id="1A7568AA62D5989DAD372E56357B5B13" italics="true" pageId="null" pageNumber="252">
mehrere Arten in Zentralasien, die 
<normalizedToken id="67F0EF4DCE6127059BF3ADD191E20FA5" originalValue="westwärts" pageId="null" pageNumber="252">westwaerts</normalizedToken>
bis ins 
<normalizedToken id="1A9DDFAE231C3BF75885395E83A47E7D" originalValue="europäische" pageId="null" pageNumber="252">europaeische</normalizedToken>
<normalizedToken id="F85CACDB96641E14531569BA28EBFB51" originalValue="Ruβland" pageId="null" pageNumber="252">Ruβland</normalizedToken>
oder den Kaukasus vordringen; im westlichen 
<taxonomicName id="680BB0BCCBFF2134EAE1C2AFD295E937" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="252" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
nur 1 Art
</emphasis>
.
</paragraph>
