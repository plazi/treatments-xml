<subSubSection id="3196373F3F34B565AE958436C5171CFA" pageId="null" pageNumber="482" type="description">
<paragraph id="8736CD466018C1B768182A04EEADEE34" pageId="null" pageNumber="482">
<normalizedToken id="2A829827ED957922992B4C1E38DC1638" originalValue="Bäume" pageId="null" pageNumber="482">Baeume</normalizedToken>
, 
<emphasis id="C4ACA229828CEAAA79217C294D63AC59" italics="true" pageId="null" pageNumber="482">
mit oft verzweigten Dornen. 
<normalizedToken id="AB9C2667A8C95B557FE9FF3F6A1E3DFB" originalValue="Blätter" pageId="null" pageNumber="482">Blaetter</normalizedToken>
1-2fach gefiedert.
</emphasis>
<normalizedToken id="B15FED939BBC35A703076E2854DCCC81" originalValue="Blüten" pageId="null" pageNumber="482">Blueten</normalizedToken>
⚥ oder ♂, in 
<normalizedToken id="E7D48B20FC22D0BDC9C530730272BF18" originalValue="blattachselständigen" pageId="null" pageNumber="482">blattachselstaendigen</normalizedToken>
Trauben, 
<emphasis id="626AEF68A989397E1727AF4A3BAAE7DB" italics="true" pageId="null" pageNumber="482">unscheinbar</emphasis>
, nur wenig zygomorph. Kelch 
<normalizedToken id="931FF5C0DBFD449B2F7632E983E15C41" originalValue="glockenförmig" pageId="null" pageNumber="482">glockenfoermig</normalizedToken>
, tief 3- oder 5teilig 
<normalizedToken id="9B2DCF8DE544943D8E56FC0A667948C8" originalValue="Kronblätter" pageId="null" pageNumber="482">Kronblaetter</normalizedToken>
3 oder 5. 
<normalizedToken id="CB0C6FC3B674E8AED9CD50C6196C1848" originalValue="Staubblätter" pageId="null" pageNumber="482">Staubblaetter</normalizedToken>
6 oder 10.
</paragraph>
<paragraph id="98B2647763D207511DAFE2A414A13F69" pageId="null" pageNumber="482">
Die Gattung 
<taxonomicName id="8644DE546633BFB6023F29E8D6E5BD29" class="Magnoliopsida" family="Fabaceae" genus="Gleditsia" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="482" phylum="Tracheophyta" rank="genus">
<emphasis id="CE90002546671AAA801A10509289E967" italics="true" pageId="null" pageNumber="482">Gleditsia</emphasis>
</taxonomicName>
<normalizedToken id="300BF2D3B4548B7A0AA18BD3E5227ADC" originalValue="umfaßt" pageId="null" pageNumber="482">umfasst</normalizedToken>
<emphasis id="DA3AA472C8CE0FE2498398190EE1C607" italics="true" pageId="null" pageNumber="482">15 tropische und subtropische Arten.</emphasis>
</paragraph>
