<taxonomicName id="566B62148FB2FADADC0257BA18BF2CB1" class="Magnoliopsida" family="Solanaceae" genus="Solanum" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Solanum praetermissum" order="Solanales" pageId="0" pageNumber="1" phylum="Tracheophyta" rank="species" species="praetermissum">
