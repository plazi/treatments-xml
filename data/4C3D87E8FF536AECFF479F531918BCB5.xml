etal. (2014), Solari (
<quantity id="036C9B1BFF536AECF920911C1925BC6C" box="[1756,1829,1861,1886]" metricMagnitude="3" metricUnit="m" metricValue="2.019" pageId="168" pageNumber="930" unit="m" value="2019.0">2019m</quantity>
