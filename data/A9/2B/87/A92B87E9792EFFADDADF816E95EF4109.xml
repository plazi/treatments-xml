</bibRefCitation>
) and the araneid 
<taxonomicName authority="Simon, 1903" authorityName="Simon" authorityYear="1903" box="[402,773,1267,1293]" class="Arachnida" family="Araneidae" genus="Mecynogea" kingdom="Animalia" order="Araneae" pageId="3" pageNumber="52" phylum="Arthropoda" rank="species" species="bigibba">
<emphasis box="[402,624,1267,1293]" italics="true" pageId="3" pageNumber="52">Mecynogea bigibba</emphasis>
<bibRefCitation author="Simon, E." box="[630,773,1267,1293]" pageId="3" pageNumber="52" pagination="21 - 39" refId="ref4957" refString="Simon, E. (1903) Descriptions d'arachnides nouveaux. Annales de la Societe Entomologique, 47, 21 - 39. https: // doi. org / 10.5962 / bhl. part. 25299" type="journal article" year="1903">Simon, 1903</bibRefCitation>
