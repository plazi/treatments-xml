<paragraph blockId="2.[151,1437,1974,2037]" lastBlockId="3.[151,1437,151,393]" lastPageId="3" lastPageNumber="52" pageId="2" pageNumber="51">
<emphasis bold="true" box="[199,335,1974,2000]" pageId="2" pageNumber="51">Comments.</emphasis>
<taxonomicName authority="Pádua, 2022" authorityName="Pádua" authorityYear="2022" box="[348,652,1975,2001]" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="51" phylum="Arthropoda" rank="species" species="atlantica" status="sp. n.">
<emphasis box="[348,652,1975,2001]" italics="true" pageId="2" pageNumber="51">Hymenoepimecis atlantica</emphasis>
</taxonomicName>
<emphasis bold="true" box="[664,733,1975,2001]" pageId="2" pageNumber="51">
<taxonomicNameLabel box="[664,733,1975,2001]" pageId="2" pageNumber="51" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
closely resembles 
<taxonomicName authority="Padua &amp; Onody, 2015" authorityName="Padua &amp; Onody" authorityYear="2015" box="[962,1392,1974,2001]" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="51" phylum="Arthropoda" rank="species" species="duckensis">
<emphasis box="[962,1111,1975,2001]" italics="true" pageId="2" pageNumber="51">H. duckensis</emphasis>
<bibRefCitation author="Padua, D. G. &amp; Oliveira, M. L. &amp; Onody, H. C. &amp; Sobczak, J. F. &amp; Saaksjarvi, I. E. &amp; Gomez, I. C." box="[1124,1392,1974,2001]" pageId="2" pageNumber="51" pagination="175 - 194" refId="ref4754" refString="Padua, D. G., Oliveira, M. L., Onody, H. C., Sobczak, J. F., Saaksjarvi, I. E. &amp; Gomez, I. C. (2015) The Brazilian Amazonian species of Hymenoepimecis Viereck, 1912 (Hymenoptera: Ichneumonidae: Pimplinae). Zootaxa, 4058 (2), 175 - 194. https: // doi. org / 10.11646 / zootaxa. 4058.2.2" type="journal article" year="2015">Pádua &amp; Onody, 2015</bibRefCitation>
</taxonomicName>
, 
<taxonomicName authority="Padua &amp; Saaksjarvi, 2020" authorityName="Padua &amp; Saaksjarvi" authorityYear="2020" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="51" phylum="Arthropoda" rank="species" species="ecuatoriana">
<emphasis italics="true" pageId="2" pageNumber="51">H. ecuatoriana</emphasis>
<bibRefCitation author="Padua, D. G. &amp; Saaksjarvi, I. E. &amp; Monteiro, R. F. &amp; Oliveira, M. L." box="[298,604,2011,2037]" pageId="2" pageNumber="51" pagination="57 - 92" refId="ref4838" refString="Padua, D. G., Saaksjarvi, I. E., Monteiro, R. F. &amp; Oliveira, M. L. (2020) Seven new species of spider-attacking Hymenoepimecis Viereck (Hymenoptera: Ichneumonidae: Pimplinae) from Ecuador, French Guiana, and Peru, with an identification key to the world species. ZooKeys, 935, 57 - 92. https: // doi. org / 10.3897 / zookeys. 935.50492" type="journal article" year="2020">Pádua &amp; Sääksjärvi, 2020</bibRefCitation>
</taxonomicName>
, 
<taxonomicName authority="Padua &amp; Saaksjarvi, 2020" authorityName="Padua &amp; Saaksjarvi" authorityYear="2020" box="[619,1092,2011,2037]" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="51" phylum="Arthropoda" rank="species" species="longilobus">
<emphasis box="[619,775,2011,2037]" italics="true" pageId="2" pageNumber="51">H. longilobus</emphasis>
<bibRefCitation author="Padua, D. G. &amp; Saaksjarvi, I. E. &amp; Monteiro, R. F. &amp; Oliveira, M. L." box="[786,1092,2011,2037]" pageId="2" pageNumber="51" pagination="57 - 92" refId="ref4838" refString="Padua, D. G., Saaksjarvi, I. E., Monteiro, R. F. &amp; Oliveira, M. L. (2020) Seven new species of spider-attacking Hymenoepimecis Viereck (Hymenoptera: Ichneumonidae: Pimplinae) from Ecuador, French Guiana, and Peru, with an identification key to the world species. ZooKeys, 935, 57 - 92. https: // doi. org / 10.3897 / zookeys. 935.50492" type="journal article" year="2020">Pádua &amp; Sääksjärvi, 2020</bibRefCitation>
</taxonomicName>
, and 
<taxonomicName authority="(Brues &amp; Richardson, 1913)" baseAuthorityName="Brues &amp; Richardson" baseAuthorityYear="1913" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" lastPageId="3" lastPageNumber="52" order="Hymenoptera" pageId="2" pageNumber="51" phylum="Arthropoda" rank="species" species="neotropica">
<emphasis box="[1159,1317,2011,2036]" italics="true" pageId="2" pageNumber="51">H. neotropica</emphasis>
(
<bibRefCitation author="Brues, C. T. &amp; Richardson, C. H." lastPageId="3" lastPageNumber="52" pageId="2" pageNumber="51" pagination="485 - 503" refId="ref4010" refString="Brues, C. T. &amp; Richardson, C. H. (1913) Descriptions of new parasitic Hymenoptera from British Guiana. Bulletin of the American Museum of Natural History, 32, 485 - 503." type="journal article" year="1913">Brues &amp; Richardson, 1913</bibRefCitation>
)
</taxonomicName>
mainly by having fore wings yellowish with two black bands and hind legs entirely black. It differs from 
<taxonomicName baseAuthorityName="Brues &amp; Richardson" baseAuthorityYear="1913" box="[293,447,187,212]" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="52" phylum="Arthropoda" rank="species" species="neotropica">
<emphasis box="[293,447,187,212]" italics="true" pageId="3" pageNumber="52">H. neotropica</emphasis>
</taxonomicName>
and 
<taxonomicName authorityName="Padua &amp; Saaksjarvi" authorityYear="2020" box="[502,655,187,213]" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="52" phylum="Arthropoda" rank="species" species="longilobus">
<emphasis box="[502,655,187,213]" italics="true" pageId="3" pageNumber="52">H. longilobus</emphasis>
</taxonomicName>
by having all tarsal claws with more or less quadrangular lobe (tarsal claw with a preapical tooth in 
<taxonomicName baseAuthorityName="Brues &amp; Richardson" baseAuthorityYear="1913" box="[488,642,223,248]" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="52" phylum="Arthropoda" rank="species" species="neotropica">
<emphasis box="[488,642,223,248]" italics="true" pageId="3" pageNumber="52">H. neotropica</emphasis>
</taxonomicName>
, and tarsal claw with a longitudinally elongated lobe in 
<taxonomicName authorityName="Padua &amp; Saaksjarvi" authorityYear="2020" box="[1268,1420,223,249]" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="52" phylum="Arthropoda" rank="species" species="longilobus">
<emphasis box="[1268,1420,223,249]" italics="true" pageId="3" pageNumber="52">H. longilobus</emphasis>
</taxonomicName>
). It differs from 
<taxonomicName authorityName="Padua &amp; Onody" authorityYear="2015" box="[326,472,259,285]" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="52" phylum="Arthropoda" rank="species" species="duckensis">
<emphasis box="[326,472,259,285]" italics="true" pageId="3" pageNumber="52">H. duckensis</emphasis>
</taxonomicName>
and 
<taxonomicName authorityName="Padua &amp; Saaksjarvi" authorityYear="2020" box="[533,705,259,284]" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="52" phylum="Arthropoda" rank="species" species="ecuatoriana">
<emphasis box="[533,705,259,284]" italics="true" pageId="3" pageNumber="52">H. ecuatoriana</emphasis>
</taxonomicName>
by having pronotum entirely orange and metasoma with black marks on posterior margins of tergites II–V, tergites VI+ black (pronotum predominantly black and metasoma orange with tergites VI+ black in 
<taxonomicName authorityName="Padua &amp; Onody" authorityYear="2015" box="[527,669,331,357]" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="52" phylum="Arthropoda" rank="species" species="duckensis">
<emphasis box="[527,669,331,357]" italics="true" pageId="3" pageNumber="52">H. duckensis</emphasis>
</taxonomicName>
, and pronotum orange and metasoma orange with tergites VI+ black in 
<taxonomicName authorityName="Padua &amp; Saaksjarvi" authorityYear="2020" box="[180,349,367,392]" class="Insecta" family="Ichneumonidae" genus="Hymenoepimecis" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="52" phylum="Arthropoda" rank="species" species="ecuatoriana">
<emphasis box="[180,349,367,392]" italics="true" pageId="3" pageNumber="52">H. ecuatoriana</emphasis>
</taxonomicName>
).
</paragraph>
