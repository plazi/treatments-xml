<collectingCountry box="[1013,1124,1715,1741]" name="Argentina" pageId="7" pageNumber="56">Argentina</collectingCountry>
(
<figureCitation box="[1140,1225,1715,1741]" captionStart="FIGURE 7" captionStartId="9.[151,250,1943,1967]" captionTargetBox="[166,1420,181,1920]" captionTargetId="figure-16@9.[166,1421,181,1920]" captionTargetPageId="9" captionText="FIGURE 7. Geographical distribution of the Hymenoepimecis species. (A) H. atlantica sp. n.; (B) H. castilloi Pádua &amp; Sääksjärvi, 2020; (C) Hymenoepimecis japi Sobczak, Loffredo, Penteado-Dias &amp; Gonzaga, 2009; (D) H. ribeiroi Pádua &amp; Sobczak, 2015; (E) H. uberensis Pádua &amp; Onody, 2015; (F) H. veranii Loffredo &amp; Penteado-Dias, 2009." figureDoi="http://doi.org/10.5281/zenodo.6911289" httpUri="https://zenodo.org/record/6911289/files/figure.png" pageId="7" pageNumber="56">Fig. 7F</figureCitation>
