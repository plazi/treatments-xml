<collectingCountry id="F36EE7D2FF87FF9CF535F970EA48F90F" box="[1059,1144,1754,1780]" name="Poland" pageId="2" pageNumber="389">Poland</collectingCountry>
, 
<collectingCountry id="F36EE7D2FF87FF9CF593F970EF24F8EF" name="Czech Republic" pageId="2" pageNumber="389">Czech Republic</collectingCountry>
, 
<collectingCountry id="F36EE7D2FF87FF9CF008F950EFB1F8EF" box="[286,385,1786,1812]" name="Slovakia" pageId="2" pageNumber="389">Slovakia</collectingCountry>
, 
<collectingCountry id="F36EE7D2FF87FF9CF09AF951EFC6F8EE" box="[396,502,1787,1813]" name="Hungary" pageId="2" pageNumber="389">Hungary</collectingCountry>
, 
<collectingCountry id="F36EE7D2FF87FF9CF317F950EC5CF8EF" box="[513,620,1786,1812]" name="Moldova" pageId="2" pageNumber="389">Moldova</collectingCountry>
, 
<collectingCountry id="F36EE7D2FF87FF9CF360F950ECF1F8EF" box="[630,705,1786,1812]" name="Russia" pageId="2" pageNumber="389">Russia</collectingCountry>
(
<collectingRegion id="49BD69A0FF87FF9CF3D9F950EDA0F8EE" box="[719,912,1786,1813]" country="Russia" name="Moscow" pageId="2" pageNumber="389">Moscow Region</collectingRegion>
) (
<bibRefCitation id="EFE8DAB3FF87FF9CF2B3F950EA90F8EF" author="Tobias, V. I. &amp; Chiriac, I. G." box="[933,1184,1786,1812]" pageId="2" pageNumber="389" refId="ref7953" refString="Tobias, V. I., Chiriac, I. G. Fam. Aphidiidae / Ed. G. S. Medvedev. - Leningrad: Nauka, 1986. - P. 254. - (Keys to the insects of the European part of the USSR; Vol. 3, part 5). - Russian: Tobiaс V. I., Kiрiik I. G. Сiм. Aphidiidae." type="book" year="1986">Tobias, Chiriac, 1986</bibRefCitation>
; Yu et al., 2012).
</paragraph>
