<taxonomicName id="4C56FE9AD10849687D36C659FAF53356" authority="Brazidec &amp; Vilhelmsen, 2022" authorityName="Brazidec &amp; Vilhelmsen" authorityYear="2022" box="[1096,1294,1814,1840]" class="Insecta" family="Diapriidae" genus="Pantolyta" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="17" pageNumber="74" phylum="Arthropoda" rank="species" species="similis" status="sp. nov.">
