(
<bibRefCitation id="BC6148D3FFC69B177883FA4BFA6F219E" author="Rigout, J. &amp; Allard, V." box="[1200,1429,1497,1519]" pageId="5" pageNumber="244" refId="ref12298" refString="Rigout, J. &amp; Allard, V. (1997) Les Coleopteres du Monde. Vol. 25. Schizorhinini 3. Hillside Books, Canterbury, 128 pp." type="book" year="1997">Rigout &amp; Allard, 1997</bibRefCitation>
