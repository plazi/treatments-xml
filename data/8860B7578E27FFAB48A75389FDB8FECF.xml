<subSubSection id="48D355CA8E27FFA948A7523CFD6BFAD6" box="[151,718,1296,1318]" pageId="105" pageNumber="106" type="reference_group">
<paragraph id="007606418E27FFA948A7523CFD6BFAD6" blockId="105.[151,1437,151,2035]" box="[151,718,1296,1318]" pageId="105" pageNumber="106">Anteon heppneri Olmi 1992a: 185; He &amp; Xu 2002: 144.</paragraph>
