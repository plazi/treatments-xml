<subSubSection id="F91E59FF40C1834654871AE8AE82A507" pageId="null" pageNumber="519" type="description">
<paragraph id="21D173F4C511AEC09FC558715FA8F989" pageId="null" pageNumber="519">
Unterscheidet sich von 
<taxonomicName id="EC5E37E05E23E0815AD1A14ACA07FDD3" class="Magnoliopsida" family="Asteraceae" genus="Inula" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="genus">
<emphasis id="2DF6F7F36F6160FC6B160283EEF5BDB1" italics="true" pageId="null" pageNumber="519">Inula</emphasis>
</taxonomicName>
(S. 522) durch folgende Merkmale: 
<emphasis id="DBA361BC7E0D821984F2291AB8321F70" italics="true" pageId="null" pageNumber="519">
Alle 
<normalizedToken id="46BF13E295786ED6D378B2B6D5C6D422" originalValue="Blüten" pageId="null" pageNumber="519">Blueten</normalizedToken>
<normalizedToken id="633EA317E463AF89E33D816D57AA73EC" originalValue="röhrenförmig" pageId="null" pageNumber="519">roehrenfoermig</normalizedToken>
</emphasis>
(
<emphasis id="B23209560D11B7A0675A5DC85A48387A" italics="true" pageId="null" pageNumber="519">
keine 
<normalizedToken id="8E38FCE796B2BE2E86DF9883263837CB" originalValue="Zungenblüten" pageId="null" pageNumber="519">Zungenblueten</normalizedToken>
</emphasis>
), die 
<normalizedToken id="E2AD36BC4C2F5694203D4BDB14C83A16" originalValue="äu" pageId="null" pageNumber="519">aeu</normalizedToken>
&amp;szligern ♀, die innern ⚥
<emphasis id="C9E64202198EBB19D77D525C64354565" italics="true" pageId="null" pageNumber="519">
; 
<normalizedToken id="29CA092326607F4BD3460777E7A6C22C" originalValue="Früchte" pageId="null" pageNumber="519">Fruechte</normalizedToken>
mit kurzem Schnabel, ohne 
<taxonomicName id="2972F67681036C65C3FD6C6D2849AC02" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="519" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
.
</emphasis>
</paragraph>
<paragraph id="45CD2964AB9C9E322F8A5A351E239A2C" pageId="null" pageNumber="519">
Die Gattung 
<taxonomicName id="DE59F2C5C11C930E038CFF81207E8BBE" class="Magnoliopsida" family="Asteraceae" genus="Carpesium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="genus">
<emphasis id="4E7385ADB5B4C6081F08080B0EF74B65" italics="true" pageId="null" pageNumber="519">Carpesium</emphasis>
</taxonomicName>
umfa&amp;szligt etwa 
<emphasis id="0AD98C006B7D9651DBD470B6FDA2EF31" italics="true" pageId="null" pageNumber="519">20 Arten</emphasis>
und ist in 
<emphasis id="C6441872F154B35F9F593A44DFC470EC" italics="true" pageId="null" pageNumber="519">
<normalizedToken id="535C41D2470F018E2164E2A2C60B9BD6" originalValue="Südeuropa" pageId="null" pageNumber="519">Suedeuropa</normalizedToken>
und besonders im 
<normalizedToken id="D54E8DC76F9EEF196717CB0E465E94CC" originalValue="gemä" pageId="null" pageNumber="519">gemae</normalizedToken>
&amp;szligigten und subtropischen 
<normalizedToken id="D3CD335F6EC37DAC674F77998C9C123D" originalValue="östlichen" pageId="null" pageNumber="519">oestlichen</normalizedToken>
Asien
</emphasis>
verbreitet.
</paragraph>
