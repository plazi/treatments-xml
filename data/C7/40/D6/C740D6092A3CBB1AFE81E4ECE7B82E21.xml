<taxonomicName authorityName="Felsche" authorityYear="1901" box="[731,871,524,548]" class="Insecta" family="Scarabaeidae" genus="Pinotus" higherTaxonomySource="CoL" kingdom="Animalia" order="Coleoptera" pageId="94" pageNumber="2324" phylum="Arthropoda" rank="species" species="quadraticeps">
