<subSubSection id="C36B652A81EFFF43FF31FE52FC14FD5E" pageId="192" pageNumber="193" type="distribution">
<paragraph id="8BCE36A181EFFF43FF31FE52FF60FDF2" blockId="192.[136,1451,374,653]" pageId="192" pageNumber="193">
<emphasis id="B905EAB381EFFF43FF31FE52FEC6FE2E" bold="true" box="[189,373,482,508]" pageId="192" pageNumber="193">Distribution:—</emphasis>
<collectingCountry id="F366763181EFFF43FEF9FE52FE02FE2E" box="[373,433,482,508]" name="India" pageId="192" pageNumber="193">India</collectingCountry>
, the eastern Himalayas, 
<collectingCountry id="F366763181EFFF43FD58FE53FCF0FE2F" box="[724,835,483,509]" name="Myanmar" pageId="192" pageNumber="193">Myanmar</collectingCountry>
, 
<collectingCountry id="F366763181EFFF43FCDEFE52FC0BFE2E" box="[850,952,482,508]" name="Thailand" pageId="192" pageNumber="193">Thailand</collectingCountry>
, Indochina and southwestern and southern 
<collectingCountry id="F366763181EFFF43FF04FDB6FF7CFDF2" box="[136,207,518,544]" name="China" pageId="192" pageNumber="193">China</collectingCountry>
.
</paragraph>
<paragraph id="8BCE36A181EFFF43FF31FD9AFC14FD5E" blockId="192.[136,1451,374,653]" pageId="192" pageNumber="193">
<emphasis id="B905EAB381EFFF43FF31FD9AFE95FD96" bold="true" box="[189,294,554,580]" pageId="192" pageNumber="193">Notes:—</emphasis>
Previously included in 
<taxonomicName id="4C714D2281EFFF43FDA5FD9BFD64FD96" box="[553,727,554,580]" class="Liliopsida" family="Orchidaceae" genus="Bletia" kingdom="Plantae" order="Asparagales" pageId="192" pageNumber="193" phylum="Tracheophyta" rank="species" species="tankervilleae">
<emphasis id="B905EAB381EFFF43FDA5FD9BFD64FD96" box="[553,727,554,580]" italics="true" pageId="192" pageNumber="193">P. tankervilleae</emphasis>
</taxonomicName>
but recently resurrected because of distinct floral characteristics by Cribb 
<emphasis id="B905EAB381EFFF43FF63FDFFFE95FDBA" box="[239,294,590,616]" italics="true" pageId="192" pageNumber="193">et al.</emphasis>
(2004), who indicted 
<collectingCountry id="F366763181EFFF43FD94FDFFFD36FDBB" box="[536,645,591,617]" name="Myanmar" pageId="192" pageNumber="193">Myanmar</collectingCountry>
but cited no specimens. The above-cited Griffith collection was included with 
<emphasis id="B905EAB381EFFF43FF4DFDC3FEC6FD5E" box="[193,373,626,652]" italics="true" pageId="192" pageNumber="193">
<taxonomicName id="4C714D2281EFFF43FF4DFDC3FEC2FD5E" box="[193,369,626,652]" class="Liliopsida" family="Orchidaceae" genus="Bletia" kingdom="Plantae" order="Asparagales" pageId="192" pageNumber="193" phylum="Tracheophyta" rank="species" species="tankervilleae">P. tankervilleae</taxonomicName>
,
</emphasis>
and its referral to 
<taxonomicName id="4C714D2281EFFF43FDC8FDC3FD72FD5E" box="[580,705,626,652]" class="Liliopsida" family="Orchidaceae" genus="Phaius" kingdom="Plantae" order="Asparagales" pageId="192" pageNumber="193" phylum="Tracheophyta" rank="species" species="wallichii">
<emphasis id="B905EAB381EFFF43FDC8FDC3FD72FD5E" box="[580,705,626,652]" italics="true" pageId="192" pageNumber="193">P. wallichii</emphasis>
</taxonomicName>
needs confirmation.
</paragraph>
