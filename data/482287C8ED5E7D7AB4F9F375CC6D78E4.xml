</paragraph>
<paragraph id="C03436DEED5E7D7ABC51FE47C3447204" blockId="3.[2061,2655,291,718]" pageId="3" pageNumber="84">
<taxonomicName id="078B4D5DED5E7D7ABC51FE47C176718D" authority="Vorontzov &amp; Shenbrot, 1984" authorityName="Vorontzov &amp; Shenbrot" authorityYear="1984" box="[2064,2655,410,443]" class="Mammalia" family="Dipodidae" genus="Salpingotus" kingdom="Animalia" order="Rodentia" pageId="3" pageNumber="84" phylum="Chordata" rank="subSpecies" species="pallidus" subSpecies="pallidus">S.p.pallidusVorontzov&amp;Shenbrot,1984—CKazakhstan(NofAralSeaareainSEAktobe,WKaraganda,andKyzylordaregions).</taxonomicName>
