<taxonomicName id="4C424D5686156B33F7FB8713FA30F427" authority="Yoo, 1994" authorityName="Yoo" authorityYear="1994" class="Gastropoda" genus="Cymbularia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Bellerophontida" pageId="7" pageNumber="70" phylum="Mollusca" rank="species" species="carinata" status="n.sp.">
<emphasis id="B936EAC786156B33F7FB8713FA30F427" italics="true" pageId="7" pageNumber="70">Cymbularia carinata</emphasis>
</taxonomicName>
