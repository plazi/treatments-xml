<subSubSection id="288AC515DB8C19C6E91B7740B14C5013" pageId="null" pageNumber="504" type="vernacular_names">
<paragraph id="C5B4907E3D35623A7B6081E427E13541" pageId="null" pageNumber="504">
<normalizedToken id="773F33E3A5B30AC9F3932DB6B62EFAE1" originalValue="Frühlings-Kreuzkraut" pageId="null" pageNumber="504">Fruehlings-Kreuzkraut</normalizedToken>
</paragraph>
</subSubSection>
</title>
<subSubSection id="6F24B1EAA93CF83EBBB5ED0280887F30" pageId="null" pageNumber="504" type="description">
<paragraph id="F887DEDD634252038BBE141E943C0DC7" pageId="null" pageNumber="504">
10-60 cm hoch. 
<normalizedToken id="7CE03C9B2A16445AD2363CDBC0867C5B" originalValue="Blätter" pageId="null" pageNumber="504">Blaetter</normalizedToken>
kahl oder zerstreut spinnwebig behaart, 
<emphasis id="D655359EDE129A04794EBACB53B8E46E" italics="true" pageId="null" pageNumber="504">
buchtig 
<normalizedToken id="95B5CE3739D7FE5A6B8247A9BF94A7FC" originalValue="gezähnt" pageId="null" pageNumber="504">gezaehnt</normalizedToken>
oder jederseits kaum 
<normalizedToken id="85B4E567FE442502D20DF569B1415F6E" originalValue="über" pageId="null" pageNumber="504">ueber</normalizedToken>
die Mitte der 
<normalizedToken id="805828ECB22CC8AA46B9E1A59A740776" originalValue="Blatthälfte" pageId="null" pageNumber="504">Blatthaelfte</normalizedToken>
fiederteilig
</emphasis>
(
<emphasis id="9EC2F274F3036E8C19D91C75029E4591" italics="true" pageId="null" pageNumber="504">Abschnitte fast rechtwinklig abstehend, meist breiter als 3 mm</emphasis>
), die obern 
<normalizedToken id="E6B75E0C00FE20A35C6EB2F13847E253" originalValue="Blätter" pageId="null" pageNumber="504">Blaetter</normalizedToken>
am Grunde mit breiten, 
<normalizedToken id="DC990C2F4655DCBC95CFD3D423DFA8CA" originalValue="gezähnten" pageId="null" pageNumber="504">gezaehnten</normalizedToken>
Zipfeln. 
<emphasis id="CBB92C1A16B24AEAEB4E931D0EB3B281" italics="true" pageId="null" pageNumber="504">
<normalizedToken id="2A299D4BC8FD69F407B1E78C29CDC800" originalValue="Blütenköpfe" pageId="null" pageNumber="504">Bluetenkoepfe</normalizedToken>
im Durchmesser 2
</emphasis>
- 
<emphasis id="387931399AF844C93F811B5A81E4E5D8" italics="true" pageId="null" pageNumber="504">3 cm.</emphasis>
<normalizedToken id="E10B58C7837B7019467B0FA6D6B5268C" originalValue="Hülle" pageId="null" pageNumber="504">Huelle</normalizedToken>
zylindrisch bis 
<normalizedToken id="E5ECD2F7352D038D49B560497D5849E3" originalValue="glockenförmig" pageId="null" pageNumber="504">glockenfoermig</normalizedToken>
, 
<emphasis id="9F4944CF1914FE54692CAC330E7CD288" italics="true" pageId="null" pageNumber="504">8</emphasis>
- 
<emphasis id="E808FC8AF5558AEB5AE5047022873AEE" italics="true" pageId="null" pageNumber="504">12 mm lang und 5</emphasis>
- 
<emphasis id="5912848149F9625C78C6CA73C71612E0" italics="true" pageId="null" pageNumber="504">10 mm dick</emphasis>
, 
<normalizedToken id="9F5014612AA4A36699D31457AA5BEF50" originalValue="außen" pageId="null" pageNumber="504">aussen</normalizedToken>
von 1-2 mm langen 
<normalizedToken id="8B6C619B8178CE3ADE7F04223244F61F" originalValue="Blättern" pageId="null" pageNumber="504">Blaettern</normalizedToken>
umgeben. Innere 
<normalizedToken id="75DFCA2734A239BF072F5D46D67C780A" originalValue="Hüllblätter" pageId="null" pageNumber="504">Huellblaetter</normalizedToken>
ca. 20, kahl. 
<normalizedToken id="B4D357089D4A439A032809E71DAA7B07" originalValue="Randständige" pageId="null" pageNumber="504">Randstaendige</normalizedToken>
Kronen 12-15, 
<normalizedToken id="2CE49E231BDCB05F257D2FA48F734F97" originalValue="zungenförmig" pageId="null" pageNumber="504">zungenfoermig</normalizedToken>
, 
<emphasis id="78CE1D575AEC2D9ED4C7E9E7C63C4BF0" italics="true" pageId="null" pageNumber="504">8</emphasis>
- 
<emphasis id="BF8D42FAFF2AABCD99A6BE008C9C900B" italics="true" pageId="null" pageNumber="504">12 mm lang und 2 mm breit.</emphasis>
<normalizedToken id="137BFA0C1817522C276763819BFD45E2" originalValue="Früchte" pageId="null" pageNumber="504">Fruechte</normalizedToken>
2-3 mm lang. 
<taxonomicName id="20713ADBA28F2326594289B922F02977" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="504" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
ca. 5 mm lang. - 
<normalizedToken id="0208D2DFD34103D22617D926B3124477" originalValue="Blüte" pageId="null" pageNumber="504">Bluete</normalizedToken>
: 
<normalizedToken id="5661510AACA8BD993B938E4E97A3B186" originalValue="Frühling" pageId="null" pageNumber="504">Fruehling</normalizedToken>
, Sommer und Herbst.
</paragraph>
<paragraph id="0528C5DA9937BD1C4923B15BDF25EB86" pageId="null" pageNumber="504">
<emphasis id="BDB6D0D65FADC5E502341C509394A56F" italics="true" pageId="null" pageNumber="504">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E278475DCCCF8E79867F37DCB6256789" italics="true" pageId="null" pageNumber="504">20:</emphasis>
Material aus botanischen 
<normalizedToken id="73119AE5DB0A3CDC2E8394F694903719" originalValue="Gärten" pageId="null" pageNumber="504">Gaerten</normalizedToken>
(Afzelius 1924).
</paragraph>
<paragraph id="89D50705F5A4079DB1614FE5F7515DD0" pageId="null" pageNumber="504">
<emphasis id="2C8E79F7328CD3EE38B27758796EFE92" italics="true" pageId="null" pageNumber="504">Standort.</emphasis>
Kollin, montan und subalpin. Lockere, 
<normalizedToken id="83AF1C7402F185703E18889F139F856D" originalValue="nährstoffreiche" pageId="null" pageNumber="504">naehrstoffreiche</normalizedToken>
, meist kalkarme, sandige oder lehmige 
<normalizedToken id="066957FCE822D8B1FD9A704D85F928C0" originalValue="Böden" pageId="null" pageNumber="504">Boeden</normalizedToken>
. 
<normalizedToken id="CD433D052F770D78DF1064AED46CA1F4" originalValue="Föhrenwälder" pageId="null" pageNumber="504">Foehrenwaelder</normalizedToken>
, 
<normalizedToken id="081D3498952C5A7178345DEF7BB3FC59" originalValue="Schuttplätze" pageId="null" pageNumber="504">Schuttplaetze</normalizedToken>
, Felder, 
<normalizedToken id="87D7FB5AF37D1FCAB00CE5E65D8FD8EB" originalValue="Wegränder" pageId="null" pageNumber="504">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="66F1FE08D06812C81BD577C0A469CE23" pageId="null" pageNumber="504">
<emphasis id="1FE051D9B1E12882E497AE2207B19B12" italics="true" pageId="null" pageNumber="504">
Verbreitung. 
<normalizedToken id="CAFAAD699D6ADA2E64100C70EB9ABD71" originalValue="Osteuropäisch-westasiatische" pageId="null" pageNumber="504">Osteuropaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
Osteuropa (in neuerer Zeit nach Westen vordringend; Westgrenze heute 
<normalizedToken id="D120F9000D3F79BA2EA24642D0039A5F" originalValue="Südschweden-Ostalpen" pageId="null" pageNumber="504">Suedschweden-Ostalpen</normalizedToken>
); Kleinasien, Kaukasus, Westsibirien. - Im Gebiet gelegentlich adventiv oder 
<normalizedToken id="1B984769F2ADB19B6F59865163B7D1EC" originalValue="eingebürgert" pageId="null" pageNumber="504">eingebuergert</normalizedToken>
(z. B. Oberrheinische Tiefebene).
</paragraph>
</subSubSection>
