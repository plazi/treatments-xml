</taxonomicName>
<taxonomicNameLabel id="5DD357A1B0203E7A14D5FBFEEB04B220" box="[967,1043,1050,1071]" pageId="82" pageNumber="831" rank="species">nov.sp.</taxonomicNameLabel>
