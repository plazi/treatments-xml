Key to genera allied to 
<taxonomicName id="96F7AF985F68A909FE61D2B62B38F839" authorityName="A. Camus" authorityYear="1950" box="[412,611,1944,1971]" class="Liliopsida" family="Poaceae" genus="Parahyparrhenia" kingdom="Plantae" order="Poales" pageId="2" pageNumber="249" phylum="Tracheophyta" rank="genus">
<emphasis id="638308095F68A909FE61D2B62B38F839" bold="true" box="[412,611,1944,1971]" italics="true" pageId="2" pageNumber="249">Parahyparrhenia</emphasis>
