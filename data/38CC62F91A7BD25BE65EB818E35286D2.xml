<taxonomicName id="593474172385837144A3C17CE23350F7" authority="L." class="Liliopsida" family="Poaceae" genus="Secale" kingdom="Plantae" order="Poales" pageId="null" pageNumber="380" phylum="Tracheophyta" rank="species" species="cereale">
