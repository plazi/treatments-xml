<normalizedToken id="D2775A234D039F00E3DC47DBF1168E42" originalValue="Schlüssel" pageId="null" pageNumber="411">Schluessel</normalizedToken>
zur Gattung 
<taxonomicName id="B93887C9E68249C845C260519E3681F5" class="Liliopsida" family="Cyperaceae" genus="Holoschoenus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="411" phylum="Tracheophyta" rank="genus">Holoschoenus</taxonomicName>
