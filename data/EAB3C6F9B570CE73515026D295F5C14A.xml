<subSubSection id="B16711FB99BA54F86C83F62BDA724E24" pageId="null" pageNumber="105" type="description">
<paragraph id="596931803988004A53BFCBE073047FB6" pageId="null" pageNumber="105">
<emphasis id="94816E6A5C848C370860711F44F0FA12" italics="true" pageId="null" pageNumber="105">
1 
<normalizedToken id="4786374150C97EB745F6D822DAA8621F" originalValue="jährig" pageId="null" pageNumber="105">jaehrig</normalizedToken>
, schon im Juni absterbend;
</emphasis>
3-10 cm hoch. 
<normalizedToken id="35C220D07A59E691973F1314C7504B7B" originalValue="Blätter" pageId="null" pageNumber="105">Blaetter</normalizedToken>
kahl, Blattstiel so lang oder 
<normalizedToken id="297DDA319A6EC1345ED9533AF8679336" originalValue="länger" pageId="null" pageNumber="105">laenger</normalizedToken>
als die Blattspreite, rotbraun, 
<normalizedToken id="60EF78C7B69820BC3C335DFBB96DD94D" originalValue="oberwärts" pageId="null" pageNumber="105">oberwaerts</normalizedToken>
<normalizedToken id="E132AD8B926187529F1E7D488DD86F2F" originalValue="grünlich" pageId="null" pageNumber="105">gruenlich</normalizedToken>
; Blattspreite 
<normalizedToken id="1C267F668B62A15B9B6E5F2C7708C9E0" originalValue="dünn" pageId="null" pageNumber="105">duenn</normalizedToken>
und zart, hell- bis 
<normalizedToken id="496E3857ED1F8427F58F4E8294F7068F" originalValue="dunkelgrün" pageId="null" pageNumber="105">dunkelgruen</normalizedToken>
, 
<emphasis id="EDF14DA37F01DB12EFFBAD0F51DB58AF" italics="true" pageId="null" pageNumber="105">
an verschiedenaltrigen 
<normalizedToken id="50892D64244BF94798FB9D8E720148E4" originalValue="Blättern" pageId="null" pageNumber="105">Blaettern</normalizedToken>
von verschiedener Form und Teilung:
</emphasis>
die untern (ersten) im 
<normalizedToken id="05C8061AE2E69A9C37225A6272818458" originalValue="Umriß" pageId="null" pageNumber="105">Umriss</normalizedToken>
<emphasis id="5003CF238B533A38FA58CBFA9AA99C4A" italics="true" pageId="null" pageNumber="105">
<normalizedToken id="CC05133C893549EA4686902705337DE5" originalValue="nierenförmig" pageId="null" pageNumber="105">nierenfoermig</normalizedToken>
bis rundlich
</emphasis>
, mehr oder weniger tief geteilt, meist nicht sporentragend, die folgenden im 
<normalizedToken id="C61A406719294177C418C9E0AFA09AB5" originalValue="Umriß" pageId="null" pageNumber="105">Umriss</normalizedToken>
oval bis lanzettlich, 1-3fach gefiedert, mit nach dem Grund 
<normalizedToken id="9E578AE03DEE713EE1F7BF3B4F5AB24F" originalValue="keilförmig" pageId="null" pageNumber="105">keilfoermig</normalizedToken>
<normalizedToken id="D64EC3045412BFF19BB481A6456DEDF5" originalValue="verschmälerten" pageId="null" pageNumber="105">verschmaelerten</normalizedToken>
, meist fiederteiligen Fiedern letzter Ordnung. 
<emphasis id="BD98D83910A0FF5025F39A878AF4874F" italics="true" pageId="null" pageNumber="105">
Sori an den ersten sporentragenden 
<normalizedToken id="35D9255B0C8750129A69FCE9D99C838A" originalValue="Blättern" pageId="null" pageNumber="105">Blaettern</normalizedToken>
<normalizedToken id="B2290D2CBBB82179DBE14ADAA4C9246C" originalValue="randständig" pageId="null" pageNumber="105">randstaendig</normalizedToken>
, an den 
<normalizedToken id="691CDFC3D42DB544B22ED38AB1449134" originalValue="spätern" pageId="null" pageNumber="105">spaetern</normalizedToken>
<normalizedToken id="ABB47C10B65FB4DB8CFC8D6D3A7FE151" originalValue="Blättern" pageId="null" pageNumber="105">Blaettern</normalizedToken>
oft die ganze Unterseite der Abschnitte bedeckend.
</emphasis>
- Sporenreife: Winter und 
<normalizedToken id="7705A2D75DDB510773D8B5DB9DDA234A" originalValue="früher" pageId="null" pageNumber="105">frueher</normalizedToken>
<normalizedToken id="A1677ACDBDEF999068F3ADFC75723264" originalValue="Frühling" pageId="null" pageNumber="105">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="775E57AA33BA367CEB7022F3E55D2DD6" pageId="null" pageNumber="105">
<emphasis id="37A77063E3FA70E0553E8D959F702CA5" italics="true" pageId="null" pageNumber="105">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A118D2DF7078857A87CC9C2BCAD95971" italics="true" pageId="null" pageNumber="105">26:</emphasis>
Material von Jersey (England) (Tutin in 
<normalizedToken id="B0308DD26DE78F78BA2726FD8E3FF9CB" originalValue="Löve" pageId="null" pageNumber="105">Loeve</normalizedToken>
und 
<normalizedToken id="BD8DBBA2688CF62D4246E6B2743004E6" originalValue="Löve" pageId="null" pageNumber="105">Loeve</normalizedToken>
1961), 
<emphasis id="69AFD368131D2CA4E28641BD42FAD5AD" italics="true" pageId="null" pageNumber="105">2n</emphasis>
= 
<emphasis id="25AC6789708FBE307BB82C562A4D349B" italics="true" pageId="null" pageNumber="105">58:</emphasis>
Material aus Neuseeland (Brownlie 1958), 
<emphasis id="B3CA437066D11790032E44D85A416DE5" italics="true" pageId="null" pageNumber="105">2n</emphasis>
= 
<emphasis id="AE1FAC572DAE382D43A80C62309468BB" italics="true" pageId="null" pageNumber="105">112</emphasis>
oder 
<emphasis id="FCA363487A527B8C3F185A202A3EBCC4" italics="true" pageId="null" pageNumber="105">114:</emphasis>
Material aus dem westlichen Himalaja (Mehra und Verma 1960).
</paragraph>
<paragraph id="2766E8A11D26F706FEA0EDA6B0B79320" pageId="null" pageNumber="105">
<emphasis id="9CC86BDB04FE7C523D35532DAB81B87B" italics="true" pageId="null" pageNumber="105">Standort.</emphasis>
Kollin, montan. Feuchte, schattige Felsnischen, 
<normalizedToken id="56E5C45B3FDD2D7DA0C822A877DAA60C" originalValue="Höhlen" pageId="null" pageNumber="105">Hoehlen</normalizedToken>
, Grotten (nicht auf Kalk).
</paragraph>
<paragraph id="C69DCA7F9EBBB35424FC00FF89A86F93" pageId="null" pageNumber="105">
<emphasis id="8DE26A46170E9362F1A6B0EE8202749C" italics="true" pageId="null" pageNumber="105">
<pageBreakToken id="5E35D331DA11D70616AEEF3FF8E36BA8" pageId="null" pageNumber="105">Verbreitung</pageBreakToken>
. Pflanze der Tropen und Subtropen beider 
<normalizedToken id="437E3B445F0231428E1BCC7690EADE03" originalValue="Hemisphären" pageId="null" pageNumber="105">Hemisphaeren</normalizedToken>
.
</emphasis>
In 
<taxonomicName id="BEA4C5424ACD153A7446B4212D467360" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="105" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
im Mediterrangebiet, 
<normalizedToken id="569B3C8F34E5BBA19D91584F4B197C88" originalValue="nordwärts" pageId="null" pageNumber="105">nordwaerts</normalizedToken>
bis in die Bretagne und bis zur 
<normalizedToken id="B1C08357C63EE971902145F790F704B0" originalValue="Alpensüdseite" pageId="null" pageNumber="105">Alpensuedseite</normalizedToken>
. - Im Gebiet: Savoyen (Albertville), Wallis (
<normalizedToken id="DCBDC1D394AA66B16F5FFD4FA05B514B" originalValue="Follatères" pageId="null" pageNumber="105">Follateres</normalizedToken>
, zwischen Fully und Saillon, zwischen Lalden und Eggerberg), Tessin (Indemini, Bignasco, Chiasso, Brissago), Aostatal, Piemont (
<normalizedToken id="1F589FDE6A087838965F075316252060" originalValue="Ossolatäler" pageId="null" pageNumber="105">Ossolataeler</normalizedToken>
), Lombardei (Maccagno am Langensee, Comerseegebiet), Meran. Genaue Fundortsangaben aus dem Gebiet von Fully und Saillon und aus den 
<normalizedToken id="A2D6142E5C095B90755CA7FB708425C8" originalValue="Ossolatälern" pageId="null" pageNumber="105">Ossolataelern</normalizedToken>
von Terretaz (1964).
</paragraph>
</subSubSection>
