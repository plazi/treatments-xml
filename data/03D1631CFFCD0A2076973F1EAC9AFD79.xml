</emphasis>
(A, B), 
<taxonomicName id="4C78A989FFCE0A2E75493C81A873F914" authority="Ermilov &amp; Starý, 2022" authorityName="Ermilov &amp; Starý" authorityYear="2022" box="[841,1060,1673,1697]" class="Arachnida" family="Galumnidae" genus="Pergalumna" kingdom="Animalia" order="Sarcoptiformes" pageId="6" pageNumber="232" phylum="Arthropoda" rank="species" species="paratsavoensis" status="sp. nov." subGenus="Pergalumna">
