<emphasis id="B90C0E18FFCE0A2E758C3C81A873F914" box="[908,1060,1673,1696]" italics="true" pageId="6" pageNumber="232">paratsavoensis</emphasis>
</taxonomicName>
<emphasis id="B90C0E18FFCE0A2E722A3C81A82CF915" bold="true" box="[1066,1147,1673,1697]" pageId="6" pageNumber="232">
<taxonomicNameLabel id="A23FB363FFCE0A2E722A3C81A82CF915" box="[1066,1147,1673,1697]" pageId="6" pageNumber="232" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
