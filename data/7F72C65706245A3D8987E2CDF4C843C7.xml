<subSubSection id="BA7EFD2E8D33C8F310679F768367E22B" pageId="null" pageNumber="576" type="description">
<paragraph id="F5CC3E473F66C365EFA08AEAF63745EE" pageId="null" pageNumber="576">
Unterscheidet sich von 
<taxonomicName id="7488BFB6A3780A0C055184EB6E7E25A7" class="Liliopsida" family="Asparagaceae" genus="Muscari" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="576" phylum="Tracheophyta" rank="species" species="racemosum">
<emphasis id="C666C60E507A6560DDA94CC17566129F" italics="true" pageId="null" pageNumber="576">M. racemosum</emphasis>
</taxonomicName>
(Nr.2) durch folgende Merkmale: 20-40 cm hoch; 
<normalizedToken id="E2D8F77F7C898691B73DACC212E0C04B" originalValue="Blätter" pageId="null" pageNumber="576">Blaetter</normalizedToken>
viel 
<normalizedToken id="DE3B5FDBF734C7FDAB952245F6097229" originalValue="länger" pageId="null" pageNumber="576">laenger</normalizedToken>
als die Stengel; 
<emphasis id="3849FD02D07368C16BB337ADDD2894FF" italics="true" pageId="null" pageNumber="576">Frucht an der Spitze abgerundet.</emphasis>
- 
<normalizedToken id="970378ABEC78B7EE2C54619407045138" originalValue="Blüte" pageId="null" pageNumber="576">Bluete</normalizedToken>
: 
<normalizedToken id="3C6EAEA4D1BAC8784CFA8E5618BE0C80" originalValue="Früher" pageId="null" pageNumber="576">Frueher</normalizedToken>
<normalizedToken id="28E0A0E8740BB2FADC0C7D7F6C7FC0EF" originalValue="Frühling" pageId="null" pageNumber="576">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="A6B285359CAC1EC4599062DF2E98C851" pageId="null" pageNumber="576">
<emphasis id="EF94A9FDD48EC7F301504F4007F03A5E" italics="true" pageId="null" pageNumber="576">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B6E20AD6634EFC727468570B55CF44FB" italics="true" pageId="null" pageNumber="576">45:</emphasis>
Material wahrscheinlich aus 
<normalizedToken id="A7A68ECE0A929627D19575521878F5C6" originalValue="Südwestasien" pageId="null" pageNumber="576">Suedwestasien</normalizedToken>
(Delaunay aus 
<normalizedToken id="50341540A2D3CCAC2ACBB807D308C491" originalValue="Löve" pageId="null" pageNumber="576">Loeve</normalizedToken>
und 
<normalizedToken id="8884A811A3BC555BCDCE5869909ACE94" originalValue="Löve" pageId="null" pageNumber="576">Loeve</normalizedToken>
1961). 
<emphasis id="1BBD6474EFACAC8E04F700D623AE1A6D" italics="true" pageId="null" pageNumber="576">2n</emphasis>
= 
<emphasis id="6092ED93EF000F4BCC46A7987E3E6D31" italics="true" pageId="null" pageNumber="576">54:</emphasis>
Material aus botanischen 
<normalizedToken id="775D86CC2530A0CE76711465B20A313E" originalValue="Gärten" pageId="null" pageNumber="576">Gaerten</normalizedToken>
(
<normalizedToken id="182E4553EEF073A764A65C91C20DAF82" originalValue="Satô" pageId="null" pageNumber="576">Sato</normalizedToken>
1942).
</paragraph>
<paragraph id="361D236C05D0B256C3076041EF1E6456" pageId="null" pageNumber="576">
<emphasis id="40AB218DBB1AEF9CB33A990F93218941" italics="true" pageId="null" pageNumber="576">Standort.</emphasis>
Wie 
<taxonomicName id="77010C1F98E2BAF46D8858F1EF660534" class="Liliopsida" family="Asparagaceae" genus="Muscari" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="576" phylum="Tracheophyta" rank="species" species="racemosum">
<emphasis id="9441EEA83D83F1DEA85EEE5F8C06D507" italics="true" pageId="null" pageNumber="576">M. racemosum</emphasis>
</taxonomicName>
(Nr. 2).
</paragraph>
<paragraph id="1756B795D305EAFF053300F4E762A65E" pageId="null" pageNumber="576">
<emphasis id="8BE911FD792B84325926E0163E13CF29" italics="true" pageId="null" pageNumber="576">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="856404FF5612510C66D36B6224F40477" originalValue="Nordwärts" pageId="null" pageNumber="576">Nordwaerts</normalizedToken>
bis ins Seinegebiet, Oberrheinische Tiefebene, 
<normalizedToken id="70347A95C6B1A3820637B2DE8811334D" originalValue="Tübingen" pageId="null" pageNumber="576">Tuebingen</normalizedToken>
, warmes Donaubecken, 
<normalizedToken id="F8A56A1855A4EC9CC69A6B34629AA69F" originalValue="ostwärts" pageId="null" pageNumber="576">ostwaerts</normalizedToken>
bis in den Kaukasus; Nordwestafrika; Syrien. - Im Gebiet: Wie 
<taxonomicName id="8A1704B5B400FF73CDDAD8742D3E35CC" class="Liliopsida" family="Asparagaceae" genus="Muscari" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="576" phylum="Tracheophyta" rank="species" species="racemosum">
<emphasis id="5464EC8EED3314DA17A0E02C91738F0F" italics="true" pageId="null" pageNumber="576">M. racemosum</emphasis>
</taxonomicName>
(Nr.2), jedoch seltener.
</paragraph>
</subSubSection>
