<caption id="90EB6676FF226A9DFA8993B61941BD6A" ID-DOI="http://doi.org/10.5281/zenodo.6399005" ID-Zenodo-Dep="6399005" httpUri="https://zenodo.org/record/6399005/files/figure.png" inLine="true" pageId="217" pageNumber="979" targetBox="[1397,1988,1052,1465]" targetPageId="217">
