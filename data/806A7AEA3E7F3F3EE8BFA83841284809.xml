<subSubSection id="F26D25E62CF2536DCE2E2DA85B183DFD" pageId="null" pageNumber="529" type="vernacular_names">
<paragraph id="E5592F1F3A45ABB3B09C049BCD2933AE" pageId="null" pageNumber="529">Schwarzer Germer</paragraph>
</subSubSection>
</title>
<subSubSection id="33D2733581E1470B4DB7AF90E9F702A2" pageId="null" pageNumber="529" type="description">
<paragraph id="38E75E707DA8307245785A08483CFF40" pageId="null" pageNumber="529">
60-120 cm hoch. Stengel weich behaart. Unterste 
<normalizedToken id="1D66C66646278C6D2C83898DD35C8A2C" originalValue="Blätter" pageId="null" pageNumber="529">Blaetter</normalizedToken>
lanzettlich, bis 30 cm lang, 4-6mal so lang wie breit, in einen 
<normalizedToken id="C98DB0835D832008393530184C4F2CAD" originalValue="geflügelten" pageId="null" pageNumber="529">gefluegelten</normalizedToken>
Stiel 
<normalizedToken id="7FFD70F6B6F0A2DE94A640A69A153061" originalValue="verschmälert" pageId="null" pageNumber="529">verschmaelert</normalizedToken>
, obere 
<normalizedToken id="F51FC6F93AFC50D5EB6D96DEB3978020" originalValue="Blätter" pageId="null" pageNumber="529">Blaetter</normalizedToken>
<normalizedToken id="3165959016215489C92C611C8DF9C819" originalValue="schmäler" pageId="null" pageNumber="529">schmaeler</normalizedToken>
werdend, die obersten 
<normalizedToken id="3016DA2194580F8EE12D226003CDBB78" originalValue="grasähnlich" pageId="null" pageNumber="529">grasaehnlich</normalizedToken>
, alle 
<normalizedToken id="F7808C8829AAFA06A59FCFE41AB01E34" originalValue="Blätter" pageId="null" pageNumber="529">Blaetter</normalizedToken>
beiderseits kahl. 
<normalizedToken id="DACC268A8CF9CF317634844E6637B1C3" originalValue="Blütenstand" pageId="null" pageNumber="529">Bluetenstand</normalizedToken>
sehr 
<normalizedToken id="B0D4AAC4777100F23E39C0D788436BDB" originalValue="reichblütig" pageId="null" pageNumber="529">reichbluetig</normalizedToken>
, bis 50 cm lang, mit zahlreichen, 
<normalizedToken id="0EA4257EB070F879915F3AD6F80A6E7E" originalValue="seitwärts" pageId="null" pageNumber="529">seitwaerts</normalizedToken>
abstehenden Trauben. 
<normalizedToken id="FF92CC038AC87E8135CEC2774A8810F9" originalValue="Äste" pageId="null" pageNumber="529">Aeste</normalizedToken>
und 
<normalizedToken id="4822115ADDA4C1D89148E5A33017E994" originalValue="Blütenstiele" pageId="null" pageNumber="529">Bluetenstiele</normalizedToken>
dicht und flaumig behaart. 
<emphasis id="FC07418BD083D71F9E64905B3C5D300A" italics="true" pageId="null" pageNumber="529">
<normalizedToken id="130576CC870A38F7E62511FD56D90129" originalValue="Tragblätter" pageId="null" pageNumber="529">Tragblaetter</normalizedToken>
viel 
<normalizedToken id="B38B0639D69AC40D79899D4663B90418" originalValue="kürzer" pageId="null" pageNumber="529">kuerzer</normalizedToken>
als die 
<normalizedToken id="1D42D3FAB4F4E6B30DC88F094DC9B221" originalValue="Blütenstiele" pageId="null" pageNumber="529">Bluetenstiele</normalizedToken>
</emphasis>
, dicht und flaumig behaart. Die meisten 
<normalizedToken id="78E158F8FC5D40032D5485DA1B920A10" originalValue="Blütenstiele" pageId="null" pageNumber="529">Bluetenstiele</normalizedToken>
5-10 mm lang, 
<emphasis id="5608868676F4B6A7E6E59B382312C872" italics="true" pageId="null" pageNumber="529">
so lang oder 
<normalizedToken id="4B061E99E04623DA831DDCF3C0945651" originalValue="länger" pageId="null" pageNumber="529">laenger</normalizedToken>
als die 
<normalizedToken id="FDA6897AB14C0B3290827BCD2E928033" originalValue="Perigonblätter" pageId="null" pageNumber="529">Perigonblaetter</normalizedToken>
. 
<normalizedToken id="D77FAC0E18527C3904EB02A43DAFAF7C" originalValue="Perigonblätter" pageId="null" pageNumber="529">Perigonblaetter</normalizedToken>
oval, ca. 5 mm lang, rotbraun bis dunkelbraun. -
</emphasis>
<normalizedToken id="CB6DC416738027074A9B4F91B52ED075" originalValue="Blüte" pageId="null" pageNumber="529">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="DD0FDA0E01FDE140CE95F6DA15774794" pageId="null" pageNumber="529">
<emphasis id="8E89EA8644EF553E0CFF2DA34F8458DB" italics="true" pageId="null" pageNumber="529">Zytologische Angaben. 2n = 32:</emphasis>
(Miller aus Tischler 1950).
</paragraph>
<paragraph id="F3E7831BB6C2593F279158A5C55A2C52" pageId="null" pageNumber="529">
<emphasis id="EEC83175148478E7C95FE17590E02AFC" italics="true" pageId="null" pageNumber="529">Standort.</emphasis>
Montan und kollin. Kalkhaltige, trockene 
<normalizedToken id="004BCCE6723B8F6B7A86031A9FA9C7CE" originalValue="Böden" pageId="null" pageNumber="529">Boeden</normalizedToken>
. Lichte 
<normalizedToken id="3256558CB87FED2A8D8DD4E5AB98E884" originalValue="Laubmischwälder" pageId="null" pageNumber="529">Laubmischwaelder</normalizedToken>
. Wiesen.
</paragraph>
<paragraph id="D4AADE21F6CF679E7F7CF8EA79720A5E" pageId="null" pageNumber="529">
<emphasis id="2D70B7CE2B4EDEDCFAF5F97C0FAEEF19" italics="true" pageId="null" pageNumber="529">
Verbreitung. 
<normalizedToken id="C825E1AEBDF83811ADD98F8DC93416BF" originalValue="Osteuropäisch-asiatische" pageId="null" pageNumber="529">Osteuropaeisch-asiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="C10C8FDDF27888A9C847C1D640CB8B09" originalValue="Französische" pageId="null" pageNumber="529">Franzoesische</normalizedToken>
Westalpen (3 Fundstellen!), 
<normalizedToken id="46957835011A32234AFA0B1F13638985" originalValue="südliche" pageId="null" pageNumber="529">suedliche</normalizedToken>
Kalkalpen vom Tessin 
<normalizedToken id="8D6A75205CA2FAB142537C25608E69B4" originalValue="ostwärts" pageId="null" pageNumber="529">ostwaerts</normalizedToken>
, Apennin, Gebirge der Balkanhalbinsel, Donaubecken, 
<normalizedToken id="9EF7F91AE7EDC321AA941BD4C1BFB4C8" originalValue="Böhmen" pageId="null" pageNumber="529">Boehmen</normalizedToken>
, Karpaten, Polen (
<normalizedToken id="BDABBFCE83A456BB011F9EE32A30C4C4" originalValue="nordwärts" pageId="null" pageNumber="529">nordwaerts</normalizedToken>
bis Lublin), 
<normalizedToken id="955823E0697DF60F75BBEE17C284691B" originalValue="Rußland" pageId="null" pageNumber="529">Russland</normalizedToken>
; in Sibirien von 60° NB 
<normalizedToken id="114D82DE3FB3A9D9462AD89D5C7CFF1D" originalValue="südwärts" pageId="null" pageNumber="529">suedwaerts</normalizedToken>
bis in die zentralasiatischen Gebirge, 
<normalizedToken id="7D2F22E3ACC31F790DA4BE508C6724C1" originalValue="ostwärts" pageId="null" pageNumber="529">ostwaerts</normalizedToken>
bis Kamtschatka. - Im Gebiet: Valsesia (nach Bertolani Marchetti 1954), 
<normalizedToken id="88A01FDA789DCCA2B8EAF3E8CF14AC9F" originalValue="Südtessin" pageId="null" pageNumber="529">Suedtessin</normalizedToken>
und angrenzende Gebiete (Monte Nudo, Ganna, Monte Pravello, Monte San Giorgio, Monte Generoso, Val Solda, Grigna, Bergamasker Alpen).
</paragraph>
</subSubSection>
