<taxonomicName id="4C1E4D52FF8A767AFDF3D27B48E1F32D" baseAuthorityName="Tanasevitch" baseAuthorityYear="1998" box="[600,725,1570,1592]" class="Arachnida" family="Linyphiidae" genus="Mitrager" kingdom="Animalia" order="Araneae" pageId="87" pageNumber="504" phylum="Arthropoda" rank="species" species="tholusa">
