and 
<taxonomicName id="4C1E4D52FF8A767AFEDED2E44812F3CA" authorityName="Lin &amp; Lopardo &amp; Uhl" authorityYear="2022" baseAuthorityName="Tanasevitch" baseAuthorityYear="1998" box="[373,550,1723,1745]" class="Arachnida" family="Linyphiidae" genus="Mitrager" kingdom="Animalia" order="Araneae" pageId="87" pageNumber="504" phylum="Arthropoda" rank="species" species="sexoculorum">
