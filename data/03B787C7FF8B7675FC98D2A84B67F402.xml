<emphasis id="B96AEAC3FF8A767AFD32D2C54931F3A8" box="[665,773,1693,1714]" italics="true" pageId="87" pageNumber="504">M. lucida</emphasis>
</taxonomicName>
, 
<taxonomicName id="4C1E4D52FF8A767AFF08D2E44B09F3CA" authorityName="Lin &amp; Lopardo &amp; Uhl" authorityYear="2022" baseAuthorityName="Wunderlich" baseAuthorityYear="1974" box="[163,317,1723,1745]" class="Arachnida" family="Linyphiidae" genus="Mitrager" kingdom="Animalia" order="Araneae" pageId="87" pageNumber="504" phylum="Arthropoda" rank="species" species="sexoculata">
<emphasis id="B96AEAC3FF8A767AFF08D2E44B09F3CA" box="[163,317,1723,1745]" italics="true" pageId="87" pageNumber="504">M. sexoculata</emphasis>
