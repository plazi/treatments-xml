</taxonomicName>
, 
<taxonomicName id="4C1E4D52FF8A767AFED2D2274BDBF389" authorityName="COMB." authorityYear="2022" baseAuthorityName="Wunderlich" baseAuthorityYear="1974" box="[377,495,1662,1684]" class="Arachnida" family="Linyphiidae" genus="Mitrager" kingdom="Animalia" order="Araneae" pageId="87" pageNumber="504" phylum="Arthropoda" rank="species" species="lineata">
