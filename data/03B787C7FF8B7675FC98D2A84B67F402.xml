<taxonomicName id="4C1E4D52FF8A767AFDE1D25C4BBDF322" authority="(Tanasevitch, 1998)" authorityName="Lin &amp; Lopardo &amp; Uhl" authorityYear="2022" baseAuthorityName="Tanasevitch" baseAuthorityYear="1998" class="Arachnida" family="Linyphiidae" genus="Mitrager" kingdom="Animalia" order="Araneae" pageId="87" pageNumber="504" phylum="Arthropoda" rank="species" species="sexoculorum" status="comb. nov.">
