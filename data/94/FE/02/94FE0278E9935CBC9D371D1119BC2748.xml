<subSubSection pageId="0" pageNumber="301" type="distribution">
<paragraph pageId="0" pageNumber="301">Distribution.</paragraph>
<paragraph pageId="0" pageNumber="301">
Mexico (Chiapas, Guerrero), Guatemala, Costa Rica, Panama, Colombia, Venezuela, French Guiana, Ecuador, Peru (
<bibRefCitation author="Sharp, WD" editor="Godman, FD" journalOrPublisher="Vol. 1. Part 2. Published for the editors by R. H. Porter, London" pageId="0" pageNumber="301" pagination="1 - 144" publicationUrl="https://www.biodiversitylibrary.org/item/14601page/8/mode/1up" refId="B89" refString="Sharp, WD, 1882. Insecta. Coleoptera (Haliplidae, Dytiscidae, Gyrinidae, Hydrophilidae, Heteroceridae, Parnidae, Georissidae, Cyathoceridae). In: Godman, FD, Salvin, O, Eds., Biologia Centrali-Americana, Insecta, Coleoptera. Vol. 1. Part 2. Published for the editors by R. H. Porter, London: 1 - 144, https://www.biodiversitylibrary.org/item/14601page/8/mode/1up" title="Insecta. Coleoptera (Haliplidae, Dytiscidae, Gyrinidae, Hydrophilidae, Heteroceridae, Parnidae, Georissidae, Cyathoceridae)." url="https://www.biodiversitylibrary.org/item/14601page/8/mode/1up" volumeTitle="Biologia Centrali-Americana, Insecta, Coleoptera." year="1882">Sharp 1882</bibRefCitation>
; 
<bibRefCitation author="Hinton, HE" journalOrPublisher="Novitates Zoologicae" pageId="0" pageNumber="301" pagination="217 - 396" publicationUrl="http://biostor.org/reference/85607" refId="B42" refString="Hinton, HE, 1940b. A monographic revision of the Mexican water beetles of the Family Elmidae. Novitates Zoologicae 42 (2): 217 - 396, http://biostor.org/reference/85607" title="A monographic revision of the Mexican water beetles of the Family Elmidae." url="http://biostor.org/reference/85607" volume="42" year="1940 b">Hinton 1940b</bibRefCitation>
, 
<bibRefCitation author="Hinton, HE" journalOrPublisher="Entomologist's Monthly Magazine" pageId="0" pageNumber="301" pagination="156 - 163" refId="B44" refString="Hinton, HE, 1941. A synopsis of the American species of Austrolimnius Carter (Col., Elmidae). Entomologist's Monthly Magazine 77: 156 - 163" title="A synopsis of the American species of Austrolimnius Carter (Col., Elmidae)." volume="77" year="1941">1941</bibRefCitation>
, 
<bibRefCitation DOI="https://doi.org/10.1111/j.1365-3113.1971.tb00110.x" author="Hinton, HE" journalOrPublisher="Journal of Entomology (B)" pageId="0" pageNumber="301" pagination="93 - 99" refId="B46" refString="Hinton, HE, 1971. Some American Austrolimnius (Coleoptera: Elmidae). Journal of Entomology (B) 40 (2): 93 - 99, DOI: https://doi.org/10.1111/j.1365-3113.1971.tb00110.x" title="Some American Austrolimnius (Coleoptera: Elmidae)." url="https://doi.org/10.1111/j.1365-3113.1971.tb00110.x" volume="40" year="1971">1971</bibRefCitation>
; 
<bibRefCitation DOI="https://doi.org/10.5479/si.03629236.185.3" author="Blackwelder, RE" journalOrPublisher="Bulletin of United States National Museum" pageId="0" pageNumber="301" pagination="189 - 341" refId="B20" refString="Blackwelder, RE, 1944. Checklist of the coleopterous insects of Mexico, Central America, The West Indies, and South America. Part 2. Bulletin of United States National Museum 185: 189 - 341, DOI: https://doi.org/10.5479/si.03629236.185.3" title="Checklist of the coleopterous insects of Mexico, Central America, The West Indies, and South America. Part 2." url="https://doi.org/10.5479/si.03629236.185.3" volume="185" year="1944">Blackwelder 1944</bibRefCitation>
; 
<normalizedToken originalValue="González-Cordoba">Gonzalez-Cordoba</normalizedToken>
et al. 2020). 
<taxonomicName baseAuthorityName="Sharp" baseAuthorityYear="1882" class="Insecta" family="Elmidae" genus="Austrolimnius" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Austrolimnius sulcicollis" order="Coleoptera" pageId="0" pageNumber="301" phylum="Arthropoda" rank="species" species="sulcicollis">
<emphasis italics="true" pageId="0" pageNumber="301">Austrolimnius sulcicollis</emphasis>
</taxonomicName>
has been previously recorded from altitudes of 600 m and 2,438 m (
<bibRefCitation author="Hinton, HE" journalOrPublisher="Novitates Zoologicae" pageId="0" pageNumber="301" pagination="217 - 396" publicationUrl="http://biostor.org/reference/85607" refId="B42" refString="Hinton, HE, 1940b. A monographic revision of the Mexican water beetles of the Family Elmidae. Novitates Zoologicae 42 (2): 217 - 396, http://biostor.org/reference/85607" title="A monographic revision of the Mexican water beetles of the Family Elmidae." url="http://biostor.org/reference/85607" volume="42" year="1940 b">Hinton 1940b</bibRefCitation>
). Herein, this species was collected in all sampling levels (670-1,776 m).
</paragraph>
