<subSubSection id="BF98049CD0984DCE30E94687DF71421F" pageId="null" pageNumber="339" type="description">
<paragraph id="6D5862BD285DACA5F7C8381C4C8FC7CD" pageId="null" pageNumber="339">
Unterscheidet sich von 
<taxonomicName id="7A0E46E84BA145EE6E5566A962A71C83" class="Liliopsida" family="Poaceae" genus="Poa" kingdom="Plantae" order="Poales" pageId="null" pageNumber="339" phylum="Tracheophyta" rank="species" species="hybrida">
<emphasis id="E1856AACE5872204682F104E698D24B4" italics="true" pageId="null" pageNumber="339">P. hybrida</emphasis>
</taxonomicName>
(Nr. 16) durch folgende Merkmale: 
<emphasis id="036A1DA269DB75CA1DF246E1B6D80E65" italics="true" pageId="null" pageNumber="339">
Alle 
<normalizedToken id="7FE6A778D5A53F448F0E9EDB5E1798D7" originalValue="Blätter" pageId="null" pageNumber="339">Blaetter</normalizedToken>
mit kurzer, 
<normalizedToken id="16C01BD7210D7C2243CEA0D2C045A578" originalValue="kapuzenförmiger" pageId="null" pageNumber="339">kapuzenfoermiger</normalizedToken>
Spitze; 
<normalizedToken id="5211031488AF5CEB61426C830A49ADF5" originalValue="Blatthäutchen" pageId="null" pageNumber="339">Blatthaeutchen</normalizedToken>
der obersten 
<normalizedToken id="0110F4C3A1F4BBD1B02F1AB013A8A370" originalValue="Stengelblätter" pageId="null" pageNumber="339">Stengelblaetter</normalizedToken>
0,5-1,5 mm lang, gestutzt, am Rande bewimpert; Deckspelzen am Grunde ohne lange Haare. -
</emphasis>
<normalizedToken id="EA8D039B63144A448F33114C57C16B32" originalValue="Blüte" pageId="null" pageNumber="339">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="AA0DA43EE4C95CC8C7C4ABB9F522A573" pageId="null" pageNumber="339">
<emphasis id="5DB68AD4A8E7F8BFE4BD4F2AB7E0AAFB" italics="true" pageId="null" pageNumber="339">Zytologische Angaben. 2n = 14:</emphasis>
Material aus botanischen 
<normalizedToken id="A662D5929E56CC10F88B41483501B6BD" originalValue="Gärten" pageId="null" pageNumber="339">Gaerten</normalizedToken>
(
<normalizedToken id="7E9DBC97F02102DFB84D5DC8E65600B4" originalValue="Stählin" pageId="null" pageNumber="339">Staehlin</normalizedToken>
1929, Avdulov 1931), aus Skandinavien (Nannfeldt 1937, 
<normalizedToken id="9861E9B5EAA383D57064158D075C2796" originalValue="Löve" pageId="null" pageNumber="339">Loeve</normalizedToken>
und 
<normalizedToken id="44CC8D19E6F7F7999E3AF872AD05A731" originalValue="Löve" pageId="null" pageNumber="339">Loeve</normalizedToken>
1942b), aus Polen (Skalinska et al. 1957). 
<taxonomicName id="642B3DE43A382473EA6368F0337B4185" class="Liliopsida" family="Poaceae" genus="Poa" kingdom="Plantae" order="Poales" pageId="null" pageNumber="339" phylum="Tracheophyta" rank="species" species="chaixii">
<emphasis id="800EB81E9B43934BD541FF27A63A30E7" italics="true" pageId="null" pageNumber="339">P. Chaixii</emphasis>
</taxonomicName>
ist normal sexuell (
<normalizedToken id="FC4E93A84EEF277EA7CE8F0E381CB1C7" originalValue="Almgård" pageId="null" pageNumber="339">Almgard</normalizedToken>
1960).
</paragraph>
<paragraph id="3F242208B0034F262148BBCA3A33F2E7" pageId="null" pageNumber="339">
<emphasis id="CBD1BB375559B5DEE9D280654183C310" italics="true" pageId="null" pageNumber="339">Standort.</emphasis>
Kollin, montan, subalpin und alpin. Kalkfreie, lockere, lehmige, humose 
<normalizedToken id="8E6AE3CF2DE9F02709491C7D550263A1" originalValue="Böden" pageId="null" pageNumber="339">Boeden</normalizedToken>
. Lichte 
<normalizedToken id="02BBE13E67BF69E280E861960E69BF85" originalValue="Laubmischwälder" pageId="null" pageNumber="339">Laubmischwaelder</normalizedToken>
, 
<normalizedToken id="737782DEDC05FE93AD72741D91BFE660" originalValue="Gebüsch" pageId="null" pageNumber="339">Gebuesch</normalizedToken>
, 
<normalizedToken id="4A05211107AF065E46F7B15B20B21407" originalValue="nährstoffarme" pageId="null" pageNumber="339">naehrstoffarme</normalizedToken>
Weiden, Zwergstrauchgesellschaften.
</paragraph>
<paragraph id="4AB015CF4D774EEFAA8091DFD80FBC95" pageId="null" pageNumber="339">
<emphasis id="A40B3C375B206BC599210E14D7050DB6" italics="true" pageId="null" pageNumber="339">
Verbreitung. Mittel- und 
<normalizedToken id="EBCA571111460586BF474118A8FD15E2" originalValue="südeuropäische" pageId="null" pageNumber="339">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
<normalizedToken id="7E6698633A2A54572645C4004C2A4AC2" originalValue="Großbritannien" pageId="null" pageNumber="339">Grossbritannien</normalizedToken>
(eingeschleppt), 
<normalizedToken id="3A45E66FB13BBD6C296E8223982977E5" originalValue="Südskandinavien" pageId="null" pageNumber="339">Suedskandinavien</normalizedToken>
, Baltikum, Mitteldeutsche Gebirge, Asturien, 
<normalizedToken id="3A45E4CE5A52A03CA73E95151947377A" originalValue="Pyrenäen" pageId="null" pageNumber="339">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="06DB3A786CDBBC09EE670D6CAE4FF6CD" originalValue="französisches" pageId="null" pageNumber="339">franzoesisches</normalizedToken>
Zentralplateau, Alpen (ohne Ostalpen), Jura, Vogesen, Schwarzwald, Karpaten, Gebirge der Balkanhalbinsel, Kaukasus, Kleinasien. Verbreitungskarte von Meusel (1964). - Im Gebiet verbreitet, im Mittelland selten (der intensiven Waldnutzung wegen in Ausbreitung begriffen).
</paragraph>
<paragraph id="B02F07ED24693ABA55C76B7E57ED30A0" pageId="null" pageNumber="339">
<emphasis id="66DD02D0DD6D5A28858EF1A3B217F7B2" italics="true" pageId="null" pageNumber="339">Bemerkungen.</emphasis>
Die Populationen von 
<taxonomicName id="7443369D0202E15F3723E7BF80F62402" class="Liliopsida" family="Poaceae" genus="Poa" kingdom="Plantae" order="Poales" pageId="null" pageNumber="339" phylum="Tracheophyta" rank="species" species="chaixii">
<emphasis id="E68CFC64F01B0B83988B5E0D944775AA" italics="true" pageId="null" pageNumber="339">P. Chaixii</emphasis>
</taxonomicName>
sind vielgestaltig, und die Art sollte besonders im Alpengebiet weiter untersucht werden (Chrtek und 
<normalizedToken id="DFE2559D2F7656378F6CFB79053BC855" originalValue="Jirásek" pageId="null" pageNumber="339">Jirasek</normalizedToken>
1962a).
</paragraph>
</subSubSection>
