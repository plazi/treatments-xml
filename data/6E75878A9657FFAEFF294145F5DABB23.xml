<subSubSection id="AEC665179657FFAEFF294212F5DABB23" pageId="5" pageNumber="266" type="distribution">
<paragraph id="E663369C9657FFAEFF294212F699BAEF" blockId="5.[136,1452,517,833]" pageId="5" pageNumber="266">
<emphasis id="D4A8EA8E9657FFAEFF294212F762BA7C" bold="true" box="[136,320,517,543]" pageId="5" pageNumber="266">Distribution:—</emphasis>
<bibRefCitation id="824D4B6D9657FFAEFEE14211F431BA43" author="Wang, W. G. &amp; Lang, X. A. &amp; Yang, L. L. &amp; Wu, Y. H. &amp; Zhang, S. Z." box="[320,531,518,544]" pageId="5" pageNumber="266" pagination="51 - 58" refId="ref2812" refString="Wang, W. G., Lang, X. A., Yang, L. L., Wu, Y. H. &amp; Zhang, S. Z. (2019) Begonia zhongyangiana, a new species of Begonia (Begoniaceae) from western China. Phytotaxa 407 (1): 51 - 58. https: // doi. org / 10.11646 / phytotaxa. 407.1.8" type="journal article" year="2019">
Wang 
<emphasis id="D4A8EA8E9657FFAEFE294210F79BBA43" box="[392,441,518,544]" italics="true" pageId="5" pageNumber="266">et al</emphasis>
. (2019)
</bibRefCitation>
while describing 
<taxonomicName id="21DC4D1F9657FFAEFD7D4210F584BA43" authorityName="W. G. Wang &amp; S. Z. Zhang. A. Habit" authorityYear="2019" box="[732,934,518,544]" class="Magnoliopsida" family="Begoniaceae" genus="Begonia" kingdom="Plantae" order="Cucurbitales" pageId="5" pageNumber="266" phylum="Tracheophyta" rank="species" species="zhongyangiana">
<emphasis id="D4A8EA8E9657FFAEFD7D4210F584BA43" box="[732,934,518,544]" italics="true" pageId="5" pageNumber="266">B. zhongyangiana</emphasis>
</taxonomicName>
observed five populations, “on rocks or slops in broad-leaved evergreen mountain forest” at Beibeng Xiang in 
<collectingRegion id="2418F87E9657FFAEFCFA423DF237BA27" box="[859,1045,554,580]" country="China" name="Xizang" pageId="5" pageNumber="266">Xizang province</collectingRegion>
(
<collectingRegion id="2418F87E9657FFAEFB82423DF241BA26" box="[1059,1123,554,581]" country="China" name="Xizang" pageId="5" pageNumber="266">Tibet</collectingRegion>
), 
<collectingCountry id="9ECB760C9657FFAEFBD7423DF29FBA27" box="[1142,1213,554,580]" name="China" pageId="5" pageNumber="266">China</collectingCountry>
. The novel collection recorded here is from a small population from Yingkiong in Upper Siang District of 
<collectingRegion id="2418F87E9657FFAEFB9A4259F32DBA0B" box="[1083,1295,590,616]" country="India" name="Arunachal Pradesh" pageId="5" pageNumber="266">Arunachal Pradesh</collectingRegion>
in 
<collectingCountry id="9ECB760C9657FFAEFA924259F34FBA0B" box="[1331,1389,590,616]" name="India" pageId="5" pageNumber="266">India</collectingCountry>
(
<figureCitation id="7EE72A199657FFAEFADC425AF688BAE8" captionStart="FIGURE 4" captionStartId="5.[136,229,1598,1620]" captionTargetBox="[151,1436,857,1555]" captionTargetId="figure-246@5.[151,1436,857,1573]" captionTargetPageId="5" captionText="FIGURE 4. Distribution map: A. Begonia zhongyangiana W.G.Wang &amp; S.Z.Zhangin China &amp; India; B. Begonia murlenensis." figureDoi="http://doi.org/10.5281/zenodo.5419441" httpUri="https://zenodo.org/record/5419441/files/figure.png" pageId="5" pageNumber="266">
<emphasis id="D4A8EA8E9657FFAEFADC425AF688BAE8" bold="true" pageId="5" pageNumber="266">Fig. 4A</emphasis>
</figureCitation>
).
</paragraph>
<paragraph id="E663369C9657FFAEFF1C4281F5A1BA9B" blockId="5.[136,1452,517,833]" pageId="5" pageNumber="266">
<emphasis id="D4A8EA8E9657FFAEFF1C4281F72BBAD3" bold="true" box="[189,265,662,688]" pageId="5" pageNumber="266">Notes:</emphasis>
<taxonomicName id="21DC4D1F9657FFAEFEB04280F403BAD3" authorityName="W. G. Wang &amp; S. Z. Zhang. A. Habit" authorityYear="2019" box="[273,545,662,688]" class="Magnoliopsida" family="Begoniaceae" genus="Begonia" kingdom="Plantae" order="Cucurbitales" pageId="5" pageNumber="266" phylum="Tracheophyta" rank="species" species="zhongyangiana">
<emphasis id="D4A8EA8E9657FFAEFEB04280F403BAD3" box="[273,545,662,688]" italics="true" pageId="5" pageNumber="266">Begonia zhongyangiana</emphasis>
</taxonomicName>
<materialsCitation id="56B43CC19657FFAEFD884281F363BAB7" elevation="1148" location="This" pageId="5" pageNumber="266" specimenCount="1">
is very distinct from other members of 
<taxonomicName id="21DC4D1F9657FFAEFC454280F339BAD3" box="[996,1307,662,688]" class="Magnoliopsida" family="Begoniaceae" genus="Begonia" kingdom="Plantae" order="Cucurbitales" pageId="5" pageNumber="266" phylum="Tracheophyta" rank="section" section="Platycentrum">
<emphasis id="D4A8EA8E9657FFAEFC454280F263BAD3" box="[996,1089,663,688]" italics="true" pageId="5" pageNumber="266">Begonia</emphasis>
sect. 
<emphasis id="D4A8EA8E9657FFAEFB254281F339BAD3" box="[1156,1307,662,688]" italics="true" pageId="5" pageNumber="266">Platycentrum</emphasis>
</taxonomicName>
in its showy orange-yellow male and female flowers. 
<location id="E30360479657FFAEFDED42ADF45CBAB7" LSID="urn:lsid:plazi:treatment:6E75878A9657FFAEFF294145F5DABB23:E30360479657FFAEFDED42ADF45CBAB7" box="[588,638,698,724]" name="This" pageId="5" pageNumber="266">This</location>
species is found to occur at an elevation between 
<quantity id="21249B799657FFAEFB0342ADF363BAB7" box="[1186,1345,698,725]" metricMagnitude="3" metricUnit="m" metricValue="1.1475" metricValueMax="1.6" metricValueMin="0.695" pageId="5" pageNumber="266" unit="m" value="1147.5" valueMax="1600.0" valueMin="695.0">
<elevation id="6DF1D1AF9657FFAEFB0342ADF363BAB7" box="[1186,1345,698,725]" metricMagnitude="3" metricUnit="m" metricValue="1.1475" metricValueMax="1.6" metricValueMin="0.695" pageId="5" pageNumber="266" unit="m" value="1147.5" valueMax="1600.0" valueMin="695.0">695 to 1600 m</elevation>
</quantity>
</materialsCitation>
<materialsCitation id="56B43CC19657FFAEFAE742ADF5A1BA9B" country="China" elevation="437" location="Indian" pageId="5" pageNumber="266" specimenCount="437">
in 
<collectingCountry id="9ECB760C9657FFAEFAC042ADF385BAB7" box="[1377,1447,698,724]" name="China" pageId="5" pageNumber="266">China</collectingCountry>
, whereas the 
<location id="E30360479657FFAEFEB542C9F77EBA9B" LSID="urn:lsid:plazi:treatment:6E75878A9657FFAEFF294145F5DABB23:E30360479657FFAEFEB542C9F77EBA9B" box="[276,348,734,760]" country="China" name="Indian" pageId="5" pageNumber="266">Indian</location>
specimens were locatedat an elevation of 
<specimenCount id="F0DAFD159657FFAEFC9442C9F5A1BA9B" box="[821,899,734,760]" pageId="5" pageNumber="266" type="generic">
<quantity id="21249B799657FFAEFC9442C9F55DBA9B" box="[821,895,734,760]" metricMagnitude="2" metricUnit="m" metricValue="4.37" pageId="5" pageNumber="266" unit="m" value="437.0">
<elevation id="6DF1D1AF9657FFAEFC9442C9F55DBA9B" box="[821,895,734,760]" metricMagnitude="2" metricUnit="m" metricValue="4.37" pageId="5" pageNumber="266" unit="m" value="437.0">437 m</elevation>
</quantity>
.
</specimenCount>
