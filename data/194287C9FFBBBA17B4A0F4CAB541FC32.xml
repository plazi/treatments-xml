<taxonomicName id="56EB4D5CFFBBBA17B7AFF33AB77DFBBD" authority="Pallas, 1766" authorityName="Pallas" authorityYear="1766" box="[957,1371,1114,1139]" class="Mammalia" family="Molossidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="7" pageNumber="626" phylum="Chordata" rank="species" species="molossus">Vespertilio molossus Pallas, 1766</taxonomicName>
,
</subSubSection>
<subSubSection id="D9F16554FFBBBA17B702F319B6D1FB0F" pageId="7" pageNumber="626" type="materials_examined">
<materialsCitation id="21833C82FFBBBA17B702F319B6D1FB0F" ID-GBIF-Occurrence="3780789418" pageId="7" pageNumber="626">
