<taxonomicName id="35E8850D9BA983A4D98A329534C9163B" class="Magnoliopsida" family="Brassicaceae" genus="Coronopus" higherTaxonomySource="GBIF" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="148" phylum="Tracheophyta" rank="species" species="procumbens">
<italic id="BF2CEE5D00ED594DBCA6BBBDCBA79648" pageId="null" pageNumber="148">H. procumbens</italic>
