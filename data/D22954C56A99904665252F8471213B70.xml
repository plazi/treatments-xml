<normalizedToken id="6ED84035EF9D111DED680E21E3E4A581" originalValue="Blätter" pageId="null" pageNumber="148">Blaetter</normalizedToken>
ungeteilt, ganzrandig; 
<normalizedToken id="4AC815DEA91B7BABDFBE4206EEE8560E" originalValue="Früchte" pageId="null" pageNumber="148">Fruechte</normalizedToken>
1- 
<normalizedToken id="C790F5F37A277FF2546A89036A0C2F26" originalValue="1½" pageId="null" pageNumber="148">11/2</normalizedToken>
