<taxonomicName id="4C7C4D75FFA44405D3EBFF66FE21FF36" authorityName="Breuning" authorityYear="1980" box="[151,509,151,178]" class="Insecta" family="Cerambycidae" genus="Mimanhammus" kingdom="Animalia" order="Coleoptera" pageId="6" pageNumber="85" phylum="Arthropoda" rank="species" species="mindanaonis">
<emphasis id="B908EAE4FFA44405D3EBFF66FE21FF36" bold="true" box="[151,509,151,178]" italics="true" pageId="6" pageNumber="85">Mimanhammus mindanaonis</emphasis>
