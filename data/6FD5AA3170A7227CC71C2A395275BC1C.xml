<subSubSection id="9663BD4CF2F752B6BAE2927F6F04BD4F" pageId="null" pageNumber="373" type="description">
<paragraph id="F941F9D34DA77E733882E84C8B4484BF" pageId="null" pageNumber="373">
10-40 cm hoch. 
<normalizedToken id="99819893F60636AE235BFCA17730ED8D" originalValue="Grundständige" pageId="null" pageNumber="373">Grundstaendige</normalizedToken>
<normalizedToken id="E7895DDEDDC3FFE6258C77CA9D766E62" originalValue="Blätter" pageId="null" pageNumber="373">Blaetter</normalizedToken>
, gestielt, 
<emphasis id="ABABF55DCF67A087408E371DEBC3D2FB" italics="true" pageId="null" pageNumber="373">
oval bis lanzettlich, am Grunde abgerundet oder 
<normalizedToken id="DB49D8F6124C03DD5C5FAA2F4484EAB2" originalValue="herzförmig" pageId="null" pageNumber="373">herzfoermig</normalizedToken>
</emphasis>
, kahl oder behaart, 
<normalizedToken id="152FE909FC4A4596E3DA354FEE80E424" originalValue="gezähnt" pageId="null" pageNumber="373">gezaehnt</normalizedToken>
; 
<normalizedToken id="E2D613693FB906F97C802AC4C2A7183E" originalValue="Zähne" pageId="null" pageNumber="373">Zaehne</normalizedToken>
spitz oder stumpf, nach vorn gerichtet. 
<normalizedToken id="2779F0AD21D36356A73DDA8EC9B93F4D" originalValue="Stengelblätter" pageId="null" pageNumber="373">Stengelblaetter</normalizedToken>
wie die 
<normalizedToken id="991CD1C38AB4554B7EF6AEADD4930AE2" originalValue="Grundblätter" pageId="null" pageNumber="373">Grundblaetter</normalizedToken>
, aber 
<normalizedToken id="BB0351DD0D5E22E0D8E648355B41E790" originalValue="schmäler" pageId="null" pageNumber="373">schmaeler</normalizedToken>
, 
<emphasis id="942923259B8F72A8C21617A3983539EA" italics="true" pageId="null" pageNumber="373">die obern sitzend.</emphasis>
<normalizedToken id="47BA76D1965B0058B47DF94B6631C23F" originalValue="Hüllblätter" pageId="null" pageNumber="373">Huellblaetter</normalizedToken>
mit breitem abgerundetem Grunde, lang zugespitzt, 
<emphasis id="C8A9137D51C28384E588F4CCE0C8F2F2" italics="true" pageId="null" pageNumber="373">2</emphasis>
- 
<emphasis id="1CD3E6F1EEC03F75BF225CD4288BED83" italics="true" pageId="null" pageNumber="373">4mal so lang wie breit</emphasis>
(
<normalizedToken id="0757A2A9A48DDF51EB7B32BFF53C8A8B" originalValue="größte" pageId="null" pageNumber="373">groesste</normalizedToken>
Breite im untersten Drittel), 
<emphasis id="7D14BCCD2F0CB5F85B1BDFBFD1A6494C" italics="true" pageId="null" pageNumber="373">
ganzrandig oder am Grunde mit kleinen 
<normalizedToken id="F96401771DA0355D54120BA6F5ED43A6" originalValue="Zähnen" pageId="null" pageNumber="373">Zaehnen</normalizedToken>
</emphasis>
, 
<normalizedToken id="A49ABA692ADE7532E83B977FB6754B77" originalValue="±" pageId="null" pageNumber="373">+/-</normalizedToken>
so lang wie die Breite des Kopfes, dem Kopf anliegend, am Rande behaart oder kahl. 
<normalizedToken id="40D0558F9ADFED3927FF888966B626C6" originalValue="Kronröhren" pageId="null" pageNumber="373">Kronroehren</normalizedToken>
vor dem 
<normalizedToken id="FD065CFCDB221B8D05F6FE46609F7842" originalValue="Aufblühen" pageId="null" pageNumber="373">Aufbluehen</normalizedToken>
gegen die Kopfmitte 
<normalizedToken id="A1B4853A443AABA7275924B49A5441EE" originalValue="gekrümmt" pageId="null" pageNumber="373">gekruemmt</normalizedToken>
. Kelchzipfel 2-3 mm lang, 
<emphasis id="0529910DEACED715CC3271DDD56F1802" italics="true" pageId="null" pageNumber="373">2</emphasis>
- 
<emphasis id="5988CC16E29024FF91A0644EFC180A5C" italics="true" pageId="null" pageNumber="373">3mal so lang wie breit</emphasis>
, kahl oder am Rande behaart. Narben 3, seltener 2. - 
<normalizedToken id="B11CE7F0333A62090FC26630B18D0315" originalValue="Blüte" pageId="null" pageNumber="373">Bluete</normalizedToken>
: 
<normalizedToken id="095719A504B7A6283BF76F0974F6D8FF" originalValue="Später" pageId="null" pageNumber="373">Spaeter</normalizedToken>
<normalizedToken id="47CF6FAE3506827107A17C69F69D9D28" originalValue="Frühling" pageId="null" pageNumber="373">Fruehling</normalizedToken>
, Sommer und 
<normalizedToken id="D7E67AC69F83FD0AEA93FFFB68E5BAB9" originalValue="früher" pageId="null" pageNumber="373">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="03108E4EDA94D5B0E7D4EFC4A79F58B0" pageId="null" pageNumber="373">
<emphasis id="B0D30F0F15F5A988225F3B99098C0D5F" italics="true" pageId="null" pageNumber="373">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="F6FE8184111BF125470B08F791305BB0" italics="true" pageId="null" pageNumber="373">22:</emphasis>
Material aus der Tatra und aus den Pieninen in Polen (Skalinska et al. 1964, Ochlewska 1966), von 8 verschiedenen Stellen aus 
<normalizedToken id="C5A84B0FD66E7FFEE7CD3CDAFB4EA283" originalValue="Österreich" pageId="null" pageNumber="373">Oesterreich</normalizedToken>
; es wurden 0-2 B-Chromosomen 
<normalizedToken id="05FA63BC054920C563ED8943DA9E1EC4" originalValue="gezählt" pageId="null" pageNumber="373">gezaehlt</normalizedToken>
(Pola- 
<pageBreakToken id="B5DD886CFA0226431FE96A7789A560FB" pageId="null" pageNumber="373">tschek</pageBreakToken>
1966a), aus botanischem Garten (Zhukova 1967b). 
<emphasis id="E5FED79410794CC59F223E313CC31F6E" italics="true" pageId="null" pageNumber="373">2n</emphasis>
= 
<emphasis id="02D224EE92D5142E888FE557E7CC9E31" italics="true" pageId="null" pageNumber="373">24:</emphasis>
Material aus 
<normalizedToken id="7C79BAB6A383CF3CBF052EE6FBC9FEA2" originalValue="Österreich" pageId="null" pageNumber="373">Oesterreich</normalizedToken>
(Mattick in Tischler 1950, Nilsson und Lassen 1971), aus dem Jura (Favarger in Contandriopoulos 1962), von verschiedenen Orten aus den Westalpen, aus dem Jura und aus 
<normalizedToken id="B4BFB1699695009E7CE1A11A3AC6A836" originalValue="Rumänien" pageId="null" pageNumber="373">Rumaenien</normalizedToken>
(Contandriopoulos 1962), aus botanischem Garten (Gadella 1966).
</paragraph>
<paragraph id="15908111BC1942D3D215142100AFA49E" pageId="null" pageNumber="373">
<emphasis id="5593F18D9201E40BFAEDF7C669B43999" italics="true" pageId="null" pageNumber="373">Standort.</emphasis>
Montan und subalpin, seltener kollin und alpin. Magere, meist kalkreiche, humose 
<normalizedToken id="3BDB197BB1BB9371C5120BE2AFAE4304" originalValue="Böden" pageId="null" pageNumber="373">Boeden</normalizedToken>
. Magere Wiesen und Weiden, lichte 
<normalizedToken id="A6CAAD969289F9969F89C99EF17FCFFF" originalValue="Wälder" pageId="null" pageNumber="373">Waelder</normalizedToken>
.
</paragraph>
<paragraph id="35997CB96740D9F001D4B9AC586B4E31" pageId="null" pageNumber="373">
<emphasis id="B73496E5F2FE679C8D5D7A1B38D81E84" italics="true" pageId="null" pageNumber="373">
Verbreitung. 
<normalizedToken id="6C4A47E62DF1CBD5ABD2446E5D03C6E4" originalValue="Mitteleuropäische" pageId="null" pageNumber="373">Mitteleuropaeische</normalizedToken>
Pflanze:
</emphasis>
West- und 
<normalizedToken id="3DB8C07FF85878D474295B05218914DD" originalValue="südwärts" pageId="null" pageNumber="373">suedwaerts</normalizedToken>
bis Auvergne, mittlerer Apennin, Albanien; nordund 
<normalizedToken id="43CF0340E739C80A4F5FE3156CE36D1E" originalValue="ostwärts" pageId="null" pageNumber="373">ostwaerts</normalizedToken>
bis nordrheinische Tiefebene, Polen, 
<normalizedToken id="5DFF6C636B918EE92D3B56B5D41E343F" originalValue="Rumänien" pageId="null" pageNumber="373">Rumaenien</normalizedToken>
. - Im Gebiet besonders in den Bergen ziemlich 
<normalizedToken id="25F1F65831E7C9A1189AE8BD707FB54E" originalValue="häufig" pageId="null" pageNumber="373">haeufig</normalizedToken>
, im Mittelland selten.
</paragraph>
</subSubSection>
