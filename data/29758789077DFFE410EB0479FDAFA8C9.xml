, and 
<taxonomicName id="66DC4D1C077FFFE4129305D8FDB7A8CE" authorityName="Schweigert, Dietl &amp; Roper" authorityYear="2000" box="[429,559,2001,2027]" class="Malacostraca" family="Erymidae" genus="Eryma" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="7" pageNumber="30" phylum="Arthropoda" rank="species" species="westphali">
