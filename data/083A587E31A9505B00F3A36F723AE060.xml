<subSubSection id="3568C55D5E538E74249706FDC4DDFFF1" pageId="null" pageNumber="221" type="description">
<paragraph id="8D9516160078111169142AB59B1AC991" pageId="null" pageNumber="221">
Ausdauernd; mit Rhizom; 30-100 cm hoch. Stengel aufrecht, einfach, 
<emphasis id="A29CE0BAB2979CF5ACE4808AADFB848D" italics="true" pageId="null" pageNumber="221">mit krausen, mehrzelligen Haaren besetzt.</emphasis>
<normalizedToken id="794DA59F47813FD372FC3EA02526C88F" originalValue="Blätter" pageId="null" pageNumber="221">Blaetter</normalizedToken>
breit lanzettlich, 
<normalizedToken id="A3FB0FDC04992EFB6394783B37E88F53" originalValue="unregelmäßig" pageId="null" pageNumber="221">unregelmaessig</normalizedToken>
<normalizedToken id="942B73F924960A09BB55562C87680303" originalValue="gezähnt" pageId="null" pageNumber="221">gezaehnt</normalizedToken>
(
<normalizedToken id="042FB466219D165E58FAAD0DF2175AFE" originalValue="Zähne" pageId="null" pageNumber="221">Zaehne</normalizedToken>
nach vorn gerichtet), 
<emphasis id="4193533E52BCA8C196F050F3F1E4A19F" italics="true" pageId="null" pageNumber="221">besonders am Rande und unterseits auf den Nerven kraus behaart</emphasis>
, die untern gestielt, die obern sitzend. 
<normalizedToken id="94810B562E026EE085B6FCB470263DD6" originalValue="Blüten" pageId="null" pageNumber="221">Blueten</normalizedToken>
kurz gestielt, in einer einseitswendigen Traube. 
<emphasis id="9B86E4A0AD9A0EA32B1AA0ECBB49E3A5" italics="true" pageId="null" pageNumber="221">Kelchzipfel schmal lanzettlich</emphasis>
, wie die 
<normalizedToken id="366A5A58EBBB9D8621827553F3981ECC" originalValue="Blütenstiele" pageId="null" pageNumber="221">Bluetenstiele</normalizedToken>
und der obere Stengel 
<normalizedToken id="85FFD3910659C66351E8351AD5C00348" originalValue="drüsig" pageId="null" pageNumber="221">druesig</normalizedToken>
behaart. Krone bauchig und weiter oben 
<normalizedToken id="9A0D6104C0D0106E8A39855A42E9AF5C" originalValue="glockenförmig" pageId="null" pageNumber="221">glockenfoermig</normalizedToken>
, 
<emphasis id="A1D06D5227139E3E6133A2D5477E3353" italics="true" pageId="null" pageNumber="221">3</emphasis>
- 
<emphasis id="D6A8CEFDAAFBE82F30071A84AAF52335" italics="true" pageId="null" pageNumber="221">
4 cm lang, im Durchmesser an der 
<normalizedToken id="E3EA75E3D1D66979E9447EC044408F10" originalValue="Mündung" pageId="null" pageNumber="221">Muendung</normalizedToken>
1,5
</emphasis>
- 
<emphasis id="41FABFF28D51F3BB3BD9C0FB67B35EA2" italics="true" pageId="null" pageNumber="221">2 cm</emphasis>
, 
<normalizedToken id="D61C5B5AC83F60E7C03C165AC4871573" originalValue="blaßgelb" pageId="null" pageNumber="221">blassgelb</normalizedToken>
, 
<emphasis id="2B9D7E888509A7C2E4F713A1F143D4BA" italics="true" pageId="null" pageNumber="221">
innen mit hellbrauner Zeichnung, nicht 
<normalizedToken id="C64A289828A1EB6DEF2CFB40B7B60890" originalValue="bärtig" pageId="null" pageNumber="221">baertig</normalizedToken>
</emphasis>
, 
<normalizedToken id="61530F203250FA9FAAD90E7CEA518E54" originalValue="außen" pageId="null" pageNumber="221">aussen</normalizedToken>
<normalizedToken id="6910D86AADC7D79155E111012DFE4A48" originalValue="drüsig" pageId="null" pageNumber="221">druesig</normalizedToken>
behaart. Frucht 
<normalizedToken id="A145438E22324DC1E82C1447ACCD12B9" originalValue="drüsig" pageId="null" pageNumber="221">druesig</normalizedToken>
behaart. Samen wie bei 
<taxonomicName id="B4DFEA079E4A4F061A630EAA171B8F48" class="Insecta" family="Cicadellidae" genus="Digitalis" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="221" phylum="Arthropoda" rank="species" species="lutea">
<emphasis id="5F3D58A4C699CDA1740EB822B1F52B23" italics="true" pageId="null" pageNumber="221">D. lutea</emphasis>
</taxonomicName>
(Nr. 1). - 
<normalizedToken id="FA8D57F878740D43392BA4E472EF8141" originalValue="Blüte" pageId="null" pageNumber="221">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="81CB5EAEA95CF13646799C7052B3B9F8" pageId="null" pageNumber="221">
<emphasis id="805A525FA7C1A219CB0BB9C510E7296D" italics="true" pageId="null" pageNumber="221">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="FC63EDCDC76901ED54EAF7CE9D501ED0" italics="true" pageId="null" pageNumber="221">56:</emphasis>
Material aus botanischen 
<normalizedToken id="24605DA6D0EBC94ED5CB6B373B373C4F" originalValue="Gärten" pageId="null" pageNumber="221">Gaerten</normalizedToken>
und aus verschiedenen Gebieten Europas (Buxton und Dark 1934, Carpio 1957, Skalinska et al. 1959, Lungeanu 1967; weitere Autoren bei 
<normalizedToken id="6B72E73240FCD5291C3191373D7EE039" originalValue="Löve" pageId="null" pageNumber="221">Loeve</normalizedToken>
und 
<normalizedToken id="CB88B68C818F203EBC75C910EAEE1FBF" originalValue="Löve" pageId="null" pageNumber="221">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="175F4446CBF020438C834444B3AD9443" pageId="null" pageNumber="221">
<emphasis id="A1E21C9F5067C27CA46077C561D9C433" italics="true" pageId="null" pageNumber="221">Standort.</emphasis>
Montan und subalpin, selten kollin. Frische, steinige, 
<normalizedToken id="038434AD951A10104CB25E9958BF40CE" originalValue="nährstoffreiche" pageId="null" pageNumber="221">naehrstoffreiche</normalizedToken>
, lockere 
<normalizedToken id="717D6412BB12967D63E4ACC44739AA56" originalValue="Böden" pageId="null" pageNumber="221">Boeden</normalizedToken>
. Lichte, krautreiche 
<normalizedToken id="EE210C347DC60CEA89A2676BEB08AC9C" originalValue="Wälder" pageId="null" pageNumber="221">Waelder</normalizedToken>
, 
<normalizedToken id="94AB6FFD4E775341CFC63575A457ADD5" originalValue="Waldschläge" pageId="null" pageNumber="221">Waldschlaege</normalizedToken>
, 
<normalizedToken id="6636C1A0E23FD441C6EF2236A1A75A28" originalValue="Geröllhalden" pageId="null" pageNumber="221">Geroellhalden</normalizedToken>
, Wiesen.
</paragraph>
<paragraph id="48BE75F7E6B588047C5B79D85DDD6E7A" pageId="null" pageNumber="221">
<emphasis id="5C5FFF5E566950A565C6DD8D032D2543" italics="true" pageId="null" pageNumber="221">Verbreitung. Eurosibirische Pflanze:</emphasis>
West- und 
<normalizedToken id="6636AC2713AF2EF1475BABCD0712708E" originalValue="nordwärts" pageId="null" pageNumber="221">nordwaerts</normalizedToken>
bis Mittelfrankreich, 
<normalizedToken id="D396071D0578D964D6F85F15FCA1BC6E" originalValue="Südbelgien" pageId="null" pageNumber="221">Suedbelgien</normalizedToken>
, Norddeutschland, baltische Staaten; 
<normalizedToken id="C368C29FEF2793D93F6893FE2BDB4D72" originalValue="ostwärts" pageId="null" pageNumber="221">ostwaerts</normalizedToken>
in isolierten Fundorten durch Sibirien bis in den Altai; 
<normalizedToken id="96F9E948A1B2C29FAD36FD9DF5CD6EFE" originalValue="südwärts" pageId="null" pageNumber="221">suedwaerts</normalizedToken>
bis 
<normalizedToken id="C68FC937F16C97EFBE4DAD6F6E9F8D85" originalValue="Südalpen" pageId="null" pageNumber="221">Suedalpen</normalizedToken>
, Nordgriechenland, 
<normalizedToken id="1973D166114C66E7048ABA63DFEB0906" originalValue="Südrußland" pageId="null" pageNumber="221">Suedrussland</normalizedToken>
; Bithynischer Olymp (?), Kaukasus. Verbreitungskarte von Werner (1964). - Im Gebiet verbreitet, nicht 
<normalizedToken id="EC5D62B1919D9B88CAEB80AC16F40453" originalValue="häufig" pageId="null" pageNumber="221">haeufig</normalizedToken>
(im Mittelland und in der Oberrheinischen Tiefebene selten).
</paragraph>
</subSubSection>
