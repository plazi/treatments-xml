<subSubSection id="D9F16554FF92BA3EB3E0FFE2BB81F705" pageId="46" pageNumber="665" type="distribution">
<caption id="C5946657FF92BA3EB3E0FFE2BB81F705" ID-DOI="http://doi.org/10.5281/zenodo.6567926" ID-Zenodo-Dep="6567926" httpUri="https://zenodo.org/record/6567926/files/figure.png" inLine="true" pageId="46" pageNumber="665" targetBox="[1419,2010,1992,2407]" targetPageId="46">
<paragraph id="915436DFFF92BA3EB3E0FFE2BB81F705" blockId="46.[2033,2627,1985,2409]" pageId="46" pageNumber="665">
<emphasis id="A39FEACDFF92BA3EB3E0FFE2BA84F76D" bold="true" box="[2034,2210,2178,2211]" pageId="46" pageNumber="665">Distribution.</emphasis>
Two isolated populations, in W &amp; S 
<collectingCountry id="E9FC764FFF92BA3EBC40FFCABA81F705" box="[2130,2215,2218,2251]" name="Kenya" pageId="46" pageNumber="665">Kenya</collectingCountry>
