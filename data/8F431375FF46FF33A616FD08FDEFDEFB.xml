<taxonomicNameLabel id="2EADC30AFF46FF0CA3E7FAC5FAB1D945" box="[1271,1399,1322,1348]" pageId="223" pageNumber="224" rank="species">comb. nov.</taxonomicNameLabel>
but rhomboid in 
<taxonomicName id="C0EAD9E0FF46FF0CA691FABFFDE7D968" authorityName="Miranda &amp; Giupponi &amp; Prendini &amp; Scharff" authorityYear="2021" baseAuthorityName="Miranda &amp; Giupponi &amp; Prendini &amp; Scharff" baseAuthorityYear="2021" box="[385,545,1360,1386]" class="Arachnida" family="Charinidae" genus="Charinus" kingdom="Animalia" order="Amblypygi" pageId="223" pageNumber="224" phylum="Arthropoda" rank="species" species="ioanniticus" status="comb. nov.">
