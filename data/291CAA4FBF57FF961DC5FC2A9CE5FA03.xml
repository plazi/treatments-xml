<quantity id="664DB6BCBF56FF9619A4FC2A9D7BFC57" box="[1270,1357,942,969]" metricMagnitude="-3" metricUnit="m" metricValue="5.5" pageId="11" pageNumber="262" unit="mm" value="5.5">5.5 mm</quantity>
(mean value: 5.2 ± 
<quantity id="664DB6BCBF56FF961C71FC57994BFC73" box="[291,381,979,1005]" metricMagnitude="-4" metricUnit="m" metricValue="1.0" pageId="11" pageNumber="262" unit="mm" value="0.1">0.1 mm</quantity>
); 
<typeStatus id="7E0EA5FBBF56FF961CC3FC5799C1FC73" box="[401,503,979,1005]" pageId="11" pageNumber="262">holotype</typeStatus>
: 
<quantity id="664DB6BCBF56FF961F53FC569A6CFC73" box="[513,602,978,1005]" metricMagnitude="-3" metricUnit="m" metricValue="5.2" pageId="11" pageNumber="262" unit="mm" value="5.2">5.2 mm</quantity>
. MW: 2.8–3.0 mm (mean value: 2.9 ± 
<quantity id="664DB6BCBF56FF96195EFC579C50FC73" box="[1036,1126,979,1005]" metricMagnitude="-4" metricUnit="m" metricValue="1.0" pageId="11" pageNumber="262" unit="mm" value="0.1">0.1 mm</quantity>
