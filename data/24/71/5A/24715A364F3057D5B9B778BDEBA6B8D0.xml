<taxonomicName class="Magnoliopsida" family="Rosaceae" genus="Sorbus" kingdom="Plantae" lsidName="Sorbus foliolosa" order="Rosales" pageId="0" pageNumber="1" phylum="Tracheophyta" rank="species" species="foliolosa">
