). Body length ca. 
<quantity id="4CAFCAB3FF90E51765103BE2FCDDF845" box="[782,849,1946,1972]" metricMagnitude="-3" metricUnit="m" metricValue="7.0" pageId="9" pageNumber="270" unit="mm" value="7.0">7 mm</quantity>
