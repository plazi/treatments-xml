<normalizedToken id="13E1C55C758A89FB4D077C204029C3B6" originalValue="Blüten" pageId="null" pageNumber="10">Blueten</normalizedToken>
<normalizedToken id="081E21F3E024DAB93B67E67746B7CD13" originalValue="groß" pageId="null" pageNumber="10">gross</normalizedToken>
(Durchmesser 3-5 cm); Blattstiele im obern Teil stumpf 3kantig; 
<normalizedToken id="BC32F10D025EE449B8B9E0AD576924B6" originalValue="Blätter" pageId="null" pageNumber="10">Blaetter</normalizedToken>
