<typeStatus id="5490A58DFFC2FFE0FD438738FC81FBD7" box="[707,810,1067,1093]" pageId="10" pageNumber="100">holotype</typeStatus>
described from Yuzhnyj Slon Cave (= “Southern Elephant Cave”), Mt Dzentu, Karachaevo-Cherkessia Republic in 
<collectingCountry id="F33C5BBFFFC2FFE0FC69875DFB9CFBFA" box="[1001,1079,1102,1128]" name="Russia" pageId="10" pageNumber="100">Russia</collectingCountry>
(
