<subSubSection id="27D07E87332C4B708CE3FD1962A3D27D" pageId="0" pageNumber="47" type="diagnosis">
<paragraph id="125FFC0C1153658393839DBDD03163F8" pageId="0" pageNumber="47">Diagnosis.</paragraph>
<paragraph id="E71283A065DF14DC9B6C861546CF1639" pageId="0" pageNumber="47">
<bibRefCitation id="B6708097E84D8A4939829101061B09BF" DOI="https://doi.org/10.1071/IT98020" author="Dangerfield, PC" journalOrPublisher="Invertebrate Systematics" pageId="0" pageNumber="47" pagination="917 - 976" refId="B2" refString="Dangerfield, PC, Austin, AD, Whitfield, JB, 1999. Systematics of the world genera of Cardiochilinae (Hymenoptera: Braconidae). Invertebrate Systematics 13 (6): 917 - 976, DOI: https://doi.org/10.1071/IT98020" title="Systematics of the world genera of Cardiochilinae (Hymenoptera: Braconidae)." url="https://doi.org/10.1071/IT98020" volume="13" year="1999">Dangerfield et al. (1999)</bibRefCitation>
and 
<bibRefCitation id="D22169387072F7215FCD825CD3499439" DOI="https://doi.org/10.1080/00222930110097167" author="Mercado, I" journalOrPublisher="Journal of Natural History" pageId="0" pageNumber="47" pagination="845 - 902" refId="B9" refString="Mercado, I, Wharton, RA, 2003. Mexican cardiochiline genera (Hymenoptera: Braconidae), including a preliminary assessment of species-groups in Toxoneuron Say and Retusigaster Dangerfield, Austin and Whitfield. Journal of Natural History 37 (7): 845 - 902, DOI: https://doi.org/10.1080/00222930110097167" title="Mexican cardiochiline genera (Hymenoptera: Braconidae), including a preliminary assessment of species-groups in Toxoneuron Say and Retusigaster Dangerfield, Austin and Whitfield." url="https://doi.org/10.1080/00222930110097167" volume="37" year="2003">Mercado and Wharton (2003)</bibRefCitation>
provided detailed diagnostic characters. 
<taxonomicName id="0202CD8CF493350BD5E3F994A85FAC74" authorityName="Dangerfield, Austin &amp; Whitfield" authorityYear="1999" class="Insecta" family="Braconidae" genus="Retusigaster" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Retusigaster" order="Hymenoptera" pageId="0" pageNumber="47" phylum="Arthropoda" rank="genus">
<emphasis id="463E8B8FB685168E685C44EE84F8F500" italics="true" pageId="0" pageNumber="47">Retusigaster</emphasis>
</taxonomicName>
can be easily distinguished from other cardiochiline genera by the combination of the following characters: eye seemingly bare (Figs 
<figureCitation id="230E2A112260B63679E3ECE1C9DA1A2F" captionStart="Figure 2" captionStartId="F2" captionText="Figure 2. Retusigaster pulawskii sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal propodeum to T 3 E wings F dorsal mesosoma G mesopleuron and metapleuron." figureDoi="10.3897/zookeys.1092.80560.figure2" httpUri="https://binary.pensoft.net/fig/668119" pageId="0" pageNumber="47">2C</figureCitation>
, 
<figureCitation id="2FB1182DDB0F1E7598E4C6A79100543B" captionStart="Figure 3" captionStartId="F3" captionText="Figure 3. Retusigaster purshi sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal mesosoma E forewing." figureDoi="10.3897/zookeys.1092.80560.figure3" httpUri="https://binary.pensoft.net/fig/668120" pageId="0" pageNumber="47">3C</figureCitation>
, 
<figureCitation id="4C375B9AFC9F6AE8768FCFF3CC6B4162" captionStart="Figure 5" captionStartId="F5" captionText="Figure 5. Retusigaster vanduzeei sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal head E lateral head F wings G mesopleuron and metapleuron H scutellum to T 3." figureDoi="10.3897/zookeys.1092.80560.figure5" httpUri="https://binary.pensoft.net/fig/668122" pageId="0" pageNumber="47">5C</figureCitation>
); clypeal tubercle absent (Figs 
<figureCitation id="8081029FEB54567A7522BC08F2D04FB7" captionStart="Figure 2" captionStartId="F2" captionText="Figure 2. Retusigaster pulawskii sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal propodeum to T 3 E wings F dorsal mesosoma G mesopleuron and metapleuron." figureDoi="10.3897/zookeys.1092.80560.figure2" httpUri="https://binary.pensoft.net/fig/668119" pageId="0" pageNumber="47">2C</figureCitation>
, 
<figureCitation id="80EDC3825BA89A881340A762790EED0D" captionStart="Figure 3" captionStartId="F3" captionText="Figure 3. Retusigaster purshi sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal mesosoma E forewing." figureDoi="10.3897/zookeys.1092.80560.figure3" httpUri="https://binary.pensoft.net/fig/668120" pageId="0" pageNumber="47">3C</figureCitation>
, 
<figureCitation id="626359AF71D3C80012B7B426A6E55C92" captionStart="Figure 5" captionStartId="F5" captionText="Figure 5. Retusigaster vanduzeei sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal head E lateral head F wings G mesopleuron and metapleuron H scutellum to T 3." figureDoi="10.3897/zookeys.1092.80560.figure5" httpUri="https://binary.pensoft.net/fig/668122" pageId="0" pageNumber="47">5C</figureCitation>
); mouthparts short (Figs 
<figureCitation id="AA914AE0C40C0DC9FECCA53F4B5C7F65" captionStart="Figure 2" captionStartId="F2" captionText="Figure 2. Retusigaster pulawskii sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal propodeum to T 3 E wings F dorsal mesosoma G mesopleuron and metapleuron." figureDoi="10.3897/zookeys.1092.80560.figure2" httpUri="https://binary.pensoft.net/fig/668119" pageId="0" pageNumber="47">2C</figureCitation>
, 
<figureCitation id="65683DD7EC57FA73D4FB4B17C0523C4D" captionStart="Figure 3" captionStartId="F3" captionText="Figure 3. Retusigaster purshi sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal mesosoma E forewing." figureDoi="10.3897/zookeys.1092.80560.figure3" httpUri="https://binary.pensoft.net/fig/668120" pageId="0" pageNumber="47">3C</figureCitation>
, 
<figureCitation id="167CD0B665E0456A54375CF36FD6D4F0" captionStart="Figure 5" captionStartId="F5" captionText="Figure 5. Retusigaster vanduzeei sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal head E lateral head F wings G mesopleuron and metapleuron H scutellum to T 3." figureDoi="10.3897/zookeys.1092.80560.figure5" httpUri="https://binary.pensoft.net/fig/668122" pageId="0" pageNumber="47">5C</figureCitation>
); scutellum apically with carinate margin (Key image 2); hind tibia without apical cuplike projection (Figs 
<figureCitation id="F1E3E90D2932323D200EEA3FF941212C" captionStart="Figure 2" captionStartId="F2" captionText="Figure 2. Retusigaster pulawskii sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal propodeum to T 3 E wings F dorsal mesosoma G mesopleuron and metapleuron." figureDoi="10.3897/zookeys.1092.80560.figure2" httpUri="https://binary.pensoft.net/fig/668119" pageId="0" pageNumber="47">2A</figureCitation>
, 
<figureCitation id="C59CCC2DD9CE2EA3763EE76227255B7D" captionStart="Figure 3" captionStartId="F3" captionText="Figure 3. Retusigaster purshi sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal mesosoma E forewing." figureDoi="10.3897/zookeys.1092.80560.figure3" httpUri="https://binary.pensoft.net/fig/668120" pageId="0" pageNumber="47">3A</figureCitation>
, 
<figureCitation id="61B3EA565EFDE261AEAB79F3228FE380" captionStart="Figure 5" captionStartId="F5" captionText="Figure 5. Retusigaster vanduzeei sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal head E lateral head F wings G mesopleuron and metapleuron H scutellum to T 3." figureDoi="10.3897/zookeys.1092.80560.figure5" httpUri="https://binary.pensoft.net/fig/668122" pageId="0" pageNumber="47">5A</figureCitation>
); ovipositor and ovipositor sheath short (Figs 
<figureCitation id="1AA02BCB70CC06311EB3904DB3451E06" captionStart="Figure 2" captionStartId="F2" captionText="Figure 2. Retusigaster pulawskii sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal propodeum to T 3 E wings F dorsal mesosoma G mesopleuron and metapleuron." figureDoi="10.3897/zookeys.1092.80560.figure2" httpUri="https://binary.pensoft.net/fig/668119" pageId="0" pageNumber="47">2A</figureCitation>
, 
<figureCitation id="3698BAE7F994FD41425300E7E7D26455" captionStart="Figure 3" captionStartId="F3" captionText="Figure 3. Retusigaster purshi sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal mesosoma E forewing." figureDoi="10.3897/zookeys.1092.80560.figure3" httpUri="https://binary.pensoft.net/fig/668120" pageId="0" pageNumber="47">3A</figureCitation>
, 
<figureCitation id="B3C3BAB82B8E5B0A3EADE5FA33B0C670" captionStart="Figure 5" captionStartId="F5" captionText="Figure 5. Retusigaster vanduzeei sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal head E lateral head F wings G mesopleuron and metapleuron H scutellum to T 3." figureDoi="10.3897/zookeys.1092.80560.figure5" httpUri="https://binary.pensoft.net/fig/668122" pageId="0" pageNumber="47">5A</figureCitation>
); hypopygium entirely sclerotized and ventro-apically blunt (Figs 
<figureCitation id="DAA515C7D1393578EAC22A4CECD93E8F" captionStart="Figure 2" captionStartId="F2" captionText="Figure 2. Retusigaster pulawskii sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal propodeum to T 3 E wings F dorsal mesosoma G mesopleuron and metapleuron." figureDoi="10.3897/zookeys.1092.80560.figure2" httpUri="https://binary.pensoft.net/fig/668119" pageId="0" pageNumber="47">2A</figureCitation>
, 
<figureCitation id="7D1B94FFAEA961B18C8D44241577D632" captionStart="Figure 3" captionStartId="F3" captionText="Figure 3. Retusigaster purshi sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal mesosoma E forewing." figureDoi="10.3897/zookeys.1092.80560.figure3" httpUri="https://binary.pensoft.net/fig/668120" pageId="0" pageNumber="47">3A</figureCitation>
, 
<figureCitation id="97BEBAF2C0F77FED61C1EBCB89A2275B" captionStart="Figure 5" captionStartId="F5" captionText="Figure 5. Retusigaster vanduzeei sp. nov. A lateral habitus B dorsal habitus C anterior head D dorsal head E lateral head F wings G mesopleuron and metapleuron H scutellum to T 3." figureDoi="10.3897/zookeys.1092.80560.figure5" httpUri="https://binary.pensoft.net/fig/668122" pageId="0" pageNumber="47">5A</figureCitation>
).
</paragraph>
</subSubSection>
<subSubSection id="488D73D5C86F0934DCDA3326FC4A96E5" pageId="0" pageNumber="47" type="distribution">
<paragraph id="B3328704D13467F5384AC430A9BF9F11" pageId="0" pageNumber="47">Distribution.</paragraph>
<paragraph id="7847DAE55D7682C3A2E93477498083AC" pageId="0" pageNumber="47">Nearctic region (Canada, USA, Mexico), Neotropical region (Jamaica and Mexico), Palearctic region (Kazakhstan, Mongolia, Turkey, Turkmenistan).</paragraph>
</subSubSection>
<subSubSection id="DA6108696B7506ACD1FA4BE39434D372" pageId="0" pageNumber="47" type="biology_ecology">
<paragraph id="88D76FA1D0DE2CFC3660D55CA6082C8D" pageId="0" pageNumber="47">Biology.</paragraph>
<paragraph id="4D7CFB0A4C5AAE636BE11021A0C3D451" pageId="0" pageNumber="47">
Potential food sources of two species of 
<taxonomicName id="7556538528CC9B39ABA0F1FD1FB07B98" authorityName="Dangerfield, Austin &amp; Whitfield" authorityYear="1999" class="Insecta" family="Braconidae" genus="Retusigaster" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Retusigaster" order="Hymenoptera" pageId="0" pageNumber="47" phylum="Arthropoda" rank="genus">
<emphasis id="87D103943D3F13C6BA8C20E63454D4A3" italics="true" pageId="0" pageNumber="47">Retusigaster</emphasis>
</taxonomicName>
are found. A member of 
<taxonomicName id="4471F6DCF367011E1D3DA7FDFAAFC7E1" class="Insecta" genus="R." kingdom="Animalia" lsidName="R. arugosus" order="Hymenoptera" pageId="0" pageNumber="47" phylum="Arthropoda" rank="species" species="arugosus">
<emphasis id="D14AC2E73B6139DA73D88222F8FAA9B6" italics="true" pageId="0" pageNumber="47">R. arugosus</emphasis>
</taxonomicName>
was collected on cotton (
<taxonomicName id="A4A82976DAEEA4BA5816338C4C03CE6A" class="Magnoliopsida" family="Malvaceae" genus="Gossypium" kingdom="Plantae" lsidName="Gossypium" order="Malvales" pageId="0" pageNumber="47" phylum="Tracheophyta" rank="genus">
<emphasis id="378042B01B59BD45614575CE78BC3E20" italics="true" pageId="0" pageNumber="47">Gossypium</emphasis>
</taxonomicName>
sp.; 
<taxonomicName id="F80ED8EF4E7AF2652A7EBDF49E8CEEBB" class="Magnoliopsida" family="Malvaceae" genus="Gossypium" kingdom="Plantae" lsidName="" order="Malvales" pageId="0" pageNumber="47" phylum="Tracheophyta" rank="family">Malvaceae</taxonomicName>
) in Texas, and a specimen of 
<taxonomicName id="D6B0CDDF768E8368D84E9049C4013082" class="Insecta" genus="R." kingdom="Animalia" lsidName="R. purshi" order="Hymenoptera" pageId="0" pageNumber="47" phylum="Arthropoda" rank="species" species="purshi">
<emphasis id="2275C938C1C4DA95C2E675F96A5C6621" italics="true" pageId="0" pageNumber="47">R. purshi</emphasis>
</taxonomicName>
sp. nov. was collected on Mexican cliffrose (
<taxonomicName id="EE1443D8CFBCC2068A4AC59A23024449" class="Magnoliopsida" family="Rosaceae" genus="Purshia" kingdom="Plantae" lsidName="Purshia mexicana" order="Rosales" pageId="0" pageNumber="47" phylum="Tracheophyta" rank="species" species="mexicana">
<emphasis id="4611EA4513087E36BC85F88C6F52AD68" italics="true" pageId="0" pageNumber="47">Purshia mexicana</emphasis>
</taxonomicName>
(D. Don) S. L. Welsh; 
<taxonomicName id="15AC353FEE5CD1341C323AC84DED6FC2" class="Magnoliopsida" family="Rosaceae" genus="Purshia" kingdom="Plantae" lsidName="" order="Rosales" pageId="0" pageNumber="47" phylum="Tracheophyta" rank="family">Rosaceae</taxonomicName>
) in Nevada.
</paragraph>
</subSubSection>
