<subSubSection id="44C472C3864AC3582C7EA72317B6FA9C" pageId="0" pageNumber="432" type="diagnosis">
<paragraph id="0C612148864AC3582C7EA7231789FD58" blockId="0.[1026,2008,615,696]" box="[1027,2007,615,682]" pageId="0" pageNumber="432">(TITIS, SAKIS AND UACARIS)</paragraph>
<paragraph id="0C612148864AC3582CB2A7BB174EFC4F" blockId="0.[1231,2110,767,957]" pageId="0" pageNumber="432">* Small to medium-sized monkeys with hindlimbs longer than forelimbs, short canines or robust anterior dentition with large, splayed canines, short, dense or long, soft, coarse fur, and tail tapering, longer than body, long and bushy, or short and bushy.</paragraph>
<caption id="58A171C0864AC3582CB2A68715C0FC16" ID-DOI="http://doi.org/10.5281/zenodo.6632291" ID-Zenodo-Dep="6632291" box="[1231,1438,963,996]" httpUri="https://zenodo.org/record/6632291/files/figure.png" inLine="true" pageId="0" pageNumber="432" startId="0.[1231,1244,963,996]" targetBox="[1590,1871,972,1161]" targetPageId="0">
<paragraph id="0C612148864AC3582CB2A68715C0FC16" blockId="0.[1231,1571,963,1154]" box="[1231,1438,963,996]" pageId="0" pageNumber="432">• 70-100 cm.</paragraph>
</caption>
<caption id="58A171C0864AC3582CB2A125167DFB70" ID-DOI="http://doi.org/10.5281/zenodo.6632293" ID-Zenodo-Dep="6632293" box="[1231,1571,1121,1154]" httpUri="https://zenodo.org/record/6632293/files/figure.png" inLine="true" pageId="0" pageNumber="432" startId="0.[1231,1244,1121,1154]" targetBox="[223,1158,776,1393]" targetPageId="0">
<paragraph id="0C612148864AC3582CB2A125167DFB70" blockId="0.[1231,1571,963,1154]" box="[1231,1571,1121,1154]" pageId="0" pageNumber="432">* Neotropical Region</paragraph>
</caption>
<paragraph id="0C612148864AC3582CB2A1CC15CEFB0B" blockId="0.[1231,2110,1160,1390]" pageId="0" pageNumber="432">* Humid submontane and lowland tropical, dry semideciduous and deciduous, gallery, and Chacoan forests and scrub.</paragraph>
<paragraph id="0C612148864AC3582CB2A04617DAFAED" blockId="0.[1231,2110,1160,1390]" box="[1231,1924,1282,1311]" pageId="0" pageNumber="432">* 4 genera, 44 species, at least 52 extant taxa.</paragraph>
<paragraph id="0C612148864AC3582CB2A06217B6FA9C" blockId="0.[1231,2110,1160,1390]" pageId="0" pageNumber="432">* 4 species Critically Endangered, 5 species Endangered, 6 species Vulnerable; 1 species Extinct since 1600.</paragraph>
</subSubSection>
