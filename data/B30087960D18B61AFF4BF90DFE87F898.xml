:— 
<taxonomicName id="FCA94D030D18B61AFD0CF90DFAD4FA44" authority="(Benth.) Small, N. Amer. Fl." authorityName="Small, N. Amer. Fl." baseAuthorityName="Benth." box="[719,1362,1387,1414]" class="Magnoliopsida" family="Linaceae" genus="Hesperolinon" kingdom="Plantae" order="Malpighiales" pageId="2" pageNumber="143" phylum="Tracheophyta" rank="species" species="californicum">
