<treatment id="677FCF20FFFBFFD0FE71FF3AFC83FB92" ID-DOI="http://doi.org/10.5281/zenodo.6450014" ID-GBIF-Taxon="194566179" ID-Zenodo-Dep="6450014" LSID="urn:lsid:plazi:treatment:677FCF20FFFBFFD0FE71FF3AFC83FB92" httpUri="http://treatment.plazi.org/id/677FCF20FFFBFFD0FE71FF3AFC83FB92" lastPageNumber="308" pageId="33" pageNumber="308">
