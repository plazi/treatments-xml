<taxonomicName id="C0E64D0E0B6016517BF6F8672364F812" authorityName="Krapovickas" authorityYear="2014" box="[931,1086,1957,1979]" class="Magnoliopsida" family="Malvaceae" genus="Sida" kingdom="Plantae" order="Malvales" pageId="16" pageNumber="121" phylum="Tracheophyta" rank="species" species="ramoniana">
