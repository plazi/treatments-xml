<taxonomicName id="E1EB4D18FF86FFABF63E21CDFE49FB95" baseAuthorityName="Hendel" baseAuthorityYear="1927" box="[285,398,1007,1028]" class="Insecta" family="Tephritidae" genus="Campiglossa" kingdom="Animalia" order="Diptera" pageId="4" pageNumber="255" phylum="Arthropoda" rank="species" species="loewiana">
