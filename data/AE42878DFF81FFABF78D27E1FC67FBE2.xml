<collectionCode id="40FAAE5EFF86FFABF3A421CCFB79FB95" box="[1159,1214,1006,1028]" country="Ukraine" httpUri="http://grbio.org/cool/c442-9tdv" name="Schmaulhausen Institute of Zoology" pageId="4" pageNumber="255">SIZK</collectionCode>
