<subSubSection id="45F1C611C464D597B7B04C56BDF9E51A" pageId="null" pageNumber="387" type="description">
<paragraph id="E7D8587AEC41FEA36C74BF6CC48811EC" pageId="null" pageNumber="387">
1 
<normalizedToken id="3C27E022BA8863B7728D19DFD03CCF9A" originalValue="jährig" pageId="null" pageNumber="387">jaehrig</normalizedToken>
, 10-30 cm hoch, kahl. Stengel bogig aufsteigend. 
<normalizedToken id="1C6BD96E90FFDFD799DA99E13DEF0B6E" originalValue="Blätter" pageId="null" pageNumber="387">Blaetter</normalizedToken>
ca. 1 mm breit; 
<normalizedToken id="814C85B4A4528C85A2752A0D302C0894" originalValue="Blatthäutchen" pageId="null" pageNumber="387">Blatthaeutchen</normalizedToken>
0,2-1 mm lang, gestutzt, 
<normalizedToken id="56CB493AA2187BE02E5691F3C9F7D3EB" originalValue="gezähnt" pageId="null" pageNumber="387">gezaehnt</normalizedToken>
. 
<normalizedToken id="E5424055846473F58952426A490E9C68" originalValue="Hüllspelze" pageId="null" pageNumber="387">Huellspelze</normalizedToken>
an den seitlichen 
<normalizedToken id="A03ED6990114B600C14F14BAD77FB3CA" originalValue="Ährchen" pageId="null" pageNumber="387">Aehrchen</normalizedToken>
5-6 mm lang, spitz. - 
<normalizedToken id="67ADE522D053C07D37B171CB4DADE3BA" originalValue="Blüte" pageId="null" pageNumber="387">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="AAF79F743B15274F2C42FCEF671B73AD" pageId="null" pageNumber="387">
<emphasis id="6901607BFF74115AC1310BFF1D92B413" italics="true" pageId="null" pageNumber="387">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="BB363BA49E41A75A9EE5ECCCF79023A2" italics="true" pageId="null" pageNumber="387">26:</emphasis>
Material aus botanischen 
<normalizedToken id="75001018922CC3CEADA8362918014BD9" originalValue="Gärten" pageId="null" pageNumber="387">Gaerten</normalizedToken>
(Avdulov 1931).
</paragraph>
<paragraph id="6467BE98C6478046528C2915C6A74209" pageId="null" pageNumber="387">
<emphasis id="EBAE0C7FDEE2D06A3BF874B8F9D65273" italics="true" pageId="null" pageNumber="387">Standort.</emphasis>
Kollin. Trockene, sandige, salzhaltige, offene 
<normalizedToken id="FF2CB0E38CF0378011BA86482348BB4E" originalValue="Böden" pageId="null" pageNumber="387">Boeden</normalizedToken>
. Ruderalstellen, 
<normalizedToken id="0DB702E73179C95B4B9FEC05233485CA" originalValue="Wegränder" pageId="null" pageNumber="387">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="FD5EC2AA8BCC13E308E438E5CDF97B5C" pageId="null" pageNumber="387">
<emphasis id="314C80720A6B42B401F84496E1FFEDF5" italics="true" pageId="null" pageNumber="387">Verbreitung. Mediterrane Pflanze:</emphasis>
Ganzes Mediterrangebiet; nach Nordamerika verschleppt. - Im Gebiet: Aostatal, sonst selten adventiv auf Bahnarealen.
</paragraph>
