<subSubSection id="A20211CD6EBB6C39377EAE59018B81D7" pageId="null" pageNumber="510" type="vernacular_names">
<paragraph id="5FFC6324BE42239AAEE07AF5E790C489" pageId="null" pageNumber="510">Belaubter Zweizahn</paragraph>
</subSubSection>
</title>
<subSubSection id="C2711719B6399BC1D6017072C1148A1F" pageId="null" pageNumber="510" type="description">
<paragraph id="2E638F687EF9DC4A5BFE33E0FEFA3348" pageId="null" pageNumber="510">
1 
<normalizedToken id="3BD5B6D00045B994860F1D6E71FC112A" originalValue="jährig" pageId="null" pageNumber="510">jaehrig</normalizedToken>
, mit 
<normalizedToken id="8FB5DC82A1D9BC3D1E3DC7501F35CE65" originalValue="dünner" pageId="null" pageNumber="510">duenner</normalizedToken>
Wurzel; 10-100 cm hoch. Stengel verzweigt, braunrot, meist kahl. 
<emphasis id="E8C9DB2B8CEB63ADBC956D2A50741DDD" italics="true" pageId="null" pageNumber="510">
<normalizedToken id="7A723D1D9C94F31C0A7005D7B3F423D3" originalValue="Blätter" pageId="null" pageNumber="510">Blaetter</normalizedToken>
mit langem, nicht 
<normalizedToken id="637DE18B3063B4CE4683B77E78444E17" originalValue="geflügeltem" pageId="null" pageNumber="510">gefluegeltem</normalizedToken>
Stiel
</emphasis>
, oft 
<normalizedToken id="EA6B80F28192A36A9FE4844C52915874" originalValue="rötlich" pageId="null" pageNumber="510">roetlich</normalizedToken>
, kahl, nur am Rande von kurzen, nach vorn gerichteten Haaren rauh, 
<emphasis id="2BCD5119F08EB5A9F526D43C46970AA1" italics="true" pageId="null" pageNumber="510">gefiedert</emphasis>
, mit 3-5 
<emphasis id="12B6F33CFDDE9CCD243ACEC7D8E0D544" italics="true" pageId="null" pageNumber="510">gestielten</emphasis>
, lanzettlichen, lang zugespitzten, 
<normalizedToken id="C651C956468EA2885EC04D660D21D3E2" originalValue="gezähnten" pageId="null" pageNumber="510">gezaehnten</normalizedToken>
<normalizedToken id="3319C999E9A97759E5F08E3F33DCE1CE" originalValue="Teilblättern" pageId="null" pageNumber="510">Teilblaettern</normalizedToken>
; 
<emphasis id="F95BE98931702E7A2848B47413926056" italics="true" pageId="null" pageNumber="510">
<normalizedToken id="D5DF4449385758E27AA491CB6B2B04E6" originalValue="Zähne" pageId="null" pageNumber="510">Zaehne</normalizedToken>
in eine feine Spitze 
<normalizedToken id="8CF1321086EA2D068D6C2BCF246585C5" originalValue="verlängert" pageId="null" pageNumber="510">verlaengert</normalizedToken>
</emphasis>
, nach vorn gerichtet. 
<normalizedToken id="7B2CA0D3552EED4B4E07EC88CE6F44A7" originalValue="Köpfe" pageId="null" pageNumber="510">Koepfe</normalizedToken>
aufrecht, im Durchmesser 1-2 cm, mit oder ohne gelbe, 
<normalizedToken id="32B1209A2F294B5E1BB7756821FB2645" originalValue="zungenförmige" pageId="null" pageNumber="510">zungenfoermige</normalizedToken>
<normalizedToken id="F6BD4010398D5AE11686992461729EAD" originalValue="Blüten" pageId="null" pageNumber="510">Blueten</normalizedToken>
. 
<normalizedToken id="7AB4084038BFC21DD5FA1772611299FB" originalValue="Äußere" pageId="null" pageNumber="510">Aeussere</normalizedToken>
<normalizedToken id="0523A094C9BD3BB504A6540AE42151A4" originalValue="Hüllblätter" pageId="null" pageNumber="510">Huellblaetter</normalizedToken>
5-8, am Rande zerstreut bewimpert, 
<emphasis id="FA586684F193287F34DE6843C5864EA1" italics="true" pageId="null" pageNumber="510">5</emphasis>
- 
<emphasis id="DD6D0E864557E4FEC2149D39135DD105" italics="true" pageId="null" pageNumber="510">20 mm lang</emphasis>
und 1-3 mm breit; innere 
<normalizedToken id="0A0DB63771F6D228B9B29259DE7295D3" originalValue="Hüllblätter" pageId="null" pageNumber="510">Huellblaetter</normalizedToken>
6-12, braun, 5-9 mm lang. 
<normalizedToken id="C44329CDD8398578956B12B3FFA27C2C" originalValue="Früchte" pageId="null" pageNumber="510">Fruechte</normalizedToken>
4kantig, flach, mit einzelnen, anliegenden, 
<emphasis id="BF0A013B46C460660865E17F7E9BDB1C" italics="true" pageId="null" pageNumber="510">nach vorn gerichteten Haaren</emphasis>
, 
<normalizedToken id="E581A3AE9912E3D13FA9949E967A71A3" originalValue="höckerig" pageId="null" pageNumber="510">hoeckerig</normalizedToken>
, 6-10 mm lang und 2-4 mm breit. 
<emphasis id="05FAB23427956FFBBDBCEA1E8E33BAC7" italics="true" pageId="null" pageNumber="510">Borsten meist 2</emphasis>
, 2,5-5 mm lang. - 
<normalizedToken id="F939D4C98284C611685EE3FDBBD217BA" originalValue="Blüte" pageId="null" pageNumber="510">Bluete</normalizedToken>
: 
<normalizedToken id="03A16711E60B8C6C76B85BAA12F3B279" originalValue="Später" pageId="null" pageNumber="510">Spaeter</normalizedToken>
Sommer und Herbst.
</paragraph>
<paragraph id="792E0C7733D54B08AD8CAD139013335D" pageId="null" pageNumber="510">
<emphasis id="206BC5840330D1D1BE2C8F34AB816488" italics="true" pageId="null" pageNumber="510">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="6BC8BA95863BBEC9AC3C2E6DC01DA630" italics="true" pageId="null" pageNumber="510">48:</emphasis>
Material aus Schleswig-Holstein (Scheerer 1940), aus botanischem Garten (mit Chromosomenanalyse: Huziwara 1955), aus Manitoba (
<normalizedToken id="63FE925697E6E62DD5922328FB32A71D" originalValue="Löve" pageId="null" pageNumber="510">Loeve</normalizedToken>
und 
<normalizedToken id="0971D4A343B2B31796C2ED86FC0B2CF4" originalValue="Löve" pageId="null" pageNumber="510">Loeve</normalizedToken>
1964), aus den USA (Mangaly et al. in 
<normalizedToken id="05AD8CA57D6D33428E083522C31CD814" originalValue="Löve" pageId="null" pageNumber="510">Loeve</normalizedToken>
1967), aus Portugal (Fernandes und Queiros 1970-1971).
</paragraph>
<paragraph id="C172175E8C7064EA2DBF2A1AF1D4B726" pageId="null" pageNumber="510">
<emphasis id="56F4CDFEE2FF89F7A6880AF5A57E2EA3" italics="true" pageId="null" pageNumber="510">Standort.</emphasis>
Kollin. Feuchte, zeitweise 
<normalizedToken id="633B05A4B7E8B7E930CE011668B930EC" originalValue="überschwemmte" pageId="null" pageNumber="510">ueberschwemmte</normalizedToken>
, 
<normalizedToken id="6CD3B067BD7A983164543BC9D07803C5" originalValue="nährstoffreiche" pageId="null" pageNumber="510">naehrstoffreiche</normalizedToken>
, humose, sandige 
<normalizedToken id="7124C5D4BE6250F09BEB702C5A8BD83F" originalValue="Böden" pageId="null" pageNumber="510">Boeden</normalizedToken>
. 
<normalizedToken id="2D307B3FBE24DA405A91AA680D1D4A6A" originalValue="Flußufer" pageId="null" pageNumber="510">Flussufer</normalizedToken>
, Seeufer, 
<normalizedToken id="E19D3E80782598954686AB1227C1765C" originalValue="Schuttplätze" pageId="null" pageNumber="510">Schuttplaetze</normalizedToken>
. 
<emphasis id="A521580FBD83F0C3961CE1A5EFD3B066" italics="true" pageId="null" pageNumber="510">Polygono-Bidentetum</emphasis>
(W. Kreh) Lohm. 1950.
</paragraph>
<paragraph id="D3DB138E3F39AEB9B955735C436A167A" pageId="null" pageNumber="510">
<emphasis id="CD295035C7438418A290A3F2270D212B" italics="true" pageId="null" pageNumber="510">Verbreitung. Nordamerikanische Pflanze;</emphasis>
in 
<normalizedToken id="FCEE64B5C0BB98114FD36401F3EA12C1" originalValue="Südeuropa" pageId="null" pageNumber="510">Suedeuropa</normalizedToken>
eingeschleppt. - Im Gebiet: Oberrheinische Tiefebene, Aostatal (Ivrea), Misox, 
<normalizedToken id="2075547834341E4C1D7FBF0E2551A342" originalValue="südliches" pageId="null" pageNumber="510">suedliches</normalizedToken>
Tessin und angrenzende italienische Gebiete; in Ausbreitung begriffen.
</paragraph>
<paragraph id="D2546E660AC12EBCFA71617C05919085" pageId="null" pageNumber="510">
<emphasis id="AC008F837F61A495CCE174E3A39CC98A" italics="true" pageId="null" pageNumber="510">
Bemerkungen. 
<taxonomicName id="B6F96E1623DA9EDE36829F9D8C00C4CC" class="Magnoliopsida" family="Asteraceae" genus="Bidens" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="510" phylum="Tracheophyta" rank="species" species="frondosa">B. frondosa</taxonomicName>
</emphasis>
ist im Gebiet erst seit 1946 bekannt.
</paragraph>
</subSubSection>
