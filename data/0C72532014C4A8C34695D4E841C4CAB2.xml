<paragraph id="BC10948B044C56ABB58B877CB1007D31" pageId="null" pageNumber="546">
Neubelgische 
<taxonomicName id="3400606BE458044C166FCB9D3E211025" class="Magnoliopsida" family="Asteraceae" genus="Aster" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="546" phylum="Tracheophyta" rank="genus">Aster</taxonomicName>
