<taxonomicName id="314717800AF36DD9B5A7D9B6DECC0DE6" authority="L." class="Magnoliopsida" family="Plantaginaceae" genus="Gratiola" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="182" phylum="Tracheophyta" rank="species" species="officinalis">
