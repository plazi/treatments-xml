</title>
<subSubSection id="DB1D3A89486E9373975431164CD3E79A" lastPageNumber="362" pageId="null" pageNumber="363" type="description">
<paragraph id="477BDB87D5F1C637701AD48CE52657C8" pageId="null" pageNumber="363">
1 
<normalizedToken id="CFC3951FF0D8AED550739031BAD5EBF9" originalValue="jährig" pageId="null" pageNumber="363">jaehrig</normalizedToken>
(unsere Arten) oder ausdauernd. Stengel meist niederliegend oder kletternd, 
<emphasis id="48ECA35FEC84AEE4803399C1A39E0A5D" italics="true" pageId="null" pageNumber="363">mit 1fachen Ranken.</emphasis>
<normalizedToken id="E4EB811F344D306E1E0EA2110B2A7102" originalValue="Blüten" pageId="null" pageNumber="363">Blueten</normalizedToken>
1 
<normalizedToken id="565DFB94700CCCB52E430896AB12A783" originalValue="häusig" pageId="null" pageNumber="363">haeusig</normalizedToken>
. ♂ 
<normalizedToken id="14DA4BF2C54B37AF56E503D46EB94D01" originalValue="Blüten" pageId="null" pageNumber="363">Blueten</normalizedToken>
gestielt, zu 1-6 in den Blattachseln; ♀ 
<normalizedToken id="9D9D7A76F1BB676EF5FF96471146BAB8" originalValue="Blüten" pageId="null" pageNumber="363">Blueten</normalizedToken>
gestielt, einzeln in Blattachseln. Kronen der ♂ 
<normalizedToken id="9773987618FB62EABD31D57FB5686BC5" originalValue="Blüten" pageId="null" pageNumber="363">Blueten</normalizedToken>
und der ♀ 
<normalizedToken id="F40AB168A4E75FD625733F6E4FA85AEB" originalValue="Blüten" pageId="null" pageNumber="363">Blueten</normalizedToken>
fast gleich 
<normalizedToken id="841AACF284E65B7ADD2C98353D810F6B" originalValue="groß" pageId="null" pageNumber="363">gross</normalizedToken>
, 
<emphasis id="F70DBE6A6DEC26BFC9C110E9CC796245" italics="true" pageId="null" pageNumber="363">fast flach ausgebreitet</emphasis>
, bis etwa zur Mitte geteilt. 
<normalizedToken id="EA0668727A41F1E555484612C5EB1D6D" originalValue="Staubblätter" pageId="null" pageNumber="363">Staubblaetter</normalizedToken>
3, 
<emphasis id="7D878D80AD1FC08D8811FAEC4D5476C5" italics="true" pageId="null" pageNumber="363">
mit freien 
<normalizedToken id="E40780846BCFD30EDD1B54A7803810FB" originalValue="Staubfäden" pageId="null" pageNumber="363">Staubfaeden</normalizedToken>
und freien Staubbeuteln.
</emphasis>
Frucht 3-5 
<normalizedToken id="7F348B04F2D7FE48D7BCBF2A50059C8E" originalValue="fächerig" pageId="null" pageNumber="363">faecherig</normalizedToken>
, meist 
<normalizedToken id="6CC4E8562B521F612001931BFF826B90" originalValue="groß" pageId="null" pageNumber="363">gross</normalizedToken>
, vielsamig. Samen flach, im 
<normalizedToken id="D6FEC7D609915527529F0B2D86B04B04" originalValue="Umriß" pageId="null" pageNumber="363">Umriss</normalizedToken>
oval, ohne verdickten Rand.
</paragraph>
<paragraph id="F869823ECB976D04C06C14F6E125BCCF" pageId="null" pageNumber="363">
Die Gattung 
<taxonomicName id="8547D079031BFDAD10B20FD0F4533DAD" class="Magnoliopsida" family="Cucurbitaceae" genus="Cucumis" kingdom="Plantae" order="Cucurbitales" pageId="null" pageNumber="363" phylum="Tracheophyta" rank="genus">
<emphasis id="18C97CA3540DFE1518F19A874C429AA4" italics="true" pageId="null" pageNumber="363">Cucumis</emphasis>
</taxonomicName>
<normalizedToken id="5726B80635DC433C43C326D6669B79D3" originalValue="umfaßt" pageId="null" pageNumber="363">umfasst</normalizedToken>
<emphasis id="B0F8FB47D2F633E1900227F2A52322AA" italics="true" pageId="null" pageNumber="363">etwa 40 Arten und ist vorwiegend in Afrika verbreitet. Chromosomengrundzahl:</emphasis>
n = 12.
</paragraph>
<paragraph id="1799181357312D37886F57AC4A0341E5" pageId="null" pageNumber="362">
<table id="7D54EDFD9B2E88249361BBE41165DDD0" frame="void" pageId="null" pageNumber="362" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="AFAA066E1FD5EAA1A150CC521557EFAB" pageId="null" pageNumber="362">
<tr id="F50535BABA7E954D903F56E9AA001F49" pageId="null" pageNumber="362">
<td id="DA8941CD2768A94591538759C97FEE2D" align="left" pageId="null" pageNumber="362" valign="top">
<pageBreakToken id="C9F1790FF58DF6C97D19C464781F37BD" pageId="null" pageNumber="362" start="start">1</pageBreakToken>
. 
<normalizedToken id="52981652E402C15B4A52EC1942A14C67" originalValue="Früchte" pageId="null" pageNumber="362">Fruechte</normalizedToken>
zylindrisch bis schmal 
<normalizedToken id="8C234906D65C0A46CA42D62E99CE15B8" originalValue="eiförmig" pageId="null" pageNumber="362">eifoermig</normalizedToken>
, oft 
<normalizedToken id="9C6DBAFBFADE5EBD64D7E9FB579BA1C3" originalValue="gekrümmt" pageId="null" pageNumber="362">gekruemmt</normalizedToken>
, undeutlich 3-6kantig; Kelchzipfel so lang oder 
<normalizedToken id="35A677659A5BDB0DCE2603DA2B7C2C69" originalValue="länger" pageId="null" pageNumber="362">laenger</normalizedToken>
als die 
<normalizedToken id="D4C828F94F1610909617DBF004CA3D50" originalValue="becherförmige" pageId="null" pageNumber="362">becherfoermige</normalizedToken>
<normalizedToken id="A3D5BF510D0FC04D023A9E99D349B99D" originalValue="Kronröhre" pageId="null" pageNumber="362">Kronroehre</normalizedToken>
</td>
<td id="267BADE57B78E880D91F6D071F2CD8C3" align="left" pageId="null" pageNumber="362" valign="bottom">
<taxonomicName id="431C21579C537778A5A80AC40B38C3FB" class="Magnoliopsida" family="Cucurbitaceae" genus="Cucumis" kingdom="Plantae" order="Cucurbitales" pageId="null" pageNumber="362" phylum="Tracheophyta" rank="species" species="sativus">
<italic id="CD48B9D8A46A12788038132A4CD24836" pageId="null" pageNumber="362">C. sativus</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="723293DA3322C39C9AABB00A87266A91" pageId="null" pageNumber="362">
<td id="CAB1AA6ECEE10DDDA37DF1003FA6DFB3" align="left" pageId="null" pageNumber="362" valign="top">
1*. 
<normalizedToken id="61C5E8E5A7FEDAC2939B9144539B5E92" originalValue="Früchte" pageId="null" pageNumber="362">Fruechte</normalizedToken>
kugelig bis 
<normalizedToken id="B1C293A92976F152A1A52FEC6F84877B" originalValue="eiförmig" pageId="null" pageNumber="362">eifoermig</normalizedToken>
, ohne Kanten, aber mit Rillen; Kelchzipfel 
<normalizedToken id="75950A5ECBE62A55E4B8BCE88A72A06D" originalValue="kürzer" pageId="null" pageNumber="362">kuerzer</normalizedToken>
als die 
<normalizedToken id="2EC247B6F47E61FFA801233BD0AFB818" originalValue="Kelchröhre" pageId="null" pageNumber="362">Kelchroehre</normalizedToken>
</td>
<td id="6C0CED9E66E53B868F9F0728BA50D916" align="left" pageId="null" pageNumber="362" valign="bottom">
<taxonomicName id="2FEA1E98F64B275476AEC56C438CD72C" class="Magnoliopsida" family="Cucurbitaceae" genus="Cucumis" kingdom="Plantae" order="Cucurbitales" pageId="null" pageNumber="362" phylum="Tracheophyta" rank="species" species="melo">
<italic id="D142DF73AF2DC0B95D73BEA95DEEE8A0" pageId="null" pageNumber="362">C. Melo</italic>
</taxonomicName>
(Nr. 2)
</td>
</tr>
</tbody>
</table>
</paragraph>
