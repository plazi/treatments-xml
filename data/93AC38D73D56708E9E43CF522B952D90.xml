<subSubSection id="9B6DA6C15809B90B2068D9FAC3AC5F6A" pageId="null" pageNumber="195" type="description">
<paragraph id="AEC8F406EE14F642EB6C84AB508B9AD0" pageId="null" pageNumber="195">
Unterscheidet sich von 
<taxonomicName id="B16F6673E407B2EE5ED772A7E2878D15" class="Liliopsida" family="Potamogetonaceae" genus="Potamogeton" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="195" phylum="Tracheophyta" rank="species" species="natans">
<emphasis id="F0DE575D83EE92857701966BED678560" italics="true" pageId="null" pageNumber="195">P. natans</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: Glieder nicht knollig verdickt; 
<emphasis id="E74805414233889EC00C2FC30DBAB166" italics="true" pageId="null" pageNumber="195">
untergetauchte 
<normalizedToken id="8E03ED84961774AC40ACD7361D1B416F" originalValue="Blätter" pageId="null" pageNumber="195">Blaetter</normalizedToken>
lanzettlich, durchsichtig, meist lang gestielt, zur 
<normalizedToken id="C6034CAE91981B96384F77AFAC76B599" originalValue="Blütezeit" pageId="null" pageNumber="195">Bluetezeit</normalizedToken>
noch vorhanden; 
<normalizedToken id="B8D168393A3EBC180FB0A9AD43722E84" originalValue="Schwimmblätter" pageId="null" pageNumber="195">Schwimmblaetter</normalizedToken>
meist nur 1
</emphasis>
<normalizedToken id="37A5C75B99926725F2144971CD480BA3" originalValue="½" pageId="null" pageNumber="195">1/2</normalizedToken>
<emphasis id="69960A67D92279AA44D30FF08CB359CA" italics="true" pageId="null" pageNumber="195">
mal so lang wie breit, einzelne am Grunde 
<normalizedToken id="8CFEA2B6836D118499D56C8FC9C694D3" originalValue="herzförmig" pageId="null" pageNumber="195">herzfoermig</normalizedToken>
</emphasis>
, weniger derb als bei 
<taxonomicName id="2B84472330141B75C931DBE32DCF0767" class="Liliopsida" family="Potamogetonaceae" genus="Potamogeton" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="195" phylum="Tracheophyta" rank="species" species="natans">
<emphasis id="E375A3927718A46B951E7E016A8EA430" italics="true" pageId="null" pageNumber="195">P. natans</emphasis>
</taxonomicName>
(Nr. 1); 
<normalizedToken id="D4526C17041C6C769AC7BD175B708C23" originalValue="Blatthäutchen" pageId="null" pageNumber="195">Blatthaeutchen</normalizedToken>
stets 
<normalizedToken id="CFC4AEA207E8562959D56B5148979596" originalValue="kürzer" pageId="null" pageNumber="195">kuerzer</normalizedToken>
als der Blattstiel; 
<emphasis id="AB55F85313A03152CBADDD5954D21049" italics="true" pageId="null" pageNumber="195">
<normalizedToken id="72A9A5D89E738C435AAD2CDA68DAB2A4" originalValue="Früchtchen" pageId="null" pageNumber="195">Fruechtchen</normalizedToken>
2-2,5 mm lang. -
</emphasis>
<normalizedToken id="C50C807913AFAB120905FCE61F7414CF" originalValue="Blüte" pageId="null" pageNumber="195">Bluete</normalizedToken>
: 
<normalizedToken id="5C8F9BAA4C8080933DD0D02A4F4A5E60" originalValue="Früher" pageId="null" pageNumber="195">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="981B4156C5D388E9FEA33F3ED09ED3C4" pageId="null" pageNumber="195">
<emphasis id="E5209D35B806B1F352BB238E0627C0AA" italics="true" pageId="null" pageNumber="195">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="10C6C1D9738011FB2C64199F81BBD503" italics="true" pageId="null" pageNumber="195">26:</emphasis>
Material aus Schweden (Palmgren 1939), aus Portugal (Fernandes 1950), aus Japan (Harada 1956).
</paragraph>
<paragraph id="DBDA944C0A4209607C5993B8D69C6A6E" pageId="null" pageNumber="195">
<emphasis id="A7CF256F5C149027023714234C815020" italics="true" pageId="null" pageNumber="195">Standort.</emphasis>
Kollin. Langsam 
<normalizedToken id="B68B02660FE2DCAC043D0C97AFB8AB97" originalValue="fließende" pageId="null" pageNumber="195">fliessende</normalizedToken>
, 
<normalizedToken id="41DB0FC8E26844DA57E44E84EBF834AA" originalValue="nährstoffarme" pageId="null" pageNumber="195">naehrstoffarme</normalizedToken>
, kalkfreie 
<normalizedToken id="A2CB956DF74337AE0C28EE4578BC93D0" originalValue="Bäche" pageId="null" pageNumber="195">Baeche</normalizedToken>
.
</paragraph>
<paragraph id="DC393AF786FD70DF9579F97FDF4BF1A1" pageId="null" pageNumber="195">
<emphasis id="1F5FD77E59C214F792AE6722CBB4D6FA" italics="true" pageId="null" pageNumber="195">
Verbreitung. West- und 
<normalizedToken id="4C2A2100FBB23838217835E02B705539" originalValue="südeuropäische" pageId="null" pageNumber="195">suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="029D7A7A7D206F0E4020C40DD56D0E79" originalValue="Nordwärts" pageId="null" pageNumber="195">Nordwaerts</normalizedToken>
der atlantischen 
<normalizedToken id="959759C1DE176AFAE9AE0A3018AA1DDC" originalValue="Küste" pageId="null" pageNumber="195">Kueste</normalizedToken>
entlang bis Nordnorwegen, 
<normalizedToken id="12B8008CFA01532B709D87C857BB102F" originalValue="südwärts" pageId="null" pageNumber="195">suedwaerts</normalizedToken>
bis Nordafrika, 
<normalizedToken id="9E3C8E45E5507C2D1BCB600588D21579" originalValue="ostwärts" pageId="null" pageNumber="195">ostwaerts</normalizedToken>
bis ins Baltikum und die 
<normalizedToken id="9509C28934745E78305C5A790B175451" originalValue="Küstengebiete" pageId="null" pageNumber="195">Kuestengebiete</normalizedToken>
Kleinasiens; in Nordamerika nur an der 
<normalizedToken id="42482279908E2FAE629D39FDC383D008" originalValue="Ostküste" pageId="null" pageNumber="195">Ostkueste</normalizedToken>
von Neufundland. Verbreitungskarten von 
<normalizedToken id="79469539539A4EDB1F302255DC86A2EF" originalValue="Hultén" pageId="null" pageNumber="195">Hulten</normalizedToken>
(1958) und Meusel (1964). Sehr nahe verwandte Sippe in 
<normalizedToken id="0F71F646A318C8173D109351D5106661" originalValue="Südasien" pageId="null" pageNumber="195">Suedasien</normalizedToken>
und im Himalaja. - Im Gebiet: Savoyen (Annecy), 
<normalizedToken id="05B18E7FA556903B7034D668C4E68249" originalValue="südliches" pageId="null" pageNumber="195">suedliches</normalizedToken>
Tessin (nach Becherer 1960 noch 7 Fundorte, im Muzzanersee erloschen), Gegend von Varese, Vogesen, 
<normalizedToken id="2B77DF0BFAEFBDAA43D69A19DD4FC64E" originalValue="früher" pageId="null" pageNumber="195">frueher</normalizedToken>
bei Genf.
</paragraph>
</subSubSection>
