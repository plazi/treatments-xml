<subSubSection id="88DADD5B229614CFD7D97751785A3112" pageId="null" pageNumber="351" type="nomenclature">
<paragraph id="1FBF615CA85156A75B6B84CA6B847E56" pageId="null" pageNumber="351">
<taxonomicName id="8905451AB14C94502C88D40A6D9C3452" authority="Roem. et Schult." class="Liliopsida" family="Poaceae" genus="Festuca" kingdom="Plantae" order="Poales" pageId="null" pageNumber="351" phylum="Tracheophyta" rank="species" species="alpestris">
Festuca 
<normalizedToken id="3AC15607686F7A7B92C5D059C61B5B34" originalValue="alpéstris" pageId="null" pageNumber="351">alpestris</normalizedToken>
Roem. et Schult.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="1FD477E5E30152422DFDCA3F92FE64AA" pageId="null" pageNumber="351" type="vernacular_names">
<paragraph id="3C1655430426C7256C9689C8A548DB13" pageId="null" pageNumber="351">Berg-Schwingel</paragraph>
</subSubSection>
</title>
<subSubSection id="A04AE6B0110A435CB07410503F76389C" pageId="null" pageNumber="351" type="description">
<paragraph id="4D8A87ED1689EDB4D2F51568E82D329E" pageId="null" pageNumber="351">
Ausdauernd, 25-50 cm hoch, feste Horste bildend (Triebe intravaginal). Alle 
<normalizedToken id="33101CD0DE3CC86AB773F893B4DB3DC4" originalValue="Blätter" pageId="null" pageNumber="351">Blaetter</normalizedToken>
<normalizedToken id="248E99B236322CBA432997CC89034FD7" originalValue="borstenförmig" pageId="null" pageNumber="351">borstenfoermig</normalizedToken>
. 
<emphasis id="82721D8FBBC5E30C606AB933C868EC40" italics="true" pageId="null" pageNumber="351">
0,7-1,1 mm dick, starr, stechend; 
<normalizedToken id="50D2AE352F4A63F4AA8F7C4DE3685885" originalValue="Blatthäutchen" pageId="null" pageNumber="351">Blatthaeutchen</normalizedToken>
3-7 mm lang, spitz, oft zerschlitzt, meist mit 3 feinen Nerven.
</emphasis>
<normalizedToken id="A4D59126939A627FFF1095A1F6166E66" originalValue="Blütenstand" pageId="null" pageNumber="351">Bluetenstand</normalizedToken>
wie bei 
<taxonomicName id="A3D52E16019E9C6F77A4EDB96C06E163" class="Liliopsida" family="Poaceae" genus="Festuca" kingdom="Plantae" order="Poales" pageId="null" pageNumber="351" phylum="Tracheophyta" rank="species" species="rubra">
<emphasis id="CA9B62182573116840699ABA3BC8F5B5" italics="true" pageId="null" pageNumber="351">F. rubra</emphasis>
</taxonomicName>
(Nr. 11). 
<normalizedToken id="D6622CE8CFC52E3654541227D686971E" originalValue="Ährchen" pageId="null" pageNumber="351">Aehrchen</normalizedToken>
6-10 mm lang, 
<normalizedToken id="7482ABF5E3652DA3698DDE83594B760E" originalValue="gelbgrün" pageId="null" pageNumber="351">gelbgruen</normalizedToken>
. Deckspelzen kurz zugespitzt, ohne Grannen. Fruchtknoten im obern Teil behaart. - 
<normalizedToken id="D10669002C61EC893E6B1AE1E6DB5207" originalValue="Blüte" pageId="null" pageNumber="351">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="37701C805B00B31B071A7493522DE032" pageId="null" pageNumber="351">
<emphasis id="3C7E262A7271018DF34B79876AE4CD99" italics="true" pageId="null" pageNumber="351">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="52B9283578164299A25A88194E653480" pageId="null" pageNumber="351">
<emphasis id="3F0E644A15B56286E3CBCB43195B7CB8" italics="true" pageId="null" pageNumber="351">Standort.</emphasis>
Wie 
<taxonomicName id="9DD2B3382E01ADA951204C8F36CE06FD" class="Liliopsida" family="Poaceae" genus="Calamagrostis" kingdom="Plantae" order="Poales" pageId="null" pageNumber="351" phylum="Tracheophyta" rank="species" species="varia">
<emphasis id="8BD732D5182B0598254E4B2E531C33B5" italics="true" pageId="null" pageNumber="351">F. varia</emphasis>
</taxonomicName>
(Nr. 15), jedoch nur auf Kalk.
</paragraph>
<paragraph id="92850FA6548F7073355DB60AAA7A4D99" pageId="null" pageNumber="351">
<emphasis id="291A223911984205150ADCD003C5A11F" italics="true" pageId="null" pageNumber="351">
Verbreitung. 
<normalizedToken id="7885724AC573A2A1415D2A2D29D691BE" originalValue="Südalpen-Pflanze" pageId="null" pageNumber="351">Suedalpen-Pflanze</normalizedToken>
:
</emphasis>
Von den Bergamasker Alpen und dem Gebiet von Trient 
<normalizedToken id="92721420762E03F5A28FFFCC1E9DCE4D" originalValue="ostwärts" pageId="null" pageNumber="351">ostwaerts</normalizedToken>
bis in die Julischen Alpen. - Im Gebiet: Bergamasker Alpen; die Angabe von Taverne Superiore im Tessin ist zu 
<normalizedToken id="F78A3EB607562846D5C59AC994A5DE20" originalValue="überprüfen" pageId="null" pageNumber="351">ueberpruefen</normalizedToken>
.
</paragraph>
</subSubSection>
