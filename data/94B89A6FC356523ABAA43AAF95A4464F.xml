<taxonomicName id="C1B67CBBA47DCE0CACF50FCE425EF44E" authorityName="Brunke" authorityYear="2014" class="Insecta" family="Staphylinidae" genus="Bolitogyrus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Bolitogyrus viridescens" order="Coleoptera" pageId="0" pageNumber="1" phylum="Arthropoda" rank="species" species="viridescens">Bolitogyrus viridescens</taxonomicName>
Brunke in 
<bibRefCitation id="CA57EEEDEC844650D7D3C87AB97A0FF9" DOI="https://doi.org/10.3897/zookeys.423.7536" author="Brunke, A" journalOrPublisher="ZooKeys" pageId="0" pageNumber="1" pagination="1 - 113" refId="B2" refString="Brunke, A, Solodovnikov, A, 2014. A revision of the Neotropical species of Bolitogyrus Chevrolat, a geographically disjunct lineage of Staphylinini (Coleoptera, Staphylinidae). ZooKeys 423: 1 - 113, DOI: https://doi.org/10.3897/zookeys.423.7536" title="A revision of the Neotropical species of Bolitogyrus Chevrolat, a geographically disjunct lineage of Staphylinini (Coleoptera, Staphylinidae)." url="https://doi.org/10.3897/zookeys.423.7536" volume="423" year="2014">Brunke and Solodovnikov 2014</bibRefCitation>
