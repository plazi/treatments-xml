</paragraph>
</caption>
<caption id="0A950EFFFFDB3342FF27F91670A7F8A2" ID-DOI="http://doi.org/10.5281/zenodo.6453690" ID-Zenodo-Dep="6453690" httpUri="https://zenodo.org/record/6453690/files/figure.png" pageId="3" pageNumber="198" startId="3.[174,207,1748,1770]" targetBox="[272,1113,774,1706]" targetPageId="3">
<paragraph id="5E555E77FFDB3342FF27F91670A7F8A2" blockId="3.[174,1233,1746,1850]" pageId="3" pageNumber="198">
Fig. 2. 
<taxonomicName id="99EA25F4FFDB3342FF78F91673E5F971" authorityName="Macquart" authorityYear="1843" box="[241,470,1748,1769]" class="Insecta" family="Pyrgotidae" genus="Campylocera" kingdom="Animalia" order="Diptera" pageId="3" pageNumber="198" phylum="Arthropoda" rank="species" species="ferruginea">
