<subSubSection id="8C8E6575FF906A2FFD2394921A12B89B" pageId="107" pageNumber="865" type="distribution">
<caption id="90EB6676FF906A2FFD2394921A12B89B" ID-DOI="http://doi.org/10.5281/zenodo.6398285" ID-Zenodo-Dep="6398285" httpUri="https://zenodo.org/record/6398285/files/figure.png" inLine="true" pageId="107" pageNumber="865" targetBox="[120,711,598,1011]" targetPageId="107">
<paragraph id="C42B36FEFF906A2FFD2394921A12B89B" blockId="107.[734,1328,593,1016]" pageId="107" pageNumber="865">
<emphasis id="F6E0EAECFF906A2FFD2394921D8FB9D6" bold="true" box="[735,911,715,740]" pageId="107" pageNumber="865">Distribution.</emphasis>
S Britain, W 
<collectingCountry id="BC83766EFF906A2FFB8094921ADDB9D6" box="[1148,1245,715,740]" name="France" pageId="107" pageNumber="865">France</collectingCountry>
, and Iberian Peninsula E through C Europe and extreme S 
<collectingCountry id="BC83766EFF906A2FFC4595481A24B800" box="[953,1060,785,818]" name="Sweden" pageId="107" pageNumber="865">Sweden</collectingCountry>
to W 
<collectingCountry id="BC83766EFF906A2FFB8095481AEEB800" box="[1148,1262,785,818]" name="Ukraine" pageId="107" pageNumber="865">Ukraine</collectingCountry>
and Balkans; also major W Mediterranean Is (Balearic, 
<collectingCountry id="BC83766EFF906A2FFC81953C1DE6B8B0" box="[893,998,869,898]" name="France" pageId="107" pageNumber="865">Corsica</collectingCountry>
, Sardinia, Sicily, and 
<collectingCountry id="BC83766EFF906A2FFD2395D51D2EB89B" box="[735,814,908,937]" name="Malta" pageId="107" pageNumber="865">Malta</collectingCountry>
