<quantity id="707F9B5E341EFF9AFEB0C42F1BB09322" box="[350,408,285,307]" metricMagnitude="2" metricUnit="m" metricValue="2.5" pageId="5" pageNumber="274" unit="m" value="250.0">250 m</quantity>
