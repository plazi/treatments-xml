<date id="C339107B341EFF9AFDEAC42F18BA9322" box="[516,658,285,306]" pageId="5" pageNumber="274" value="2014-07-10" valueMax="2014-07-28" valueMin="2014-07-10">10.-28.VII.2014</date>
