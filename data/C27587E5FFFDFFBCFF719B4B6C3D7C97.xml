<taxonomicName id="8DDC4D70FFFDFFBCFF709BED6B377ADE" authority="LE ROY." authorityName="LE ROY." box="[218,570,1961,1983]" class="Globothalamea" family="Pseudogaudryinidae" genus="Pseudoclavulina" kingdom="Chromista" order="Textulariida" pageId="16" pageNumber="30" phylum="Foraminifera" rank="species" species="magfiensis">
