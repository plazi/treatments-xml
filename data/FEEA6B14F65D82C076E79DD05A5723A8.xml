<subSubSection id="8B5FAA614DB988071825E615B93BD742" pageId="null" pageNumber="499" type="description">
<paragraph id="09181C8336263A33DC28FAD19B176C5A" pageId="null" pageNumber="499">
1 
<normalizedToken id="E35D71DC9EE18B10C9D1AC316BA19C7A" originalValue="jährige" pageId="null" pageNumber="499">jaehrige</normalizedToken>
oder ausdauernde 
<normalizedToken id="11193D806856D84AE0BFA6C603FB7031" originalValue="Kräuter" pageId="null" pageNumber="499">Kraeuter</normalizedToken>
; weniger als 1 m hoch, aufrecht oder niederliegend und am Boden kriechend und an den Stengelknoten Wurzeln treibend. 
<normalizedToken id="006516F832AD3A7E80B941E7F69C840A" originalValue="Blätter" pageId="null" pageNumber="499">Blaetter</normalizedToken>
breit oval bis 
<normalizedToken id="4258B06DE058CB94FBF4648026431FFC" originalValue="grasähnlich" pageId="null" pageNumber="499">grasaehnlich</normalizedToken>
, oft fleischig, selten gestielt. 
<normalizedToken id="95638B475619F12D12CC1D2DD7A10088" originalValue="Blütenstände" pageId="null" pageNumber="499">Bluetenstaende</normalizedToken>
in Blattachseln oder 
<normalizedToken id="05E43A92713EAE5FA146312FC80295CD" originalValue="endständig" pageId="null" pageNumber="499">endstaendig</normalizedToken>
, seltener einzeln. 
<normalizedToken id="67D4ECCACA067431C5DC13F1049BF537" originalValue="Tragblätter" pageId="null" pageNumber="499">Tragblaetter</normalizedToken>
wie die 
<normalizedToken id="1FC2C8FADD6AA48370606F235754FA82" originalValue="Laubblätter" pageId="null" pageNumber="499">Laubblaetter</normalizedToken>
oder 
<normalizedToken id="0C838547A6D0FF5B9702A1B11F281D38" originalValue="spathaähnlich" pageId="null" pageNumber="499">spathaaehnlich</normalizedToken>
(
<normalizedToken id="663E7F50874B7EC746BB6212536F4FF4" originalValue="hüllblattähnlich" pageId="null" pageNumber="499">huellblattaehnlich</normalizedToken>
), selten nicht vorhanden. 
<normalizedToken id="92C08900957DB9C063B5FEB542B9D6F8" originalValue="Blüten" pageId="null" pageNumber="499">Blueten</normalizedToken>
meist zwitterig, 
<emphasis id="423F8EB11638C2CC356D8D88570563ED" italics="true" pageId="null" pageNumber="499">
3 
<normalizedToken id="A30135D2EB7A9B44C99CB9EACA7CECE3" originalValue="zählig" pageId="null" pageNumber="499">zaehlig</normalizedToken>
, aktinomorph oder zygomorph
</emphasis>
, mit 3 
<normalizedToken id="1D8295573C57C079D035C672C0FCA4D8" originalValue="äußern" pageId="null" pageNumber="499">aeussern</normalizedToken>
und 3 innern 
<normalizedToken id="D60633B675F10C29D205C668AC1D3461" originalValue="Perigonblättern" pageId="null" pageNumber="499">Perigonblaettern</normalizedToken>
. 
<emphasis id="23D3882F0A9A1DEE8AAF08D83877D143" italics="true" pageId="null" pageNumber="499">
<normalizedToken id="495F57A501AEC7A5BE222D9744591C0F" originalValue="Äußere" pageId="null" pageNumber="499">Aeussere</normalizedToken>
<normalizedToken id="FC37674C7FD482F718C662B08936BB16" originalValue="Perigonblätter" pageId="null" pageNumber="499">Perigonblaetter</normalizedToken>
frei
</emphasis>
, alle gleich, 
<emphasis id="B67629E2ECA0CA7788ECD6F8B26D823F" italics="true" pageId="null" pageNumber="499">
meist 
<normalizedToken id="5F063E483FDC4D09075484DC9549979C" originalValue="grün" pageId="null" pageNumber="499">gruen</normalizedToken>
; innere 
<normalizedToken id="9104D0A74DE15684F3C216921F496CC1" originalValue="Perigonblätter" pageId="null" pageNumber="499">Perigonblaetter</normalizedToken>
frei, bunt 
<normalizedToken id="AE01317D9FC874BE01FDCB4B59159546" originalValue="gefärbt" pageId="null" pageNumber="499">gefaerbt</normalizedToken>
</emphasis>
(blau, rot, gelb, 
<normalizedToken id="F1FC40358162547732B8F3098DAB7AE7" originalValue="weiß" pageId="null" pageNumber="499">weiss</normalizedToken>
), oft 
<normalizedToken id="F350992D743C0DD57B33CD3C3EB2B036" originalValue="plötzlich" pageId="null" pageNumber="499">ploetzlich</normalizedToken>
in einen Stiel (Nagel) 
<normalizedToken id="53EAD14A241D9C618D9B544D0FFC2AD3" originalValue="verschmälert" pageId="null" pageNumber="499">verschmaelert</normalizedToken>
; bei zygomorphen 
<normalizedToken id="EC856B844EC70ABAAB77C6A73D97FE8F" originalValue="Blüten" pageId="null" pageNumber="499">Blueten</normalizedToken>
ist 1 inneres Perigonblatt reduziert. 
<normalizedToken id="65C99EFBCDE2EE678AAA8BFB810D4B08" originalValue="Staubblätter" pageId="null" pageNumber="499">Staubblaetter</normalizedToken>
vielgestaltig, 
<emphasis id="06807689175F2C8E1CCF6BC6839FED87" italics="true" pageId="null" pageNumber="499">einzelne oft steril</emphasis>
, 
<normalizedToken id="79464CEE15BBA4677804E8551CA4313F" originalValue="häufig" pageId="null" pageNumber="499">haeufig</normalizedToken>
behaart. Fruchtknoten 
<normalizedToken id="6F582AE92EE948B73765F7CAA45C283A" originalValue="oberständig" pageId="null" pageNumber="499">oberstaendig</normalizedToken>
, 3- oder 2 
<normalizedToken id="517F16FEADD965AD68C542E994D88F7F" originalValue="fächerig" pageId="null" pageNumber="499">faecherig</normalizedToken>
, in jedem Fach mit wenigen Samenanlagen. Griffel 
<normalizedToken id="A329F8A987D24CEC846887AA8BC8214D" originalValue="endständig" pageId="null" pageNumber="499">endstaendig</normalizedToken>
. Frucht eine Kapsel, die meist aufspringt (selten fleischig).
</paragraph>
<paragraph id="57304B3FA42065A0FADBBBD4814E0079" pageId="null" pageNumber="499">
Die Familie der 
<taxonomicName id="18E57EC361C9AAD39C171220B13C7842" class="Liliopsida" family="Commelinaceae" kingdom="Plantae" order="Commelinales" pageId="null" pageNumber="499" phylum="Tracheophyta" rank="family">
<emphasis id="775A8F681445F6827A9212AE453AA428" italics="true" pageId="null" pageNumber="499">Commelinaceae</emphasis>
</taxonomicName>
<normalizedToken id="F40A0E99957D1412F4028DC147CBB3A3" originalValue="umfaßt" pageId="null" pageNumber="499">umfasst</normalizedToken>
<emphasis id="3153929ED876792438CC4E15C93F65BA" italics="true" pageId="null" pageNumber="499">40 Gattungen; die meisten der etwa 600 Arten sind in den Tropen und Subtropen verbreitet;</emphasis>
mehrere Arten sind Zierpflanzen.
</paragraph>
