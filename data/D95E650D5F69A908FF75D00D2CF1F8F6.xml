<emphasis id="638308095F69A908FB6CD3AE2DB2F91F" bold="true" box="[1169,1257,1664,1685]" italics="true" pageId="3" pageNumber="250">P. annua</emphasis>
</taxonomicName>
(endemic to Africa)
</keyLead>
</paragraph>
<paragraph id="5148D41B5F69A908FF75D3B32CF1F939" blockId="3.[136,1452,1376,1916]" box="[136,1450,1693,1715]" pageId="3" pageNumber="250">
<keyLead id="EA06772E5F69A908FF75D3B32CF1F939" box="[136,1450,1693,1715]" pageId="3" pageNumber="250">
