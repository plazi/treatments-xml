</taxonomicName>
(endemic to 
<collectingCountry id="29E0948B5F69A908FAB0D3F82CFFF966" box="[1357,1444,1750,1772]" name="Thailand" pageId="3" pageNumber="250">Thailand</collectingCountry>
)
</keyLead>
</paragraph>
</keyStep>
<keyStep id="EA03CCBE5F69A908FF75D3DD2CF1F8F6" pageId="3" pageNumber="250">
<paragraph id="5148D41B5F69A908FF75D3DD2CF1F8AC" blockId="3.[136,1452,1376,1916]" pageId="3" pageNumber="250">
<keyLead id="EA06772E5F69A908FF75D3DD2CF1F8AC" pageId="3" pageNumber="250">
6. Annual, up to 
<quantity id="960F79FE5F69A908FEA1D3DD28CCF883" box="[348,407,1779,1801]" metricMagnitude="-1" metricUnit="m" metricValue="3.0" pageId="3" pageNumber="250" unit="cm" value="30.0">30 cm</quantity>
high; basal sheaths not bulged, glabrous; leaf blade short, granulate, 2.5–6.0 × 
<quantity id="960F79FE5F69A908FB69D3DD2C55F883" box="[1172,1294,1779,1801]" metricMagnitude="-3" metricUnit="m" metricValue="1.25" metricValueMax="1.5" metricValueMin="1.0" pageId="3" pageNumber="250" unit="cm" value="0.125" valueMax="0.15" valueMin="0.1">0.1–0.15 cm</quantity>
; ligule lacerated membranous; anthers 
<quantity id="960F79FE5F69A908FE5AD23E2B41F8AF" box="[423,538,1808,1830]" metricMagnitude="-4" metricUnit="m" metricValue="6.5" metricValueMax="8.0" metricValueMin="5.0" pageId="3" pageNumber="250" unit="mm" value="0.65" valueMax="0.8" valueMin="0.5">0.5–0.8 mm</quantity>
long ..................................................................... 
