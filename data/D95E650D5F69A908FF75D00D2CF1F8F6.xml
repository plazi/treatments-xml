</taxonomicName>
(narrow endemic to Central 
<collectingCountry id="29E0948B5F69A908FA8CD23E2CFFF8AC" box="[1393,1444,1808,1830]" name="India" pageId="3" pageNumber="250">India</collectingCountry>
)
</keyLead>
</paragraph>
<paragraph id="5148D41B5F69A908FF75D2032CF1F8F6" blockId="3.[136,1452,1376,1916]" pageId="3" pageNumber="250">
<keyLead id="EA06772E5F69A908FF75D2032CF1F8F6" pageId="3" pageNumber="250">
6. Perennial, up to 
<quantity id="960F79FE5F69A908FE8ED20228F4F8C8" box="[371,431,1836,1858]" metricMagnitude="-1" metricUnit="m" metricValue="6.5" pageId="3" pageNumber="250" unit="cm" value="65.0">65 cm</quantity>
high; basal sheaths bulged, dorsally strongly villous or bearded with appressed or spreading white hairs; leaf blades long, smooth not granulate, 5.0–45 × 
<quantity id="960F79FE5F69A908FD54D2642A4CF8D5" box="[681,791,1866,1887]" metricMagnitude="-3" metricUnit="m" metricValue="2.5" metricValueMax="4.0" metricValueMin="1.0" pageId="3" pageNumber="250" unit="cm" value="0.25" valueMax="0.4" valueMin="0.1">0.1–0.4 cm</quantity>
; ligule biseriately ciliate; anthers 2.8–3.0 mm long ............................ ......................................................................................... 
<taxonomicName id="96F7AF985F69A908FD0DD2492A22F8F6" authorityName="Clayton" authorityYear="1972" baseAuthorityName="Hackel" baseAuthorityYear="1885" box="[752,889,1894,1916]" class="Liliopsida" family="Poaceae" genus="Parahyparrhenia" kingdom="Plantae" order="Poales" pageId="3" pageNumber="250" phylum="Tracheophyta" rank="species" species="bellariensis">
