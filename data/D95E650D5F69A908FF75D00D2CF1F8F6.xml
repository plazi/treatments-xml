long ......................................................... 
<taxonomicName id="96F7AF985F69A908FB81D3B32DB3F938" authorityName="Clayton" authorityYear="1966" box="[1148,1256,1693,1714]" class="Liliopsida" family="Poaceae" genus="Parahyparrhenia" kingdom="Plantae" order="Poales" pageId="3" pageNumber="250" phylum="Tracheophyta" rank="species" species="perennis">
