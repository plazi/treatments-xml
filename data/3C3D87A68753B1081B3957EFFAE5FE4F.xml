<paragraph id="B42B36B08753B1091B335D63FBD8F473" blockId="28.[92,1309,1112,3193]" box="[106,1100,2929,2958]" pageId="28" pageNumber="2">
<taxonomicName id="73944D338753B1091B335D63FE5EF473" authority="Hall, 1941" authorityName="Hall" authorityYear="1941" box="[106,458,2929,2958]" class="Mammalia" family="Heteromyidae" genus="Microdipodops" kingdom="Animalia" order="Rodentia" pageId="28" pageNumber="2" phylum="Chordata" rank="subSpecies" species="megacephalus" subSpecies="sabulonis">M. m. sabulonis Hall, 1941</taxonomicName>
— W USA (Great Basin Desert of SC Nevada).
</paragraph>
