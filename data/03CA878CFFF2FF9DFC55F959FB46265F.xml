(
<figureCitation id="13582A1FFFF2FF9DFBFAF8A2FBF9265D" box="[1028,1118,1813,1838]" captionStart="Figure 2" captionStartId="2.[145,226,1414,1436]" captionTargetBox="[225,1345,195,1374]" captionTargetId="figure-248@2.[225,1345,195,1374]" captionTargetPageId="2" captionText="Figure 2. Habitus in vivo of some Discosomaticinae from Brazil. A, Roquettea singularis from Pará. B, Gryne leprosa from Pará. C, Gryne marginalis from Pará. D, Gryne dimorpha from Goiás. E–G, Gryne orensis from Mato Grosso do Sul. Photographs of Arthur Anker &amp; Pedro H. Martins (A, C–D), Bruno Garcia (B) and Adriano Kury (E–G)." pageId="71" pageNumber="656">FIGS 2C</figureCitation>
, 
<figureCitation id="13582A1FFFF2FF9DFB95F8A2FB20265F" box="[1131,1159,1813,1838]" captionStart="Figure 48" captionStartId="64.[145,226,1758,1780]" captionTargetBox="[147,1428,447,1718]" captionTargetId="figure-112@64.[145,1428,445,1719]" captionTargetPageId="64" captionText="Figure 48. Map of known distribution of Gryne. Numbers correspond to the following WWF ecoregions: 1 = Uatumã- Trombetas moist forest, 2 = Madeira-Tapajós moist forest, 3 = Xingú-Tocantins-Araguaia moist forest, 4 = Marajó várzea, 5 = Tocantins/Pindaré moist forest, 6 = Mato grosso seasonal forest, 7 = Caatinga, 8 = Pernambuco Coastal forest, 9 = Cerrado, 10 = Bahia interior forest, 11 = Bahia coastal forest, 12 = Alto Paraná Atlantic forest, 13 = Pantanal, 14 = Dry Chaco, 15 = Humid chaco, 16 = Parana flooded savanna, 17 = Humid pampas." pageId="71" pageNumber="656">48</figureCitation>
, 
<figureCitation id="13582A1FFFF2FF9DFB6AF8A2FB17265F" box="[1172,1200,1813,1838]" captionStart="Figure 54" captionStartId="72.[145,225,1703,1725]" captionTargetBox="[145,1425,196,1662]" captionTargetId="figure-24@72.[145,1425,195,1663]" captionTargetPageId="72" captionText="Figure 54. Gryne marginalis. A, male (UFMG 9388), dorsal view. B, same, lateral view. C, same, panoramic dorsal view. D–G, variations of spots pattern in dorsal view: D, male (MNRJ 60252) from Nova Timboteua (Pará, Brazil); E, male, same data; F, female (MNRJ 60251) from Rondon do Pará (Pará, Brazil); G, female, same data. Scale bars 1 mm." pageId="71" pageNumber="656">54</figureCitation>
, 
<figureCitation id="13582A1FFFF2FF9DFB43F8A2FB7E265F" box="[1213,1241,1813,1838]" captionStart="Figure 55" captionStartId="73.[163,243,1727,1749]" captionTargetBox="[163,1443,195,1687]" captionTargetId="figure-24@73.[163,1443,195,1687]" captionTargetPageId="73" captionText="Figure 55. SEM images of some structures of Gryne marginalis. A–D, penis (MNRJ 17579): A, dorsal view; B, lateral view; C, ventral view; D, detail of microsetae, MS-D and MS-E, ventral view. E–I, male (MNRJ 2156): E, claws of left leg IV showing two rows of pectination; F, left cheliceral hand, dorsal view; G, left basichelicerite, dorsal view; H, left pedipalpus, femur, mesal view; I, same, tibia and tarsus, ventral view. Scale bars 200 μm (F, H, I), 100 μm (A, B, G), 50 μm (C, E), 10 μm (D). Abbreviation: MS = macrosetae." pageId="71" pageNumber="656">55</figureCitation>
)
