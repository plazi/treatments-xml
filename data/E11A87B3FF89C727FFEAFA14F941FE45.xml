<subSubSection id="21A9652EFF89C727FD50F92AFB45F894" pageId="2" pageNumber="107" type="discussion">
<paragraph id="690C36A5FF89C727FD50F92AFB45F894" blockId="2.[715,1310,1675,2101]" pageId="2" pageNumber="107">
<taxonomicName id="AEB34D26FF89C727FD50F92AFC0EF926" authorityName="Milne-Edwards" authorityYear="1877" box="[720,957,1758,1787]" class="Mammalia" family="Platacanthomyidae" genus="Typhlomys" kingdom="Animalia" order="Rodentia" pageId="2" pageNumber="107" phylum="Chordata" rank="species" species="cinereus">Typhlomys cinereus</taxonomicName>
was formerly considered conspecific with 7. 
<taxonomicName id="AEB34D26FF89C727FC74F8F1FBD8F8FF" authorityName="Osgood" authorityYear="1932" box="[1012,1131,1797,1826]" class="Mammalia" family="Platacanthomyidae" genus="Typhlomys" kingdom="Animalia" order="Rodentia" pageId="2" pageNumber="107" phylum="Chordata" rank="species" species="chapensis">chapensis</taxonomicName>
and T. daloushanensis. Two subspecies recognized.
</paragraph>
</subSubSection>
<subSubSection id="21A9652EFF89C727FD4CF8A4FB70F7D3" pageId="2" pageNumber="107" type="multiple">
<caption id="3DCC662DFF89C727FD4CF8A4FB70F7D3" ID-DOI="http://doi.org/10.5281/zenodo.6603037" ID-Zenodo-Dep="6603037" httpUri="https://zenodo.org/record/6603037/files/figure.png" inLine="true" pageId="2" pageNumber="107" targetBox="[101,691,1686,2100]" targetPageId="2">
<paragraph id="690C36A5FF89C727FD4CF8A4FBEFF8AC" blockId="2.[715,1310,1675,2101]" box="[716,1116,1872,1905]" pageId="2" pageNumber="107">
<emphasis id="5BC7EAB7FF89C727FD4CF8A4FBEFF8AC" bold="true" box="[716,1116,1872,1905]" pageId="2" pageNumber="107">Subspecies and Distribution.</emphasis>
</paragraph>
<paragraph id="690C36A5FF89C727FD50F88FFAAAF81D" blockId="2.[715,1310,1675,2101]" pageId="2" pageNumber="107">
