<subSubSection id="AFBFB13C655C5C25413331CBE56BADB9" pageId="null" pageNumber="384" type="description">
<paragraph id="19B653474779BF455FF100CD14697026" pageId="null" pageNumber="384">
2 
<normalizedToken id="9A6EB428F26B8E89F8FD32820BD27B41" originalValue="jährig" pageId="null" pageNumber="384">jaehrig</normalizedToken>
; 10-50 cm hoch. Stengel aufrecht, einfach, 
<emphasis id="9939495B2E9ADF5334A4E34E7CC0A19E" italics="true" pageId="null" pageNumber="384">
sehr dicht 
<normalizedToken id="10B60E6474BB61C640EF826DD50EE7BD" originalValue="beblättert" pageId="null" pageNumber="384">beblaettert</normalizedToken>
</emphasis>
, wie die 
<normalizedToken id="32FB1F1C1B71E046ED39DDEAE8A817BF" originalValue="Blätter" pageId="null" pageNumber="384">Blaetter</normalizedToken>
rauhhaarig. 
<normalizedToken id="6B5B1D17831020E79A81A5D3BC6AEDDE" originalValue="Blätter" pageId="null" pageNumber="384">Blaetter</normalizedToken>
schmal oval bis schmal lanzettlich, 
<normalizedToken id="D1DEB20F28B592806D48B4B77570F06F" originalValue="±" pageId="null" pageNumber="384">+/-</normalizedToken>
ganzrandig, 
<normalizedToken id="BFDF1B67B72EF34ABCFA69B030E6CE93" originalValue="allmählich" pageId="null" pageNumber="384">allmaehlich</normalizedToken>
gegen den Grund 
<normalizedToken id="F8774D33C16A2B477437E67031BAB0CE" originalValue="verschmälert" pageId="null" pageNumber="384">verschmaelert</normalizedToken>
, kaum gestielt, die 
<normalizedToken id="C2A3E563CF74E8DC747B122162C53F30" originalValue="stengelständigen" pageId="null" pageNumber="384">stengelstaendigen</normalizedToken>
den Stengel halbumfassend, behaart. 
<emphasis id="6648D9F6CC242A5916FCD813A54B40D5" italics="true" pageId="null" pageNumber="384">
<normalizedToken id="B882874FAF0FC35193BA3773C4E5A0CC" originalValue="Blüten" pageId="null" pageNumber="384">Blueten</normalizedToken>
ungestielt, in einer dichten, 
<normalizedToken id="C6F086197365190B6F165FA1333354BF" originalValue="endständigen" pageId="null" pageNumber="384">endstaendigen</normalizedToken>
<normalizedToken id="3CD67A5409BBC5650D7342D0DEF319EB" originalValue="Ähre" pageId="null" pageNumber="384">Aehre</normalizedToken>
</emphasis>
, zu 1-3 in den Achseln der 
<normalizedToken id="D053DF71F8048BEE33B3BF02934A3D33" originalValue="Blätter" pageId="null" pageNumber="384">Blaetter</normalizedToken>
. Kelchzipfel schmal lanzettlich, 
<normalizedToken id="E0FFAF98C81B11208A8CBB994D6EAB6E" originalValue="±" pageId="null" pageNumber="384">+/-</normalizedToken>
stumpf, behaart; Buchten zwischen den Zipfeln 
<emphasis id="74B2A68D3AB70FEE3213600BDFF85733" italics="true" pageId="null" pageNumber="384">spitz</emphasis>
, ohne 
<normalizedToken id="EA4FCAB571A65E1A11EFD6620C8099C2" originalValue="Anhängsel" pageId="null" pageNumber="384">Anhaengsel</normalizedToken>
. Krone 
<normalizedToken id="0DBBD945E9A2EC00DA17E2ADF56094CE" originalValue="trichterförmig" pageId="null" pageNumber="384">trichterfoermig</normalizedToken>
bis 
<normalizedToken id="B3782C96292510CC9711F6896AADC350" originalValue="glockenförmig" pageId="null" pageNumber="384">glockenfoermig</normalizedToken>
, 1,5-2,5 cm lang, 
<emphasis id="A584B6247F05E04F54084E461ED1D796" italics="true" pageId="null" pageNumber="384">gelblich</emphasis>
, 
<normalizedToken id="7662AFB808C9FBDD843B137F404FBD3E" originalValue="außen" pageId="null" pageNumber="384">aussen</normalizedToken>
den Nerven entlang 
<emphasis id="C287B9BF7DF74BEFD494770E4F9515DC" italics="true" pageId="null" pageNumber="384">dicht behaart.</emphasis>
Frucht behaart, aufrecht, nahe dem Grunde sich mit 3 
<normalizedToken id="837F36D1EAD25474957632AB48F2CF65" originalValue="Löchern" pageId="null" pageNumber="384">Loechern</normalizedToken>
<normalizedToken id="5B88D6EA9A3C620D23F8E8B8640D83AD" originalValue="öffnend" pageId="null" pageNumber="384">oeffnend</normalizedToken>
. - 
<normalizedToken id="2B876ED7EBC9A292993766F6BB742892" originalValue="Blüte" pageId="null" pageNumber="384">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="D8746AD4B82557AF8D64E72A28223896" pageId="null" pageNumber="384">
<emphasis id="E0BA656D3354B66CEBBC06F47E0BE40F" italics="true" pageId="null" pageNumber="384">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="452EAE06F18DB2EEAB94565A20130B2A" italics="true" pageId="null" pageNumber="384">34:</emphasis>
Material ohne Herkunftsangabe (Rosen 1931) und von der Schynigen Platte im Berner Oberland (Larsen 1954a), von 4 Stellen aus den 
<normalizedToken id="5481D4B5D095EBCCC21C0ABE930DB966" originalValue="französischen" pageId="null" pageNumber="384">franzoesischen</normalizedToken>
und schweizerischen Alpen und aus Kulturen (Gadella 1964).
</paragraph>
<paragraph id="1B5BA3450CE924BAC7959A5850879B4B" pageId="null" pageNumber="384">
<emphasis id="96934586B72444739A09C25F9B9C6F73" italics="true" pageId="null" pageNumber="384">Standort.</emphasis>
Subalpin und alpin. Trockene, lockere, kalkhaltige, 
<normalizedToken id="4816C5591364961ABECAC0728303C43C" originalValue="mäßig" pageId="null" pageNumber="384">maessig</normalizedToken>
feuchte 
<normalizedToken id="7A876903299D2281634B55F78D1B6BAF" originalValue="Böden" pageId="null" pageNumber="384">Boeden</normalizedToken>
in sonnigen Lagen. 
<emphasis id="52A1F4BCF31D51FFA5168282C3A8EF70" italics="true" pageId="null" pageNumber="384">Caricetum ferrugineae</emphasis>
<normalizedToken id="C8DD4A991EBBABE237EAC073F67CF6CA" originalValue="Lüdi" pageId="null" pageNumber="384">Luedi</normalizedToken>
1921, 
<emphasis id="C90166245A667489984BF55D154D0124" italics="true" pageId="null" pageNumber="384">Festuco-Trifolietum Thalii</emphasis>
Br.-Bl. 1926.
</paragraph>
<paragraph id="00753B5F6E101FBBB81135F172600F7F" pageId="null" pageNumber="384">
<emphasis id="579A92F7392E08DA79BEF36898E6D7B7" italics="true" pageId="null" pageNumber="384">
Verbreitung. Mittel- und 
<normalizedToken id="AD8297DED14BA6E25EA226C5230EE4B3" originalValue="südeuropäische" pageId="null" pageNumber="384">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="30B46CA495677E728319944EA54896C7" italics="true" pageId="null" pageNumber="384">
<normalizedToken id="9AECC9370714684E6379502555374FD7" originalValue="östlich" pageId="null" pageNumber="384">oestlich</normalizedToken>
</emphasis>
)
<emphasis id="A8F953DF9F975F00EB5B42E08C383719" italics="true" pageId="null" pageNumber="384">:</emphasis>
Jura, Alpen, Gebirge der Balkanhalbinsel (
<normalizedToken id="632922B1A47CEA9A00718B78A698E886" originalValue="südwärts" pageId="null" pageNumber="384">suedwaerts</normalizedToken>
bis Bulgarien). - Im Gebiet: Alpen, 
<normalizedToken id="2DE994BC34676DC4110F420F09D2143C" originalValue="südlicher" pageId="null" pageNumber="384">suedlicher</normalizedToken>
Jura (
<normalizedToken id="25867CAC62010B822E0D4D424D6A8A78" originalValue="nordostwärts" pageId="null" pageNumber="384">nordostwaerts</normalizedToken>
bis zum Chasseron); nicht 
<normalizedToken id="FB3968B4385A9971DEB7B2179B4770F1" originalValue="häufig" pageId="null" pageNumber="384">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
