<subSubSection id="513BF1E908216D37BC8874FECFE89DA9" pageId="null" pageNumber="312" type="description">
<paragraph id="C75C389776112D6C3E53F65B921F7FCA" pageId="null" pageNumber="312">
30-80 cm hoch. Stengel aufrecht, in der ganzen 
<normalizedToken id="1853B0579F2DAF561D850CE2A224EEE2" originalValue="Länge" pageId="null" pageNumber="312">Laenge</normalizedToken>
<normalizedToken id="9437AE210DDE72AC430F82A611A6167B" originalValue="beblättert" pageId="null" pageNumber="312">beblaettert</normalizedToken>
(bis 12 
<normalizedToken id="D7E0205F07290005A89AAF94560F2CFA" originalValue="Blätter" pageId="null" pageNumber="312">Blaetter</normalizedToken>
). 
<normalizedToken id="BAE96B66DB9E861966F4567743D20C79" originalValue="Blätter" pageId="null" pageNumber="312">Blaetter</normalizedToken>
kurz, bis 5 mm breit, 
<normalizedToken id="D4D4270F2DD8A07D0AF434C9E7DDDA80" originalValue="allmählich" pageId="null" pageNumber="312">allmaehlich</normalizedToken>
zugespitzt, 
<emphasis id="7FD71484D40458CAD3F2ACAF8245ACC9" italics="true" pageId="null" pageNumber="312">starr und abstehend</emphasis>
(
<emphasis id="E2E5A5A36F2EDF611602D6996E8A093E" italics="true" pageId="null" pageNumber="312">auffallender Habitus!</emphasis>
), 
<normalizedToken id="57F279A3B0442D3A399FB6393711D7E4" originalValue="graugrün" pageId="null" pageNumber="312">graugruen</normalizedToken>
; Haare anstelle des 
<normalizedToken id="768344D48812BC76B96D44F46AA2DD74" originalValue="Blatthäutchens" pageId="null" pageNumber="312">Blatthaeutchens</normalizedToken>
etwa 0,5 mm lang. 
<normalizedToken id="260EB39C2CB5C9A00E3081EB0C101DAF" originalValue="Blütenstand" pageId="null" pageNumber="312">Bluetenstand</normalizedToken>
eine Rispe; 
<normalizedToken id="5EC0FB18F42A1BD6B045BE399D6094D7" originalValue="Ährchen" pageId="null" pageNumber="312">Aehrchen</normalizedToken>
an den untersten 
<normalizedToken id="AAA0F400811326423518EA16D9098FBD" originalValue="Rispenästen" pageId="null" pageNumber="312">Rispenaesten</normalizedToken>
1. Ordnung kurz gestielt, an den obern sitzend. 
<normalizedToken id="0C2FCEB2A3C771A61669BDF125248A55" originalValue="Hüllspelzen" pageId="null" pageNumber="312">Huellspelzen</normalizedToken>
1- oder 3nervig, spitz, 
<normalizedToken id="AAF8A9849F4CA0D3E06F38B2ADB0E4D0" originalValue="häutig" pageId="null" pageNumber="312">haeutig</normalizedToken>
, die untere 
<normalizedToken id="89B394BC36D80F5B5B1812B2DC36EF97" originalValue="kürzer" pageId="null" pageNumber="312">kuerzer</normalizedToken>
als die obere. Deckspelzen 5-6 mm lang, 5nervig, gekielt, Mittelnerv in eine bis 0,5 mm lange Granne auslaufend. Vorspelzen wenig 
<normalizedToken id="94EAD9D705E4FDD3C1FB732D9474C6AA" originalValue="kürzer" pageId="null" pageNumber="312">kuerzer</normalizedToken>
als die Deckspelzen. - 
<normalizedToken id="8C45AE002A007B7445BC6C2036E13551" originalValue="Blüte" pageId="null" pageNumber="312">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="A3EFD1D032EDC0F0E0F67EE6EB266310" pageId="null" pageNumber="312">
<emphasis id="3EB102C7A2B07CC601EBB2141DE55B4D" italics="true" pageId="null" pageNumber="312">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="CCBA8D0F0494A572A98A8F456E6F9921" italics="true" pageId="null" pageNumber="312">40:</emphasis>
Material aus botanischen 
<normalizedToken id="AE3CBE80C762C2406797B5F08237A13E" originalValue="Gärten" pageId="null" pageNumber="312">Gaerten</normalizedToken>
(Avdulov 1931).
</paragraph>
<paragraph id="F43C75F3943D3FA00AF78E7755225BE6" pageId="null" pageNumber="312">
<emphasis id="FD4D8C50D0E0503DF4740F03A7185158" italics="true" pageId="null" pageNumber="312">Standort.</emphasis>
Kollin. Trockene, steinige oder felsige 
<normalizedToken id="371F5EFE593C1038B97871D418572331" originalValue="Böden" pageId="null" pageNumber="312">Boeden</normalizedToken>
in 
<normalizedToken id="C0FD558541A41C522B9433285F819DAA" originalValue="heißen" pageId="null" pageNumber="312">heissen</normalizedToken>
Lagen. 
<normalizedToken id="46B9D69CA01892DBE8D6AAE0C56383B1" originalValue="Gebüsche" pageId="null" pageNumber="312">Gebuesche</normalizedToken>
, Trockenwiesen.
</paragraph>
<paragraph id="2EA2C2EEF04980A850361C77BBE2C93B" pageId="null" pageNumber="312">
<emphasis id="206D3649A36C108714AF25FBF6A0475B" italics="true" pageId="null" pageNumber="312">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="FE4C0212D20D6FD0B0C40D24E53315F0" originalValue="Nordwärts" pageId="null" pageNumber="312">Nordwaerts</normalizedToken>
bis Wallis, 
<normalizedToken id="A4830E1FD3523F16AB7787ACD00A9F07" originalValue="südliches" pageId="null" pageNumber="312">suedliches</normalizedToken>
Tessin, Vintschgau, Donaubecken (bis in die Gegend von Wien), 
<normalizedToken id="273A8F57B2749224F70E4281225C302E" originalValue="Südrußland" pageId="null" pageNumber="312">Suedrussland</normalizedToken>
; 
<normalizedToken id="D171CDC71868F6B8B12099909CB1465E" originalValue="ostwärts" pageId="null" pageNumber="312">ostwaerts</normalizedToken>
bis in den Kaukasus. - Im Gebiet: Savoyen, 
<normalizedToken id="DB3805FC44EBB5AA32B4A81C44F01147" originalValue="Dép" pageId="null" pageNumber="312">Dep</normalizedToken>
. Ain, Rhonetal (Aigle bis 
<normalizedToken id="A89ECBD01F6B867BAE8717F6E9FBB307" originalValue="Lötschental" pageId="null" pageNumber="312">Loetschental</normalizedToken>
), Aostatal, Misox (Monticello), 
<normalizedToken id="65FE37083D91397492BEDC0DFA3C91AC" originalValue="südliches" pageId="null" pageNumber="312">suedliches</normalizedToken>
Tessin (Castione, Gandria, Castagnola, Monte di Caslano, San Salvatore) und angrenzende italienische Gebiete, Veltlin, Vintschgau; 
<normalizedToken id="01920C65FA5D70CF828651163DBEA810" originalValue="überall" pageId="null" pageNumber="312">ueberall</normalizedToken>
selten.
</paragraph>
</subSubSection>
