<subSubSection id="4DA82C77578D0AE0DFFF311C4C80AD39" pageId="null" pageNumber="464" type="description">
<paragraph id="7DE7CC7B46B9062CDB87B54BCD1F7FA6" pageId="null" pageNumber="464">
Unterscheidet sich von 
<taxonomicName id="59636D4FE4CB56194CC79625E0C2598C" class="Magnoliopsida" family="Asteraceae" genus="Ambrosia" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="464" phylum="Tracheophyta" rank="species" species="elatior">
<emphasis id="AF7B11A66F56D5EE4EEC59298E06E5C2" italics="true" pageId="null" pageNumber="464">A. elatior</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="2932DC53AE7DF073BAC1AC805E69CBF8" italics="true" pageId="null" pageNumber="464">Ausdauernd, mit kriechenden Wurzeln, die Sprosse bilden;</emphasis>
20-60 cm hoch; 
<normalizedToken id="85F94FF37634E3F9FCF14604889167A7" originalValue="Blätter" pageId="null" pageNumber="464">Blaetter</normalizedToken>
beiderseits dicht behaart (Haare bis 1 mm lang) und 
<emphasis id="4941A5B9B47D1764C47CD0B3554F241E" italics="true" pageId="null" pageNumber="464">
mit ungestielten 
<normalizedToken id="919097996E5D3867E2C8692B42AD46EE" originalValue="Drüsen" pageId="null" pageNumber="464">Druesen</normalizedToken>
; Blattabschnitte ganzrandig oder mit einzelnen 
<normalizedToken id="7D036492CA8BEF68D5B7F7D6B9A40A52" originalValue="Zähnen" pageId="null" pageNumber="464">Zaehnen</normalizedToken>
; 
<normalizedToken id="525A47ED6E0B51BC3BA40DD96459C95A" originalValue="Hülle" pageId="null" pageNumber="464">Huelle</normalizedToken>
der
</emphasis>
♂ 
<emphasis id="A102168AFC2CDF2DE04BC80B53F7A7F6" italics="true" pageId="null" pageNumber="464">
<normalizedToken id="ADC737B380B4C3F828DDA1602E7C912D" originalValue="Köpfe" pageId="null" pageNumber="464">Koepfe</normalizedToken>
dicht behaart; 
<normalizedToken id="CD13B904E81C4CC264D20CA78E1D9E10" originalValue="Früchte" pageId="null" pageNumber="464">Fruechte</normalizedToken>
2,5
</emphasis>
- 
<emphasis id="BEEACF4E6F2AF624F04A23829510F843" italics="true" pageId="null" pageNumber="464">3 mm lang.</emphasis>
- 
<normalizedToken id="BC08B0A3205945CD23F3B6F479DF1325" originalValue="Blüte" pageId="null" pageNumber="464">Bluete</normalizedToken>
: 
<normalizedToken id="A6C955D80AC9A76AC5D393E9799DA6EF" originalValue="Später" pageId="null" pageNumber="464">Spaeter</normalizedToken>
Sommer und Herbst.
</paragraph>
<paragraph id="BDD35C33DBBBDBBF0D71DC9C2E8A315B" pageId="null" pageNumber="464">
<emphasis id="4196F21DE8BF24AD552FEDBFC313DFA0" italics="true" pageId="null" pageNumber="464">
<pageBreakToken id="B91F73F686273D1041E264B8DA43ADDF" pageId="null" pageNumber="464">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="E5E1207BBA6557A780DE82734FEC3847" italics="true" pageId="null" pageNumber="464">36:</emphasis>
Material aus Nordamerika (Miller et al. 1968). 
<emphasis id="015A1651FC54D4813C2354802441328C" italics="true" pageId="null" pageNumber="464">2n</emphasis>
= 
<emphasis id="92C19EA3AFAD188E0B4FC497FFA5BA7F" italics="true" pageId="null" pageNumber="464">72, 108, 144:</emphasis>
Material aus Nordamerika (Payne etal. 1964). 
<emphasis id="0631A2E8801CF75F777CECA2BCCDC2D7" italics="true" pageId="null" pageNumber="464">2n</emphasis>
= 
<emphasis id="31E70E4390A56B321F42D3F15093A380" italics="true" pageId="null" pageNumber="464">100</emphasis>
- 
<emphasis id="218BC510B26FEBC82776083E38187501" italics="true" pageId="null" pageNumber="464">104:</emphasis>
Material aus Kalifornien (Heiser und Whitaker 1948). 
<emphasis id="D2B0CF8E7B0B90AFEC5B5B9D4F003CCC" italics="true" pageId="null" pageNumber="464">2n ca. 108:</emphasis>
Material aus Michigan (USA) (Wagner und Beals 1958).
</paragraph>
<paragraph id="08E84EB31FD14FFAD66A6E7F90F11889" pageId="null" pageNumber="464">
<emphasis id="0325D4AD70F71694CCE39364D2A686AC" italics="true" pageId="null" pageNumber="464">Standort.</emphasis>
Kollin, seltener montan. Lockere, sommertrockene, 
<normalizedToken id="A743C48B2C6A2BA0FFBF07E5F03AA2EA" originalValue="nährstoffreiche" pageId="null" pageNumber="464">naehrstoffreiche</normalizedToken>
<normalizedToken id="ABF26F12259A4C99A9C8752F4775AD64" originalValue="Böden" pageId="null" pageNumber="464">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="645DBCCA6CB43426FAE1282296477B90" originalValue="Schuttplätze" pageId="null" pageNumber="464">Schuttplaetze</normalizedToken>
, Bahnareale, 
<normalizedToken id="144A57AEB50FC9D191C9779C7EB88238" originalValue="Wegränder" pageId="null" pageNumber="464">Wegraender</normalizedToken>
. 
<emphasis id="1E827122B7B10D13CBE65DAC03010021" italics="true" pageId="null" pageNumber="464">Centaureo diffusae-Berteroetum incanae</emphasis>
Oberd. 1957.
</paragraph>
<paragraph id="F2CA730D3441EA68B8D85EBD45847129" pageId="null" pageNumber="464">
<emphasis id="5BBF25367FC08D60AEEC77E6B9E4D9F8" italics="true" pageId="null" pageNumber="464">Verbreitung. Nordamerikanische Pflanze;</emphasis>
in Europa eingeschleppt. - Im Gebiet selten eingeschleppt, z. B.: Oberrheinische Tiefebene, Wallis.
</paragraph>
</subSubSection>
