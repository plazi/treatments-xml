<taxonomicName id="4C0E4D2FFFF2E50150E282026245FA95" authorityName="CAMERON" authorityYear="1930" box="[199,334,1289,1313]" class="Insecta" family="Staphylinidae" genus="Zyras" kingdom="Animalia" order="Coleoptera" pageId="51" pageNumber="168" phylum="Arthropoda" rank="species" species="rufithorax">
