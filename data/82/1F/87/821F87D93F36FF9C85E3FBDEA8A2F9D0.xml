<heading box="[136,641,1050,1076]" fontSize="10" level="2" pageId="1" pageNumber="255" reason="2">
<emphasis bold="true" box="[136,641,1050,1076]" pageId="1" pageNumber="255">
Family 
<taxonomicName authority="Rohdendorf, 1962" authorityName="Rohdendorf" authorityYear="1962" box="[225,641,1050,1076]" class="Insecta" family="Archizelmiridae" higherTaxonomySource="GBIF" kingdom="Animalia" order="Diptera" pageId="1" pageNumber="255" phylum="Arthropoda" rank="family">
Archizelmiridae 
<bibRefCitation author="Rohdendorf, B. B." box="[426,641,1050,1076]" pageId="1" pageNumber="255" pagination="444 - 502" refId="ref4344" refString="Rohdendorf, B. B. (1962). Order Diptera. In: Rohdendorf, B. B. (Ed.), Fundamentals of paleontology, volume 9, Arthropoda, Tracheata, Chelicerata. Smithsonian Institution Libraries and National Science Foundation, Washington, D. C., pp. 444 - 502 [In Russian, English translation 1991]" type="book chapter" year="1962">Rohdendorf, 1962</bibRefCitation>
</taxonomicName>
</emphasis>
</heading>
</paragraph>
