<subSubSection id="07B64CD048F0979FA2757E2B7EBD8044" pageId="null" pageNumber="281" type="description">
<paragraph id="017C720A1636B69CA8B42F83D2CAB69C" pageId="null" pageNumber="281">
1 
<normalizedToken id="A60584D34A888AEC6FE73E29A6319E58" originalValue="jährig" pageId="null" pageNumber="281">jaehrig</normalizedToken>
; 10-40 cm hoch; 
<normalizedToken id="381A03F9759A7EAC5826FE897FDFE3BE" originalValue="graugrün" pageId="null" pageNumber="281">graugruen</normalizedToken>
. Stengel aufsteigend oder aufrecht, oft verzweigt, kahl. Obere 
<normalizedToken id="2D9FA219AFEF80AD47A0BEC1CD5AF6F0" originalValue="Blätter" pageId="null" pageNumber="281">Blaetter</normalizedToken>
zu 6 im Quirl, 
<emphasis id="6858D2DF63E89755449FCD25739A5C89" italics="true" pageId="null" pageNumber="281">sehr schmal lanzettlich</emphasis>
, 0,5-1,5 cm lang, 
<emphasis id="7B2CA61B73DDE16A4CAC26B328B6B3C9" italics="true" pageId="null" pageNumber="281">15</emphasis>
- 
<emphasis id="B8E49C595D27BE20CA475126FC0710DD" italics="true" pageId="null" pageNumber="281">40mal so lang wie breit</emphasis>
, mit nach unten eingerolltem Rand, mit einzelnen, nach vorn gerichteten, kaum 0,1 mm langen, zahnartigen Haaren (rauh). 
<normalizedToken id="BC7332D13D6BD230F207DAA8CB90CA14" originalValue="Blüten" pageId="null" pageNumber="281">Blueten</normalizedToken>
in 
<normalizedToken id="3653FED64C8FE3DADF33777DA6D41F22" originalValue="dünnen" pageId="null" pageNumber="281">duennen</normalizedToken>
, 
<normalizedToken id="0D82532D731E140D7F09BC07486131AE" originalValue="vielblütigen" pageId="null" pageNumber="281">vielbluetigen</normalizedToken>
, 2,5-5 cm langen 
<normalizedToken id="4E2193DE220ACF2839540004E0BC9EC9" originalValue="Ähren" pageId="null" pageNumber="281">Aehren</normalizedToken>
; diese 
<normalizedToken id="F2CC8F757612EC03CC0B0DF3667FA923" originalValue="endständig" pageId="null" pageNumber="281">endstaendig</normalizedToken>
oder auch 
<normalizedToken id="51286EC0FE3FD429FF0EDFED80C24C09" originalValue="seitenständig" pageId="null" pageNumber="281">seitenstaendig</normalizedToken>
(ungestielt oder gestielt) in den Achseln von 
<normalizedToken id="D53B0E8132323C8CAC3FD16EEA2ABF79" originalValue="Blättern" pageId="null" pageNumber="281">Blaettern</normalizedToken>
, am Grunde von 4 
<normalizedToken id="C28EE0A2C23CEA0C178D5BD4DC42EDF1" originalValue="häutig" pageId="null" pageNumber="281">haeutig</normalizedToken>
berandeten, schmalen 
<normalizedToken id="E533C4DF70843996B9B4A996ABE11CB5" originalValue="Blättern" pageId="null" pageNumber="281">Blaettern</normalizedToken>
umgeben. 
<normalizedToken id="7821A2F90FA6A7BD6FC20A7240D68FAF" originalValue="Blüten" pageId="null" pageNumber="281">Blueten</normalizedToken>
in den Achseln von 
<normalizedToken id="098EF2DB988E600D789D99157C14422D" originalValue="häutig" pageId="null" pageNumber="281">haeutig</normalizedToken>
berandeten, lanzettlichen 
<normalizedToken id="D12FC95C068BF085C92530FEF111E620" originalValue="Tragblättern" pageId="null" pageNumber="281">Tragblaettern</normalizedToken>
und mit 2 
<normalizedToken id="BF897267CDCA99E206B929A790243B99" originalValue="ähnlichen" pageId="null" pageNumber="281">aehnlichen</normalizedToken>
<normalizedToken id="88C61BC94DBF59BBE7192A2301067AA9" originalValue="Vorblättern" pageId="null" pageNumber="281">Vorblaettern</normalizedToken>
. 
<emphasis id="10A395EE962EB797CC05CECD75BFF9EB" italics="true" pageId="null" pageNumber="281">Krone gelblich</emphasis>
, mit 3-5 mm langer 
<normalizedToken id="E878BA4032D192713011C8A9AFAF744C" originalValue="Röhre" pageId="null" pageNumber="281">Roehre</normalizedToken>
und kleinen, zugespitzten Zipfeln, 
<emphasis id="0374990276CFA857E18B94A0C98350E8" italics="true" pageId="null" pageNumber="281">
kaum 
<normalizedToken id="60832AC9EE9156261763E6B51A201805" originalValue="länger" pageId="null" pageNumber="281">laenger</normalizedToken>
als Trag- und 
<normalizedToken id="2C77E3F9338E198223796BCB2E04D088" originalValue="Vorblätter" pageId="null" pageNumber="281">Vorblaetter</normalizedToken>
.
</emphasis>
<normalizedToken id="CA7732E25B2FB384E4CE92B8658D596C" originalValue="Früchte" pageId="null" pageNumber="281">Fruechte</normalizedToken>
etwa 2 mm hoch, mit 
<normalizedToken id="43C5A3659EE066D1235FA3A4401EF316" originalValue="feingekörnter" pageId="null" pageNumber="281">feingekoernter</normalizedToken>
<normalizedToken id="DB511D43A8E7B012AEBC8AFBBD2B1496" originalValue="Oberfläche" pageId="null" pageNumber="281">Oberflaeche</normalizedToken>
. - 
<normalizedToken id="E4C9747126A503EB6FA5636F8595591C" originalValue="Blüte" pageId="null" pageNumber="281">Bluete</normalizedToken>
: 
<normalizedToken id="89FF4D19DE4891FC9C2CF8D1C0DCCA45" originalValue="Frühling" pageId="null" pageNumber="281">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="DCE327288B1DC88AE53733BE93180C06" pageId="null" pageNumber="281">
<emphasis id="6F663F92310A58D2C35B9C6B41BAF74B" italics="true" pageId="null" pageNumber="281">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="AE04D79B6CDFC8230065E900E68C0098" italics="true" pageId="null" pageNumber="281">22:</emphasis>
Material aus Frankreich (Poucques 1949).
</paragraph>
<paragraph id="64D05CDF847B2E513A19DA59696B6042" pageId="null" pageNumber="281">
<emphasis id="2A37DEEA9EFB9E0C61F0802432AF5219" italics="true" pageId="null" pageNumber="281">Standort.</emphasis>
Kollin und montan. Trockene, sandige, kalkarme 
<normalizedToken id="E5D839899A7CD82F2CD95B9FA94EEA7E" originalValue="Böden" pageId="null" pageNumber="281">Boeden</normalizedToken>
in warmen Lagen. Trockenrasen, Bahnareale.
</paragraph>
<paragraph id="4D285D346A175728FD55BE72190FEF52" pageId="null" pageNumber="281">
<emphasis id="FAC32936C41A73E9116B317C0E7EDB43" italics="true" pageId="null" pageNumber="281">Verbreitung. Mediterrane Pflanze:</emphasis>
Ganzes Mittelmeergebiet; 
<normalizedToken id="B8955D6D2DBA621FA545A5798F56B242" originalValue="nordwärts" pageId="null" pageNumber="281">nordwaerts</normalizedToken>
bis 
<normalizedToken id="B04D43CF1EB105974A79ADD3D7A69646" originalValue="Südfrankreich" pageId="null" pageNumber="281">Suedfrankreich</normalizedToken>
, 
<normalizedToken id="78B8D4100C912F0DEB560C286CE61B9E" originalValue="Südalpen" pageId="null" pageNumber="281">Suedalpen</normalizedToken>
, Dalmatien. - Im Gebiet: Aostatal (z. B. Veynes bei Aosta, nach Braun-Blanquet 1961); selten auch adventiv.
</paragraph>
</subSubSection>
