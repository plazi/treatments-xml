LOCALITY: 
<location id="8EF20DDDF76CB12DB096F9C830134513" LSID="urn:lsid:plazi:treatment:0384EA10F76CB12DB1D2FC9833A645DB:8EF20DDDF76CB12DB096F9C830134513" box="[467,554,1591,1617]" name="Durban" pageId="25" pageNumber="546" stateProvince="KwaZulu-Natal">Durban</location>
