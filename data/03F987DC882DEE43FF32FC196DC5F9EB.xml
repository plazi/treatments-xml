<emphasis id="B924EAD8882DEE43FDCEFAFB6EB1FA83" box="[619,764,1328,1354]" italics="true" pageId="5" pageNumber="388">M. anatolica</emphasis>
</taxonomicName>
<emphasis id="B924EAD8882DEE43FCA1FAFA6F09FA83" bold="true" box="[772,836,1328,1354]" pageId="5" pageNumber="388">
<taxonomicNameLabel id="A21757A3882DEE43FCA1FAFA6F09FA83" box="[772,836,1328,1354]" pageId="5" pageNumber="388" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="136B2A4F882DEE43FCF6FAFA6FD0FA83" box="[851,925,1328,1354]" captionStart="FIGURES 4–12" captionStartId="2.[151,264,1943,1967]" captionTargetBox="[320,1267,181,1920]" captionTargetId="figure-31@2.[320,1267,181,1920]" captionTargetPageId="2" captionText="FIGURES 4–12. 4–6 Maimuna anatolica sp. n., holotype male, right palp (flipped). 7–9 Maimuna cariae, paratype male, left palp. 10–12 Maimuna vestita, male, left palp. 1,7, 10 ventral 5, 8, 11 retrolateral; 6, 9, 12 prolateral. Scale line: 0.5 mm" figureDoi="http://doi.org/10.5281/zenodo.6411052" httpUri="https://zenodo.org/record/6411052/files/figure.png" pageId="5" pageNumber="388">Figs 4</figureCitation>
