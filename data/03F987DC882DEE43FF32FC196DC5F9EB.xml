<figureCitation id="136B2A4F882DEE43FC0FFAFA6F84FA83" box="[938,969,1328,1354]" captionStart="FIGURES 21–27" captionStartId="4.[151,264,1781,1805]" captionTargetBox="[156,1433,181,1758]" captionTargetId="figure-31@4.[151,1435,181,1758]" captionTargetPageId="4" captionText="FIGURES 21–27. 21–23 Maimuna anatolica sp. n., male holotype. 24–25 Maimuna anatolica sp. n., female paratype. 26 Maimuna cariae, male paratype. 27 Maimuna vestita, male. 21, 26–27 palp, ventral. 22 palp prolateral. 23 palp retrolateral. 24 epigyne, ventral view. 25 vulva, dorsal view. Scale line: 0.5 mm" figureDoi="http://doi.org/10.5281/zenodo.6411056" httpUri="https://zenodo.org/record/6411056/files/figure.png" pageId="5" pageNumber="388">21</figureCitation>
