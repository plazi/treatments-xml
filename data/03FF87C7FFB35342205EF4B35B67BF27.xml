<taxonomicName id="4C564D52FFB353432174F2DA5A1EB6E3" authorityName="Burmeister" authorityYear="1876" box="[1098,1312,3453,3474]" class="Mammalia" family="Caviidae" genus="Dolichotis" kingdom="Animalia" order="Rodentia" pageId="2" pageNumber="433" phylum="Chordata" rank="species" species="salinicola">Dolichotis salinicola</taxonomicName>
