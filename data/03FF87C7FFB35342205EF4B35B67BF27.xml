<taxonomicName id="4C564D52FFB353432425F28E5ED0B633" box="[283,494,3369,3394]" class="Mammalia" family="Caviidae" genus="Microcavia" kingdom="Animalia" order="Rodentia" pageId="2" pageNumber="433" phylum="Chordata" rank="species" species="shiptoni">Microcavia shiptoni</taxonomicName>
