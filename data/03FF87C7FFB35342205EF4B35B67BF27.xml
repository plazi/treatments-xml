<taxonomicName id="4C564D52FFB353432595F2DA5E55B6E3" authorityName="Moojen, Locks &amp; Langguth" authorityYear="1997" box="[171,363,3453,3474]" class="Mammalia" family="Caviidae" genus="Kerodon" kingdom="Animalia" order="Rodentia" pageId="2" pageNumber="433" phylum="Chordata" rank="species" species="acrobata">Kerodon acrobata</taxonomicName>
