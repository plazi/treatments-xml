<taxonomicName id="4C564D52FFB353432751F2DA5C60B6E3" baseAuthorityName="Zimmermann" baseAuthorityYear="1780" box="[623,862,3453,3474]" class="Mammalia" family="Caviidae" genus="Dolichotis" kingdom="Animalia" order="Rodentia" pageId="2" pageNumber="433" phylum="Chordata" rank="species" species="patagonum">Dolichotis patagonum</taxonomicName>
