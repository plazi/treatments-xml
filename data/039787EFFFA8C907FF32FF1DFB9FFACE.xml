<taxonomicName id="4C3E4D7AFFA8C907FE0AFE51FD9EFE36" authority="Rheims &amp; Jäger, 2022" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[431,528,475,501]" class="Arachnida" family="Salticidae" genus="Sadala" kingdom="Animalia" order="Araneae" pageId="9" pageNumber="10" phylum="Arthropoda" rank="species" species="kaiabi" status="spec. nov.">
<emphasis id="B94AEAEBFFA8C907FE0AFE51FD9EFE36" box="[431,528,475,501]" italics="true" pageId="9" pageNumber="10">S. kaiabi</emphasis>
</taxonomicName>
