<collectingCountry id="BC83766EFFB76A08FC29978F1A45BAC1" box="[981,1093,470,499]" name="Uganda" pageId="76" pageNumber="834">Uganda</collectingCountry>
, and 
<collectingCountry id="BC83766EFFB76A08FB4C978F1B30BAC1" box="[1200,1328,470,499]" name="Tanzania" pageId="76" pageNumber="834">Tanzania</collectingCountry>
