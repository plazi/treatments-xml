<paragraph id="8BD136A7FFA1FFCBD4CCF8950C0AFF6A" blockId="92.[151,1436,1854,2025]" lastBlockId="93.[151,1437,151,1582]" lastPageId="93" lastPageNumber="94" pageId="92" pageNumber="93">
<emphasis id="B91AEAB5FFA1FFCAD4CCF8950C1AF8CB" bold="true" box="[199,322,1854,1880]" pageId="92" pageNumber="93">Diagnosis.</emphasis>
Males of 
<taxonomicName id="4C6E4D24FFA1FFCAD5B0F8950FD4F8CB" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" box="[443,652,1854,1880]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="92" pageNumber="93" phylum="Arthropoda" rank="species" species="eberhardi" status="sp. n.">
<emphasis id="B91AEAB5FFA1FFCAD5B0F8950FD4F8CB" box="[443,652,1854,1880]" italics="true" pageId="92" pageNumber="93">Tenedos eberhardi</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFA1FFCAD69DF8950F81F8CB" bold="true" box="[662,729,1854,1880]" pageId="92" pageNumber="93">
<taxonomicNameLabel id="A22957CEFFA1FFCAD69DF8950F81F8CB" box="[662,729,1854,1880]" pageId="92" pageNumber="93" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
