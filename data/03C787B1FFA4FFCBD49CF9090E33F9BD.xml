<taxonomicName id="4C6E4D24FFA1FFCAD768F8940EB6F8CB" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" box="[867,1006,1855,1880]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="92" pageNumber="93" phylum="Arthropoda" rank="species" species="santarosa" status="sp. n.">
<emphasis id="B91AEAB5FFA1FFCAD768F8940EB6F8CB" box="[867,1006,1855,1880]" italics="true" pageId="92" pageNumber="93">T. santarosa</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFA1FFCAD7F2F8950963F8CB" bold="true" box="[1017,1083,1854,1880]" pageId="92" pageNumber="93">
<taxonomicNameLabel id="A22957CEFFA1FFCAD7F2F8950963F8CB" box="[1017,1083,1854,1880]" pageId="92" pageNumber="93" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
and 
<taxonomicName id="4C6E4D24FFA1FFCAD07CF89409BBF8CB" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" box="[1143,1251,1855,1880]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="92" pageNumber="93" phylum="Arthropoda" rank="species" species="tatama" status="sp. n.">
<emphasis id="B91AEAB5FFA1FFCAD07CF89409BBF8CB" box="[1143,1251,1855,1880]" italics="true" pageId="92" pageNumber="93">T. tatama</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFA1FFCAD0E6F8950877F8CB" bold="true" box="[1261,1327,1854,1880]" pageId="92" pageNumber="93">
<taxonomicNameLabel id="A22957CEFFA1FFCAD0E6F8950877F8CB" box="[1261,1327,1854,1880]" pageId="92" pageNumber="93" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
, by wide posterior branch of the retrolateral tibial apophysis (pRTA) and thin anterior branch (aRTA) (
<figureCitation id="13552A22FFA1FFCAD0A2F8C90861F8EF" box="[1193,1337,1890,1916]" captionStart="FIGURE 64" captionStartId="91.[151,250,1943,1967]" captionTargetBox="[277,1310,189,1920]" captionTargetId="figure-19@91.[277,1310,181,1920]" captionTargetPageId="91" captionText="FIGURE 64. Tenedos eberhardi sp. n. A–D. Male palp (IAvH-I-659):A. Prolateral view. B. Retroventral view. C. Ventral view. D. Retrolateral view. E–F. Female epigyne (IAvH-I-585): E. Ventral view. F. Dorsal view. Scale bars: A–B: 300µm; C–D: 500 µm; E–F: 200µm." figureDoi="http://doi.org/10.5281/zenodo.6520936" httpUri="https://zenodo.org/record/6520936/files/figure.png" pageId="92" pageNumber="93">Figs 64A–D</figureCitation>
; 
<figureCitation id="13552A22FFA1FFCAD14FF8C908C0F8EE" box="[1348,1432,1890,1917]" captionStart="FIGURE 65" captionStartId="92.[151,250,1640,1664]" captionTargetBox="[153,1432,196,1606]" captionTargetId="figure-27@92.[151,1436,181,1616]" captionTargetPageId="92" captionText="FIGURE 65. Tenedos eberhardi sp. n. A–B. Male palp (IAvH-I-659): A. Ventral view. B. Retrolateral view. C–D. Female epigyne (IAvH-I-585): C. Ventral view. D. Dorsal view. Scale bars: A–B: 200µm; C–D: 500µm. Abbreviations: ApC, appendix of the conductor; C, conductor; E, embolus; FD, fertilization ducts; LB, lateral borders; MA, median apophysis; pRTA, posterior branch of the retrolateral tibial apophysis; MFP, median field plate; RPC, retrolateral process of the cymbium; S, spermathecae; SD, spermatic ducts; SR, seminal receptacles; T, tegulum; VTA, ventral tegular apophysis." figureDoi="http://doi.org/10.5281/zenodo.6520939" httpUri="https://zenodo.org/record/6520939/files/figure.png" pageId="92" pageNumber="93">65A–B</figureCitation>
; 
<figureCitation id="13552A22FFA1FFCAD49CF82D0DB5F833" box="[151,237,1926,1952]" captionStart="FIGURE 67" captionStartId="95.[151,250,1943,1967]" captionTargetBox="[256,1331,191,1920]" captionTargetId="figure-19@95.[256,1331,181,1920]" captionTargetPageId="95" captionText="FIGURE 67. Tenedos santarosa sp. n. A–D. Male palp (IAvH-I-651):A. Prolateral view. B. Retroventral view. C. Ventral view. D. Retrolateral view. E–F. Female epigyne (IAvH-I-656): E. Ventral view. F. Dorsal view. Scale bars: A–B: 300µm; C–D: 500 µm; E–F: 200µm." figureDoi="http://doi.org/10.5281/zenodo.6520944" httpUri="https://zenodo.org/record/6520944/files/figure.png" pageId="92" pageNumber="93">67A–D</figureCitation>
; 
<figureCitation id="13552A22FFA1FFCAD4F3F82D0C14F833" box="[248,332,1926,1952]" captionStart="FIGURE 68" captionStartId="96.[151,250,1910,1934]" captionTargetBox="[182,1405,422,1877]" captionTargetId="figure-131@96.[179,1409,417,1887]" captionTargetPageId="96" captionText="FIGURE 68. Tenedos santarosa sp. n. A–B. Male palp (IAvH-I-651): A. Ventral view. B. Retrolateral view. C–D. Female epigyne (IAvH-I-656): C. Ventral view. D. Dorsal view. Scale bars: A–B: 200µm; C–D: 500µm. Abbreviations: ApC, appendix of the conductor; FD, fertilization ducts; LB, lateral borders; pRTA, posterior branch of the retrolateral tibial apophysis; MFP, median field plate; S, spermathecae; SR, seminal receptacles; T, tegulum; VTA, ventral tegular apophysis." figureDoi="http://doi.org/10.5281/zenodo.6520946" httpUri="https://zenodo.org/record/6520946/files/figure.png" pageId="92" pageNumber="93">68A–B</figureCitation>
; 
<figureCitation id="13552A22FFA1FFCAD553F82D0CF5F833" box="[344,429,1926,1952]" captionStart="FIGURE 70" captionStartId="99.[151,250,1943,1967]" captionTargetBox="[226,1361,201,1920]" captionTargetId="figure-19@99.[226,1361,181,1920]" captionTargetPageId="99" captionText="FIGURE 70. Tenedos tatama sp. n. A–D. Male palp (IAvH-I-2965): A. Prolateral view. B. Retroventral view. C. Ventral view. D. Retrolateral view. E–F. Female epigyne (IAvH-I-666): E. Ventral view. F. Dorsal view. Scale bars: A–B: 300µm; C–D: 500 µm; E–F: 200µm." figureDoi="http://doi.org/10.5281/zenodo.6520950" httpUri="https://zenodo.org/record/6520950/files/figure.png" pageId="92" pageNumber="93">70A–D</figureCitation>
; 
<figureCitation id="13552A22FFA1FFCAD5B3F82D0F55F833" box="[440,525,1926,1952]" captionStart="FIGURE 71" captionStartId="100.[151,250,1680,1704]" captionTargetBox="[158,1430,189,1650]" captionTargetId="figure-27@100.[151,1436,181,1656]" captionTargetPageId="100" captionText="FIGURE 71. Tenedos tatama sp. n. A–B. Male palp (IAvH-I-2965): A. Ventral view. B. Retrolateral view. C–D. Female epigyne (IAvH-I-666): C. Ventral view. D. Dorsal view. Scale bars: A–B: 200µm; C–D: 500µm. Abbreviations: ApC, appendix of the conductor; C, conductor; FD, fertilization ducts; MA, median apophysis; pRTA, posterior branch of the retrolateral tibial apophysis; MFP, median field plate; S, spermathecae; St, subtegulum; SR, seminal receptacles; VTA, ventral tegular apophysis." figureDoi="http://doi.org/10.5281/zenodo.6520952" httpUri="https://zenodo.org/record/6520952/files/figure.png" pageId="92" pageNumber="93">71A–B</figureCitation>
), further this species is distinguished from 
<taxonomicName id="4C6E4D24FFA1FFCAD7E6F82C092DF833" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" box="[1005,1141,1927,1952]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="92" pageNumber="93" phylum="Arthropoda" rank="species" species="santarosa" status="sp. n.">
<emphasis id="B91AEAB5FFA1FFCAD7E6F82C092DF833" box="[1005,1141,1927,1952]" italics="true" pageId="92" pageNumber="93">T. santarosa</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFA1FFCAD077F82D09E3F833" bold="true" box="[1148,1211,1926,1952]" pageId="92" pageNumber="93">
<taxonomicNameLabel id="A22957CEFFA1FFCAD077F82D09E3F833" box="[1148,1211,1926,1952]" pageId="92" pageNumber="93" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
by having nine dorsal abdominal spots (vs thirteen 
<taxonomicName id="4C6E4D24FFA1FFCAD5F6F8000FDDF857" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" box="[509,645,1963,1988]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="92" pageNumber="93" phylum="Arthropoda" rank="species" species="santarosa" status="sp. n.">
<emphasis id="B91AEAB5FFA1FFCAD5F6F8000FDDF857" box="[509,645,1963,1988]" italics="true" pageId="92" pageNumber="93">T. santarosa</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFA1FFCAD680F8010F92F857" bold="true" box="[651,714,1962,1988]" pageId="92" pageNumber="93">
<taxonomicNameLabel id="A22957CEFFA1FFCAD680F8010F92F857" box="[651,714,1962,1988]" pageId="92" pageNumber="93" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
). Males are diagnosed by flattened median apophysis (MA) with very short anterior tip, wide posterior branch of the retrolateral tibial apophysis (pRTA). Females are characterized by lateral borders (LB) reaching the basal region of median field plate (MFP); median field plate flattened in dorsal surface; seminal receptacle forming glass-shaped lumen in dorsal view (
<figureCitation id="13552A22FFA0FFCBD7F8FF100923FF46" box="[1011,1147,187,213]" captionStart="FIGURE 64" captionStartId="91.[151,250,1943,1967]" captionTargetBox="[277,1310,189,1920]" captionTargetId="figure-19@91.[277,1310,181,1920]" captionTargetPageId="91" captionText="FIGURE 64. Tenedos eberhardi sp. n. A–D. Male palp (IAvH-I-659):A. Prolateral view. B. Retroventral view. C. Ventral view. D. Retrolateral view. E–F. Female epigyne (IAvH-I-585): E. Ventral view. F. Dorsal view. Scale bars: A–B: 300µm; C–D: 500 µm; E–F: 200µm." figureDoi="http://doi.org/10.5281/zenodo.6520936" httpUri="https://zenodo.org/record/6520936/files/figure.png" pageId="93" pageNumber="94">Figs 64E–F</figureCitation>
; 
<figureCitation id="13552A22FFA0FFCBD083FF110984FF46" box="[1160,1244,186,213]" captionStart="FIGURE 65" captionStartId="92.[151,250,1640,1664]" captionTargetBox="[153,1432,196,1606]" captionTargetId="figure-27@92.[151,1436,181,1616]" captionTargetPageId="92" captionText="FIGURE 65. Tenedos eberhardi sp. n. A–B. Male palp (IAvH-I-659): A. Ventral view. B. Retrolateral view. C–D. Female epigyne (IAvH-I-585): C. Ventral view. D. Dorsal view. Scale bars: A–B: 200µm; C–D: 500µm. Abbreviations: ApC, appendix of the conductor; C, conductor; E, embolus; FD, fertilization ducts; LB, lateral borders; MA, median apophysis; pRTA, posterior branch of the retrolateral tibial apophysis; MFP, median field plate; RPC, retrolateral process of the cymbium; S, spermathecae; SD, spermatic ducts; SR, seminal receptacles; T, tegulum; VTA, ventral tegular apophysis." figureDoi="http://doi.org/10.5281/zenodo.6520939" httpUri="https://zenodo.org/record/6520939/files/figure.png" pageId="93" pageNumber="94">65C–D</figureCitation>
; 
<figureCitation id="13552A22FFA0FFCBD0E2FF10086EFF46" box="[1257,1334,187,213]" captionStart="FIGURE 67" captionStartId="95.[151,250,1943,1967]" captionTargetBox="[256,1331,191,1920]" captionTargetId="figure-19@95.[256,1331,181,1920]" captionTargetPageId="95" captionText="FIGURE 67. Tenedos santarosa sp. n. A–D. Male palp (IAvH-I-651):A. Prolateral view. B. Retroventral view. C. Ventral view. D. Retrolateral view. E–F. Female epigyne (IAvH-I-656): E. Ventral view. F. Dorsal view. Scale bars: A–B: 300µm; C–D: 500 µm; E–F: 200µm." figureDoi="http://doi.org/10.5281/zenodo.6520944" httpUri="https://zenodo.org/record/6520944/files/figure.png" pageId="93" pageNumber="94">67E–F</figureCitation>
; 
<figureCitation id="13552A22FFA0FFCBD148FF1008C0FF46" box="[1347,1432,187,213]" captionStart="FIGURE 68" captionStartId="96.[151,250,1910,1934]" captionTargetBox="[182,1405,422,1877]" captionTargetId="figure-131@96.[179,1409,417,1887]" captionTargetPageId="96" captionText="FIGURE 68. Tenedos santarosa sp. n. A–B. Male palp (IAvH-I-651): A. Ventral view. B. Retrolateral view. C–D. Female epigyne (IAvH-I-656): C. Ventral view. D. Dorsal view. Scale bars: A–B: 200µm; C–D: 500µm. Abbreviations: ApC, appendix of the conductor; FD, fertilization ducts; LB, lateral borders; pRTA, posterior branch of the retrolateral tibial apophysis; MFP, median field plate; S, spermathecae; SR, seminal receptacles; T, tegulum; VTA, ventral tegular apophysis." figureDoi="http://doi.org/10.5281/zenodo.6520946" httpUri="https://zenodo.org/record/6520946/files/figure.png" pageId="93" pageNumber="94">68C–D</figureCitation>
; 
<figureCitation id="13552A22FFA0FFCBD49CFF740DBDFF6A" box="[151,229,223,249]" captionStart="FIGURE 70" captionStartId="99.[151,250,1943,1967]" captionTargetBox="[226,1361,201,1920]" captionTargetId="figure-19@99.[226,1361,181,1920]" captionTargetPageId="99" captionText="FIGURE 70. Tenedos tatama sp. n. A–D. Male palp (IAvH-I-2965): A. Prolateral view. B. Retroventral view. C. Ventral view. D. Retrolateral view. E–F. Female epigyne (IAvH-I-666): E. Ventral view. F. Dorsal view. Scale bars: A–B: 300µm; C–D: 500 µm; E–F: 200µm." figureDoi="http://doi.org/10.5281/zenodo.6520950" httpUri="https://zenodo.org/record/6520950/files/figure.png" pageId="93" pageNumber="94">70E–F</figureCitation>
