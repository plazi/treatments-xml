<figureCitation id="C5FF10EEFF91EF52FF12F891FE95F887" box="[151,288,1828,1855]" captionStart="FIGURE 30" captionStartId="56.[151,250,1861,1885]" captionTargetBox="[239,1353,184,1836]" captionTargetId="figure-29@56.[231,1357,181,1837]" captionTargetPageId="56" captionText="FIGURE 30. Calling songs of the species of Pseudophyllinae from the ParNa Iguaçu. A–C: Meroncidius flavolimbatus; D–F: Dasyscelus normalis; G–I: Brachyteleutias flavolimbatus. A: sonogram of one echeme (the “noise” before the echeme corresponds to drumming behaviour); B: sonogram of one echeme; C: spectrogram of one syllable; D: sonogram of three echemes; E: sonogram of one echeme; F: sonogram of two syllables, (note the change of dominant frequency along time); G: sonogram of one echeme; H and I: sonogram and spectrogram of two syllables, respectively." figureDoi="http://doi.org/10.5281/zenodo.6550135" httpUri="https://zenodo.org/record/6550135/files/figure.png" pageId="57" pageNumber="58">Fig. 30G, H</figureCitation>
; 
<figureCitation id="C5FF10EEFF91EF52FEA9F891FEEEF886" box="[300,347,1828,1854]" captionStart="FIGURE 31" captionStartId="57.[151,250,1048,1072]" captionTargetBox="[176,1410,489,1016]" captionTargetId="figure-123@57.[176,1411,489,1025]" captionTargetPageId="57" captionText="FIGURE 31. Live specimens of Pseudophyllinae from the ParNa Iguaçu. A: Dasyscelus normalis; B: Brachyteleutias bilineattus; C: Gongrocnemis (Melanocnemis) hilaris; D: Meroncidius flavolimbatus; A–C: photos by Marcos Fianco; D: photo by Pedro. G.B. Souza-Dias." figureDoi="http://doi.org/10.5281/zenodo.6550137" httpUri="https://zenodo.org/record/6550137/files/figure.png" pageId="57" pageNumber="58">31B</figureCitation>
</paragraph>
</subSubSection>
<subSubSection id="15DE5FE0FF91EF52FF12F8D9FCB5F813" pageId="57" pageNumber="58" type="distribution">
<paragraph id="5D7B0C6BFF91EF52FF12F8D9FD56F83F" blockId="57.[151,1436,1899,2035]" box="[151,739,1899,1927]" pageId="57" pageNumber="58">
<emphasis id="6FB0D079FF91EF52FF12F8D9FE86F83E" bold="true" box="[151,307,1900,1926]" pageId="57" pageNumber="58">Distribution:</emphasis>
Argentina: Misiones; 
<emphasis id="6FB0D079FF91EF52FDA8F8D9FDC3F83E" bold="true" box="[557,630,1900,1926]" pageId="57" pageNumber="58">
<collectingCountry id="25D34CFBFF91EF52FDA8F8D9FDC3F83E" box="[557,630,1900,1926]" name="Brazil" pageId="57" pageNumber="58">Brazil</collectingCountry>
</emphasis>
: 
<emphasis id="6FB0D079FF91EF52FD00F8DEFD69F83E" bold="true" box="[645,732,1899,1926]" pageId="57" pageNumber="58">
<collectingRegion id="9F00C289FF91EF52FD00F8DEFD69F83E" box="[645,732,1899,1926]" country="Brazil" name="Parana" pageId="57" pageNumber="58">Paraná</collectingRegion>
</emphasis>
