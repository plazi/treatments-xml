<paragraph id="8BBB36ECFFFFF6118BC13506FBB9FE4F" blockId="59.[703,1329,282,704]" pageId="59" pageNumber="117">
<taxonomicName id="4C044D6FFFFFF6118BC13506FC42FEAC" baseAuthorityName="Bergmans" baseAuthorityYear="2001" box="[735,999,282,311]" class="Mammalia" family="Pteropodidae" genus="Paranyctimene" kingdom="Animalia" order="Chiroptera" pageId="59" pageNumber="117" phylum="Chordata" rank="species" species="tenax">Paranyctimene tenax</taxonomicName>
