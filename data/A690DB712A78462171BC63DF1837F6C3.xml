<taxonomicName id="67D5B2A61FAB4527148983EEB93FCC1A" authority="L." class="Liliopsida" family="Liliaceae" genus="Tulipa" kingdom="Plantae" order="Liliales" pageId="null" pageNumber="551" phylum="Tracheophyta" rank="species" species="silvestris">
