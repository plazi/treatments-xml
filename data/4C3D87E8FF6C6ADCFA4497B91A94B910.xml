<taxonomicName id="03944D7DFF6C6AD3F7E7924A17ADBF02" authority="Kruskop, 2005" authorityName="Kruskop" authorityYear="2005" box="[2075,2477,1043,1072]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="151" pageNumber="912" phylum="Chordata" rank="subSpecies" species="ussuriensis" subSpecies="katerinae">M.u.katerinaeKruskop,2005—SSakhalin;</taxonomicName>
