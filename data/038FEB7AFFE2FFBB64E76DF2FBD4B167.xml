<subSubSection id="C33C09E7FFE2FFBB67206FF3FBD4B167" pageId="9" pageNumber="112" type="discussion">
<paragraph id="8B995A6CFFE2FFBB67206FF3FBD4B167" blockId="9.[831,1437,1743,2054]" pageId="9" pageNumber="112">
<emphasis id="B952867EFFE2FFBB67206FF3FC01BF87" bold="true" box="[831,947,1743,1766]" pageId="9" pageNumber="112">Remarks:</emphasis>
This species is a member of the 
<taxonomicName id="4C2621EFFFE2FFBB67206FD3FC47BE66" authorityName="Pic" authorityYear="1956" box="[831,1013,1775,1799]" class="Insecta" family="Staphylinidae" genus="Scaphisoma" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="112" phylum="Arthropoda" rank="species" species="unifasciatum">
<emphasis id="B952867EFFE2FFBB67206FD3FC47BE66" box="[831,1013,1775,1799]" italics="true" pageId="9" pageNumber="112">S. unifasciatum</emphasis>
</taxonomicName>
group defined in 
<bibRefCitation id="EFB7279DFFE2FFBB60F86FD3FADDBE67" author="Lobl I." box="[1255,1391,1775,1798]" pageId="9" pageNumber="112" pagination="3 - 69" refId="ref11156" refString="Lobl I. 1977. Beitrag zur Kenntnis der Scaphidiidae (Coleoptera) Australiens. Revue suisse de Zoologie 84: 3 - 69." type="journal article" year="1977">Löbl, 1977</bibRefCitation>
. In addition to 
<taxonomicName id="4C2621EFFFE2FFBB67C36E33FB27BE46" authorityName="Lobl" authorityYear="1977" box="[988,1173,1807,1831]" class="Insecta" family="Staphylinidae" genus="Scaphisoma" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="112" phylum="Arthropoda" rank="species" species="sublimbatum">
<emphasis id="B952867EFFE2FFBB67C36E33FB27BE46" box="[988,1173,1807,1831]" italics="true" pageId="9" pageNumber="112">S. sublimbatum</emphasis>
</taxonomicName>
, the group includes four New Guinean species: 
<taxonomicName id="4C2621EFFFE2FFBB60866E13FA25BE27" authority="Lobl, 1975" authorityName="Lobl" authorityYear="1975" box="[1177,1431,1839,1863]" class="Insecta" family="Staphylinidae" genus="Scaphisoma" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="112" phylum="Arthropoda" rank="species" species="audax">
<emphasis id="B952867EFFE2FFBB60866E13FAB3BE26" box="[1177,1281,1839,1863]" italics="true" pageId="9" pageNumber="112">S. audax</emphasis>
<bibRefCitation id="EFB7279DFFE2FFBB610C6E13FA25BE27" author="Lobl I." box="[1299,1431,1839,1862]" pageId="9" pageNumber="112" pagination="369 - 420" refId="ref11102" refString="Lobl I. 1975. Beitrag zur Kenntnis der Scaphidiidae (Coleoptera) von Neuguinea. Revue suisse de Zoologie 82: 369 - 420." type="journal article" year="1975">Löbl, 1975</bibRefCitation>
</taxonomicName>
, 
<taxonomicName id="4C2621EFFFE2FFBB67206E73FB1ABE07" authority="(Pic, 1956)" baseAuthorityName="Pic" baseAuthorityYear="1956" box="[831,1192,1871,1895]" class="Insecta" family="Staphylinidae" genus="Scaphisoma" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="112" phylum="Arthropoda" rank="species" species="quadripunctatum">
<emphasis id="B952867EFFE2FFBB67206E73FBA8BE06" box="[831,1050,1871,1895]" italics="true" pageId="9" pageNumber="112">S. quadripunctatum</emphasis>
(Pic, 1956)
</taxonomicName>
, 
<taxonomicName id="4C2621EFFFE2FFBB60A66E73FCC5BEE7" authority="Pic, 1956" authorityName="Pic" authorityYear="1956" class="Insecta" family="Staphylinidae" genus="Scaphisoma" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="112" phylum="Arthropoda" rank="species" species="unifasciatum">
<emphasis id="B952867EFFE2FFBB60A66E73FAD4BE06" box="[1209,1382,1871,1895]" italics="true" pageId="9" pageNumber="112">S. unifasciatum</emphasis>
Pic, 1956
</taxonomicName>
, and 
<taxonomicName id="4C2621EFFFE2FFBB67A76E53FB4BBEE7" authority="Lobl, 1975" authorityName="Lobl" authorityYear="1975" box="[952,1273,1903,1927]" class="Insecta" family="Staphylinidae" genus="Scaphisoma" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="112" phylum="Arthropoda" rank="species" species="unimaculatum">
