<taxonomicName id="4C6F4D506424FF8CFDD9F0514D7AC07A" authority="Coryell &amp; Rogatz, 1932" authorityName="Coryell &amp; Rogatz" authorityYear="1932" box="[638,1032,1557,1584]" class="Ostracoda" family="Geisinidae" genus="Knoxina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Platycopina" pageId="20" pageNumber="21" phylum="Arthropoda" rank="genus">
