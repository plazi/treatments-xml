<taxonomicName id="4C6F4D506424FF8CFF1AF18D4BF6C1B7" authority="Coryell &amp; Rogatz, 1932" authorityName="Coryell &amp; Rogatz" authorityYear="1932" box="[189,644,1992,2019]" class="Ostracoda" family="Geisinidae" genus="Knoxina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Platycopina" pageId="20" pageNumber="21" phylum="Arthropoda" rank="species" species="lecta">
