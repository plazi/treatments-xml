<subSubSection id="5990D6B6636B321A6222F010AEDB28A8" pageId="null" pageNumber="580" type="description">
<paragraph id="BF2304EBCB67E9AA3379C38C12F6706E" pageId="null" pageNumber="580">
Unterscheidet sich von 
<taxonomicName id="9BA65802FECD50D5D9A77F8574D42A14" class="Magnoliopsida" family="Asteraceae" genus="Artemisia" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="580" phylum="Tracheophyta" rank="species" species="vulgaris">
<emphasis id="0B3C0A6DE24364545F44E0AAD768A945" italics="true" pageId="null" pageNumber="580">A. vulgaris</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="AEB47F464FFB26231919207AC6486D01" italics="true" pageId="null" pageNumber="580">
Mit langen 
<normalizedToken id="0EB8F5C631A5C7C5224291C1CC449164" originalValue="Ausläufern" pageId="null" pageNumber="580">Auslaeufern</normalizedToken>
;
</emphasis>
30-200 cm hoch; 
<emphasis id="9D758166EE3505D285902F7904C646FE" italics="true" pageId="null" pageNumber="580">
mit aromatischem Geruch; 
<normalizedToken id="91FE339813B5B16D97E3B706B9D82595" originalValue="Blätter" pageId="null" pageNumber="580">Blaetter</normalizedToken>
von der Mitte des Stengels an 
<normalizedToken id="53C65E3632A188BAF6924514A1E55866" originalValue="aufwärts" pageId="null" pageNumber="580">aufwaerts</normalizedToken>
stets 1fach fiederteilig, mit ganzrandigen, schmal lanzettlichen Abschnitten
</emphasis>
(
<emphasis id="CFE2D8125587EB5C34215294D992922D" italics="true" pageId="null" pageNumber="580">ganzrandiger Mittelabschnitt 6</emphasis>
- 
<emphasis id="DCFB37355CDEAC8C7CD75DA627476F93" italics="true" pageId="null" pageNumber="580">12mal so lang wie breit</emphasis>
)
<emphasis id="C61A06C7CC5A407063FA805E6F496EC8" italics="true" pageId="null" pageNumber="580">;</emphasis>
<normalizedToken id="2FB518B2442CC6A199BCB5BC806FEB60" originalValue="Blüten" pageId="null" pageNumber="580">Blueten</normalizedToken>
<normalizedToken id="CDAB3564F5EA0013812193488AE09DCB" originalValue="rötlich" pageId="null" pageNumber="580">roetlich</normalizedToken>
. - 
<normalizedToken id="CC1E965AE22612D97C6CCC1EA366F5E9" originalValue="Blüte" pageId="null" pageNumber="580">Bluete</normalizedToken>
: 
<normalizedToken id="6042CA4A90D41A6C4DDCE865AF3548A4" originalValue="Später" pageId="null" pageNumber="580">Spaeter</normalizedToken>
Herbst.
</paragraph>
<paragraph id="B1A6DC1E4415E76F19BD3A7BF53E308C" pageId="null" pageNumber="580">
<emphasis id="2F88D80D5A0FFE206E1F41525B6CB1D1" italics="true" pageId="null" pageNumber="580">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="712D148AAFD2D6E033BC55BE075DAA33" italics="true" pageId="null" pageNumber="580">54:</emphasis>
Material aus Bologna, Pollenmeiose normal (Vignoli 1945a), von der Insel Sachalin (Sokolovskaya 1960), aus botanischen 
<normalizedToken id="F366F6D85C80A09592D2B6BFB383D5A9" originalValue="Gärten" pageId="null" pageNumber="580">Gaerten</normalizedToken>
in Europa (Kawatani und Ohno 1964).
</paragraph>
<paragraph id="60A14577093E48C7A5F9C7018AA538E3" pageId="null" pageNumber="580">
<emphasis id="94407CB67F9459B44C529416C54812EE" italics="true" pageId="null" pageNumber="580">Standort.</emphasis>
Kollin und montan. 
<normalizedToken id="35120426C54D52CA8B798E2B956C8F8B" originalValue="Ähnlich" pageId="null" pageNumber="580">Aehnlich</normalizedToken>
wie 
<taxonomicName id="962095B941FA7C37B923AD442699541B" class="Magnoliopsida" family="Asteraceae" genus="Artemisia" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="580" phylum="Tracheophyta" rank="species" species="vulgaris">
<emphasis id="8838A1BBF7A7DA8513631F2B9947A918" italics="true" pageId="null" pageNumber="580">A. vulgaris</emphasis>
</taxonomicName>
(Nr. 1).
</paragraph>
<paragraph id="E9D9FD0ACD6CD37285D7FFAEE9F97281" pageId="null" pageNumber="580">
<emphasis id="0E72B11F47DC497619638ADBA5AE61CC" italics="true" pageId="null" pageNumber="580">Verbreitung.</emphasis>
<normalizedToken id="891C57DFD08D6FA8F324AF41267DCC1B" originalValue="Ursprünglich" pageId="null" pageNumber="580">Urspruenglich</normalizedToken>
<emphasis id="82320744DB2C5BF5D6BDE483D47157DF" italics="true" pageId="null" pageNumber="580">ostasiatische Pflanze</emphasis>
(vgl. Pampani 1929); heute 
<normalizedToken id="8280734FCBDC69DED739B0AB900B452F" originalValue="über" pageId="null" pageNumber="580">ueber</normalizedToken>
ganz Eurasien verschleppt. - Im Gebiet ziemlich verbreitet und oft 
<normalizedToken id="89E196D37FDFD4284116550CFCFB6C5D" originalValue="häufig" pageId="null" pageNumber="580">haeufig</normalizedToken>
, sich ausbreitend.
</paragraph>
<paragraph id="5A83E60FBEB68837CF3BB1B8DCEB2EB2" pageId="null" pageNumber="580">
<emphasis id="1D36C830A73C1A02EBEC8CC30B777D48" italics="true" pageId="null" pageNumber="580">Bemerkungen.</emphasis>
Trat im Gebiet erstmals 1920 im Bodenseegebiet auf.
</paragraph>
</subSubSection>
