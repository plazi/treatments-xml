<subSubSection id="316FD3A2D4FC3AF1B51060491AB7B8FD" pageId="0" pageNumber="1" type="ecology">
<paragraph id="266AC9EFFA20448A0581340AC4214770" pageId="0" pageNumber="1">Ecology and habitat.</paragraph>
<paragraph id="B90098AA23E71C2EC72AC3FB1DC25CE5" pageId="0" pageNumber="1">
<taxonomicName id="84CCBB9AA6A98A0135A4BF84DCC19872" authorityName="Nees, Trans. Linn. Soc. London 17 (1): 51" authorityYear="1834" class="Magnoliopsida" family="Solanaceae" genus="Solanum" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Solanum barbisetum" order="Solanales" pageId="0" pageNumber="1" phylum="Tracheophyta" rank="species" species="barbisetum">
<emphasis id="37BF94BAF812CEEC21D117C446FA19DE" italics="true" pageId="0" pageNumber="1">Solanum barbisetum</emphasis>
</taxonomicName>
grows in open areas, in fields and along forest edges in mixed broadleaf forests; usually from 300 to 2,000 m elevation, more rarely at sea level.
</paragraph>
</subSubSection>
