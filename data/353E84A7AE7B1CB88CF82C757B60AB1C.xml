<subSubSection id="777AE36B93968194786E3BBB7F1A9EBB" pageId="null" pageNumber="89" type="vernacular_names">
<paragraph id="7C1B570A296ED5A3D58EA52AB8A1CF3E" pageId="null" pageNumber="89">
<normalizedToken id="61170D60D6CE079954C940E059EAE76C" originalValue="Stein-Hahnenfuß" pageId="null" pageNumber="89">Stein-Hahnenfuss</normalizedToken>
</paragraph>
</subSubSection>
</title>
<subSubSection id="2C4075A923F35466096DFF32E642FB49" pageId="null" pageNumber="89" type="description">
<paragraph id="5EF751E21400AB494586F274D5F3AFDF" pageId="null" pageNumber="89">
Ausdauernd; 20-50 cm hoch, aufrecht, dicht und zottig behaart. 
<emphasis id="27480E21FA5D4221937CC906F7D60417" italics="true" pageId="null" pageNumber="89">
Wurzeln am Grunde auffallend verdickt. Kein Faserschopf. 
<normalizedToken id="E1D828F84EE35CA09AD839331D4958E3" originalValue="Grundständige" pageId="null" pageNumber="89">Grundstaendige</normalizedToken>
<normalizedToken id="592911FB1C351556794AB41BA98544DE" originalValue="Blätter" pageId="null" pageNumber="89">Blaetter</normalizedToken>
bis auf
</emphasis>
<normalizedToken id="91D0A5D4D91023CD70305B34E6C46F9F" originalValue="½" pageId="null" pageNumber="89">1/2</normalizedToken>
, 
<emphasis id="7E8F397D1A8B0F22C624621F34C0295F" italics="true" pageId="null" pageNumber="89">oft bis zum Grunde 3-5teilig;</emphasis>
Abschnitte breit, selten kurz gestielt, grob 
<normalizedToken id="AA72F8929271F8CD636ABCCE3D78B3C1" originalValue="gezähnt" pageId="null" pageNumber="89">gezaehnt</normalizedToken>
; 
<normalizedToken id="C26334C23A4F2F88FF37384D5E4038CB" originalValue="Zähne" pageId="null" pageNumber="89">Zaehne</normalizedToken>
abgerundet. Stengel 1. 
<normalizedToken id="EAE326E360C40694AB28E29C5C863D67" originalValue="Stengelblätter" pageId="null" pageNumber="89">Stengelblaetter</normalizedToken>
sitzend, stets bis zum Grunde geteilt; Abschnitte schmal lanzettlich. 
<normalizedToken id="F9BB8C2E8C3C01B7296BF46A4EE2F4F7" originalValue="Blütenstand" pageId="null" pageNumber="89">Bluetenstand</normalizedToken>
<normalizedToken id="FEEF7C96CB2D42B9C16845AE5C413BD6" originalValue="mehrblütig" pageId="null" pageNumber="89">mehrbluetig</normalizedToken>
. 
<normalizedToken id="0341D152175B495035F1B460945526D1" originalValue="Blüten" pageId="null" pageNumber="89">Blueten</normalizedToken>
gelb, im Durchmesser 2,5-3,5 cm. 
<emphasis id="86027507E6E6829D1747CAD6AD9D05EE" italics="true" pageId="null" pageNumber="89">
<normalizedToken id="0F0F0127E30FD9BEEA7E6183E6977114" originalValue="Kelchblätter" pageId="null" pageNumber="89">Kelchblaetter</normalizedToken>
<normalizedToken id="1D251E7401F7772186FEEE1EA1037563" originalValue="rückwärts" pageId="null" pageNumber="89">rueckwaerts</normalizedToken>
gerichtet
</emphasis>
. 
<normalizedToken id="D40038B8EDC620849A44B0738F4C424C" originalValue="Früchtchenkopf" pageId="null" pageNumber="89">Fruechtchenkopf</normalizedToken>
und 
<normalizedToken id="10E23830B90B37DD790EF35D756BC5C2" originalValue="Früchtchen" pageId="null" pageNumber="89">Fruechtchen</normalizedToken>
<normalizedToken id="F7711D275D2F2B96449926AB8FE87F11" originalValue="ähnlich" pageId="null" pageNumber="89">aehnlich</normalizedToken>
wie bei 
<taxonomicName id="9C218CC4655546D5F1A4ACF7ACCF702D" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="89" phylum="Tracheophyta" rank="species" species="flabellatus">
<emphasis id="2C79981B750A34B5EE53D6ABE3AA7D8C" italics="true" pageId="null" pageNumber="89">R. flabellatus</emphasis>
</taxonomicName>
(Nr. 21). 
<normalizedToken id="D8FE48E70F8A35B9FB2FA9BAA2F1BCE2" originalValue="Blütenboden" pageId="null" pageNumber="89">Bluetenboden</normalizedToken>
kahl. - 
<normalizedToken id="CF93C9932190FACD4AD7C3CC7A6C2B43" originalValue="Blüte" pageId="null" pageNumber="89">Bluete</normalizedToken>
: 
<normalizedToken id="C88A506954EE55A72328DAE4A37A038C" originalValue="Frühling" pageId="null" pageNumber="89">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="03C2501A2265725C09E01EB7C94A7620" pageId="null" pageNumber="89">
<emphasis id="1688D1F1EB771A71FE140349FC64D349" italics="true" pageId="null" pageNumber="89">Zytologische Angaben</emphasis>
. Keine Untersuchungen.
</paragraph>
<paragraph id="961E485E232B95D45EF5CB7B0E1A51C9" pageId="null" pageNumber="89">
<emphasis id="7E149AB2B2021A65E7B680A1C9C07B82" italics="true" pageId="null" pageNumber="89">Standort</emphasis>
. Kollin. Trockene Wiesen, 
<normalizedToken id="2CDFA5334E985F0E9798E251A2B9F22D" originalValue="Wegränder" pageId="null" pageNumber="89">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="F44DEAF1799ED39974713FF877CAAE81" pageId="null" pageNumber="89">
<emphasis id="86D8C0EB293532B1D5231BF8FD2C1460" italics="true" pageId="null" pageNumber="89">Verbreitung</emphasis>
. Wenig bekannt, da meist mit 
<taxonomicName id="FDE4CC7DF4E69FC248E6EE41385836CA" authority="L." authorityName="L." class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="89" phylum="Tracheophyta" rank="species" species="monspeliacus">
<emphasis id="D0674924C09D46AE3F5D5AC039926EBB" italics="true" pageId="null" pageNumber="89">R. monspeliacus</emphasis>
<authorityName id="D4A52C077A797F844CC4B60EE894F83B" pageId="null" pageNumber="89">L.</authorityName>
</taxonomicName>
vereinigt: Wahrscheinlich Westalpen, Piemont, Sizilien. - Im Gebiet: Aostatal, zwischen 
<normalizedToken id="52D6E5EA7C5CCCB144C6C1324AF2A135" originalValue="Féline" pageId="null" pageNumber="89">Feline</normalizedToken>
und Saint-Marcel.
</paragraph>
<paragraph id="41FA365A877AA6506DC41B6D2412B5EB" pageId="null" pageNumber="89">
<emphasis id="03333D4A1D61E99FBD8F075C2FD23F0E" italics="true" pageId="null" pageNumber="89">Bemerkungen</emphasis>
. Die Verbreitung von 
<taxonomicName id="5356BA792F2FEFBC67E7C6E8823555D7" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="89" phylum="Tracheophyta" rank="species" species="saxatilis">
<emphasis id="B59D343FB8FDC318064BFFC8C7AFCAB3" italics="true" pageId="null" pageNumber="89">R. saxatilis</emphasis>
</taxonomicName>
ist festzustellen und experimentell die Verwandtschaft mit 
<taxonomicName id="4D9F91A9E4A9A76A47D950A73AED9B48" authority="L." authorityName="L." class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="89" phylum="Tracheophyta" rank="species" species="monspeliacus">
<emphasis id="FA028E08BC812BF667557D0D2639BCF1" italics="true" pageId="null" pageNumber="89">R. monspeliacus</emphasis>
<authorityName id="84844E4E4B8C4C6E9C965CBBAFC19101" pageId="null" pageNumber="89">L.</authorityName>
</taxonomicName>
zu untersuchen.
</paragraph>
</subSubSection>
