<quantity id="036C9B1BFF666AD9F8D69E0C198EB344" box="[1834,1934,2133,2166]" metricMagnitude="3" metricUnit="m" metricValue="1.78" pageId="157" pageNumber="918" unit="m" value="1780.0">1780 m</quantity>
(type locality).
</paragraph>
</subSubSection>
