<bibRefCitation id="DA0D870AE258510911A63D758AC8CFC5" author="Albre, Jerome" journalOrPublisher="Annales de la Societe entomologique de France (N. S.)" pageId="0" pageNumber="83231" pagination="497 - 508" refId="B7826400" refString="Albre, Jerome, Gibernau, Marc, 2019. Diversity and temporal variations of the Hemiptera Auchenorrhyncha fauna in the Ajaccio region (France, Corsica). Annales de la Societe entomologique de France (N.S.) 55 (6): 497 - 508" title="Diversity and temporal variations of the Hemiptera Auchenorrhyncha fauna in the Ajaccio region (France, Corsica)" volume="55" year="2019">Albre and Gibernau 2019</bibRefCitation>
