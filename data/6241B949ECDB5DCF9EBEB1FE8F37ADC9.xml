<bibRefCitation id="8DC1DD4EAFD5238D590F54662AD40CB7" author="Koranyi, David" journalOrPublisher="Opuscula Zoologica Budapest" pageId="0" pageNumber="83231" pagination="71 - 75" refId="B7834428" refString="Koranyi, David, Marko, Viktor, Haltrich, Attila, Orosz, Andras, 2018. First records of Latilica maculipes (Hemiptera: Issidae) and Synophropsis lauri (Hemiptera: Cicadellidae) in Hungary. Opuscula Zoologica Budapest 49 (1): 71 - 75" title="First records of Latilica maculipes (Hemiptera: Issidae) and Synophropsis lauri (Hemiptera: Cicadellidae) in Hungary" volume="49" year="2018">
