<subSubSection id="C3106558FFD7FFD2FF1BF977FC92FF58" lastPageId="6" lastPageNumber="145" pageId="5" pageNumber="144" type="discussion">
<paragraph id="8BB536D3FFD7FFD1FF1BF977FC7BF8CC" blockId="5.[151,1436,1687,2038]" pageId="5" pageNumber="144">
<emphasis id="B97EEAC1FFD7FFD1FF1BF977FEA8F93F" bold="true" box="[151,260,1688,1714]" pageId="5" pageNumber="144">Remarks</emphasis>
. 
<taxonomicName id="4C0A4D50FFD7FFD1FE9FF978FEC8F93C" authorityName="de Haan" authorityYear="1833" box="[275,356,1687,1713]" class="Florideophyceae" family="Halymeniaceae" genus="Galene" kingdom="Plantae" order="Halymeniales" pageId="5" pageNumber="144" phylum="Rhodophyta" rank="genus">
<emphasis id="B97EEAC1FFD7FFD1FE9FF978FEC8F93C" box="[275,356,1687,1713]" italics="true" pageId="5" pageNumber="144">Galene</emphasis>
</taxonomicName>
has been classified in the 
<taxonomicName id="4C0A4D50FFD7FFD1FD1DF978FCA8F93C" authorityName="MacLeay" authorityYear="1838" box="[657,772,1687,1713]" class="Malacostraca" family="Xanthidae" kingdom="Animalia" order="Decapoda" pageId="5" pageNumber="144" phylum="Arthropoda" rank="family">Xanthidae</taxonomicName>
(e.g., 
<bibRefCitation id="EF9B4B22FFD7FFD1FCC1F978FC61F93F" author="Balss, H." box="[845,973,1687,1714]" pageId="5" pageNumber="144" pagination="1505 - 1672" refId="ref5570" refString="Balss, H. (1957) Decapoda. In: H. G. Bronn's, Klassen und Ordnungen des Tierreichs, Funfter Band, I. Abteilung 7, Buch 12. Akademische Verlagsgesellschaft, Geest &amp; Portig K. - G, Leipzig, pp. 1505 - 1672." type="book chapter" year="1957">Balss 1957</bibRefCitation>
; 
<bibRefCitation id="EF9B4B22FFD7FFD1FC55F978FB27F93C" author="Glaessner, M. F." box="[985,1163,1687,1713]" pageId="5" pageNumber="144" refId="ref7009" refString="Glaessner, M. F. (1969) Decapoda. In: Moore, R. C. (Ed.), Treatise on Invertebrate Paleontology, Part R (Vol. 2). Geological Society of America, Boulder, Colorado, and University of Kansas Press, Lawrence, Kansas, R 399 - R 566 pp." type="book" year="1969">Glaessner 1969</bibRefCitation>
; 
<bibRefCitation id="EF9B4B22FFD7FFD1FB1BF978FA80F93F" author="Takeda, M." box="[1175,1324,1687,1714]" pageId="5" pageNumber="144" pagination="69 - 99" refId="ref9898" refString="Takeda, M. (1976) Studies on the Crustacea Brachyura of the Palau Islands, III. Xanthidae (1). Researches on Crustacea, 7, 69 - 99. https: // doi. org / 10.18353 / rcustacea. 7.0 _ 69" type="journal article" year="1976">Takeda 1976</bibRefCitation>
), whereas 
<bibRefCitation id="EF9B4B22FFD7FFD1FF1BF954FE93F958" author="Guinot, D." box="[151,319,1723,1749]" pageId="5" pageNumber="144" pagination="241 - 265" refId="ref7108" refString="Guinot, D. (1969 a) Les Goneplacidae: Recherches preliminaires sur les groupements naturels chez les Crustaces Decapodes Brachyoures, VII. Bulletin du Museum national d'Histoire naturelle, Paris, 2 (41), 241 - 265." type="journal article" year="1969">Guinot (1969a</bibRefCitation>
, 
<bibRefCitation id="EF9B4B22FFD7FFD1FEC0F954FE39F958" author="Guinot, D." box="[332,405,1723,1749]" pageId="5" pageNumber="144" pagination="507 - 528" refId="ref7151" refString="Guinot, D. (1969 b) Les Goneplacidae (suite): Recherches prelimi- naires sur les groupements naturels chez les Crustaces Decapodes Brachyoures, VII. Bulletin du Museum national d'Histoire naturelle, Paris, 2 (41), 507 - 528." type="journal article" year="1969">1969b</bibRefCitation>
, 
<bibRefCitation id="EF9B4B22FFD7FFD1FE2FF954FE45F958" author="Guinot, D." box="[419,489,1723,1749]" pageId="5" pageNumber="144" pagination="688 - 724" refId="ref7198" refString="Guinot, D. (1969 c) Les Goneplacidae (suite): Recherches prelimi- naires sur les groupements naturels chez les Crustaces Decap odes Brachyoures, VII. Bulletin du Museum national d' Histoire naturelle, Paris, 2 (41), 688 - 724." type="journal article" year="1969">1969c</bibRefCitation>
, 
<bibRefCitation id="EF9B4B22FFD7FFD1FE7BF953FD9CF95B" author="Guinot, D." box="[503,560,1724,1750]" pageId="5" pageNumber="144" pagination="1063 - 1090" refId="ref7247" refString="Guinot, D. (1971) Synthese et bibliographie: Recherches preliminaires sur les groupements naturels chez les Crustaces Decapodes Brachyoures, VIII. Bulletin du Museum national d'Histoire naturelle, Paris, 2 (42), 1063 - 1090. [Dated 1970, published 1971]" type="journal article" year="1971">1971</bibRefCitation>
) assigned 
<taxonomicName id="4C0A4D50FFD7FFD1FD20F954FD51F958" authorityName="de Haan" authorityYear="1833" box="[684,765,1723,1749]" class="Florideophyceae" family="Halymeniaceae" genus="Galene" kingdom="Plantae" order="Halymeniales" pageId="5" pageNumber="144" phylum="Rhodophyta" rank="genus">
<emphasis id="B97EEAC1FFD7FFD1FD20F954FD51F958" box="[684,765,1723,1749]" italics="true" pageId="5" pageNumber="144">Galene</emphasis>
</taxonomicName>
to “ 
<taxonomicName id="4C0A4D50FFD7FFD1FCA2F954FC67F958" authorityName="MacLeay" authorityYear="1838" box="[814,971,1723,1749]" class="Malacostraca" family="Goneplacidae" kingdom="Animalia" order="Decapoda" pageId="5" pageNumber="144" phylum="Arthropoda" rank="family">Goneplacidae</taxonomicName>
pilumniens 
<emphasis id="B97EEAC1FFD7FFD1FBD6F953FB62F958" box="[1114,1230,1723,1749]" italics="true" pageId="5" pageNumber="144">sensu lato</emphasis>
”. This suggestion was followed by a number of scholars (
<bibRefCitation id="EF9B4B22FFD7FFD1FDD7F90FFD6FF977" author="Ng, P. K. L." box="[603,707,1760,1786]" pageId="5" pageNumber="144" refId="ref8792" refString="Ng, P. K. L. (1998) Crabs. In: Carpenter, K. E. &amp; Niem, V. H. (Eds.), The living marine resources of the western Central Pacific. Volume 2. Cephalopods, crustaceans, holothurians, and sharks. Food and Agriculture Organization of the United Nations, Rome, pp. 1046 - 1155." type="book" year="1998">Ng 1998</bibRefCitation>
; 
<bibRefCitation id="EF9B4B22FFD7FFD1FD5CF930FC3DF977" author="Schweitzer, C. E." box="[720,913,1759,1786]" pageId="5" pageNumber="144" pagination="715 - 742" refId="ref9648" refString="Schweitzer, C. E. (2000) Tertiary Xanthoidea (Crustacea: Decapoda: Brachyura) from the west coast of North America. Journal of Crustacean Biology, 20, 715 - 742. https: // doi. org / 10.1163 / 20021975 - 99990095" type="journal article" year="2000">Schweitzer 2000</bibRefCitation>
; Ng e 
<emphasis id="B97EEAC1FFD7FFD1FC59F90FFC57F974" box="[981,1019,1759,1785]" italics="true" pageId="5" pageNumber="144">t al</emphasis>
. 2001; 
<bibRefCitation id="EF9B4B22FFD7FFD1FBDFF930FAFDF977" author="Hsueh, P. &amp; Huang, J." box="[1107,1361,1759,1786]" pageId="5" pageNumber="144" pagination="111 - 136" refId="ref7699" refString="Hsueh, P. &amp; Huang, J. (2002) Crabs of The Family Goneplacidae (Decapoda, Brachyura) From Taiwan. Crustaceana, 75 (2), 111 - 136. https: // doi. org / 10.1163 / 15685400252902344" type="journal article" year="2002">Hsueh &amp; Huang 2002</bibRefCitation>
; 
<bibRefCitation id="EF9B4B22FFD7FFD1FAD1F90FFF54F893" author="Ng, P. K. L. &amp; Guinot, D. &amp; Davie, P. J." pageId="5" pageNumber="144" pagination="1 - 286" refId="ref8933" refString="Ng, P. K. L., Guinot, D. &amp; Davie, P. J. (2008) Systema Brachyurorum: Part I. An annotated checklist of extant brachyuran crabs of the world. Raffles Bulletin of Zoology, 17, 1 - 286." type="journal article" year="2008">
Ng 
<emphasis id="B97EEAC1FFD7FFD1FA04F90FFF01F890" italics="true" pageId="5" pageNumber="144">et al</emphasis>
. 2008
</bibRefCitation>
), who classified 
<taxonomicName id="4C0A4D50FFD7FFD1FE3BF8ECFDA4F890" authorityName="de Haan" authorityYear="1833" box="[439,520,1795,1821]" class="Florideophyceae" family="Halymeniaceae" genus="Galene" kingdom="Plantae" order="Halymeniales" pageId="5" pageNumber="144" phylum="Rhodophyta" rank="genus">
<emphasis id="B97EEAC1FFD7FFD1FE3BF8ECFDA4F890" box="[439,520,1795,1821]" italics="true" pageId="5" pageNumber="144">Galene</emphasis>
</taxonomicName>
within (or close to) the 
<taxonomicName id="4C0A4D50FFD7FFD1FC91F8ECFC0CF890" authorityName="Samouelle" authorityYear="1819" box="[797,928,1795,1821]" class="Malacostraca" family="Pilumnidae" kingdom="Animalia" order="Decapoda" pageId="5" pageNumber="144" phylum="Arthropoda" rank="family">Pilumnidae</taxonomicName>
. 
<bibRefCitation id="EF9B4B22FFD7FFD1FC20F8EBFBCEF893" author="Ng, P. K. L. &amp; Guinot, D. &amp; Davie, P. J." box="[940,1122,1795,1822]" pageId="5" pageNumber="144" pagination="1 - 286" refId="ref8933" refString="Ng, P. K. L., Guinot, D. &amp; Davie, P. J. (2008) Systema Brachyurorum: Part I. An annotated checklist of extant brachyuran crabs of the world. Raffles Bulletin of Zoology, 17, 1 - 286." type="journal article" year="2008">
Ng 
<emphasis id="B97EEAC1FFD7FFD1FC5AF8EBFBBCF890" box="[982,1040,1795,1821]" italics="true" pageId="5" pageNumber="144">et al.</emphasis>
(2008)
</bibRefCitation>
summarized the taxonomic history of 
<taxonomicName id="4C0A4D50FFD7FFD1FE86F8C8FED2F8CC" authorityName="Alcock" authorityYear="1898" box="[266,382,1831,1857]" class="Malacostraca" family="Galenidae" kingdom="Animalia" order="Decapoda" pageId="5" pageNumber="144" phylum="Arthropoda" rank="family">Galenidae</taxonomicName>
, which was included in the superfamily 
<taxonomicName id="4C0A4D50FFD7FFD1FCCEF8C8FC7FF8CC" authorityName="Samouelle" authorityYear="1819" box="[834,979,1831,1857]" class="Insecta" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="5" pageNumber="144" phylum="Arthropoda" rank="superFamily" superFamily="Pilumnoidea">Pilumnoidea</taxonomicName>
.
</paragraph>
<paragraph id="8BB536D3FFD7FFD1FF4BF8A4FD0BF85F" blockId="5.[151,1436,1687,2038]" pageId="5" pageNumber="144">
The family 
<taxonomicName id="4C0A4D50FFD7FFD1FECAF8A4FDFFF8EB" authority="Alcock, 1898" authorityName="Alcock" authorityYear="1898" box="[326,595,1867,1894]" class="Malacostraca" family="Galenidae" kingdom="Animalia" order="Decapoda" pageId="5" pageNumber="144" phylum="Arthropoda" rank="family">Galenidae Alcock, 1898</taxonomicName>
, as currently recognized, consists of four genera (
<bibRefCitation id="EF9B4B22FFD7FFD1FBFCF8A3FAA3F8EB" author="Ng, P. K. L. &amp; Guinot, D. &amp; Davie, P. J." box="[1136,1295,1867,1894]" pageId="5" pageNumber="144" pagination="1 - 286" refId="ref8933" refString="Ng, P. K. L., Guinot, D. &amp; Davie, P. J. (2008) Systema Brachyurorum: Part I. An annotated checklist of extant brachyuran crabs of the world. Raffles Bulletin of Zoology, 17, 1 - 286." type="journal article" year="2008">
Ng 
<emphasis id="B97EEAC1FFD7FFD1FB14F8A3FB63F8E8" box="[1176,1231,1867,1893]" italics="true" pageId="5" pageNumber="144">et al.</emphasis>
2008
</bibRefCitation>
; 
<bibRefCitation id="EF9B4B22FFD7FFD1FA95F8A3FF59F807" author="De Grave, S. &amp; Pentcheff, N. D. &amp; Ahyong, S. T. &amp; Chan, T. - Y. &amp; Crandall, K. A. &amp; Dworschak, P. C. &amp; Felder, D. L. &amp; Feldmann, R. M. &amp; Fransen, C. H. J. M. &amp; Goulding, L. Y. D. &amp; Lemaitre, R. &amp; Low, M. E. Y. &amp; Martin, J. W. &amp; Ng, P. K. L. &amp; Schweitzer, C. E. &amp; Tan, S. H. &amp; Tshudy, D. &amp; Wetzer, R." pageId="5" pageNumber="144" pagination="1 - 109" refId="ref6112" refString="De Grave, S., Pentcheff, N. D., Ahyong, S. T., Chan, T. - Y., Crandall, K. A., Dworschak, P. C., Felder, D. L., Feldmann, R. M., Fransen, C. H. J. M., Goulding, L. Y. D., Lemaitre, R., Low, M. E. Y., Martin, J. W., Ng, P. K. L., Schweitzer, C. E., Tan, S. H., Tshudy, D. &amp; Wetzer, R. (2009) A classification of living and fossil decapod crustaceans. Raffles Bulletin of Zoology, Supplement No. 21, 1 - 109." type="book chapter" year="2009">
De Grave 
<emphasis id="B97EEAC1FFD7FFD1FA04F8A3FF01F804" italics="true" pageId="5" pageNumber="144">et al</emphasis>
. 2009
</bibRefCitation>
; 
