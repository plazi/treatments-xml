<emphasis id="B97EEAC1FFD7FFD1FF1BF9A0FDB7F9E4" bold="true" box="[151,539,1615,1641]" pageId="5" pageNumber="144">
Family 
<taxonomicName id="4C0A4D50FFD7FFD1FF7BF9A0FDB7F9E4" authority="Alcock, 1898" authorityName="Alcock" authorityYear="1898" box="[247,539,1615,1641]" class="Malacostraca" family="Galenidae" kingdom="Animalia" order="Decapoda" pageId="5" pageNumber="144" phylum="Arthropoda" rank="family">Galenidae Alcock, 1898</taxonomicName>
