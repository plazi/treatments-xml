(
<bibRefCitation id="EF859AC183777E08A669FC45B6EE6965" author="Scopoli, J. A." pageId="1" pageNumber="212" refId="ref9421" refString="Scopoli, J. A. (1763) Entomologia carniolica exhibens Insecta Carnioliae indigena et distributa in ordines, genera, species, varietatis. Methodo Linnaeana. Trattner, Vindobonae, xxxvi + 420 pp. https: // doi. org / 10.5962 / bhl. title. 119976" type="book" year="1763">Scopoli, 1763</bibRefCitation>
)
</taxonomicName>
; 
