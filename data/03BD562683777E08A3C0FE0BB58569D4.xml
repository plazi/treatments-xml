<taxonomicName id="4C149CB383777E08A27DFBD1B4D6691C" authority="Liu &amp; Liu, 1998" authorityName="G. Q. Liu &amp; Q. Liu" authorityYear="1998" box="[298,747,1096,1122]" class="Insecta" family="Alydidae" genus="Megalotomus" kingdom="Animalia" order="Hemiptera" pageId="1" pageNumber="212" phylum="Arthropoda" rank="species" species="acutulus">
