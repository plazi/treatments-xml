<subSubSection id="2B77C2B0DAA9053EF73116699E8A7E70" pageId="null" pageNumber="230" type="vernacular_names">
<paragraph id="5519936A36B835B06928F211D759DABC" pageId="null" pageNumber="230">
Blattreiches 
<normalizedToken id="FFE8C6A1799933008149B0A475ED979B" originalValue="Läusekraut" pageId="null" pageNumber="230">Laeusekraut</normalizedToken>
</paragraph>
</subSubSection>
</title>
<subSubSection id="C903F40CF3A0F9C1F59AB8516BEA8AB8" pageId="null" pageNumber="230" type="description">
<paragraph id="48C68A20CD2BE3105657BDB3A8DB5D11" pageId="null" pageNumber="230">
Ausdauernd; 20-50 cm hoch. Stengel aufrecht, kahl oder zerstreut behaart. 
<normalizedToken id="8C4E253929426510200D4DD94D136790" originalValue="Blätter" pageId="null" pageNumber="230">Blaetter</normalizedToken>
kahl oder unterseits behaart, bis auf den Mittelnerv fiederteilig, die 
<normalizedToken id="5B41592562E724F64FD82E82D774F5B0" originalValue="größeren" pageId="null" pageNumber="230">groesseren</normalizedToken>
10-25 cm lang und 
<emphasis id="07786A5CD3C59BC428104627AE63D099" italics="true" pageId="null" pageNumber="230">3</emphasis>
- 
<emphasis id="CF7AFEA3F039C34592FBAB7F55982D35" italics="true" pageId="null" pageNumber="230">8 cm breit</emphasis>
(bei den andern Arten im Gebiet kaum 
<normalizedToken id="4FED5EDF49F8BCD5F843F2957B94181B" originalValue="über" pageId="null" pageNumber="230">ueber</normalizedToken>
3 cm breit!); Abschnitte nochmals tief fiederteilig, 
<emphasis id="1B737E4E37BA280E6936CB9DCADC4258" italics="true" pageId="null" pageNumber="230">
mit bis 2 cm langen, 
<normalizedToken id="538C9D8375C0EB67BF2C8E181452A270" originalValue="gezähnten" pageId="null" pageNumber="230">gezaehnten</normalizedToken>
Zipfeln;
</emphasis>
Blattstiel behaart. 
<emphasis id="087609C1100C8558A68A5903F94FB528" italics="true" pageId="null" pageNumber="230">
<normalizedToken id="39292B9F4CA5989E98360716B54649E4" originalValue="Blätter" pageId="null" pageNumber="230">Blaetter</normalizedToken>
im 
<normalizedToken id="87E7D211194B4A9B72855453081DAEB5" originalValue="Blütenstand" pageId="null" pageNumber="230">Bluetenstand</normalizedToken>
<normalizedToken id="1AFA693BB5633701B9EA38698B85C05F" originalValue="länger" pageId="null" pageNumber="230">laenger</normalizedToken>
als die 
<normalizedToken id="AC9596B6EE0D303F88F0A7A5EEFCDAF5" originalValue="Blüten" pageId="null" pageNumber="230">Blueten</normalizedToken>
</emphasis>
, zerstreut behaart. 
<normalizedToken id="7FFF8714479FC058DE54A283AF44E7CD" originalValue="Blüten" pageId="null" pageNumber="230">Blueten</normalizedToken>
in einem 
<normalizedToken id="CD7212E6DD0062214732BA14DF71CDF2" originalValue="längeren" pageId="null" pageNumber="230">laengeren</normalizedToken>
, dichten 
<normalizedToken id="3959C38492A4B711DAA8F5B782EA5A4E" originalValue="Blütenstand" pageId="null" pageNumber="230">Bluetenstand</normalizedToken>
, nicht abgedreht. 
<emphasis id="16CFAA4E781192181B6A54FEC8EA4D3A" italics="true" pageId="null" pageNumber="230">Kelch 8</emphasis>
- 
<emphasis id="889AEF4AD83C8C2D9B10FEA233739B28" italics="true" pageId="null" pageNumber="230">10 mm lang</emphasis>
, am Grunde abgerundet, mit 5 ganz kurzen, 
<emphasis id="0EFBF62C862BFB862A3A8BE154AB1695" italics="true" pageId="null" pageNumber="230">
ganzrandigen 
<normalizedToken id="B404FB40689892ACF7B4C5BD5726A97E" originalValue="Zähnen" pageId="null" pageNumber="230">Zaehnen</normalizedToken>
</emphasis>
, auf den Nerven, am Rande und auf der Innenseite der Zipfel behaart (Haare 1-2 mm lang). 
<emphasis id="D36413D02490A0E0404997DBF68CFCFC" italics="true" pageId="null" pageNumber="230">Krone 20 bis 28 mm lang, hellgelb; Oberlippe vorn abgerundet</emphasis>
, ohne 
<normalizedToken id="6DC18FE50C4EE97C17F2F311E79FEDCA" originalValue="Zähne" pageId="null" pageNumber="230">Zaehne</normalizedToken>
, 
<emphasis id="1324D58624BD4C476477D7D3EF9274D5" italics="true" pageId="null" pageNumber="230">
<normalizedToken id="B308EFDC296D04F258CFC7111430BB1B" originalValue="außen" pageId="null" pageNumber="230">aussen</normalizedToken>
meist behaart
</emphasis>
(im Gebiet nur noch bei 
<taxonomicName id="0C0536D8F3E61C209FC366415F53E875" authority="Nr." authorityName="Nr." class="Magnoliopsida" family="Orobanchaceae" genus="Pedicularis" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="230" phylum="Tracheophyta" rank="species" species="acaulis">
<emphasis id="083FA641909EC0C3EB9A3992A992DD19" italics="true" pageId="null" pageNumber="230">P. acaulis</emphasis>
Nr.
</taxonomicName>
2 behaart); Unterlippe abstehend, etwa so lang wie die Oberlippe, 
<emphasis id="0EF9B5429905A4ABCFEAF59AC1396DE5" italics="true" pageId="null" pageNumber="230">kahl</emphasis>
. Die 2 
<normalizedToken id="370AC1ED1F632380A1BF0FED0BECEBCB" originalValue="längeren" pageId="null" pageNumber="230">laengeren</normalizedToken>
<normalizedToken id="51036E3E9683EFA599B7E46A728CB6E9" originalValue="Staubfäden" pageId="null" pageNumber="230">Staubfaeden</normalizedToken>
behaart. Frucht 
<normalizedToken id="F34F9E95A4633C999AD2FB4400305E22" originalValue="länger" pageId="null" pageNumber="230">laenger</normalizedToken>
als der Kelch. Samen 2,5-3 mm lang. - 
<normalizedToken id="0D9823BABC69E2EED005B9FF1E5C544E" originalValue="Blüte" pageId="null" pageNumber="230">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="0C337CD4B2CAC5E2C9D10FE9C1C49447" pageId="null" pageNumber="230">
<emphasis id="3F7187F3382FD72DE47A7CCD2C37A577" italics="true" pageId="null" pageNumber="230">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0E036A1451C0719B869226EA218E52AB" italics="true" pageId="null" pageNumber="230">16:</emphasis>
Material aus 
<normalizedToken id="74D671B26F1D677C36F393658EB80D39" originalValue="Österreich" pageId="null" pageNumber="230">Oesterreich</normalizedToken>
(Witsch 1932, Mattick in Tischler 1950).
</paragraph>
<paragraph id="7A1A395FB4F40E02A06AFAC2AB4166E3" pageId="null" pageNumber="230">
<emphasis id="8454D9EB703CC31A58A1211D8EE544EC" italics="true" pageId="null" pageNumber="230">Standort</emphasis>
. Subalpin, selten montan und alpin. Lockere, ziemlich feuchte, 
<normalizedToken id="F9B18E116B3AE75EA70B102D0E106F40" originalValue="nährstoffreiche" pageId="null" pageNumber="230">naehrstoffreiche</normalizedToken>
, kalkhaltige 
<normalizedToken id="26F1C3C10AE10A1C97E40F4F7166E6C9" originalValue="Böden" pageId="null" pageNumber="230">Boeden</normalizedToken>
. Wildheuplanken, Hochstaudenfluren. 
<emphasis id="30AE396DB038119D5E8DBC1D45A7FE2B" italics="true" pageId="null" pageNumber="230">Caricion ferrugineae</emphasis>
Br.-Bl. 1931.
</paragraph>
<paragraph id="BCCC6FF5D6C57E2769CA344B128E8890" pageId="null" pageNumber="230">
<emphasis id="155B6C1ECE34826493B3D7DB4082924C" italics="true" pageId="null" pageNumber="230">
Verbreitung. Mittel- und 
<normalizedToken id="C1367CADBAB99027865648DED635FF67" originalValue="südeuropäische" pageId="null" pageNumber="230">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
Nordspanische Gebirge, 
<normalizedToken id="F21F7C8EBCE624B5C564F445008E1C6C" originalValue="Pyrenäen" pageId="null" pageNumber="230">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="B33CD2A7BEE61415CC679D89886DA602" originalValue="Corbières" pageId="null" pageNumber="230">Corbieres</normalizedToken>
, Plateau Central, Vogesen, Jura, Alpen, Apennin (
<normalizedToken id="761B43316A6A4F0B58501D2E732D0C25" originalValue="südwärts" pageId="null" pageNumber="230">suedwaerts</normalizedToken>
bis Neapel), Bosnien, Herzegowina. - Im Gebiet: Hochvogesen (Rotenbach bis Hohneck), Jura (Reculet bis Chasseral, 
<normalizedToken id="77A980CF37A823B64262C0540C02BE15" originalValue="Schwäbische" pageId="null" pageNumber="230">Schwaebische</normalizedToken>
Alb), Alpen (in den 
<normalizedToken id="79C94DA65B41450349D07DED7D7C1C4A" originalValue="Südalpen" pageId="null" pageNumber="230">Suedalpen</normalizedToken>
nur Val Vigezzo im Valle 
<normalizedToken id="7975E73795F67964C887844AF3D945FF" originalValue="d’Ossola" pageId="null" pageNumber="230">d'Ossola</normalizedToken>
, Monte Generoso, Grigna, Val di Scalve; im Wallis nur westlich der Linie 
<normalizedToken id="5C8969C48E68AD8296FB7807F9FA5821" originalValue="Entremont-Gemmipaß" pageId="null" pageNumber="230">Entremont-Gemmipass</normalizedToken>
), nicht 
<normalizedToken id="0DB2D2756A684BD752001B976415DBC3" originalValue="häufig" pageId="null" pageNumber="230">haeufig</normalizedToken>
; nur in den 
<normalizedToken id="201F498CD27F2666CCEBFCF9A47E1253" originalValue="östlichen" pageId="null" pageNumber="230">oestlichen</normalizedToken>
Nordalpen ziemlich 
<normalizedToken id="DFE1686367C2F3FBB99F3547D820863C" originalValue="häufig" pageId="null" pageNumber="230">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="A72A40F8F9095EB677343C353183C6AA" pageId="null" pageNumber="230">
<emphasis id="6BC707467225E5BD87564FB2AA797D9E" italics="true" pageId="null" pageNumber="230">Bemerkungen</emphasis>
. Die Pflanzen in den Vogesen, im Jura und in den 
<normalizedToken id="BB905EB494BC60586198F6360DC51F8E" originalValue="Südalpen" pageId="null" pageNumber="230">Suedalpen</normalizedToken>
sind oft 
<normalizedToken id="C9AC785207C5C4E53B59B07F7B614C33" originalValue="höher" pageId="null" pageNumber="230">hoeher</normalizedToken>
(40-80 cm hoch) und haben meist eine kahle Oberlippe. Der systematische Wert und die Verbreitung dieser Sippe (
<taxonomicName id="C1D860B72FEAF24BE1E505B98334984A" authority="Steininger" authorityName="Steininger" pageId="null" pageNumber="230" rank="variety" variety="glabriuscula">
var. 
<emphasis id="521616A0903B9EF2F401B358D356E063" italics="true" pageId="null" pageNumber="230">glabriuscula</emphasis>
Steininger
</taxonomicName>
) sind 
<normalizedToken id="3E7A45C527F73C629F0CF023403C750F" originalValue="abzuklären" pageId="null" pageNumber="230">abzuklaeren</normalizedToken>
.
</paragraph>
</subSubSection>
