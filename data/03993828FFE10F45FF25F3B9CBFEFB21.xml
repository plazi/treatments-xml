<taxonomicName id="4C30F2BDFFE10F45FECBF30BCF63F372" authority="Hayman, 1936" authorityName="Hayman" authorityYear="1936" box="[347,790,3252,3281]" class="Mammalia" family="Nesomyidae" genus="Steatomys" kingdom="Animalia" order="Rodentia" pageId="19" pageNumber="202" phylum="Chordata" rank="species" species="jackson">Steatomys jackson: Hayman, 1936</taxonomicName>
