<materialsCitation id="3B588363FFE10F45FCB5F30BC8F5F372" ID-GBIF-Occurrence="3805028354" box="[805,1152,3252,3281]" country="Ghana" location="Wenchi" pageId="19" pageNumber="202" specimenCount="1" stateProvince="Ashanti">
<location id="8EEFDFE5FFE10F45FCB5F30BCFE7F372" LSID="urn:lsid:plazi:treatment:03993828FFE10F45FF25F3B9CBFEFB21:8EEFDFE5FFE10F45FCB5F30BCFE7F372" box="[805,914,3252,3281]" country="Ghana" name="Wenchi" pageId="19" pageNumber="202" stateProvince="Ashanti">Wenchi</location>
