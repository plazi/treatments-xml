<taxonomicName id="4C634D19FFA8FFC7FF19F9B7FECB2767" authority="Medrano &amp; Kury &amp; Mendes, 2022" authorityName="Medrano &amp; Kury &amp; Mendes" authorityYear="2022" box="[231,364,1536,1558]" pageId="29" pageNumber="614" rank="subFamily" status="subfam. nov." subFamily="Flirteinae">
<emphasis id="B917EA88FFA8FFC7FF19F9B7FECB2767" bold="true" box="[231,364,1536,1558]" pageId="29" pageNumber="614">Flirteinae</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A22457F3FFA8FFC7FE8BF9B7FDBB2764" box="[373,540,1536,1558]" pageId="29" pageNumber="614" rank="subFamily">
<emphasis id="B917EA88FFA8FFC7FE8BF9B7FDB22764" bold="true" box="[373,533,1536,1558]" pageId="29" pageNumber="614">subfam. nov</emphasis>
.
</taxonomicNameLabel>
and 
<emphasis id="B917EA88FFA8FFC7FDA7F9B7FEE62745" bold="true" pageId="29" pageNumber="614">
<taxonomicName id="4C634D19FFA8FFC7FDA7F9B7FCAD2767" authority="Medrano &amp; Kury &amp; Mendes, 2022" authorityName="Medrano &amp; Kury &amp; Mendes" authorityYear="2022" box="[601,778,1536,1558]" pageId="29" pageNumber="614" rank="subFamily" status="subfam. nov." subFamily="Metergininae">Metergininae</taxonomicName>
<taxonomicNameLabel id="A22457F3FFA8FFC7FF5DF9A9FEE62745" box="[163,321,1566,1588]" pageId="29" pageNumber="614" rank="subFamily">subfam. nov.</taxonomicNameLabel>
</emphasis>
, plus one isolated genus: 
<taxonomicName id="4C634D19FFA8FFC7FD9AF9A8FD432745" authorityName="Roewer" authorityYear="1915" box="[612,740,1567,1588]" class="Arachnida" family="Cosmetidae" genus="Neocynorta" kingdom="Animalia" order="Opiliones" pageId="29" pageNumber="614" phylum="Arthropoda" rank="genus">
<emphasis id="B917EA88FFA8FFC7FD9AF9A8FD432745" box="[612,740,1567,1588]" italics="true" pageId="29" pageNumber="614">Neocynorta</emphasis>
</taxonomicName>
.
</paragraph>
