<taxonomicName authorityName="Neves &amp; Lacau" authorityYear="2018" box="[401,644,1716,1740]" class="Insecta" family="Formicidae" genus="Hylomyrma" kingdom="Animalia" order="Hymenoptera" pageId="121" pageNumber="122" phylum="Arthropoda" rank="species" species="villemantae">
<emphasis box="[401,644,1716,1740]" italics="true" pageId="121" pageNumber="122">Hylomyrma villemantae</emphasis>
</taxonomicName>
