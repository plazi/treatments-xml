<taxonomicName id="169981D11B1BFFD7FF52F046FDD3F384" authority="Thomas, 1900" authorityName="Thomas" authorityYear="1900" box="[198,579,3127,3160]" class="Mammalia" family="Ctenomyidae" genus="Ctenomys" kingdom="Animalia" order="Rodentia" pageId="5" pageNumber="516" phylum="Chordata" rank="subSpecies" species="opimus" subSpecies="mgriceps">C. o. mgriceps Thomas, 1900</taxonomicName>
