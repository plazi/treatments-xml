<subSubSection id="9983A9D91B1BFFD7FCBDF82EFAF6FA67" pageId="5" pageNumber="516" type="reference_group">
<paragraph id="D126FA521B1BFFD7FCBDF82EFBF8FAC2" blockId="5.[808,1401,1119,1546]" pageId="5" pageNumber="516">
<emphasis id="E3ED26401B1BFFD7FCBDF82EFC54FB5C" bold="true" box="[809,964,1119,1152]" pageId="5" pageNumber="516">Taxonomy.</emphasis>
<taxonomicName id="169981D11B1BFFD7FC40F82EFAE2FB5C" authority="Philippi, 1860" authorityName="Philippi" authorityYear="1860" box="[980,1394,1119,1152]" class="Mammalia" family="Ctenomyidae" genus="Ctenomys" kingdom="Animalia" order="Rodentia" pageId="5" pageNumber="516" phylum="Chordata" rank="species" species="fulvus">Ctenomys fulvus Philippi, 1860</taxonomicName>
, 
<materialsCitation id="61F1F00F1B1BFFD7FCBEF8F6FBF4FAC2" ID-GBIF-Occurrence="3798388340" pageId="5" pageNumber="516">“Reise durch die Wuste Atacama.” Restricted by W. H. Osgood in 1943 to vicinity of Pingo-Pingo, 24°00’ S and 69°00&quot; W, Atacama Desert, Chile</materialsCitation>
.
</paragraph>
<paragraph id="D126FA521B1BFFD7FCB8F955FAF6FA67" blockId="5.[808,1401,1119,1546]" pageId="5" pageNumber="516">
<taxonomicName id="169981D11B1BFFD7FCB8F955FC6CFA99" authorityName="Philippi" authorityYear="1860" box="[812,1020,1316,1349]" class="Mammalia" family="Ctenomyidae" genus="Ctenomys" kingdom="Animalia" order="Rodentia" pageId="5" pageNumber="516" phylum="Chordata" rank="species" species="fulvus">Ctenomys fulvus</taxonomicName>
belongs to the opimusspecies group based on mtDNA analysis. Karyotype is 2n = 26, and sperm morphology is symmetric. Two subspecies recognized.
</paragraph>
</subSubSection>
<subSubSection id="9983A9D91B1BFFD7FCBDF9B4FB09F984" pageId="5" pageNumber="516" type="synonymic_list">
<caption id="85E6AADA1B1BFFD7FCBDF9B4FB09F984" ID-DOI="http://doi.org/10.5281/zenodo.6588212" ID-Zenodo-Dep="6588212" httpUri="https://zenodo.org/record/6588212/files/figure.png" inLine="true" pageId="5" pageNumber="516" targetBox="[194,785,1125,1539]" targetPageId="5">
<paragraph id="D126FA521B1BFFD7FCBDF9B4FB29FA3E" blockId="5.[808,1401,1119,1546]" box="[809,1209,1477,1506]" pageId="5" pageNumber="516">
<emphasis id="E3ED26401B1BFFD7FCBDF9B4FB29FA3E" bold="true" box="[809,1209,1477,1506]" pageId="5" pageNumber="516">Subspecies and Distribution.</emphasis>
</paragraph>
<paragraph id="D126FA521B1BFFD7FCB8F99CFE54F9F3" blockId="5.[808,1401,1119,1546]" lastBlockId="5.[195,1400,1550,2294]" pageId="5" pageNumber="516">
<taxonomicName id="169981D11B1BFFD7FCB8F99CFB15F9D6" authority="Philippi, 1860" authorityName="Philippi" authorityYear="1860" box="[812,1157,1517,1546]" class="Mammalia" family="Ctenomyidae" genus="Ctenomys" kingdom="Animalia" order="Rodentia" pageId="5" pageNumber="516" phylum="Chordata" rank="subSpecies" species="fulvus" subSpecies="fulvus">C.f.fulvusPhilippi,1860—NChile(EAntofogastaRegion).</taxonomicName>
</paragraph>
<paragraph id="D126FA521B1BFFD7FF5CFA46FB09F984" blockId="5.[195,1400,1550,2294]" box="[200,1177,1591,1624]" pageId="5" pageNumber="516">
<taxonomicName id="169981D11B1BFFD7FF5CFA46FD8CF984" authority="Mann, 1978" authorityName="Mann" authorityYear="1978" box="[200,540,1591,1624]" class="Mammalia" family="Ctenomyidae" form="robustus" genus="Ctenomys" kingdom="Animalia" order="Rodentia" pageId="5" pageNumber="516" phylum="Chordata" rank="form" species="fulvus" subSpecies="robustus">C. f. robustus Mann, 1978</taxonomicName>
— N Chile (Oasis de Pica in Tarapaca desert).
</paragraph>
