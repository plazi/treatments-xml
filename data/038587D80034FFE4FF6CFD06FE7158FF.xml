<materialsCitation id="3B443C930034FFE4FC9CF8AFFE4658C3" ID-GBIF-Occurrence="3785194304" collectionCode="SMTD" country="Ecuador" location="Latacunga" pageId="2" pageNumber="153" specimenCount="1" stateProvince="Cotopaxi" typeStatus="holotype">
