<subSubSection id="C33665450034FFE4FF6CFC54FE7158FF" pageId="2" pageNumber="153" type="discussion">
<paragraph id="8B9336CE0034FFE4FF6CFC54FEB95B3B" blockId="2.[151,1437,937,1971]" pageId="2" pageNumber="153">
<emphasis id="B958EADC0034FFE4FF6CFC54FEF95C8F" bold="true" box="[151,267,937,963]" pageId="2" pageNumber="153">Remarks.</emphasis>
<bibRefCitation id="EFBD4B3F0034FFE4FEE8FC54FE435C8F" author="Kirsch, T. F." box="[275,433,937,963]" pageId="2" pageNumber="153" pagination="1 - 58" refId="ref6203" refString="Kirsch, T. F. (1889) Coleopteren gesammelt in den Jahren 1868 - 1877 auf einen Reise durch Sud Amerika von Alphons Stubel. Abhandlungen und Berichte des Koniglichen Zoologischen und Anthropologisch-Etnographischen Museums zu Dresden, 4, 1 - 58." type="journal article" year="1889">Kirsch (1889)</bibRefCitation>
described 
<taxonomicName id="4C2C4D4D0034FFE4FDD6FC54FCB75C8F" authorityName="Kirsch" authorityYear="1889" box="[557,837,937,963]" class="Insecta" family="Cerambycidae" genus="Amphionycha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="annulifera">
<emphasis id="B958EADC0034FFE4FDD6FC54FCB75C8F" box="[557,837,937,963]" italics="true" pageId="2" pageNumber="153">Amphionycha annulifera</emphasis>
</taxonomicName>
based on a single specimen from 
<collectingCountry id="F33B765E0034FFE4FB30FC54FADA5C8F" box="[1227,1320,937,963]" name="Ecuador" pageId="2" pageNumber="153">Ecuador</collectingCountry>
(
<figureCitation id="13172A4B0034FFE4FAC3FC54FF455CAB" captionStart="FIGURES 18–20" captionStartId="5.[151,264,1012,1036]" captionTargetBox="[151,1436,182,988]" captionTargetId="figure-22@5.[151,1436,181,988]" captionTargetPageId="5" captionText="FIGURES 18–20. Juninia annulifera (Kirsch, 1889), holotype male. 18) Dorsal habitus; 19) Labels; 20) Ventral habitus." figureDoi="http://doi.org/10.5281/zenodo.6581642" httpUri="https://zenodo.org/record/6581642/files/figure.png" pageId="2" pageNumber="153">Figs 18– 20</figureCitation>
). Later, 
<bibRefCitation id="EFBD4B3F0034FFE4FEEAFC33FE6B5CA4" author="Lane, F." box="[273,409,973,1000]" pageId="2" pageNumber="153" pagination="245 - 249" refId="ref6274" refString="Lane, F. (1966) Novos generos e especies de Hemilophini I. Generos com antenas de 12 articulos (Coleoptera, Lamiidae). Papeis Avulsos do Departamento de Zoologia, 18 (21), 245 - 249." type="journal article" year="1966">Lane (1966)</bibRefCitation>
described 
<taxonomicName id="4C2C4D4D0034FFE4FDEAFC33FD975CAB" authorityName="Lane" authorityYear="1966" box="[529,613,974,999]" class="Insecta" family="Cerambycidae" genus="Juninia" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FDEAFC33FD975CAB" box="[529,613,974,999]" italics="true" pageId="2" pageNumber="153">Juninia</emphasis>
</taxonomicName>
for his new species 
<taxonomicName id="4C2C4D4D0034FFE4FCBEFC33FC535CAB" authorityName="Lane" authorityYear="1966" box="[837,929,973,999]" class="Insecta" family="Cerambycidae" genus="Juninia" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="leechi">
<emphasis id="B958EADC0034FFE4FCBEFC33FC535CAB" box="[837,929,973,999]" italics="true" pageId="2" pageNumber="153">J. leechi</emphasis>
</taxonomicName>
based on a pair from 
<collectingCountry id="F33B765E0034FFE4FB6BFC33FB355CA4" box="[1168,1223,974,1000]" name="Peru" pageId="2" pageNumber="153">Peru</collectingCountry>
. 
<bibRefCitation id="EFBD4B3F0034FFE4FB2AFC30FF105B47" author="Martins, U. R. &amp; Galileo, M. H. M." pageId="2" pageNumber="153" pagination="109 - 116" refId="ref6365" refString="Martins, U. R. &amp; Galileo, M. H. M. (1993) Descricao de novos taxons com antenas de doze articulos, transferencia de especies de Adesmus Lepeletier &amp; Audinet-Serville, 1825 e sinonimos (Coleoptera, Cerambycidae, Lamiinae, Hemilophini). Iheringia, Zoologia, 74, 109 - 116." type="journal article" year="1993">Martins &amp; Galileo (1993)</bibRefCitation>
synonymized 
<taxonomicName id="4C2C4D4D0034FFE4FE72FC0FFE1A5B47" authorityName="Lane" authorityYear="1966" box="[393,488,1009,1035]" class="Insecta" family="Cerambycidae" genus="Juninia" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="leechi">
<emphasis id="B958EADC0034FFE4FE72FC0FFE1A5B47" box="[393,488,1009,1035]" italics="true" pageId="2" pageNumber="153">J. leechi</emphasis>
</taxonomicName>
with 
<taxonomicName id="4C2C4D4D0034FFE4FDD7FC0FFD305B47" authorityName="Kirsch" authorityYear="1889" box="[556,706,1009,1036]" class="Insecta" family="Cerambycidae" genus="Amphionycha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="annulifera">
<emphasis id="B958EADC0034FFE4FDD7FC0FFD305B47" box="[556,706,1009,1036]" italics="true" pageId="2" pageNumber="153">A. annulifera</emphasis>
</taxonomicName>
, and transferred it to 
<taxonomicName id="4C2C4D4D0034FFE4FC47FC0FFBE25B47" authorityName="Lane" authorityYear="1966" box="[956,1040,1010,1035]" class="Insecta" family="Cerambycidae" genus="Juninia" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FC47FC0FFBE25B47" box="[956,1040,1010,1035]" italics="true" pageId="2" pageNumber="153">Juninia</emphasis>
</taxonomicName>
, and only pointed out (translated): “Alerted about this synonymy by our colleague M.A. Monné, we thought it opportune to formalize it.” However, they examined a female from 
<collectingCountry id="F33B765E0034FFE4FE1AFBC4FDB25B1F" box="[481,576,1081,1107]" name="Ecuador" pageId="2" pageNumber="153">Ecuador</collectingCountry>
, which belonged to the MNRJ. Martins &amp; Galileo (2004) reported the species from 
<collectingCountry id="F33B765E0034FFE4FF2EFBA0FEB55B3B" box="[213,327,1117,1143]" name="Colombia" pageId="2" pageNumber="153">Colombia</collectingCountry>
.
</paragraph>
<paragraph id="8B9336CE0034FFE4FF3CFB7CFE1A5A67" blockId="2.[151,1437,937,1971]" pageId="2" pageNumber="153">
<bibRefCitation id="EFBD4B3F0034FFE4FF3CFB7CFE195BD7" author="Martins, U. R. &amp; Galileo, M. H. M." box="[199,491,1153,1179]" pageId="2" pageNumber="153" pagination="1868" refId="ref6425" refString="Martins, U. R. &amp; Galileo, M. H. M. (2014) Subfamilia Lamiinae, Hemilophini Thomson, 1868. Parte I. In: Martins, U. R. (Org.), Cerambycidae Sul-Americanos (Coleoptera). Volume 13. Sociedade Brasileira de Entomologia, Curitiba, pp. 3 - 231." type="book chapter" year="2014">Martins &amp; Galileo (2014)</bibRefCitation>
mistakenly informed that 
<bibRefCitation id="EFBD4B3F0034FFE4FCE2FB7CFC0C5BD7" author="Monne, M. L. &amp; Monne, M. A. &amp; Quintino, H. Y. &amp; Botero, J. P. &amp; Machado, V. S. &amp; Aragao, A. C. &amp; Simoes, M. V. P. &amp; Cupello, M." box="[793,1022,1153,1179]" pageId="2" pageNumber="153" pagination="39 - 76" refId="ref6644" refString="Monne, M. L., Monne, M. A., Quintino, H. Y., Botero, J. P., Machado, V. S., Aragao, A. C., Simoes, M. V. P. &amp; Cupello, M. (2012 b) Inventario das especies de Lamiinae (Insecta, Coleoptera, Cerambycidae) do Parque Nacional do Itatiaia, RJ, Brasil. Biota Neotropica, 12 (1), 39 - 76. https: // doi. org / 10.1590 / S 1676 - 06032012000100004" type="journal article" year="2012">
Monné 
<emphasis id="B958EADC0034FFE4FC8AFB7FFC595BD7" box="[881,939,1153,1179]" italics="true" pageId="2" pageNumber="153">et al.</emphasis>
(2012)
</bibRefCitation>
had recorded 
<taxonomicName id="4C2C4D4D0034FFE4FB59FB7FFAC15BD7" authorityName="Kirsch" authorityYear="1889" box="[1186,1331,1153,1179]" class="Insecta" family="Cerambycidae" genus="Amphionycha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="annulifera">
<emphasis id="B958EADC0034FFE4FB59FB7FFAC15BD7" box="[1186,1331,1153,1179]" italics="true" pageId="2" pageNumber="153">J. annulifera</emphasis>
</taxonomicName>
from the Brazilian state of Rio de Janeiro. There are two works published in 2012 that could be “ 
<bibRefCitation id="EFBD4B3F0034FFE4FB8FFB58FAAC5BF3" author="Monne, M. L. &amp; Monne, M. A. &amp; Quintino, H. Y. &amp; Botero, J. P. &amp; Machado, V. S. &amp; Aragao, A. C. &amp; Simoes, M. V. P. &amp; Cupello, M." box="[1140,1374,1189,1215]" pageId="2" pageNumber="153" pagination="39 - 76" refId="ref6644" refString="Monne, M. L., Monne, M. A., Quintino, H. Y., Botero, J. P., Machado, V. S., Aragao, A. C., Simoes, M. V. P. &amp; Cupello, M. (2012 b) Inventario das especies de Lamiinae (Insecta, Coleoptera, Cerambycidae) do Parque Nacional do Itatiaia, RJ, Brasil. Biota Neotropica, 12 (1), 39 - 76. https: // doi. org / 10.1590 / S 1676 - 06032012000100004" type="journal article" year="2012">
Monné 
<emphasis id="B958EADC0034FFE4FB36FB5BFAF45BF3" box="[1229,1286,1189,1215]" italics="true" pageId="2" pageNumber="153">et al.</emphasis>
(2012)
</bibRefCitation>
:” one published by Miguel A. Monné and collaborators (
<bibRefCitation id="EFBD4B3F0034FFE4FD23FB34FC4F5BAF" author="Monne, M. A. &amp; Nearns, E. H. &amp; Carbonel Carril, S. H. &amp; Swift, I. P. &amp; Monne, M. L." box="[728,957,1225,1251]" pageId="2" pageNumber="153" pagination="1 - 48" refId="ref6580" refString="Monne, M. A., Nearns, E. H., Carbonel Carril, S. H., Swift, I. P. &amp; Monne, M. L. (2012 a) Preliminary checklist of the Cerambycidae, Disteniidae, and Vesperidae (Coleoptera) of Peru. Insecta Mundi, 213, 1 - 48." type="journal article" year="2012">
Monné 
<emphasis id="B958EADC0034FFE4FCCAFB37FC995BAF" box="[817,875,1225,1251]" italics="true" pageId="2" pageNumber="153">et al.</emphasis>
2012a
</bibRefCitation>
); another published by Marcela L. Monné and collaborators (
<bibRefCitation id="EFBD4B3F0034FFE4FE9DFB10FDB45A44" author="Monne, M. L. &amp; Monne, M. A. &amp; Quintino, H. Y. &amp; Botero, J. P. &amp; Machado, V. S. &amp; Aragao, A. C. &amp; Simoes, M. V. P. &amp; Cupello, M." box="[358,582,1261,1288]" pageId="2" pageNumber="153" pagination="39 - 76" refId="ref6644" refString="Monne, M. L., Monne, M. A., Quintino, H. Y., Botero, J. P., Machado, V. S., Aragao, A. C., Simoes, M. V. P. &amp; Cupello, M. (2012 b) Inventario das especies de Lamiinae (Insecta, Coleoptera, Cerambycidae) do Parque Nacional do Itatiaia, RJ, Brasil. Biota Neotropica, 12 (1), 39 - 76. https: // doi. org / 10.1590 / S 1676 - 06032012000100004" type="journal article" year="2012">
Monné 
<emphasis id="B958EADC0034FFE4FE45FB13FE045A4B" box="[446,502,1261,1287]" italics="true" pageId="2" pageNumber="153">et al.</emphasis>
2012b
</bibRefCitation>
). Only the first one mentions 
<taxonomicName id="4C2C4D4D0034FFE4FC74FB13FBAD5A4B" baseAuthorityName="Kirsch" baseAuthorityYear="1889" box="[911,1119,1261,1287]" class="Insecta" family="Cerambycidae" genus="Juninia" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="annulifera">
<emphasis id="B958EADC0034FFE4FC74FB13FBAD5A4B" box="[911,1119,1261,1287]" italics="true" pageId="2" pageNumber="153">Juninia annulifera</emphasis>
</taxonomicName>
, and only lists the species in 
<collectingCountry id="F33B765E0034FFE4FF6CFAECFF045A67" box="[151,246,1297,1323]" name="Ecuador" pageId="2" pageNumber="153">Ecuador</collectingCountry>
, 
<collectingCountry id="F33B765E0034FFE4FEFAFAEFFEC55A60" box="[257,311,1298,1324]" name="Peru" pageId="2" pageNumber="153">Peru</collectingCountry>
, and 
<collectingCountry id="F33B765E0034FFE4FE89FAECFE165A67" box="[370,484,1297,1323]" name="Colombia" pageId="2" pageNumber="153">Colombia</collectingCountry>
.
</paragraph>
<paragraph id="8B9336CE0034FFE4FF3CFAC8FA9E5948" blockId="2.[151,1437,937,1971]" pageId="2" pageNumber="153">
<bibRefCitation id="EFBD4B3F0034FFE4FF3CFAC8FE1A5A03" author="Martins, U. R. &amp; Galileo, M. H. M." box="[199,488,1333,1359]" pageId="2" pageNumber="153" pagination="1868" refId="ref6425" refString="Martins, U. R. &amp; Galileo, M. H. M. (2014) Subfamilia Lamiinae, Hemilophini Thomson, 1868. Parte I. In: Martins, U. R. (Org.), Cerambycidae Sul-Americanos (Coleoptera). Volume 13. Sociedade Brasileira de Entomologia, Curitiba, pp. 3 - 231." type="book chapter" year="2014">Martins &amp; Galileo (2014)</bibRefCitation>
separated 
<taxonomicName id="4C2C4D4D0034FFE4FD9AFACBFD475A03" authorityName="Lane" authorityYear="1966" box="[609,693,1334,1359]" class="Insecta" family="Cerambycidae" genus="Juninia" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FD9AFACBFD475A03" box="[609,693,1334,1359]" italics="true" pageId="2" pageNumber="153">Juninia</emphasis>
</taxonomicName>
from 
<taxonomicName id="4C2C4D4D0034FFE4FD00FAC8FC7B5A03" authorityName="Martins &amp; Galileo" authorityYear="1993" box="[763,905,1333,1359]" class="Insecta" family="Cerambycidae" genus="Sibapipunga" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FD00FAC8FC7B5A03" box="[763,905,1333,1359]" italics="true" pageId="2" pageNumber="153">Sibapipunga</emphasis>
</taxonomicName>
in their key by the frons in the male uniformly convex in the former, and with two callosities in the latter. However, they also stated that in 
<taxonomicName id="4C2C4D4D0034FFE4FB66FAA7FB035A3F" authorityName="Lane" authorityYear="1966" box="[1181,1265,1370,1395]" class="Insecta" family="Cerambycidae" genus="Juninia" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FB66FAA7FB035A3F" box="[1181,1265,1370,1395]" italics="true" pageId="2" pageNumber="153">Juninia</emphasis>
</taxonomicName>
the elytron has two carinae, the humeral and another close to it, while in 
<taxonomicName id="4C2C4D4D0034FFE4FCDAFA80FC5D5ADB" authorityName="Martins &amp; Galileo" authorityYear="1993" box="[801,943,1405,1431]" class="Insecta" family="Cerambycidae" genus="Sibapipunga" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FCDAFA80FC5D5ADB" box="[801,943,1405,1431]" italics="true" pageId="2" pageNumber="153">Sibapipunga</emphasis>
</taxonomicName>
there is only the humeral carina. This latter statement is not accurate because there is a second carina in 
<taxonomicName id="4C2C4D4D0034FFE4FCB2FA5CFC255AF7" authorityName="Martins &amp; Galileo" authorityYear="1993" box="[841,983,1441,1467]" class="Insecta" family="Cerambycidae" genus="Sibapipunga" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FCB2FA5CFC255AF7" box="[841,983,1441,1467]" italics="true" pageId="2" pageNumber="153">Sibapipunga</emphasis>
</taxonomicName>
(
<figureCitation id="13172A4B0034FFE4FC1DFA5CFB9E5AF0" box="[998,1132,1441,1468]" captionStart="FIGURES 21–26" captionStartId="6.[151,264,1920,1944]" captionTargetBox="[151,1436,382,1897]" captionTargetId="figure-136@6.[151,1436,381,1897]" captionTargetPageId="6" captionText="FIGURES 21–26. Sibapipunga beckeri (Martins &amp; Galileo, 1992). 21) Holotype female, dorsal habitus. 22–25) Male: 22) Dorsal habitus; 23) Ventral habitus; 24) Lateral habitus; 25) Frontal tubercles. 26) Holotype female, elytral carinae (by Diego de Santana Souza)." figureDoi="http://doi.org/10.5281/zenodo.6581646" httpUri="https://zenodo.org/record/6581646/files/figure.png" pageId="2" pageNumber="153">Figs 24, 26</figureCitation>
). The difference is that the second carina in 
<taxonomicName id="4C2C4D4D0034FFE4FEAAFA3BFE575A93" authorityName="Lane" authorityYear="1966" box="[337,421,1478,1503]" class="Insecta" family="Cerambycidae" genus="Juninia" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FEAAFA3BFE575A93" box="[337,421,1478,1503]" italics="true" pageId="2" pageNumber="153">Juninia</emphasis>
</taxonomicName>
(
<figureCitation id="13172A4B0034FFE4FE48FA38FDF15AAC" box="[435,515,1477,1504]" captionStart="FIGURES 13–17" captionStartId="4.[151,264,1814,1838]" captionTargetBox="[151,1436,181,1789]" captionTargetId="figure-29@4.[151,1436,181,1790]" captionTargetPageId="4" captionText="FIGURES 13–17. Juninia annulifera (Kirsch, 1889). 13–16) Juninia leechi Lane, 1966, paratype male: 13) Dorsal habitus; 14) Ventral habitus; 15) Lateral habitus; 16) Elytral carinae. 17) Female, dorsal habitus." figureDoi="http://doi.org/10.5281/zenodo.6581640" httpUri="https://zenodo.org/record/6581640/files/figure.png" pageId="2" pageNumber="153">Fig. 16</figureCitation>
) is separated from the humeral carina on basal third, while it is close to the humeral carina in 
<taxonomicName id="4C2C4D4D0034FFE4FF04FA14FE7F594F" authorityName="Martins &amp; Galileo" authorityYear="1993" box="[255,397,1513,1539]" class="Insecta" family="Cerambycidae" genus="Sibapipunga" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FF04FA14FE7F594F" box="[255,397,1513,1539]" italics="true" pageId="2" pageNumber="153">Sibapipunga</emphasis>
</taxonomicName>
. See remarks in 
<taxonomicName id="4C2C4D4D0034FFE4FDB3FA17FD53594F" authorityName="Lane" authorityYear="1956" box="[584,673,1514,1539]" class="Insecta" family="Cerambycidae" genus="Purusia" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FDB3FA17FD53594F" box="[584,673,1514,1539]" italics="true" pageId="2" pageNumber="153">Purusia</emphasis>
</taxonomicName>
on the difference between females of 
<taxonomicName id="4C2C4D4D0034FFE4FBB6FA17FB53594F" authorityName="Lane" authorityYear="1966" box="[1101,1185,1514,1539]" class="Insecta" family="Cerambycidae" genus="Juninia" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FBB6FA17FB53594F" box="[1101,1185,1514,1539]" italics="true" pageId="2" pageNumber="153">Juninia</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C2C4D4D0034FFE4FB2CFA14FA97594F" authorityName="Martins &amp; Galileo" authorityYear="1993" box="[1239,1381,1513,1539]" class="Insecta" family="Cerambycidae" genus="Sibapipunga" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis id="B958EADC0034FFE4FB2CFA14FA97594F" box="[1239,1381,1513,1539]" italics="true" pageId="2" pageNumber="153">Sibapipunga</emphasis>
</taxonomicName>
.
</paragraph>
<paragraph id="8B9336CE0034FFE4FF3CF9F0FD9459DF" blockId="2.[151,1437,937,1971]" pageId="2" pageNumber="153">
The tarsal claws in the female (
<figureCitation id="13172A4B0034FFE4FDDDF9F0FD8A596B" box="[550,632,1549,1575]" captionStart="FIGURES 27–32" captionStartId="7.[151,264,1847,1871]" captionTargetBox="[152,1436,1137,1822]" captionTargetId="figure-420@7.[151,1436,1137,1823]" captionTargetPageId="7" captionText="FIGURES 27–32. Protarsal claws. 27–28) Sibapipunga beckeri (Martins &amp; Galileo, 1992): 27) Holotype female (by Diego de Santana Souza); 28) Male. 29–30) Purusia acreana Lane, 1956: 29) Holotype male; 30) Female. 31–32) Juninia annulifera (Kirsch, 1889): 31) Female; 32) Juninia leechi Lane, 1966, paratype male." figureDoi="http://doi.org/10.5281/zenodo.6581648" httpUri="https://zenodo.org/record/6581648/files/figure.png" pageId="2" pageNumber="153">Fig. 31</figureCitation>
) of 
<taxonomicName id="4C2C4D4D0034FFE4FD5DF9F3FCC7596B" baseAuthorityName="Kirsch" baseAuthorityYear="1889" box="[678,821,1549,1575]" class="Insecta" family="Cerambycidae" genus="Juninia" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="annulifera">
<emphasis id="B958EADC0034FFE4FD5DF9F3FCC7596B" box="[678,821,1549,1575]" italics="true" pageId="2" pageNumber="153">J. annulifera</emphasis>
</taxonomicName>
are considerably different from those in the male (
<figureCitation id="13172A4B0034FFE4FA94F9F0FF455907" captionStart="FIGURES 27–32" captionStartId="7.[151,264,1847,1871]" captionTargetBox="[152,1436,1137,1822]" captionTargetId="figure-420@7.[151,1436,1137,1823]" captionTargetPageId="7" captionText="FIGURES 27–32. Protarsal claws. 27–28) Sibapipunga beckeri (Martins &amp; Galileo, 1992): 27) Holotype female (by Diego de Santana Souza); 28) Male. 29–30) Purusia acreana Lane, 1956: 29) Holotype male; 30) Female. 31–32) Juninia annulifera (Kirsch, 1889): 31) Female; 32) Juninia leechi Lane, 1966, paratype male." figureDoi="http://doi.org/10.5281/zenodo.6581648" httpUri="https://zenodo.org/record/6581648/files/figure.png" pageId="2" pageNumber="153">Fig. 32</figureCitation>
): inner tooth widened basally and about as long as outer tooth, while in the male it is not noticeably widened basally and is shorter than the outer tooth. As we only had 
<specimenCount id="9D2AFD470034FFE4FCD3F9ABFC7F5923" box="[808,909,1621,1648]" pageId="2" pageNumber="153" type="male">one male</specimenCount>
and 
<specimenCount id="9D2AFD470034FFE4FC3FF9ABFBB15923" box="[964,1091,1621,1648]" pageId="2" pageNumber="153" type="female">one female</specimenCount>
, it was not possible to verify if this is a common variation in the species.
</paragraph>
<paragraph id="8B9336CE0034FFE4FF3CF960FCBC586F" blockId="2.[151,1437,937,1971]" pageId="2" pageNumber="153">
<materialsCitation id="3B443C930034FFE4FF3CF960FA6B5997" ID-GBIF-Occurrence="3785194301" country="Ecuador" elevation="1500" location="Ecuadorian province" municipality="This" pageId="2" pageNumber="153" specimenCount="1" stateProvince="Morona-Santiago">
According to 
<bibRefCitation id="EFBD4B3F0034FFE4FE92F960FDFE59FB" author="Kirsch, T. F." box="[361,524,1693,1719]" pageId="2" pageNumber="153" pagination="1 - 58" refId="ref6203" refString="Kirsch, T. F. (1889) Coleopteren gesammelt in den Jahren 1868 - 1877 auf einen Reise durch Sud Amerika von Alphons Stubel. Abhandlungen und Berichte des Koniglichen Zoologischen und Anthropologisch-Etnographischen Museums zu Dresden, 4, 1 - 58." type="journal article" year="1889">Kirsch (1889)</bibRefCitation>
, the type locality of 
<taxonomicName id="4C2C4D4D0034FFE4FCFDF960FBD259FB" authorityName="Kirsch" authorityYear="1889" box="[774,1056,1693,1719]" class="Insecta" family="Cerambycidae" genus="Amphionycha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="annulifera">
<emphasis id="B958EADC0034FFE4FCFDF960FBD259FB" box="[774,1056,1693,1719]" italics="true" pageId="2" pageNumber="153">Amphionycha annulifera</emphasis>
</taxonomicName>
is “Patria: 
<collectingCountry id="F33B765E0034FFE4FB52F960FAF459FB" box="[1193,1286,1693,1719]" name="Ecuador" pageId="2" pageNumber="153">Ecuador</collectingCountry>
(Huamboya, regione sylvarum, in 
<quantity id="4CD49B2B0034FFE4FE77F93CFDD85990" box="[396,554,1729,1756]" metricMagnitude="3" metricUnit="m" metricValue="1.5" metricValueMax="2.0" metricValueMin="1.0" pageId="2" pageNumber="153" unit="m" value="1500.0" valueMax="2000.0" valueMin="1000.0">
<elevation id="0001D1FD0034FFE4FE77F93CFDD85990" box="[396,554,1729,1756]" metricMagnitude="3" metricUnit="m" metricValue="1.5" metricValueMax="2.0" metricValueMin="1.0" pageId="2" pageNumber="153" unit="m" value="1500.0" valueMax="2000.0" valueMin="1000.0">1000–2000 m</elevation>
</quantity>
alt. coll.).” 
<collectingMunicipality id="6BF7ACB40034FFE4FD4DF93CFD1A5997" box="[694,744,1729,1755]" pageId="2" pageNumber="153">This</collectingMunicipality>
location is in the 
<location id="8EF360150034FFE4FC47F93CFB555997" LSID="urn:lsid:plazi:treatment:038587D80034FFE4FF6CFD06FE7158FF:8EF360150034FFE4FC47F93CFB555997" box="[956,1191,1729,1755]" country="Ecuador" municipality="This" name="Ecuadorian province" pageId="2" pageNumber="153" stateProvince="Morona-Santiago">Ecuadorian province</location>
of 
<collectingRegion id="49E8F82C0034FFE4FB2AF93CFA6B5997" box="[1233,1433,1729,1755]" country="Ecuador" name="Morona-Santiago" pageId="2" pageNumber="153">Morona-Santiago</collectingRegion>
</materialsCitation>
. 
<materialsCitation id="3B443C930034FFE4FF6CF91BFCB8586F" ID-GBIF-Occurrence="3785194306" country="Ecuador" location="Ecuadorian province" municipality="Latacunga" pageId="2" pageNumber="153" specimenCount="2" stateProvince="Cotopaxi" typeStatus="holotype">
However, the label of the 
<typeStatus id="5497886C0034FFE4FE49F918FDE659B3" box="[434,532,1765,1791]" pageId="2" pageNumber="153">holotype</typeStatus>
(
<figureCitation id="13172A4B0034FFE4FDD9F918FD8159B3" box="[546,627,1765,1791]" captionStart="FIGURES 18–20" captionStartId="5.[151,264,1012,1036]" captionTargetBox="[151,1436,182,988]" captionTargetId="figure-22@5.[151,1436,181,988]" captionTargetPageId="5" captionText="FIGURES 18–20. Juninia annulifera (Kirsch, 1889), holotype male. 18) Dorsal habitus; 19) Labels; 20) Ventral habitus." figureDoi="http://doi.org/10.5281/zenodo.6581642" httpUri="https://zenodo.org/record/6581642/files/figure.png" pageId="2" pageNumber="153">Fig. 19</figureCitation>
) makes it clear that the information is wrong. The 
<typeStatus id="5497886C0034FFE4FB65F918FAF259B3" box="[1182,1280,1765,1791]" pageId="2" pageNumber="153">holotype</typeStatus>
was collected in 
<collectingMunicipality id="6BF7ACB40034FFE4FF4FF8F7FEDE5868" box="[180,300,1802,1828]" pageId="2" pageNumber="153">Latacunga</collectingMunicipality>
, a place in the 
<location id="8EF360150034FFE4FE29F8F4FD49586F" LSID="urn:lsid:plazi:treatment:038587D80034FFE4FF6CFD06FE7158FF:8EF360150034FFE4FE29F8F4FD49586F" box="[466,699,1801,1827]" country="Ecuador" municipality="Latacunga" name="Ecuadorian province" pageId="2" pageNumber="153" stateProvince="Cotopaxi">Ecuadorian province</location>
of 
<collectingRegion id="49E8F82C0034FFE4FD1BF8F4FCB8586F" box="[736,842,1801,1827]" country="Ecuador" name="Cotopaxi" pageId="2" pageNumber="153">Cotopaxi</collectingRegion>
</materialsCitation>
.
</paragraph>
<paragraph id="8B9336CE0034FFE4FF3CF8D0FE7158FF" blockId="2.[151,1437,937,1971]" pageId="2" pageNumber="153">
<emphasis id="B958EADC0034FFE4FF3CF8D0FD76580B" bold="true" box="[199,644,1837,1864]" pageId="2" pageNumber="153">
