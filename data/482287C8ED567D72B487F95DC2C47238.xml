<taxonomicName id="078B4D5DED567D72B482F6A0C96E79AC" authority="Womochel, 1978" authorityName="Womochel" authorityYear="1978" box="[195,583,2429,2458]" class="Mammalia" family="Dipodidae" genus="Scarturus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Rodentia" pageId="11" pageNumber="92" phylum="Chordata" rank="subSpecies" species="hotsoni" subSpecies="firouzi">S. h. firouzi Womochel, 1978</taxonomicName>
