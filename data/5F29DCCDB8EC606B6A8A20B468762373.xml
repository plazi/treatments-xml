<subSubSection id="851D9F5002E940AB9FD8DCEA3E047FAA" pageId="null" pageNumber="667" type="description">
<paragraph id="0BFD2B758B463783B864E8B45C1189D7" pageId="null" pageNumber="667">
Unterscheidet sich von 
<taxonomicName id="9B37BCB445042715BA57FBB70D9C69DB" class="Magnoliopsida" family="Euphorbiaceae" genus="Euphorbia" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="667" phylum="Tracheophyta" rank="species" species="virgata">
<emphasis id="098935159C26788415CD9B505EEDC91C" italics="true" pageId="null" pageNumber="667">E. virgata</emphasis>
</taxonomicName>
(Nr. 15b) durch folgende Merkmale: 
<emphasis id="B8AF01C1AB56ABD35528ECC6557A08D1" italics="true" pageId="null" pageNumber="667">
Wurzelstock 
<normalizedToken id="AD5DC49D94B8D47D6BFAA7224CDBF0CD" originalValue="dünn" pageId="null" pageNumber="667">duenn</normalizedToken>
</emphasis>
, weit kriechende 
<normalizedToken id="709BC3E7847917BDAC052EB9425EDA49" originalValue="Ausläufer" pageId="null" pageNumber="667">Auslaeufer</normalizedToken>
stets vorhanden; 
<emphasis id="71B1D8DA2147D5272012FF859D26986E" italics="true" pageId="null" pageNumber="667">
<normalizedToken id="9B15105FBC38C68E7BB8696D21DF08BE" originalValue="größte" pageId="null" pageNumber="667">groesste</normalizedToken>
Blattbreite meist 
<normalizedToken id="EFFAB33786C95066E6530820CA71A5B0" originalValue="über" pageId="null" pageNumber="667">ueber</normalizedToken>
der Mitte, 
<normalizedToken id="5373F54B73077012A6B74E232B43ADFE" originalValue="Blätter" pageId="null" pageNumber="667">Blaetter</normalizedToken>
nach dem Grunde 
<normalizedToken id="0D491DED26FF31D81C6BF137E8E27391" originalValue="verschmälert" pageId="null" pageNumber="667">verschmaelert</normalizedToken>
</emphasis>
(
<emphasis id="3BFB953E9A0C5C5C8277043E82382D08" italics="true" pageId="null" pageNumber="667">Basis nur so breit wie der Mittelnerv</emphasis>
), 
<emphasis id="268BE51C87A50BECAF0611275C9D3535" italics="true" pageId="null" pageNumber="667">Blattrand nach unten umgebogen</emphasis>
(
<emphasis id="4C006623E0B84BF8627893B3905DFC29" italics="true" pageId="null" pageNumber="667">frisches Material</emphasis>
!), 
<emphasis id="21CD03C7C9B9597ABF93CBFD6D9C0D8C" italics="true" pageId="null" pageNumber="667">
wenigstens an der Blattspitze fein und 
<normalizedToken id="AD7F3C8880F71D2D35FEFE17129E7869" originalValue="unregelmäßig" pageId="null" pageNumber="667">unregelmaessig</normalizedToken>
<normalizedToken id="896945B4BDD498E17F35DA3AB5D694B7" originalValue="gezähnt" pageId="null" pageNumber="667">gezaehnt</normalizedToken>
</emphasis>
(
<normalizedToken id="6F260455B6F577394D86F74A77639B2A" originalValue="Zähne" pageId="null" pageNumber="667">Zaehne</normalizedToken>
<normalizedToken id="162E5F2A0297A9AAF3F2FFB4A6B5C432" originalValue="höchstens" pageId="null" pageNumber="667">hoechstens</normalizedToken>
0,05 mm hoch; 20fache 
<normalizedToken id="0FD647D8F17804939CE36ED86A99AB1B" originalValue="Vergrößerung" pageId="null" pageNumber="667">Vergroesserung</normalizedToken>
!); 
<emphasis id="4D78BB9EDA2F15AC9D1183A1A2E882C4" italics="true" pageId="null" pageNumber="667">
Spitzen der 
<normalizedToken id="2897E64907C605380F1D5AE9AC874164" originalValue="sichelförmigen" pageId="null" pageNumber="667">sichelfoermigen</normalizedToken>
<normalizedToken id="183E8439A3EB2EB62BA9FAC469854933" originalValue="Drüsen" pageId="null" pageNumber="667">Druesen</normalizedToken>
nicht verdickt.
</emphasis>
- 
<normalizedToken id="B9FA9A9E022A41F2C0FB75E6907C3C1E" originalValue="Blüte" pageId="null" pageNumber="667">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="78149F4C26E329BDC46C34B6CF8198B7" pageId="null" pageNumber="667">
<emphasis id="E1FD33D04205A9A93741DFB6C051770D" italics="true" pageId="null" pageNumber="667">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="BF1CA99F1AB7A08D7F9C5D62047B3C35" italics="true" pageId="null" pageNumber="667">60:</emphasis>
Material aus Kanada (14 Proben von Ontario bis Saskatchewan) (Moore 1958, Mulligan 1961), aus England (Material vielgestaltig, selbststeril) (Pritchard 1959), aus Holland (Gadella und Kliphuis 1966). 
<emphasis id="FF519F81167821B6E5A8D3A921BC6395" italics="true" pageId="null" pageNumber="667">2n</emphasis>
= 
<emphasis id="EFF52AA99B6322FF1C3DA39BDFD68D42" italics="true" pageId="null" pageNumber="667">64:</emphasis>
Material aus Holland (Gadella und Kliphuis 1968).
</paragraph>
<paragraph id="872528020A9D523C9B85E3FEFA7BD905" pageId="null" pageNumber="667">
<emphasis id="2A9784AE7520C0B11B78F5D4F33335DF" italics="true" pageId="null" pageNumber="667">
<pageBreakToken id="125986C37A5A7781AB256C12B04DB611" pageId="null" pageNumber="667">Standort</pageBreakToken>
.
</emphasis>
Kollin und montan. Kalkhaltige, 
<normalizedToken id="4B2261B97564B447B92CA6065F342805" originalValue="nährstoffreiche" pageId="null" pageNumber="667">naehrstoffreiche</normalizedToken>
, feuchte bis ziemlich trockene 
<normalizedToken id="6729AC213AC28151E0DB2A35C1C92CA3" originalValue="Böden" pageId="null" pageNumber="667">Boeden</normalizedToken>
. An 
<normalizedToken id="1FA29E842DEA992976C105AFA796C3EC" originalValue="Gräben" pageId="null" pageNumber="667">Graeben</normalizedToken>
, 
<normalizedToken id="84505D9E630E09609ECA321BD4FBD0E3" originalValue="Dämmen" pageId="null" pageNumber="667">Daemmen</normalizedToken>
, in 
<normalizedToken id="D9D0F43CD6DAD4CB2D1E4AFD03A1661E" originalValue="Äckern" pageId="null" pageNumber="667">Aeckern</normalizedToken>
, Wiesen (auch Trockenwiesen).
</paragraph>
<paragraph id="F2970B79832BE9AEB258A8FAF8E3C48A" pageId="null" pageNumber="667">
<emphasis id="A1B5E22C3CF61C74DADE501AE7ECD642" italics="true" pageId="null" pageNumber="667">
Verbreitung. 
<normalizedToken id="E1E07EACD4D47BFAB85CFC4876C09774" originalValue="Europäische" pageId="null" pageNumber="667">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="6E55984FE8EE4090A3B9FD9AC6724FBC" originalValue="Nordwärts" pageId="null" pageNumber="667">Nordwaerts</normalizedToken>
bis England, 
<normalizedToken id="D69E4049344CCB2B25008419D031B67B" originalValue="Südnorwegen" pageId="null" pageNumber="667">Suednorwegen</normalizedToken>
, 
<normalizedToken id="893DE3BFECB6A67AB61B711241FD1CFF" originalValue="Südfinnland" pageId="null" pageNumber="667">Suedfinnland</normalizedToken>
; 
<normalizedToken id="ECC8DB45EDA43FC74453C22CC7278190" originalValue="ostwärts" pageId="null" pageNumber="667">ostwaerts</normalizedToken>
bis Ukraine; 
<normalizedToken id="620F5E1003FC19DC0BF530CE51E6FEB1" originalValue="südwärts" pageId="null" pageNumber="667">suedwaerts</normalizedToken>
bis Spanien (Katalonien), 
<normalizedToken id="F538599CAB939068C893AE8D8CB26223" originalValue="Süditalien" pageId="null" pageNumber="667">Sueditalien</normalizedToken>
, Mazedonien; nach Amerika verschleppt und dort weit verbreitet. - Im Gebiet: 
<normalizedToken id="97016087F4ABDE7E3BBCFDAC1326D78B" originalValue="Französischer" pageId="null" pageNumber="667">Franzoesischer</normalizedToken>
Jura (Alluvionen des Doubs und der Loue bei 
<normalizedToken id="F2879DE114EBFF3BBB27C2EA739C7ABD" originalValue="Dôle" pageId="null" pageNumber="667">Dole</normalizedToken>
und bei 
<normalizedToken id="574B7C3D5C882BACCEA2142043C05602" originalValue="Besançon" pageId="null" pageNumber="667">Besancon</normalizedToken>
), Oberrheinische Tiefebene und angrenzendes 
<normalizedToken id="BA537A30E59B2D7DE552B57FC3D8C8F2" originalValue="Hügelland" pageId="null" pageNumber="667">Huegelland</normalizedToken>
(wenige Angaben), Aostatal (Cogne, Aosta, Ivrea), 
<normalizedToken id="8491781F58DE7A11D100ED55A57794AE" originalValue="Alpensüdfuß" pageId="null" pageNumber="667">Alpensuedfuss</normalizedToken>
(nach Rodegher und Venanzi 1894 
<normalizedToken id="C004A57E90460DFF059614B48BCCD289" originalValue="häufig" pageId="null" pageNumber="667">haeufig</normalizedToken>
in feuchten 
<normalizedToken id="383615D9B53E4D2191F4D174C4E1EA7B" originalValue="Straßengräben" pageId="null" pageNumber="667">Strassengraeben</normalizedToken>
der Provinz Bergamo); sonst selten und nur adventiv.
</paragraph>
<paragraph id="4DFBF058B56FBFAD66CC344D8C6336EC" pageId="null" pageNumber="667">
<emphasis id="91AD1E9A8E596101C731CC13E1C9639D" italics="true" pageId="null" pageNumber="667">Bemerkungen.</emphasis>
Die 7 nahe verwandten Arten von 
<taxonomicName id="B23B59FDFD38591DADF21D519CFFBDDF" class="Magnoliopsida" family="Euphorbiaceae" genus="Euphorbia" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="667" phylum="Tracheophyta" rank="species" species="esula">
<emphasis id="F2BD78CB95E665F58A0AD3C5F5E39C42" italics="true" pageId="null" pageNumber="667">E. Esula</emphasis>
</taxonomicName>
sind alle in 
<normalizedToken id="2383E6DE20BAEE19F3A971872438BC77" originalValue="Südrußland" pageId="null" pageNumber="667">Suedrussland</normalizedToken>
, Westsibirien und Zentralasien verbreitet (Kuzmanov 1964).
</paragraph>
</subSubSection>
