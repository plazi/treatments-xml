Female genital plates in Ventral view. A: 
<taxonomicName id="4C084D712155FFF8FD0E1CD6FCDBF80F" authority="Silva &amp; Fernandes, 2022" authorityName="Da Silva &amp; Fernandes" authorityYear="2022" box="[699,837,2003,2027]" class="Insecta" family="Pentatomidae" genus="Grammedessa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hemiptera" pageId="7" pageNumber="218" phylum="Arthropoda" rank="species" species="longispina" status="sp.n.">
<emphasis id="B97CEAE02155FFF8FD0E1CD6FCDBF80F" box="[699,837,2003,2027]" italics="true" pageId="7" pageNumber="218">G. longispina</emphasis>
</taxonomicName>
<emphasis id="B97CEAE02155FFF8FCFE1CD6FCE0F80F" bold="true" box="[843,894,2003,2027]" pageId="7" pageNumber="218">
<taxonomicNameLabel id="A24F579B2155FFF8FCFE1CD6FCE0F80F" box="[843,894,2003,2027]" pageId="7" pageNumber="218" rank="species">sp.n.</taxonomicNameLabel>
</emphasis>
B: 
<taxonomicName id="4C084D712155FFF8FC171CD6FBC3F80F" authorityName="Correia &amp; Fernandes" authorityYear="2016" box="[930,1117,2003,2027]" class="Insecta" family="Pentatomidae" genus="Grammedessa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hemiptera" pageId="7" pageNumber="218" phylum="Arthropoda" rank="species" species="brunneotarsata">
