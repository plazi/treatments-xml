(
<figureCitation id="13332A772155FFF8FF2A1BBEFE81FF31" box="[159,287,187,213]" captionStart="FIGURE 1" captionStartId="3.[151,250,1866,1890]" captionTargetBox="[171,1412,191,1824]" captionTargetId="figure-20@3.[171,1416,181,1841]" captionTargetPageId="3" captionText="FIGURE 1. Grammedessa. A–B: G. hamata comb.n. A: Dorsal view. B: Ventral view. C–D: G. nigricava sp.n. C: Dorsal view. D: Ventral view. E–F: G. longispina sp.n. E: Dorsal view. F: Ventral view. G–H: G. fundicava sp.n. G: Dorsal view. H: Ventral view. I–J: G. graciligramma sp.n. I: Dorsal view. J: Ventral view. K–L: G. stichtocephala sp.n. K: Dorsal view. L: Ventral view. M–N: G. acalyptoprocta sp.n. M: Dorsal view. N: Ventral view. Scale = 10 mm." figureDoi="http://doi.org/10.5281/zenodo.6500667" httpUri="https://zenodo.org/record/6500667/files/figure.png" pageId="7" pageNumber="218">Figs. 1E–F</figureCitation>
