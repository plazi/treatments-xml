<caption id="DF1B66025A709804FA68FE84E995FD2E" ID-DOI="http://doi.org/10.5281/zenodo.6624526" ID-Zenodo-Dep="6624526" httpUri="https://zenodo.org/record/6624526/files/figure.png" inLine="true" pageId="7" pageNumber="200" targetBox="[157,749,3064,3477]" targetPageId="7">
