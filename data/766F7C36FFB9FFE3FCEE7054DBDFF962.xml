<emphasis id="CCB21132FFB9FFE3FCB4730EDBC9F9C2" bold="true" box="[831,945,1577,1601]" pageId="8" pageNumber="21">Comment</emphasis>
: 
<taxonomicName id="39C6B6A3FFB9FFE3FC4F730EDCE9F9C2" authorityName="ASSING" authorityYear="2006" box="[964,1169,1577,1601]" class="Insecta" family="Staphylinidae" genus="Orphnebius" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="21" phylum="Arthropoda" rank="species" species="gibber">
