<subSubSection id="3B9830623BF62D36A31D733E12822936" pageId="null" pageNumber="113" type="description">
<paragraph id="6D7A1D55E4AD9BFDA2136C1ADA88A00D" pageId="null" pageNumber="113">
<emphasis id="7A956AAEE9283066EEB7E79C5A33D9E4" italics="true" pageId="null" pageNumber="113">Stengel mit 0,5-1 mm langen Haaren. Kelch zerstreut mit 0,5-1 mm langen Haaren</emphasis>
besetzt oder fast kahl. 
<emphasis id="E82482E39C8DD3E9E6E4A46EACE3B02C" italics="true" pageId="null" pageNumber="113">
Frucht 
<normalizedToken id="EC3F0A14C2F8C5B83A327CAAF4EB1DCF" originalValue="eiförmig" pageId="null" pageNumber="113">eifoermig</normalizedToken>
, 0,6-1 cm lang
</emphasis>
und 0,4-0,5 cm breit, mit ziemlich zahlreichen 1-2 mm langen und am Grunde 0,2 mm dicken Haaren. Samen 0,7-0,9 mm lang. - 
<normalizedToken id="143ED8A8F945DEDBE2480DE87CCAE21C" originalValue="Blüte" pageId="null" pageNumber="113">Bluete</normalizedToken>
: 
<normalizedToken id="42F1CE06D72278641789F76A926E1189" originalValue="Später" pageId="null" pageNumber="113">Spaeter</normalizedToken>
<normalizedToken id="EB7E2F0FD357F5364B95BA366A32FAC3" originalValue="Frühling" pageId="null" pageNumber="113">Fruehling</normalizedToken>
und 
<normalizedToken id="6120562E3787ED091A783D0CB0624705" originalValue="früher" pageId="null" pageNumber="113">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="2F1F952D1DE03AA1B282748FB167849D" pageId="null" pageNumber="113">
<emphasis id="AFC44B29887ABB676A24B60D29F15B15" italics="true" pageId="null" pageNumber="113">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="841C5B4A1F5262DD1A49C9BDE1B8807D" italics="true" pageId="null" pageNumber="113">12:</emphasis>
Material aus botanischen 
<normalizedToken id="21BB6320072A60945B01E76B2CB827AD" originalValue="Gärten" pageId="null" pageNumber="113">Gaerten</normalizedToken>
(Sugiura 1936a, McNaughton 1960).
</paragraph>
<paragraph id="66F149CC90C07BA2EF8766CB4FF00794" pageId="null" pageNumber="113">
<emphasis id="09120349351872BD85E5130B90114BE6" italics="true" pageId="null" pageNumber="113">Standort.</emphasis>
Kollin. Lockere, 
<normalizedToken id="BBBEAD8C70CA247E6DCBBF5461A9B7B5" originalValue="nährstoffreiche" pageId="null" pageNumber="113">naehrstoffreiche</normalizedToken>
, kalkhaltige 
<normalizedToken id="23527F4795A77F681155F03DCBAB02CF" originalValue="Böden" pageId="null" pageNumber="113">Boeden</normalizedToken>
in warmen Lagen. Getreidefelder, unbebaute Orte, 
<normalizedToken id="FFEC5A87970DBDBAC9DB2C7F8E6E02E8" originalValue="Schuttplätze" pageId="null" pageNumber="113">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="81B237752ABF3D342203CD5F0A7981F5" pageId="null" pageNumber="113">
<emphasis id="623B05F95532573FB5ACF59333B8BB33" italics="true" pageId="null" pageNumber="113">
Verbreitung. 
<normalizedToken id="324B170C9D80FA2BA77CABAD16F858BC" originalValue="Südosteuropäische" pageId="null" pageNumber="113">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Von Italien 
<normalizedToken id="464F98DCB28E6882130EF33B98B973B5" originalValue="ostwärts" pageId="null" pageNumber="113">ostwaerts</normalizedToken>
bis nach Griechenland und zu den 
<normalizedToken id="CF373338400C6F89FA1726331DC2896E" originalValue="Ägäischen" pageId="null" pageNumber="113">Aegaeischen</normalizedToken>
Inseln; 
<normalizedToken id="F8A85BC50F559A78EA0CBE61BEFB8FFA" originalValue="nordwärts" pageId="null" pageNumber="113">nordwaerts</normalizedToken>
bis 
<normalizedToken id="58A38C055567640FFF0834DB837C551D" originalValue="Südalpen" pageId="null" pageNumber="113">Suedalpen</normalizedToken>
, Istrien, Thrazien. - Im Gebiet: 
<normalizedToken id="98121D2B3C652C81F8039BBCDCD81A9C" originalValue="Südliches" pageId="null" pageNumber="113">Suedliches</normalizedToken>
Tessin (
<normalizedToken id="FEDE303D4C69C5DBC7AE1CAB4B11F33E" originalValue="früher" pageId="null" pageNumber="113">frueher</normalizedToken>
bei Lugano und Balerna), Comerseegebiet (z. B. Brianza, Varenna, Mandello, Esino), Bergamasker Alpen (z. B. Gebiet von Bergamo, Clusone, 
<normalizedToken id="7987B312549BBD696C6694F29EBFBC1E" originalValue="Presolanapaß" pageId="null" pageNumber="113">Presolanapass</normalizedToken>
); vgl. auch Landolt (1967).
</paragraph>
</subSubSection>
