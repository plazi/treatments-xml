((NI = op/pq, BCI = st/rs); scale bar = 
<quantity box="[1260,1318,1999,2023]" metricMagnitude="-3" metricUnit="m" metricValue="1.0" pageId="3" pageNumber="145" unit="mm" value="1.0">1 mm</quantity>
