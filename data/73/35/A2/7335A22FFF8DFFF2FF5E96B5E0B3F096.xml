<taxonomicName authority="Shimizu &amp; Lima" authorityName="Shimizu &amp; Lima" authorityYear="2017" box="[279,739,1927,1951]" class="Insecta" family="Ichneumonidae" genus="Stauropoctonus" kingdom="Animalia" order="Hymenoptera" pageId="4" pageNumber="146" phylum="Arthropoda" rank="species" species="aurantiacus">
