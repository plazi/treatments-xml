<subSubSection id="0BAB34ECE8BCC80068A7B47F099D37B9" pageId="null" pageNumber="717" type="vernacular_names">
<paragraph id="83FA2B8C23DAD8541552D023905E315A" pageId="null" pageNumber="717">Bleiche Osterluzei</paragraph>
</subSubSection>
</title>
<subSubSection id="18F921213569FE32D20371860F76EE13" pageId="null" pageNumber="717" type="description">
<paragraph id="6563C304E939FAA1D959869D30481D73" pageId="null" pageNumber="717">
Unterscheidet sich von 
<taxonomicName id="F00A65C1A6C022377B88C0BDE415BC3D" class="Magnoliopsida" family="Aristolochiaceae" genus="Aristolochia" kingdom="Plantae" order="Piperales" pageId="null" pageNumber="717" phylum="Tracheophyta" rank="species" species="rotunda">
<emphasis id="B81DA30D856216D5AED978EB895308E7" italics="true" pageId="null" pageNumber="717">A. rotunda</emphasis>
</taxonomicName>
(Nr. 2) durch folgende Merkmale: 
<emphasis id="10F3665362626100CC823404A4B168C2" italics="true" pageId="null" pageNumber="717">
<normalizedToken id="66CAF5E208EA88F4FFD7D4F98BF8AAC7" originalValue="Blätter" pageId="null" pageNumber="717">Blaetter</normalizedToken>
am Grunde mit weitem, 
<normalizedToken id="8927693F51FA9B72E52E51AE4A21E57C" originalValue="herzförmigem" pageId="null" pageNumber="717">herzfoermigem</normalizedToken>
Ausschnitt
</emphasis>
, 
<normalizedToken id="42BBE7175F249AEA74F50D29D527C561" originalValue="allmählich" pageId="null" pageNumber="717">allmaehlich</normalizedToken>
in den Stiel 
<normalizedToken id="59FEF7DAB853398F9EC5D02E678581CA" originalValue="verschmälert" pageId="null" pageNumber="717">verschmaelert</normalizedToken>
, an der Spitze oft ausgerandet; 
<emphasis id="90DF33F922265D59E783B7717074D63B" italics="true" pageId="null" pageNumber="717">Blattstiel oft mehr als 10 mm lang.</emphasis>
- 
<normalizedToken id="DD3F9753777F5B25F4CA54EB17364E83" originalValue="Blüte" pageId="null" pageNumber="717">Bluete</normalizedToken>
: 
<normalizedToken id="DF1ACD4BAE5B8A642F3EB01EBF1EEC49" originalValue="Frühling" pageId="null" pageNumber="717">Fruehling</normalizedToken>
und 
<normalizedToken id="8C8BDB897517CF028C7EC72F5317ACB3" originalValue="früher" pageId="null" pageNumber="717">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="2714AB7082ABFB8920C7B13960DEBD69" pageId="null" pageNumber="717">
<emphasis id="D0D014BFC98C79A34F938840352E4018" italics="true" pageId="null" pageNumber="717">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="838135F03A357B7351C4CF933B915428" pageId="null" pageNumber="717">
<emphasis id="BE9F193CA78C14744F0C219FDD9ABE67" italics="true" pageId="null" pageNumber="717">Standort.</emphasis>
Kollin und montan. Trockene und wechselfeuchte, kalkhaltige 
<normalizedToken id="FCD3DF68ACA2FCD777C48E70FEB7EEBF" originalValue="Böden" pageId="null" pageNumber="717">Boeden</normalizedToken>
in warmen Lagen. Wiesen, 
<normalizedToken id="E483EBC228806E8963523A65FADC544E" originalValue="Gebüsche" pageId="null" pageNumber="717">Gebuesche</normalizedToken>
, 
<normalizedToken id="3266D6DA02077F5676CC7ADBBFC1E862" originalValue="Auenwälder" pageId="null" pageNumber="717">Auenwaelder</normalizedToken>
.
</paragraph>
<paragraph id="903F3FF96B1297E23E83E4C9316C9944" pageId="null" pageNumber="717">
<emphasis id="E525EF5FC75C2B5D749B7F9B8C38C5C9" italics="true" pageId="null" pageNumber="717">Verbreitung. Mediterrane Pflanze:</emphasis>
Von Spanien und Nordafrika 
<normalizedToken id="30111DB3B0D8A031E5E994C5DFAB4B14" originalValue="nordwärts" pageId="null" pageNumber="717">nordwaerts</normalizedToken>
bis Var, 
<normalizedToken id="A8941F47508A6E1085A462D00EB4BE03" originalValue="Südalpen" pageId="null" pageNumber="717">Suedalpen</normalizedToken>
, Balkanhalbinsel, 
<normalizedToken id="B4D824156802D221C7B650E9FB2A4A31" originalValue="ostwärts" pageId="null" pageNumber="717">ostwaerts</normalizedToken>
bis Kleinasien, - Im Gebiet: Aostatal (Tavagnasco), Piemont (Val Oropa), Gegend des Comersees (Grigna), 
<normalizedToken id="3F61378EF5091E32C8B91E2DA3AB5889" originalValue="Südseite" pageId="null" pageNumber="717">Suedseite</normalizedToken>
der Bergamasker Alpen (Monte Canto alto).
</paragraph>
</subSubSection>
