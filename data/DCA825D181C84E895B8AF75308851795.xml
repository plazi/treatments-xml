<normalizedToken id="472C03D716F307CF692F8BD1E89CADA7" originalValue="khünx">khuenx</normalizedToken>
, hma:k 
<normalizedToken id="7281285FB79F4E5430DB70F2A636015F" originalValue="khüa">khuea</normalizedToken>
<normalizedToken id="E21C2234C49BF818F336D5EC75F9D7E5" originalValue="hlè">hle</normalizedToken>
