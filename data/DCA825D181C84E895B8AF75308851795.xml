); 
<normalizedToken id="F73A48BCBF986161C308775F5D01540E" originalValue="cà">ca</normalizedToken>
<normalizedToken id="59A26A4927712B9C01C805FE0453D8D1" originalValue="du’o’c">du'o'c</normalizedToken>
nui, 
