<taxonomicName id="51432B31747BDF79D4DF6CBD0AA1E001" authority="L." class="Magnoliopsida" family="Apiaceae" genus="Seseli" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="826" phylum="Tracheophyta" rank="species" species="montanum">
