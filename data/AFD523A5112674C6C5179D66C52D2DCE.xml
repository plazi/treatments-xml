<subSubSection id="A84266F12169399080F1822ADA6AB632" pageId="null" pageNumber="199" type="nomenclature">
<paragraph id="5639BF48672FDA6B4A1F845CBF92536D" pageId="null" pageNumber="199">
<taxonomicName id="E26379D21003A652CD02DBB0797237F8" authority="L." class="Liliopsida" family="Potamogetonaceae" genus="Potamogeton" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="199" phylum="Tracheophyta" rank="species" species="crispus">
Potamogeton 
<normalizedToken id="25A57B7DE9D5573C4CFB6ED3C98FCBFD" originalValue="críspus" pageId="null" pageNumber="199">crispus</normalizedToken>
<authorityName id="C8752416568DE4CA22537359A209080C" pageId="null" pageNumber="199">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="AA6DC70C9DC7A058074E95086BA20E45" pageId="null" pageNumber="199" type="vernacular_names">
<paragraph id="2FF0A735FAB1994A10169988C1F5249E" pageId="null" pageNumber="199">Krauses Laichkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="5F3E13CB46937975237F9EA2D4150D5A" pageId="null" pageNumber="199" type="description">
<paragraph id="B9A426FAF5A955DBC205D7A380C68B0E" pageId="null" pageNumber="199">
Rhizom sehr 
<normalizedToken id="E8B7909B59558433876DFC91171375B3" originalValue="dünn" pageId="null" pageNumber="199">duenn</normalizedToken>
, kurz kriechend. Stengel bis 2 m lang, meist verzweigt. Alle 
<normalizedToken id="AAC1CA0EBFDC61E31AF474455CFB26A5" originalValue="Blätter" pageId="null" pageNumber="199">Blaetter</normalizedToken>
untergetaucht (nie besondere 
<normalizedToken id="E4C70A4617321D6830FEA0A81F5B299F" originalValue="Schwimmblätter" pageId="null" pageNumber="199">Schwimmblaetter</normalizedToken>
vorhanden), schmal oval, bis 10 cm lang und 5-10mal so lang wie breit, 
<emphasis id="63DB536A2D81FF58D8989A8B177A1104" italics="true" pageId="null" pageNumber="199">
fein 
<normalizedToken id="A292FDC1876F64728E5F18E863B90401" originalValue="gezähnt" pageId="null" pageNumber="199">gezaehnt</normalizedToken>
</emphasis>
(
<emphasis id="DAE235A6095E966F758035892A591D66" italics="true" pageId="null" pageNumber="199">
die meisten 
<normalizedToken id="C7B8FCD05E17F586A6F93F5B3E61FA44" originalValue="Zähne" pageId="null" pageNumber="199">Zaehne</normalizedToken>
0,1-0,3 mm hoch
</emphasis>
) und am Rande meist kraus, nach dem Grunde 
<normalizedToken id="BD0561301A9F70D1BE45D0E3C800E798" originalValue="allmählich" pageId="null" pageNumber="199">allmaehlich</normalizedToken>
<normalizedToken id="281CC6121C38200BAA19EFA70315F6A4" originalValue="verschmälert" pageId="null" pageNumber="199">verschmaelert</normalizedToken>
, sitzend, den Stengel teilweise umfassend. 
<normalizedToken id="1D964E6C82B5ED564EEA0F861F98DFBF" originalValue="Blatthäutchen" pageId="null" pageNumber="199">Blatthaeutchen</normalizedToken>
bis 1,5 cm lang. 
<normalizedToken id="551EB169F6B2A1F6B84C7338312203AD" originalValue="Blütenstand" pageId="null" pageNumber="199">Bluetenstand</normalizedToken>
kurz, selten 
<normalizedToken id="D6D704ACA05455416D75898CE3D20BDD" originalValue="über" pageId="null" pageNumber="199">ueber</normalizedToken>
2 cm lang, locker und mit wenigen 
<normalizedToken id="A94051CF509D3125FC6E95115E33A208" originalValue="Blüten" pageId="null" pageNumber="199">Blueten</normalizedToken>
(bis 10 
<normalizedToken id="01C01F1AE480BC04F6B7223D51067820" originalValue="Blüten" pageId="null" pageNumber="199">Blueten</normalizedToken>
), auf bis 10 cm langem Stiel. Stiel nicht dicker als der unten angrenzende Teil des Stengels. 
<emphasis id="D54A6D89D63C5BCA69718E46B6F36184" italics="true" pageId="null" pageNumber="199">
<normalizedToken id="29B9107B46AC9282524D273A2F9C8EE8" originalValue="Früchtchen" pageId="null" pageNumber="199">Fruechtchen</normalizedToken>
am Grunde miteinander verwachsen
</emphasis>
(im Gebiet nur bei dieser Art so!), 
<emphasis id="33DCADC1858E88C9B1D43C1232871666" italics="true" pageId="null" pageNumber="199">5-6 mm lang, wovon ca. 2 mm auf den hakig gebogenen Schnabel entfallen</emphasis>
(bei den andern Arten Schnabel meist 
<emphasis id="214926DA44F6D6DCA2CDC9C58FD6D1A2" italics="true" pageId="null" pageNumber="199">
nicht 
<normalizedToken id="6876A685316B212E4DCD5097D5DA4403" originalValue="über" pageId="null" pageNumber="199">ueber</normalizedToken>
1 mm lang!
</emphasis>
). - 
<normalizedToken id="9CB210189D6909BDA735C3343BDEAB5B" originalValue="Blüte" pageId="null" pageNumber="199">Bluete</normalizedToken>
: 
<normalizedToken id="0EF118234C392B95A5306F42A3BF9592" originalValue="Früher" pageId="null" pageNumber="199">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="F78EE05F2D63522C027B35861D38561A" pageId="null" pageNumber="199">
<emphasis id="80738AF30732E29FB1FA65CB16E77E4D" italics="true" pageId="null" pageNumber="199">Zytologische Angaben. 2n = 52:</emphasis>
Material aus Schweden (Palmgren 1939), aus Japan (Harada 1956).
</paragraph>
<paragraph id="CA50DB7CA40078E0DE661917127E0BFE" pageId="null" pageNumber="199">
<emphasis id="F2CBA67D13430F6CB0A2F2E842A559D0" italics="true" pageId="null" pageNumber="199">Standort.</emphasis>
Kollin und montan, selten subalpin (Oberengadin). Stehende, 
<normalizedToken id="34C98212F4A2A41C1E85C882F272FD25" originalValue="nährstoffreiche" pageId="null" pageNumber="199">naehrstoffreiche</normalizedToken>
, 1-3 m tiefe 
<normalizedToken id="7750E50990783116B310CB91F791A5BC" originalValue="Gewässer" pageId="null" pageNumber="199">Gewaesser</normalizedToken>
.
</paragraph>
<paragraph id="0293A3C3B68EFD0A98707B99B969C34B" pageId="null" pageNumber="199">
<emphasis id="9E27848BF902BA2D2B4ECFFB88F32DA4" italics="true" pageId="null" pageNumber="199">Verbreitung. Eurasiatisch-nordamerikanische Pflanze:</emphasis>
Fast ganz 
<taxonomicName id="0E7A772CDE94A7A1062CC2921DFE4C3E" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="199" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
(ohne 
<normalizedToken id="C305D60014D0ED40C2EEA129100E4234" originalValue="nördliches" pageId="null" pageNumber="199">noerdliches</normalizedToken>
Skandinavien), Nordafrika, Ost- und 
<normalizedToken id="89D5F8CE7FD7B603A7C952490A297404" originalValue="Südafrika" pageId="null" pageNumber="199">Suedafrika</normalizedToken>
; in Asien von 50-60° NB 
<normalizedToken id="48624C1D42B82160142308264A3254A6" originalValue="südwärts" pageId="null" pageNumber="199">suedwaerts</normalizedToken>
bis Indien, Java, 
<normalizedToken id="0CD311DA809D006FC939B2ACB59EC7D2" originalValue="ostwärts" pageId="null" pageNumber="199">ostwaerts</normalizedToken>
bis Japan; Australien; in Nordamerika zwischen 35 und 50° NB. Verbreitungskarten von 
<normalizedToken id="461FEA76A43877AE1989DFE76EAF8F75" originalValue="Hultén" pageId="null" pageNumber="199">Hulten</normalizedToken>
(1962) und Meusel (1964). - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="94B947E0703D0AA9A151A0515E822AC2" originalValue="häufig" pageId="null" pageNumber="199">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
