<subSubSection id="517C17E7E4A46A4B67AB5CEE71CC610F" pageId="null" pageNumber="557" type="description">
<paragraph id="09E4B9477BE82225452352C7F3E1B13C" pageId="null" pageNumber="557">
Ausdauernd. 
<normalizedToken id="20C56E342D0323752C066EB60A0467B5" originalValue="Blätter" pageId="null" pageNumber="557">Blaetter</normalizedToken>
gefiedert, mit Endteilblatt und freien 
<normalizedToken id="B83CCB70FB6031EF5679DC0CE3B01392" originalValue="Nebenblättern" pageId="null" pageNumber="557">Nebenblaettern</normalizedToken>
; 
<normalizedToken id="CEEE689118082E35C2DEB060755F14B2" originalValue="Teilblätter" pageId="null" pageNumber="557">Teilblaetter</normalizedToken>
ganzrandig, oval bis lanzettlich. 
<normalizedToken id="31DBF0E2EDFC162ED80D0D551B9C9650" originalValue="Blüten" pageId="null" pageNumber="557">Blueten</normalizedToken>
in lockeren, aufrechten Trauben, die in den Achseln von 
<normalizedToken id="A865B006BA6F428AD240509176BEEDE7" originalValue="Stengelblättern" pageId="null" pageNumber="557">Stengelblaettern</normalizedToken>
stehen. 
<normalizedToken id="D153DCBE00B6EFB0EFFE185BD0A4DDA1" originalValue="Blütenstiele" pageId="null" pageNumber="557">Bluetenstiele</normalizedToken>
<normalizedToken id="92A20E72A6D3F47A358471A46F0811F4" originalValue="kürzer" pageId="null" pageNumber="557">kuerzer</normalizedToken>
als der Kelch. Kelch 
<normalizedToken id="915F7C5C6CE9A58324819A852E45D238" originalValue="glockenförmig" pageId="null" pageNumber="557">glockenfoermig</normalizedToken>
, mit 5 
<normalizedToken id="E1E5DF7FBEFB47E6F52D6261A1AC443F" originalValue="±" pageId="null" pageNumber="557">+/-</normalizedToken>
gleichen, 
<normalizedToken id="043712C695CB22B2B4F85748BFC0D358" originalValue="fadenförmigen" pageId="null" pageNumber="557">fadenfoermigen</normalizedToken>
<pageBreakToken id="4B5AD6EE38BC32702E789E47D1F04337" pageId="null" pageNumber="557">Zipfeln</pageBreakToken>
. Krone 
<normalizedToken id="01D2721E37FDBE88A53A8AABF8B2B7A1" originalValue="weiß" pageId="null" pageNumber="557">weiss</normalizedToken>
oder blauviolett; 
<emphasis id="F8BD3D4FE376945B3FA2C687161181E9" italics="true" pageId="null" pageNumber="557">
Fahne, 
<normalizedToken id="B22193E3D82C7856701024EB5A07D598" originalValue="Flügel" pageId="null" pageNumber="557">Fluegel</normalizedToken>
und Schiffchen fast gleich lang;
</emphasis>
Schiffchen nach 
<normalizedToken id="026C0417FB1C7171CDDD049DFD459DC7" originalValue="aufwärts" pageId="null" pageNumber="557">aufwaerts</normalizedToken>
gebogen, spitz. 
<emphasis id="D83C111E5DC4EFBA95EE804EF03B8D01" italics="true" pageId="null" pageNumber="557">
Alle 
<normalizedToken id="D4EE522115D372F579FF878F657F29C5" originalValue="Staubfäden" pageId="null" pageNumber="557">Staubfaeden</normalizedToken>
wenigstens im untern Teil verwachsen.
</emphasis>
Frucht im Kelch ungestielt, gerade, zylindrisch, bedeutend 
<normalizedToken id="83853B6F06BE42707CD2620D27EE09F0" originalValue="länger" pageId="null" pageNumber="557">laenger</normalizedToken>
als der Kelch, vielsamig.
</paragraph>
<paragraph id="46F0698CF92AFB8B58E30CCC9E16A7AC" pageId="null" pageNumber="557">
Die Gattung 
<taxonomicName id="8BBBD801217A389E5661576B35D43AA7" class="Magnoliopsida" family="Fabaceae" genus="Galega" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="557" phylum="Tracheophyta" rank="genus">
<emphasis id="64B0080263DD5630847AA5B4B435C8B9" italics="true" pageId="null" pageNumber="557">Galega</emphasis>
</taxonomicName>
<normalizedToken id="7D02BD6139B468B20138BFED8EF13133" originalValue="umfaßt" pageId="null" pageNumber="557">umfasst</normalizedToken>
<emphasis id="35E8A25D1934C9325A952AC306284E7E" italics="true" pageId="null" pageNumber="557">
4 Arten, die im 
<normalizedToken id="D8E5D53AA5893BB41A6A15B52E2B69CF" originalValue="östlichen" pageId="null" pageNumber="557">oestlichen</normalizedToken>
Mittelmeergebiet und in Westasien
</emphasis>
auftreten.
</paragraph>
