<subSubSection id="F9E34812D77B64EB897FC08611ACBC12" pageId="null" pageNumber="590" type="description">
<paragraph id="28F35F8E698FD9DFA8A1EEF4F5675330" pageId="null" pageNumber="590">
<emphasis id="7E54CA82A68102ED08E11FE8120E5CD2" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="E66B74E60B8614BF12194F8E9F4449F8" originalValue="Ausläufer" pageId="null" pageNumber="590">Auslaeufer</normalizedToken>
vorhanden
</emphasis>
, oft halb unterirdisch, 
<normalizedToken id="F4E7A5C2FF4034D7F466B38DD6B54F2B" originalValue="dünn" pageId="null" pageNumber="590">duenn</normalizedToken>
, lang, mit 
<normalizedToken id="E50D365E21352EE1A3ABE32E077770FF" originalValue="±" pageId="null" pageNumber="590">+/-</normalizedToken>
entfernt stehenden, 
<emphasis id="B58F7A09B53E83C95875B7FC798742ED" italics="true" pageId="null" pageNumber="590">
gegen die Spitze des 
<normalizedToken id="C57BDBDB8188DBD36C96A070E9BE82E2" originalValue="Ausläufers" pageId="null" pageNumber="590">Auslaeufers</normalizedToken>
<normalizedToken id="A33FC212D33D191E29010C5657D1F403" originalValue="größer" pageId="null" pageNumber="590">groesser</normalizedToken>
werdenden 
<normalizedToken id="31EED8EB2302C44881A61106B94BDB8F" originalValue="Blättern" pageId="null" pageNumber="590">Blaettern</normalizedToken>
. Stengel ohne einfache Haare
</emphasis>
, kahl, oder im obern Teil mit Sternhaaren und 
<normalizedToken id="E418811FFFBF5121CB62619AE5784AD4" originalValue="Drüsenhaaren" pageId="null" pageNumber="590">Druesenhaaren</normalizedToken>
. 
<emphasis id="8F02C05D7B77C5AC2F4A3DB5B7C3F1A8" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="440BBC675324A1C4FDDB0794F7018CE0" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
<normalizedToken id="B1747BBB6FCF823F0BD5C86D099324A4" originalValue="blaugrün" pageId="null" pageNumber="590">blaugruen</normalizedToken>
, meist stumpf, ohne Sternhaare.
</emphasis>
<normalizedToken id="C6F760DD2C5DDE5AF1D60865DF7436AA" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
stumpf, 
<emphasis id="BDD197AD00DC6AB55EF1058CC49398B4" italics="true" pageId="null" pageNumber="590">ohne oder nur mit wenigen einfachen Haaren.</emphasis>
- 
<normalizedToken id="2F2D7667D12A2157ADD583BBFF0757D9" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: 
<normalizedToken id="971AA636224EAA52934C253F36031970" originalValue="Später" pageId="null" pageNumber="590">Spaeter</normalizedToken>
<normalizedToken id="7D72C16FE6F3E5160C177AA29FA28AAC" originalValue="Frühling" pageId="null" pageNumber="590">Fruehling</normalizedToken>
, Sommer und 
<normalizedToken id="8162F7E268B29E93A777BE0DDCDA3C44" originalValue="früher" pageId="null" pageNumber="590">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="AF7533DE113A149EEAEE7D033C3FDFA7" pageId="null" pageNumber="590">
<emphasis id="DD572CCA7B85C358D2F74981D5683BA4" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="41B0CE7742931D6F63CEE9BC90105687" italics="true" pageId="null" pageNumber="590">18:</emphasis>
Fortpflanzung normal sexuell: Material aus botanischen 
<normalizedToken id="21C65E8978643C90D48963FCB34D4401" originalValue="Gärten" pageId="null" pageNumber="590">Gaerten</normalizedToken>
(Rosenberg 1907 1917, Gentcheff 1937a, Christoff 1942a), aus Skandinavien und 
<normalizedToken id="39CBD39C8D3A4B501E0BB2670A81BD7A" originalValue="Österreich" pageId="null" pageNumber="590">Oesterreich</normalizedToken>
(Turesson und Turesson 1960), von vielen Stellen aus Polen (Skalinska 1967, Kubien in Skalinska et al. 1968). 
<emphasis id="780EE40AB443666B9EA1E0A606C52B84" italics="true" pageId="null" pageNumber="590">2n</emphasis>
= 
<emphasis id="BE666C6E803FF724124FD3BF850F0FA0" italics="true" pageId="null" pageNumber="590">27:</emphasis>
Material (evtl. Bastard) aus botanischen 
<normalizedToken id="A08DF04587C615115716028B0A44CD8E" originalValue="Gärten" pageId="null" pageNumber="590">Gaerten</normalizedToken>
(Rosenberg 1917), aus Korsika (
<taxonomicName id="815C215A5E3C51C053C2F3A857F0ABC7" form="soleirolianum" pageId="null" pageNumber="590" rank="form">
f. 
<emphasis id="03F98CD3139E6CD9DF046BD0356C82F6" italics="true" pageId="null" pageNumber="590">soleirolianum</emphasis>
</taxonomicName>
A.-T. et Briq.) (Contandriopoulos 1957), aus Schweden (
<taxonomicName id="817EC705BAA8D3C9B3E6D5E12A90FC72" authority="Fries" authorityName="Fries" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="suecicum">
<emphasis id="16B2B1732A0D7C0957E2941BB2517018" italics="true" pageId="null" pageNumber="590">H. suecicum</emphasis>
Fries
</taxonomicName>
) (Turesson und Turesson 1963). 
<emphasis id="E8BDC09B4ABC9B92562698511CDF6A1E" italics="true" pageId="null" pageNumber="590">2n</emphasis>
= 
<emphasis id="730C796BCA6CFF155ACED711F217A197" italics="true" pageId="null" pageNumber="590">36:</emphasis>
Material aus Skandinavien; Fortpflanzung teilweise apomiktisch (Turesson und Turesson 1960).
</paragraph>
<paragraph id="0BC7B889F6E641FF881EE8022679B0D5" pageId="null" pageNumber="590">
<emphasis id="4F83B7CEDBCEF867D70A6C01DDDE30EF" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Kollin, montan und subalpin. 
<normalizedToken id="D01D309079DAEF6E73909FB7C8A0F1F8" originalValue="Mäßig" pageId="null" pageNumber="590">Maessig</normalizedToken>
feuchte, magere, meist kalkarme, humose, tonige 
<normalizedToken id="35E96BA713BB04A8CCAFD7AE6105E9C8" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
. Weiden, Wiesen, Riedwiesen, 
<normalizedToken id="FD998A451A2EB9A17F0F812C70041B58" originalValue="Wegränder" pageId="null" pageNumber="590">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="208BD50B35F2948C5891A94449C3290F" pageId="null" pageNumber="590">
<emphasis id="406968F44B9293B07265F9F923687C8D" italics="true" pageId="null" pageNumber="590">
Verbreitung. 
<normalizedToken id="62412C081A4F7526C65F9363BD11EEC9" originalValue="Europäische" pageId="null" pageNumber="590">Europaeische</normalizedToken>
Pflanze:
</emphasis>
West- und 
<normalizedToken id="E0808DE2449358F9B3A225175C15A390" originalValue="nordwärts" pageId="null" pageNumber="590">nordwaerts</normalizedToken>
bis 
<normalizedToken id="FE7D3A8125B54FBB9DE93261BAE55BB9" originalValue="Pyrenäen" pageId="null" pageNumber="590">Pyrenaeen</normalizedToken>
, Nordfrankreich, 
<normalizedToken id="73788FF7D5FABC1A31E87A082523D9A2" originalValue="Südskandinavien" pageId="null" pageNumber="590">Suedskandinavien</normalizedToken>
, Onegasee; 
<normalizedToken id="564359E223190A1DE0AA109F6FCC13C1" originalValue="süd-" pageId="null" pageNumber="590">sued-</normalizedToken>
und 
<normalizedToken id="0DEA0FCB10BA22EFD2E2DAA9DE96D969" originalValue="ostwärts" pageId="null" pageNumber="590">ostwaerts</normalizedToken>
bis 
<normalizedToken id="4F1E95C8A99C3089EC7BBA0E50CB3E04" originalValue="Süditalien" pageId="null" pageNumber="590">Sueditalien</normalizedToken>
, Bosnien, Bulgarien, Kaukasus (?). - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="B93749178776B88A77FBF0A2414F975E" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
