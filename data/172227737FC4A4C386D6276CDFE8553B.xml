<subSubSection id="088DC43A689AE49007FDEB6500E65E3B" pageId="null" pageNumber="290" type="vernacular_names">
<paragraph id="7BEB6602E0CF8EE96151BF764B73AC97" pageId="null" pageNumber="290">Krappartiges Labkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="798076B40E9536E6611C76B3F8D8B01A" pageId="null" pageNumber="290" type="description">
<paragraph id="C961CCE6D4F02778E6A21914C7F19DF1" pageId="null" pageNumber="290">
30-70 cm, seltener bis 120 cm hoch. Stengel unten mit kurzen, abstehenden Haaren oder kahl. 
<emphasis id="432A402E22D8B7C5E4885D8812DD431B" italics="true" pageId="null" pageNumber="290">
Die meisten 
<normalizedToken id="45E1153EA681197D3B2E7DD0EFA1885F" originalValue="Blätter" pageId="null" pageNumber="290">Blaetter</normalizedToken>
40
</emphasis>
- 
<emphasis id="BB31306892B640079ED96D1E5188501C" italics="true" pageId="null" pageNumber="290">80 mm lang und 9</emphasis>
- 
<emphasis id="20BB04DC69FCC2B2C5052C0360A74154" italics="true" pageId="null" pageNumber="290">20 mm breit und 3</emphasis>
- 
<emphasis id="FD58E14FC07EF05C73480263CE1B6B7A" italics="true" pageId="null" pageNumber="290">4</emphasis>
<normalizedToken id="3B84ECE64AEEE73C11B3FE7F64D8CEDB" originalValue="½" pageId="null" pageNumber="290">1/2</normalizedToken>
<emphasis id="1D50E1895DEC67CC11AA364A7828BDB4" italics="true" pageId="null" pageNumber="290">mal so lang wie breit</emphasis>
, zwischen den Nerven geadert. 
<normalizedToken id="E18A52FD36914600D174EE901A2ABA3E" originalValue="Blütenstand" pageId="null" pageNumber="290">Bluetenstand</normalizedToken>
breit 
<normalizedToken id="BD081C6A022FD032A427F9B935FEEE54" originalValue="eiförmig" pageId="null" pageNumber="290">eifoermig</normalizedToken>
. 
<normalizedToken id="7E376037A0773F8B4C9D5619C265996F" originalValue="Blütenstiele" pageId="null" pageNumber="290">Bluetenstiele</normalizedToken>
3-5 mm lang, 
<emphasis id="0C686045887C49C28997522242F3DA1D" italics="true" pageId="null" pageNumber="290">mit</emphasis>
<normalizedToken id="F76C570D0E503877483D42E6B73A0839" originalValue="±" pageId="null" pageNumber="290">+/-</normalizedToken>
<emphasis id="77886425843C7E8FB1A027BEE8766D79" italics="true" pageId="null" pageNumber="290">
<normalizedToken id="90CD912257BCA04F8EEE6C0FBFA18A2E" originalValue="blasenförmig" pageId="null" pageNumber="290">blasenfoermig</normalizedToken>
abgehobener Fruchtwand
</emphasis>
, 2,5-3,5 mm hoch, 
<emphasis id="8855EDED57CD67186F7D5668EF013C30" italics="true" pageId="null" pageNumber="290">fast immer kahl.</emphasis>
- 
<normalizedToken id="7D03C5F4C738C60692DB9A8CC3900E64" originalValue="Blüte" pageId="null" pageNumber="290">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="C0AFF9D7BAD788D7D884F21E63D6AF5D" originalValue="früher" pageId="null" pageNumber="290">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="81F29B6F891AE2DEDDFB95EC1B090DEB" pageId="null" pageNumber="290">
<emphasis id="71F3045ABD2F37D40355F02E9098E2B1" italics="true" pageId="null" pageNumber="290">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="54E1C16315A204E5457FE627F5757E0D" italics="true" pageId="null" pageNumber="290">66:</emphasis>
Material aus botanischem Garten (Homeyer 1936). 
<emphasis id="D705D7729356A43EBCC6A5F841B289EB" italics="true" pageId="null" pageNumber="290">2n ca. 132:</emphasis>
Material ohne Herkunftsangabe (Fagerlind 1934 1937).
</paragraph>
<paragraph id="939818DF8323C1EE1574FB9D965A0F4F" pageId="null" pageNumber="290">
<emphasis id="F5C37C4EB989BD04877ECE61B89177A6" italics="true" pageId="null" pageNumber="290">Standort.</emphasis>
Kollin. Feuchte, 
<normalizedToken id="7F72A873ED39DC0BA99B8E39645F723B" originalValue="nährstoffreiche" pageId="null" pageNumber="290">naehrstoffreiche</normalizedToken>
<normalizedToken id="0CF032623A653077FB4506E4E6B99E58" originalValue="Böden" pageId="null" pageNumber="290">Boeden</normalizedToken>
. 
<normalizedToken id="DF615E4E5E1A4090287144B007A99AE7" originalValue="Auenwaldränder" pageId="null" pageNumber="290">Auenwaldraender</normalizedToken>
, 
<normalizedToken id="93978CD8261C13EDD908F546CEA8A4A7" originalValue="Wegränder" pageId="null" pageNumber="290">Wegraender</normalizedToken>
, 
<normalizedToken id="ADE6E14AE6F60A9A556DF4EA148A3C46" originalValue="Gebüsche" pageId="null" pageNumber="290">Gebuesche</normalizedToken>
.
</paragraph>
<paragraph id="0EDB176E8745FB69689486F5278F65F3" pageId="null" pageNumber="290">
<emphasis id="7804F1D4D46C7218AF770E93FF80F438" italics="true" pageId="null" pageNumber="290">
Verbreitung. 
<normalizedToken id="433E23B162378A44F4FDFAFFA0DFF82F" originalValue="Osteuropäische" pageId="null" pageNumber="290">Osteuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="921B1BBB2C17D056508800C35792E164" originalValue="Niederösterreich" pageId="null" pageNumber="290">Niederoesterreich</normalizedToken>
und 
<normalizedToken id="86619F9D8C03C5DF7CC5A7BB62A70FF8" originalValue="Böhmen" pageId="null" pageNumber="290">Boehmen</normalizedToken>
bis Ural und Kaukasus. - Im Gebiet nur eingeschleppt, so bei Dietikon (
<normalizedToken id="87C0B9E6E02923144388ABDB83F59BD1" originalValue="Zürich" pageId="null" pageNumber="290">Zuerich</normalizedToken>
) und im Wallis (Monthey).
</paragraph>
</subSubSection>
