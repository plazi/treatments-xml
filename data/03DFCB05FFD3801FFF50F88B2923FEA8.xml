(
<figureCitation id="134D6696FFD3801BFF58F8E72B2CF88A" box="[159,272,1865,1891]" captionStart="FIGURES 7–11" captionStartId="4.[151,264,1905,1929]" captionTargetBox="[157,1418,330,1869]" captionTargetId="figure-75@4.[151,1435,309,1882]" captionTargetPageId="4" captionText="FIGURES 7–11. Euplocania wilsoni n. sp. Male. 7. Forewing. 8. Front view of head. 9. Epiproct and right paraproct. 10. Hypandrium. 11. Phallosome. Scales in mm." figureDoi="http://doi.org/10.5281/zenodo.6488310" httpUri="https://zenodo.org/record/6488310/files/figure.png" pageId="2" pageNumber="131">Figs 7–11</figureCitation>
