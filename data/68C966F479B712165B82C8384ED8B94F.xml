<subSubSection id="D15304EAFD195659F2735E2FA795FA86" pageId="null" pageNumber="632" type="description">
<paragraph id="9CA23BDEBA7E88F4ED522BD6A56960C2" pageId="null" pageNumber="632">
Unterscheidet sich nur durch wenige Merkmale an den 
<normalizedToken id="929E187ECA57E5BBFD88B404982D41B3" originalValue="Blüten" pageId="null" pageNumber="632">Blueten</normalizedToken>
von 
<taxonomicName id="1851E26056D53368006BB6D8DE6CCD2B" class="Liliopsida" family="Orchidaceae" genus="Orchis" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="632" phylum="Tracheophyta" rank="species" species="palustris">
<emphasis id="74122E3419610BD96BD917897EED19A7" italics="true" pageId="null" pageNumber="632">O. palustris</emphasis>
</taxonomicName>
(Nr. 12): 
<emphasis id="3B31FD0EFC53ACB607BE9ABA71A08F2B" italics="true" pageId="null" pageNumber="632">
Lippe 
<normalizedToken id="195BF3D2B725124C92FC319A650E0FA8" originalValue="sattelförmig" pageId="null" pageNumber="632">sattelfoermig</normalizedToken>
</emphasis>
, nicht flach, 
<emphasis id="62DF95A2736B87566D8648CB7811C0BF" italics="true" pageId="null" pageNumber="632">
Seitenabschnitte nach unten gebogen, Mittelabschnitt undeutlich oder klein, ausgerandet oder 
<normalizedToken id="1E3D267655FEB89510B7B063C10442E3" originalValue="gezähnt" pageId="null" pageNumber="632">gezaehnt</normalizedToken>
, gleich weit oder weniger weit nach vorn ragend als die breit abgerundeten Seitenabschnitte, so 
<normalizedToken id="94B49D42FD1C877D7622587BC4B5D247" originalValue="daβ" pageId="null" pageNumber="632">daβ</normalizedToken>
die Lippe
</emphasis>
(
<emphasis id="049FD741A1764B5C8C794C1030B44610" italics="true" pageId="null" pageNumber="632">wenn ausgebreitet</emphasis>
) 
<emphasis id="C3F0104D8D5EECB481440A4245E822AF" italics="true" pageId="null" pageNumber="632">
im 
<normalizedToken id="FC0A7E710A9F4AB5F57C9C246172FC66" originalValue="Umriβ" pageId="null" pageNumber="632">Umriβ</normalizedToken>
einem gleichseitigen Dreieck 
<normalizedToken id="2BCDD0FCBCA4A7072A4F8BA9FB3D375C" originalValue="ähnlich" pageId="null" pageNumber="632">aehnlich</normalizedToken>
ist; 
<taxonomicName id="C79B3DD899FD6866D29B2E7042DFCAC3" class="Liliopsida" family="Orchidaceae" genus="Sporn" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="632" phylum="Tracheophyta" rank="species" species="gegen">Sporn gegen</taxonomicName>
die Spitze hin oft verdickt oder
</emphasis>
auch abgeflacht, 
<emphasis id="A294B9ED5D7060A77CE58D6E3C9A0CE3" italics="true" pageId="null" pageNumber="632">an der Spitze gefurcht</emphasis>
, horizontal, oft etwas 
<normalizedToken id="476FF3BB540BE73378DE90B5E196B629" originalValue="aufwärts" pageId="null" pageNumber="632">aufwaerts</normalizedToken>
gebogen. - 
<normalizedToken id="0A96A995E302851AB2B3FCE14FB7397B" originalValue="Blüte" pageId="null" pageNumber="632">Bluete</normalizedToken>
: 
<normalizedToken id="6A78FF0FFD45A4303DC13DE586A7486F" originalValue="Später" pageId="null" pageNumber="632">Spaeter</normalizedToken>
<normalizedToken id="46288791060FAEF12F69F14A88E3DA37" originalValue="Frühling" pageId="null" pageNumber="632">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="8DD0D6224ADC5311FA1EA007F8F45444" pageId="null" pageNumber="632">
<emphasis id="538784DE549824F7AFE51E8D7425840B" italics="true" pageId="null" pageNumber="632">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="8E7ED0A3CCE6B68372DE97C2FD52F169" pageId="null" pageNumber="632">
<emphasis id="75BA17F299CD4FEDE19B5DDFC3AEB187" italics="true" pageId="null" pageNumber="632">Standort.</emphasis>
Kollin und montan. Saure, nasse 
<normalizedToken id="12AAC60D1F38DD887C513A8D728E4A3D" originalValue="Böden" pageId="null" pageNumber="632">Boeden</normalizedToken>
. Quellmoore, Sumpfwiesen.
</paragraph>
<paragraph id="8F6175C04B0A51C9D7291DA900A26662" pageId="null" pageNumber="632">
<emphasis id="CF47617C2DC2AED6ED41B881A634137F" italics="true" pageId="null" pageNumber="632">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="1479889566DF27760F20C98A3B3101C5" originalValue="Nordwärts" pageId="null" pageNumber="632">Nordwaerts</normalizedToken>
bis Kanalinsel Jersey, Flandern, Neuenburg und Tessin, Gardaseegebiet, Laibach, Balkanhalbinsel; ganzes Mediterrangebiet (eingeschlossen Nordwestafrika), 
<normalizedToken id="CF384BDD998B4B3AB6B19ACABF3CC75E" originalValue="ostwärts" pageId="null" pageNumber="632">ostwaerts</normalizedToken>
bis Kleinasien. Verbreitungskarte von Meusel (1964). - Im Gebiet: Savoyen und 
<normalizedToken id="381AA5E37339FE1B02027B8137037856" originalValue="Dép" pageId="null" pageNumber="632">Dep</normalizedToken>
. Ain, 
<normalizedToken id="00DF8D8D8B3E1002B55DCBC85B81FCC8" originalValue="früher" pageId="null" pageNumber="632">frueher</normalizedToken>
bis Genferseegebiet und Neuenburg (heute an den meisten Orten verschwunden), 
<normalizedToken id="3B1D83EA8792A4E26C798738D1026F0D" originalValue="südliches" pageId="null" pageNumber="632">suedliches</normalizedToken>
Tessin und angrenzende Gegenden, sehr selten.
</paragraph>
</subSubSection>
