<bibRefCitation id="1F7D4B5A6E35FFC3463DE394841EFF79" author="Balsamo, M. &amp; d'Hondt, J. L. &amp; Kisielewski, J. &amp; Pierboni, L." box="[855,1096,175,202]" pageId="4" pageNumber="353" pagination="85 - 91" refId="ref3591" refString="Balsamo, M., d'Hondt, J. L., Kisielewski, J., Pierboni, L. 2008. Global diversity of gastrotrichs (Gastrotricha) in fresh waters. Hydrobiologia, 595, 85 - 91." type="journal article" year="2008">Balsamo et al., 2008</bibRefCitation>
). Reported from Europe: 
<collectingCountry id="03FB763B6E35FFC34439E3EB81F0FF5A" box="[339,422,208,234]" name="France" pageId="4" pageNumber="353">France</collectingCountry>
, 
<collectingCountry id="03FB763B6E35FFC344DEE3F48273FF59" box="[436,549,207,233]" name="Germany" pageId="4" pageNumber="353">Germany</collectingCountry>
, 
<collectingCountry id="03FB763B6E35FFC3475EE3F48283FF59" box="[564,725,207,233]" name="United Kingdom" pageId="4" pageNumber="353">Great Britain</collectingCountry>
, 
<collectingCountry id="03FB763B6E35FFC34789E3F4834CFF59" box="[739,794,207,233]" name="Italy" pageId="4" pageNumber="353">Italy</collectingCountry>
, 
<collectingCountry id="03FB763B6E35FFC34643E3F48329FF59" box="[809,895,207,233]" name="Poland" pageId="4" pageNumber="353">Poland</collectingCountry>
, 
<collectingCountry id="03FB763B6E35FFC346E4E3F483ADFF59" box="[910,1019,207,233]" name="Romania" pageId="4" pageNumber="353">Romania</collectingCountry>
, 
<collectingCountry id="03FB763B6E35FFC34160E3F4840FFF59" box="[1034,1113,207,233]" name="Russia" pageId="4" pageNumber="353">Russia</collectingCountry>
, 
<collectingCountry id="03FB763B6E35FFC3410DE3F48492FF59" box="[1127,1220,207,233]" name="Sweden" pageId="4" pageNumber="353">Sweden</collectingCountry>
; 
