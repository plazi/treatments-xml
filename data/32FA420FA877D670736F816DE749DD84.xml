<subSubSection id="5FBF90B4DD9A3880933CE08B0CFA3491" pageId="null" pageNumber="607" type="description">
<paragraph id="C367A227F61713813A20FC8D44952ED6" pageId="null" pageNumber="607">
Unterscheidet sich von 
<taxonomicName id="46F5263743E4BF5132A000F5CBBCC5B0" class="Magnoliopsida" family="Fabaceae" genus="Lathyrus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="607" phylum="Tracheophyta" rank="species" species="bauhinii">
<emphasis id="725441835D25E298D991596AD5E58CEF" italics="true" pageId="null" pageNumber="607">
<authorityName id="1D14E2F0AF1AB1C436B0362C5343037B" pageId="null" pageNumber="607">L.</authorityName>
Bauhinii
</emphasis>
</taxonomicName>
(Nr. 12) durch folgende Merkmale: 
<normalizedToken id="C3D916692D18841AE677F6162D2517E7" originalValue="Teilblätter" pageId="null" pageNumber="607">Teilblaetter</normalizedToken>
unterseits meist mit einigen kurzen Haaren, oberseits 
<normalizedToken id="4CDB2F67848FDEE211202F89A9D36D00" originalValue="±" pageId="null" pageNumber="607">+/-</normalizedToken>
kahl; Krone 1,5-2 cm lang; 
<emphasis id="0D860329AD54B664F9A5EC58C8BF271D" italics="true" pageId="null" pageNumber="607">
Schiffchen stumpf und ausgerandet, an der untern, vordern Seite mit einem kurzen 
<normalizedToken id="3EAAC4BF9AAE28A57EB36AE6E93B9335" originalValue="Flügel" pageId="null" pageNumber="607">Fluegel</normalizedToken>
; Griffel vorn bis auf mehr als die doppelte Breite verbreitert.
</emphasis>
- 
<normalizedToken id="8FF7773F26DAC2225EF5FD0176F4492C" originalValue="Blüte" pageId="null" pageNumber="607">Bluete</normalizedToken>
: 
<normalizedToken id="369054D5100670E031306B39A8D282C9" originalValue="Später" pageId="null" pageNumber="607">Spaeter</normalizedToken>
<normalizedToken id="A5FEFB8102FAA6A4C7F899B69828413A" originalValue="Frühling" pageId="null" pageNumber="607">Fruehling</normalizedToken>
und 
<normalizedToken id="1DD6AAB73CE9CF2C281609CF17398339" originalValue="früher" pageId="null" pageNumber="607">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="59C85F2C43222BA44FDA39E2B7753E10" pageId="null" pageNumber="607">
<emphasis id="FCFB24898CA158D3CCF3D3326109042B" italics="true" pageId="null" pageNumber="607">Zytologische Angaben.</emphasis>
Siehe unter 
<taxonomicName id="C4EC86D8BEB6419985800BCAB69743F2" class="Magnoliopsida" family="Fabaceae" genus="Lathyrus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="607" phylum="Tracheophyta" rank="species" species="bauhinii">
<emphasis id="2B21A7CC4B3803CC2880A0AB413CD208" italics="true" pageId="null" pageNumber="607">
<authorityName id="E07B1E51D407598F70D452C30A2A0240" pageId="null" pageNumber="607">L.</authorityName>
Bauhinii
</emphasis>
</taxonomicName>
(Nr. 12).
</paragraph>
<paragraph id="77F270FFB4D16DAAC566DF70D880EADB" pageId="null" pageNumber="607">
<emphasis id="A9FAAE4E79559D7DC8460391C33B8DD8" italics="true" pageId="null" pageNumber="607">Standort.</emphasis>
Kollin und montan. Trockene Wiesen.
</paragraph>
<paragraph id="D4F45FB5D39D8F9B15B8366E284B8C79" pageId="null" pageNumber="607">
<emphasis id="C252D713DAEB3226CB876FE56334B93D" italics="true" pageId="null" pageNumber="607">
Verbreitung. 
<normalizedToken id="435BA001F958A86B70287BBECED254EA" originalValue="Südwesteuropäische" pageId="null" pageNumber="607">Suedwesteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Sierra de Chiva, 
<normalizedToken id="EBBAB0F3F34CEB77786F1202B712037F" originalValue="Pyrenäen" pageId="null" pageNumber="607">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="0B41D24CE167E581F9EA2ABBE0CA8E10" originalValue="Corbières" pageId="null" pageNumber="607">Corbieres</normalizedToken>
, Aude, Westalpen, Ligurien. - Im Gebiet: Comerseegebiet (unsichere Angaben von Bellagio).
</paragraph>
</subSubSection>
