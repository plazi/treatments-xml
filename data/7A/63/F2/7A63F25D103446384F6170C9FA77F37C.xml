<taxonomicName authorityName="Rauzer-Chernousova" authorityYear="1951" box="[1047,1220,426,450]" class="Fusulinata" family="Fusulinidae" genus="Beedeina" kingdom="Chromista" order="Fusulinida" pageId="21" pageNumber="546" phylum="Foraminifera" rank="species" species="timanica">
<emphasis box="[1047,1220,426,450]" italics="true" pageId="21" pageNumber="546">Beedeina timanica</emphasis>
</taxonomicName>
(
<figureCitation box="[1235,1347,426,450]" captionStart="FIG" captionStartId="25.[132,143,1963,1980]" captionTargetId="figure-20@26.[219,794,763,1320]" captionTargetPageId="26" captionText="FIG. 14. — Thin-section photomicrographs of the fusulinid assemblages of the Yassıpınar (YS), Bademli (BS) and GÖlbelen (GS) sections: A-D, Beedeina schellwieni (Staff in Schellwien &amp; Staff, 1912); A, axial section, 16B40A.09, BS; B, axial section, 16B40C.11, BS; C, axial section, 18G41.15, GS; D, oblique section, 18G45.07, GS; E, F, Beedeina tauridiana Akba ¸s, n. sp.; E, axial section, 16B41.07 (Holotype), BS; F, axial section, 16B41.08, BS; G, detailed view of the wall" figureDoi="http://doi.org/10.5281/zenodo.6677693" httpUri="https://zenodo.org/record/6677693/files/figure.png" pageId="21" pageNumber="546">Fig. 14H, I</figureCitation>
