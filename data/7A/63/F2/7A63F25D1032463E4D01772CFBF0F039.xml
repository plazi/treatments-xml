; 
<bibRefCitation author="VILLA E." box="[1247,1369,1618,1645]" pageId="19" pageNumber="544" refId="ref25629" refString="VILLA E. 1995. - Fusulinaceos Carboniferos del Este de Asturias (N de Espana). Universite Claude Bernard, Lyon, 261 p. (Biostratigraphie du Paleozoique; 13)." type="book" year="1995">Villa 1995</bibRefCitation>
