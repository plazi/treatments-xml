<taxonomicName authorityName="Putrya &amp; Leontovich" authorityYear="1948" box="[1127,1252,1714,1740]" class="Fusulinata" family="Profusulinellidae" genus="Profusulinella" kingdom="Chromista" order="Fusulinida" pageId="19" pageNumber="544" phylum="Foraminifera" rank="species" species="skelnevatica">
