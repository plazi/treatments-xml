<taxonomicName authority="Akbas" authorityName="Akbas" authorityYear="2022" class="Fusulinata" family="Fusulinellidae" genus="Praefusulinella" kingdom="Chromista" order="Fusulinida" pageId="25" pageNumber="550" phylum="Foraminifera" rank="species" species="tekini" status="n. gen., n. sp.">
