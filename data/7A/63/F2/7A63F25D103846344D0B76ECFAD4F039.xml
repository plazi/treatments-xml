<subSubSection pageId="25" pageNumber="550" type="diagnosis">
<paragraph blockId="25.[811,1455,447,524]" pageId="25" pageNumber="550">
DIAGNOSIS. — A species of 
<taxonomicName authority="Akbas" authorityName="Akbas" authorityYear="2022" box="[1079,1285,447,471]" class="Fusulinata" family="Fusulinellidae" genus="Praefusulinella" kingdom="Chromista" order="Fusulinida" pageId="25" pageNumber="550" phylum="Foraminifera" rank="genus" status="n. gen.">
<emphasis box="[1079,1217,447,471]" italics="true" pageId="25" pageNumber="550">Praefusulinella</emphasis>
