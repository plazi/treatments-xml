<taxonomicName authorityName="Rauzer-Chernousova" authorityYear="1951" box="[435,529,420,444]" class="Fusulinata" family="Aljutovellidae" genus="Aljutovella" kingdom="Chromista" order="Fusulinida" pageId="21" pageNumber="546" phylum="Foraminifera" rank="genus">
