<date id="ED301042FA72D421FB8D5C92A83AFA5E" box="[1024,1129,1466,1488]" pageId="4" pageNumber="55" value="2012-05-20">20.05.2012</date>
, 
<specimenCount id="8F88FD0BFA72D421FBFF5C92A8C1FA5E" box="[1138,1170,1465,1488]" pageId="4" pageNumber="55" type="female">1 ♀</specimenCount>
