<date id="ED301042FA72D421FE825CFDAD2BFA65" box="[271,376,1493,1515]" pageId="4" pageNumber="55" value="2012-05-23">23.05.2012</date>
, 1 ♂, 
<specimenCount id="8F88FD0BFA72D421FE3E5CFDAD86FA65" box="[435,469,1492,1515]" pageId="4" pageNumber="55" type="female">2 ♀</specimenCount>
