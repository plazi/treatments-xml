<taxonomicName id="4C6D4D5EEF903AF4FF1AFE11FE3BFE38" authority="Stock, 1967" authorityName="Stock" authorityYear="1967" box="[223,510,479,505]" class="Maxillopoda" family="Notodelphyidae" genus="Periproctia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="193" pageNumber="194" phylum="Arthropoda" rank="genus">
