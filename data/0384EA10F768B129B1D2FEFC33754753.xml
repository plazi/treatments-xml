<subSubSection id="C337088DF768B129B182FE903724415B" pageId="29" pageNumber="550" type="description">
<paragraph id="8B925B06F768B129B182FE9031E44293" blockId="29.[151,1437,330,1041]" pageId="29" pageNumber="550">
CURRENT STATUS: Synonym of 
<taxonomicName id="4C2D2085F768B129B36DFE9031F142CB" authority="Swainson, 1838" authorityName="Swainson" authorityYear="1838" box="[552,968,367,393]" class="Aves" family="Zosteropidae" genus="Zosterops" higherTaxonomySource="GBIF" kingdom="Animalia" order="Passeriformes" pageId="29" pageNumber="550" phylum="Chordata" rank="species" species="pallidus">
<emphasis id="B9598714F768B129B36DFE90313842CB" box="[552,769,367,393]" italics="true" pageId="29" pageNumber="550">Zosterops pallidus</emphasis>
Swainson, 1838
</taxonomicName>
; 
<taxonomicName id="4C2D2085F768B129B290FE90332442EF" authority="(Dickinson &amp; Christidis 2014: 520)" baseAuthorityName="Dickinson &amp; Christidis" baseAuthorityPageNumber="520" baseAuthorityYear="2014" class="Aves" family="Zosteropidae" higherTaxonomySource="GBIF" kingdom="Animalia" order="Passeriformes" pageId="29" pageNumber="550" phylum="Chordata" rank="family">
Zosteropidae (
<bibRefCitation id="EFBC26F7F768B129B53BFE90332D42EF" author="Dickinson, E. C. &amp; Christidis, L." pageId="29" pageNumber="550" refId="ref28395" refString="Dickinson, E. C. &amp; Christidis, L. (2014) The Howard and Moore Complete Checklist of the Birds of the World. 4 th Edition. Vol. 2. Passerines. Aves Press, Eastbourne, 752 pp." type="book" year="2014">Dickinson &amp; Christidis 2014: 520</bibRefCitation>
)
</taxonomicName>
. Sometimes recognized as a subspecies (not supported by DNA) under the name 
<taxonomicName id="4C2D2085F768B129B5B4FE6C30324293" authority="Hartlaub, 1865" authorityName="Hartlaub" authorityYear="1865" class="Aves" family="Zosteropidae" genus="Zosterops" higherTaxonomySource="GBIF" kingdom="Animalia" order="Passeriformes" pageId="29" pageNumber="550" phylum="Chordata" rank="subSpecies" species="pallidus" subSpecies="sundevalli">
<emphasis id="B9598714F768B129B5B4FE6C33684293" italics="true" pageId="29" pageNumber="550">Zosterops pallidus sundevalli</emphasis>
<bibRefCitation id="EFBC26F7F768B129B01DFE4830324293" author="Hartlaub, G." box="[344,523,438,465]" pageId="29" pageNumber="550" pagination="1 - 30" refId="ref28842" refString="Hartlaub, G. (1865) Monographischer Versuch uber die Gattung Zosterops. Journal fur Ornithologie, 13 (73), 1 - 30. https: // doi. org / 10.1007 / BF 02261150" type="journal article" year="1865">Hartlaub, 1865</bibRefCitation>
</taxonomicName>
; see below under comments for details.
</paragraph>
<paragraph id="8B925B06F768B129B182FE243724415B" blockId="29.[151,1437,330,1041]" pageId="29" pageNumber="550">
STATUS REFERENCE: 
<bibRefCitation id="EFBC26F7F768B129B0D9FE24312F42B7" author="Dickinson, E. C. &amp; Christidis, L." box="[412,790,474,501]" pageId="29" pageNumber="550" refId="ref28395" refString="Dickinson, E. C. &amp; Christidis, L. (2014) The Howard and Moore Complete Checklist of the Birds of the World. 4 th Edition. Vol. 2. Passerines. Aves Press, Eastbourne, 752 pp." type="book" year="2014">Dickinson &amp; Christidis 2014: 520</bibRefCitation>
and 
<bibRefCitation id="EFBC26F7F768B129B208FE24367C42B7" author="Bowie, R. C. K." box="[845,1093,474,501]" pageId="29" pageNumber="550" pagination="823 - 824" refId="ref28062" refString="Bowie, R. C. K. (2005) Zosterops lateralis. In: Hockey, P. A. R., Dean, W. R. J. &amp; Ryan, P. G. (Eds.), Roberts' Birds of Southern Africa, 7 th edition. John Voelcker Bird Book Fund, Cape Town, pp. 823 - 824." type="book chapter" year="2005">Bowie 2005: 823–824</bibRefCitation>
(includes 
<taxonomicName id="4C2D2085F768B129B5FCFE2432F6415B" authority="Hartlaub, 1865" authorityName="Hartlaub" authorityYear="1865" class="Aves" family="Zosteropidae" genus="Zosterops" higherTaxonomySource="GBIF" kingdom="Animalia" order="Passeriformes" pageId="29" pageNumber="550" phylum="Chordata" rank="species" species="sundevalli">
<emphasis id="B9598714F768B129B5FCFE24371542B7" box="[1209,1324,475,501]" italics="true" pageId="29" pageNumber="550">sundevalli</emphasis>
<bibRefCitation id="EFBC26F7F768B129B476FE2432F6415B" author="Hartlaub, G." pageId="29" pageNumber="550" pagination="1 - 30" refId="ref28842" refString="Hartlaub, G. (1865) Monographischer Versuch uber die Gattung Zosterops. Journal fur Ornithologie, 13 (73), 1 - 30. https: // doi. org / 10.1007 / BF 02261150" type="journal article" year="1865">Hartlaub, 1865</bibRefCitation>
</taxonomicName>
(see 
<bibRefCitation id="EFBC26F7F768B129B04FFE003032415B" author="Gyldenstolpe, N." box="[266,523,510,537]" pageId="29" pageNumber="550" pagination="1 - 116" refId="ref28755" refString="Gyldenstolpe, N. (1926) Types of birds in the Royal Natural History Museum in Stockholm. Arkiv f or Zoologi, 19, 1 - 116." type="journal article" year="1926">Gyldenstolpe 1926: 35</bibRefCitation>
, 
<emphasis id="B9598714F768B129B352FE0030AA415B" box="[535,659,511,537]" italics="true" pageId="29" pageNumber="550">deserticola</emphasis>
Reichenow, 1905 and 
<emphasis id="B9598714F768B129B2D6FE00366C415B" box="[915,1109,511,537]" italics="true" pageId="29" pageNumber="550">haigamchabensis</emphasis>
Bradfield, 1944).
</paragraph>
</subSubSection>
<subSubSection id="C337088DF768B129B182FDDC31964057" pageId="29" pageNumber="550" type="materials_examined">
<paragraph id="8B925B06F768B129B182FDDC371141B0" blockId="29.[151,1437,330,1041]" pageId="29" pageNumber="550">
<materialsCitation id="3B45515BF768B129B182FDDC371D41B0" ID-GBIF-Occurrence="3766756392" collectingDate="1843-08-05" collectionCode="TYPE" location="Vaal River" municipality="Vaal River" pageId="29" pageNumber="550" specimenCount="1" stateProvince="Berlin" typeStatus="lectotype">
<collectionCode id="ED3CC3C3F768B129B182FDDC32C24178" box="[199,251,547,573]" pageId="29" pageNumber="550">TYPE</collectionCode>
MATERIAL: We can find no indication in Sundevall’s original description text that he had more than a single specimen at hand, but according to his acquisition catalogue he apparently had three available. 
<bibRefCitation id="EFBC26F7F768B129B445FDB8332B41C7" author="Gyldenstolpe, N." pageId="29" pageNumber="550" pagination="1 - 116" refId="ref28755" refString="Gyldenstolpe, N. (1926) Types of birds in the Royal Natural History Museum in Stockholm. Arkiv f or Zoologi, 19, 1 - 116." type="journal article" year="1926">Gyldenstolpe (1926: 35)</bibRefCitation>
refers to NRM 568713 [6678] as a “type”; we treat this as a 
<typeStatus id="5496E5A4F768B129B294FD94360441C7" box="[977,1085,619,645]" pageId="29" pageNumber="550">lectotype</typeStatus>
designation of this adult male collected 
<date id="FF937DC6F768B129B042FD71338941EB" box="[263,432,654,681]" pageId="29" pageNumber="550" value="1843-08-05">
<collectingDate id="EFD7842EF768B129B042FD71338941EB" box="[263,432,654,681]" pageId="29" pageNumber="550" value="1843-08-05">5 August 1843</collectingDate>
</date>
north of the 
<collectingMunicipality id="6BF6C17CF768B129B307FD7030F941EB" box="[578,704,655,681]" pageId="29" pageNumber="550">Vaal River</collectingMunicipality>
. The 
<specimenCount id="9D2B908FF768B129B3B9FD7031E141EB" box="[764,984,655,681]" pageId="29" pageNumber="550" type="generic" typeStatus="paralectotypes">two paralectotypes</specimenCount>
are: NRM 555448 [6679], a study skin of an adult female collected 
<date id="FF937DC6F768B129B09AFD4D30B1418F" box="[479,648,690,717]" pageId="29" pageNumber="550" value="1843-08-05">
<collectingDate id="EFD7842EF768B129B09AFD4D30B1418F" box="[479,648,690,717]" pageId="29" pageNumber="550" value="1843-08-05">5 August 1843</collectingDate>
</date>
north of the 
<location id="8EF20DDDF768B129B25EFD4C31A3418F" LSID="urn:lsid:plazi:treatment:0384EA10F768B129B1D2FEFC33754753:8EF20DDDF768B129B25EFD4C31A3418F" box="[795,922,691,717]" municipality="Vaal River" name="Vaal River" pageId="29" pageNumber="550" stateProvince="Berlin">Vaal River</location>
; and a specimen [6677] of unknown sex and only noted as “Caffr. Inf.” sent on exchange to 
<collectingRegion id="49E995E4F768B129B384FD28313241B3" box="[705,779,727,753]" country="Germany" name="Berlin" pageId="29" pageNumber="550">Berlin</collectingRegion>
in 1853 (but not found in the ZMB database)
</materialsCitation>
.
</paragraph>
<paragraph id="8B925B06F768B129B182FD0431964057" blockId="29.[151,1437,330,1041]" box="[199,943,763,789]" pageId="29" pageNumber="550">
