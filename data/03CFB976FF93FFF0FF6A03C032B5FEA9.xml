<figureCitation id="135D14E5FF93FFF1FD8A03DF31F9FE29" box="[582,643,431,458]" captionStart="Fig" captionStartId="4.[167,200,1713,1735]" captionTargetBox="[220,1179,724,1681]" captionTargetId="figure-208@4.[699,1180,1073,1424]" captionTargetPageId="4" captionText="Fig. 4. Epipharynx of Hypera species: a — H. miles; b — H. transsylvanica, general view; c — the same, apical excision; d — Limobius borealis. Scale bars 10 μm." figureDoi="http://doi.org/10.5281/zenodo.6453269" httpUri="https://zenodo.org/record/6453269/files/figure.png" pageId="4" pageNumber="349">fig. 4</figureCitation>
