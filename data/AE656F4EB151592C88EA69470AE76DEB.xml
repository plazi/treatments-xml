<subSubSection id="615414A9AD90D3BEFD4F6DFA31221F73" pageId="0" pageNumber="33" type="description">
<paragraph id="6C5947654BE705C30171FF734B244C98" pageId="0" pageNumber="33">Measurements.</paragraph>
<paragraph id="2555A48225242AA037F39BF417619504" pageId="0" pageNumber="33">
Valve length 308 
<normalizedToken id="53441CBD49B8CA3539A64AB9FD2C63F9" originalValue="μm">μm</normalizedToken>
