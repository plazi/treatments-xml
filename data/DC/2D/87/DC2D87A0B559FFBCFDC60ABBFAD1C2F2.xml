<emphasis bold="true" box="[1146,1301,1182,1209]" italics="true" pageId="2" pageNumber="82">S. celebensis</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[1308,1399,1183,1209]" pageId="2" pageNumber="82" rank="species">sp. nov.</taxonomicNameLabel>
</keyLead>
</paragraph>
