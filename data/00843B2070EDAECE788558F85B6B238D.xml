<subSubSection id="060F3CA0DE3BF710B6E860C4642A032A" pageId="null" pageNumber="415" type="description">
<paragraph id="41FD135A97CF6E496A3761C27B2F2495" pageId="null" pageNumber="415">
Unterscheidet sich von 
<taxonomicName id="18AB4FA924A7D53D6A8E062C473B8377" class="Magnoliopsida" family="Asteraceae" genus="Cirsium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="415" phylum="Tracheophyta" rank="species" species="eriophorum">
<emphasis id="057E75A9B8A7A0D7B6B36124AA0B1BFF" italics="true" pageId="null" pageNumber="415">C. eriophorum</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="85DFD8D97AE3D878DFA475B372FE5917" italics="true" pageId="null" pageNumber="415">
<normalizedToken id="48B7AC31D49EA973999D2800BCCC6D26" originalValue="Blätter" pageId="null" pageNumber="415">Blaetter</normalizedToken>
am Stengel herablaufend und so der Stengel von stachligen 
<normalizedToken id="3665D53922AE591625106E9F0089AC12" originalValue="Blatträndern" pageId="null" pageNumber="415">Blattraendern</normalizedToken>
<normalizedToken id="9C10A3DAA759B4A95F3D1DAE61814B18" originalValue="geflügelt" pageId="null" pageNumber="415">gefluegelt</normalizedToken>
;
</emphasis>
<normalizedToken id="788262B29FD4DB25F10F5BCCCED22B39" originalValue="Hülle" pageId="null" pageNumber="415">Huelle</normalizedToken>
der 
<normalizedToken id="C3FB8E18CDDC408B626A0F2B98E05B61" originalValue="blühenden" pageId="null" pageNumber="415">bluehenden</normalizedToken>
<normalizedToken id="8F9D62389B35170ECF14573501F5CF94" originalValue="Köpfe" pageId="null" pageNumber="415">Koepfe</normalizedToken>
3-5 cm 
<pageBreakToken id="04655ADE39F2DE8099E3759422A462B1" pageId="null" pageNumber="415">lang</pageBreakToken>
, 
<emphasis id="9CCF31D4C9D4B6C1C1DB5F9A33DE9899" italics="true" pageId="null" pageNumber="415">mir zerstreut spinnwebig behaart;</emphasis>
<normalizedToken id="6F9EE2FF982F36096C5D8F42F1B4BED9" originalValue="Hüllblätter" pageId="null" pageNumber="415">Huellblaetter</normalizedToken>
vor dem Stachel nicht verbreitert; Kronen 2,5-3,5 cm lang, hellpurpurn; 
<normalizedToken id="05623F900509F061CEAC9158533DFA1D" originalValue="Früchte" pageId="null" pageNumber="415">Fruechte</normalizedToken>
3-4 mm lang. - 
<normalizedToken id="FDB4A3F075859194E0413C8945268700" originalValue="Blüte" pageId="null" pageNumber="415">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="BC48764E00B7677626DA73546DD0F513" pageId="null" pageNumber="415">
<emphasis id="71432DEA316C7E4C7C22D12643146B1F" italics="true" pageId="null" pageNumber="415">Zytologische Angaben. 2n</emphasis>
= 68
<emphasis id="1383C57F4CA2FDA4E46EA91DE3041407" italics="true" pageId="null" pageNumber="415">:</emphasis>
Material aus 
<normalizedToken id="4EB8A576099A47F76CE54B413246ABC4" originalValue="Rußland" pageId="null" pageNumber="415">Russland</normalizedToken>
(Poddubnaja-Arnoldi 1931), aus Skandinavien (
<normalizedToken id="FA8444BB8DD47BE28F0B9B20BBE5C465" originalValue="Löve" pageId="null" pageNumber="415">Loeve</normalizedToken>
und 
<normalizedToken id="6B06F958CC5759CBC69BA122AFABC314" originalValue="Löve" pageId="null" pageNumber="415">Loeve</normalizedToken>
1944b), aus Polen (Czapik 1958), aus Kanada (Moore und Frankton 1962, Taylor und Mulligan 1968), aus Holland (Gadella und Kliphuis 1966), aus der Slowakei (Index Slov. 1967).
</paragraph>
<paragraph id="CE79B4411D173D3ADE05E60C2567C57B" pageId="null" pageNumber="415">
<emphasis id="D6D6ADE1FE5ECD50F517167C7CAE9815" italics="true" pageId="null" pageNumber="415">Standort.</emphasis>
Kollin und montan, seltener subalpin. Frische, 
<normalizedToken id="21985B5D778344086CA6A2554A00A645" originalValue="nährstoffreiche" pageId="null" pageNumber="415">naehrstoffreiche</normalizedToken>
, vor allem stickstoffreiche, humose, lehmige 
<normalizedToken id="2B215EA38158B045B12BCA6AC359553A" originalValue="Böden" pageId="null" pageNumber="415">Boeden</normalizedToken>
. 
<normalizedToken id="1E5185AB2E1F62C355B3D4DD07998AFE" originalValue="Schuttplätze" pageId="null" pageNumber="415">Schuttplaetze</normalizedToken>
, 
<normalizedToken id="7C49578C07E4CA850FA5EF03ED4E3B35" originalValue="Wegränder" pageId="null" pageNumber="415">Wegraender</normalizedToken>
, 
<normalizedToken id="6B82204541976143EB1D99BD3ECCB36E" originalValue="Waldschläge" pageId="null" pageNumber="415">Waldschlaege</normalizedToken>
.
</paragraph>
<paragraph id="789BE661E43AECF67EFD5B9C6A930909" pageId="null" pageNumber="415">
<emphasis id="B69437D017064791FEE4DA3BB87F7B07" italics="true" pageId="null" pageNumber="415">Verbreitung. Eurasiatische Pflanze:</emphasis>
<normalizedToken id="774E45A0FE5B1274C8AE6AAA0534D264" originalValue="Nordwärts" pageId="null" pageNumber="415">Nordwaerts</normalizedToken>
bis zu den Shetlandinseln, 
<normalizedToken id="4892587172D4373772329ED7DECDCBB7" originalValue="Südskandinavien" pageId="null" pageNumber="415">Suedskandinavien</normalizedToken>
; 
<normalizedToken id="7CF041C7FEDFDBC96B5354459EB85D3C" originalValue="ostwärts" pageId="null" pageNumber="415">ostwaerts</normalizedToken>
bis Turkestan; 
<normalizedToken id="4B3310A326A97C16FFAD4E89C6463C8F" originalValue="südwärts" pageId="null" pageNumber="415">suedwaerts</normalizedToken>
bis Zypern, Sizilien, Atlas; in Amerika eingeschleppt. - Im Gebiet verbreitet und 
<normalizedToken id="7A4BF9F9FB4A2FA0E268765674675FAF" originalValue="häufig" pageId="null" pageNumber="415">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="A2D617F15F70BDC175F66C184480551F" pageId="null" pageNumber="415">
<emphasis id="4ABB5D0D31000786B0CD3B61476B3729" italics="true" pageId="null" pageNumber="415">Bemerkungen.</emphasis>
Eine Sippe (
<taxonomicName id="8274DA98C0717A59D761A2A01100AEA3" authority="Tausch" authorityName="Tausch" class="Magnoliopsida" family="Asteraceae" genus="Cirsium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="415" phylum="Tracheophyta" rank="species" species="silvaticum">
<emphasis id="36FB44029BC9B2E542EF90FA05BEF1C8" italics="true" pageId="null" pageNumber="415">C. silvaticum</emphasis>
Tausch
</taxonomicName>
), die sich durch weichere, 
<emphasis id="1E836B07B88433EF13DC322F2D73EBE6" italics="true" pageId="null" pageNumber="415">
unterseits meist 
<normalizedToken id="01614ACE74E4190AFDB31EDCD0F1C30E" originalValue="weißfilzige" pageId="null" pageNumber="415">weissfilzige</normalizedToken>
<normalizedToken id="23D41A48BE4CF96852120D94123EC0F8" originalValue="Blätter" pageId="null" pageNumber="415">Blaetter</normalizedToken>
</emphasis>
, kleinere 
<normalizedToken id="C095C89BE7BAC32A0F0AAF9E7FC13CCF" originalValue="Früchte" pageId="null" pageNumber="415">Fruechte</normalizedToken>
(bis 3,5 mm lang) und 
<normalizedToken id="D75C384A608F33EBFCBB3A465C5F839A" originalValue="frühere" pageId="null" pageNumber="415">fruehere</normalizedToken>
<normalizedToken id="0DB888678919B773D5407C17F788E566" originalValue="Blütezeit" pageId="null" pageNumber="415">Bluetezeit</normalizedToken>
auszeichnet und in Waldlichtungen gedeiht, 
<normalizedToken id="03F8BD1157A4E1C909224375F9A6FD7A" originalValue="muß" pageId="null" pageNumber="415">muss</normalizedToken>
auf den systematischen Wert 
<normalizedToken id="4AFC22FC5E076E14F1F94A5CFA7B042D" originalValue="geprüft" pageId="null" pageNumber="415">geprueft</normalizedToken>
werden.
</paragraph>
</subSubSection>
