<specimenCount id="9D6BFD54EF713A15FEBCFE11FE66FE38" box="[377,419,479,505]" pageId="32" pageNumber="33" type="female">1 ♀</specimenCount>
, 2 ♂♂ (MNHN-IU-2017-2160) and 1 dissected 
<specimenCount id="9D6BFD54EF713A15FE8AFDCFFEA1FDDA" box="[335,356,513,539]" pageId="32" pageNumber="33">♀</specimenCount>
(figured) from 
<taxonomicName id="4C6D4D5EEF713A15FDEDFDCFFEF9FDFF" authority="(Savigny, 1816)" baseAuthorityName="Savigny" baseAuthorityYear="1816" class="Ascidiacea" family="Styelidae" genus="Polycarpa" kingdom="Animalia" order="Pleurogona" pageId="32" pageNumber="33" phylum="Chordata" rank="species" species="pomaria">
