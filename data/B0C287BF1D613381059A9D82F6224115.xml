<subSubSection id="5FFAED6CF87535D8A695F634D333A3CB" pageId="null" pageNumber="715" type="description">
<paragraph id="E776DD22EDA8F317388FC645EE2C6513" pageId="null" pageNumber="715">
Niedrige 
<normalizedToken id="2EA3E7DDC08523586BE3AF9B9A205E48" originalValue="Kräuter" pageId="null" pageNumber="715">Kraeuter</normalizedToken>
mit 
<emphasis id="9ACF756BB3E8D2476F0A56A80EA13F0A" italics="true" pageId="null" pageNumber="715">kriechenden Stengeln;</emphasis>
am Grunde 
<normalizedToken id="44FBBD4E36C36AB7C3A6A1806336A71A" originalValue="schuppenförmige" pageId="null" pageNumber="715">schuppenfoermige</normalizedToken>
<normalizedToken id="B48B7A4F43CE5ED0CB5E3421C2B7DA9A" originalValue="Niederblätter" pageId="null" pageNumber="715">Niederblaetter</normalizedToken>
vorhanden. 
<normalizedToken id="B63D20AD13F860DEDD835556F938BAA0" originalValue="Blätter" pageId="null" pageNumber="715">Blaetter</normalizedToken>
<normalizedToken id="444E1A8ABB987E25FF2117FA3A26B8A2" originalValue="herzförmig" pageId="null" pageNumber="715">herzfoermig</normalizedToken>
, 
<normalizedToken id="67F7A06D8F90697C3E2A9AAE5571FB96" originalValue="nierenförmig" pageId="null" pageNumber="715">nierenfoermig</normalizedToken>
oder 
<normalizedToken id="17B1DE0EDCE387983FD8AE2DD3DD35D5" originalValue="pfeilförmig" pageId="null" pageNumber="715">pfeilfoermig</normalizedToken>
, lederig, 
<normalizedToken id="58E935BD9271DB39C98A38CC9BCDBB11" originalValue="glänzend" pageId="null" pageNumber="715">glaenzend</normalizedToken>
, kahl oder behaart; Blattstiel lang. 
<normalizedToken id="57049F0BF9E0C3AFEAA13BF0D12F3DF7" originalValue="Blüten" pageId="null" pageNumber="715">Blueten</normalizedToken>
einzeln, 
<emphasis id="B4EB4FA181DA9C6CF53276629C513D41" italics="true" pageId="null" pageNumber="715">
<normalizedToken id="19831757E928B083A28C3CE564CF9060" originalValue="endständig" pageId="null" pageNumber="715">endstaendig</normalizedToken>
</emphasis>
, kurz gestielt, 
<normalizedToken id="DAB81AF6CF60A16097E54871D6DEB3F7" originalValue="häutig" pageId="null" pageNumber="715">haeutig</normalizedToken>
bis fleischig, braun bis dunkelpurpurn; 
<emphasis id="B606E346CD1C541AFEAEE7EABAA06ECA" italics="true" pageId="null" pageNumber="715">Perigon aktinomorph, 3teilig</emphasis>
, glockig, unterhalb der freien Perigonabschnitte verengt. 
<normalizedToken id="B8B4084EBAFCB50F0B66394D3E4D27F1" originalValue="Staubblätter" pageId="null" pageNumber="715">Staubblaetter</normalizedToken>
12, frei oder am Grunde nur wenig verwachsen. Griffel frei oder zu einer 
<normalizedToken id="D51B1ADABBE225CF1CE6CC91D559CF57" originalValue="Säule" pageId="null" pageNumber="715">Saeule</normalizedToken>
verwachsen. Fruchtknoten 6 
<normalizedToken id="25ABD0BDF42E356B957958C837DF89E8" originalValue="fächerig" pageId="null" pageNumber="715">faecherig</normalizedToken>
. Frucht eine kugelige Kapsel.
</paragraph>
<paragraph id="899EE25F94EC57B9AE51FA375F006AE8" pageId="null" pageNumber="715">
Die Gattung 
<taxonomicName id="1A777A83072FAC254D0FC67693FE6463" class="Magnoliopsida" family="Aristolochiaceae" genus="Asarum" kingdom="Plantae" order="Piperales" pageId="null" pageNumber="715" phylum="Tracheophyta" rank="genus">
<emphasis id="F4BE936691188915527D61C4C93640AB" italics="true" pageId="null" pageNumber="715">Asarum</emphasis>
</taxonomicName>
<normalizedToken id="F1A51E97C33D6CFFF0B3A7287D54E74D" originalValue="umfaßt" pageId="null" pageNumber="715">umfasst</normalizedToken>
etwa 
<emphasis id="3A785F275A6A2AB75642630F5A5667FA" italics="true" pageId="null" pageNumber="715">100 Arten</emphasis>
(Gregory 1956) und hat 
<emphasis id="120A701F06FBA298631F96779B39464F" italics="true" pageId="null" pageNumber="715">eurasiatisch-nordamerikanische Verbreitung;</emphasis>
in 
<taxonomicName id="CB868B48B84A1E7E2B5DB6DF046E4972" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="715" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
nur 
<emphasis id="A94D46C49FDF72C6C30DE580E46DA2F0" italics="true" pageId="null" pageNumber="715">
<taxonomicName id="49C7AA011D6A5AC72DB4269923029858" class="Magnoliopsida" family="Aristolochiaceae" genus="Asarum" kingdom="Plantae" order="Piperales" pageId="null" pageNumber="715" phylum="Tracheophyta" rank="species" species="europaeum">A. europaeum</taxonomicName>
;
</emphasis>
zahlreiche Arten in Ost- und 
<normalizedToken id="5B62ACF129BB236C533A37C1DF2DFB77" originalValue="Südostasien" pageId="null" pageNumber="715">Suedostasien</normalizedToken>
. Die Gattung 
<taxonomicName id="8C0F6EAFA42E9AF08B52C28F7CAEA53B" class="Magnoliopsida" family="Aristolochiaceae" genus="Asarum" kingdom="Plantae" order="Piperales" pageId="null" pageNumber="715" phylum="Tracheophyta" rank="genus">
<emphasis id="0BFE32EB1B5268DCA79B4F154B9BD792" italics="true" pageId="null" pageNumber="715">Asarum</emphasis>
</taxonomicName>
wird von Araki (1953) in 9 Sektionen eingeteilt (keine Angaben 
<normalizedToken id="8676FFC046B265D1641B87EE2595E2DC" originalValue="über" pageId="null" pageNumber="715">ueber</normalizedToken>
einzelne Arten). Gregory (1956) 
<normalizedToken id="26F987DB6D0D46B4CCC617DE7578ABBD" originalValue="zählte" pageId="null" pageNumber="715">zaehlte</normalizedToken>
bei 17 nordamerikanischen Arten und Sippen von 
<taxonomicName id="1C19E70C5F65F344762DA7571FA4B65E" class="Magnoliopsida" family="Aristolochiaceae" genus="Asarum" kingdom="Plantae" order="Piperales" pageId="null" pageNumber="715" phylum="Tracheophyta" rank="genus">
<emphasis id="0CAD99B186B62C455E934647AA302C77" italics="true" pageId="null" pageNumber="715">Asarum</emphasis>
</taxonomicName>
und bei 
<taxonomicName id="1F4C018CBF31B9AAEBFBDD17D5ADEBB2" class="Magnoliopsida" family="Aristolochiaceae" genus="Asarum" kingdom="Plantae" order="Piperales" pageId="null" pageNumber="715" phylum="Tracheophyta" rank="species" species="europaeum">
<emphasis id="873CBCF36153357FC2EE15B590430A2F" italics="true" pageId="null" pageNumber="715">A. europaeum</emphasis>
</taxonomicName>
stets 
<emphasis id="053D0F77E63DAC7821158C0ACE54674F" italics="true" pageId="null" pageNumber="715">2n</emphasis>
= 
<emphasis id="6DD79D660A0DB95CFDDAFB525CF5CEFE" italics="true" pageId="null" pageNumber="715">26 Chromosomen.</emphasis>
</paragraph>
</subSubSection>
