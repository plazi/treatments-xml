<subSubSection id="02F18C87ECB208CB640FB0C76E1AE0F7" pageId="null" pageNumber="19" type="description">
<paragraph id="469A96B80DDB362E8F39FDE1EB85509D" pageId="null" pageNumber="19">
1 
<normalizedToken id="6B350B09495A4B178550510CEE0E7E24" originalValue="jährig" pageId="null" pageNumber="19">jaehrig</normalizedToken>
oder ausdauernd. Stengel 4kantig; Kanten der 
<normalizedToken id="785C257368738DD90C8F088A652299C0" originalValue="Blütenstiele" pageId="null" pageNumber="19">Bluetenstiele</normalizedToken>
<normalizedToken id="3B51E414FB58A684B63CFC26B084B2E0" originalValue="geflügelt" pageId="null" pageNumber="19">gefluegelt</normalizedToken>
. 
<normalizedToken id="6BBB0D13AE7419045E6A064C9851FB4F" originalValue="Blätter" pageId="null" pageNumber="19">Blaetter</normalizedToken>
<normalizedToken id="EE438E86B37AE31433E957E9F4554AA7" originalValue="gegenständig" pageId="null" pageNumber="19">gegenstaendig</normalizedToken>
, die obern spitzer als die untern. 
<emphasis id="4181BD8779A82D1671760C643BCC8E33" italics="true" pageId="null" pageNumber="19">
<normalizedToken id="84D5BBC9260328FA486319257FF18190" originalValue="Blüten" pageId="null" pageNumber="19">Blueten</normalizedToken>
in lockeren Trauben oder Rispen.
</emphasis>
Kelch bis fast auf den Grund 4-5teilig. 
<emphasis id="142B1561D976AE977C53E26D84E5849B" italics="true" pageId="null" pageNumber="19">
Krone mit sehr kurzer, undeutlicher 
<normalizedToken id="66C07A97D81FE141D6D0758FC5D9A37E" originalValue="Röhre" pageId="null" pageNumber="19">Roehre</normalizedToken>
und 4
</emphasis>
- 
<emphasis id="BA6153E912382E77E8B5A6B3328BEDF2" italics="true" pageId="null" pageNumber="19">
5 
<normalizedToken id="17C6D0A1645E41ED86D316C55D700B08" originalValue="sternförmig" pageId="null" pageNumber="19">sternfoermig</normalizedToken>
ausgebreiteten Zipfeln, die viel 
<normalizedToken id="67F0FA9922271F550E3E742EA3298F06" originalValue="länger" pageId="null" pageNumber="19">laenger</normalizedToken>
sind als die 
<normalizedToken id="A5C14C1B234D6EA6C41F1F7C8D1CF92E" originalValue="Kronröhre" pageId="null" pageNumber="19">Kronroehre</normalizedToken>
. Kronzipfel innen am Grunde mit 2 
<normalizedToken id="B22A3EF798DC2BCA940CBB20524A6783" originalValue="bärtigen" pageId="null" pageNumber="19">baertigen</normalizedToken>
Honiggruben
</emphasis>
(bei Arten 
<normalizedToken id="F4A14E2C652256E6073813D1E2BBFED2" originalValue="außerhalb" pageId="null" pageNumber="19">ausserhalb</normalizedToken>
des Gebiets z. T. nur 1 Honiggrube). 
<emphasis id="BCC8EDD88E61F6B98DF83D585B1FBDA8" italics="true" pageId="null" pageNumber="19">Griffel sehr kurz</emphasis>
, mit meist 2teiliger Narbe. Frucht 
<normalizedToken id="4D660F3DA974BAAB1C75B5BB1773F0ED" originalValue="eiförmig" pageId="null" pageNumber="19">eifoermig</normalizedToken>
.
</paragraph>
<paragraph id="9434E106C6DFCEA2AA8ADF18DCD4C947" pageId="null" pageNumber="19">
Die Gattung 
<taxonomicName id="D5059E338212FEAA5E2526A4BBCBA093" class="Magnoliopsida" family="Gentianaceae" genus="Swertia" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="19" phylum="Tracheophyta" rank="genus">
<emphasis id="FA5268454FD01CFC06A2BD9E5DB75702" italics="true" pageId="null" pageNumber="19">Swertia</emphasis>
</taxonomicName>
<normalizedToken id="D0465B8B0DE8B90C16FCDF266923CFB2" originalValue="umfaßt" pageId="null" pageNumber="19">umfasst</normalizedToken>
etwa 
<emphasis id="2AB246C423D89A8D7BD43C528A35FCD1" italics="true" pageId="null" pageNumber="19">
90 Arten und ist fast 
<normalizedToken id="D999B15738F51FA8819E4DE975771B9C" originalValue="über" pageId="null" pageNumber="19">ueber</normalizedToken>
die ganze Erde verbreitet
</emphasis>
(in warmen Gegenden nur im Gebirge). 
<normalizedToken id="5B3D25EDA22691CB7E78F99AECACB8CD" originalValue="Über" pageId="null" pageNumber="19">Ueber</normalizedToken>
die 4 
<normalizedToken id="6DD509222E5FC0C91A742EA8667BD64D" originalValue="europäischen" pageId="null" pageNumber="19">europaeischen</normalizedToken>
Sippen vgl. 
<normalizedToken id="FE559E9AE667B840E06EDC4D7B101336" originalValue="Kárpáti" pageId="null" pageNumber="19">Karpati</normalizedToken>
(1970).
</paragraph>
</subSubSection>
