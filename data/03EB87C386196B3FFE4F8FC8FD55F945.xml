Description. 
<bibRefCitation id="EFD34B2486196B3FFDD38845FB81FBC2" author="Campbell, K. S. W. &amp; B. Engel" box="[523,1051,1073,1113]" pageId="11" pageNumber="74" pagination="55 - 122" refId="ref24605" refString="Campbell, K. S. W. &amp; B. Engel, 1963. The Faunas of the Tournaisian Tulcumba Sandstone and its Members in the Werrie and Belvue Synclines, N. S. W. Geological Society of Australia Journal 10 (1): 55 - 122." type="journal article" year="1963">Campbell &amp; Engel (1963:95)</bibRefCitation>
.
</paragraph>
<paragraph id="8BFD36D586196B3FFEC38814FD69FB13" blockId="11.[232,1215,1073,1758]" box="[283,755,1120,1160]" pageId="11" pageNumber="74">
<materialsCitation id="3B2A3C8886196B3FFEC38814FD69FB13" accessionNumber="F78391" box="[283,755,1120,1160]" pageId="11" pageNumber="74" specimenCount="1" typeStatus="lectotype">
Type. 
<typeStatus id="54F9887786196B3FFE4C8814FDA0FB13" box="[404,570,1120,1160]" pageId="11" pageNumber="74">Lectotype</typeStatus>
(
<accessionNumber id="9411AB3686196B3FFD848814FD78FB13" box="[604,738,1120,1160]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/F78391" pageId="11" pageNumber="74">F78391</accessionNumber>
