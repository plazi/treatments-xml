<paragraph id="D2C386A34496166868DBC390E5FE237E" pageId="0" pageNumber="1">
<emphasis id="8CE3B058A9E9E9CF9C8759277FA0C9D7" bold="true" pageId="0" pageNumber="1">
(
<bibRefCitation id="800EDE7D7E0D5E8E9658D78991939800" author="Hutchings, A" journalOrPublisher="AGRIVITA Journal of Agricultural Science" pageId="0" pageNumber="1" publicationUrl="http://www.iucnredlist.org/documents/RedListGuidelines.pdf" refId="B105" refString="2019. . http://www.iucnredlist.org/documents/RedListGuidelines.pdf" url="http://www.iucnredlist.org/documents/RedListGuidelines.pdf" year="2019">IUCN 2019</bibRefCitation>
