<emphasis id="B3A87E6EFF9CCE4CFBABF81ADE773BCA" box="[1108,1316,1994,2021]" italics="true" pageId="17" pageNumber="18">Actinopus apalai</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A89BC315FF9CCE4CFAC3F81ADEF43BCB" box="[1340,1447,1995,2021]" pageId="17" pageNumber="18" rank="species">sp. nov.</taxonomicNameLabel>
; 
<taxonomicName id="46DCD9FFFF9CCE4CFCD5F83EDF6D3426" box="[810,1086,2031,2057]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="17" pageNumber="18" phylum="Arthropoda" rank="species" species="mairinquensis" status="sp. nov.">
