<bibRefCitation id="EFB94B194C49FFB3FDD0FD318C3AEA91" author="Urban, I." box="[604,783,690,714]" pageId="0" pageNumber="126" pagination="257 - 335" refId="ref596" refString="Urban, I. (1900) Leguminosae novae vel minus cognitae. I. In: Urban, I. (Ed.) Symbolae antillanae, 2. Leipzig, Paris, London, pp. 257 - 335." type="book chapter" year="1900">Urban 1900: 281</bibRefCitation>
