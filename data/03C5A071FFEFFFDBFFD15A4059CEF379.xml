<materialsCitation id="3B041B3AFFEFFFDBFC9E5B2B5E51FCAF" ID-GBIF-Occurrence="3804303382" box="[802,1072,802,827]" pageId="2" pageNumber="554">“Saint-Dominguie.”</materialsCitation>
