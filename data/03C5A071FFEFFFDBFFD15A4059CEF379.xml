<paragraph id="8BD31167FFEFFFDBFD715B485EFFFCF6" blockId="2.[717,1308,758,1182]" box="[717,1182,833,866]" pageId="2" pageNumber="554">Three subspecies are recognized.</paragraph>
</subSubSection>
<subSubSection id="C37642ECFFEFFFDBFD725B645933FB0A" pageId="2" pageNumber="554" type="synonymic_list">
<caption id="DF1341EFFFEFFFDBFD725B645933FB0A" ID-DOI="http://doi.org/10.5281/zenodo.6623657" ID-Zenodo-Dep="6623657" httpUri="https://zenodo.org/record/6623657/files/figure.png" inLine="true" pageId="2" pageNumber="554" targetBox="[103,693,764,1177]" targetPageId="2">
<paragraph id="8BD31167FFEFFFDBFD725B645E3FFC1E" blockId="2.[717,1308,758,1182]" box="[718,1118,877,906]" pageId="2" pageNumber="554">
<emphasis id="B918CD75FFEFFFDBFD725B645E3FFC1E" bold="true" box="[718,1118,877,906]" pageId="2" pageNumber="554">Subspecies and Distribution.</emphasis>
</paragraph>
<paragraph id="8BD31167FFEFFFDBFD725B90598DFC4D" blockId="2.[717,1308,758,1182]" pageId="2" pageNumber="554">
<taxonomicName id="4C6C6AE4FFEFFFDBFD725B905E06FC26" authority="F. Cuvier, 1836" authorityName="F. Cuvier" authorityYear="1836" box="[718,1127,921,946]" class="Mammalia" family="Capromyidae" genus="Plagiodontia" kingdom="Animalia" order="Rodentia" pageId="2" pageNumber="554" phylum="Chordata" rank="species" species="aedium">P. a. aedium F. Cuvier, 1836</taxonomicName>
— SW Haiti (Massif de la Hotte).
</paragraph>
<paragraph id="8BD31167FFEFFFDBFD725BEA5E14FBC4" blockId="2.[717,1308,758,1182]" pageId="2" pageNumber="554">
<taxonomicName id="4C6C6AE4FFEFFFDBFD725BEA5E17FB94" authority="Turvey et al., 2015" authorityName="Turvey et al." authorityYear="2015" box="[718,1142,995,1024]" class="Mammalia" family="Capromyidae" genus="Plagiodontia" kingdom="Animalia" order="Rodentia" pageId="2" pageNumber="554" phylum="Chordata" rank="subSpecies" species="aedium" subSpecies="bondi">P.a.bondiTurveyetal.,2015—SEHait(MassifdelaSelle),andSWDominicanRepublic(SierradeBaoruco).</taxonomicName>
