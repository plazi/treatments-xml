<emphasis id="B918CD75FFEFFFDBFD715AFF5909FC87" bold="true" box="[717,872,758,787]" pageId="2" pageNumber="554">Taxonomy.</emphasis>
<taxonomicName id="4C6C6AE4FFEFFFDBFCC65AFF5973FCAF" authority="F. Cuvier, 1836" authorityName="F. Cuvier" authorityYear="1836" class="Mammalia" family="Capromyidae" genus="Plagiodontia" kingdom="Animalia" order="Rodentia" pageId="2" pageNumber="554" phylum="Chordata" rank="species" species="aedium">Plagiodontia aedium F. Cuvier, 1836</taxonomicName>
