<taxonomicName id="BEB72781596558105952C11CFBF9503B" authority="(Sw.) P. Karst." authorityName="P. Karst." baseAuthorityName="Sw." box="[319,721,299,326]" class="Agaricomycetes" family="Fomitopsidaceae" genus="Fomitopsis" kingdom="Fungi" order="Polyporales" pageId="6" pageNumber="323" phylum="Basidiomycota" rank="species" species="pinicola">
