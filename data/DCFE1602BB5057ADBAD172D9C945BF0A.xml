<bibRefCitation id="8262CECFFF970F60FA28AA7FBD18787D" author="Konishi, K" journalOrPublisher="Memoirs of the National Science Museum" pageId="0" pageNumber="105" pagination="307 - 323" refId="B9" refString="Konishi, K, Maeto, K, 2000. Ichneumonoidea, Evanioidea, Trigonaloidea and Ibaliidae (Hymenoptera) from the Imperial Palace, Tokyo. Memoirs of the National Science Museum 36: 307 - 323" title="Ichneumonoidea, Evanioidea, Trigonaloidea and Ibaliidae (Hymenoptera) from the Imperial Palace, Tokyo." volume="36" year="2000">Konishi and Maeto 2000</bibRefCitation>
