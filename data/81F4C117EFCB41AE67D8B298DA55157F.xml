<subSubSection id="E3A415C8BC6781331203EFD8F604DD98" pageId="null" pageNumber="499" type="nomenclature">
<paragraph id="DCA29814846ED788EF0690F2612FB48B" pageId="null" pageNumber="499">
<taxonomicName id="1E334B805C2DE298E83D05F726FD1443" authority="L." class="Liliopsida" family="Commelinaceae" genus="Tradescantia" kingdom="Plantae" order="Commelinales" pageId="null" pageNumber="499" phylum="Tracheophyta" rank="species" species="virginiana">
Tradescantia 
<normalizedToken id="9514731D4E7170EE46FB5620801F85F6" originalValue="virginiána" pageId="null" pageNumber="499">virginiana</normalizedToken>
<authorityName id="BD68F66DD61CF45D66E4A76A988B0AA9" pageId="null" pageNumber="499">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="89DE43EAF074E88D27FF7A1AFAB3C9CA" pageId="null" pageNumber="499" type="vernacular_names">
<paragraph id="DF00CDA2EA1244017445E01CEDDBBFBC" pageId="null" pageNumber="499">Virginische Dreimasterblume</paragraph>
</subSubSection>
</title>
<subSubSection id="2927970E2BCE24861BBC3787AAAF7A55" pageId="null" pageNumber="499" type="description">
<paragraph id="36AF4D81C273543AE162D5BED273E1AE" pageId="null" pageNumber="499">
Bogig aufsteigend, meist verzweigt. 
<emphasis id="4B5C6ECD392CF8A7D2767EFC065CC3D6" italics="true" pageId="null" pageNumber="499">
<normalizedToken id="55191411A3E7B99DE8EA7C3ED5FF5A2C" originalValue="Blätter" pageId="null" pageNumber="499">Blaetter</normalizedToken>
schmal lanzettlich
</emphasis>
, 5-30 cm lang, 1-4 cm breit, eingerollt, 
<emphasis id="457B10BC6431F1BA89019FDF7CDD4782" italics="true" pageId="null" pageNumber="499">rinnig gefaltet</emphasis>
oder flach, behaart oder kahl. 
<normalizedToken id="D6B43837482D06DBA16C8F5A10709E59" originalValue="Blütenstände" pageId="null" pageNumber="499">Bluetenstaende</normalizedToken>
meist 
<normalizedToken id="6DD9C6CF20BBDCDE146836F5D15756BB" originalValue="endständig" pageId="null" pageNumber="499">endstaendig</normalizedToken>
, 
<normalizedToken id="5FAE1CCBD0FD717497B362624B6C3B97" originalValue="vielblütig" pageId="null" pageNumber="499">vielbluetig</normalizedToken>
, mit 5-20 cm langen, 
<normalizedToken id="985B34C126AD13E3684B138BD1EFBF9D" originalValue="blattähnlichen" pageId="null" pageNumber="499">blattaehnlichen</normalizedToken>
<normalizedToken id="89B8809D800957FB06615713AE165A06" originalValue="Tragblättern" pageId="null" pageNumber="499">Tragblaettern</normalizedToken>
. 
<emphasis id="4F1D22EB6152D7A8ACED044B079B03BF" italics="true" pageId="null" pageNumber="499">
<normalizedToken id="28D0CC56A10412D25FBA0C9F282B2DD7" originalValue="Blütendurchmesser" pageId="null" pageNumber="499">Bluetendurchmesser</normalizedToken>
1-3 cm.
</emphasis>
Innere 
<normalizedToken id="CC95DF73BF5B418139FABCB53BC51246" originalValue="Perigonblätter" pageId="null" pageNumber="499">Perigonblaetter</normalizedToken>
purpurn, violett, blau oder 
<normalizedToken id="8BF4DF3D52C8B8741E9D97D1196D9052" originalValue="weiß" pageId="null" pageNumber="499">weiss</normalizedToken>
. - 
<normalizedToken id="FC2696E93064949D0B014430F0C5DE31" originalValue="Blüte" pageId="null" pageNumber="499">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="9ED7DBE61C88BE3B13BC555FF26939AE" pageId="null" pageNumber="499">
<emphasis id="062445435D16F873829B9FD42A2E69F1" italics="true" pageId="null" pageNumber="499">Zytologische Angaben. 2n = 12:</emphasis>
Material aus dem 
<normalizedToken id="117CB5BE7C1E9EB1A4002751CB8D54A8" originalValue="nördlichen" pageId="null" pageNumber="499">noerdlichen</normalizedToken>
Missouri, Illinois und Iowa. 
<emphasis id="2C53203EE6DFE52E9150A7C121EF213E" italics="true" pageId="null" pageNumber="499">2n = 24:</emphasis>
Material aus Pennsylvanien und dem 
<normalizedToken id="EACF807FDA66EE5DAD202EA02F9264D9" originalValue="südlichen" pageId="null" pageNumber="499">suedlichen</normalizedToken>
Missouri (Anderson 1954). 
<normalizedToken id="FBD69C233C34CB25952C392DC7469A39" originalValue="Häufig" pageId="null" pageNumber="499">Haeufig</normalizedToken>
verwendet zur Untersuchung der Feinstruktur der Meiose-Chromosomen. Viele 
<normalizedToken id="2B2DC28792B2881F057751E4963AB8D8" originalValue="Zählungen" pageId="null" pageNumber="499">Zaehlungen</normalizedToken>
in 
<normalizedToken id="198E6BF14E6DBE4F87023609248C16C4" originalValue="Löve" pageId="null" pageNumber="499">Loeve</normalizedToken>
und 
<normalizedToken id="63E04B13FA4CBA01CBFF22384C66E11C" originalValue="Löve" pageId="null" pageNumber="499">Loeve</normalizedToken>
(1961) zitiert. 
<normalizedToken id="2DF81DE7B63B2EC14A6D035308CE5F30" originalValue="Über" pageId="null" pageNumber="499">Ueber</normalizedToken>
Kreuzungen der beiden Chromosomensippen vgl. Vosa (1965).
</paragraph>
<paragraph id="68944D5F95149B9EFD8AEF34C679E4A4" pageId="null" pageNumber="499">
<emphasis id="B573357913A5F72D357F77049242CF1F" italics="true" pageId="null" pageNumber="499">Standort.</emphasis>
Kollin. 
<normalizedToken id="7FB9C1A7E42CF6FC04301B169A172C5E" originalValue="Schuttplätze" pageId="null" pageNumber="499">Schuttplaetze</normalizedToken>
, Weinberge; nur in den 
<normalizedToken id="BA03E3A3B6A44A65252566AA7687ADB4" originalValue="wärmsten" pageId="null" pageNumber="499">waermsten</normalizedToken>
Gegenden.
</paragraph>
<paragraph id="B6DD4D127BBA6CF735E500049C305E57" pageId="null" pageNumber="499">
<emphasis id="BB7FBEA2DD4C48E3B33F47A025C32A00" italics="true" pageId="null" pageNumber="499">Verbreitung. Nordamerikanische Pflanze:</emphasis>
<normalizedToken id="3FF931774CBEBE247754F781E064A1B1" originalValue="Südliche" pageId="null" pageNumber="499">Suedliche</normalizedToken>
Staaten der Union (vgl. Anderson 1954). - Im 
<normalizedToken id="4B3F1A13148F4752636D91EB258C94BC" originalValue="Süden" pageId="null" pageNumber="499">Sueden</normalizedToken>
des Gebiets gelegentlich verwilderte Gartenpflanze.
</paragraph>
<paragraph id="FCB506134FFA614877DF54F496BC0453" pageId="null" pageNumber="499">
<emphasis id="2033E06F888C0F24DB8FD6C040A9B03B" italics="true" pageId="null" pageNumber="499">Bemerkungen.</emphasis>
Die bei uns kultivierte 
<taxonomicName id="9C9B3A14FEF2D03F3BDD646104AFFB6B" class="Liliopsida" family="Commelinaceae" genus="Tradescantia" kingdom="Plantae" order="Commelinales" pageId="null" pageNumber="499" phylum="Tracheophyta" rank="species" species="virginiana">
<emphasis id="A8750EF8517CA21E7CFABBA468AA2FAE" italics="true" pageId="null" pageNumber="499">T. virginiana</emphasis>
</taxonomicName>
ist durch Bastardierungen und Selektion so weit 
<normalizedToken id="F33EA2194800347BEA06BE41168A37A5" originalValue="verändert" pageId="null" pageNumber="499">veraendert</normalizedToken>
, 
<normalizedToken id="5D4834FB0A2C49F5F3604B3D664CBE9E" originalValue="daß" pageId="null" pageNumber="499">dass</normalizedToken>
sie sich von der wilden 
<taxonomicName id="6B5D9187EA725BF71117817B461A4635" class="Liliopsida" family="Commelinaceae" genus="Tradescantia" kingdom="Plantae" order="Commelinales" pageId="null" pageNumber="499" phylum="Tracheophyta" rank="species" sensu="stricto" species="virginiana">
<emphasis id="5E93977F3D0BFCE78E6A4CBAB5BC29B3" italics="true" pageId="null" pageNumber="499">T. virginiana</emphasis>
</taxonomicName>
<taxonomicNameLabel id="BBEF40C967CD1FB7DAA94488D3B7B796" pageId="null" pageNumber="499" sensu="stricto">s. str.</taxonomicNameLabel>
deutlich unterscheidet.
</paragraph>
</subSubSection>
