<taxonomicName id="9EC84D2B4544B646B7EFFF4AFBA01D81" authority="Hagen, 1866" authorityName="Hagen" authorityYear="1866" box="[701,1053,223,249]" class="Insecta" family="Boreidae" genus="Boreus" kingdom="Animalia" order="Mecoptera" pageId="7" pageNumber="466" phylum="Arthropoda" rank="species" species="westwoodi">
<emphasis id="6BBCEABA4544B646B7EFFF4AFC3B1D81" box="[701,902,223,249]" italics="true" pageId="7" pageNumber="466">Boreus westwoodi</emphasis>
<bibRefCitation id="3D594B594544B646B6DFFF4AFBA01D81" author="Hagen, A. H." box="[909,1053,223,249]" pageId="7" pageNumber="466" pagination="132" refId="ref14476" refString="Hagen, A. H. (1866) Synopsis of the genus Boreus. Entomologists Monthly Magazine, 3, 132" type="journal article" year="1866">Hagen, 1866</bibRefCitation>
</taxonomicName>
” [
<date id="2D7610684544B646B166FF4AFB1A1D81" box="[1076,1191,223,249]" pageId="7" pageNumber="466" value="1903-11-09">11.9.1903</date>
