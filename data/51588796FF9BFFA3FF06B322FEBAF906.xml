; 
<materialsCitation id="69993CDDFF9BFFA5FE0DB62FFE92F906" ID-GBIF-Occurrence="3754836427" collectingDate="2000-10-30" collectionCode="P, TAN" collectorName="Rakotondrainibe" elevation="1200" location="Province de Fianarantsoa" pageId="18" pageNumber="169" specimenCount="1" stateProvince="Fianarantsoa">
