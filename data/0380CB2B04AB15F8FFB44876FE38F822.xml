<subSubSection id="C33329B604AB15F8FFB44905FE38F822" pageId="162" pageNumber="163" type="discussion">
<paragraph id="8B967A3D04AB15F8FFB44905FE38F822" blockId="162.[151,1437,1630,2006]" pageId="162" pageNumber="163">
<emphasis id="B95DA62F04AB15F8FFB44905FEE0F8B2" bold="true" box="[151,267,1836,1862]" pageId="162" pageNumber="163">Remarks.</emphasis>
<taxonomicName id="4C2901BE04AB15F8FE314905FD07F8B2" authority="Pilsbry &amp; Aguayo, 1933" authorityName="Pilsbry &amp; Aguayo" authorityYear="1933" box="[274,748,1836,1862]" class="Gastropoda" family="Triphoridae" genus="Triphora" higherTaxonomySource="CoL" kingdom="Animalia" order="Asparagales" pageId="162" pageNumber="163" phylum="Mollusca" rank="species" species="somersi">
<emphasis id="B95DA62F04AB15F8FE314905FE3FF8B2" box="[274,468,1836,1862]" italics="true" pageId="162" pageNumber="163">Triphora somersi</emphasis>
<bibRefCitation id="EFB807CC04AB15F8FEF84905FD07F8B2" author="Pilsbry, H. A. &amp; Aguayo, C. G." box="[475,748,1836,1862]" pageId="162" pageNumber="163" pagination="116 - 123" refId="ref165638" refString="Pilsbry, H. A. &amp; Aguayo, C. G. C (1933) Marine and Freshwater Mollusks new to the fauna of Cuba. The Nautilus, 46, 116 - 123." type="journal article" year="1933">Pilsbry &amp; Aguayo, 1933</bibRefCitation>
</taxonomicName>
was reported as a 
<emphasis id="B95DA62F04AB15F8FC9F4904FBB1F8B2" box="[956,1114,1836,1862]" italics="true" pageId="162" pageNumber="163">nomen nudum</emphasis>
by 
<bibRefCitation id="EFB807CC04AB15F8FBA64905FEF9F89E" author="Rolan, E. &amp; Fernandez-Garces, R." pageId="162" pageNumber="163" pagination="13 - 24" refId="ref167445" refString="Rolan, E. &amp; Fernandez-Garces, R. (2007) Caribbean Triphoridae (Gastropoda: Triphoroidea): list and colour illustrations. Neptunea, 6 (3), 13 - 24." type="journal article" year="2007">Rolán &amp; Fernández-Garcés (2007)</bibRefCitation>
; 
<bibRefCitation id="EFB807CC04AB15F8FE024979FD94F89E" author="Pilsbry, H. A. &amp; Aguayo, C. G." box="[289,639,1872,1898]" pageId="162" pageNumber="163" pagination="116 - 123" refId="ref165638" refString="Pilsbry, H. A. &amp; Aguayo, C. G. C (1933) Marine and Freshwater Mollusks new to the fauna of Cuba. The Nautilus, 46, 116 - 123." type="journal article" year="1933">Pilsbry &amp; Aguayo (1933: 119)</bibRefCitation>
never described this species. 
<bibRefCitation id="EFB807CC04AB15F8FCFA4979FA8DF89E" author="Rolan, E. &amp; Fernandez-Garces, R." box="[985,1382,1872,1898]" pageId="162" pageNumber="163" pagination="13 - 24" refId="ref167445" refString="Rolan, E. &amp; Fernandez-Garces, R. (2007) Caribbean Triphoridae (Gastropoda: Triphoroidea): list and colour illustrations. Neptunea, 6 (3), 13 - 24." type="journal article" year="2007">Rolán &amp; Fernández-Garcés (2007)</bibRefCitation>
also listed 
<taxonomicName id="4C2901BE04AB15F8FFFF495DFDCAF87A" authority="Peile 1926" authorityName="Bartsch Rolan &amp; Fernandez-Garces, 2008 Peile" authorityYear="1926" box="[220,545,1908,1934]" class="Gastropoda" family="Triphoridae" genus="Triphora" higherTaxonomySource="CoL" kingdom="Animalia" order="Asparagales" pageId="162" pageNumber="163" phylum="Mollusca" rank="species" species="somersi">
<emphasis id="B95DA62F04AB15F8FFFF495DFE75F87A" box="[220,414,1908,1934]" italics="true" pageId="162" pageNumber="163">Triphora somersi</emphasis>
<bibRefCitation id="EFB807CC04AB15F8FE85495DFDCAF87A" author="Peile, A. H." box="[422,545,1908,1934]" pageId="162" pageNumber="163" pagination="71 - 98" refId="ref165217" refString="Peile, A. H. (1926) The Mollusca of Bermuda. Proceedings of the Malacological Society of London, 17 (2 - 3), 71 - 98." type="journal article" year="1926">Peile 1926</bibRefCitation>
</taxonomicName>
, but 
<bibRefCitation id="EFB807CC04AB15F8FD7A495DFD08F87B" author="Peile, A. H." box="[601,739,1908,1935]" pageId="162" pageNumber="163" pagination="71 - 98" refId="ref165217" refString="Peile, A. H. (1926) The Mollusca of Bermuda. Proceedings of the Malacological Society of London, 17 (2 - 3), 71 - 98." type="journal article" year="1926">Peile (1926)</bibRefCitation>
never described this species either. Peile referred to 
<taxonomicName id="4C2901BE04AB15F8FA1A495DFEDFF846" authority="&quot; Bar." authorityName="Bar." class="Gastropoda" family="Triphoridae" genus="Triphora" higherTaxonomySource="CoL" kingdom="Animalia" order="Asparagales" pageId="162" pageNumber="163" phylum="Mollusca" rank="species" species="somersi">
<emphasis id="B95DA62F04AB15F8FA1A495DFF05F846" italics="true" pageId="162" pageNumber="163">Triphora somersi</emphasis>
“Bar.
</taxonomicName>
”, where “Bar.” stands for Bartsch. Yet again we have not found any publication of Bartsch where he described 
<emphasis id="B95DA62F04AB15F8FE2A4995FE38F822" box="[265,467,1980,2006]" italics="true" pageId="162" pageNumber="163">
<taxonomicName id="4C2901BE04AB15F8FE2A4995FE24F822" box="[265,463,1980,2006]" class="Gastropoda" family="Triphoridae" genus="Triphora" higherTaxonomySource="CoL" kingdom="Animalia" order="Asparagales" pageId="162" pageNumber="163" phylum="Mollusca" rank="species" species="somersi">Triphora somersi</taxonomicName>
.
</emphasis>
</paragraph>
