<collectionCode box="[1181,1272,945,971]" country="France" httpUri="http://biocol.org/urn:lsid:biocol.org:col:34988" lsid="urn:lsid:biocol.org:col:34988" name="Museum National d'Histoire Naturelle" pageId="2" pageNumber="109">MNHN</collectionCode>
)
