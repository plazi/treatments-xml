, 
<quantity id="036C9B1BFF846A3BF73A9A57170AB71D" box="[2246,2314,3086,3119]" metricMagnitude="1" metricUnit="m" metricValue="5.0" pageId="127" pageNumber="886" unit="m" value="50.0">50 m</quantity>
