<subSubSection id="195E89BD75B3BC6FB9B3A6694F064A31" pageId="null" pageNumber="111" type="description">
<paragraph id="1E2600CFA6D7138CD5F171F9A103CD74" pageId="null" pageNumber="111">
<emphasis id="22E26A150F1D65FDC27EEDF6209CB952" italics="true" pageId="null" pageNumber="111">
Pflanze ohne 
<normalizedToken id="5B5798A79F8B1C8CF731B8C36D2C7B04" originalValue="Drüsen" pageId="null" pageNumber="111">Druesen</normalizedToken>
;
</emphasis>
sonst wie 
<taxonomicName id="273F82EC965751878AB48BC409102190" class="Polypodiopsida" family="Thelypteridaceae" genus="Thelypteris" kingdom="Plantae" order="Polypodiales" pageId="null" pageNumber="111" phylum="Tracheophyta" rank="species" species="robertiana">
<emphasis id="E4C0DE57795981BE24C3867E3404B84B" italics="true" pageId="null" pageNumber="111">
<authorityName id="5557E35FA83194A464558B5214CECE89" pageId="null" pageNumber="111">L.</authorityName>
Robertiana
</emphasis>
</taxonomicName>
(Nr. 1).
</paragraph>
<paragraph id="E1E69A009BB397CAE6E27256A996D9D3" pageId="null" pageNumber="111">
<emphasis id="35C4F97425B41E13BD6A2502C793B839" italics="true" pageId="null" pageNumber="111">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="FBFF17FEA9610F7362F28BC72BC9F885" italics="true" pageId="null" pageNumber="111">160:</emphasis>
Material aus England; normal sexuell (Manton 1950), aus Finnland (Sorsa 1958 1962 1963), aus Island (
<normalizedToken id="0541A1F4519EDA03378E94B94018B670" originalValue="Löve" pageId="null" pageNumber="111">Loeve</normalizedToken>
und 
<normalizedToken id="BFEFD156C02A61C61A4180EAC0D3C922" originalValue="Löve" pageId="null" pageNumber="111">Loeve</normalizedToken>
1961a), aus Nordamerika (Wagner 1963).
</paragraph>
<paragraph id="B78529B08D7AC067FB30141EE093BA8C" pageId="null" pageNumber="111">
<emphasis id="C3404E0B3690E2CA270638EDE10A7E7E" italics="true" pageId="null" pageNumber="111">Standort.</emphasis>
Montan und subalpin. Kalkarme, feuchte, humose, steinige 
<normalizedToken id="A7946126C34356459B842987590B2872" originalValue="Böden" pageId="null" pageNumber="111">Boeden</normalizedToken>
; gelegentlich Blockschutt. 
<normalizedToken id="310B825184A623BAEC8C33A888FFEF7C" originalValue="Buchen-Tannenwälder" pageId="null" pageNumber="111">Buchen-Tannenwaelder</normalizedToken>
, 
<normalizedToken id="3A7E2386C8A46B122031BC7A3083A7D1" originalValue="Fichtenwälder" pageId="null" pageNumber="111">Fichtenwaelder</normalizedToken>
, Hochstaudenfluren.
</paragraph>
<paragraph id="A3D327AC44EF8DB86F963F5B50F179D5" pageId="null" pageNumber="111">
<emphasis id="F99CF22348C81B0C09A7A0E129F506A7" italics="true" pageId="null" pageNumber="111">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
Wie 
<taxonomicName id="715BD2F07A5F5E0ECBF3558A86945A99" class="Polypodiopsida" family="Thelypteridaceae" genus="Thelypteris" kingdom="Plantae" order="Polypodiales" pageId="null" pageNumber="111" phylum="Tracheophyta" rank="species" species="robertiana">
<emphasis id="E937854201BA5F98653389DD22230608" italics="true" pageId="null" pageNumber="111">
<authorityName id="CD66C81D88656CF27C4BB009862D757F" pageId="null" pageNumber="111">L.</authorityName>
Robertiana
</emphasis>
</taxonomicName>
(Nr.1), jedoch auch auf Island und 
<normalizedToken id="20A773526260B6A745C59537433C2A2B" originalValue="Grönland" pageId="null" pageNumber="111">Groenland</normalizedToken>
. Verbreitungskarten von 
<normalizedToken id="6876CD308A0C67C7691E671AD000C3F0" originalValue="Hultén" pageId="null" pageNumber="111">Hulten</normalizedToken>
(1962) und Meusel (1964). - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="E8EC4F81D606AA1C3664E07CAB56E6BC" originalValue="häufig" pageId="null" pageNumber="111">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
