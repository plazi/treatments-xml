<paragraph id="D126FA521B1AFFD6FA17FEF6F758FD74" blockId="4.[1409,2616,291,1075]" box="[1411,2248,647,680]" pageId="4" pageNumber="515">
<emphasis id="E3ED26401B1AFFD6FA17FEF6F999FD74" bold="true" box="[1411,1545,647,680]" pageId="4" pageNumber="515">Breeding.</emphasis>
There is no information available for this species.
</paragraph>
</subSubSection>
<subSubSection id="9983A9D91B1AFFD6FA15FEDFF6BBFD13" box="[1409,2347,686,719]" pageId="4" pageNumber="515" type="activity">
<paragraph id="D126FA521B1AFFD6FA15FEDFF6BBFD13" blockId="4.[1409,2616,291,1075]" box="[1409,2347,686,719]" pageId="4" pageNumber="515">
<emphasis id="E3ED26401B1AFFD6FA15FEDFF9FCFD13" bold="true" box="[1409,1644,686,719]" pageId="4" pageNumber="515">Activity patterns.</emphasis>
