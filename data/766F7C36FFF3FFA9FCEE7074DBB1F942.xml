<collectingCountry id="86D18DB0FFF3FFA9FC54734EDC53F902" box="[991,1067,1641,1665]" name="Turkey" pageId="66" pageNumber="79">Turkey</collectingCountry>
(
<bibRefCitation id="9A57B0D1FFF3FFA9FBC9734EDD74F902" author="MARUYAMA, M." box="[1090,1292,1641,1665]" pageId="66" pageNumber="79" pagination="1 - 207" refId="ref77541" refString="MARUYAMA, M. 2006: Revision of the Palearctic species of the myrmecophilous genus Pella (Coleoptera, Staphylinidae, Aleocharinae). - National Science Museum Monographs 32: 1 - 207." type="journal article" year="2006">MARUYAMA 2006</bibRefCitation>
