<emphasis id="F37883CC376F9DAE7668762F10C74EC1" bold="true" pageId="0" pageNumber="1">A</emphasis>
hypopygium 
<emphasis id="436C910ADF3D39941337EE1715B33034" bold="true" pageId="0" pageNumber="1">B, C</emphasis>
genitalia in ventral view 
<emphasis id="885A3EB33B0E9CB960B6B8FABA453E62" bold="true" pageId="0" pageNumber="1">D</emphasis>
