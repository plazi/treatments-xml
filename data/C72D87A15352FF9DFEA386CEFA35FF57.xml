<quantity id="887C9B525352FF9CFC80803CFCEEFAF4" box="[692,838,1343,1370]" metricMagnitude="3" metricUnit="m" metricValue="1.033" metricValueMax="1.9649999999999999" metricValueMin="0.101" pageId="12" pageNumber="13" unit="m" value="1033.0" valueMax="1965.0" valueMin="101.0">101–1965 m</quantity>
), E Atlantic (
<quantity id="887C9B525352FF9CFDE8803CFBC7FAF4" box="[988,1135,1343,1370]" metricMagnitude="3" metricUnit="m" metricValue="2.2515" metricValueMax="4.088" metricValueMin="0.415" pageId="12" pageNumber="13" unit="m" value="2251.5" valueMax="4088.0" valueMin="415.0">415–4088 m</quantity>
), W Indian (
<quantity id="887C9B525352FF9CFAC8803CFA27FAF4" box="[1276,1423,1343,1370]" metricMagnitude="3" metricUnit="m" metricValue="1.3844999999999998" metricValueMax="2.312" metricValueMin="0.457" pageId="12" pageNumber="13" unit="m" value="1384.5" valueMax="2312.0" valueMin="457.0">457–2312 m</quantity>
), E Indo-W Pacific (
<quantity id="887C9B525352FF9CFF5A8060FDA9FAD0" box="[366,513,1379,1406]" metricMagnitude="3" metricUnit="m" metricValue="1.8215" metricValueMax="3.343" metricValueMin="0.3" pageId="12" pageNumber="13" unit="m" value="1821.5" valueMax="3343.0" valueMin="300.0">300–3343 m</quantity>
), E Pacific (
<quantity id="887C9B525352FF9CFCBA8060FC8AFAD0" box="[654,802,1379,1406]" metricMagnitude="3" metricUnit="m" metricValue="1.6644999999999999" metricValueMax="2.5989999999999998" metricValueMin="0.73" pageId="12" pageNumber="13" unit="m" value="1664.5" valueMax="2599.0" valueMin="730.0">730–2599 m</quantity>
), S America (
<quantity id="887C9B525352FF9CFD8A8060FBFAFAD0" box="[958,1106,1379,1406]" metricMagnitude="3" metricUnit="m" metricValue="2.0469999999999997" metricValueMax="3.3939999999999997" metricValueMin="0.7" pageId="12" pageNumber="13" unit="m" value="2047.0" valueMax="3394.0" valueMin="700.0">700–3394 m</quantity>
), S Africa (
