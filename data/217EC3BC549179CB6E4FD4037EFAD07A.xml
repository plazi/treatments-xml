<normalizedToken id="07E460D5F77366B93865CD404C020A33" originalValue="Drüsenhaare" pageId="null" pageNumber="128">Druesenhaare</normalizedToken>
, 
<normalizedToken id="705CE6CF71077E327D4E66633A080AC0" originalValue="höchstens" pageId="null" pageNumber="128">hoechstens</normalizedToken>
mit fast ungestielten 
<normalizedToken id="A1C496DB358EB6854D80D2CFB18A3A95" originalValue="Drüsen" pageId="null" pageNumber="128">Druesen</normalizedToken>
; 
<normalizedToken id="8B6C378DB1EA632007D5D6ABE0C96926" originalValue="gleichmäßig" pageId="null" pageNumber="128">gleichmaessig</normalizedToken>
5 
<normalizedToken id="E677CD5B7E70E9CA79F69A6F663A089B" originalValue="zähnig" pageId="null" pageNumber="128">zaehnig</normalizedToken>
; Kronunterlippe 5-8 mm lang
</td>
<td id="286FABFEC9C407BAB270A9BB4E813B64" align="left" pageId="null" pageNumber="128" valign="bottom">
<taxonomicName id="AE125C3E989D02544E080118E99E299B" class="Magnoliopsida" family="Lamiaceae" genus="Stachys" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="128" phylum="Tracheophyta" rank="species" species="recta">
<italic id="A82E4AB78F6E6DFF3ECF876141FF3DD0" pageId="null" pageNumber="128">S. recta</italic>
