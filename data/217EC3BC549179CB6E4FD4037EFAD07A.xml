<tr id="E7C1668DE03051BE92C965E4F9408914" pageId="null" pageNumber="128">
<td id="61C6111F43C1D283EF29506B2FB9F643" align="left" pageId="null" pageNumber="128" valign="top">
1*. Kelch mit 0,5-1 mm langen 
<normalizedToken id="2657022B9B973D734C73F4B8E53524F8" originalValue="Drüsenhaaren" pageId="null" pageNumber="128">Druesenhaaren</normalizedToken>
, undeutlich 2lippig; Kronunterlippe 10-12 mm lang
</td>
<td id="92100DFBF5BC3C85FF0B773CF265BCA4" align="left" pageId="null" pageNumber="128" valign="bottom">
