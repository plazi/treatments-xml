<paragraph id="B365CA5B3B9FD9C5C079FBDE8C7F5F2C" pageId="null" pageNumber="128">
Artengruppe der 
<taxonomicName id="DFDB9089626B082BA1532106EE05C1C5" authority="L." class="Magnoliopsida" family="Lamiaceae" genus="Stachys" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="128" phylum="Tracheophyta" rank="species" species="recta">
Stachys 
<normalizedToken id="75CEBB50FCD742C7018DE62DBAAF2657" originalValue="récta" pageId="null" pageNumber="128">recta</normalizedToken>
<authorityName id="40D571AC5BCA74C48E4883E44AD3C2ED" pageId="null" pageNumber="128">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="2F77E594E94EC38DAEBDE2683C47D0CE" pageId="null" pageNumber="128" type="vernacular_names">
<paragraph id="54267746EFE81CD1513FC3A973EA64CB" pageId="null" pageNumber="128">Aufrechter Ziest</paragraph>
</subSubSection>
</title>
<subSubSection id="3077248FE60100C847954DE5778749FF" pageId="null" pageNumber="128" type="description">
<paragraph id="F8A18CBCB652A73B953BE785EEB2329F" pageId="null" pageNumber="128">
<emphasis id="904F840EE38939E3194DEB51927DB295" italics="true" pageId="null" pageNumber="128">Ausdauernd</emphasis>
, mit kurzem, 
<normalizedToken id="3D4BEBD732ACC333AD32DA2D35176014" originalValue="dünnem" pageId="null" pageNumber="128">duennem</normalizedToken>
Rhizom und langer Pfahlwurzel, ohne 
<normalizedToken id="6F9746A1BCF19CA2283F55EDD3AF265F" originalValue="Ausläufer" pageId="null" pageNumber="128">Auslaeufer</normalizedToken>
; nur wenig riechend; 20-60 cm hoch. Stengel aufrecht oder aufsteigend, einfach oder vom Grunde an verzweigt (buschig), auf 2 
<normalizedToken id="89E649FBE6F59BF6B7F75F02D63E4F63" originalValue="gegenüberliegenden" pageId="null" pageNumber="128">gegenueberliegenden</normalizedToken>
, bei jedem Knoten wechselnden Seiten 
<normalizedToken id="48A581DEC0AAFB44A38F04F3BA0D08F8" originalValue="stärker" pageId="null" pageNumber="128">staerker</normalizedToken>
behaart (Haare bis 3 mm lang, mehrzellig, abstehend oder nach vorn gerichtet). 
<emphasis id="40F0F3B7BE5BFB8CE0E3F7F4650932C4" italics="true" pageId="null" pageNumber="128">
<normalizedToken id="F4289189908A8E2AD80B301B494C1239" originalValue="Blätter" pageId="null" pageNumber="128">Blaetter</normalizedToken>
kurz gestielt
</emphasis>
(
<emphasis id="201637C11DAAE593522A2CEF516F221A" italics="true" pageId="null" pageNumber="128">
Stiel 
<normalizedToken id="46B3E29E45E0A9FFD73D264F477E936C" originalValue="höchstens" pageId="null" pageNumber="128">hoechstens</normalizedToken>
</emphasis>
<normalizedToken id="E41CC254264DB309ADEBE60409A83DEA" originalValue="½" pageId="null" pageNumber="128">1/2</normalizedToken>
<emphasis id="6C3FD74106A0936347B3E771690DAE3D" italics="true" pageId="null" pageNumber="128">so lang wie die Spreite</emphasis>
) 
<emphasis id="F53AC9ECF8DEF81B22ECC9240032B896" italics="true" pageId="null" pageNumber="128">oder sitzend</emphasis>
, sonst wie 
<taxonomicName id="669EC49078A2D92213761256A80A767B" class="Magnoliopsida" family="Lamiaceae" genus="Stachys" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="128" phylum="Tracheophyta" rank="species" species="annua">
<emphasis id="20E72E730451BCFC7211CC8973A0DED4" italics="true" pageId="null" pageNumber="128">S. annua</emphasis>
</taxonomicName>
(Nr. 2). 
<normalizedToken id="53EA4B5ABFF1DDE5E9BB77DB43C33791" originalValue="Blüten" pageId="null" pageNumber="128">Blueten</normalizedToken>
, 
<normalizedToken id="A61FEBC2AEADD2B879846EBF15477873" originalValue="Vorblätter" pageId="null" pageNumber="128">Vorblaetter</normalizedToken>
, Kelch und Krone 
<normalizedToken id="61DE8CBCF5317A6FC8C3E42525BD56CF" originalValue="ähnlich" pageId="null" pageNumber="128">aehnlich</normalizedToken>
wie bei 
<taxonomicName id="191B8093E45F4D121A914555EBB81A5E" class="Magnoliopsida" family="Lamiaceae" genus="Stachys" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="128" phylum="Tracheophyta" rank="species" species="annua">
<emphasis id="9327FB9E411BE15804F6EEFBA8F88B69" italics="true" pageId="null" pageNumber="128">S. annua</emphasis>
</taxonomicName>
, aber die 
<normalizedToken id="E37B2AD25B1C6A638F36D3290E1542E4" originalValue="Blüten" pageId="null" pageNumber="128">Blueten</normalizedToken>
<normalizedToken id="BBABCC160A0A2D4F8225E44E008B6549" originalValue="±" pageId="null" pageNumber="128">+/-</normalizedToken>
sitzend, in 4-8 
<normalizedToken id="65E71A509558727F8468D76415325947" originalValue="blütigen" pageId="null" pageNumber="128">bluetigen</normalizedToken>
<normalizedToken id="58C341B2E09B42E1141215E0BA905B98" originalValue="Teilblütenständen" pageId="null" pageNumber="128">Teilbluetenstaenden</normalizedToken>
und der 
<emphasis id="001FFADAF35455998E0B86125F8CE98A" italics="true" pageId="null" pageNumber="128">Kelch mit 0,5</emphasis>
- 
<emphasis id="2A665DA01866EEC03B1B27111C6ADC13" italics="true" pageId="null" pageNumber="128">
1 mm langen Haaren und stechend begrannten 
<normalizedToken id="848576BE5EBB1433C99D5B5E851EB584" originalValue="Zähnen" pageId="null" pageNumber="128">Zaehnen</normalizedToken>
</emphasis>
(
<emphasis id="B24CADBC39C46995B22423CE555C1421" italics="true" pageId="null" pageNumber="128">Grannen nicht behaart</emphasis>
). Teilfrucht 2-2,5 mm lang, glatt. - 
<normalizedToken id="DC1892A45DDA390AC49A7A7897F8743E" originalValue="Blüte" pageId="null" pageNumber="128">Bluete</normalizedToken>
: 
<normalizedToken id="FE023D88B9B1AA4B82AF73A6C4706CAE" originalValue="Später" pageId="null" pageNumber="128">Spaeter</normalizedToken>
<normalizedToken id="DFE303D69B62EE0CFB8CC9170EBA588D" originalValue="Frühling" pageId="null" pageNumber="128">Fruehling</normalizedToken>
bis 
<normalizedToken id="60F5E9FEA4BA2FEB942DFA01CEB9F1C9" originalValue="früher" pageId="null" pageNumber="128">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="ACDFE1EA2FCB754F86D638A775DDB7EE" pageId="null" pageNumber="128">
Die Artengruppe 
<normalizedToken id="036E994E2A052BF2EB7EF47C02E61F07" originalValue="umfaßt" pageId="null" pageNumber="128">umfasst</normalizedToken>
etwa 
<emphasis id="F74E54CE393D0F0ACA2FEE1444CA6AB3" italics="true" pageId="null" pageNumber="128">
5 wenig untersuchte, 
<normalizedToken id="6B84177D336B36300FA9686B8727C9AB" originalValue="hauptsächlich" pageId="null" pageNumber="128">hauptsaechlich</normalizedToken>
mediterrane Arten
</emphasis>
.
</paragraph>
<paragraph id="228220398F1795983BD3393D73D3BE64" pageId="null" pageNumber="128">
<table id="650298E577A5F32748C430790E69218B" frame="void" pageId="null" pageNumber="128" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
