<emphasis id="B92F7B4F2906FFEAB0EAFDE3FC786F29" bold="true" box="[151,994,582,609]" pageId="2" pageNumber="410">
Genus group 
<taxonomicName id="4C5BDCDE2906FFEAB13DFDE3FC786F29" authority="Cadena-Castaneda &amp; Garcia Garcia, 2020" authorityName="Cadena-Castaneda &amp; Garcia Garcia" authorityYear="2020" box="[320,994,582,609]" family="Gryllidae" genus="Miogryllae" kingdom="Animalia" order="Orthoptera" pageId="2" pageNumber="410" rank="genus">
Miogryllae 
