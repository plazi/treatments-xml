<subSubSection id="79E1DE34F47209DA63A77695F2DC707B" pageId="null" pageNumber="210" type="description">
<paragraph id="A54664BD5D230AEFC2F9E6D4170E35EF" pageId="null" pageNumber="210">
Ausdauernd; 20-50 cm hoch; 
<emphasis id="A83A6418A3B78D7E2D426D702E662985" italics="true" pageId="null" pageNumber="210">kahl</emphasis>
(
<emphasis id="30982EA4F3AF03F1D95D97E407E4D089" italics="true" pageId="null" pageNumber="210">
auch im 
<normalizedToken id="DF381C4D21C075E5B17CBACC7A19FEDA" originalValue="Blütenstand" pageId="null" pageNumber="210">Bluetenstand</normalizedToken>
</emphasis>
)
<emphasis id="E47DFDA9689A4838B89BF05D2B6CE849" italics="true" pageId="null" pageNumber="210">
. 
<normalizedToken id="DDCF9D42114F2070BFE43B80F44DE58B" originalValue="Blätter" pageId="null" pageNumber="210">Blaetter</normalizedToken>
<normalizedToken id="D5F1BB9AD466C5FD429D245B3E094455" originalValue="bläulich" pageId="null" pageNumber="210">blaeulich</normalizedToken>
, flach.
</emphasis>
Kelch mit kurzen, lanzettlichen Zipfeln. 
<emphasis id="DD5A24DCA5C70002C6623950BA171A70" italics="true" pageId="null" pageNumber="210">Krone 0,8</emphasis>
- 
<emphasis id="6AF4B94DEB02D2984CB87DA1AEE27BD7" italics="true" pageId="null" pageNumber="210">1 cm lang</emphasis>
(ohne Sporn), 
<emphasis id="98F383F1D0A92ABD3A46F54EE090A432" italics="true" pageId="null" pageNumber="210">
leuchtend zitronengelb, mit orangegelbem Gaumen; Sporn etwa so lang wie die 
<normalizedToken id="5CB244F090B0FC6097392BEACD359C44" originalValue="übrige" pageId="null" pageNumber="210">uebrige</normalizedToken>
Krone. Frucht 4
</emphasis>
- 
<emphasis id="0BB127B1011E1240B399CA5D8D71A413" italics="true" pageId="null" pageNumber="210">5 mm lang.</emphasis>
Sonst wie 
<taxonomicName id="DB29B6C0AF76538A09AD0DE72B7A32EC" class="Aves" family="Fringillidae" genus="Linaria" kingdom="Animalia" order="Passeriformes" pageId="null" pageNumber="210" phylum="Chordata" rank="species" species="vulgaris">
<emphasis id="8AE681E8229B0F6FAF9838D9ABFDAE81" italics="true" pageId="null" pageNumber="210">
<authorityName id="1739551F9A2FF31AC8D9E3CF555E12C9" pageId="null" pageNumber="210">L.</authorityName>
vulgaris
</emphasis>
</taxonomicName>
(Nr. 8). - 
<normalizedToken id="214C512BC797AAC02F646C63FB48A462" originalValue="Blüte" pageId="null" pageNumber="210">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="B828B1168A2CD2C3FB639CA5358E6F91" pageId="null" pageNumber="210">
<emphasis id="502589E7AD52CA02A7EE0CD272CDC630" italics="true" pageId="null" pageNumber="210">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="01A55C2F04632AE15238AF15C8592715" pageId="null" pageNumber="210">
<emphasis id="9B51E15505B72CB1F80C6B463A59F9D2" italics="true" pageId="null" pageNumber="210">Standort.</emphasis>
Kollin, montan, seltener subalpin. Trockene, lockere, steinige, meist kalkarme 
<normalizedToken id="AF3018C23339F366A998AEFCF82451D5" originalValue="Böden" pageId="null" pageNumber="210">Boeden</normalizedToken>
in warmen Lagen. Felssteppen, Getreidefelder, 
<normalizedToken id="85563B4F344ADFD059CC5C61B2477C3A" originalValue="Gebüsche" pageId="null" pageNumber="210">Gebuesche</normalizedToken>
.
</paragraph>
<paragraph id="CA01E59781E046D357E79095C0B473E8" pageId="null" pageNumber="210">
<emphasis id="E0607C0DEB31923C83F050A2491777C7" italics="true" pageId="null" pageNumber="210">
<pageBreakToken id="FE5F85F90644B236FF254A3FF649E71D" pageId="null" pageNumber="210">Verbreitung</pageBreakToken>
. Mittel- und 
<normalizedToken id="992F7EC2D54BF28C70AD7BE51B54386E" originalValue="südeuropäische" pageId="null" pageNumber="210">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="356A67218690BB25F61EC5F84D915764" italics="true" pageId="null" pageNumber="210">
<normalizedToken id="610032223A607F757E8E1D099AC9F6A1" originalValue="südlich" pageId="null" pageNumber="210">suedlich</normalizedToken>
</emphasis>
): 
<normalizedToken id="785D0412274424C89E4F536E81696A7B" originalValue="Ostpyrenäen" pageId="null" pageNumber="210">Ostpyrenaeen</normalizedToken>
, 
<normalizedToken id="DB641BC64A6173ACE09336B7BA1B7201" originalValue="Südalpen" pageId="null" pageNumber="210">Suedalpen</normalizedToken>
, Gebirge der Balkanhalbinsel, 
<normalizedToken id="623D28CC0EE4BCD83B7F0BBBB37AEBDC" originalValue="Südkarpaten" pageId="null" pageNumber="210">Suedkarpaten</normalizedToken>
. - Im Gebiet: Savoyen (?), Wallis, Aostatal, Langenseegebiet (Lavena), 
<normalizedToken id="350BC378FCC0B65192884A4C599FD4CF" originalValue="südliches" pageId="null" pageNumber="210">suedliches</normalizedToken>
Tessin und angrenzende italienische Gebiete, Comerseegebiet, Veltlin, Puschlav (?), Gebiet von Bormio, Bergamasker Alpen (Val Brembana, Valle Seriana, Valle di Scalve), Vintschgau, 
<normalizedToken id="A505B5EB8C36B9B4220CD7C164A715F9" originalValue="Münstertal" pageId="null" pageNumber="210">Muenstertal</normalizedToken>
; nicht 
<normalizedToken id="488CC765B0D8F8DF4688E5ECF29C9922" originalValue="häufig" pageId="null" pageNumber="210">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="673EC5AA8C15F26950E70A2EA246D1AA" pageId="null" pageNumber="210">
<emphasis id="B6139A2BFC6B6B9700B616B5BDCD68E3" italics="true" pageId="null" pageNumber="210">Bemerkungen.</emphasis>
Nach 
<normalizedToken id="7F0F53466BDB79C9CC4EBE22453D04F2" originalValue="Valdès" pageId="null" pageNumber="210">Valdes</normalizedToken>
(1970) 
<normalizedToken id="93102BD45535B17F56301018D2483189" originalValue="müßte" pageId="null" pageNumber="210">muesste</normalizedToken>
die Art 
<taxonomicName id="CFC3C5C8755A65834E316B785FE749FD" authority="(Lam.) Valdes" authorityName="Valdes" baseAuthorityName="Lam." class="Aves" family="Fringillidae" genus="Linaria" kingdom="Animalia" order="Passeriformes" pageId="null" pageNumber="210" phylum="Chordata" rank="species" species="pallidiflora">
<emphasis id="96D0FEAE828FFCD1842B9951F9A9E4A0" italics="true" pageId="null" pageNumber="210">
<authorityName id="4EBBFF319170CA3D214E61B537D2A762" pageId="null" pageNumber="210">L.</authorityName>
pallidiflora
</emphasis>
(Lam.) 
<normalizedToken id="E912690D042E7D02D44F120D369E9E0B" originalValue="Valdès" pageId="null" pageNumber="210">Valdes</normalizedToken>
</taxonomicName>
<normalizedToken id="74DFD10CFE2535B43C051A99684D22AE" originalValue="heißen" pageId="null" pageNumber="210">heissen</normalizedToken>
.
</paragraph>
</subSubSection>
