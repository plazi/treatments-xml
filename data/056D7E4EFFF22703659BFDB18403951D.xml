<taxonomicName id="4AC4B4DBFFF22703659BFDB183289211" authority="Perret, 1966" authorityName="Perret" authorityYear="1966" box="[151,560,547,574]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="37" pageNumber="338" phylum="Chordata" rank="species" species="bangwae">
<emphasis id="BFB0134AFFF22703659BFDB183289211" bold="true" box="[151,560,547,574]" pageId="37" pageNumber="338">
<emphasis id="BFB0134AFFF22703659BFDB180889212" bold="true" box="[151,400,547,574]" italics="true" pageId="37" pageNumber="338">Hyperolius bangwae</emphasis>
<bibRefCitation id="E955B2A9FFF22703649BFDB183289211" author="Perret" box="[407,560,547,573]" firstAuthor="Perret" pageId="37" pageNumber="338" pagination="289 - 464" refId="ref33102" refString="Perret, J. - L. (1966) Les amphibiens du Cameroun. Zoologische Jahrbucher. Abteilung fur Systematik, Okologie und Geographie, 93, 289 - 464." type="journal article" year="1966">Perret, 1966</bibRefCitation>
</emphasis>
