<emphasis id="3C68A9482DB0A17BDBF5B14FCDEBB1D5" italics="true" pageId="0" pageNumber="1">Pristepyris ishigakiensis</emphasis>
</taxonomicName>
, male, A-E, G, H, JI170808_34, F, TH190717_42 
