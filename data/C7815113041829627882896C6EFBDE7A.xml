<subSubSection id="A3BF28D872822365BA7C8D64A70CFF02" pageId="null" pageNumber="474" type="description">
<paragraph id="60280F7B943201CC956BAA84B7ABDD11" pageId="null" pageNumber="474">
Habitus wie 
<taxonomicName id="17EEE4F38FF96C3C4BD99CBDF0743F8A" class="Magnoliopsida" family="Rosaceae" genus="Sorbus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="474" phylum="Tracheophyta" rank="species" species="aucuparia">
<emphasis id="C382A972C2A1C2246512B83947F795A1" italics="true" pageId="null" pageNumber="474">S. aucuparia</emphasis>
</taxonomicName>
(Nr. 1). 
<normalizedToken id="1A5E6461712C3687860F90E28B9D22D2" originalValue="Blätter" pageId="null" pageNumber="474">Blaetter</normalizedToken>
sehr 
<normalizedToken id="9D7EBE9EDFBEC9756870BE5E7DE83FEF" originalValue="ähnlich" pageId="null" pageNumber="474">aehnlich</normalizedToken>
denen von 
<taxonomicName id="E13F071E4E969E55D14CE6CD09767A13" class="Magnoliopsida" family="Rosaceae" genus="Sorbus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="474" phylum="Tracheophyta" rank="species" species="aucuparia">
<emphasis id="1155185250D4113843184AD63E25A2CF" italics="true" pageId="null" pageNumber="474">S. aucuparia</emphasis>
</taxonomicName>
(Nr. 1), Rand der 
<normalizedToken id="94A73EE5EDFF419D85341BBE5EEE3D14" originalValue="Teilblätter" pageId="null" pageNumber="474">Teilblaetter</normalizedToken>
jedoch 
<emphasis id="CA5CF4CC648E655F22E77A8CC057D2C0" italics="true" pageId="null" pageNumber="474">
wenigstens auf der einen Seite nur in der obern 
<normalizedToken id="146CFDB830E81ABDB2D61D869890A6CE" originalValue="Hälfte" pageId="null" pageNumber="474">Haelfte</normalizedToken>
oder in den obern
</emphasis>
⅔ 
<emphasis id="C76C344F31941CAF0F3A3F722B96E88C" italics="true" pageId="null" pageNumber="474">
mit 
<normalizedToken id="227321D65E9830F6A662AA7CEEF90456" originalValue="Zähnen" pageId="null" pageNumber="474">Zaehnen</normalizedToken>
.
</emphasis>
<normalizedToken id="254E4C268F3AE3A3B25666A65A1EEEB9" originalValue="Kronblätter" pageId="null" pageNumber="474">Kronblaetter</normalizedToken>
5-7 mm lang, 
<normalizedToken id="F668000F36AAA7F3758BD21419174F08" originalValue="weiß" pageId="null" pageNumber="474">weiss</normalizedToken>
bis 
<normalizedToken id="8D0E408ED53D42D1920DAFB941643EB3" originalValue="rötlich" pageId="null" pageNumber="474">roetlich</normalizedToken>
. 
<emphasis id="7FFA6D7A1941F74D2F9E0715F946EAF9" italics="true" pageId="null" pageNumber="474">Griffel 5.</emphasis>
Frucht 
<normalizedToken id="2B50267E4F9EC9D5EC8A861CBB71C6C0" originalValue="birnenförmig" pageId="null" pageNumber="474">birnenfoermig</normalizedToken>
, 1,5-3 cm lang, 
<normalizedToken id="DC7BE996D1C153198451747A023A22AA" originalValue="rötlich" pageId="null" pageNumber="474">roetlich</normalizedToken>
. - 
<normalizedToken id="5589EE59938707BFAE582DB2AEA0F1B7" originalValue="Blüte" pageId="null" pageNumber="474">Bluete</normalizedToken>
: 
<normalizedToken id="C4FEC9CAD1288E76F64185F3F0C33903" originalValue="Später" pageId="null" pageNumber="474">Spaeter</normalizedToken>
<normalizedToken id="423A787F224FB9FF36A17380D0A6297A" originalValue="Frühling" pageId="null" pageNumber="474">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="F9E88749E4F30125EE2AD50DB75D2A8D" pageId="null" pageNumber="474">
<emphasis id="791834C30786DAE3DE95338581F02D36" italics="true" pageId="null" pageNumber="474">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="F0F1905CB79B391943CAEBF9B89E76F2" italics="true" pageId="null" pageNumber="474">34:</emphasis>
Material aus botanischen 
<normalizedToken id="E028CDCB5F1C788A791544BD7E55B463" originalValue="Gärten" pageId="null" pageNumber="474">Gaerten</normalizedToken>
(Liljefors 1934), aus dem 
<normalizedToken id="4A9C3E0DA7A3811811808EFCAD708BC7" originalValue="Elsaß" pageId="null" pageNumber="474">Elsass</normalizedToken>
(Linder und Brun 1956).
</paragraph>
<paragraph id="8AD2A148F09E7D653F829C386022178B" pageId="null" pageNumber="474">
<emphasis id="D423CF3CC241855AE79F7D81D421A98D" italics="true" pageId="null" pageNumber="474">Standort.</emphasis>
Meist angepflanzt. 
<normalizedToken id="AFE4061F4C80D337E0C9B864326EF7D8" originalValue="Wärmebedürftige" pageId="null" pageNumber="474">Waermebeduerftige</normalizedToken>
Eichenwaldgesellschaften, wohl nur verwildert.
</paragraph>
<paragraph id="1AD48A10EE8C9F2BB46EDBCF454B5C02" pageId="null" pageNumber="474">
<emphasis id="6B8FA16E1882899BA7A4A5738FCD1E5F" italics="true" pageId="null" pageNumber="474">Verbreitung. Mediterrane Pflanze:</emphasis>
Durch das Mediterrangebiet verbreitet, 
<normalizedToken id="D5E864D396549093F5E0B6618B89DEB3" originalValue="nordwärts" pageId="null" pageNumber="474">nordwaerts</normalizedToken>
bis gegen den 
<normalizedToken id="32524B777822E90CED0B2BE60A520C32" originalValue="Alpensüdfuß" pageId="null" pageNumber="474">Alpensuedfuss</normalizedToken>
, Donaubecken; 
<normalizedToken id="ABC7D72F5977B9020A064FE7DB0806CD" originalValue="ostwärts" pageId="null" pageNumber="474">ostwaerts</normalizedToken>
bis an die 
<normalizedToken id="19D9456CBE2A9B794BD9FA41D9E7F43A" originalValue="Schwarzmeerküsten" pageId="null" pageNumber="474">Schwarzmeerkuesten</normalizedToken>
; 
<normalizedToken id="17C6B4CB98DC0C00B3292AE885E38B35" originalValue="nördlich" pageId="null" pageNumber="474">noerdlich</normalizedToken>
der Alpen wahrscheinlich nur angepflanzt und verwildert. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet gelegentlich angepflanzt, im Schaffhauser Jura verbreitet, in den 
<normalizedToken id="5CD7C129D44C534B4AA8DADA0DF317D0" originalValue="wärmsten" pageId="null" pageNumber="474">waermsten</normalizedToken>
Gegenden verwildert.
</paragraph>
</subSubSection>
