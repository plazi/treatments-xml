<subSubSection id="E9A968F715AA2E2447FE504C67432965" pageId="null" pageNumber="544" type="vernacular_names">
<paragraph id="CDF045CA5A9AED71DAE384AC3D220528" pageId="null" pageNumber="544">Faden-Yucca</paragraph>
</subSubSection>
</title>
<subSubSection id="A52BFA7C887CFC198F3AC742712D8348" pageId="null" pageNumber="544" type="description">
<paragraph id="F6B0DDB586FD413590EEAA233D81F0DD" pageId="null" pageNumber="544">
Stamm kurz. 
<emphasis id="4D677867078C71FC81057A5292062BD6" italics="true" pageId="null" pageNumber="544">
<normalizedToken id="429C62715F311E9CC646F9C364213754" originalValue="Blätter" pageId="null" pageNumber="544">Blaetter</normalizedToken>
bis 80 cm lang, am Grunde bis 10 cm breit
</emphasis>
, dick, mit 
<normalizedToken id="C74F8376840BB23EBDBC26F799C65940" originalValue="kapuzenförmiger" pageId="null" pageNumber="544">kapuzenfoermiger</normalizedToken>
, meist stechender Spitze, 
<emphasis id="78A19839C420425C785F56AF872FEE60" italics="true" pageId="null" pageNumber="544">
am Rand mit einzelnen, langen, an 
<normalizedToken id="F73FC73F088D9DE252763282C7E4BA86" originalValue="älteren" pageId="null" pageNumber="544">aelteren</normalizedToken>
<normalizedToken id="8D0D01731D38E8B9F87E0549F4E3DAA7" originalValue="Blättern" pageId="null" pageNumber="544">Blaettern</normalizedToken>
abfallenden 
<normalizedToken id="E762E60F829234D05C8A1CB45B04A6ED" originalValue="Fäden" pageId="null" pageNumber="544">Faeden</normalizedToken>
</emphasis>
. 
<normalizedToken id="4F8EE31CC417F5AFB688ED7F5DF8C316" originalValue="Blütenstand" pageId="null" pageNumber="544">Bluetenstand</normalizedToken>
(mit Stiel) bis 3 m hoch; 
<emphasis id="969156292B91E023E8D31605A57653B5" italics="true" pageId="null" pageNumber="544">Rispe verzweigt</emphasis>
, bis 
<emphasis id="DC268322EE47C3A689F851448B76CF1D" italics="true" pageId="null" pageNumber="544">
2 m hoch. 
<normalizedToken id="749E516A9EA52F7A63A4EA85838D2917" originalValue="Blüten" pageId="null" pageNumber="544">Blueten</normalizedToken>
<normalizedToken id="7417E193C20E41A76E0E48285CD028AA" originalValue="weißlich" pageId="null" pageNumber="544">weisslich</normalizedToken>
, 5-7 cm lang
</emphasis>
. 
<normalizedToken id="D11D3857E7CAD2512E6DB26A50C68F86" originalValue="Perigonblätter" pageId="null" pageNumber="544">Perigonblaetter</normalizedToken>
2-3 cm breit, abgerundet oder mit aufgesetzter Spitze. Griffel ca. 1 cm lang. Frucht eine bis 4,5 cm lange, zylindrische oder 
<normalizedToken id="A3BE6DBD835A4A14E631910DCB585AF1" originalValue="eiförmige" pageId="null" pageNumber="544">eifoermige</normalizedToken>
Kapsel. - 
<normalizedToken id="C195098319A6D65C301DF93CB8C6CE34" originalValue="Blüte" pageId="null" pageNumber="544">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="DA64782C05B45AE87F858B12F00726F0" pageId="null" pageNumber="544">
<emphasis id="4430CE6536F573EA752F4CA80129D3D9" italics="true" pageId="null" pageNumber="544">Zytologische Angaben. 2n = 60:</emphasis>
(siehe unter Gattung).
</paragraph>
<paragraph id="D908628CD051187824B8668C4892C6B8" pageId="null" pageNumber="544">
<emphasis id="A3DA1E8E7C7BF142346E63F5A92A02BF" italics="true" pageId="null" pageNumber="544">Standort.</emphasis>
Kollin. Felsige, 
<normalizedToken id="9D11CE72A13443B738FCDF36B8E1D87E" originalValue="heiße" pageId="null" pageNumber="544">heisse</normalizedToken>
und trockene 
<normalizedToken id="62D01A3D58926611CD6C51217C185916" originalValue="Hänge" pageId="null" pageNumber="544">Haenge</normalizedToken>
.
</paragraph>
<paragraph id="AC024C053C630D00AF3F107905CC6A6D" pageId="null" pageNumber="544">
<emphasis id="30AC7D609D4A67D295B56C9973A68E85" italics="true" pageId="null" pageNumber="544">
Verbreitung. 
<normalizedToken id="E518498DB431EC65928A34E0C635E03A" originalValue="Ursprünglich" pageId="null" pageNumber="544">Urspruenglich</normalizedToken>
Pflanze der 
<normalizedToken id="B0DEABF5BA1EE83E89A6ECA307090004" originalValue="Südoststaaten" pageId="null" pageNumber="544">Suedoststaaten</normalizedToken>
der USA
</emphasis>
(von Maryland bis Florida). In 
<normalizedToken id="3DDE44EA979C6881B4A161A6076FAB83" originalValue="Südeuropa" pageId="null" pageNumber="544">Suedeuropa</normalizedToken>
verwilderte Zierpflanze. - Im Gebiet: 
<normalizedToken id="169ED8CC0A37CEC13609595DC3F282F8" originalValue="Dép" pageId="null" pageNumber="544">Dep</normalizedToken>
. Ain, 
<normalizedToken id="0EBA7FE5B3BE74CA77D08F7422020FEB" originalValue="Alpensüdfuß" pageId="null" pageNumber="544">Alpensuedfuss</normalizedToken>
(z. B. 
<normalizedToken id="DB4AA7B3844D15EF6F584E6B4E4F7897" originalValue="südliches" pageId="null" pageNumber="544">suedliches</normalizedToken>
Tessin).
</paragraph>
</subSubSection>
</treatment>
