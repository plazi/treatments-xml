Yucca 
<normalizedToken id="F2665278E063E4FEFAD1BFCF6BF75E9B" originalValue="filamentósa" pageId="null" pageNumber="544">filamentosa</normalizedToken>
<authorityName id="DEBDC913250CFB7CF8F82850A8BFCB7E" pageId="null" pageNumber="544">L.</authorityName>
