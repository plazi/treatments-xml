<collectingCountry id="1EC8763CFFA8FFA9BCFFBB3116578957" box="[450,559,1619,1643]" name="Argentina" pageId="95" pageNumber="96">Argentina</collectingCountry>
and 
<collectingCountry id="1EC8763CFFA8FFA9BF59BB3116E78957" box="[612,671,1619,1643]" name="Chile" pageId="95" pageNumber="96">Chile</collectingCountry>
