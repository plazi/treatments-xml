<quantity box="[759,885,820,847]" metricMagnitude="-2" metricUnit="m" metricValue="2.2" metricValueMax="2.5" metricValueMin="1.9" pageId="18" pageNumber="34" unit="mm" value="22.0" valueMax="25.0" valueMin="19.0">19–25 mm</quantity>
