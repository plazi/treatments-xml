<taxonomicName authorityName="Dall" authorityYear="1871" box="[234,322,1391,1417]" class="Gastropoda" family="Cymbuliidae" genus="Corolla" kingdom="Animalia" order="Pteropoda" pageId="18" pageNumber="30" phylum="Mollusca" rank="genus">Corolla</taxonomicName>
