<quantity box="[1090,1234,926,953]" metricMagnitude="-2" metricUnit="m" metricValue="7.25" metricValueMax="11.5" metricValueMin="3.0" pageId="18" pageNumber="34" unit="mm" value="72.5" valueMax="115.0" valueMin="30.0">30–115 mm</quantity>
