<subSubSection id="BCBBAB13C17076D396C3583C098C7D2F" pageId="null" pageNumber="108" type="description">
<paragraph id="220F63204D1629446E5A9E10014B4C21" pageId="null" pageNumber="108">
Kelch 
<normalizedToken id="FE9C42F40D50395F187B40F90979A9E5" originalValue="röhrenförmig" pageId="null" pageNumber="108">roehrenfoermig</normalizedToken>
, etwa 15nervig, 2lippig, 
<emphasis id="B205E8BB5B6A7C44DA6B26D4CE396EA6" italics="true" pageId="null" pageNumber="108">
mit meist 1 
<normalizedToken id="3039B1E3795AFD4894878B32737614A5" originalValue="zähniger" pageId="null" pageNumber="108">zaehniger</normalizedToken>
Oberlippe und 4 
<normalizedToken id="52965158447D0BD8DCE771BAB578B271" originalValue="zähniger" pageId="null" pageNumber="108">zaehniger</normalizedToken>
Unterlippe.
</emphasis>
Krone mit vorn erweiterter 
<normalizedToken id="B80BAA213A1639DE4EA2559B11417CF4" originalValue="Röhre" pageId="null" pageNumber="108">Roehre</normalizedToken>
und undeutlich 2lippigem Rand; Oberlippe 
<normalizedToken id="0D54214383CBFD400F815508946EBD11" originalValue="aufwärts" pageId="null" pageNumber="108">aufwaerts</normalizedToken>
gebogen, 
<normalizedToken id="D1C854088FA28B843D31360755D10CF2" originalValue="±" pageId="null" pageNumber="108">+/-</normalizedToken>
flach, 2teilig, behaart, Unterlippe 3teilig. 
<normalizedToken id="1057E21AEC25B2BC4A2A4816E10B6150" originalValue="Staubblätter" pageId="null" pageNumber="108">Staubblaetter</normalizedToken>
4, 
<emphasis id="0FADC4F9BEBCE72D51F5545B10CADB49" italics="true" pageId="null" pageNumber="108">
vorn herabgebogen, wie der Griffel nicht aus der 
<normalizedToken id="AF9E80D02F64796E13788476EC829F9D" originalValue="Kronröhre" pageId="null" pageNumber="108">Kronroehre</normalizedToken>
herausragend
</emphasis>
(von 
<normalizedToken id="054054AF9253ECE08F6F66211FBDF855" originalValue="außen" pageId="null" pageNumber="108">aussen</normalizedToken>
nicht sichtbar), mit spreizenden 
<normalizedToken id="CA6C7297ED28B2C14047F8368A56D63A" originalValue="Staubbeutelhälften" pageId="null" pageNumber="108">Staubbeutelhaelften</normalizedToken>
. 
<normalizedToken id="607F31FEB2BA22407FF5FBC63A435F97" originalValue="Griffeläste" pageId="null" pageNumber="108">Griffelaeste</normalizedToken>
kurz, flach. 
<normalizedToken id="799221A535AF624FF7889A55D8BF9A30" originalValue="Teilfrüchte" pageId="null" pageNumber="108">Teilfruechte</normalizedToken>
<normalizedToken id="F68CD7EA5F611E17E383D07635EE6669" originalValue="eiförmig" pageId="null" pageNumber="108">eifoermig</normalizedToken>
, glatt.
</paragraph>
<paragraph id="2BB562E9ADBF49528F4CF2492761F203" pageId="null" pageNumber="108">
Die Gattung 
<taxonomicName id="88C4442A582EEDE7A9380D9D5F0380F5" class="Magnoliopsida" family="Lamiaceae" genus="Lavandula" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="108" phylum="Tracheophyta" rank="genus">
<emphasis id="947DF599C0A3F893F7FBE3BA3955EB32" italics="true" pageId="null" pageNumber="108">Lavandula</emphasis>
</taxonomicName>
<normalizedToken id="4754100F03633E7B898CB311C3117676" originalValue="umfaßt" pageId="null" pageNumber="108">umfasst</normalizedToken>
etwa 
<emphasis id="13C34DAF8D3C81E3AAC20F595F88C36C" italics="true" pageId="null" pageNumber="108">26 meist mediterrane Arten.</emphasis>
Monographie der Gattung von Chaytor (1937).
</paragraph>
</subSubSection>
