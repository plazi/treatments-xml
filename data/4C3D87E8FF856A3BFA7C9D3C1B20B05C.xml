<taxonomicName id="03944D7DFF856A3AF9129B7719C2B675" authorityName="Robbins" authorityYear="1983" box="[1774,1986,3374,3399]" class="Mammalia" family="Vespertilionidae" genus="Scotophilus" kingdom="Animalia" order="Chiroptera" pageId="126" pageNumber="889" phylum="Chordata" rank="species" species="nucella">Scotophilus nucella</taxonomicName>
); 284. Andrew Rebori’s Yellow Bat (
<taxonomicName id="03944D7DFF856A3AF6B69B7717C9B675" box="[2378,2505,3374,3399]" class="Mammalia" family="Vespertilionidae" genus="Scotophilus" kingdom="Animalia" order="Chiroptera" pageId="126" pageNumber="885" phylum="Chordata" rank="genus">Scotophilus</taxonomicName>
andrewreboril); 285. Western Greenish Yellow Bat (
