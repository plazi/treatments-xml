<taxonomicName id="03944D7DFF856A3AFB149B771BB4B675" baseAuthorityName="Schreber" baseAuthorityYear="1774" box="[1256,1460,3374,3399]" class="Mammalia" family="Vespertilionidae" genus="Scotophilus" kingdom="Animalia" order="Chiroptera" pageId="126" pageNumber="891" phylum="Chordata" rank="species" species="nigrita">Scotophilus nigrita</taxonomicName>
