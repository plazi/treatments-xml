); 277. East African Yellow Bat (
<taxonomicName id="03944D7DFF856A3AFBDA9B521AE4B612" authorityName="G. M. Allen" authorityYear="1914" box="[1062,1252,3339,3360]" class="Mammalia" family="Vespertilionidae" genus="Scotophilus" kingdom="Animalia" order="Chiroptera" pageId="126" pageNumber="885" phylum="Chordata" rank="species" species="altilis">Scotophilus altilis</taxonomicName>
); 278. Robust Yellow Bat (
<taxonomicName id="03944D7DFF856A3AF9FF9B5218EAB612" authorityName="Milne-Edwards" authorityYear="1881" box="[1539,1770,3339,3360]" class="Mammalia" family="Vespertilionidae" genus="Scotophilus" kingdom="Animalia" order="Chiroptera" pageId="126" pageNumber="885" phylum="Chordata" rank="species" species="robustus">Scotophilus robustus</taxonomicName>
