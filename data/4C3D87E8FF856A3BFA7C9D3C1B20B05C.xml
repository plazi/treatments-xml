<taxonomicName id="03944D7DFF856A3AFD799A861D80B7CA" authorityName="Sody" authorityYear="1928" box="[645,896,3295,3320]" class="Mammalia" family="Vespertilionidae" genus="Scotophilus" kingdom="Animalia" order="Chiroptera" pageId="126" pageNumber="886" phylum="Chordata" rank="species" species="celebensis">Scotophilus celebensis</taxonomicName>
