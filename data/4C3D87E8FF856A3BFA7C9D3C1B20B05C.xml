<taxonomicName id="03944D7DFF856A3AF7FA9B521707B612" baseAuthorityName="E. Geoffroy" baseAuthorityYear="1803" box="[2054,2311,3339,3360]" class="Mammalia" family="Vespertilionidae" genus="Scotophilus" kingdom="Animalia" order="Chiroptera" pageId="126" pageNumber="885" phylum="Chordata" rank="species" species="borbonicus">Scotophilus borbonicus</taxonomicName>
