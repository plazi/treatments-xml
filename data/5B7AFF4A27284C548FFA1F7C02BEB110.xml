<td id="B7E4EAE69C03D45CF17947A29BD7EB78" align="left" pageId="null" pageNumber="310" valign="top">
1. Stengel 
<normalizedToken id="387F88B64DD1B74636EB33B94838B9A2" originalValue="sommergrün" pageId="null" pageNumber="310">sommergruen</normalizedToken>
; 
<normalizedToken id="7FC7A9E0C9E9C246DF8992FFDA01F61E" originalValue="Blätter" pageId="null" pageNumber="310">Blaetter</normalizedToken>
kurz gestielt; Krone im Durchmesser 2-3 mm; Staubbeutel schmal 
<normalizedToken id="1B066126E58C103103484203BD6D99CF" originalValue="eiförmig" pageId="null" pageNumber="310">eifoermig</normalizedToken>
, 0,5-0,6 mm lang
