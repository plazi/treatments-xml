<normalizedToken id="2BB9D932F76D18A384009042A8677E69" originalValue="immergrün" pageId="null" pageNumber="310">immergruen</normalizedToken>
, 
<italic id="D78E61D2CFAC4C69835CE55375E05CC3" pageId="null" pageNumber="310">
<normalizedToken id="FAD851F53F407A7DEF1E2534BBEEF211" originalValue="±" pageId="null" pageNumber="310">+/-</normalizedToken>
</italic>
