<normalizedToken id="41384E756F974D384528C4AFCE959628" originalValue="Blätter" pageId="null" pageNumber="310">Blaetter</normalizedToken>
ungestielt; Krone im Durchmesser 3-6 mm; Staubbeutel 
<normalizedToken id="EA30522ED02254F0EA618F4DB0CDE290" originalValue="±" pageId="null" pageNumber="310">+/-</normalizedToken>
