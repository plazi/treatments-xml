<taxonomicName id="B90E24FA44629DF197B6145A5C67CED7" class="Magnoliopsida" family="Rubiaceae" genus="Rubia" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="310" phylum="Tracheophyta" rank="species" species="tinctorum">
<italic id="9F7E1A52D91E8AF0850199EE4A1A71E9" pageId="null" pageNumber="310">R. tinctorum</italic>
