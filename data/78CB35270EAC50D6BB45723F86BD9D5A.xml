<bibRefCitation id="46165731DBA386699B35348BDEF34BE5" DOI="https://doi.org/10.24272/j.issn.2095-8137.2017.043" author="Suwannapoom, C" journalOrPublisher="Zoological Research" pageId="0" pageNumber="169" pagination="243 - 250" refId="B82" refString="Suwannapoom, C, Yuan, ZY, Jiang, K, Yan, F, Gao, W, Che, J, 2017. A new species of rain-pool frog (Dicroglossidae: Fejervarya) from western Thailand. Zoological Research 38: 243 - 250, DOI: https://doi.org/10.24272/j.issn.2095-8137.2017.043" title="A new species of rain-pool frog (Dicroglossidae: Fejervarya) from western Thailand." url="https://doi.org/10.24272/j.issn.2095-8137.2017.043" volume="38" year="2017">Suwannapoom et al. 2017</bibRefCitation>
).
</paragraph>
