<emphasis id="05A47FA340A548B6A9224436F767241E" italics="true" pageId="0" pageNumber="169">Minervarya charlesdarwini</emphasis>
</taxonomicName>
, 
<taxonomicName id="BC9E256A12140AD40847FAC95EE47085" genus="M." lsidName="M. andamanensis" pageId="0" pageNumber="169" rank="species" species="andamanensis">
<emphasis id="3A9552678B0DEFD3467387A6367CF415" italics="true" pageId="0" pageNumber="169">M. andamanensis</emphasis>
</taxonomicName>
, 
<taxonomicName id="3887358B94ABF42D75DB1867AA132AC6" genus="M." lsidName="M. muangkanensis" pageId="0" pageNumber="169" rank="species" species="muangkanensis">
<emphasis id="1CBDB3867BC480BC982E0F1160F95908" italics="true" pageId="0" pageNumber="169">M. muangkanensis</emphasis>
</taxonomicName>
