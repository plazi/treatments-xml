3. 
<taxonomicName id="4C284682FFFAC10C7FFBFC94FCC1F510" authority="(Bosch &amp; Sande Lac.) P. E. A. S. Camara" authorityName="P. E. A. S. Camara" baseAuthorityName="Bosch &amp; Sande Lac." box="[164,856,806,833]" class="Bryopsida" family="Hypnaceae" genus="Phyllodon" kingdom="Plantae" order="Hypnales" pageId="10" pageNumber="235" phylum="Bryophyta" rank="species" species="glossoides">
