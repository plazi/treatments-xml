<taxonomicName id="4C096BDAFFC9FFAC6005F8E4C7DEF8C9" authorityName="Chatterjee &amp; Chang" authorityYear="2004" box="[322,645,1842,1868]" class="Arachnida" family="Halacaridae" genus="Copidognathus" kingdom="Animalia" order="Trombidiformes" pageId="5" pageNumber="306" phylum="Arthropoda" rank="species" species="mumbaiensis">
