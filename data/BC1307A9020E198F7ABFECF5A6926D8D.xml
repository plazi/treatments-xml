<taxonomicName id="40884FE2FFF94BD36B4214867C1DE287" authority="L." class="Magnoliopsida" family="Gentianaceae" genus="Gentiana" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="24" phylum="Tracheophyta" rank="species" species="purpurea">
Gentiana 
<normalizedToken id="880556B47D2E6A8D54F7212BEE2ECF29" originalValue="purpúrea" pageId="null" pageNumber="24">purpurea</normalizedToken>
<authorityName id="E9C898BF6E1DE31F926F45C8F4C5D20B" pageId="null" pageNumber="24">L.</authorityName>
