<taxonomicName id="C7C97DC28E9DFF134928569BFE01FE3F" baseAuthorityName="Guglielmino &amp; Olmi" baseAuthorityYear="1997" box="[280,420,439,463]" class="Insecta" family="Cicadellidae" kingdom="Animalia" order="Hemiptera" pageId="211" pageNumber="212" phylum="Arthropoda" rank="family">Cicadellidae</taxonomicName>
