<subSubSection id="310D96C3D20AE0FB5131F1BB0E57B9FB" pageId="null" pageNumber="326" type="description">
<paragraph id="5E699E6A6B8C09C85DE778CD315115F6" pageId="null" pageNumber="326">
5-15 cm hoch. Rhizom mit wenigen bis zahlreichen Trieben, kleine, dichte Horste bildend, 
<normalizedToken id="8E1B2DD765B21A88E7787A13F7A01080" originalValue="höchstens" pageId="null" pageNumber="326">hoechstens</normalizedToken>
von einzelnen schwarzen Blattresten 
<normalizedToken id="4F5AB8DC6BEE119E44D04EA14F1791D9" originalValue="umhüllt" pageId="null" pageNumber="326">umhuellt</normalizedToken>
. Stengel aufrecht, kahl, mit 0-1 Blattpaaren bis zum 
<normalizedToken id="3CBA08359AE346BB6D526DFA5F062280" originalValue="Blütenstand" pageId="null" pageNumber="326">Bluetenstand</normalizedToken>
. 
<normalizedToken id="4333B64A74CAA0B6EB2DCCD110EDA48C" originalValue="Grundständige" pageId="null" pageNumber="326">Grundstaendige</normalizedToken>
<normalizedToken id="3F5E4727311FFA486AE1F7E34DA4D56E" originalValue="Blätter" pageId="null" pageNumber="326">Blaetter</normalizedToken>
oval, 0,4-1 cm breit, 
<normalizedToken id="E0BFA2EF583450CBE854865BF13E746D" originalValue="1½" pageId="null" pageNumber="326">11/2</normalizedToken>
-4mal so lang wie breit (ohne Stiel), ganzrandig, 
<normalizedToken id="4DDB848838B4CC7978E8AD8EA95E6278" originalValue="allmählich" pageId="null" pageNumber="326">allmaehlich</normalizedToken>
in den kurzen Stiel 
<normalizedToken id="B7684048CA536DDF596C76100AB75010" originalValue="verschmälert" pageId="null" pageNumber="326">verschmaelert</normalizedToken>
, kahl; 
<normalizedToken id="E3E420DBFE11306D35F0505D2BEA9671" originalValue="stengelständige" pageId="null" pageNumber="326">stengelstaendige</normalizedToken>
<normalizedToken id="C0527AB751E7BE5E98C28D9EFD14A931" originalValue="Blätter" pageId="null" pageNumber="326">Blaetter</normalizedToken>
kleiner, schmal lanzettlich, ganzrandig oder jederseits mit 1-2 
<normalizedToken id="2DFB80C2BAB866630D208F4D64A12605" originalValue="Zähnen" pageId="null" pageNumber="326">Zaehnen</normalizedToken>
oder Zipfeln, kahl oder am Rand mit 0,2 mm langen Haaren. 
<emphasis id="9866D7129CDDDFC9C96656B7E345E864" italics="true" pageId="null" pageNumber="326">
<normalizedToken id="59DFDADF98B68E04A3CB7B982233AF2B" originalValue="Blütenstand" pageId="null" pageNumber="326">Bluetenstand</normalizedToken>
<normalizedToken id="9856991165F960E0ABEA776557E5D28C" originalValue="wenigblütig" pageId="null" pageNumber="326">wenigbluetig</normalizedToken>
, kopfartig
</emphasis>
, von schmal lanzett- 
<pageBreakToken id="0F5E770FD5BF22B302AEA0F1E12340DE" pageId="null" pageNumber="326">lichen</pageBreakToken>
, am Rande behaarten 
<normalizedToken id="2F92A39F58900259715F2A7DC5047919" originalValue="Hochblättern" pageId="null" pageNumber="326">Hochblaettern</normalizedToken>
umgeben. Krone der meist ⚥ 
<normalizedToken id="16AF801512D06AE0CFE6F2701C21821C" originalValue="Blüten" pageId="null" pageNumber="326">Blueten</normalizedToken>
4-5,5 mm lang, 
<emphasis id="272F54149F62C7128185FD377C44EE02" italics="true" pageId="null" pageNumber="326">rosa</emphasis>
, mit 
<normalizedToken id="712BC8A01D6BA3602E99FD189B2DD122" originalValue="zungenförmigen" pageId="null" pageNumber="326">zungenfoermigen</normalizedToken>
Zipfeln. 
<emphasis id="B1C7D94E0B76BCCA692962EB544F3488" italics="true" pageId="null" pageNumber="326">
<normalizedToken id="698B24BABF6BEFC9194E11091E97F3F6" originalValue="Früchte" pageId="null" pageNumber="326">Fruechte</normalizedToken>
5
</emphasis>
- 
<emphasis id="6D4AC7B0001DA66165BEEFEEC89C27C1" italics="true" pageId="null" pageNumber="326">6 mm lang</emphasis>
, kahl; Pappusborsten 15-20, 6-10 mm lang. - 
<normalizedToken id="60933895626458D24C02524D02CF3328" originalValue="Blüte" pageId="null" pageNumber="326">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="BBC1EB0790FAF09A43274C9AD88A4FDD" pageId="null" pageNumber="326">
<emphasis id="5B2CDDC5939C61B512ECE251BA0CF7E9" italics="true" pageId="null" pageNumber="326">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="1809974F7F249A5B80B8317322CFDF38" italics="true" pageId="null" pageNumber="326">16:</emphasis>
Material aus den Westalpen (Col de la Cayolle) (Favarger 1965).
</paragraph>
<paragraph id="96FE7FD6B597FD9792F1930038C04652" pageId="null" pageNumber="326">
<emphasis id="4B81F9600260F97FF262FD75FA3B502B" italics="true" pageId="null" pageNumber="326">Standort.</emphasis>
Alpin, selten subalpin. Felsige oder steinige 
<normalizedToken id="AA75114A6C37EDF460D6D480B1EAACFE" originalValue="Böden" pageId="null" pageNumber="326">Boeden</normalizedToken>
, meist 
<normalizedToken id="A9AB287B8B66851C531EB78370D05CA4" originalValue="über" pageId="null" pageNumber="326">ueber</normalizedToken>
Kalk. Felsschutt, steinige Weiden.
</paragraph>
<paragraph id="F53779FB906ED30E7C1BCE92403482E0" pageId="null" pageNumber="326">
<emphasis id="B6BEF9BFEC410E597D888BFD9629487F" italics="true" pageId="null" pageNumber="326">
Verbreitung. Mittel- und 
<normalizedToken id="661E9FDDB88A77610296D69D58E78C60" originalValue="südeuropäische" pageId="null" pageNumber="326">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="DE35D67D93C210C23FA91773663CB7A7" italics="true" pageId="null" pageNumber="326">westlich</emphasis>
)
<emphasis id="DB906B2CA20B1F1D31B2B35125B860BE" italics="true" pageId="null" pageNumber="326">:</emphasis>
<normalizedToken id="1E481678C9040322FEFD0F89256D88F3" originalValue="Pyrenäen" pageId="null" pageNumber="326">Pyrenaeen</normalizedToken>
, Westalpen (
<normalizedToken id="A36066F30A18E49C8A745EFC225F28B4" originalValue="ostwärts" pageId="null" pageNumber="326">ostwaerts</normalizedToken>
bis ins Berner Oberland und in den 
<normalizedToken id="CD609EFF1404D1E0A1A91AEE26F36ED5" originalValue="Südalpen" pageId="null" pageNumber="326">Suedalpen</normalizedToken>
vereinzelt bis ins 
<normalizedToken id="DF11DF03C1806AE62D2839789B0C8F5E" originalValue="Südtirol" pageId="null" pageNumber="326">Suedtirol</normalizedToken>
), Abruzzen. Verbreitungskarte von 
<normalizedToken id="DE7AC7F34056EBE271E4E9893A953EBD" originalValue="Merxmüller" pageId="null" pageNumber="326">Merxmueller</normalizedToken>
(1962). - Im Gebiet: Savoyen (Mont 
<normalizedToken id="D19B9C4309536F33C1C2DAC5E8ABFE69" originalValue="Méry" pageId="null" pageNumber="326">Mery</normalizedToken>
, Pointe 
<normalizedToken id="4980C7AEA6DC8AF0F094DDBA3EB5304B" originalValue="Percée" pageId="null" pageNumber="326">Percee</normalizedToken>
, Col de Champ-Rossu, Mont Cenis), Aostatal (Kleiner Sankt Bernhard, Gegend von Cogne), Wallis (wenige Fundstellen zwischen Simplon und 
<normalizedToken id="5B9DA06E850C027381FEF73B87FD7E81" originalValue="Nufenenpaß" pageId="null" pageNumber="326">Nufenenpass</normalizedToken>
und zwlschen Dent de Morcle und Tubang oberhalb Siders), Valle 
<normalizedToken id="7C9C26CCABA720A1CC25D7CA93B78542" originalValue="d’Ossola" pageId="null" pageNumber="326">d'Ossola</normalizedToken>
(Valle Anzasca), Freiburger Alpen (Massif de Morteys, Kaiseregg), Bergamasker Alpen (Monte Stabio, auf Granit, nach Arietti 1944); selten.
</paragraph>
</subSubSection>
