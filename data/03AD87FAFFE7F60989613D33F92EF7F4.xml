(
<taxonomicName id="4C044D6FFFE7F60988403F97FE0AF437" authorityName="Kerr" authorityYear="1792" box="[350,431,2955,2988]" class="Dothideomycetes" family="Pteropodidae" genus="Pteropus" kingdom="Fungi" order="Chiroptera" pageId="35" pageNumber="93" phylum="Ascomycota" rank="species" species="niger">
