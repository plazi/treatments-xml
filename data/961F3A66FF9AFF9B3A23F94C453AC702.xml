<taxonomicName id="D9B6F0F3FF98FF9B39E0FEF1442EC721" authorityName="Olmi" authorityYear="1984" box="[390,566,311,337]" class="Insecta" family="Dryinidae" genus="Aphelopus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="23" pageNumber="63" phylum="Arthropoda" rank="species" species="penanganus">
