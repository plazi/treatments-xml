<collectingRegion id="E20058913D42FFA5FDBDFB06FCE1FB7F" box="[567,778,1231,1257]" country="Colombia" name="Narino" pageId="49" pageNumber="50">Nariño department</collectingRegion>
(
<figureCitation id="B8FF8AF63D42FFA5FC93FB06FC87FB7F" box="[793,876,1231,1257]" captionStart="FIGURE 33" captionStartId="59.[151,250,1943,1967]" captionTargetBox="[198,1395,187,1920]" captionTargetId="figure-18@59.[192,1395,181,1920]" captionTargetPageId="59" captionText="FIGURE 33. Distribution of species of the philipi group in Colombia." figureDoi="http://doi.org/10.5281/zenodo.4468455" httpUri="https://zenodo.org/record/4468455/files/figure.png" pageId="49" pageNumber="50">Fig. 33</figureCitation>
