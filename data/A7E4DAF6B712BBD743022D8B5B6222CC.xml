<subSubSection id="E7DAB127A6745E67FD03D54483FD6157" pageId="null" pageNumber="223" type="vernacular_names">
<paragraph id="5870600A5862810B2C9E901A05F07CBC" pageId="null" pageNumber="223">Wasserpest</paragraph>
</subSubSection>
</title>
<subSubSection id="8B1780C4EDE6BB3DA82475296AE9074F" pageId="null" pageNumber="223" type="description">
<paragraph id="8695753B7145102DD98963F414F56394" pageId="null" pageNumber="223">
Untergetauchte, ausdauernde Wasserpflanzen. 
<emphasis id="6245885B5C63045E1F1DD38FDFE9B949" italics="true" pageId="null" pageNumber="223">
Stengel in der ganzen 
<normalizedToken id="41F77673CE6756AF8770789B28404435" originalValue="Länge" pageId="null" pageNumber="223">Laenge</normalizedToken>
<normalizedToken id="4F4F799B50CF40E4DA41FC5F84405D31" originalValue="beblättert" pageId="null" pageNumber="223">beblaettert</normalizedToken>
. 
<normalizedToken id="9B7B1BC5A9EC7F325DF03EAB5305C205" originalValue="Blätter" pageId="null" pageNumber="223">Blaetter</normalizedToken>
<normalizedToken id="877EE25B400F1A81704E529B5E40E0DF" originalValue="quirlständig" pageId="null" pageNumber="223">quirlstaendig</normalizedToken>
</emphasis>
, sehr fein 
<normalizedToken id="2C62C190FDCAF54358CCA46BCCD3F486" originalValue="gezähnt" pageId="null" pageNumber="223">gezaehnt</normalizedToken>
. Pflanzen meist 2 
<normalizedToken id="401327BF7D11672BB14F7CE78D988E88" originalValue="häusig" pageId="null" pageNumber="223">haeusig</normalizedToken>
(eingeschlechtig). ♂ 
<emphasis id="1EBB5B7E7C33C8236243654032F1C509" italics="true" pageId="null" pageNumber="223">
<normalizedToken id="F3D3D94544DAA74075A7C431F0FB99F2" originalValue="Blüten" pageId="null" pageNumber="223">Blueten</normalizedToken>
:
</emphasis>
Zahlreiche Knospen von in Blattachsel sitzender 
<taxonomicName id="794E57D6BA988E96F41E6BD3118559A1" class="Bivalvia" family="Iridinidae" genus="Spatha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Unionida" pageId="null" pageNumber="223" phylum="Mollusca" rank="genus">Spatha</taxonomicName>
gemeinsam umschlossen; wenn 
<taxonomicName id="668A1CB03BB5A136965EB587BA129F66" class="Bivalvia" family="Iridinidae" genus="Spatha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Unionida" pageId="null" pageNumber="223" phylum="Mollusca" rank="genus">Spatha</taxonomicName>
sich 
<normalizedToken id="73F254485C3A14AE546F37CE519B665A" originalValue="öffnet" pageId="null" pageNumber="223">oeffnet</normalizedToken>
, 
<emphasis id="CB7D33DEC86F83CEC39918042CCB0D6F" italics="true" pageId="null" pageNumber="223">
<normalizedToken id="D964C50D49525CA0C302784368F47DB8" originalValue="lösen" pageId="null" pageNumber="223">loesen</normalizedToken>
sich Knospen von den 
<normalizedToken id="B3D85D80FAAB37C52E4687F006F3B255" originalValue="dünnen" pageId="null" pageNumber="223">duennen</normalizedToken>
Stielen, steigen an die 
<normalizedToken id="BB81EF6E3FD0BB9F2C8E4BB868B5B977" originalValue="Oberfläche" pageId="null" pageNumber="223">Oberflaeche</normalizedToken>
, 
<normalizedToken id="AA0891B3E943CA123A0147F64D2FE665" originalValue="öffnen" pageId="null" pageNumber="223">oeffnen</normalizedToken>
sich und schwimmen frei herum.
</emphasis>
♀ 
<emphasis id="FF05D8B84AA61BB13887D6D147DE548D" italics="true" pageId="null" pageNumber="223">
<normalizedToken id="9F0DDB7FB5C717A1AC2C19867A3B0BEF" originalValue="Blüten" pageId="null" pageNumber="223">Blueten</normalizedToken>
:
</emphasis>
<taxonomicName id="83B30A84ECB0AB94C6B822A9069E0F76" class="Bivalvia" family="Iridinidae" genus="Spatha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Unionida" pageId="null" pageNumber="223" phylum="Mollusca" rank="genus">Spatha</taxonomicName>
sitzend oder auf kurzem Stengel; 
<emphasis id="8EC0503CA20723970D352D5B4D8E5E18" italics="true" pageId="null" pageNumber="223">
nur 1 Knospe in jeder 
<taxonomicName id="EDF34D750C2885A0317E73BE877777C1" class="Bivalvia" family="Iridinidae" genus="Spatha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Unionida" pageId="null" pageNumber="223" phylum="Mollusca" rank="genus">Spatha</taxonomicName>
; 
<normalizedToken id="000BE5D8E4B9C11431157D1EB6404768" originalValue="fadenförmiger" pageId="null" pageNumber="223">fadenfoermiger</normalizedToken>
, 
<normalizedToken id="56EABB4AEBB516AEE9CA8A963B376BDC" originalValue="stielähnlicher" pageId="null" pageNumber="223">stielaehnlicher</normalizedToken>
Halsteil der 
<normalizedToken id="4619A8FF2A2979811C071F399753B917" originalValue="Blüte" pageId="null" pageNumber="223">Bluete</normalizedToken>
bis an die 
<normalizedToken id="67FCC960BE0B4E0341C37EF5FCC5742D" originalValue="Wasseroberfläche" pageId="null" pageNumber="223">Wasseroberflaeche</normalizedToken>
reichend.
</emphasis>
Frucht von 
<taxonomicName id="A7741430EE08D858B86865C062483C29" class="Bivalvia" family="Iridinidae" genus="Spatha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Unionida" pageId="null" pageNumber="223" phylum="Mollusca" rank="genus">Spatha</taxonomicName>
umschlossen, 1 
<normalizedToken id="A6CA2C8FA11BDF427B3026C2B9C0CA68" originalValue="fächerig" pageId="null" pageNumber="223">faecherig</normalizedToken>
, mit wenigen Samenanlagen.
</paragraph>
<paragraph id="D01B88AD1B47857B12D5D98BC507B546" pageId="null" pageNumber="223">
Die Gattung 
<taxonomicName id="F6A2B7720DDE1F5B6E85398FC4F8282D" class="Liliopsida" family="Hydrocharitaceae" genus="Helodea" higherTaxonomySource="GBIF" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="223" phylum="Tracheophyta" rank="genus">
<emphasis id="338F2A519F0BD706117A626BE823145A" italics="true" pageId="null" pageNumber="223">Helodea</emphasis>
</taxonomicName>
<normalizedToken id="945F941009B0458B5FB0A1BDEFB2B5E9" originalValue="umfaßt" pageId="null" pageNumber="223">umfasst</normalizedToken>
nach der Monographie von St. John (1965) 
<emphasis id="43CA9F4CDBB1C3ADDB912D85FA6868F8" italics="true" pageId="null" pageNumber="223">21 Arten</emphasis>
, die 
<normalizedToken id="11C579E8A642194BD593AC53C6C8B2F8" originalValue="ursprünglich" pageId="null" pageNumber="223">urspruenglich</normalizedToken>
im 
<emphasis id="A23774C328E75E91661B22D506C6147B" italics="true" pageId="null" pageNumber="223">
<normalizedToken id="154AC1609D1A565E893308689099B00F" originalValue="gemäβigten" pageId="null" pageNumber="223">gemaeβigten</normalizedToken>
und tropischen Amerika verbreitet sind;
</emphasis>
2 Arten sind bei uns eingeschleppt.
</paragraph>
<paragraph id="AF902952CDDC45ABDACBFAD0518812FA" pageId="null" pageNumber="223">
Die griechische Schreibweise 
<taxonomicName id="E352759F13AA4FC7C1A2C73CE8CC74EB" class="Liliopsida" family="Hydrocharitaceae" genus="Helodea" higherTaxonomySource="GBIF" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="223" phylum="Tracheophyta" rank="genus">
<emphasis id="1FC01E722282ABACCE1F452DB9E493F0" italics="true" pageId="null" pageNumber="223">Helodea</emphasis>
</taxonomicName>
(nicht 
<taxonomicName id="F5EAC5C2D5049ADBB190CDF516ECEA3E" class="Liliopsida" family="Hydrocharitaceae" genus="Elodea" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="223" phylum="Tracheophyta" rank="genus">
<emphasis id="76A9F1C9C4E1E66979B9F1D2DCE05BAD" italics="true" pageId="null" pageNumber="223">Elodea</emphasis>
</taxonomicName>
) ist richtig. Den neu vorgeschlagenen 
<normalizedToken id="27E7767B8E0FCB45AB9D69F77CD4A0E4" originalValue="ungebräuchlichen" pageId="null" pageNumber="223">ungebraeuchlichen</normalizedToken>
Gattungsnamen 
<taxonomicName id="92E7FF520F83AAC86FE32CE2F687A695" authority="L. C. Rieh" authorityName="L. C. Rieh" class="Liliopsida" family="Hydrocharitaceae" genus="Anacharis" higherTaxonomySource="GBIF" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="223" phylum="Tracheophyta" rank="genus">
<emphasis id="38863512D962891D4255F8EBB9EBCF5D" italics="true" pageId="null" pageNumber="223">Anacharis</emphasis>
<authorityName id="AB8A0D753DF25F2E7D469EF0BE728710" pageId="null" pageNumber="223">L.</authorityName>
C. Rieh
</taxonomicName>
, 
<normalizedToken id="AC7DECC827AB89F4A8E9D5656042DE8A" originalValue="übernehmen" pageId="null" pageNumber="223">uebernehmen</normalizedToken>
wir nicht.
</paragraph>
