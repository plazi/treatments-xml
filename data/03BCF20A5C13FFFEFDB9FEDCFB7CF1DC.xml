<taxonomicName id="4C15389F5C13FFFEFF52FDB3FE78F06C" authority="Zhu &amp; Shi &amp; Zhou, 2022" authorityName="Zhu &amp; Shi &amp; Zhou" authorityYear="2022" box="[189,464,513,539]" class="Insecta" family="Rhaphidophoridae" genus="Megatachycines" kingdom="Animalia" order="Orthoptera" pageId="3" pageNumber="4" phylum="Arthropoda" rank="species" species="pentus" status="gen. et sp. nov.">
