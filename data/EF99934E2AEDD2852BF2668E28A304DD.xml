<subSubSection id="2EF9F97B1FD7557BA69557FCBE8C4713" pageId="null" pageNumber="574" type="description">
<paragraph id="FDB312DBF5318512CC88EBD539A454F2" pageId="null" pageNumber="574">
Ausdauernd; 15-80 cm hoch: Stengel meist 
<normalizedToken id="47DBB61BD18B82708B9D6275AC1EDCD8" originalValue="einköpfig" pageId="null" pageNumber="574">einkoepfig</normalizedToken>
, bis auf 5-10 cm unterhalb des Kopfes 
<normalizedToken id="8FA8382183B89FB7A607AF39E058896F" originalValue="beblättert" pageId="null" pageNumber="574">beblaettert</normalizedToken>
, meist ohne braunrote Streifen. 
<emphasis id="92FAF5CA3B25680A16DE7178D04ACFEA" italics="true" pageId="null" pageNumber="574">
<normalizedToken id="A50FEF3BF58D4C3877A7EED57A79F6E4" originalValue="Blätter" pageId="null" pageNumber="574">Blaetter</normalizedToken>
</emphasis>
<normalizedToken id="E1DCFB46672D1998D1411A5BB35F5AC7" originalValue="±" pageId="null" pageNumber="574">+/-</normalizedToken>
<emphasis id="AC5B7DDC6BBC65C9F1FA1F6D6B2BD388" italics="true" pageId="null" pageNumber="574">fleischig</emphasis>
, hart, am Rande jederseits mit 10-20 spitzen, feinen, 
<emphasis id="241A46A4DB96FE5411E705C140EC07D3" italics="true" pageId="null" pageNumber="574">nach vorn gerichteten, konvex zugespitzten</emphasis>
<normalizedToken id="A1C0FF22D5DB9754E5B7A9ED857F29F2" originalValue="Zähnen" pageId="null" pageNumber="574">Zaehnen</normalizedToken>
; 
<emphasis id="D57559FF2D80689E3F97744E01EB1300" italics="true" pageId="null" pageNumber="574">
die untern 
<normalizedToken id="D5530764AC7B251C04E9EE42EDE8F145" originalValue="Blätter" pageId="null" pageNumber="574">Blaetter</normalizedToken>
spitz
</emphasis>
, die mittleren und obern 
<normalizedToken id="454C4C8B4D97BC428EE293FC84CAC6BB" originalValue="Blätter" pageId="null" pageNumber="574">Blaetter</normalizedToken>
mit abgerundetem Grunde sitzend, ohne Zipfel und 
<normalizedToken id="C52AFED362A5A1E2834A076D900FC521" originalValue="Zähne" pageId="null" pageNumber="574">Zaehne</normalizedToken>
am Grunde, oft fast ganzrandig, 
<emphasis id="FC978D14D9F8ECBDD1FA171510412D1C" italics="true" pageId="null" pageNumber="574">
oft 
<normalizedToken id="F061B4047B767891CAD4E1A7E5F4B64F" originalValue="blaugrün" pageId="null" pageNumber="574">blaugruen</normalizedToken>
</emphasis>
(nur bei dieser Art der Gruppe im Gebiet so!). 
<normalizedToken id="C74874D502B25C8E2F43BDD2FE03AE5C" originalValue="Köpfe" pageId="null" pageNumber="574">Koepfe</normalizedToken>
im Durchmesser 4-7 cm. 
<normalizedToken id="C824E76670C37368B98D73B30D67ED40" originalValue="Hüllblätter" pageId="null" pageNumber="574">Huellblaetter</normalizedToken>
<normalizedToken id="262B8BBCCDDD667DD38CC39D5A3A7589" originalValue="bräunlich" pageId="null" pageNumber="574">braeunlich</normalizedToken>
berandet (an den Seiten Rand sehr schmal). 
<normalizedToken id="239FD08CD7DBA9AF1D7C2C5668CD173F" originalValue="Früchte" pageId="null" pageNumber="574">Fruechte</normalizedToken>
2,5-3,5 mm lang, die 
<normalizedToken id="2E339F0FC83F19F9F50A60F4A4DDB48B" originalValue="äußern" pageId="null" pageNumber="574">aeussern</normalizedToken>
<normalizedToken id="DBE8DE6C71577CE863D7E4E94847D778" originalValue="Früchte" pageId="null" pageNumber="574">Fruechte</normalizedToken>
oben mit deutlichem, 
<normalizedToken id="1A3C0B746F89F365BBFED2F8D1DB205B" originalValue="gezähntem" pageId="null" pageNumber="574">gezaehntem</normalizedToken>
Rand. - 
<normalizedToken id="74DD337510FE8E8DB06CEA1B581EB4B3" originalValue="Blüte" pageId="null" pageNumber="574">Bluete</normalizedToken>
: 
<normalizedToken id="1446DB60E325997CE6109997E5173E90" originalValue="Später" pageId="null" pageNumber="574">Spaeter</normalizedToken>
Sommer und 
<normalizedToken id="F7F69E908AC4D74CD22EEBCAD18D3CDF" originalValue="früher" pageId="null" pageNumber="574">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="FB1F9AE5A89DE8AC3960DD61C7385D20" pageId="null" pageNumber="574">
<emphasis id="6609120311D248C8CA08E510AADB575D" italics="true" pageId="null" pageNumber="574">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="298001EA9090D57A1C4B2DFC304C4D74" italics="true" pageId="null" pageNumber="574">72:</emphasis>
Material von vielen Stellen aus den 
<normalizedToken id="6505D937B6ACA2E0D8D34D6343CBFF0A" originalValue="Südalpen" pageId="null" pageNumber="574">Suedalpen</normalizedToken>
und Jugoslawien (Favarger 1959, Favarger und Villard 1965, Polatschek 1966a, Villard 1970).
</paragraph>
<paragraph id="83A3D5C2093FEEEBE6E40A3EC5463BB1" pageId="null" pageNumber="574">
<emphasis id="0E9C0E66F1646576499123E44B5DDD17" italics="true" pageId="null" pageNumber="574">Standort.</emphasis>
Montan und subalpin, seltener kollin. Lockere, kalkreiche 
<normalizedToken id="5049A32B6BAC89F0C31EE2EDC5463B53" originalValue="Böden" pageId="null" pageNumber="574">Boeden</normalizedToken>
. Grasige 
<normalizedToken id="04E8112564E707BF6CCCA5D2DBE57D9D" originalValue="Hänge" pageId="null" pageNumber="574">Haenge</normalizedToken>
.
</paragraph>
<paragraph id="A23531AE1051DED330AD891FE3BB6203" pageId="null" pageNumber="574">
<emphasis id="31FEFEDD4856DE147A35C11A0A7816F6" italics="true" pageId="null" pageNumber="574">
Verbreitung. 
<normalizedToken id="571CD1623861A1AB819E39422C5A89B2" originalValue="Südalpen-Pflanze" pageId="null" pageNumber="574">Suedalpen-Pflanze</normalizedToken>
:
</emphasis>
Cottische Alpen bis Karawanken. - Im Gebiet: Aostatal (?), 
<normalizedToken id="D7796E1D237D57464D6F941066A81CDF" originalValue="südliches" pageId="null" pageNumber="574">suedliches</normalizedToken>
Tessin, Comerseegebiet, Bergamasker Alpen.
</paragraph>
</subSubSection>
