<paragraph blockId="8.[151,807,1827,1854]" box="[151,807,1827,1854]" pageId="8" pageNumber="59">
<heading bold="true" box="[151,807,1827,1854]" fontSize="11" level="1" pageId="8" pageNumber="59" reason="1">
<taxonomicName authority="Kurshakov &amp; Zolotuhin, 2013" authorityName="Kurshakov &amp; Zolotuhin" authorityYear="2013" box="[151,807,1827,1854]" class="Insecta" family="Limacodidae" genus="Strigivenifera" kingdom="Animalia" order="Lepidoptera" pageId="8" pageNumber="59" phylum="Arthropoda" rank="species" species="bartschi">
<emphasis bold="true" box="[151,807,1827,1854]" pageId="8" pageNumber="59">
<emphasis bold="true" box="[151,423,1827,1854]" italics="true" pageId="8" pageNumber="59">Strigivenifera bartschi</emphasis>
<bibRefCitation author="Kurshakov, P. A. &amp; Zolotuhin, V. V." box="[430,807,1828,1854]" pageId="8" pageNumber="59" pagination="904 - 919" refId="ref6695" refString="Kurshakov, P. A. &amp; Zolotuhin, V. V. (2013) A review of the genus Strigivenifera Hering, 1937 (Lepidoptera, Chrysopolomidae) with a description of ten new species. Entomological Review, 93 (7), 904 - 919. https: // doi. org / 10.1134 / S 0013873813070142" type="journal article" year="2013">Kurshakov &amp; Zolotuhin, 2013</bibRefCitation>
</emphasis>
</taxonomicName>
