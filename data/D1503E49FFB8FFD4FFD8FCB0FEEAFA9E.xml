<emphasis id="6B8D534DFFB8FFD4FF3EFB8AFD45FBDE" box="[151,645,1068,1092]" italics="true" pageId="7" pageNumber="276">
Distribution and ecology. – 
<taxonomicName id="9EF9F4DCFFB8FFD4FE01FB8AFD45FBDE" authorityName="Buerki, Callm., Munzinger &amp; Lowry" authorityYear="2020" baseAuthorityName="Buerki, Callm., Munzinger &amp; Lowry" baseAuthorityYear="2020" box="[424,645,1068,1092]" class="Magnoliopsida" family="Sapindaceae" genus="Lepidocupania" kingdom="Plantae" order="Sapindales" pageId="7" pageNumber="276" phylum="Tracheophyta" rank="species" species="globosa">Lepidocupania globosa</taxonomicName>
</emphasis>
