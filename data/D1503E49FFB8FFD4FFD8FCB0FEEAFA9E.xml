<bibRefCitation id="3D68F2AEFFB8FFD4FE9FFBCAFDDBFB1E" author="BOUCHET, P." box="[310,539,1132,1156]" pageId="7" pageNumber="276" pagination="415 - 428" refId="ref11530" refString="BOUCHET, P., T. JAFFRE &amp; J. M. VEILLON (1995). Plant extinction in New Caledonia: protection of sclerophyll forests urgently needed. Biodivers. Conserv. 4: 415 - 428." type="journal article" year="1995">BOUCHET et al., 1995</bibRefCitation>
).
</paragraph>
