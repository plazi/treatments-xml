<subSubSection id="5B24E646DFF9398582C1186F3DEDFE0D" pageId="null" pageNumber="619" type="description">
<paragraph id="DAE452BB17BB97C9F4A04C6FFA1A4033" pageId="null" pageNumber="619">
Unterscheidet sich von 
<taxonomicName id="916B7F308B8277D4F132629193193EEA" class="Magnoliopsida" family="Geraniaceae" genus="Geranium" kingdom="Plantae" order="Geraniales" pageId="null" pageNumber="619" phylum="Tracheophyta" rank="species" species="columbinum">G. columbinum</taxonomicName>
(Nr. 4) durch folgende Merkmale: Stengel 
<normalizedToken id="C4067233718BDF6D4BC241F08643FF19" originalValue="rückwärts" pageId="null" pageNumber="619">rueckwaerts</normalizedToken>
abstehend behaart (Haare 0,5-1 mm lang); 
<normalizedToken id="63797BD522B706FA990B3822ECE97D27" originalValue="Blüten" pageId="null" pageNumber="619">Blueten</normalizedToken>
die 
<normalizedToken id="A3D609BCD70E399119A018849D80EFD3" originalValue="nächststehenden" pageId="null" pageNumber="619">naechststehenden</normalizedToken>
<normalizedToken id="D3AB183763542A4478AD1D1CF234D67F" originalValue="Blätter" pageId="null" pageNumber="619">Blaetter</normalizedToken>
nicht 
<normalizedToken id="C059A8F51090FD2C619E99C2A3684681" originalValue="überragend" pageId="null" pageNumber="619">ueberragend</normalizedToken>
; 
<normalizedToken id="08DC5A410BE8DEDBF67628949E140B4E" originalValue="Blütenstiele" pageId="null" pageNumber="619">Bluetenstiele</normalizedToken>
, Kelch und Frucht mit 0,2-0,8 mm langen 
<normalizedToken id="FB57F3E7BA23E922DFDF15041F0D1590" originalValue="Drüsenhaaren" pageId="null" pageNumber="619">Druesenhaaren</normalizedToken>
; 
<normalizedToken id="FD1381236FAA406A073A70F2A58D6578" originalValue="Kelchblätter" pageId="null" pageNumber="619">Kelchblaetter</normalizedToken>
mit 1-1,5 mm langer, aufgesetzter Spitze, 4-8 mm lang; 
<normalizedToken id="07E85939AAEBC9050A3E6D9C80AD14E1" originalValue="Kronblätter" pageId="null" pageNumber="619">Kronblaetter</normalizedToken>
4-6 mm lang, rot; Frucht 1,5-1,8 cm lang. - 
<normalizedToken id="7B274A9BF46990361EED4861D4866612" originalValue="Blüte" pageId="null" pageNumber="619">Bluete</normalizedToken>
: 
<normalizedToken id="5978F6C1F4EE08D76DEB59A6F538C435" originalValue="Später" pageId="null" pageNumber="619">Spaeter</normalizedToken>
<normalizedToken id="105D4F14278D87CEE07F9A4CDF1772D2" originalValue="Frühling" pageId="null" pageNumber="619">Fruehling</normalizedToken>
, Sommer und Herbst.
</paragraph>
<paragraph id="11330D82CA8600D4FEC8428764A641E0" pageId="null" pageNumber="619">
<emphasis id="D6F1F5B9572CE02AC1F2FB126430FC42" italics="true" pageId="null" pageNumber="619">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="6EF2A606D65D023C2D737806F8256EBA" italics="true" pageId="null" pageNumber="619">22:</emphasis>
Material aus Belgien und Norddeutschland (Gauger 1937), aus England (Warburg 1938), aus Skandinavien (
<normalizedToken id="3E99C15FDC343661199D3AD01E8AD5B3" originalValue="Löve" pageId="null" pageNumber="619">Loeve</normalizedToken>
und 
<normalizedToken id="8A93461DD3016E24D908A710C51A385B" originalValue="Löve" pageId="null" pageNumber="619">Loeve</normalizedToken>
1944b), aus Holland (Gadella und Kliphuis 1966).
</paragraph>
<paragraph id="37FCF75982ABB6D649A98C5A80F7B7FE" pageId="null" pageNumber="619">
<emphasis id="5AC9D9076F0E5F477194C52179F82295" italics="true" pageId="null" pageNumber="619">Standort</emphasis>
. Kollin und montan. Lockere, lehmige 
<normalizedToken id="6818E131BCFD37EEFEBD91503AFF27FB" originalValue="Böden" pageId="null" pageNumber="619">Boeden</normalizedToken>
. 
<normalizedToken id="4E612AFACAE9AFDFE03DE14A29E36936" originalValue="Äcker" pageId="null" pageNumber="619">Aecker</normalizedToken>
, 
<normalizedToken id="48A12A418F67AD4DB6E3DC5C62D139CA" originalValue="Wegränder" pageId="null" pageNumber="619">Wegraender</normalizedToken>
, 
<normalizedToken id="FCF799101D0E64820A218BE19435530C" originalValue="Schuttplätze" pageId="null" pageNumber="619">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="5A531A32606A1C8D059BBA91418EE9D6" pageId="null" pageNumber="619">
<emphasis id="B424D69649F6C4FF02E1C5D184C58F2D" italics="true" pageId="null" pageNumber="619">Verbreitung</emphasis>
. 
<normalizedToken id="CE35AD611B617C874A2654EDFEDD04A0" originalValue="Ursprünglich" pageId="null" pageNumber="619">Urspruenglich</normalizedToken>
wahrscheinlich 
<emphasis id="E61AE8C77C8FAC4343EDA8942A16B585" italics="true" pageId="null" pageNumber="619">mediterrane Pflanze;</emphasis>
heute 
<normalizedToken id="4AD7CC24521B2812CD097B07A8E3D64F" originalValue="über" pageId="null" pageNumber="619">ueber</normalizedToken>
die ganze Erde verbreitet. - Im Gebiet verbreitet und 
<normalizedToken id="BEB9B9DC0C44D8417D7437CA7E4843A6" originalValue="häufig" pageId="null" pageNumber="619">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
