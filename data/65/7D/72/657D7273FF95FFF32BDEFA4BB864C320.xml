<subSubSection lastPageId="4" lastPageNumber="552" pageId="3" pageNumber="551" type="description">
<paragraph blockId="3.[151,1140,1527,1589]" box="[151,274,1563,1589]" pageId="3" pageNumber="551">
(
<figureCitation box="[159,266,1563,1589]" captionStart-0="FIGURE 3" captionStart-1="FIGURE 4" captionStartId-0="4.[151,250,1870,1894]" captionStartId-1="5.[151,250,1169,1193]" captionTargetBox-0="[151,1436,705,1847]" captionTargetBox-1="[151,1418,181,1144]" captionTargetId-0="figure-238@4.[151,1436,705,1847]" captionTargetId-1="figure-22@5.[151,1436,181,1144]" captionTargetPageId-0="4" captionTargetPageId-1="5" captionText-0="FIGURE 3. Malthodes (Malthodes) markpankowskii sp. nov. A: Holotype, habitus, dorsal view, scale bar = 0.5 mm. B: Holotype, habitus, detail of metasternum, scale bar = 0.2 mm. C: Holotype, habitus, ventral view, scale bar = 1.0 mm. D: Holotype, habitus, ventral view (detail), scale bar = 0.5 mm." captionText-1="FIGURE 4. Malthodes (Malthodes) markpankowskii sp. nov. A: Holotype, habitus, detail of last abdominal segments (ventral view), scale bar = 0.1 mm. B: Reconstruction of last abdominal segments, scale bar = 0.1 mm. Illustration by Dr. Carly Tribull." figureDoi-0="http://doi.org/10.5281/zenodo.6854014" figureDoi-1="http://doi.org/10.5281/zenodo.6854018" httpUri-0="https://zenodo.org/record/6854014/files/figure.png" httpUri-1="https://zenodo.org/record/6854018/files/figure.png" pageId="3" pageNumber="551">Figs. 3–4</figureCitation>
