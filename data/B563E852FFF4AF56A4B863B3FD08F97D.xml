<emphasis id="0FBE8556FFF4AF56A4B86224FD59FEF9" bold="true" box="[136,302,266,292]" pageId="7" pageNumber="239">Etymology:—</emphasis>
Referring to 
<collectingRegion id="FF0E97A6FFF4AF56A58E6224FEDEFEF9" box="[446,681,266,292]" country="Thailand" name="Chiang Rai" pageId="7" pageNumber="239">Chiang Rai Province</collectingRegion>
