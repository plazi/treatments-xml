<taxonomicName id="03944D7DFFE96A56FB2492E61B63BFD2" authorityName="Thomas" authorityYear="1904" box="[1240,1379,1215,1248]" class="Mammalia" family="Vespertilionidae" genus="Pipistrellus" kingdom="Animalia" order="Chiroptera" pageId="18" pageNumber="776" phylum="Chordata" rank="species" species="nanulus">P. nanulus</taxonomicName>
