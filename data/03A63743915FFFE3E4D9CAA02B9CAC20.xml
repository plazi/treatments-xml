<taxonomicName id="4C0FFDD6915FFFE3E7B2CDA32B1AA4B7" authorityName="Cossmann" authorityYear="1903" class="Gastropoda" family="Muricidae" genus="Pleronotus" kingdom="Animalia" order="Neogastropoda" pageId="8" pageNumber="442" phylum="Mollusca" rank="subSpecies" species="mesoamericanus" subSpecies="parnellic">Pleronotus parnellic mesoamericanus]. D. Smith, 1972</taxonomicName>
, 
<materialsCitation id="3B678C08915FFFE3E02ECD8B2A18A561" pageId="8" pageNumber="442">
“ 
<quantity id="4CF72BB0915FFFE3E01ACD8B2BF5A4B7" box="[1128,1188,1192,1221]" metricMagnitude="3" metricUnit="m" metricValue="1.609344" pageId="8" pageNumber="442" unit="mi" value="1.0">1 mi</quantity>
