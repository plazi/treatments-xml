<subSubSection id="F6FDDEF732E4FDAF4C7B27B0D7BCD251" pageId="null" pageNumber="322" type="description">
<paragraph id="D1AE815D31337F89671DB168B21597A2" pageId="null" pageNumber="322">
<taxonomicName id="B9C58E1412FB6DF6AC9D62361B12A2E1" class="Magnoliopsida" family="Rosaceae" genus="Aphanes" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="322" phylum="Tracheophyta" rank="species" species="arvensis">
<emphasis id="79C5814255CBC1259F481AF8F127B968" italics="true" pageId="null" pageNumber="322">A. arvensis</emphasis>
</taxonomicName>
(Nr. 1) sehr 
<normalizedToken id="91C13B00B9271E495F6C7276BA8132FD" originalValue="ähnlich" pageId="null" pageNumber="322">aehnlich</normalizedToken>
: Habitus und Behaarung wie bei 
<emphasis id="13B1DA85C6C7BB6665233D78AFED9FE6" italics="true" pageId="null" pageNumber="322">
<taxonomicName id="598731B93D6EBC7A5C2BA60553E7FAB3" class="Magnoliopsida" family="Rosaceae" genus="Aphanes" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="322" phylum="Tracheophyta" rank="species" species="arvensis">A. arvensis</taxonomicName>
;
</emphasis>
Pflanze selten 
<normalizedToken id="3D6FC25295E544CDA6DA73118B011DCF" originalValue="über" pageId="null" pageNumber="322">ueber</normalizedToken>
5 cm lang. 
<normalizedToken id="5FE277D88EBE23BCE4714821F3E76536" originalValue="Blätter" pageId="null" pageNumber="322">Blaetter</normalizedToken>
<normalizedToken id="12809C37C8E5F85B565E52A2EEB15CD3" originalValue="höchstens" pageId="null" pageNumber="322">hoechstens</normalizedToken>
halb so 
<normalizedToken id="B1D0D6BB043FE3A5273210F45C411C64" originalValue="groß" pageId="null" pageNumber="322">gross</normalizedToken>
wie bei 
<taxonomicName id="934E5F9D78BC653665619D759FE579EE" class="Magnoliopsida" family="Rosaceae" genus="Aphanes" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="322" phylum="Tracheophyta" rank="species" species="arvensis">
<emphasis id="3083F4871DB3CAB1FAFD2DFCD6808C18" italics="true" pageId="null" pageNumber="322">A. arvensis</emphasis>
</taxonomicName>
, aber von gleicher Form. 
<emphasis id="E2F9849F6E63AE510B16469A87D90DFB" italics="true" pageId="null" pageNumber="322">
<normalizedToken id="584BFD165FEE5D4FE46E74974FFD163C" originalValue="Zähne" pageId="null" pageNumber="322">Zaehne</normalizedToken>
der 
<normalizedToken id="E0A51944CA35A316289944E71FA83B84" originalValue="Nebenblätter" pageId="null" pageNumber="322">Nebenblaetter</normalizedToken>
meist lanzettlich, 2-4mal so lang wie breit. 
<normalizedToken id="DD769BC47A5B626EDDD58FB3BC39B09E" originalValue="Kelchblätter" pageId="null" pageNumber="322">Kelchblaetter</normalizedToken>
und Kelchbecher
</emphasis>
(
<emphasis id="E12DE02782E29A18E112209518AD1ADE" italics="true" pageId="null" pageNumber="322">wenn Frucht reif</emphasis>
) 
<emphasis id="84294725229FEE8C951239A5FA85E58E" italics="true" pageId="null" pageNumber="322">
zusammen 1,4-1,6 mm lang, die 
<normalizedToken id="8E5A9974C8FC96C3BA876D8B1EB89D85" originalValue="Zähne" pageId="null" pageNumber="322">Zaehne</normalizedToken>
der 
<normalizedToken id="D8251F975349964E149FD31CBBFF7037" originalValue="Nebenblätter" pageId="null" pageNumber="322">Nebenblaetter</normalizedToken>
meist nicht 
<normalizedToken id="3084D7589C0C8317DC64A345D11A41BC" originalValue="überragend" pageId="null" pageNumber="322">ueberragend</normalizedToken>
</emphasis>
(
<emphasis id="A987E1C3DA95B1990CD7E84026EAEDC7" italics="true" pageId="null" pageNumber="322">
von den 
<normalizedToken id="E7A5FECB1E46866240BA03624F7B2F71" originalValue="Nebenblättern" pageId="null" pageNumber="322">Nebenblaettern</normalizedToken>
<normalizedToken id="737AADF7664BD82F326874F2344F5C54" originalValue="umhüllt" pageId="null" pageNumber="322">umhuellt</normalizedToken>
</emphasis>
), 
<emphasis id="98EC55BF73CAC1FDED2E7FDAF7919766" italics="true" pageId="null" pageNumber="322">
dicht bis zerstreut mit 0,1-0,2 mm langen Haaren besetzt, ohne deutliche vortretende Nerven, am Grunde der 
<normalizedToken id="11D9A56E79A900D16703F92F04FE6084" originalValue="Kelchblätter" pageId="null" pageNumber="322">Kelchblaetter</normalizedToken>
mit undeutlicher 
<normalizedToken id="95B53FBB3A81FD17889DD1CF30A46D9F" originalValue="Einschnürung" pageId="null" pageNumber="322">Einschnuerung</normalizedToken>
; 
<normalizedToken id="6ACB9E71FA66EBE5A133AE9AAAD68AFE" originalValue="Kelchblätter" pageId="null" pageNumber="322">Kelchblaetter</normalizedToken>
meist zusammenneigend. 
<normalizedToken id="410109CDE7830874E273320A61E2D80F" originalValue="Früchte" pageId="null" pageNumber="322">Fruechte</normalizedToken>
0,9-1,1 mm lang, gelb.
</emphasis>
- 
<normalizedToken id="F151706941C7C29EC8767026236E169E" originalValue="Früchte" pageId="null" pageNumber="322">Fruechte</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="385DE6EB9719E33D40BB64197092EA91" pageId="null" pageNumber="322">
<emphasis id="25C598C7DECB13ACFA7D24E78108D868" italics="true" pageId="null" pageNumber="322">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="C539FDB71C51E9D189DC050E6310891F" italics="true" pageId="null" pageNumber="322">16:</emphasis>
Material aus 
<normalizedToken id="795139DD7667966CEEAFBF057EDD5A44" originalValue="Dänemark" pageId="null" pageNumber="322">Daenemark</normalizedToken>
(Gudjonsson 1941). Nach Walters (1949) ist 
<taxonomicName id="9BBCA89B5D2897959F0D4EEA05A6894B" class="Magnoliopsida" family="Rosaceae" genus="Aphanes" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="322" phylum="Tracheophyta" rank="species" species="microcarpa">
<emphasis id="3955B4916ED65D9D6CCC1FD7FDBB597D" italics="true" pageId="null" pageNumber="322">A. microcarpa</emphasis>
</taxonomicName>
wahrscheinlich sexuell normal; Hjelmqvist (1959) stellte Tendenz zu 
<emphasis id="2C08495C483FA4CB7C82C1A4AE316C06" italics="true" pageId="null" pageNumber="322">Apomixis</emphasis>
fest: Apomiktisch entstandene 
<normalizedToken id="67CA5DFB5304629A0BDA721B25FB2204" originalValue="Embryosäcke" pageId="null" pageNumber="322">Embryosaecke</normalizedToken>
entwickeln sich nicht weiter.
</paragraph>
<paragraph id="0AEB5100F1358974F44262D77BA0489E" pageId="null" pageNumber="322">
<emphasis id="A58E11E31B04921AAE35CB592BC37F75" italics="true" pageId="null" pageNumber="322">Standort.</emphasis>
Kollin. Sandige, meist trockene, kalkfreie 
<normalizedToken id="37125D24A081AE2818BC8514AE44C20C" originalValue="Böden" pageId="null" pageNumber="322">Boeden</normalizedToken>
. 
<normalizedToken id="93AFA321C69EC36C6FDB2568F2A43CE4" originalValue="Äcker" pageId="null" pageNumber="322">Aecker</normalizedToken>
, Ruderalstellen in sommertrockenen Gegenden.
</paragraph>
<paragraph id="3FA28BAEE3F0D3FDAC0947DBF5F51F7D" pageId="null" pageNumber="322">
<emphasis id="509C6AEBF6F14344FBEA01100D886C68" italics="true" pageId="null" pageNumber="322">
Verbreitung. 
<normalizedToken id="915065E6ECAD7C7028E54131D30DE124" originalValue="Westeuropäisch-mediterrane" pageId="null" pageNumber="322">Westeuropaeisch-mediterrane</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="F65B77F8742ADAFE7E5442DED7F5EF72" originalValue="Häufig" pageId="null" pageNumber="322">Haeufig</normalizedToken>
im westlichen Mediterrangebiet (auch Nordwestafrika), aus dem 
<normalizedToken id="6EE403F4C7E65A4D3A5C01DF67306A50" originalValue="östlichen" pageId="null" pageNumber="322">oestlichen</normalizedToken>
Mediterrangebiet wenig bekannt, atlantische Gebiete, Frankreich, England, Belgien, Holland, Deutschland, Skandinavien, Rheingebiet (
<normalizedToken id="3EA51E95CC4D7D6EA6C11B10A5A3F8DE" originalValue="Elsaß" pageId="null" pageNumber="322">Elsass</normalizedToken>
und Bas-Rhin [Kunz 1966]); Oststaaten der USA (eingeschleppt). Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: Locarno; 
<normalizedToken id="5A3A49C33EF914A1B728655852F099C0" originalValue="dürfte" pageId="null" pageNumber="322">duerfte</normalizedToken>
am 
<normalizedToken id="B1FCEA977813023371AF09A7456881D3" originalValue="südlichen" pageId="null" pageNumber="322">suedlichen</normalizedToken>
<normalizedToken id="F2AB5E416C41E4AE75C9DE387D436945" originalValue="Alpenfuß" pageId="null" pageNumber="322">Alpenfuss</normalizedToken>
nicht selten sein (Koch 1937); Ochsenfeld bei Sennheim (Cernay) im 
<normalizedToken id="06B7342E32DB988BACBE4FA45476EA5F" originalValue="Elsaß" pageId="null" pageNumber="322">Elsass</normalizedToken>
(Kunz 1966).
</paragraph>
<paragraph id="8DF5BE0E516FD7DF8E4A3076E1C8ED9E" pageId="null" pageNumber="322">
<emphasis id="94FCD8A772B2DAAC6B2F5E601EEF3EDA" italics="true" pageId="null" pageNumber="322">Bemerkungen.</emphasis>
Auf 
<taxonomicName id="108E8A85FC7CBECADEBD4A2BC2E84FA1" class="Magnoliopsida" family="Rosaceae" genus="Aphanes" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="322" phylum="Tracheophyta" rank="species" species="microcarpa">
<emphasis id="04B3D8032D6AAAA3DF9F160E0AC9DB0C" italics="true" pageId="null" pageNumber="322">A. microcarpa</emphasis>
</taxonomicName>
sollte auch 
<normalizedToken id="CA76F62E082D1228E7712C09DCC397A0" originalValue="nördlich" pageId="null" pageNumber="322">noerdlich</normalizedToken>
der Alpen (Genf, Basel, 
<normalizedToken id="9A6CD88257C841B64FF0E461CA0D6417" originalValue="Zürich" pageId="null" pageNumber="322">Zuerich</normalizedToken>
, Schaffhausen) geachtet werden. Im Habitus scheint sie nur eine 
<normalizedToken id="5D6FEF93852556DF53CD126E75F76415" originalValue="Kümmerform" pageId="null" pageNumber="322">Kuemmerform</normalizedToken>
von 
<taxonomicName id="C836D105CBC91B461866144DD1615228" class="Magnoliopsida" family="Rosaceae" genus="Aphanes" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="322" phylum="Tracheophyta" rank="species" species="arvensis">
<emphasis id="F1B56B7B989BCA04C4F350206B3BE498" italics="true" pageId="null" pageNumber="322">A. arvensis</emphasis>
</taxonomicName>
(Nr. 1) zu sein; die unterscheidenden Merkmale an den 
<normalizedToken id="E76F5B5982F6A43EF2F9DFFCCFEF82E8" originalValue="Nebenblättern" pageId="null" pageNumber="322">Nebenblaettern</normalizedToken>
und Kelchbechern sind bereits ohne Lupe zu erkennen.
</paragraph>
</subSubSection>
