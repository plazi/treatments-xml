<emphasis id="1FA0C1336A38AC0FF0A26B8979B8EFD1" italics="true" pageId="0" pageNumber="191">C. impalella</emphasis>
</taxonomicName>
and 
<taxonomicName id="FA654884F54959CEA6C5403120D8E2D2" class="Insecta" genus="C." kingdom="Animalia" lsidName="C. lessinica" order="Lepidoptera" pageId="0" pageNumber="191" phylum="Arthropoda" rank="species" species="lessinica">
