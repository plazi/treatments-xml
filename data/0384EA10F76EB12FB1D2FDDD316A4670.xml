<typeStatus id="5496E5A4F76EB12FB068FC6D336740E0" box="[301,350,914,930]" pageId="27" pageNumber="548">TYPE</typeStatus>
LOCALITY: 
<collectingCounty id="62F3238AF76EB12FB09EFC7430A840E7" box="[475,657,907,933]" pageId="27" pageNumber="548">Magalies Berge</collectingCounty>
, junction of 
<collectingMunicipality id="6BF6C17CF76EB12FB260FC7431E840E7" box="[805,977,907,933]" pageId="27" pageNumber="548">Hennops River</collectingMunicipality>
and 
<location id="8EF20DDDF76EB12FB548FC7436FC40E7" LSID="urn:lsid:plazi:treatment:0384EA10F76EB12FB1D2FDDD316A4670:8EF20DDDF76EB12FB548FC7436FC40E7" box="[1037,1221,907,933]" county="Magalies Berge" municipality="Hennops River" name="Crocodile River" pageId="27" pageNumber="548" stateProvince="Gauteng">Crocodile River</location>
, southwest of 
<location id="8EF20DDDF76EB12FB42BFC7432F4408B" LSID="urn:lsid:plazi:treatment:0384EA10F76EB12FB1D2FDDD316A4670:8EF20DDDF76EB12FB42BFC7432F4408B" county="Magalies Berge" municipality="Hennops River" name="Pretoria" pageId="27" pageNumber="548" stateProvince="Gauteng">Pretoria</location>
, 
<collectingRegion id="49E995E4F76EB12FB19CFC50339C408B" box="[217,421,943,969]" country="South Africa" name="Gauteng" pageId="27" pageNumber="548">Gauteng Province</collectingRegion>
