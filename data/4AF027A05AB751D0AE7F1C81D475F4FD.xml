<paragraph id="26FB2EA2C609C11681D7BE367DED3AD0" pageId="0" pageNumber="83231">
Ukraine (
<bibRefCitation id="15E0C8227A84D91F5F4B3E39272C2F73" author="Nast, Janusz" journalOrPublisher="Annales zoologici" pageId="0" pageNumber="83231" pagination="535 - 661" refId="B7716611" refString="Nast, Janusz, 1987. The Auchenorrhyncha (Homoptera) of Europe. Annales zoologici 40 (15): 535 - 661" title="The Auchenorrhyncha (Homoptera) of Europe" volume="40" year="1987">Nast 1987</bibRefCitation>
), Greece (
<bibRefCitation id="4F2CACEDAD017F9C2C3CFF2E6FA82EE7" author="Drosopoulos, Sakis" journalOrPublisher="Marburger Entomologische Publikationen" pageId="0" pageNumber="83231" pagination="35 - 88" refId="B7713061" refString="Drosopoulos, Sakis, 1982. Hemipterological Studies in Greece. Part II. Homoptera - Auchenorrhyncha. On the Family Delphacidae. Marburger Entomologische Publikationen 1 (6): 35 - 88" title="Hemipterological Studies in Greece. Part II. Homoptera - Auchenorrhyncha. On the Family Delphacidae." volume="1" year="1982">Drosopoulos 1982b</bibRefCitation>
, 
<bibRefCitation id="F1BD41DF828DECF784DE245C46E942FB" author="Drosopoulos, Sakis" journalOrPublisher="Annales de l'Institut Phytopathologique Benaki (N. S.)" pageId="0" pageNumber="83231" pagination="19 - 68" refId="B7712678" refString="Drosopoulos, Sakis, Asche, Manfred, Hoch, Hannelore, 1983. Contribution to the planthopper fauna of Greece. Homoptera, Auchenorrhyncha, Fulgoromorpha, Delphacidae). Annales de l'Institut Phytopathologique Benaki (N.S.) 14: 19 - 68" title="Contribution to the planthopper fauna of Greece. Homoptera, Auchenorrhyncha, Fulgoromorpha, Delphacidae)" volume="14" year="1983">Drosopoulos et al. 1983</bibRefCitation>
), Armenia (
<bibRefCitation id="1FCA71D543DA62FC32FB7D14CE49657D" author="Anufriev, G. A." journalOrPublisher="Bulletin de l'Academie Polonaise des Sciences. Serie des Sciences Biologiques" pageId="0" pageNumber="83231" pagination="201 - 205" refId="B7834372" refString="Anufriev, G. A., 1970. Two new Palaearctic species of Delphax Fabricius, 1798 (Homoptera, Delphacidae). Bulletin de l'Academie Polonaise des Sciences. Serie des Sciences Biologiques 18: 201 - 205" title="Two new Palaearctic species of Delphax Fabricius, 1798 (Homoptera, Delphacidae)" volume="18" year="1970">Anufriev 1970</bibRefCitation>
