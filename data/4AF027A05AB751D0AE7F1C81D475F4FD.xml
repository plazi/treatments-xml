<bibRefCitation id="D76A69B4BD2A5D3D6FB55B5A631F1871" author="Mitjaev, I. D." journalOrPublisher="Selevinia" pageId="0" pageNumber="83231" pagination="43 - 81" refId="B7834889" refString="Mitjaev, I. D., 2015. Leafhoppers (Homoptera, Cicadinea) of Kazakhstan, annotated check-list of species. Selevinia 23: 43 - 81" title="Leafhoppers (Homoptera, Cicadinea) of Kazakhstan, annotated check-list of species" volume="23" year="2015">Mitjaev 2015</bibRefCitation>
