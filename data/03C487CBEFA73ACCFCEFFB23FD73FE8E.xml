</paragraph>
</caption>
<caption id="DF126655EFA93ACDFF4DFB49FEF4FB05" ID-DOI="http://doi.org/10.5281/zenodo.4591599" ID-Zenodo-Dep="4591599" httpUri="https://zenodo.org/record/4591599/files/figure.png" pageId="248" pageNumber="249" startId="248.[136,245,1159,1185]" targetBox="[184,1402,208,1088]" targetPageId="248">
<paragraph id="8BD236DDEFA93ACDFF4DFB49FEF4FB05" blockId="248.[136,1452,1159,1220]" pageId="248" pageNumber="249">
<emphasis id="B919EACFEFA93ACDFF4DFB49FEEBFB60" bold="true" box="[136,302,1159,1185]" pageId="248" pageNumber="249">FIGURE 166.</emphasis>
<taxonomicName id="4C6D4D5EEFA93ACDFEF3FB49FD30FB60" authority="Illg &amp; Dudley, 1961" authorityName="Illg &amp; Dudley" authorityYear="1961" box="[310,757,1159,1185]" class="Maxillopoda" family="Notodelphyidae" genus="Bonnierilla" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="248" pageNumber="249" phylum="Arthropoda" rank="species" species="similis">
<emphasis id="B919EACFEFA93ACDFEF3FB49FDC2FB60" box="[310,519,1159,1185]" italics="true" pageId="248" pageNumber="249">Bonnierilla similis</emphasis>
