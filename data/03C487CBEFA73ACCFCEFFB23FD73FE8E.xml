<taxonomicName id="4C6D4D5EEFA63AC2FEFCF8BAFCC4F84C" authority="Illg &amp; Dudley, 1961" authorityName="Illg &amp; Dudley" authorityYear="1961" box="[313,769,1907,1934]" class="Maxillopoda" family="Notodelphyidae" genus="Bonnierilla" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="247" pageNumber="248" phylum="Arthropoda" rank="species" species="similis">
