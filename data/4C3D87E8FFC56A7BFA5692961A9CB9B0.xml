<caption id="90EB6676FFC56A7AFA5B917B17DBBC59" ID-DOI="http://doi.org/10.5281/zenodo.6398031" ID-Zenodo-Dep="6398031" httpUri="https://zenodo.org/record/6398031/files/figure.png" inLine="true" pageId="62" pageNumber="820" targetBox="[1444,2035,1406,1820]" targetPageId="62">
<paragraph id="C42B36FEFFC56A7AFA5B917B17DBBC59" blockId="62.[1447,2654,1826,3476]" pageId="62" pageNumber="820">
