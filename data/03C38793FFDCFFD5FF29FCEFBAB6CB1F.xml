, 
<bibRefCitation id="EFFB4B74FFC3FFD5FC3EFC5BBB7ACCD6" author="Hiratsuka, N." box="[927,1103,950,976]" pageId="16" pageNumber="237" pagination="189 - 314" refId="ref19411" refString="Hiratsuka, N. (1960) A provisional list of Uredinales of Japan proper and the Ryukyu Islands. The Science Bulletin of the Division of Agriculture, Home Economics and Engineering, University of Ryukyus 7: 189 - 314." type="journal article" year="1960">Hiratsuka 1960</bibRefCitation>
