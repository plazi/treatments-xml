<subSubSection id="6972AF748F068A53103542263B3011C0" pageId="null" pageNumber="361" type="description">
<paragraph id="8D838693F8E32FFBD8FAD6E814115B0D" pageId="null" pageNumber="361">
1 
<normalizedToken id="CDBF260BFF402E0E45EBBA69DA61BCAB" originalValue="jährig" pageId="null" pageNumber="361">jaehrig</normalizedToken>
; 5-6 m hoch, kletternd. Stengel kahl, verzweigt, gefurcht. 
<normalizedToken id="DF488B59BFA8358C5AE57A22FFA29857" originalValue="Blätter" pageId="null" pageNumber="361">Blaetter</normalizedToken>
lang gestielt, bis 15 cm lang, bis 
<normalizedToken id="9E9D80C515AB51708978BEE6A9B3E09E" originalValue="über" pageId="null" pageNumber="361">ueber</normalizedToken>
die Mitte 
<normalizedToken id="5D8EFB541092252AC29F948122C2E20B" originalValue="radiär" pageId="null" pageNumber="361">radiaer</normalizedToken>
3-7teilig, mit schmal 3eckigen Abschnitten, nur am Rande mit kurzen Haaren, oberseits von kleinen 
<normalizedToken id="CF5AEE44FF3CAB5C0B948DC70692DC17" originalValue="Höckern" pageId="null" pageNumber="361">Hoeckern</normalizedToken>
rauh. 
<emphasis id="9EA6476E7EBEDC0072020C9A6B5ED241" italics="true" pageId="null" pageNumber="361">
Kelchzipfel kaum 1 mm lang, 
<normalizedToken id="C437123B15D89567BB29A39CF60DF5C7" originalValue="fadenförmig" pageId="null" pageNumber="361">fadenfoermig</normalizedToken>
.
</emphasis>
Krone ca. 1 mm lang, 
<normalizedToken id="E88910FF6C715FD050B6BDA0626FC8EF" originalValue="weiß" pageId="null" pageNumber="361">weiss</normalizedToken>
, 
<emphasis id="75CC76E71B8B277ABD58751089BFA4D9" italics="true" pageId="null" pageNumber="361">
<normalizedToken id="82CFCEDA677BD570826DCBCB5AA99B38" originalValue="drüsig" pageId="null" pageNumber="361">druesig</normalizedToken>
behaart. Frucht 
<normalizedToken id="6ADB85E8F352C3792F2F42458784C585" originalValue="eiförmig" pageId="null" pageNumber="361">eifoermig</normalizedToken>
, 4
</emphasis>
- 
<emphasis id="B9A00235A1AE63DC695722E1E881F37A" italics="true" pageId="null" pageNumber="361">5 cm lang und 3</emphasis>
- 
<emphasis id="0D96A97A647E19F30615B4CFB10952E6" italics="true" pageId="null" pageNumber="361">4 cm dick, mit 5</emphasis>
- 
<emphasis id="B692BC7AB2622CBA69C9EFEAA0811B2D" italics="true" pageId="null" pageNumber="361">8 mm langen, steifen, abstehenden Borsten. Samen 1,5</emphasis>
- 
<emphasis id="2159771BB5A7F0CB23EE395A482B7F0E" italics="true" pageId="null" pageNumber="361">1,8 cm lang</emphasis>
, dunkelbraun. - 
<normalizedToken id="948076F70E1BC3762415270158F12774" originalValue="Blüte" pageId="null" pageNumber="361">Bluete</normalizedToken>
: 
<normalizedToken id="5DDD048F2C3234F2F3EA45ECAD2E4269" originalValue="Später" pageId="null" pageNumber="361">Spaeter</normalizedToken>
Sommer und Herbst.
</paragraph>
<paragraph id="53557D7AE134CBCE199A66506BDDC184" pageId="null" pageNumber="361">
<emphasis id="74D8C845BD6F201A2514FDD333C1BB58" italics="true" pageId="null" pageNumber="361">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="90C56CC73AA9A8F3F206C727B65E03C1" italics="true" pageId="null" pageNumber="361">32:</emphasis>
Material aus Amerika (Kirkwood 1907), von einem Garten (Turala 1966). Im Endosperm wurden bis 3072ploide Kerne 
<normalizedToken id="0716A62B7E487B725787E42F8BE0F717" originalValue="gezählt" pageId="null" pageNumber="361">gezaehlt</normalizedToken>
(Turala 1966).
</paragraph>
<paragraph id="2B0285FAB3EE6621D5CC6E3F524A24A6" pageId="null" pageNumber="361">
<emphasis id="4E0309D89E83486AD1648E285B83FCE9" italics="true" pageId="null" pageNumber="361">Standort.</emphasis>
Kollin, 
<normalizedToken id="3260D7C902DF41C392CFEC204728E871" originalValue="nährstoffreiche" pageId="null" pageNumber="361">naehrstoffreiche</normalizedToken>
, tonige 
<normalizedToken id="7EAD2F26FC9D5870907485C1E623347E" originalValue="Böden" pageId="null" pageNumber="361">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="CEED7EAB22C1841B803FBEA3AF821291" originalValue="Ufergebüsch" pageId="null" pageNumber="361">Ufergebuesch</normalizedToken>
, Hochstaudenfluren an Ufern.
</paragraph>
<paragraph id="2B35FA2A9F359CBB4D7ECE53DF0F80AA" pageId="null" pageNumber="361">
<emphasis id="FF027CE401578A6756AD84A50F894FD7" italics="true" pageId="null" pageNumber="361">Verbreitung.</emphasis>
<normalizedToken id="27B5FF8EA10A371A4659BBADC3A1A756" originalValue="Ursprünglich" pageId="null" pageNumber="361">Urspruenglich</normalizedToken>
<emphasis id="53C1EB74DD0D2F91714FB4D3DA09526E" italics="true" pageId="null" pageNumber="361">nordamerikanische Pflanze</emphasis>
, als Zierpflanze kultiviert und heute in 
<normalizedToken id="B79F9E575C8F94BBE3A80CD35A37DFBA" originalValue="wärmeren" pageId="null" pageNumber="361">waermeren</normalizedToken>
Gegenden gelegentlich verwildert, so in Mittel- und 
<normalizedToken id="108A84E9C136FB602D7DE89E60B31895" originalValue="Südosteuropa" pageId="null" pageNumber="361">Suedosteuropa</normalizedToken>
. - Im Gebiet gelegentlich in 
<normalizedToken id="088A4C07E4171C068F4E7B66330B9FD8" originalValue="Gärten" pageId="null" pageNumber="361">Gaerten</normalizedToken>
angepflanzt und selten verwildert (z. B. 
<normalizedToken id="5267CB16CD5CC12F5D5F0C55ACC1971E" originalValue="vorübergehend" pageId="null" pageNumber="361">voruebergehend</normalizedToken>
in Pruntrut).
</paragraph>
<paragraph id="3F767425138A3673509B30AE47DD023E" pageId="null" pageNumber="361">
<emphasis id="246848AF34A8972402CB055FFCE540B0" italics="true" pageId="null" pageNumber="361">
Bemerkungen. 
<taxonomicName id="9D838C2DC8BBBF630320D145176D5D0B" class="Magnoliopsida" family="Acanthocystidae" genus="Echinocystis" kingdom="Chromista" order="Centrohelida" pageId="null" pageNumber="361" phylum="Heliozoa" rank="species" species="lobata">E. lobata</taxonomicName>
</emphasis>
ist in 
<normalizedToken id="A5F4AFC922594EEFC7629F9EE58D22D0" originalValue="wärmeren" pageId="null" pageNumber="361">waermeren</normalizedToken>
Gegenden Mitteleuropas 
<normalizedToken id="811C3CE10F4721013D4A1070D9D0E335" originalValue="eingebürgert" pageId="null" pageNumber="361">eingebuergert</normalizedToken>
und im Vordringen. 
<normalizedToken id="A80DD639F057D90BE6D6D2EE508691A5" originalValue="Über" pageId="null" pageNumber="361">Ueber</normalizedToken>
Einwanderungsgeschichte vgl. Heine und Tschopp (1953) und Heine (1962).
</paragraph>
<paragraph id="4896C1FA4D11A8273B9CFC0DAA8D6918" pageId="null" pageNumber="361">
Die gelegentlich angepflanzte und bei Premasello im Valle 
<normalizedToken id="668ED0E15CCE3B878069B1D5D8E39B90" originalValue="d’Ossola" pageId="null" pageNumber="361">d'Ossola</normalizedToken>
verwilderte nordamerikanische Art 
<taxonomicName id="5B46E146BC4BD84465AF7232C5A1A548" authority="L." authorityName="L." class="Magnoliopsida" family="Cucurbitaceae" genus="Sicyos" kingdom="Plantae" order="Cucurbitales" pageId="null" pageNumber="361" phylum="Tracheophyta" rank="species" species="angulatus">
<emphasis id="4252AED6ABE90548849F92454043BD76" italics="true" pageId="null" pageNumber="361">Sicyos angulatus</emphasis>
<authorityName id="DE051A23C016C84641DA716B3441869F" pageId="null" pageNumber="361">L.</authorityName>
</taxonomicName>
(Haargurke) unterscheidet sich von 
<taxonomicName id="A15A9571E29966E0B4264195FA6990DC" class="Magnoliopsida" family="Acanthocystidae" genus="Echinocystis" kingdom="Chromista" order="Centrohelida" pageId="null" pageNumber="361" phylum="Heliozoa" rank="species" species="lobata">
<emphasis id="D82CEE5EE0B8D18EEC9334998682789E" italics="true" pageId="null" pageNumber="361">E. lobata</emphasis>
</taxonomicName>
durch folgende Merkmale: wenig tief geteilte 
<normalizedToken id="59E23E44877659D664EF54900C246CC0" originalValue="Blätter" pageId="null" pageNumber="361">Blaetter</normalizedToken>
; ♀ 
<normalizedToken id="CE06657D7C6119DF68864B7A76CBAF02" originalValue="Blüten" pageId="null" pageNumber="361">Blueten</normalizedToken>
zu mehreren in den Achseln der 
<normalizedToken id="4D6617EB96AC7F83027DE4AFBA903235" originalValue="Blätter" pageId="null" pageNumber="361">Blaetter</normalizedToken>
; Kronen gelblich; Frucht 1 
<normalizedToken id="15AF2B627988C15A5C5820D6941DD1AC" originalValue="fächerig" pageId="null" pageNumber="361">faecherig</normalizedToken>
, mit 1 Samen, abgeflacht, 12-17 mm lang, 7-8 mm breit und 2-3 mm dick; neben den stechenden Borsten sind noch lange, 
<normalizedToken id="18A58AD19605A0697E664B75C7A9BDCA" originalValue="weiße" pageId="null" pageNumber="361">weisse</normalizedToken>
, wollige Haare vorhanden.
</paragraph>
