<taxonomicName id="4C30F2BDFFFD0F59F799F8CFC4C7F832" baseAuthorityName="Heuglin" baseAuthorityYear="1863" box="[2057,2226,1904,1937]" class="Mammalia" family="Nesomyidae" genus="Dendromus" kingdom="Animalia" order="Rodentia" pageId="15" pageNumber="198" phylum="Chordata" rank="species" species="mystacalis">D. mystacalis</taxonomicName>
