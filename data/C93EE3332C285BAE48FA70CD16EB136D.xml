</subSubSection>
<subSubSection id="6635E5BE6F3B409B00E8890FF931E593" pageId="null" pageNumber="613" type="vernacular_names">
<paragraph id="136A5166E59E97B2AAC0A9EEF48DC138" pageId="null" pageNumber="613">Glanzkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="F81C77455BA44CBE08B1EC6E5A76D228" pageId="null" pageNumber="613" type="description">
<paragraph id="EE0A74FB334FC4977660E99EFDCC2A60" pageId="null" pageNumber="613">
Knollen 2, kugelig oder 
<normalizedToken id="57139BCFAAFA5CD03464D4406239622C" originalValue="eiförmig" pageId="null" pageNumber="613">eifoermig</normalizedToken>
. Stengel wenigstens am Grunde 
<normalizedToken id="B46DB881E0E925A72EFBA4B195681E50" originalValue="beblättert" pageId="null" pageNumber="613">beblaettert</normalizedToken>
. 
<normalizedToken id="2BCA78C4F604A48ECC3023F9D7080CE8" originalValue="Blütenstand" pageId="null" pageNumber="613">Bluetenstand</normalizedToken>
<normalizedToken id="371F7ED2D565AB93DEA0CA65F70BB64D" originalValue="wenigblütig" pageId="null" pageNumber="613">wenigbluetig</normalizedToken>
, allseitswendig. 
<normalizedToken id="E6F69DAC63BFE6027978B48822A1178A" originalValue="Perigonblätter" pageId="null" pageNumber="613">Perigonblaetter</normalizedToken>
abstehend, schmal, 
<emphasis id="7267AAF67ECF970DA974C79A91DC5C45" italics="true" pageId="null" pageNumber="613">
die 
<normalizedToken id="4B3B4D88425B2B4E05E17C7129183619" originalValue="Ränder" pageId="null" pageNumber="613">Raender</normalizedToken>
nach 
<normalizedToken id="8FC932167D6EAA76A3F7AEA7AA6E3FC4" originalValue="auβen" pageId="null" pageNumber="613">auβen</normalizedToken>
umgerollt, so 
<normalizedToken id="7F8919981FD3CA7C360F3B9784E192B0" originalValue="daβ" pageId="null" pageNumber="613">daβ</normalizedToken>
wenigstens die innern 
<normalizedToken id="8A7F474DAD056212077D334DA81135AE" originalValue="Perigonblätter" pageId="null" pageNumber="613">Perigonblaetter</normalizedToken>
<normalizedToken id="AEE8EE7D6F113C50151EDB99049C53F8" originalValue="fadenförmig" pageId="null" pageNumber="613">fadenfoermig</normalizedToken>
erscheinen;
</emphasis>
Lippe 
<normalizedToken id="1BDC625F3922DBBAB9DDCBCB8A6F3BBE" originalValue="aufwärts" pageId="null" pageNumber="613">aufwaerts</normalizedToken>
gerichtet, horizontal oder 
<emphasis id="7ABDF4C106AD8F2445C4F5E387C3FBE8" italics="true" pageId="null" pageNumber="613">
<normalizedToken id="D4B1A256A98457185D538821447E18C6" originalValue="abwärts" pageId="null" pageNumber="613">abwaerts</normalizedToken>
gebogen
</emphasis>
, nicht geteilt, am Rande kraus; 
<emphasis id="C481E5C9063A7EBE2E353059972737CF" italics="true" pageId="null" pageNumber="613">kein Sporn.</emphasis>
</paragraph>
<paragraph id="88964CFE139977655D977068F9C6D2BC" pageId="null" pageNumber="613">
Die Gattung 
<emphasis id="93ECB61FEF2C7A3313AD61A9563CFA95" italics="true" pageId="null" pageNumber="613">
<taxonomicName id="70376C4CDE06AFA6AF287B5C5AFFF37C" class="Actinopterygii" family="Liparidae" genus="Liparis" kingdom="Animalia" order="Scorpaeniformes" pageId="null" pageNumber="613" phylum="Chordata" rank="genus">Liparis</taxonomicName>
<normalizedToken id="1E96B62DFE5020CB7AB7AE44AA45FA4D" originalValue="umfaβt" pageId="null" pageNumber="613">umfaβt</normalizedToken>
etwa 260 Arten
</emphasis>
, die, 
<emphasis id="A789CAA1C34D827935C86E049EFFD560" italics="true" pageId="null" pageNumber="613">
mit Ausnahme der Arktis und Antarktis, 
<normalizedToken id="36088A5412D5FEE661250EF3B445EA04" originalValue="über" pageId="null" pageNumber="613">ueber</normalizedToken>
die ganze Erde verbreitet sind;
</emphasis>
besonders artenreich sind die 
<emphasis id="ECF6CEF8007F7E59072F3578D4F97089" italics="true" pageId="null" pageNumber="613">Monsungebiete Asiens.</emphasis>
</paragraph>
</subSubSection>
