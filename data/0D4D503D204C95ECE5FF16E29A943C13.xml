<subSubSection id="2E65F41B0A481C6A09EBB4D8B2364FD3" pageId="null" pageNumber="590" type="description">
<paragraph id="E438F0EF5C03BB93940BA542FF6E37A3" pageId="null" pageNumber="590">
5-35 cm hoch. Am Grunde der Blattrosette zerstreut 
<normalizedToken id="945A98B272688EE262E5F21348DCB800" originalValue="weißflockig" pageId="null" pageNumber="590">weissflockig</normalizedToken>
behaart und ohne alte Blattreste. 
<normalizedToken id="651E6AFC963E9C1EEF2E70173C29D7C8" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
(besonders der vordere Teil) meist nur 
<normalizedToken id="476DA134EEBA0B27902DAB3F05465D73" originalValue="gezähnt" pageId="null" pageNumber="590">gezaehnt</normalizedToken>
oder wenig tief geteilt, mit 1-2mal so langen wie breiten, wenig 
<normalizedToken id="864EE6D781CEBA34136CE5B57C6B74EA" originalValue="gezähnten" pageId="null" pageNumber="590">gezaehnten</normalizedToken>
Abschnitten; Blattstiel und Mittelnerv 
<normalizedToken id="1A07B1ABAF209D506036E0072B399C79" originalValue="auffällig" pageId="null" pageNumber="590">auffaellig</normalizedToken>
dunkelpurpurn. 
<normalizedToken id="850C55C110F02CC9E5B522684DD76598" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
zur 
<normalizedToken id="DC26CB661B512A80E1A4BD47F6279EAE" originalValue="Blütezeit" pageId="null" pageNumber="590">Bluetezeit</normalizedToken>
1-1,4 cm lang, 
<normalizedToken id="9E6EFF62A78B524F84F33DC660654B13" originalValue="dunkelgrün" pageId="null" pageNumber="590">dunkelgruen</normalizedToken>
. 
<normalizedToken id="2D177032D6861DF09AE2E0C759D166ED" originalValue="Äußere" pageId="null" pageNumber="590">Aeussere</normalizedToken>
<normalizedToken id="062BCD125A88A1249E55E59C5342D4B8" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
oval bis breit lanzettlich, 1,5-3,5 mm breit, ⅓- 
<normalizedToken id="609B45FC45BBA6FC18743F965AAEFA82" originalValue="½" pageId="null" pageNumber="590">1/2</normalizedToken>
so lang und ⅔- 
<emphasis id="6B5E3E0AF036A581BADDCBFAC00B853D" italics="true" pageId="null" pageNumber="590">1mal so breit wie die innern</emphasis>
, ohne hellen Rand, 
<emphasis id="3C7F1BCB6581D12FE6F3A0129B2A80A6" italics="true" pageId="null" pageNumber="590">
zur 
<normalizedToken id="703C05780ECE95E63B14F96EC15172A8" originalValue="Blütezeit" pageId="null" pageNumber="590">Bluetezeit</normalizedToken>
anliegend;
</emphasis>
innere 
<normalizedToken id="93B3712BFC68FF594DC1D888FAC27138" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
an der Spitze ohne 
<normalizedToken id="B9B8937346022715F5FE5455717F3A0F" originalValue="Höcker" pageId="null" pageNumber="590">Hoecker</normalizedToken>
. 
<normalizedToken id="03C5E0F276F892A85F76438163E72BC3" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
dunkelgelb; 
<normalizedToken id="7C2709D8E0A28889B035EE5A1F08A01C" originalValue="außen" pageId="null" pageNumber="590">aussen</normalizedToken>
purpurn. 
<normalizedToken id="59DE106FFA45C6BE34F41AAF25BC8FBB" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
(ohne Schnabel) 4-5 mm lang, hellrotbraun; Fruchtspitze 1/7-⅕ so lang wie der Rest der Frucht; 
<emphasis id="A9CC5E09AB57B271E049E91932EF9750" italics="true" pageId="null" pageNumber="590">Schnabel 1</emphasis>
⅓- 
<emphasis id="642B03FD7A0D0BD86842A98176A76F0D" italics="true" pageId="null" pageNumber="590">1</emphasis>
⅔ 
<emphasis id="2862A8901D716E3A754002DC06A4A510" italics="true" pageId="null" pageNumber="590">mal so lang wie die Frucht.</emphasis>
- 
<normalizedToken id="34BDF9F2DF7667EB24078858FCB8F3E7" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="B291E3A590C9C289945E1C8B262FDE73" pageId="null" pageNumber="590">
<emphasis id="1ADB2CFE8D54A7D05CC6515E78DD52C9" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="4A5E999A75B4ABD0830E49B1BBB5F5D4" italics="true" pageId="null" pageNumber="590">24:</emphasis>
Material aus dem Wallis (Hou-Liu 1963).
</paragraph>
<paragraph id="D7CB1EE7CF0E696B08CC8009F1F561DC" pageId="null" pageNumber="590">
<emphasis id="618A442CB0114A5132103BB32152122C" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Subalpin und alpin. Nasse, torfige, kalkarme 
<normalizedToken id="D40D4CA8FF0E47E26BCE6C3BFCACEE87" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
. Flachmoore, sumpfige Wiesen.
</paragraph>
<paragraph id="1CEA5DB18A66EEBA1ED0191ED63B6925" pageId="null" pageNumber="590">
<emphasis id="5A0A6CF571CBB2C8CB3D9208FD30EA50" italics="true" pageId="null" pageNumber="590">
Verbreitung. Mittel- und 
<normalizedToken id="57B06534EC0DAE307FF412215446D501" originalValue="südeuropäische" pageId="null" pageNumber="590">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="1B369A297264395B2050971F7FBEC7F9" italics="true" pageId="null" pageNumber="590">westlich</emphasis>
)
<emphasis id="4BA7566EBF8166F2F21E432C82B8DF38" italics="true" pageId="null" pageNumber="590">:</emphasis>
Sierra de Guadarrama in Spanien, Westalpen (Alpes Maritimes bis Silvretta und 
<normalizedToken id="84AA088FDDCF52BB9CC0BEDA04F9A1E3" originalValue="Südtirol" pageId="null" pageNumber="590">Suedtirol</normalizedToken>
). - Im Gebiet: Zentral- und 
<normalizedToken id="036256A4B5B25E7119E4B6ABC36EF8DF" originalValue="Südalpen" pageId="null" pageNumber="590">Suedalpen</normalizedToken>
, nicht 
<normalizedToken id="A82D2A1529A0EC2D1737BDEEDF1F02BE" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
; Nordalpen, selten.
</paragraph>
</subSubSection>
