<tr id="05B089945ED8DC9D365E953153B66FE8" pageId="null" pageNumber="790">
<td id="2129D4C9EF53EDF4077D12EE67315F18" align="left" pageId="null" pageNumber="790" valign="top">1. Pflanze 30-70 cm hoch; Kelch 17-25 mm lang; Kapsel etwa 20 mm lang</td>
<td id="9A4C4912C5BD6C50687C3BC2760F4564" align="left" pageId="null" pageNumber="790" valign="bottom">
<taxonomicName id="6FB2F11E941AF70F4596CC1F778DB335" class="Liliopsida" family="Asparagaceae" genus="Asparagus" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="790" phylum="Tracheophyta" rank="species" species="officinalis">
<italic id="E7331ECE8E7A5E850F71CC155AB9BC2A" pageId="null" pageNumber="790">S. officinalis</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="5042A1649F15FCA9CB345756711E820F" pageId="null" pageNumber="790">
<td id="C0D03946BF18D472A9F2C419C01E0779" align="left" pageId="null" pageNumber="790" valign="top">1*. Pflanze 5-25 cm hoch; Kelch 7-12 mm lang; Kapsel 6-8 mm lang.</td>
</tr>
<tr id="C625B76AE485F7D70D79170DF7349717" pageId="null" pageNumber="790">
<td id="065518D6CAF7009ED7CD78EDB255DCFE" align="left" pageId="null" pageNumber="790" valign="top">
2. 
<normalizedToken id="FA43D8D71A38FC7781D1B06F8124679C" originalValue="Kronblätter" pageId="null" pageNumber="790">Kronblaetter</normalizedToken>
rot; Stengel niederliegend, 
<normalizedToken id="3B49A6C512E1090BBCFB798DE4C7A603" originalValue="hängend" pageId="null" pageNumber="790">haengend</normalizedToken>
oder aufsteigend
</td>
<td id="5B0CA687F68900F65302F1781775A1BE" align="left" pageId="null" pageNumber="790" valign="bottom">
<taxonomicName id="DF07652DD63306DF8DEA34A1FA25A268" class="Magnoliopsida" family="Caryophyllaceae" genus="Saponaria" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="790" phylum="Tracheophyta" rank="species" species="ocymoides">
<italic id="C4D2B5474EF6701FB1EABAB6F5E1A1A9" pageId="null" pageNumber="790">S. Ocymoides</italic>
</taxonomicName>
(Nr. 2)
</td>
</tr>
<tr id="E738B8D6021F8C9EF9F3F273F7B3F65E" pageId="null" pageNumber="790">
<td id="B79A790143420DF316F41DB0EF2AE60E" align="left" pageId="null" pageNumber="790" valign="top">
2*. 
<normalizedToken id="02398DE88BF85BD8690A740660E7DBE5" originalValue="Kronblätter" pageId="null" pageNumber="790">Kronblaetter</normalizedToken>
hellgelb, mit violettem Stiel; Stengel aufrecht
</td>
<td id="DF5B833FC239F87F094320F0AFC2DCE7" align="left" pageId="null" pageNumber="790" valign="bottom">
<taxonomicName id="8676D889439E336641A2C851B85C710D" class="Liliopsida" family="Liliaceae" genus="Gagea" kingdom="Plantae" order="Liliales" pageId="null" pageNumber="790" phylum="Tracheophyta" rank="species" species="lutea">
<italic id="73BAB61DF4F7CDB24089DAAF3C49A179" pageId="null" pageNumber="790">S. lutea</italic>
</taxonomicName>
(Nr. 3)
</td>
</tr>
