<subSubSection id="B562E55007380175D81C8B16A0BC2050" pageId="null" pageNumber="638" type="description">
<paragraph id="9FD3BB48C72D7F0BF5C069890F5148B6" pageId="null" pageNumber="638">
1 
<emphasis id="EEE4615D2BE54AE7ADD184D4F9CB71DC" italics="true" pageId="null" pageNumber="638">
<normalizedToken id="08F254F0EBF3D10CE6A83BAA11B27D7E" originalValue="jährig" pageId="null" pageNumber="638">jaehrig</normalizedToken>
;
</emphasis>
30-80 cm hoch; 
<emphasis id="B2948654D610187B1683D9CDDA6C6301" italics="true" pageId="null" pageNumber="638">
ohne 
<normalizedToken id="185D0317603290FE35629BE4950E5EDC" originalValue="nichtblühende" pageId="null" pageNumber="638">nichtbluehende</normalizedToken>
Sprosse.
</emphasis>
Stengel meist aufrecht, im 
<normalizedToken id="0C0DEEEC98CB70DA9968A07F24AB1208" originalValue="Blütenstand" pageId="null" pageNumber="638">Bluetenstand</normalizedToken>
verzweigt, kahl. 
<normalizedToken id="2719C7D6972C94CD6434AB079DB9F926" originalValue="Blätter" pageId="null" pageNumber="638">Blaetter</normalizedToken>
<normalizedToken id="17B924786D47F121AF16B3982C6C4312" originalValue="wechselständig" pageId="null" pageNumber="638">wechselstaendig</normalizedToken>
, kahl, 5-15mal so lang wie breit, bis 4 cm lang. 
<emphasis id="18DB55B0EA4806B1D315DD10DF227709" italics="true" pageId="null" pageNumber="638">
<normalizedToken id="78AD96DC32C67B1C011890D3AB2E8AA5" originalValue="Blütenstiele" pageId="null" pageNumber="638">Bluetenstiele</normalizedToken>
</emphasis>
<emphasis id="1CB0C2635077E796DDC02DF9B3AB0050" italics="true" pageId="null" pageNumber="638">
<pageBreakToken id="2565D27860B22E09FBB7F000732966F2" pageId="null" pageNumber="638">meist</pageBreakToken>
bedeutend 
<normalizedToken id="2F1ED01DF62D287ADE7C6F2DEA4C1BF2" originalValue="länger" pageId="null" pageNumber="638">laenger</normalizedToken>
als die 
<normalizedToken id="308134EA97B852DDA6FE632A5EBF80E4" originalValue="nächststehenden" pageId="null" pageNumber="638">naechststehenden</normalizedToken>
<normalizedToken id="A2B92E1402EB23D6AA8D1EA5870AEE61" originalValue="Blätter" pageId="null" pageNumber="638">Blaetter</normalizedToken>
</emphasis>
, kahl, aufrecht. 
<normalizedToken id="7274A1BBFF01250CFBE690E439368DF5" originalValue="Kelchblätter" pageId="null" pageNumber="638">Kelchblaetter</normalizedToken>
5-7 mm lang, lang zugespitzt, mit 
<normalizedToken id="34255184195F800A5D6778A4D343ED20" originalValue="weißem" pageId="null" pageNumber="638">weissem</normalizedToken>
bewimpertem Hautrand, 3- oder 5nervig. 
<emphasis id="3921F7F09A7BA0D92ABFD9B69DDA8BC4" italics="true" pageId="null" pageNumber="638">
<normalizedToken id="6E97C8115F1BC3CD878BB51C5AD3E09A" originalValue="Kronblätter" pageId="null" pageNumber="638">Kronblaetter</normalizedToken>
12-15 mm lang
</emphasis>
, blau. 
<emphasis id="627549790736C02987CC79B60A604E6D" italics="true" pageId="null" pageNumber="638">
Narben 
<normalizedToken id="65C1248A18D725A0161CA1AFB3054D40" originalValue="keulenförmig" pageId="null" pageNumber="638">keulenfoermig</normalizedToken>
</emphasis>
(
<emphasis id="86ED158A4AD7CED3130D773BA1A89AA9" italics="true" pageId="null" pageNumber="638">
<normalizedToken id="0A37E71428535F468825095E285E9CEA" originalValue="länger" pageId="null" pageNumber="638">laenger</normalizedToken>
als 0,8 mm
</emphasis>
). Frucht aufrecht, 6-8 mm lang. - 
<normalizedToken id="191506D8A320BF7FD047EFBF5BCE44B2" originalValue="Blüte" pageId="null" pageNumber="638">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="9D4401B6F8C18E3D469A9AD4B038A17A" pageId="null" pageNumber="638">
<emphasis id="9EF8F6B48284A9FF643493D8A0920CE9" italics="true" pageId="null" pageNumber="638">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="093ADA4AA6CF6A4234073E5ABB3549C4" italics="true" pageId="null" pageNumber="638">30:</emphasis>
Sehr zahlreiche 
<normalizedToken id="6A87361226D9DC36ABF363628914333E" originalValue="Stämme" pageId="null" pageNumber="638">Staemme</normalizedToken>
aus Kulturen (Simonet 1929a, Ray 1944, Pandey 1956, Gill und Yermanos 1967; weitere Autoren bei Tischler 1950). 
<emphasis id="232AEAD271395AD1C8EF0C6DC581A1BD" italics="true" pageId="null" pageNumber="638">2n</emphasis>
= 
<emphasis id="75F05D6D771A267843A2FAC445E1FA63" italics="true" pageId="null" pageNumber="638">32:</emphasis>
Viele 
<normalizedToken id="1B206133BEF934AE51ED55F4C1ED76EB" originalValue="Stämme" pageId="null" pageNumber="638">Staemme</normalizedToken>
aus Kulturen (Martzenitzina 1927, zahlreiche weitere Autoren bei 
<normalizedToken id="48EE2495153A4C783134025C665593B9" originalValue="Löve" pageId="null" pageNumber="638">Loeve</normalizedToken>
und 
<normalizedToken id="9FC25F4D4803A87124776F25BCDD3A17" originalValue="Löve" pageId="null" pageNumber="638">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="0C08035CD112C3B328749112FE562D0C" pageId="null" pageNumber="638">
<emphasis id="7A70BC842D9CAB14DF682E015405F749" italics="true" pageId="null" pageNumber="638">Standort.</emphasis>
Kollin und montan, seltener subalpin. Kalkarme, sandige 
<normalizedToken id="2EC89C28E95928601D409308E758190C" originalValue="Lehmböden" pageId="null" pageNumber="638">Lehmboeden</normalizedToken>
. 
<normalizedToken id="A8D5699D0F4361870C2C4D7EDFFF7D02" originalValue="Äcker" pageId="null" pageNumber="638">Aecker</normalizedToken>
, 
<normalizedToken id="45E3316DC7BD11EC18FA857499C34B87" originalValue="Schuttplätze" pageId="null" pageNumber="638">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="38E5D80D6927584BB5AD264F6CB80BBE" pageId="null" pageNumber="638">
<emphasis id="0658A70725022FEB8828189D5BA2A273" italics="true" pageId="null" pageNumber="638">Verbreitung. Kulturpflanze</emphasis>
, wahrscheinlich von 
<taxonomicName id="6C5705A2C93C1007C9EF6E52DDA726B9" class="Magnoliopsida" family="Linaceae" genus="Linum" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="638" phylum="Tracheophyta" rank="species" species="angustifolium">
<emphasis id="827FD077C241D89E754A88FAC1A9B4B0" italics="true" pageId="null" pageNumber="638">
<authorityName id="E8930D96A7DE282D5B5CEFA3DAE05EF4" pageId="null" pageNumber="638">L.</authorityName>
angustifolium
</emphasis>
</taxonomicName>
(Nr. 7) abstammend, nicht wild auftretend. - Im Gebiet selten mehr angebaut; selten adventiv.
</paragraph>
<paragraph id="0E100D0B243071ED65E5C076BF921F92" pageId="null" pageNumber="638">
<emphasis id="F80D6004F107B09B16CF685263FB3187" italics="true" pageId="null" pageNumber="638">
Bemerkungen. 
<taxonomicName id="6E1C72DEFD8D5DF1CEC190D9C4CC8C32" class="Magnoliopsida" family="Linaceae" genus="Linum" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="638" phylum="Tracheophyta" rank="species" species="usitatissimum">
<authorityName id="221800C38B1C6B45834803BD25CA522F" pageId="null" pageNumber="638">L.</authorityName>
usitatissimum
</taxonomicName>
</emphasis>
<normalizedToken id="39FA09C9358953FE545D9850A27AE581" originalValue="umfaßt" pageId="null" pageNumber="638">umfasst</normalizedToken>
Sorten, die zur Fasergewinnung (Flachs) und solche, die zur Samengewinnung (
<normalizedToken id="9E346E9D684D06DCE0591E8DEFE5FB1F" originalValue="Leinöl" pageId="null" pageNumber="638">Leinoel</normalizedToken>
) angebaut werden. Zur Systematik vgl. Kulpa und Danert (1962).
</paragraph>
</subSubSection>
