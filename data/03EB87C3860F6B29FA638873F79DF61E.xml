<quantity id="4CBA9B30860F6B29F9838B25F953F8E3" box="[1627,1737,1873,1912]" metricMagnitude="2" metricUnit="m" metricValue="1.5" pageId="29" pageNumber="92" unit="m" value="150.0">150 m</quantity>
