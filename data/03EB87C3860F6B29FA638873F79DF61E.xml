<quantity id="4CBA9B30860F6B29F8B38BF4F849F83D" box="[1899,2003,1920,1958]" metricMagnitude="3" metricUnit="m" metricValue="4.0" pageId="29" pageNumber="92" unit="km" value="4.0">4 km</quantity>
