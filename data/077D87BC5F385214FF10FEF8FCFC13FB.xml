<figureCitation id="17EF2A2F5F385214FDD9FEF9FD6710C1" box="[635,682,371,393]" captionStart="Figs 8-10" captionStartId="5.[178,218,643,665]" captionTargetBox="[190,1082,225,609]" captionTargetId="figure-1@5.[178,1082,212,618]" captionTargetPageId="5" captionText="Figs 8-10: Tetartopeus lomnickii (ROUBAL) (8) and T. lentus RYVKIN (9-10): (8) apical portion of dorsal plate of aedeagus in dorsal view; (9) female tergite VIII; (10) female tergite IX. Scale bars: 9-10: 0.5 mm; 8: 0.2 mm." figureDoi="http://doi.org/10.5281/zenodo.5307289" httpUri="https://zenodo.org/record/5307289/files/figure.png" pageId="6" pageNumber="1125">9-10</figureCitation>
