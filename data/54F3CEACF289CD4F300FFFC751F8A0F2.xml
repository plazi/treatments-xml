<taxonomicName id="D2F9160C146256628DB106ADBDFEB1F3" authority="Ten." class="Magnoliopsida" family="Primulaceae" genus="Cyclamen" kingdom="Plantae" order="Ericales" pageId="null" pageNumber="916" phylum="Tracheophyta" rank="species" species="neapolitanum">
