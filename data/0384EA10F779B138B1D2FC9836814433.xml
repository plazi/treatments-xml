<materialsCitation id="3B45515BF779B138B182FC0832F6464C" ID-GBIF-Occurrence="3766756319" collectingDate="1855-07-23" collectingDateMax="1855-08-03" collectingDateMin="1855-07-23" collectionCode="TYPE" country="Sweden" county="Berlin" location="The" municipality="Okavango River" pageId="12" pageNumber="533" specimenCount="1" typeStatus="lectotype">
<collectionCode id="ED3CC3C3F779B138B182FC0832C2474C" box="[199,251,1015,1041]" pageId="12" pageNumber="533">TYPE</collectionCode>
MATERIAL: 
<location id="8EF20DDDF779B138B03FFC08339F4753" LSID="urn:lsid:plazi:treatment:0384EA10F779B138B1D2FC9836814433:8EF20DDDF779B138B03FFC08339F4753" box="[378,422,1015,1041]" country="Sweden" county="Berlin" municipality="Okavango River" name="The" pageId="12" pageNumber="533">The</location>
description was based on many specimens (cf. verbatim type locality above). 
<location id="8EF20DDDF779B138B463FC0837A54753" LSID="urn:lsid:plazi:treatment:0384EA10F779B138B1D2FC9836814433:8EF20DDDF779B138B463FC0837A54753" box="[1318,1436,1015,1041]" country="Sweden" county="Berlin" municipality="Okavango River" name="According" pageId="12" pageNumber="533">According</location>
to 
<location id="8EF20DDDF779B138B1F3FBE433004777" LSID="urn:lsid:plazi:treatment:0384EA10F779B138B1D2FC9836814433:8EF20DDDF779B138B1F3FBE433004777" box="[182,313,1051,1077]" country="Sweden" county="Berlin" municipality="Okavango River" name="Sundevall's" pageId="12" pageNumber="533">Sundevall’s</location>
