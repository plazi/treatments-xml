<caption id="C5946657FFA0BA0CBC13F471BA7CFC39" ID-DOI="http://doi.org/10.5281/zenodo.6567804" ID-Zenodo-Dep="6567804" httpUri="https://zenodo.org/record/6567804/files/figure.png" inLine="true" pageId="28" pageNumber="647" targetBox="[1433,2025,639,1054]" targetPageId="28">
