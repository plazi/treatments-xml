<taxonomicName id="56EB4D5CFFA0BA0CBC11F4E7BB82FC66" authority="Monard, 1933" authorityName="Monard" authorityYear="1933" box="[2051,2468,903,936]" class="Mammalia" family="Molossidae" genus="Chaerephon" kingdom="Animalia" order="Chiroptera" pageId="28" pageNumber="647" phylum="Chordata" rank="subSpecies" species="nigeriae" subSpecies="spillmanni">C. n. spillmanni Monard, 1933</taxonomicName>
