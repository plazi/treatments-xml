<taxonomicName id="4C794D22D178FFCA68A72FE3FE5FFA50" authority="Koretsky &amp; Rahmat &amp; Peters, 2014" authorityName="Koretsky &amp; Rahmat &amp; Peters" authorityYear="2014" box="[246,408,1426,1447]" class="Mammalia" family="Phocidae" genus="Gryphoca" higherTaxonomySource="GBIF" kingdom="Animalia" order="Carnivora" pageId="9" pageNumber="428" phylum="Chordata" rank="species" species="danica" status="sp. n.">
