<subSubSection id="C36A6504A468FFAEFCB1FB9BFBDCFAAF" pageId="9" pageNumber="298" type="discussion">
<paragraph id="8BCF368FA468FFAEFCB1FB9BFBDCFAAF" blockId="9.[801,1452,1090,1338]" pageId="9" pageNumber="298">
<emphasis id="B904EA9DA468FFAEFCB1FB9BFC1BFBCF" box="[839,906,1090,1113]" italics="true" pageId="9" pageNumber="298">Notes.</emphasis>
– This species is found in 
<collectingCountry id="F367761FA468FFAEFB3EFB9BFA8EFBCC" box="[1224,1311,1090,1114]" name="Nigeria" pageId="9" pageNumber="298">Nigeria</collectingCountry>
, 
<collectingCountry id="F367761FA468FFAEFADBFB9BFA37FBCC" box="[1325,1446,1090,1114]" name="Cameroon" pageId="9" pageNumber="298">Cameroon</collectingCountry>
, 
<collectingCountry id="F367761FA468FFAEFCD7FBBBFC7CFBEC" box="[801,1005,1122,1146]" name="Republic of the Congo" pageId="9" pageNumber="298">Republic of Congo</collectingCountry>
, and 
<collectingCountry id="F367761FA468FFAEFBDEFBBBFAEBFBEC" box="[1064,1402,1122,1146]" name="Democratic Republic of the Congo" pageId="9" pageNumber="298">Democratic Republic of Congo</collectingCountry>
. The 
<typeStatus id="54CB882DA468FFAEFCD7FB5BFCC1FB0C" box="[801,848,1154,1178]" pageId="9" pageNumber="298">type</typeStatus>
material of this name was cited by 
<bibRefCitation id="EFE14B7EA468FFAEFB20FB5BFCC4FB2C" author="VERDCOURT" firstAuthor="VERDCOURT" page="799" pageId="9" pageNumber="298" pagination="785 - 818" refId="ref27689" refString="VERDCOURT, B. (1977). A synopsis of the genus Chazaliella (Rubiaceae-Psychotrieae). Kew Bull. 31: 785 - 818." type="journal article" year="1977">VERDCOURT (1977: 799)</bibRefCitation>
