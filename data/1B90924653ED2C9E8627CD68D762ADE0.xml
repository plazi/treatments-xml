<subSubSection id="F81BB21E7889CFF328DCE8A121A5A55A" pageId="null" pageNumber="148" type="description">
<paragraph id="F025F212E3F492FA119DA61D8FA5C95B" pageId="null" pageNumber="148">
<normalizedToken id="8713AE5ACC9823AF7AB8A4977C3AD7C7" originalValue="Blätter" pageId="null" pageNumber="148">Blaetter</normalizedToken>
<normalizedToken id="C84F3199E3E74CA0470D83C33880FC01" originalValue="quirlständig" pageId="null" pageNumber="148">quirlstaendig</normalizedToken>
, 
<emphasis id="27163734F69C9FFF7B419E6E95B759EF" italics="true" pageId="null" pageNumber="148">
zu 3 in einem Quirl, die seitlichen ganzrandig, 
<normalizedToken id="763C1EC104FE02043F7F43DAFF196D55" originalValue="grün" pageId="null" pageNumber="148">gruen</normalizedToken>
, auf dem Wasser schwimmend, das untere in jedem Quirl in 
<normalizedToken id="95192CD4750C7FF1A96EC909FFF82203" originalValue="haarförmige" pageId="null" pageNumber="148">haarfoermige</normalizedToken>
Abschnitte geteilt, untergetaucht und Scheinwurzeln bildend.
</emphasis>
Sporokarpien in Gruppen an der Basis der Scheinwurzeln.
</paragraph>
<paragraph id="FB93EDCFB38F3E2DECF3EEAEA0B66469" pageId="null" pageNumber="148">
Die Gattung 
<emphasis id="E261019F7E4A6428197C2ED4FE6C8A63" italics="true" pageId="null" pageNumber="148">
<normalizedToken id="8002D1795EC350F5B8E62370625F5C57" originalValue="umfaβt" pageId="null" pageNumber="148">umfaβt</normalizedToken>
8 Arten, die meisten in den Tropen Afrikas und 
<normalizedToken id="B60AF300925C0FD87C475D68E79FB6E3" originalValue="Südamerikas" pageId="null" pageNumber="148">Suedamerikas</normalizedToken>
.
</emphasis>
In 
<taxonomicName id="95A6467DB9BDF828A220B1CC6E68B5CB" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="148" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
nur 
<emphasis id="559430012EBDA04BE8CF394A361618D8" italics="true" pageId="null" pageNumber="148">
<taxonomicName id="AEEBA594CD53CFABAF37FC18F7DA1BD2" class="Polypodiopsida" family="Salviniaceae" genus="Salvinia" kingdom="Plantae" order="Salviniales" pageId="null" pageNumber="148" phylum="Tracheophyta" rank="species" species="natans">S. natans</taxonomicName>
.
</emphasis>
Monographische Bearbeitung der Gattung (instruktive Zeichnungen) von Herzog (1935).
</paragraph>
