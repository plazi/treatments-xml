<collectingCountry id="F3707615FFF1FFAFFD8EF91F3C1FF8AA" box="[517,603,1780,1806]" name="Mexico" pageId="1" pageNumber="231">Mexico</collectingCountry>
(
<figureCitation id="135C2A00FFF1FFAFFDE1F91F3CF4F8AA" box="[618,688,1780,1806]" captionStart="FIGURE 4" captionStartId="5.[151,250,1559,1583]" captionTargetBox="[151,1435,631,1535]" captionTargetId="figure-49@5.[151,1436,631,1536]" captionTargetPageId="5" captionText="FIGURE 4. Distribution map of Chespirito species." figureDoi="http://doi.org/10.5281/zenodo.6405140" httpUri="https://zenodo.org/record/6405140/files/figure.png" pageId="1" pageNumber="231">Fig. 4</figureCitation>
).
</paragraph>
