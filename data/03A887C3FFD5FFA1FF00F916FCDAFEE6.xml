<bibRefCitation id="EF904B24FFD5FFA6FE39F94AFDBEF8CE" author="Greuter, W." box="[433,560,1782,1804]" pageId="11" pageNumber="140" pagination="257 - 265" refId="ref7494" refString="Greuter, W. (1968) Notulae nomenclaturales et bibliographicae 5 - 6. Candollea 23: 257 - 265." type="journal article" year="1968">Greuter 1968</bibRefCitation>
