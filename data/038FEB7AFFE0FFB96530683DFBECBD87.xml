<collectingRegion id="49E2948EFFE0FFB9658368DCFE66B896" box="[412,468,480,503]" country="Switzerland" name="Bern" pageId="11" pageNumber="114">Bern</collectingRegion>
, 
<collectingCountry id="F3311AFCFFE0FFB965C068DCFDD1B896" box="[479,611,480,503]" name="Switzerland" pageId="11" pageNumber="114">Switzerland</collectingCountry>
