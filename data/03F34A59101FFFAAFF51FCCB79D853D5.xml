, 
<taxonomicName id="4C5A80CC101FFFAAFF23FAAF79B35149" authorityName="Wood &amp; Bright" authorityYear="1992" box="[250,509,1346,1372]" class="Insecta" family="Curculionidae" genus="Hypothenemus" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="45" phylum="Arthropoda" rank="species" species="hampei">
<emphasis id="B92E275D101FFFAAFF23FAAF79B35149" box="[250,509,1346,1372]" italics="true" pageId="8" pageNumber="45">Hypothenemus hampei</emphasis>
</taxonomicName>
, 
<taxonomicName id="4C5A80CC101FFFAAFDC9FAAE7AB45149" baseAuthorityName="Guerin-Meneville &amp; Perrotet" baseAuthorityYear="1842" box="[528,762,1346,1372]" class="Magnoliopsida" family="Asteraceae" genus="Leucoptera" kingdom="Plantae" order="Asterales" pageId="8" pageNumber="45" phylum="Tracheophyta" rank="species" species="coffeella">
<emphasis id="B92E275D101FFFAAFDC9FAAE7AB45149" box="[528,762,1346,1372]" italics="true" pageId="8" pageNumber="45">Leucoptera coffeella</emphasis>
</taxonomicName>
