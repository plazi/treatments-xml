</taxonomicName>
. 
<emphasis id="32BDDA538F7EFEF04C7250AEFBDCF868" bold="true" box="[1090,1145,1921,1944]" pageId="304" pageNumber="305">B, C.</emphasis>
<taxonomicName id="C7C97DC28F7EFEF04CB050AFFB58F868" baseAuthorityName="Olmi" baseAuthorityYear="1984" box="[1152,1277,1923,1944]" class="Insecta" family="Dryinidae" genus="Dryinus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="304" pageNumber="305" phylum="Arthropoda" rank="species" species="peterseni">
