<paragraph pageId="0" pageNumber="113">
<taxonomicName LSID="225C50F2-9050-5AEE-87B9-9F07392DE3AC" authority="Luangsa-ard, Hywel-Jones &amp; Spatafora, in Kepler, Luangsa-ard, Hywel-Jones, Quandt, Sung, Rehner, Aime, Henkel, Sanjuan, Zare, Chen, Li, Rossman, Spatafora, Shrestha, IMA Fungus 8: 348 (2017). Emend. S. Mongkolsamrit, W. Noisripoom &amp; K. Tasanathai" authorityName="Luangsa-ard, Hywel-Jones &amp; Spatafora, in Kepler, Luangsa-ard, Hywel-Jones, Quandt, Sung, Rehner, Aime, Henkel, Sanjuan, Zare, Chen, Li, Rossman, Spatafora, Shrestha, IMA Fungus 8: 348" authorityYear="2017" class="Arachnida" family="Cordycipitaceae" genus="Hevansia" higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Hevansia" order="Hypocreales" pageId="0" pageNumber="113" phylum="Ascomycota" rank="genus">Hevansia Luangsa-ard, Hywel-Jones &amp; Spatafora, in Kepler, Luangsa-ard, Hywel-Jones, Quandt, Sung, Rehner, Aime, Henkel, Sanjuan, Zare, Chen, Li, Rossman, Spatafora, Shrestha, IMA Fungus 8: 348 (2017). Emend. S. Mongkolsamrit, W. Noisripoom &amp; K. Tasanathai</taxonomicName>
</paragraph>
