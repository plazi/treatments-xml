<taxonomicName id="03944D7DFFFE6A41FB209C731D14B140" authorityName="Dobson" authorityYear="1875" class="Mammalia" family="Vespertilionidae" genus="Glischropus" kingdom="Animalia" order="Chiroptera" pageId="5" pageNumber="763" phylum="Chordata" rank="species" species="tylopus">G. tylopus</taxonomicName>
, based on genetic data. Monotypic.
</paragraph>
</subSubSection>
<subSubSection id="8C8E6575FFFE6A41FD2C9C211DD0B1F2" pageId="5" pageNumber="763" type="distribution">
<caption id="90EB6676FFFE6A41FD2C9C211DD0B1F2" ID-DOI="http://doi.org/10.5281/zenodo.6397772" ID-Zenodo-Dep="6397772" httpUri="https://zenodo.org/record/6397772/files/figure.png" inLine="true" pageId="5" pageNumber="763" targetBox="[105,695,2451,2864]" targetPageId="5">
<paragraph id="C42B36FEFFFE6A41FD2C9C211DD0B1F2" blockId="5.[719,1316,2443,2871]" pageId="5" pageNumber="763">
<emphasis id="F6E0EAECFFFE6A41FD2C9C211D80B1AB" bold="true" box="[720,896,2680,2713]" pageId="5" pageNumber="763">Distribution.</emphasis>
