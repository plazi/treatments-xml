<subSubSection id="E2A3CEFC1250B8D17B76BDAC50E18A69" pageId="null" pageNumber="93" type="description">
<paragraph id="AB5910B44AC321AAE211A34449DA2431" pageId="null" pageNumber="93">
Unterscheidet sich von 
<taxonomicName id="ED2760365BE0792AE91E98F67061E24A" class="Magnoliopsida" family="Lamiaceae" genus="Ajuga" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="93" phylum="Tracheophyta" rank="species" species="reptans">
<emphasis id="ECCFBED262E30382A97B404D78C74CB9" italics="true" pageId="null" pageNumber="93">A. reptans</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="C5DE6BF680BC704295073043524EEAC7" italics="true" pageId="null" pageNumber="93">
Keine 
<normalizedToken id="6EA155F0F3D5C1F74C88C6D2CD9A2F1E" originalValue="Ausläufer" pageId="null" pageNumber="93">Auslaeufer</normalizedToken>
</emphasis>
, 10-20 cm hoch; Stengel meist ringsum zerstreut behaart; 
<normalizedToken id="0C7298197F2BD5B56377CB00B1535C7B" originalValue="Blätter" pageId="null" pageNumber="93">Blaetter</normalizedToken>
bis 10 cm lang und 5 cm breit, am Stengel dicht stehend, und deshalb 
<emphasis id="FF3C140378B975FBBD2FE514FC845394" italics="true" pageId="null" pageNumber="93">
die Pflanze 
<normalizedToken id="3E7385A25E6320B1565F290BAF92FAFF" originalValue="pyramidenförmig" pageId="null" pageNumber="93">pyramidenfoermig</normalizedToken>
aussehend, die 
<normalizedToken id="FCDACC78BDE32C191CB4AD80F5EE7A2B" originalValue="Blätter" pageId="null" pageNumber="93">Blaetter</normalizedToken>
im obern Teil des 
<normalizedToken id="0BC8863E9171C302EE146F94F3D2D0BC" originalValue="Blütenstandes" pageId="null" pageNumber="93">Bluetenstandes</normalizedToken>
etwa 2mal so lang wie die 
<normalizedToken id="21D88193F0204498F7E5928BCCAC6BE2" originalValue="Blüten" pageId="null" pageNumber="93">Blueten</normalizedToken>
;
</emphasis>
Kelch 5-7 mm lang; Krone 1-1,8 cm lang; 
<normalizedToken id="FC2301AF162AF09376416030B0043B79" originalValue="Teilfrüchte" pageId="null" pageNumber="93">Teilfruechte</normalizedToken>
2-2,5 mm lang und 1-1,5 mm breit. - 
<normalizedToken id="4C7F4625569E6CAB42034D31DC0C70FE" originalValue="Blüte" pageId="null" pageNumber="93">Bluete</normalizedToken>
: 
<normalizedToken id="8A5E4C1E7D399C85B412AB058E1882B8" originalValue="Später" pageId="null" pageNumber="93">Spaeter</normalizedToken>
<normalizedToken id="073E48B58458799C23649F13CAB6459D" originalValue="Frühling" pageId="null" pageNumber="93">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="1AD2EE4B483B14B8AA896D20C028F0C9" pageId="null" pageNumber="93">
<emphasis id="D65528FE0E22AF05F0C721444763A597" italics="true" pageId="null" pageNumber="93">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="71A0A0A44AEEE4E66A0F2BECB0F7A7AF" italics="true" pageId="null" pageNumber="93">32:</emphasis>
Material aus Skandinavien (
<normalizedToken id="9001F8DE12463902E05B90AB9C63C89C" originalValue="Löve" pageId="null" pageNumber="93">Loeve</normalizedToken>
und 
<normalizedToken id="8DEF7A42FC7CEA392036DED111C7AABD" originalValue="Löve" pageId="null" pageNumber="93">Loeve</normalizedToken>
1944b), aus dem Wallis (Favarger 1953), aus Island (
<normalizedToken id="440C899D1EAFE370517F491976FB679B" originalValue="Löve" pageId="null" pageNumber="93">Loeve</normalizedToken>
und 
<normalizedToken id="0F1C14C8E5D3C06DDCAFD7ED4278D602" originalValue="Löve" pageId="null" pageNumber="93">Loeve</normalizedToken>
1956b), aus Polen (Skalinska et al. 1971).
</paragraph>
<paragraph id="77DCE6A442B2572DBC2EDFF57F962468" pageId="null" pageNumber="93">
<emphasis id="88E1A6259A0EF16EC0769D02510CBC70" italics="true" pageId="null" pageNumber="93">Standort</emphasis>
. Subalpin, seltener montan und alpin. Ziemlich trockene bis feuchte, kalkarme, saure, lehmige 
<normalizedToken id="BBF01E8E596266589D250F939FC96CAA" originalValue="Böden" pageId="null" pageNumber="93">Boeden</normalizedToken>
. Magere Wiesen und Weiden (besonders Borstgras-Weiden). 
<emphasis id="6B6D513AE600907C8C2C01730D70A5CC" italics="true" pageId="null" pageNumber="93">Nardetum alpigenum</emphasis>
Br.-Bl. 1949, 
<emphasis id="DFD6BBA2D97F309BF3BD6432132D310C" italics="true" pageId="null" pageNumber="93">Festucetum Halleri</emphasis>
Br.-Bl. 1926.
</paragraph>
<paragraph id="64702E6923C129DCC2AF127CEE9F255E" pageId="null" pageNumber="93">
<emphasis id="498F8CB1B7F3287926745B95A00B09B0" italics="true" pageId="null" pageNumber="93">
Verbreitung. 
<normalizedToken id="5E21CCFEDF5D2FFDD4DBA676C61C026D" originalValue="Europäische" pageId="null" pageNumber="93">Europaeische</normalizedToken>
Pflanze:
</emphasis>
Island, Irland, Schottland, Skandinavien, Baltikum, Gebirge Mittel- und 
<normalizedToken id="356D9F5829E642976330E84994DEA0E9" originalValue="Südeuropas" pageId="null" pageNumber="93">Suedeuropas</normalizedToken>
(
<normalizedToken id="812D2E8939914F2D0B88A0557EBB6B74" originalValue="südwärts" pageId="null" pageNumber="93">suedwaerts</normalizedToken>
bis Nordspanien, Ligurien, Bulgarien); nach der Flora der URSS Bd. 20 nicht im Kaukasus. - Im Gebiet: Alpen (besonders Zentral- und 
<normalizedToken id="E3638CA05369D818D033898A67A57D37" originalValue="Südalpen" pageId="null" pageNumber="93">Suedalpen</normalizedToken>
), ziemlich 
<normalizedToken id="DEA77D0FB59A50D124B7383B63BDAD22" originalValue="häufig" pageId="null" pageNumber="93">haeufig</normalizedToken>
; Schwarzwald und Vogesen, selten.
</paragraph>
</subSubSection>
