<subSubSection id="D683861F923099A8A3E32BD416E352D3" pageId="null" pageNumber="446" type="description">
<paragraph id="684676585BAB306020B7E9926910A1A9" pageId="null" pageNumber="446">
Habitus wie 
<taxonomicName id="73A98FC26A37274314D9E2EDCB5AB22C" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="446" phylum="Tracheophyta" rank="species" species="norvegica">
<emphasis id="69D5C46D6F49E058F4B972F9F85FCD9A" italics="true" pageId="null" pageNumber="446">C. norvegica</emphasis>
</taxonomicName>
(Nr. 40). 
<normalizedToken id="7D5E1DF2D9FEE0011B52B78D67192BD8" originalValue="Grundständige" pageId="null" pageNumber="446">Grundstaendige</normalizedToken>
Blattscheiden gelbbraun bis rotbraun. 
<normalizedToken id="A7D860D1AD5291D335D180E70C8FE1CC" originalValue="Blätter" pageId="null" pageNumber="446">Blaetter</normalizedToken>
2-4 mm breit, flach, steif, kaum 
<normalizedToken id="A199B66CDD582A2D3B23249F6E8707B0" originalValue="½" pageId="null" pageNumber="446">1/2</normalizedToken>
so lang wie der Stengel. Stengel 3kantig, nicht rauh. 
<normalizedToken id="CCE8988E51B79F269939FAE78F03CB47" originalValue="Blütenstand" pageId="null" pageNumber="446">Bluetenstand</normalizedToken>
kopfig, etwa 1 cm lang, aus 3-4 
<normalizedToken id="50ECF39978D797E7F0F76B5A99B709FC" originalValue="eiförmigen" pageId="null" pageNumber="446">eifoermigen</normalizedToken>
, 0,5-1 cm langen, sitzenden 
<normalizedToken id="041E36B88C875D85113514E085BABF3C" originalValue="Ähren" pageId="null" pageNumber="446">Aehren</normalizedToken>
bestehend; seitliche 
<normalizedToken id="510DD3C4460E4CE0E040CA6A0F200B9E" originalValue="Ähren" pageId="null" pageNumber="446">Aehren</normalizedToken>
♀, 
<normalizedToken id="F3BA82B1C4DC052B8ABBD47A854CD9B2" originalValue="endständige" pageId="null" pageNumber="446">endstaendige</normalizedToken>
<normalizedToken id="48D876AED869931E9DDD25CFEC1A2D7B" originalValue="Ähre" pageId="null" pageNumber="446">Aehre</normalizedToken>
unten ♂, oben ♀. Unterstes Hochblatt 
<normalizedToken id="EBBA9552B2DD24F7AA56F7A4D735FBF5" originalValue="blattähnlich" pageId="null" pageNumber="446">blattaehnlich</normalizedToken>
, den 
<normalizedToken id="8ABDAA83479B67C3AC729051383B002E" originalValue="Blü-" pageId="null" pageNumber="446">Blue-</normalizedToken>
<pageBreakToken id="2D6985F13DD38A9DBD32CD45117D63C9" pageId="null" pageNumber="446">tenstand</pageBreakToken>
oft 
<normalizedToken id="A2AEE93F6C9C08DB7F7467A3A08438FD" originalValue="überragend" pageId="null" pageNumber="446">ueberragend</normalizedToken>
. 
<normalizedToken id="70E230574B54C8515367D1051CAAB45F" originalValue="Tragblätter" pageId="null" pageNumber="446">Tragblaetter</normalizedToken>
⅔ bis ⅘ so lang wie die reifen 
<normalizedToken id="6C76A7689E3BCD2999E6F41F9761CD0E" originalValue="Fruchtschläuche" pageId="null" pageNumber="446">Fruchtschlaeuche</normalizedToken>
, spitz oder stumpf, schwarz, mit rotem Mittelnerv. 
<emphasis id="0D80948FEC81C0F638701B48E50E6A0E" italics="true" pageId="null" pageNumber="446">
<normalizedToken id="B78A1535FA49CEFB1DD5BD32B67F8BE8" originalValue="Fruchtschläuche" pageId="null" pageNumber="446">Fruchtschlaeuche</normalizedToken>
3-3,5 mm lang, in der Mitte am breitesten
</emphasis>
(
<emphasis id="6A4D119B9656E3D7BEDEF6423466F1D8" italics="true" pageId="null" pageNumber="446">2-2,3 mm</emphasis>
), stumpf 3kantig, ohne Nerven, 
<emphasis id="BD4AB31A88553303617903627F709230" italics="true" pageId="null" pageNumber="446">schwarz, mit hellem Rand</emphasis>
, 
<normalizedToken id="9B5CFC15521200DF9434293470C9DDA5" originalValue="plötzlich" pageId="null" pageNumber="446">ploetzlich</normalizedToken>
in den kleinen Schnabel 
<normalizedToken id="EEBD5AAFC2F814325F1310FFD82F2DB2" originalValue="verschmälert" pageId="null" pageNumber="446">verschmaelert</normalizedToken>
. Narben 3.
</paragraph>
<paragraph id="511B51A912AFDE599204CACC3DF3EE4F" pageId="null" pageNumber="446">
<emphasis id="DEB69D0954BD5D9514825273E06D0BA3" italics="true" pageId="null" pageNumber="446">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="7E9A8A799C72F92B4133ABA93DDDEC69" pageId="null" pageNumber="446">
<emphasis id="4D7A976815951B3D27806739FCB3CA33" italics="true" pageId="null" pageNumber="446">Standort.</emphasis>
Alpin. 
<normalizedToken id="5BC1C967AB8918A4047CAA046DAF88CF" originalValue="Ständig" pageId="null" pageNumber="446">Staendig</normalizedToken>
durchfeuchteter, kalkhaltiger Ruhschutt; in Mulden mit ziemlich langer Schneebedeckung. Besonders im 
<emphasis id="9ACD9F5495E70B24639F9C753462465D" italics="true" pageId="null" pageNumber="446">Salicetum retuso-reticulatae</emphasis>
Br.-Bl. 1926, seltener in lockerrasigen Urwiesen.
</paragraph>
<paragraph id="A87FEC3C46C69EC01F217F7ADBFFBDFA" pageId="null" pageNumber="446">
<emphasis id="237F6718C42C7717E6F782373F793EF9" italics="true" pageId="null" pageNumber="446">
Verbreitung. Mittel- und 
<normalizedToken id="55EE3CBB6B63BDF80CCFD9FFB56A6B14" originalValue="südeuropäische" pageId="null" pageNumber="446">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
Nordspanische Gebirge, 
<normalizedToken id="4F637BA57A26A0A9127F8C56E13A2615" originalValue="Pyrenäen" pageId="null" pageNumber="446">Pyrenaeen</normalizedToken>
, Alpen (Seealpen bis Ostalpen), Abruzzen, Tatra, Gebirge der Balkanhalbinsel, Kaukasus, kleinasiatische Gebirge. - Im Gebiet in den Alpen verbreitet, nicht 
<normalizedToken id="FA64C3907EE7FD90DFBDD0F0E47F21D4" originalValue="häufig" pageId="null" pageNumber="446">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="54C13CD6FEA648269329EFFE6C9C3994" pageId="null" pageNumber="446">
<emphasis id="B57E7E293410B57499F5074AC1FE601C" italics="true" pageId="null" pageNumber="446">Bemerkungen.</emphasis>
Von Hermann (1956) wird der Name 
<taxonomicName id="F636B119C8E5178718A72ED48F963C0E" authority="Schkuhr" authorityName="Schkuhr" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="446" phylum="Tracheophyta" rank="species" species="aethostachya">
<emphasis id="691DF873CFDD6A88B6DA0C099267AE5D" italics="true" pageId="null" pageNumber="446">C. aethostachya</emphasis>
Schkuhr
</taxonomicName>
gebraucht.
</paragraph>
</subSubSection>
