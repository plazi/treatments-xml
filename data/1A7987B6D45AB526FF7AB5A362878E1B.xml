(
<figureCitation id="0AEB2A25D45AB526FF72B47F626B8B51" box="[159,295,259,286]" captionStart-0="FIGURES 2" captionStart-1="FIGURES 3" captionStart-2="FIGURES 4" captionStart-3="FIGURES 5" captionStart-4="FIGURES 6" captionStartId-0="4.[151,264,1944,1968]" captionStartId-1="5.[151,264,1901,1925]" captionStartId-2="6.[151,264,1943,1967]" captionStartId-3="7.[151,264,1983,2007]" captionStartId-4="8.[151,264,1943,1967]" captionTargetBox-0="[194,1393,181,1920]" captionTargetBox-1="[181,1406,181,1877]" captionTargetBox-2="[199,1387,181,1918]" captionTargetBox-3="[202,1385,597,1939]" captionTargetBox-4="[160,1428,184,1920]" captionTargetId-0="figure-18@4.[194,1393,181,1920]" captionTargetId-1="figure-21@5.[181,1406,181,1877]" captionTargetId-2="figure-18@6.[199,1388,181,1920]" captionTargetId-3="figure-216@7.[202,1385,597,1959]" captionTargetId-4="figure-18@8.[160,1428,181,1920]" captionTargetPageId-0="4" captionTargetPageId-1="5" captionTargetPageId-2="6" captionTargetPageId-3="7" captionTargetPageId-4="8" captionText-0="FIGURES 2(A–F). Occipitotus langpramensis sp. nov., holotype, female. (A) Head, lateral view; (B) habitus, lateral view; (C) apex of antenna; (D) base of antenna; (E) head, frontal view; (F) mesosoma, lateral view. Scale bars = 0.2 mm (A, C, D, E, F); 0.5 mm (B)." captionText-1="FIGURES 3(A–G). (A–E) Occipitotus langpramensis sp. nov., holotype, female. (A) Head, dorsal view; (B) mesosoma, dorsal view; (C) metasoma, dorsal view; (D) apex of metasoma, showing ovipositor sheath and ovipositor; (E) ovipositor; (F–G) paratype, female. (F) Pronotum, dorsal view, showing pronope; (G) propodeum + metasomal tergite I, dorsal view. Scale bars = 0.2 mm (A, B, C, D, F, G); 0.1 mm (E)." captionText-2="FIGURES 4(A–D). (A) Occipitotus langpramensis sp. nov., paratype, female, metasoma, dorsal view; (B–D), paratype, male; (B) habitus, lateral view; (C) head + pronotum, dorsal view, showing pronope; (D) mesosoma, dorsal view. Scale bars = 0.2 mm (A, C, D); 0.5 mm (B)." captionText-3="FIGURES 5(A–D). (A, D) Occipitotus langpramensis sp. nov., paratype, male. (A) Metasoma, dorsal view; (D) fore wing; (B–C) paratype, female. (B) fore wing; (C) hind wing. Scale bars = 0.2 mm (A); 0.5 mm (B, C, D)." captionText-4="FIGURES 6(A–E). Occipitotus langpramensis sp. nov., head, latero-posterior view. (A) Holotype, female; (B–E) paratypes. (B–D) females; (E) male. Scale bars = 0.2 mm." figureDoi-0="http://doi.org/10.5281/zenodo.6521271" figureDoi-1="http://doi.org/10.5281/zenodo.6521273" figureDoi-2="http://doi.org/10.5281/zenodo.6521275" figureDoi-3="http://doi.org/10.5281/zenodo.6521281" figureDoi-4="http://doi.org/10.5281/zenodo.6521283" httpUri-0="https://zenodo.org/record/6521271/files/figure.png" httpUri-1="https://zenodo.org/record/6521273/files/figure.png" httpUri-2="https://zenodo.org/record/6521275/files/figure.png" httpUri-3="https://zenodo.org/record/6521281/files/figure.png" httpUri-4="https://zenodo.org/record/6521283/files/figure.png" pageId="3" pageNumber="43">Figures 2–6</figureCitation>
)
</paragraph>
</subSubSection>
