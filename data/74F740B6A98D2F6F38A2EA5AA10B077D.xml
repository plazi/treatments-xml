<subSubSection id="00BFFBD077B120D28A668999D2081FAB" pageId="null" pageNumber="19" type="vernacular_names">
<paragraph id="7F1D872B30E3905B6F7F9AA2A1D3F2A0" pageId="null" pageNumber="19">Ausdauernder Moorenzian</paragraph>
</subSubSection>
</title>
<subSubSection id="C2DBAA94A980ED1EA1A01E479B290C27" pageId="null" pageNumber="19" type="description">
<paragraph id="6D98A3CB6E5A07B41E8D7634F71581AA" pageId="null" pageNumber="19">
<emphasis id="085C70E1F27DC22569E6FE09F6C3EF72" italics="true" pageId="null" pageNumber="19">Ausdauernd; 15</emphasis>
- 
<emphasis id="F5F3A98E5E81CF270F19C2EBAE337D95" italics="true" pageId="null" pageNumber="19">40 cm hoch.</emphasis>
Stengel einfach, aufrecht. 
<normalizedToken id="218E94D87C3B34D5C872C4A769713549" originalValue="Blätter" pageId="null" pageNumber="19">Blaetter</normalizedToken>
oval bis lanzettlich, die untern gestielt, die obern sitzend. Kelch 5teilig, mit schmal lanzettlichen Zipfeln. 
<emphasis id="DB1C01236752EABD294446AE22554BA4" italics="true" pageId="null" pageNumber="19">Krone dunkelviolett, dunkler punktiert</emphasis>
(
<emphasis id="55FD471F8070378FA0807D72663CD729" italics="true" pageId="null" pageNumber="19">
selten 
<normalizedToken id="69FBCA195E0206C6484332D3DC47FDA7" originalValue="weiß" pageId="null" pageNumber="19">weiss</normalizedToken>
</emphasis>
), am Grunde 
<normalizedToken id="89BE3AB21ACC4B123E1DD2B655FD0841" originalValue="grünlich" pageId="null" pageNumber="19">gruenlich</normalizedToken>
, im Durchmesser 2-3 cm. Frucht 1-1,5 cm lang. - 
<normalizedToken id="5D12DAFF6FC1A6662F2AAEF9F56AF3B4" originalValue="Blüte" pageId="null" pageNumber="19">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="10B6058F7BE2FCE65A3130467D150327" pageId="null" pageNumber="19">
<emphasis id="389D42E2FA124C22896E178F4F6C941E" italics="true" pageId="null" pageNumber="19">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="14C94B48EA281C4F6CB7EA2FFC75F257" italics="true" pageId="null" pageNumber="19">28:</emphasis>
Material vom Jura und Berner Oberland (Favarger 1952), aus den 
<normalizedToken id="24236D355FAD25774C1920F57DE632B3" originalValue="Südwestalpen" pageId="null" pageNumber="19">Suedwestalpen</normalizedToken>
(Delay 1970) und aus den Karpaten (
<taxonomicName id="340AF27E3E064EC6422CB8956B012C6C" pageId="null" pageNumber="19" rank="subSpecies" subSpecies="alpestris">
ssp. 
<emphasis id="8674491726FF02710CAF504C7EBF803A" italics="true" pageId="null" pageNumber="19">alpestris</emphasis>
</taxonomicName>
[Bmg.] Jav.) (Skalinska et al. 1959). Woycicki (1937) 
<normalizedToken id="3BD2E637C5FCECEB093119ABC43E3D29" originalValue="zählte" pageId="null" pageNumber="19">zaehlte</normalizedToken>
an unbekanntem Material 
<emphasis id="E9231503EF38A24522D07ADD9E6A1B3C" italics="true" pageId="null" pageNumber="19">2n</emphasis>
= 
<emphasis id="25D62423BFDF51094D636AD3A95E7437" italics="true" pageId="null" pageNumber="19">24.</emphasis>
</paragraph>
<paragraph id="E874AFE008EF9DEEA9853D3024F81B07" pageId="null" pageNumber="19">
<emphasis id="BC2B18B8D42300179462C9E43196F2B8" italics="true" pageId="null" pageNumber="19">Standort.</emphasis>
Montan und subalpin. Sickernasse, kalkhaltige, oft torfige 
<normalizedToken id="34B69075BF5B79DAB5429AC2A8FCADFD" originalValue="Böden" pageId="null" pageNumber="19">Boeden</normalizedToken>
. Flachmoore, Quellmoore. 
<emphasis id="893C8A40403F563992150F91C6D27092" italics="true" pageId="null" pageNumber="19">Caricetum Davallianae</emphasis>
(Br.-Bl.) W. Koch 1926.
</paragraph>
<paragraph id="EA1AC4439F1CA78553A4375B25442426" pageId="null" pageNumber="19">
<emphasis id="F8BD93C09D239FCF291473F6CBB03280" italics="true" pageId="null" pageNumber="19">
Verbreitung. Mittel- und 
<normalizedToken id="C3FA96C2479E802E29D8DB122E65FF04" originalValue="südeuropäische" pageId="null" pageNumber="19">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
<normalizedToken id="CE8970C76EBEC7FDAC55AE4707E1E9EB" originalValue="Pyrenäen" pageId="null" pageNumber="19">Pyrenaeen</normalizedToken>
, Plateau Central, Jura, Alpen und Alpenvorland, Apennin, Gebirge der Balkanhalbinsel, Karpaten, mitteldeutsche Gebirge, norddeutsche Tiefebene, Estland, Polen. 3 nahe verwandte Arten in Sibirien, Zentral- und Ostasien. - Im Gebiet: Jura (
<normalizedToken id="F093C202940B8184C6C031E9E51EDFAB" originalValue="nordostwärts" pageId="null" pageNumber="19">nordostwaerts</normalizedToken>
bis 
<pageBreakToken id="58771B22E9A305C51706A0A317CB7783" pageId="null" pageNumber="19">in</pageBreakToken>
den Berner Jura), Schwarzwald (Feldberg, Hinterzarten). Baar, deutsches Bodenseegebiet, 
<normalizedToken id="8A3549B028D45558FDC3F818828A6C1B" originalValue="nördliches" pageId="null" pageNumber="19">noerdliches</normalizedToken>
Alpenvorland, Nordalpen, Zentralalpen (nur am Mont Cenis, in der untern Tarentaise und in der Umgebung der Lenzerheide); 
<normalizedToken id="0024FB759BB530912F97E1115C8CC99F" originalValue="Südalpen" pageId="null" pageNumber="19">Suedalpen</normalizedToken>
(Val Divedro in der Valle 
<normalizedToken id="FAE56180B2CB6D55DF5803F59B2A84E5" originalValue="d’Ossola" pageId="null" pageNumber="19">d'Ossola</normalizedToken>
); nicht 
<normalizedToken id="21B12DB3E4ECA558CAFFB094294C4F60" originalValue="häufig" pageId="null" pageNumber="19">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
