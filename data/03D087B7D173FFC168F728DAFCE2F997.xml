T y p e s p e c i e s: 
<materialsCitation id="3B113CFCD173FFC169EC2997FB01FBD7" ID-GBIF-Occurrence="3751756305" country="Moldova" location="Kishinev" municipality="Kishinev" pageId="2" pageNumber="421" specimenCount="1" stateProvince="Eastern Europe" typeStatus="holotype">
