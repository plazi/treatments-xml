, 
<collectingCountry id="F36E7631D173FFC1694D2E77FE4FFBD7" box="[284,392,1030,1056]" name="Moldova" pageId="2" pageNumber="421">Moldova</collectingCountry>
, 
<collectingRegion id="49BDF843D173FFC169C32E76FD8FFBD6" box="[402,584,1031,1057]" pageId="2" pageNumber="421">Eastern Europe</collectingRegion>
(
