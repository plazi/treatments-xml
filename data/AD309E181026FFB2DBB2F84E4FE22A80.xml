<paragraph id="25262F0E1022FFB2DBE2F83749282BF8" blockId="7.[151,1437,1916,2015]" lastBlockId="8.[151,1437,150,429]" lastPageId="8" lastPageNumber="109" pageId="7" pageNumber="108">
<emphasis id="17EDF31C1022FFBDDBE2F8374D432CBB" bold="true" box="[199,374,1916,1942]" pageId="7" pageNumber="108">Measurements</emphasis>
