<subSubSection id="33F98A35589289694DF585511A47F170" pageId="null" pageNumber="497" type="description">
<paragraph id="6FF33CA66D8361E5C8BC97920908DCC7" pageId="null" pageNumber="497">
<emphasis id="7C4AFB5BE1DA7B6CFC9A4B492453032F" italics="true" pageId="null" pageNumber="497">
<normalizedToken id="2843D4C821FCAAAD2710CCA900AFB151" originalValue="Zähne" pageId="null" pageNumber="497">Zaehne</normalizedToken>
der untern 
<normalizedToken id="FCDBEFC0196A6A20FFED89B3571A9A8E" originalValue="Blätter" pageId="null" pageNumber="497">Blaetter</normalizedToken>
2
</emphasis>
- 
<emphasis id="A54073C9F4F592BCB9AAC8E0B9B13615" italics="true" pageId="null" pageNumber="497">
4 mm lang. 
<normalizedToken id="2646F58F0E9D9616BFC43A67005D9582" originalValue="Blätter" pageId="null" pageNumber="497">Blaetter</normalizedToken>
im obersten Stengeldrittel 3
</emphasis>
- 
<emphasis id="86A7941E9008DC4AC99598FE9014CCAC" italics="true" pageId="null" pageNumber="497">
5mal so lang wie breit, mit 
<normalizedToken id="1D4925BE3DEA047B5F8385019892A265" originalValue="verschmälertem" pageId="null" pageNumber="497">verschmaelertem</normalizedToken>
Grunde meist sitzend und oft den Stengel teilweise umfassend
</emphasis>
. 
<normalizedToken id="75F30D9B2BB32AC31F7F634B459DAA4B" originalValue="Blütenköpfe" pageId="null" pageNumber="497">Bluetenkoepfe</normalizedToken>
mit 4-8 
<normalizedToken id="A013958FCC5D02D2E5322F43AA2D17F5" originalValue="zungenförmigen" pageId="null" pageNumber="497">zungenfoermigen</normalizedToken>
<normalizedToken id="C686F1C4F23C8AAB7949DDE0DD1D940B" originalValue="Blüten" pageId="null" pageNumber="497">Blueten</normalizedToken>
, im Durchmesser 2,5-3 cm. 
<emphasis id="228C65F3D521553392C6259958341C26" italics="true" pageId="null" pageNumber="497">
<normalizedToken id="B7495E84232BF07EC4483D9F2B9B7E78" originalValue="Hülle" pageId="null" pageNumber="497">Huelle</normalizedToken>
in der Mitte 3
</emphasis>
- 
<emphasis id="C68EB1D17626B81566A26CC0013552AA" italics="true" pageId="null" pageNumber="497">4 mm dick</emphasis>
, von wenigen, halb bis fast so langen 
<normalizedToken id="9ABFA8464451779CB1440ECF3C49695E" originalValue="Blättern" pageId="null" pageNumber="497">Blaettern</normalizedToken>
umgeben, die 
<emphasis id="1513DC3088D79E95F8470D90BB858C49" italics="true" pageId="null" pageNumber="497">am Grunde kurze, mehrzellige Haare tragen;</emphasis>
innere 
<normalizedToken id="6A8C7C6DED6D6A2E771DA856E44F10E0" originalValue="Hüllblätter" pageId="null" pageNumber="497">Huellblaetter</normalizedToken>
10-12, kahl oder zerstreut behaart. Kronen gelb. - 
<normalizedToken id="9D55FF4833DD56452639CBF1A7D72FF5" originalValue="Blüte" pageId="null" pageNumber="497">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="8B71DD3EFB5D5B1ED92F2A9B23734CD0" originalValue="früher" pageId="null" pageNumber="497">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="DEE37D74C308F97A4A1EB9EB572A56A2" pageId="null" pageNumber="497">
<emphasis id="C6BA181C37E4DB01C6683B122E85374C" italics="true" pageId="null" pageNumber="497">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="23ACF5097235D929E808F7E1C101D2EA" italics="true" pageId="null" pageNumber="497">40:</emphasis>
Material aus botanischen 
<normalizedToken id="BE241737C30C9119260CED5F40B0739D" originalValue="Gärten" pageId="null" pageNumber="497">Gaerten</normalizedToken>
(Matsuura und 
<normalizedToken id="2EFA180F185E47360DFA32E986FE9D6D" originalValue="Sutô" pageId="null" pageNumber="497">Suto</normalizedToken>
1935, Zhukova 1964 1967b), aus Japan (Arano 1964 1965 1968).
</paragraph>
<paragraph id="5F30AF97CB0EC146A7358B2890912E5D" pageId="null" pageNumber="497">
<emphasis id="E66828E7DFADEA5DD89CB25282C25EF5" italics="true" pageId="null" pageNumber="497">Standort</emphasis>
. Subalpin, seltener montan. 
<normalizedToken id="1AF5CC8E5FDD880EA8002B870629AFDF" originalValue="Mäßig" pageId="null" pageNumber="497">Maessig</normalizedToken>
feuchte, lockere, 
<normalizedToken id="59C01CC477AC0489D2260542DB2D1165" originalValue="nährstoffreiche" pageId="null" pageNumber="497">naehrstoffreiche</normalizedToken>
, humose 
<normalizedToken id="E756998A6F39559B89754B1E8EA599DE" originalValue="Böden" pageId="null" pageNumber="497">Boeden</normalizedToken>
in luftfeuchten Lagen. Hochstaudenfluren, hochstaudenreiche 
<normalizedToken id="CEDBA51B6E8754C22082A1811DE9F065" originalValue="Wälder" pageId="null" pageNumber="497">Waelder</normalizedToken>
, 
<normalizedToken id="4EBF0B53365B70C8051DD5D42AF12967" originalValue="Grünerlengebüsche" pageId="null" pageNumber="497">Gruenerlengebuesche</normalizedToken>
, 
<normalizedToken id="B66BA0E99E647D93B79604661A4F32D5" originalValue="Lägerstellen" pageId="null" pageNumber="497">Laegerstellen</normalizedToken>
.
</paragraph>
<paragraph id="134569A4B6388B25594E532E162C1616" pageId="null" pageNumber="497">
<emphasis id="AEBDB6E5DBC818F504D526E67A9D4604" italics="true" pageId="null" pageNumber="497">Verbreitung. Eurasiatische Pflanze:</emphasis>
<normalizedToken id="2A46BA2EF754AF0F612E2657A0E3E789" originalValue="Nordwärts" pageId="null" pageNumber="497">Nordwaerts</normalizedToken>
bis Nordfrankreich, Mitteldeutschland, 
<normalizedToken id="F96E198E5218E2C5C8F055C6588083AA" originalValue="Südpolen" pageId="null" pageNumber="497">Suedpolen</normalizedToken>
, 
<normalizedToken id="15752DFD2A2510BDED6212C49E28DA1C" originalValue="Mittelrußland" pageId="null" pageNumber="497">Mittelrussland</normalizedToken>
; 
<normalizedToken id="0915B6293B29A2B814C9BEF649F69BA6" originalValue="südwärts" pageId="null" pageNumber="497">suedwaerts</normalizedToken>
bis 
<normalizedToken id="DE60F23EF1168B5BF27D767C7F7AABEE" originalValue="Pyrenäen" pageId="null" pageNumber="497">Pyrenaeen</normalizedToken>
, Norditalien, Albanien, Rhodopegebirge, Kaukasus; 
<normalizedToken id="0BE04F97DEEBBED39E94450DA37C2A82" originalValue="ostwärts" pageId="null" pageNumber="497">ostwaerts</normalizedToken>
bis Japan (?). - Im Gebiet: Alpen, Jura, Vogesen, Schwarzwald; ziemlich 
<normalizedToken id="396405736113D3246218EB077C85EB24" originalValue="häufig" pageId="null" pageNumber="497">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
