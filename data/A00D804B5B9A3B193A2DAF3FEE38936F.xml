<subSubSection id="2003DCF5DDA552F3CF8E9189D61C24CD" pageId="null" pageNumber="613" type="description">
<paragraph id="6028A9092F6BC3A1E856B04E00D4A0AA" pageId="null" pageNumber="613">
Knollen nebeneinander. Stengel 10-30 cm hoch. 
<normalizedToken id="0EE3EBDA69E10DE9316F9C827916416F" originalValue="Blätter" pageId="null" pageNumber="613">Blaetter</normalizedToken>
1-2, das obere (
<normalizedToken id="065F8ACCCD8B30D650C1ECC7F31FC57C" originalValue="größte" pageId="null" pageNumber="613">groesste</normalizedToken>
) 
<emphasis id="1E7D126B5F7260B88340BE15EBA2B77C" italics="true" pageId="null" pageNumber="613">bis 6 cm lang, 1</emphasis>
<normalizedToken id="6891DC0F9172D3936439832C0B5F25E7" originalValue="½" pageId="null" pageNumber="613">1/2</normalizedToken>
<emphasis id="4D5403CB0B3B6D13ACB8E847EB922E9A" italics="true" pageId="null" pageNumber="613">-3mal so lang wie breit.</emphasis>
<normalizedToken id="0ABE6C24C2AE4B4259713C905B9F00E2" originalValue="Tragblätter" pageId="null" pageNumber="613">Tragblaetter</normalizedToken>
wie bei 
<taxonomicName id="5AB59714EF9A696A6498C119398E3083" class="Liliopsida" family="Orchidaceae" genus="Hammarbya" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="613" phylum="Tracheophyta" rank="species" species="paludosa">
<emphasis id="7EAAAE572C0D0AD7A88AB35EC830348F" italics="true" pageId="null" pageNumber="613">M. paludosa</emphasis>
</taxonomicName>
(Nr. 1). 
<normalizedToken id="87A8AF143FB563698F3FE78B2F0CB524" originalValue="Äußere" pageId="null" pageNumber="613">Aeussere</normalizedToken>
<normalizedToken id="75654F43AA0E002AE9DF4D11796ADB59" originalValue="Perigonblätter" pageId="null" pageNumber="613">Perigonblaetter</normalizedToken>
vom Grunde an 
<normalizedToken id="B253DD7EFC51C664AAF2C644FB172EFB" originalValue="verschmälert" pageId="null" pageNumber="613">verschmaelert</normalizedToken>
, 1,5-2 mm lang, am Grunde etwa 1 mm breit; innere 
<normalizedToken id="85CB0E0F7965FBCC450A520D7ABDADD8" originalValue="Perigonblätter" pageId="null" pageNumber="613">Perigonblaetter</normalizedToken>
etwa so lang wie die 
<normalizedToken id="50CE62713F45AEDB1EDAA4E4E2EAB0BD" originalValue="äußern" pageId="null" pageNumber="613">aeussern</normalizedToken>
, 
<emphasis id="CCF29A8C72980266E519F4A5841AE273" italics="true" pageId="null" pageNumber="613">sehr schmal, nur 0,3 mm breit, fast parallelrandig, 6-10mal so lang wie breit; Lippe breit lanzettlich</emphasis>
, 
<normalizedToken id="1073696B827B53F881B0E8F323660540" originalValue="plötzlich" pageId="null" pageNumber="613">ploetzlich</normalizedToken>
zugespitzt, so lang wie die 
<normalizedToken id="CD9279379FAAF09C26F958382AAC83D2" originalValue="Perigonblätter" pageId="null" pageNumber="613">Perigonblaetter</normalizedToken>
, am Grunde mit wulstigen, glatten 
<normalizedToken id="1E9CA4A1EF8C100D2D26B7785050D2A1" originalValue="Rändern" pageId="null" pageNumber="613">Raendern</normalizedToken>
. - 
<normalizedToken id="335D2E23D8DD1A727712E980F5E87707" originalValue="Blüte" pageId="null" pageNumber="613">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="5FD2A7B204E7D125B2FF68354E7121BE" pageId="null" pageNumber="613">
<emphasis id="5F4E2FC2558CCF33131D98FA15EEAA81" italics="true" pageId="null" pageNumber="613">Zytologische Angaben. 2n = ca. 30:</emphasis>
Material aus Skandinavien (Hagerup aus 
<normalizedToken id="1A7BA2C91D96FA8508D67B81457CE2E4" originalValue="Löve" pageId="null" pageNumber="613">Loeve</normalizedToken>
und 
<normalizedToken id="E1E662945E0EEAE32528C875B84326C4" originalValue="Löve" pageId="null" pageNumber="613">Loeve</normalizedToken>
1942b), aus Schweden (Hagerup 1944a).
</paragraph>
<paragraph id="D9F25F1CA88B00457FA503CE26D548CA" pageId="null" pageNumber="613">
<emphasis id="48681EBA8BB9DE2CECD1FCCA37D9F9E5" italics="true" pageId="null" pageNumber="613">Standort.</emphasis>
Montan (bis 1600 m): Schattige, kurzrasige, feuchte Waldwiesen und Moore.
</paragraph>
<paragraph id="8F149DD41C9045DFDBF6B3CDA61F12CB" pageId="null" pageNumber="613">
<emphasis id="E1FD007143F3D5D8EBB2A4B1A56E36C6" italics="true" pageId="null" pageNumber="613">Verbreitung. Eurosibirische Pflanze:</emphasis>
Nordgrenze in Skandinavien bei 66° NB, Finnland, Karelien, 
<normalizedToken id="33483A50F5BB08C423CA023AC0AE1F6C" originalValue="westwärts" pageId="null" pageNumber="613">westwaerts</normalizedToken>
bis 
<normalizedToken id="61D004645B55EAC64A0985BF65428117" originalValue="Südnorwegen" pageId="null" pageNumber="613">Suednorwegen</normalizedToken>
, Rheingebiet, Westalpen; 
<normalizedToken id="72F3B0D749835FFEF73A144430B9E01A" originalValue="Südgrenzen" pageId="null" pageNumber="613">Suedgrenzen</normalizedToken>
durch die Alpen, Karpaten; in 
<normalizedToken id="8328B0F60DE8836DE887A084DF19DF22" originalValue="Rußland" pageId="null" pageNumber="613">Russland</normalizedToken>
und Sibirien zwi- 
<pageBreakToken id="2465EAAABE6499CA88C15FAA69748738" pageId="null" pageNumber="613">schen</pageBreakToken>
50 und 60° NB; 
<normalizedToken id="14634D5DB9724FD7D4609CD07D98CA51" originalValue="ostwärts" pageId="null" pageNumber="613">ostwaerts</normalizedToken>
bis Japan und Kamtschatka, 
<normalizedToken id="90387073F41180408A463566F8EF0968" originalValue="Südchina" pageId="null" pageNumber="613">Suedchina</normalizedToken>
. Angaben aus dem Himalaja und Nordamerika beziehen sich auf andere Arten. Verbreitungskarte von 
<normalizedToken id="0DF567AC06D6892C12880F1D79F6B77F" originalValue="Hultén" pageId="null" pageNumber="613">Hulten</normalizedToken>
(1962). - Im Gebiet durch die Alpen vom Berner Oberland 
<normalizedToken id="D0226424A9474DF6A3D2A60D6CD34B1C" originalValue="ostwärts" pageId="null" pageNumber="613">ostwaerts</normalizedToken>
und 
<normalizedToken id="9A552ABF6F8D5DB9F723281830FB9007" originalValue="südwärts" pageId="null" pageNumber="613">suedwaerts</normalizedToken>
bis Veltlin und Bormio (aus dem Wallis und Aostatal nicht angegeben, im Tessin nur im Norden), im Schwarzwald nach Oberdorfer (1962) nicht mehr gefunden; selten.
</paragraph>
</subSubSection>
