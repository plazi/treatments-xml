<typeStatus id="54A7A98EFFB81B52F565FD559CC8D7BB" box="[798,899,739,765]" pageId="4" pageNumber="309">holotype</typeStatus>
, female— 
<collectingRegion id="49D8D9CEFFB81B52F583FD559B20D7BB" box="[1016,1131,739,765]" country="United States of America" name="California" pageId="4" pageNumber="309">California</collectingRegion>
, 
<collectingCountry id="F30B57BCFFB81B52F20EFD529BE0D7B8" box="[1141,1195,740,766]" name="United States of America" pageId="4" pageNumber="309">USA</collectingCountry>
