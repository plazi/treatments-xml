<taxonomicName id="4C514D6DFFF0FFF6FAF74C962FEBFE0D" authorityName="Blackwall" authorityYear="1841" box="[1352,1436,445,466]" class="Arachnida" family="Agelenidae" genus="Agelena" kingdom="Animalia" order="Araneae" pageId="10" pageNumber="565" phylum="Arthropoda" rank="species" species="montana">
