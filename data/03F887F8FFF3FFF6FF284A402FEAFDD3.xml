<taxonomicName id="4C514D6DFFF0FFF6FAF04C6C2FEBFE83" baseAuthorityName="Simon" baseAuthorityYear="1875" box="[1359,1436,327,348]" class="Arachnida" family="Hahniidae" genus="Iberina" kingdom="Animalia" order="Araneae" pageId="10" pageNumber="565" phylum="Arthropoda" rank="species" species="candida">
