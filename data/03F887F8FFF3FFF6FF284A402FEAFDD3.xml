<taxonomicName id="4C514D6DFFF0FFF6FCA84CA92911FE48" baseAuthorityName="Harm" baseAuthorityYear="1966" box="[791,870,386,407]" class="Arachnida" family="Hahniidae" genus="Iberina" kingdom="Animalia" order="Araneae" pageId="10" pageNumber="565" phylum="Arthropoda" rank="species" species="difficilis">
