<taxonomicName id="4C514D6DFFF0FFF6FD2D4CA82891FE47" authorityName="Blackwall" authorityYear="1841" box="[658,742,387,408]" class="Arachnida" family="Agelenidae" genus="Agelena" kingdom="Animalia" order="Araneae" pageId="10" pageNumber="565" phylum="Arthropoda" rank="species" species="montana">
