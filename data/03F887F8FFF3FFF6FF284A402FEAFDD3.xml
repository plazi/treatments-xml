<paragraph id="8BEE36EEFFF0FFF6FF284DDB2FEBFEE0" blockId="10.[151,1437,151,525]" pageId="10" pageNumber="565">
<keyLead id="30A095DBFFF0FFF6FF284DDB2FEBFEE0" pageId="10" pageNumber="565">
- Eyes reduced (
<collectingCountry id="F346767EFFF0FFF6FED14DDB2B98FEDA" box="[366,495,239,261]" name="United Kingdom" pageId="10" pageNumber="565">Great Britain</collectingCountry>
, 
<collectingCountry id="F346767EFFF0FFF6FE474DDB2825FEDA" box="[504,594,240,261]" name="Germany" pageId="10" pageNumber="565">Germany</collectingCountry>
, 
<collectingCountry id="F346767EFFF0FFF6FDE44DC428A7FEDA" box="[603,720,239,261]" name="Switzerland" pageId="10" pageNumber="565">Switzerland</collectingCountry>
, 
<collectingCountry id="F346767EFFF0FFF6FD664DC4295EFEDA" box="[729,809,239,261]" name="Czech Republic" pageId="10" pageNumber="565">Czechia</collectingCountry>
, 
<collectingCountry id="F346767EFFF0FFF6FC8D4DC429FFFEDA" box="[818,904,239,261]" name="Slovakia" pageId="10" pageNumber="565">Slovakia</collectingCountry>
, 
<collectingCountry id="F346767EFFF0FFF6FC2D4DDB2991FEDA" box="[914,998,240,261]" name="Hungary" pageId="10" pageNumber="565">Hungary</collectingCountry>
