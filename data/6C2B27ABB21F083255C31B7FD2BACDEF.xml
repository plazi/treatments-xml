<td id="3E15DCD35471BFAD6877938EBE6BEEB1" align="left" pageId="null" pageNumber="512" valign="top">1. Stengel niederliegend oder aufsteigend, bis 3 mm dick; Krone 4-6 mm lang</td>
<td id="99A59B4FB763BCFAEDE1D3180730C39B" align="left" pageId="null" pageNumber="512" valign="bottom">
<taxonomicName id="D84DAF609D9FE5EC14933A546D0E2683" class="Magnoliopsida" family="Fabaceae" genus="Trifolium" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="512" phylum="Tracheophyta" rank="species" species="resupinatum">
<italic id="F3FC2CB26164A2D37AE108190ACE05AB" pageId="null" pageNumber="512">T. resupinatum</italic>
</taxonomicName>
(Nr. 6a)
</td>
</tr>
<tr id="D38DD98DE610CC69BB3FD5395CE0833F" pageId="null" pageNumber="512">
<td id="C05B35757D92EECD651874DEEAF0C4BB" align="left" pageId="null" pageNumber="512" valign="top">
1*. Stengel aufrecht, 
<normalizedToken id="AB6A0854E13CAE0ED4F6781334EB6D31" originalValue="auffällig" pageId="null" pageNumber="512">auffaellig</normalizedToken>
dick und hohl (unten dicker als 4 mm); Krone 6-8 mm lang
</td>
<td id="8F541104883A0305A1AE377A5722F24B" align="left" pageId="null" pageNumber="512" valign="bottom">
<taxonomicName id="F761A460F3206B6483AFE477BACA6419" class="Magnoliopsida" family="Fabaceae" genus="Trifolium" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="512" phylum="Tracheophyta" rank="species" species="suaveolens">
<italic id="977550463943D43372AB4947F11E6FF9" pageId="null" pageNumber="512">T. suaveolens</italic>
</taxonomicName>
(Nr. 6b)
</td>
</tr>
</tbody>
