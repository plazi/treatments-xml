<paragraph id="12EE82F272232394BDD834B5E47934E3" pageId="null" pageNumber="512">
Artengruppe des 
<taxonomicName id="7905E867BD28EFF8E9EE9358A8E9437F" authority="L." class="Magnoliopsida" family="Fabaceae" genus="Trifolium" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="512" phylum="Tracheophyta" rank="species" species="resupinatum">
Trifolium 
<normalizedToken id="83417C8BEED83DD9225280F593C5EF79" originalValue="resupinátum" pageId="null" pageNumber="512">resupinatum</normalizedToken>
<authorityName id="5D198AA77590DFDB3DCDB219888611FF" pageId="null" pageNumber="512">L.</authorityName>
</taxonomicName>
</paragraph>
