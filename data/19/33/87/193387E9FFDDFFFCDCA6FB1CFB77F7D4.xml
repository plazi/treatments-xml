[
<collectingRegion box="[697,829,1138,1160]" country="India" name="West Bengal" pageId="1" pageNumber="218">West Bengal</collectingRegion>
], Sinchul [Senchal], 
<collectionCode box="[1034,1045,1139,1160]" country="South Africa" lsid="urn:lsid:biocol.org:col:14647" name="University of the Witwatersrand" pageId="1" pageNumber="218" type="Herbarium">J</collectionCode>
.D. Hooker 1411, 
