<collectionCode box="[1126,1137,1103,1124]" country="South Africa" lsid="urn:lsid:biocol.org:col:14647" name="University of the Witwatersrand" pageId="1" pageNumber="218" type="Herbarium">J</collectionCode>
.D. Hooker 1411, 
<collectionCode box="[1306,1341,1102,1124]" country="USA" lsid="urn:lsid:biocol.org:col:15556" name="William and Lynda Steere Herbarium of the New York Botanical Garden" pageId="1" pageNumber="218" type="Herbarium">NY</collectionCode>
00236760); 2. 
<typeStatus box="[162,258,1139,1160]" pageId="1" pageNumber="218">Lectotype</typeStatus>
of 
<taxonomicName authority="Mitt." authorityName="Mitt." box="[295,535,1138,1160]" class="Jungermanniopsida" family="Lepidoziaceae" genus="Lepidozia" kingdom="Plantae" order="Jungermanniales" pageId="1" pageNumber="218" phylum="Marchantiophyta" rank="species" species="flexuosa">
