<subSubSection lastPageId="3" lastPageNumber="220" pageId="2" pageNumber="219" type="discussion">
<paragraph blockId="2.[136,1452,1900,2070]" lastBlockId="3.[136,1452,157,544]" lastPageId="3" lastPageNumber="220" pageId="2" pageNumber="219">
<collectorName box="[136,210,1974,1998]" pageId="2" pageNumber="219">Mitten</collectorName>
, in the year 1861, first described the taxon 
<taxonomicName authority="Mitten (1861: 104)" authorityName="Mitten" authorityPageNumber="104" authorityYear="1861" box="[684,1114,1974,1998]" class="Jungermanniopsida" family="Lepidoziaceae" genus="Lepidozia" kingdom="Plantae" order="Jungermanniales" pageId="2" pageNumber="219" phylum="Marchantiophyta" rank="species" species="brevifolia">
<emphasis box="[684,900,1974,1998]" italics="true" pageId="2" pageNumber="219">Lepidozia brevifolia</emphasis>
<bibRefCitation author="Mitten, W." box="[908,1114,1974,1998]" pageId="2" pageNumber="219" pagination="89 - 128" refId="ref2054" refString="Mitten, W. (1861) Hepaticae Indiae Orientalis. Journal of the Proceedings of the Linnean Society. Botany 5: 89 - 128. https: // doi. org / 10.1111 / j. 1095 - 8312.1860. tb 01045. x" type="journal article" year="1861">Mitten (1861: 104)</bibRefCitation>
</taxonomicName>
based on a specimen collected from 
<collectorName box="[195,423,2010,2034]" pageId="2" pageNumber="219">Himalayae Orientalis</collectorName>
by 
<collectionCode box="[465,477,2010,2033]" country="South Africa" lsid="urn:lsid:biocol.org:col:14647" name="University of the Witwatersrand" pageId="2" pageNumber="219" type="Herbarium">J</collectionCode>
. 
<collectorName box="[481,596,2010,2034]" pageId="2" pageNumber="219">D. Hooker</collectorName>
(No. 1417) without 
<typeStatus box="[817,863,2010,2034]" pageId="2" pageNumber="219">type</typeStatus>
designation. 
<collectorName box="[1007,1069,2010,2034]" pageId="2" pageNumber="219">There</collectorName>
is a specimen in 
<collectionCode box="[1258,1296,2010,2033]" country="USA" lsid="urn:lsid:biocol.org:col:15556" name="William and Lynda Steere Herbarium of the New York Botanical Garden" pageId="2" pageNumber="219" type="Herbarium">NY</collectionCode>
with collector number 
<emphasis box="[227,414,2046,2070]" italics="true" pageId="2" pageNumber="219">
<collectionCode box="[227,241,2046,2070]" country="South Africa" lsid="urn:lsid:biocol.org:col:14647" name="University of the Witwatersrand" pageId="2" pageNumber="219" type="Herbarium">J</collectionCode>
. 
<collectorName box="[244,351,2046,2070]" pageId="2" pageNumber="219">D.Hooker</collectorName>
1317
</emphasis>
(Barcode 
<specimenCode box="[531,677,2046,2070]" collectionCode="NY" country="USA" lsid="urn:lsid:biocol.org:col:15556" name="William and Lynda Steere Herbarium of the New York Botanical Garden" pageId="2" pageNumber="219" type="Herbarium">NY00236747</specimenCode>
) collected by 
<collectorName box="[836,916,2046,2070]" pageId="2" pageNumber="219">Hooker</collectorName>
from 
<location LSID="urn:lsid:plazi:treatment:193387E9FFDFFFFEDCA6F87EFC0FFDC6:94456024FFDFFFFFDFF7F811FBBCF7CF" box="[985,1083,2046,2070]" name="Yumtong" pageId="2" pageNumber="219" stateProvince="Sikkim">Yumtong</location>
[=Yumthung], 
<collectingRegion box="[1252,1332,2046,2070]" country="India" name="Sikkim" pageId="2" pageNumber="219">Sikkim</collectingRegion>
, 
<quantity box="[1346,1452,2046,2070]" metricMagnitude="3" metricUnit="m" metricValue="3.6576" pageId="2" pageNumber="219" unit="ft" value="12000.0">
<elevation box="[1346,1452,2046,2070]" metricMagnitude="3" metricUnit="m" metricValue="3.6576" pageId="2" pageNumber="219" unit="ft" value="12000.0">12,000 ft.</elevation>
</quantity>
on 
<date box="[171,380,157,183]" pageId="3" pageNumber="220" value="1849-09-05">
5 
<superScript attach="left" box="[184,196,157,171]" fontSize="6" pageId="3" pageNumber="220">th</superScript>
September 1849
</date>
(
<figureCitation box="[397,470,159,183]" captionStart="FIGURE B" captionStartId="2.[136,229,1650,1672]" captionTargetBox="[332,1255,190,1626]" captionTargetId="figure-30@2.[332,1255,190,1626]" captionTargetPageId="2" captionText="FIGURE B. 1. Holotype of Lepidozia brevifolia Mitt. (India, Sikkim, Yumtong [Yumthang], J.D.Hooker 1317 [1417], 5 September 1849, NY00236747); 2. Lepidozia brevifolia Mitt. (India, Sikkim, [Acc. No. G14981] J.D. Hooker, G00115203); 3. Lepidozia brevifolia Mitt. [India, Sikkim, [Acc. No. G14982] J.D. Hooker (G)]; 4. Lepidozia brevifolia Mitt. [India, N.W. India, Dehra Dun, [Acc. No. G14983] W. Gollan, 14 October 1900 (G)]. ©Copyright of the Board of Trustees of the New York Botanical Garden, New York and ©Conservatoire et Jardin botaniques de la Ville de Genève." pageId="3" pageNumber="220">Fig. B</figureCitation>
1). 
<bibRefCitation author="Thiers, B. M." box="[503,651,159,183]" pageId="3" pageNumber="220" pagination="271 - 300" refId="ref2131" refString="Thiers, B. M. (1983) Index to the genera and species of Hepaticae described by William Mitten. Brittonia 35 (3): 271 - 300. https: // doi. org / 10.2307 / 2806026" type="journal article" year="1983">Thiers (1983)</bibRefCitation>
noted that the 
<typeStatus box="[816,909,159,183]" pageId="3" pageNumber="220">holotype</typeStatus>
is present in NY with its isotype at BM. Leonard T. Ellis, Senior Curator, BM is of the same opinion and mentioned that Mitten had mislabeled the specimen as ‘1317’ rather than ‘1417’ and this was very common in Mitten’s herbarium (L. Ellis 
<emphasis box="[961,1085,232,255]" italics="true" pageId="3" pageNumber="220">pers. comm</emphasis>
., 2021). In herbarium G, there are specimens 
<accessionNumber box="[253,339,267,291]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/G14981" pageId="3" pageNumber="220">G14981</accessionNumber>
[an old G accession number] collected by J.D. Hooker (Barcode G00115203) cited as original, collected from 
<collectingRegion box="[195,275,303,327]" country="India" name="Sikkim" pageId="3" pageNumber="220">Sikkim</collectingRegion>
, 
<quantity box="[286,390,303,327]" metricMagnitude="3" metricUnit="m" metricValue="3.6576" pageId="3" pageNumber="220" unit="ft" value="12000.0">12,000 ft.</quantity>
(
<figureCitation box="[404,474,303,327]" captionStart="FIGURE B" captionStartId="2.[136,229,1650,1672]" captionTargetBox="[332,1255,190,1626]" captionTargetId="figure-30@2.[332,1255,190,1626]" captionTargetPageId="2" captionText="FIGURE B. 1. Holotype of Lepidozia brevifolia Mitt. (India, Sikkim, Yumtong [Yumthang], J.D.Hooker 1317 [1417], 5 September 1849, NY00236747); 2. Lepidozia brevifolia Mitt. (India, Sikkim, [Acc. No. G14981] J.D. Hooker, G00115203); 3. Lepidozia brevifolia Mitt. [India, Sikkim, [Acc. No. G14982] J.D. Hooker (G)]; 4. Lepidozia brevifolia Mitt. [India, N.W. India, Dehra Dun, [Acc. No. G14983] W. Gollan, 14 October 1900 (G)]. ©Copyright of the Board of Trustees of the New York Botanical Garden, New York and ©Conservatoire et Jardin botaniques de la Ville de Genève." pageId="3" pageNumber="220">Fig. B</figureCitation>
2); 
<accessionNumber box="[509,595,303,327]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/G14982" pageId="3" pageNumber="220">G14982</accessionNumber>
[an old G accession number] collected by J.D. Hooker (
<figureCitation box="[1208,1277,303,327]" captionStart="FIGURE B" captionStartId="2.[136,229,1650,1672]" captionTargetBox="[332,1255,190,1626]" captionTargetId="figure-30@2.[332,1255,190,1626]" captionTargetPageId="2" captionText="FIGURE B. 1. Holotype of Lepidozia brevifolia Mitt. (India, Sikkim, Yumtong [Yumthang], J.D.Hooker 1317 [1417], 5 September 1849, NY00236747); 2. Lepidozia brevifolia Mitt. (India, Sikkim, [Acc. No. G14981] J.D. Hooker, G00115203); 3. Lepidozia brevifolia Mitt. [India, Sikkim, [Acc. No. G14982] J.D. Hooker (G)]; 4. Lepidozia brevifolia Mitt. [India, N.W. India, Dehra Dun, [Acc. No. G14983] W. Gollan, 14 October 1900 (G)]. ©Copyright of the Board of Trustees of the New York Botanical Garden, New York and ©Conservatoire et Jardin botaniques de la Ville de Genève." pageId="3" pageNumber="220">Fig. B</figureCitation>
3) and specimen 
<accessionNumber box="[136,221,339,363]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/G14983" pageId="3" pageNumber="220">G14983</accessionNumber>
[an old G accession number] collected by 
<emphasis box="[678,779,339,363]" italics="true" pageId="3" pageNumber="220">W.Gollan</emphasis>
from Dehra Dun (N.W. 
<collectingCountry box="[1045,1101,339,363]" name="India" pageId="3" pageNumber="220">India</collectingCountry>
) on 
<date box="[1149,1340,337,363]" pageId="3" pageNumber="220" value="1900-10-14">
14 
<superScript attach="left" box="[1176,1188,337,351]" fontSize="6" pageId="3" pageNumber="220">th</superScript>
October 1900
</date>
(
<figureCitation box="[1355,1424,339,363]" captionStart="FIGURE B" captionStartId="2.[136,229,1650,1672]" captionTargetBox="[332,1255,190,1626]" captionTargetId="figure-30@2.[332,1255,190,1626]" captionTargetPageId="2" captionText="FIGURE B. 1. Holotype of Lepidozia brevifolia Mitt. (India, Sikkim, Yumtong [Yumthang], J.D.Hooker 1317 [1417], 5 September 1849, NY00236747); 2. Lepidozia brevifolia Mitt. (India, Sikkim, [Acc. No. G14981] J.D. Hooker, G00115203); 3. Lepidozia brevifolia Mitt. [India, Sikkim, [Acc. No. G14982] J.D. Hooker (G)]; 4. Lepidozia brevifolia Mitt. [India, N.W. India, Dehra Dun, [Acc. No. G14983] W. Gollan, 14 October 1900 (G)]. ©Copyright of the Board of Trustees of the New York Botanical Garden, New York and ©Conservatoire et Jardin botaniques de la Ville de Genève." pageId="3" pageNumber="220">Fig. B</figureCitation>
4). Meanwhile, 
<bibRefCitation author="Sharma, D. &amp; Srivastava, S. C." box="[271,598,375,399]" pageId="3" pageNumber="220" pagination="1 - 353" refId="ref2100" refString="Sharma, D. &amp; Srivastava, S. C. (1993) Indian Lepidoziineae - (A taxonomic revision). Bryophytorum Bibliotheca 47: 1 - 353." type="journal article" year="1993">Sharma and Srivastava (1993)</bibRefCitation>
without providing any reason, considered the specimens 
<accessionNumber box="[1224,1310,375,399]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/G14981" pageId="3" pageNumber="220">G14981</accessionNumber>
and 
<accessionNumber box="[1365,1451,375,399]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/G14982" pageId="3" pageNumber="220">G14982</accessionNumber>
[old G accession numbers] both collected by J.D. Hooker (G) as isotypes. Both of the above-mentioned specimens are not cited in the protologue, therefore, could not be considered as isotypes. Specimens 
<accessionNumber box="[1034,1120,447,471]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/G14981" pageId="3" pageNumber="220">G14981</accessionNumber>
and 
<accessionNumber box="[1175,1262,447,471]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/G14982" pageId="3" pageNumber="220">G14982</accessionNumber>
[old G accession numbers] both collected by J.D. Hooker will be considered merely as specimens collected by J.D. Hooker. 
<bibRefCitation author="Sharma, D. &amp; Srivastava, S. C." pageId="3" pageNumber="220" pagination="1 - 353" refId="ref2100" refString="Sharma, D. &amp; Srivastava, S. C. (1993) Indian Lepidoziineae - (A taxonomic revision). Bryophytorum Bibliotheca 47: 1 - 353." type="journal article" year="1993">Sharma and Srivastava (1993)</bibRefCitation>
may have been unaware of 
<bibRefCitation author="Thiers, B. M." box="[624,770,519,543]" pageId="3" pageNumber="220" pagination="271 - 300" refId="ref2131" refString="Thiers, B. M. (1983) Index to the genera and species of Hepaticae described by William Mitten. Brittonia 35 (3): 271 - 300. https: // doi. org / 10.2307 / 2806026" type="journal article" year="1983">Thiers (1983)</bibRefCitation>
publication.
</paragraph>
</subSubSection>
</treatment>
