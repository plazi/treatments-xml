<subSubSection id="A2AC9CAE7767FAC1BFCE48C472E0ACB9" pageId="null" pageNumber="486" type="description">
<paragraph id="9FA8A1953931303D1DDC399695749DBD" pageId="null" pageNumber="486">
Ausdauernd. 
<emphasis id="226560DDCAFEE3B3E5495075A91DC79D" italics="true" pageId="null" pageNumber="486">
<normalizedToken id="D19A627A90E17D637819C77790999CF4" originalValue="Blätter" pageId="null" pageNumber="486">Blaetter</normalizedToken>
</emphasis>
(
<emphasis id="9EE423D633772028F0D2A582391E74A4" italics="true" pageId="null" pageNumber="486">
wenigstens die untern 
<normalizedToken id="276CBC083711831345565B71DD42CE90" originalValue="Stengelblätter" pageId="null" pageNumber="486">Stengelblaetter</normalizedToken>
</emphasis>
) 
<emphasis id="C770E54CBD76B8D4C06CB2C3A3974A23" italics="true" pageId="null" pageNumber="486">
<normalizedToken id="F8451FE0B0B81B013630A21A0503B1BD" originalValue="gegenständig" pageId="null" pageNumber="486">gegenstaendig</normalizedToken>
.
</emphasis>
<normalizedToken id="535644982AC99B610E8C21F7103D0E51" originalValue="Hülle" pageId="null" pageNumber="486">Huelle</normalizedToken>
halbkugelig, aus zahlreichen, in 2 Reihen angeordneten, 
<emphasis id="802387DFEAE611A4A0622A8D31010ED0" italics="true" pageId="null" pageNumber="486">fast gleichlangen</emphasis>
, schmal lanzettlichen, spitzen 
<normalizedToken id="66639FF80EECB84E5F1E99A09AD62F28" originalValue="Hüllblättern" pageId="null" pageNumber="486">Huellblaettern</normalizedToken>
bestehend, 
<emphasis id="38AE7BA71435EFB50BC2DDB0D888F2EF" italics="true" pageId="null" pageNumber="486">
<normalizedToken id="4F5DB8A958A28A4B71B9EA024A9F380C" originalValue="außen" pageId="null" pageNumber="486">aussen</normalizedToken>
ohne kleinere 
<normalizedToken id="5689D390F1CC59AD36F0252D90811DF3" originalValue="Hüllblätter" pageId="null" pageNumber="486">Huellblaetter</normalizedToken>
. Boden des 
<normalizedToken id="055DDCF1B5A57019EE0DBA4CF1093E38" originalValue="Blütenkopfes" pageId="null" pageNumber="486">Bluetenkopfes</normalizedToken>
flach
</emphasis>
, meist behaart, ohne 
<normalizedToken id="700B5A00BCF48E4BE8BDF302D8B4FB9E" originalValue="Spreublätter" pageId="null" pageNumber="486">Spreublaetter</normalizedToken>
. 
<normalizedToken id="0932D9007D6981F03F7B06DA6CC47CE8" originalValue="Blüten" pageId="null" pageNumber="486">Blueten</normalizedToken>
gelb, die 
<normalizedToken id="9278AC22D649CD19233F1AC203E18101" originalValue="randständigen" pageId="null" pageNumber="486">randstaendigen</normalizedToken>
<normalizedToken id="8FAA2FBF0FEBCB6AD4EF01A60E279A4F" originalValue="zungenförmig" pageId="null" pageNumber="486">zungenfoermig</normalizedToken>
und nur ♀, die innern ⚥, 
<normalizedToken id="4AA5FB04DB76ADF68DA0AD6D97AD873B" originalValue="röhrenförmig" pageId="null" pageNumber="486">roehrenfoermig</normalizedToken>
. 
<normalizedToken id="19D35C7CD5A512EF39E025D419E24E4E" originalValue="Früchte" pageId="null" pageNumber="486">Fruechte</normalizedToken>
zylindrisch bis 
<normalizedToken id="66128E15EC89B2AB29A148F4C1637C69" originalValue="spindelförmig" pageId="null" pageNumber="486">spindelfoermig</normalizedToken>
, 5-10rippig. 
<emphasis id="E0331E7F4D8297A8BD8D8F69A70D63EC" italics="true" pageId="null" pageNumber="486">
<taxonomicName id="718028102DDF9B7CA9C88C62BC8983E6" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="486" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
immer vorhanden
</emphasis>
, aus 1 Reihe rauher Pappusborsten bestehend.
</paragraph>
<paragraph id="B5EF0F82D5F66EF29D6DE82155844E95" pageId="null" pageNumber="486">
Die Gattung 
<taxonomicName id="39ECAF3FD39847BBFD4E21A1484A5ECE" class="Magnoliopsida" family="Asteraceae" genus="Arnica" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="486" phylum="Tracheophyta" rank="genus">
<emphasis id="48E706091E236A5DE7CC7A6D9998CC20" italics="true" pageId="null" pageNumber="486">Arnica</emphasis>
</taxonomicName>
<normalizedToken id="D50BBA2D43B02B6BE6B80DEB88B0B5BE" originalValue="umfaßt" pageId="null" pageNumber="486">umfasst</normalizedToken>
nach der monographischen Bearbeitung von Maguire (1943) 
<emphasis id="E3CC04A36C10AF218BA73B929A1D4C8F" italics="true" pageId="null" pageNumber="486">32 Arten</emphasis>
und hat ihre Hauptverbreitung in 
<emphasis id="F635E1B21B9AA2DCB22839DDF0B79CDF" italics="true" pageId="null" pageNumber="486">Nordamerika.</emphasis>
3 Arten sind 
<emphasis id="1721B70C24F968284AB4DDEEDDBD18A1" italics="true" pageId="null" pageNumber="486">apomiktisch</emphasis>
(Afzelius 1936, Khokholov 1968).
</paragraph>
</subSubSection>
