<subSubSection id="24CB1080FF9FFFC1FAB2ADC485F9FCEE" pageId="43" pageNumber="44" type="discussion">
<paragraph id="6C6E430BFF9FFFC1FAB2ADC485F9FCEE" blockId="43.[151,1437,320,778]" pageId="43" pageNumber="44">
<emphasis id="5EA59F19FF9FFFC1FAB2ADC4815FFD26" bold="true" box="[199,314,682,706]" pageId="43" pageNumber="44">Remarks.</emphasis>
Previous records from the coast of 
<collectingRegion id="AE158DE9FF9FFFC1F8A3ADC4832DFD26" box="[726,840,682,706]" country="Brazil" name="Sao Paulo" pageId="43" pageNumber="44">São Paulo</collectingRegion>
include São Sebastião (
<bibRefCitation id="08403EFAFF9FFFC1FE28ADC485FDFD26" author="Rodrigues, S. A. &amp; Shimizu, R. M." box="[1117,1432,682,706]" pageId="43" pageNumber="44" pagination="317 - 323" refId="ref75663" refString="Rodrigues, S. A. &amp; Shimizu, R. M. (1992) Description of a new Axianassa (Crustacea: Decapoda: Thalassinidea). Proceedings of the Biological Society of Washington, 105, 317 - 323." type="journal article" year="1992">
<collectingRegion id="AE158DE9FF9FFFC1FE28ADC484AAFD26" box="[1117,1231,682,706]" country="Mauritius" name="Rodrigues" pageId="43" pageNumber="44">Rodrigues</collectingRegion>
&amp; Shimizu 1992
</bibRefCitation>
; 
<bibRefCitation id="08403EFAFF9FFFC1FAE2ADA0810DFD02" author="Kihara, T. C. &amp; Rocha, C. E. &amp; Santos, C." box="[151,360,718,742]" pageId="43" pageNumber="44" pagination="39 - 55" refId="ref66135" refString="Kihara, T. C., Rocha, C. E. &amp; Santos, C. (2005) A new species of Catinia Bocquet and Stock, 1957 (Copepoda, Catiniidae) associated with mud shrimps, Axianassa australis Rodrigues and Shimizu, 1992 (Decapoda, Thalassinidea, Laomediidae), from Brazil. Zootaxa, 1039 (1), 39 - 55. https: // doi. org / 10.11646 / zootaxa. 1039.1.4" type="journal article" year="2005">
Kihara 
<emphasis id="5EA59F19FF9FFFC1FA9EADA18141FD02" box="[235,292,718,742]" italics="true" pageId="43" pageNumber="44">et al.</emphasis>
2005
</bibRefCitation>
). The complete mitochondrial data was recently provided by 
<bibRefCitation id="08403EFAFF9FFFC1FE69ADA184B7FD02" author="Tan, M. H. &amp; Gan, H. M. &amp; Lee, Y. P. &amp; Bracken-Grissom, H. &amp; Chan, T. Y. &amp; Miller A. D. &amp; Austin, C. M." box="[1052,1234,718,742]" pageId="43" pageNumber="44" pagination="10756" refId="ref79778" refString="Tan, M. H., Gan, H. M., Lee, Y. P., Bracken-Grissom, H., Chan, T. Y., Miller A. D. &amp; Austin, C. M. (2019) Comparative mitogenomics of the Decapoda reveals evolutionary heterogeneity in architecture and composition. Scientific Reports, 9, 10756. https: // doi. org / 10.1038 / s 41598 - 019 - 47145 - 0" type="journal article" year="2019">
Tan 
<emphasis id="5EA59F19FF9FFFC1FE38ADA184E2FD02" box="[1101,1159,718,742]" italics="true" pageId="43" pageNumber="44">et al.</emphasis>
(2019
</bibRefCitation>
, 
<accessionNumber id="7382DEE8FF9FFFC1FEAAADA08501FD02" box="[1247,1380,718,742]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/MH234568" pageId="43" pageNumber="44">MH234568</accessionNumber>
). Sequences accession number (GenBank): CCDB 1037—16S (
<accessionNumber id="7382DEE8FF9FFFC1F958AD9C83CAFCEE" box="[813,943,754,778]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/MF490232" pageId="43" pageNumber="44">MF490232</accessionNumber>
), COI (
<accessionNumber id="7382DEE8FF9FFFC1FE75AD9C841BFCEE" box="[1024,1150,754,778]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/MF490135" pageId="43" pageNumber="44">MF490135</accessionNumber>
) (
<bibRefCitation id="08403EFAFF9FFFC1FEE1AD9C85F5FCEE" author="Mantelatto, F. L. &amp; Terossi, M. &amp; Negri, M. &amp; Buranelli, R. C. &amp; Robles, R. &amp; Magalhaes, T. &amp; Tamburus, A. F. &amp; Rossi, N. &amp; Miyazaki, M. J." box="[1172,1424,754,778]" pageId="43" pageNumber="44" pagination="805 - 815" refId="ref68637" refString="Mantelatto, F. L., Terossi, M., Negri, M., Buranelli, R. C., Robles, R., Magalhaes, T., Tamburus, A. F., Rossi, N. &amp; Miyazaki, M. J. (2018) DNA sequence database as a tool to identify decapod crustaceans on the Sao Paulo coastline. Mitochondrial DNA Part A: DNA Mapping, Sequencing and Analysis, 29 (5), 805 - 815. https: // doi. org / 10.1080 / 24701394.2017.1365848" type="journal article" year="2018">
