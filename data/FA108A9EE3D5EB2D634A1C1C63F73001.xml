<paragraph id="C12E1B5A92493F8CDDA624237426A2B5" pageId="null" pageNumber="531">
<taxonomicName id="3B0A6C4B8453412DDA36B5341949100F" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Solidago" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="531" phylum="Tracheophyta" rank="species" species="canadensis">
Solidago 
<normalizedToken id="EC094292EC4E6648B6E8C56AE0BEE022" originalValue="canadénsis" pageId="null" pageNumber="531">canadensis</normalizedToken>
<authorityName id="EED8C8EC521ACC293D5EA77DB687E3A1" pageId="null" pageNumber="531">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="E1C24C4C68E5EFA4179B0889209A8453" pageId="null" pageNumber="531" type="vernacular_names">
<paragraph id="7BF8757639F5C1B498690BB04AEDA602" pageId="null" pageNumber="531">Kanadische Goldrute</paragraph>
</subSubSection>
</title>
<subSubSection id="61E6B74D394DCB921F07152ADAF3CD6A" pageId="null" pageNumber="531" type="description">
<paragraph id="48E82AD823AC255B833BAE0BA7A64D2C" pageId="null" pageNumber="531">
<normalizedToken id="5E1C547E3A9EAE4ECDFB10323C7F6925" originalValue="Ausläufer" pageId="null" pageNumber="531">Auslaeufer</normalizedToken>
treibend; 50-200 cm hoch. Stengel glatt oder gerillt, besonders im obern Teil von zahlreichen, 
<emphasis id="EF3298069095EA35024D9834BEE958B0" italics="true" pageId="null" pageNumber="531">
mehrzelligen Haaren flaumig, 
<normalizedToken id="876673489C54239CE118913F6710D0A9" originalValue="grün" pageId="null" pageNumber="531">gruen</normalizedToken>
. 
<normalizedToken id="0E0CF1AC3809F6C661F48D2E3E294646" originalValue="Blätter" pageId="null" pageNumber="531">Blaetter</normalizedToken>
unterseits dicht behaart
</emphasis>
, lanzettlich, 
<emphasis id="F75C2CDE85F33597124EC15B3D826C10" italics="true" pageId="null" pageNumber="531">5</emphasis>
- 
<emphasis id="4368194CF17028E7AB55AEF13B06829B" italics="true" pageId="null" pageNumber="531">
10mal so lang wie breit, entfernt und scharf 
<normalizedToken id="DA5A4F69A8BE8FEFF691B3BA48FBF6BB" originalValue="gezähnt" pageId="null" pageNumber="531">gezaehnt</normalizedToken>
</emphasis>
(
<normalizedToken id="D07EFCB678E462B48818FEAC501F6F65" originalValue="Zähne" pageId="null" pageNumber="531">Zaehne</normalizedToken>
nach vorn gerichtet). 
<normalizedToken id="3FA0AA15EA7E48C0ECBEC9B7B483DD6A" originalValue="Blütenköpfe" pageId="null" pageNumber="531">Bluetenkoepfe</normalizedToken>
im Durchmesser 3-5 mm, in einer 
<normalizedToken id="AEC70EEBDB61E977A9C1A8A3C6AE57C0" originalValue="endständigen" pageId="null" pageNumber="531">endstaendigen</normalizedToken>
, 
<emphasis id="7466BB07965FB7DDD2B632E19BF28F14" italics="true" pageId="null" pageNumber="531">
einseitswendigen Rispe. 
<normalizedToken id="1A6DFB63978E9F9F09CB4CB8AA026BC5" originalValue="Hülle" pageId="null" pageNumber="531">Huelle</normalizedToken>
2
</emphasis>
- 
<emphasis id="8EEB002EC0E505AA75A9DA312B2AF98A" italics="true" pageId="null" pageNumber="531">3 mm lang.</emphasis>
<normalizedToken id="D72AF4B3C019E2B6976CB494E1C21C6D" originalValue="Hüllblätter" pageId="null" pageNumber="531">Huellblaetter</normalizedToken>
zerstreut behaart, kurz zugespitzt. 
<normalizedToken id="0E6B6C07CBF35A74F29C516F4AAEAAD4" originalValue="Zungenblüten" pageId="null" pageNumber="531">Zungenblueten</normalizedToken>
8-20, nicht 
<normalizedToken id="B4A73FA0ACA8165E2811A875B01070B9" originalValue="länger" pageId="null" pageNumber="531">laenger</normalizedToken>
als die 
<normalizedToken id="B514BF3437DDD74D7C208BA9D685505D" originalValue="röhrenförmigen" pageId="null" pageNumber="531">roehrenfoermigen</normalizedToken>
<normalizedToken id="173EDB88065B2550BF93D3A030762D12" originalValue="Blüten" pageId="null" pageNumber="531">Blueten</normalizedToken>
, ca. 0,5 mm breit. 
<emphasis id="00EEC8042EA1C1703A3877DB9C778CD9" italics="true" pageId="null" pageNumber="531">
<normalizedToken id="8A43693E3CE4815D8514E978B4AAE5FF" originalValue="Früchte" pageId="null" pageNumber="531">Fruechte</normalizedToken>
0,5
</emphasis>
- 
<emphasis id="E8AEC8D6761E8925397BCCB99E9D5DF7" italics="true" pageId="null" pageNumber="531">1 mm lang</emphasis>
, undeutlich 4-8rippig, behaart. 
<taxonomicName id="A0AFB141B1356B7AF9A07C351C2B570F" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="531" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
ca. 3 mm lang. - 
<normalizedToken id="C189866AB672952B9E66969657428AD0" originalValue="Blüte" pageId="null" pageNumber="531">Bluete</normalizedToken>
: 
<normalizedToken id="A94C6A5522BC8CC84572364783A89711" originalValue="Später" pageId="null" pageNumber="531">Spaeter</normalizedToken>
Sommer und Herbst.
</paragraph>
<paragraph id="72F0BF0A415EFBA691DE5879FB17D422" pageId="null" pageNumber="531">
<emphasis id="FB50218A2C3B29A7B0F86754E947028B" italics="true" pageId="null" pageNumber="531">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5D4D0B9FC7C991909BF3D14CF6C6DF47" italics="true" pageId="null" pageNumber="531">18:</emphasis>
Material aus Italien (Carano 1921), von verschiedenen Stellen aus Kanada (Beaudry und Chabot 1957 1959, Kapoor und Beaudry 1966; es wurden bis 2 B-Chromosomen 
<normalizedToken id="E06A64A0DD2D77C59E8615E0A2B6F577" originalValue="gezählt" pageId="null" pageNumber="531">gezaehlt</normalizedToken>
), aus Indien (Mehra et al. 1965). 
<emphasis id="98A26BAAAA4DF9AF61C4B63C24C814F5" italics="true" pageId="null" pageNumber="531">2n</emphasis>
= 
<emphasis id="61488FCBBCC1E03999BE0695C213AD44" italics="true" pageId="null" pageNumber="531">36:</emphasis>
Material aus Kanada (Taylor und Mulligan 1968).
</paragraph>
<paragraph id="7031FD1ED1E19C0FFBAAF32A789DECC0" pageId="null" pageNumber="531">
<emphasis id="798CDFE7C36E369E51AE6A36C6AEEC19" italics="true" pageId="null" pageNumber="531">Standort.</emphasis>
Kollin. Feuchte, 
<normalizedToken id="4005A11E3D8EAEFD588842571C515E63" originalValue="nährstoffreiche" pageId="null" pageNumber="531">naehrstoffreiche</normalizedToken>
<normalizedToken id="7838AA0318122E3292A1232A36913660" originalValue="Böden" pageId="null" pageNumber="531">Boeden</normalizedToken>
in 
<normalizedToken id="197C8EA1B243BA8C635B2C1E3D5771C4" originalValue="wärmeren" pageId="null" pageNumber="531">waermeren</normalizedToken>
Lagen. 
<normalizedToken id="9191D95B9DAE95F9949ED3B8FDF0C390" originalValue="Ufergebüsche" pageId="null" pageNumber="531">Ufergebuesche</normalizedToken>
, Waldlichtungen, 
<normalizedToken id="D3BF13F839B13F98DFF1BFE105B826CC" originalValue="Schuttplätze" pageId="null" pageNumber="531">Schuttplaetze</normalizedToken>
. 
<emphasis id="E76A14AE9EAF24E733A625DEB1587B40" italics="true" pageId="null" pageNumber="531">Impatienti-Solidaginetum</emphasis>
Moor 1958.
</paragraph>
<paragraph id="6D2D083A5D436B5233E597167E972DF2" pageId="null" pageNumber="531">
<emphasis id="8CF52BFC22CDDF08E69FFDCF0FC1977B" italics="true" pageId="null" pageNumber="531">Verbreitung. Nordamerikanische Pflanze:</emphasis>
In Europa eingeschleppt. - Im Gebiet oft als Zierpflanze angebaut und verwildert; nicht 
<normalizedToken id="E2C1AD954A2A004B90BBF37359062A93" originalValue="häufig" pageId="null" pageNumber="531">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
