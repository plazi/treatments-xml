<taxonomicName id="0FCF31F690F1D3AE89D12F7E3A794D2C" authority="(Nath.) Rich." class="Liliopsida" family="Orchidaceae" genus="Gymnadenia" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="622" phylum="Tracheophyta" rank="species" species="odoratissima">
