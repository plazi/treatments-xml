<taxonomicName id="992A2A312D4D9F1788C3F1B21F03F661" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Artemisia" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="583" phylum="Tracheophyta" rank="species" species="abrotanum">
