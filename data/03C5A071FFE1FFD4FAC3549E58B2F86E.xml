<emphasis id="B918CD75FFE1FFD5FAC2551B5C78F2A7" bold="true" box="[1406,1561,3346,3379]" pageId="12" pageNumber="564">Taxonomy.</emphasis>
<taxonomicName id="4C6C6AE4FFE1FFD5F992551B5242F2A7" authority="Thomas, 1904" authorityName="Thomas" authorityYear="1904" box="[1582,2083,3346,3379]" class="Mammalia" family="Echimyidae" genus="Thrichomys" kingdom="Animalia" order="Rodentia" pageId="12" pageNumber="564" phylum="Chordata" rank="species" species="laurentius">Thrichomys laurentius Thomas, 1904</taxonomicName>
, 
<materialsCitation id="3B041B3AFFE1FFD5F785551B52CDF2C8" ID-GBIF-Occurrence="3804303378" pageId="12" pageNumber="564">“Sao Lourenco [= Sao Lorenco da Mata], near Pernambuco, Alt. 50 m,” Pernambuco, Brazil.</materialsCitation>
