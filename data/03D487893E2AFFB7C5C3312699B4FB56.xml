</taxonomicName>
(A, D, G) and 
<taxonomicName id="4C7D4D1C3E2BFFB7C119324A9FB8FA1D" authorityName="Scopoli ex Schmidt" authorityYear="1795" baseAuthorityName="Linnaeus" baseAuthorityYear="1753" box="[1106,1224,1566,1588]" class="Magnoliopsida" family="Asteraceae" genus="Urospermum" kingdom="Plantae" order="Asterales" pageId="1" pageNumber="221" phylum="Tracheophyta" rank="species" species="picroides">
