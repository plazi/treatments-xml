<taxonomicName authority="Kim, Khim, Witkowski and Park" authorityName="Kim, Khim, Witkowski and Park" authorityYear="2022" box="[297,798,1771,1793]" class="Bacillariophyceae" family="Naviculaceae" genus="Fogedia" higherTaxonomySource="GBIF" kingdom="Chromista" order="Naviculales" pageId="2" pageNumber="79" phylum="Ochrophyta" rank="species" species="orientalis" status="sp. nov.">
<emphasis box="[297,474,1771,1792]" italics="true" pageId="2" pageNumber="79">Fogedia orientalis</emphasis>
Kim, Khim, Witkowski and Park
</taxonomicName>
, 
<emphasis box="[808,881,1772,1793]" italics="true" pageId="2" pageNumber="79">
<taxonomicNameLabel box="[808,881,1772,1793]" pageId="2" pageNumber="79" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
Valves of 
<taxonomicName authorityName="Kim, Khim, Witkowski and Park" authorityYear="2022" box="[981,1159,1771,1792]" class="Bacillariophyceae" family="Naviculaceae" genus="Fogedia" higherTaxonomySource="GBIF" kingdom="Chromista" order="Naviculales" pageId="2" pageNumber="79" phylum="Ochrophyta" rank="species" species="orientalis">
