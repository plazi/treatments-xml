</taxonomicName>
, 
<taxonomicName class="Pinopsida" family="Pinaceae" genus="Pinus" kingdom="Plantae" lsidName="Pinus" order="Pinales" pageId="0" pageNumber="119" phylum="Tracheophyta" rank="genus">
