</taxonomicName>
, 
<taxonomicName authorityName="Pankov, Webster, Blasco-Costa, Gibson, Littlewood, Balbuena &amp; Kostadinova" authorityYear="2006" class="Magnoliopsida" family="Fabaceae" genus="Robinia" kingdom="Plantae" lsidName="Robinia" order="Fabales" pageId="0" pageNumber="119" phylum="Tracheophyta" rank="genus">
