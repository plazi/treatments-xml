</taxonomicName>
, 
<taxonomicName class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" lsidName="Quercus" order="Fagales" pageId="0" pageNumber="119" phylum="Tracheophyta" rank="genus">
