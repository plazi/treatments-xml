</emphasis>
<taxonomicName id="4C424D56861F6B39F9E68027F849F3E1" authority="Yoo, 1994" authorityName="Yoo" authorityYear="1994" box="[1598,2003,3155,3194]" class="Gastropoda" family="Eotomariidae" genus="Campbeuospira" higherTaxonomySource="GBIF" kingdom="Animalia" order="Pleurotomariida" pageId="13" pageNumber="76" phylum="Mollusca" rank="species" species="conica" status="n.sp.">
