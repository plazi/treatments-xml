<bibRefCitation id="8D5E4B2C3F19FF8EFE39FA18FD31FA57" author="Kolombatovic, G." box="[472,721,1438,1462]" pageId="44" pageNumber="45" pagination="3 - 29" refId="ref57508" refString="Kolombatovic, G. (1891) Glamoci (Gobii) Spljetskog Pomorskog Okruzja Dalmaciji (In Croatian and Italian). Godisnje Izviesce C. K. Velike Realke u Splitu za Skolsku Godinu, Split, 1890 - 1891, 3 - 29." type="journal article" year="1891">Kolombatović, 1891: 27</bibRefCitation>
