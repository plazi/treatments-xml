Central 
<collectingCountry id="F3507619FFF6FFE0847AF907FE741DF1" box="[383,446,1695,1718]" name="Nepal" pageId="4" pageNumber="517">Nepal</collectingCountry>
(
<figureCitation id="137C2A0CFFF6FFE084C9F907FDD01DF1" box="[460,538,1695,1718]" captionStart="Fig" captionStartId="4.[1073,1104,757,776]" captionTargetBox="[152,1056,189,881]" captionTargetId="figure-575@4.[152,1057,186,881]" captionTargetPageId="4" captionText="Fig. 20. The distribution of Selasia species in the southern part of Asia. Selasia decipiens Guérin-Menéville, 1843 is not included in the map because its exact distribution in India is not known." figureDoi="http://doi.org/10.5281/zenodo.4488885" httpUri="https://zenodo.org/record/4488885/files/figure.png" pageId="4" pageNumber="517">Fig. 20</figureCitation>
).
</paragraph>
</subSubSection>
