, EL 
<quantity id="4CBF9B6CFFF6FFE087CFFC47FF091F51" metricMagnitude="-3" metricUnit="m" metricValue="4.8" pageId="4" pageNumber="517" unit="mm" value="4.8">4.80 mm</quantity>
, WHe 
