<quantity id="4CBF9B6CFFF6FFE08496FC67FE381F51" box="[403,498,1023,1046]" metricMagnitude="-3" metricUnit="m" metricValue="1.25" pageId="4" pageNumber="517" unit="mm" value="1.25">1.25 mm</quantity>
