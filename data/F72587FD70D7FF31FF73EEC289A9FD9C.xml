<taxonomicName id="B88C4D6870D7FF31FF73EE8A8BD4FF31" authority="Mayr, 1867 b" authorityName="Mayr" authorityYear="1867" box="[151,479,222,245]" class="Insecta" family="Formicidae" genus="Hypoclinea" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="169" pageNumber="170" phylum="Arthropoda" rank="species" species="haueri">
<emphasis id="4DF8EAF970D7FF31FF73EE8A8B5FFF30" box="[151,340,223,245]" italics="true" pageId="169" pageNumber="170">Hypoclinea haueri</emphasis>
<bibRefCitation id="1B1D4B1A70D7FF31FEBEEE8A8BD4FF31" author="Mayr, G." box="[346,479,222,244]" pageId="169" pageNumber="170" pagination="47 - 62" refId="ref112018" refString="Mayr, G. (1867 b) Vorlaufige Studien uber die Radoboj-Formiciden, in der Sammlung der k. k. geologischen Reichsanstalt. Jahrbuch der k. k. Geologischen Reichsanstalt, 17, 47 - 62." type="journal article" year="1867">Mayr, 1867b</bibRefCitation>
