<subSubSection id="C5BB6CA06C6B3935A6E59BCA23CE5899" pageId="null" pageNumber="757" type="description">
<paragraph id="17374208D3DDE5409AD00B983A2D25F0" pageId="null" pageNumber="757">
Unterscheidet sich von 
<taxonomicName id="8DEB61169C55C38D8D040C9CEFB07FCC" class="Magnoliopsida" family="Amaranthaceae" genus="Chenopodium" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="757" phylum="Tracheophyta" rank="species" species="album">
<emphasis id="DE5FC6D4C43C5A4C79E61CF5260793BA" italics="true" pageId="null" pageNumber="757">Ch. album</emphasis>
</taxonomicName>
(Nr. 12) durch das folgende Merkmal: 
<emphasis id="B7C29F918ED6DA088E0F96963338E9A8" italics="true" pageId="null" pageNumber="757">
die meisten 
<normalizedToken id="EDA882B418A7F35F849156852F067C0A" originalValue="Blätter" pageId="null" pageNumber="757">Blaetter</normalizedToken>
weniger als 
<normalizedToken id="6D7783922B76587C0DCF1805BF1E034D" originalValue="1½" pageId="null" pageNumber="757">11/2</normalizedToken>
mal so lang wie breit.
</emphasis>
- 
<normalizedToken id="3B2A3AAF6E9F41714B443B325069CCE1" originalValue="Blüte" pageId="null" pageNumber="757">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="BC4F350B2DB13EFDEBAE5CD95D276E7B" pageId="null" pageNumber="757">
<emphasis id="CB79895A7494E3589A745B7EF8A0664C" italics="true" pageId="null" pageNumber="757">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="697AAD532DAE4D04444823DF5A89415B" italics="true" pageId="null" pageNumber="757">18:</emphasis>
Material aus botanischen 
<normalizedToken id="6522076343C56BD32A59E56F8D7F3132" originalValue="Gärten" pageId="null" pageNumber="757">Gaerten</normalizedToken>
(Kawatani und Ohno 1956). 
<emphasis id="FD6623838690EC92DC981D93B5221292" italics="true" pageId="null" pageNumber="757">2n</emphasis>
= 
<emphasis id="5514E3F8363B140DFADC3E9799BDC6E5" italics="true" pageId="null" pageNumber="757">36:</emphasis>
Material aus botanischen 
<normalizedToken id="8A888131A751765E0BEC95A748846A93" originalValue="Gärten" pageId="null" pageNumber="757">Gaerten</normalizedToken>
(Wulff 1937). 
<emphasis id="6904AE1B65CB63B3D0C27948A0CD627D" italics="true" pageId="null" pageNumber="757">2n</emphasis>
= 
<emphasis id="F498C0919B3718073982B81E97DA733B" italics="true" pageId="null" pageNumber="757">54:</emphasis>
Material aus England (Cole 1962), aus Indien (Mehra und Malik (1963).
</paragraph>
<paragraph id="84C34FCE413A377B8903B5E7D60A14ED" pageId="null" pageNumber="757">
<emphasis id="BD3C54F8D6DDE54142DDA3161199FEAA" italics="true" pageId="null" pageNumber="757">Standort.</emphasis>
Wie 
<taxonomicName id="77847C31E46CCF45375BC163343374E7" class="Magnoliopsida" family="Amaranthaceae" genus="Chenopodium" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="757" phylum="Tracheophyta" rank="species" species="murale">
<emphasis id="9B31FEC996CFDD145FCDB633EA0B3E65" italics="true" pageId="null" pageNumber="757">Ch. murale</emphasis>
</taxonomicName>
(Nr. 10).
</paragraph>
<paragraph id="F61D117920ABCCAA450981CFB23F4378" pageId="null" pageNumber="757">
<emphasis id="60DFABC15CB7EC12592BD0A7E9ABC3BA" italics="true" pageId="null" pageNumber="757">Verbreitung. Mediterran-asiatische Pflanze:</emphasis>
<normalizedToken id="DF372FD262014B2004C902299284BE77" originalValue="Südeuropa" pageId="null" pageNumber="757">Suedeuropa</normalizedToken>
, Nordwestafrika; in Asien 
<normalizedToken id="F76344A45824349A274A6EECCC54A26C" originalValue="nordwärts" pageId="null" pageNumber="757">nordwaerts</normalizedToken>
bis 
<normalizedToken id="2E71061DDEA27A9D70FC2E36093199A7" originalValue="Südsibirien" pageId="null" pageNumber="757">Suedsibirien</normalizedToken>
, 
<normalizedToken id="7312895AC7DF261A4D1DD9140E4ACE9A" originalValue="südwärts" pageId="null" pageNumber="757">suedwaerts</normalizedToken>
bis Persien, 
<normalizedToken id="437E959CBD7465B409058F90B720D7AD" originalValue="ostwärts" pageId="null" pageNumber="757">ostwaerts</normalizedToken>
bis in die Mongolei; nach Nordamerika und Mittel- und 
<normalizedToken id="866B5C5EA0DB2C56850AD2C6440F0EF2" originalValue="Südafrika" pageId="null" pageNumber="757">Suedafrika</normalizedToken>
verschleppt. - Im Gebiet: 
<normalizedToken id="622EED7E20A2CC4902E09CCFB5F3FBBB" originalValue="Alpensüdseite" pageId="null" pageNumber="757">Alpensuedseite</normalizedToken>
, Savoyen (Maurienne, Tarentaise), Wallis, Aostatal, Oberrheinische Tiefebene, ziemlich selten; sonst selten und 
<normalizedToken id="D87D1EA507AFFFB4947E7DDB5A111C29" originalValue="unbeständig" pageId="null" pageNumber="757">unbestaendig</normalizedToken>
.
</paragraph>
</subSubSection>
