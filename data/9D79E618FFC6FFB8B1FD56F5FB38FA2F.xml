<emphasis id="27A48B1CFFC6FFB8B1FD5762FE26FED7" box="[151,394,256,280]" italics="true" pageId="73" pageNumber="74">Pseudococcus burnerae</emphasis>
<bibRefCitation id="71412AFFFFC6FFB8B0FA5762FD90FED7" author="Brain, C. K." box="[400,572,255,280]" pageId="73" pageNumber="74" pagination="65 - 194" refId="ref86826" refString="Brain, C. K. (1915) The Coccidae of South Africa. Transactions of the Royal Society of South Africa. Cape Town, 5, 65 - 194. https: // doi. org / 10.1080 / 00359191509519718" type="journal article" year="1915">Brain, 1915: 111</bibRefCitation>
