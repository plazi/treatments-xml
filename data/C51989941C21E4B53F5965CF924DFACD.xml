<subSubSection id="7B23D2F6F6368A8CB32472D77EA0085A" pageId="null" pageNumber="590" type="description">
<paragraph id="4E56CF3DB8455149545D0E26FDEE1DAF" pageId="null" pageNumber="590">
Unterscheidet sich von 
<taxonomicName id="CB93606508D11DEE2E03F7728D03234A" class="Magnoliopsida" family="Asteraceae" genus="Hypochoeris" higherTaxonomySource="GBIF" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="uniflora">
<emphasis id="4D87B6B41C59F9B4FD049677B270F299" italics="true" pageId="null" pageNumber="590">H. uniflora</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="9928DF3E6026C3455B81E3A50FDA3F59" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="8A58379EAAC3D5BBD5C983CEF49DC402" originalValue="Grundständige" pageId="null" pageNumber="590">Grundstaendige</normalizedToken>
<normalizedToken id="FA568D77025D2E9279F254E21C65B217" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
mit kurzem, 
<normalizedToken id="815DDFE151865A72F012620EBFE5FB64" originalValue="geflügeltem" pageId="null" pageNumber="590">gefluegeltem</normalizedToken>
Stiel;
</emphasis>
<normalizedToken id="B8279B2F380ABD182061FBA806F5D983" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
1,5-2,2 cm lang; 
<emphasis id="C93411A362E55CBF0BD1FDC6BCC29138" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="7505E5F77B7D35C4C2E32669DFD5CF78" originalValue="äußere" pageId="null" pageNumber="590">aeussere</normalizedToken>
<normalizedToken id="27B216E5CBA83F6E55CABA8D49262629" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
am Rande kurz bewimpert, nicht gefranst;
</emphasis>
<normalizedToken id="61805CFF2934B71C301A9F9D2E791EED" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
gelb, 2-3 cm lang; 
<normalizedToken id="7F77968798EBFB3991997D07B5B91290" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
(mit Schnabel) ca. 
<emphasis id="E3FE0F2A5E513BB2BCF36FF9281173E6" italics="true" pageId="null" pageNumber="590">15 mm lang.</emphasis>
- 
<normalizedToken id="9B068BACDA8989DF0464598894F3852B" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="D8652407B2305E141395D5C0DE5F7F39" pageId="null" pageNumber="590">
<emphasis id="1A4020802F157D3DB545786038FF0A23" italics="true" pageId="null" pageNumber="590">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="4CBD40AAB80F454DDA7F024623F4870D" pageId="null" pageNumber="590">
<emphasis id="07610D6A866DCB64D863E0C9BD7B134C" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
<normalizedToken id="DFBE196C75BFE2DDA8E06E8B22AD5D23" originalValue="Ähnlich" pageId="null" pageNumber="590">Aehnlich</normalizedToken>
wie 
<taxonomicName id="D8695D9BE7DC18C079C61B783A095AB2" class="Magnoliopsida" family="Asteraceae" genus="Hypochoeris" higherTaxonomySource="GBIF" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="uniflora">
<emphasis id="2654318E3C7DEB3DFD25D803E195B3E0" italics="true" pageId="null" pageNumber="590">H. uniflora</emphasis>
</taxonomicName>
(Nr. 1).
</paragraph>
<paragraph id="E1FCBA0148D10934BCD9DDD4FAB43861" pageId="null" pageNumber="590">
<emphasis id="BD1909BF90CB31E42AB1367A370F0B18" italics="true" pageId="null" pageNumber="590">
Verbreitung. 
<normalizedToken id="80B39BA2C12C614845A12ED0DB254479" originalValue="Südtiroler" pageId="null" pageNumber="590">Suedtiroler</normalizedToken>
Pflanze:
</emphasis>
Val di Ledro, Lessiner Berge (bei Verona); 
<normalizedToken id="EAC73E880E6C51CF73D63C26E45CADA8" originalValue="östliche" pageId="null" pageNumber="590">oestliche</normalizedToken>
Bergamasker Alpen, Oberinntal (Nauders). - Im Gebiet: Bergamasker Alpen (Val Sanguigna), Oberinntal (Schmalzkopf bei Nauders).
</paragraph>
</subSubSection>
