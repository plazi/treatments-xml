<paragraph id="C42B36FEFFE36A5CFA4F9AC217A7B78A" blockId="24.[1458,2666,2323,3492]" box="[1459,2471,3227,3256]" pageId="24" pageNumber="782">
<emphasis id="F6E0EAECFFE36A5CFA4F9AC21839B78A" bold="true" box="[1459,1593,3227,3256]" pageId="24" pageNumber="782">Breeding.</emphasis>
Two pregnant New 
<collectingCountry id="BC83766EFFE36A5CF8A59AC219BFB78A" box="[1881,1983,3227,3256]" name="Guinea-Bissau" pageId="24" pageNumber="782">Guinea</collectingCountry>
