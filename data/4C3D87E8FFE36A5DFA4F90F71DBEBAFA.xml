<emphasis id="F6E0EAECFFE36A5CFA4F9A3618B8B7A2" bold="true" box="[1459,1720,3183,3216]" pageId="24" pageNumber="782">Food and Feeding.</emphasis>
New 
<collectingCountry id="BC83766EFFE36A5CF8F79A361971B7A2" box="[1803,1905,3183,3216]" name="Guinea-Bissau" pageId="24" pageNumber="782">Guinea</collectingCountry>
