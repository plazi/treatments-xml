<subSubSection id="C34472A7FFF2682045CA32B0B8DDFECC" lastPageId="8" lastPageNumber="291" pageId="7" pageNumber="290" type="materials_examined">
<paragraph id="8BE1212CFFF2682F45CA32B0B937F85F" blockId="7.[151,844,1978,2002]" box="[151,844,1978,2002]" pageId="7" pageNumber="290">
<emphasis id="B92AFD3EFFF2682F45CA32B0BB66F85C" box="[151,285,1978,2002]" italics="true" pageId="7" pageNumber="290">
<typeStatus id="54E59F8EFFF2682F45CA32B0BABDF85F" box="[151,198,1979,2002]" pageId="7" pageNumber="290">Type</typeStatus>
species.
</emphasis>
<taxonomicName id="4C5E5AAFFFF2682F447E32B1B8C2F85F" authority="Ulmer 1905 a" authorityName="Ulmer" authorityYear="1905" box="[291,697,1978,2002]" class="Insecta" family="Polycentropodidae" genus="Polyplectropus" kingdom="Animalia" order="Trichoptera" pageId="7" pageNumber="290" phylum="Arthropoda" rank="species" species="flavicornis">
<emphasis id="B92AFD3EFFF2682F447E32B1B856F85F" box="[291,557,1978,2002]" italics="true" pageId="7" pageNumber="290">Polyplectropus flavicornis</emphasis>
<bibRefCitation id="EFCF5CDDFFF2682F476932B1B8C2F85F" author="Ulmer, G." box="[564,697,1978,2002]" pageId="7" pageNumber="290" pagination="1 - 119" refId="ref15733" refString="Ulmer, G. (1905 a) Zur Kenntniss aussereuropaischer Trichopteren. (Neue Trichoptern des Hamburger und Stettiner Museums und des Zoologischen Instituts in Halle, nebst Beschreibungen einiger Typen Kolenati's und Burmeister's.). Stettiner Entomologische Zeitung, 66, 1 - 119." type="journal article" year="1905">Ulmer 1905a</bibRefCitation>
</taxonomicName>
by monotypy.
</paragraph>
<paragraph id="8BE1212CFFFD682045CA359CB8DDFECC" blockId="8.[151,1437,151,321]" pageId="8" pageNumber="291">
Although 
<taxonomicName id="4C5E5AAFFFFD68204455359CBBCBFF3C" authorityName="Ulmer" authorityYear="1905" box="[264,432,151,177]" class="Insecta" family="Polycentropodidae" genus="Polyplectropus" kingdom="Animalia" order="Trichoptera" pageId="8" pageNumber="291" phylum="Arthropoda" rank="genus">
<emphasis id="B92AFD3EFFFD68204455359CBBCBFF3C" box="[264,432,151,177]" italics="true" pageId="8" pageNumber="291">Polyplectropus</emphasis>
</taxonomicName>
is found almost world-wide and is diverse in Southeast Asia and the Neotropics (there are about 40 species in the Australian Region, including 
<quantity id="4CA68CC9FFFD682047AD35B0B951FF58" box="[752,810,187,213]" metricMagnitude="-1" metricUnit="m" metricValue="5.334" pageId="8" pageNumber="291" unit="in" value="21.0">21 in</quantity>
<collectingCountry id="F34961BCFFFD6820466F35B0B99EFF5B" box="[818,997,187,214]" name="New Caledonia" pageId="8" pageNumber="291">New Caledonia</collectingCountry>
), the genus is presently represented by only four described species in New 
<collectingCountry id="F34961BCFFFD6820477535D4B802FF74" box="[552,633,223,249]" name="Guinea-Bissau" pageId="8" pageNumber="291">Guinea</collectingCountry>
(
<bibRefCitation id="EFCF5CDDFFFD682047DA35D4B96BFF74" author="Morse, J. C." box="[647,784,223,249]" pageId="8" pageNumber="291" refId="ref15171" refString="Morse, J. C. (2021) Trichoptera World Checklist. Available from: http: // entweb. clemson. edu / database / trichopt / index. htm (accessed 8 Oct 2021)" type="url" year="2021">Morse 2021</bibRefCitation>
) and a single described species, 
<taxonomicName id="4C5E5AAFFFFD6820412035D4BB16FE90" authority="Kimmins 1953" authorityName="Kimmins" authorityYear="1953" class="Insecta" family="Polycentropodidae" genus="Polyplectropus" kingdom="Animalia" order="Trichoptera" pageId="8" pageNumber="291" phylum="Arthropoda" rank="species" species="lacusalbinae">
<emphasis id="B92AFD3EFFFD6820412035D4BAC4FE91" italics="true" pageId="8" pageNumber="291">Polyplectropus lacusalbinae</emphasis>
Kimmins 1953
</taxonomicName>
(in 
<bibRefCitation id="EFCF5CDDFFFD682044C73408B8C7FE90" author="Mosely, M. E. &amp; Kimmins, D. E." box="[410,700,258,285]" pageId="8" pageNumber="291" refId="ref15209" refString="Mosely, M. E. &amp; Kimmins, D. E. (1953) The Trichoptera of Australia and New Zealand. British Museum (Natural History), London, 550 pp. https: // doi. org / 10.5962 / bhl. title. 118696" type="book" year="1953">Mosely &amp; Kimmins 1953</bibRefCitation>
), in 
<collectingCountry id="F34961BCFFFD682047B63408B92EFE90" box="[747,853,259,285]" name="Australia" pageId="8" pageNumber="291">Australia</collectingCountry>
. Here two new species, 
<taxonomicName id="4C5E5AAFFFFD6820413F3408BE89FE90" authority="Cartwright &amp; Dostine, 2022" authorityName="Cartwright &amp; Dostine" authorityYear="2022" box="[1122,1266,259,285]" class="Insecta" family="Polycentropodidae" genus="Polyplectropus" kingdom="Animalia" order="Trichoptera" pageId="8" pageNumber="291" phylum="Arthropoda" rank="species" species="berryensis" status="sp. nov.">
<emphasis id="B92AFD3EFFFD6820413F3408BE89FE90" box="[1122,1266,259,285]" italics="true" pageId="8" pageNumber="291">P. berryensis</emphasis>
</taxonomicName>
<emphasis id="B92AFD3EFFFD682041A53408BF29FE90" bold="true" box="[1272,1362,259,285]" pageId="8" pageNumber="291">
<taxonomicNameLabel id="A2194045FFFD682041A53408BF29FE90" box="[1272,1362,259,285]" pageId="8" pageNumber="291" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
and 
<taxonomicName id="4C5E5AAFFFFD682040D53408BB71FECC" authority="Cartwright &amp; Dostine, 2022" authorityName="Cartwright &amp; Dostine" authorityYear="2022" class="Insecta" family="Polycentropodidae" genus="Polyplectropus" kingdom="Animalia" order="Trichoptera" pageId="8" pageNumber="291" phylum="Arthropoda" rank="species" species="bamboosa" status="sp. nov.">
<emphasis id="B92AFD3EFFFD682040D53408BB71FECC" italics="true" pageId="8" pageNumber="291">P. bamboosa</emphasis>
</taxonomicName>
<emphasis id="B92AFD3EFFFD6820444C342CBB10FECC" bold="true" box="[273,363,295,321]" pageId="8" pageNumber="291">
<taxonomicNameLabel id="A2194045FFFD6820444C342CBB10FECC" box="[273,363,295,321]" pageId="8" pageNumber="291" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
, are described from the NT.
</paragraph>
