<subSubSection id="714EDE3EE04C4C0E374263787BA052CF" pageId="null" pageNumber="71" type="description">
<paragraph id="5D4B722732F608A386F581949549C990" pageId="null" pageNumber="71">
Habitus und 
<normalizedToken id="A023AF173246F23B06E5E0D485158C87" originalValue="Blüten" pageId="null" pageNumber="71">Blueten</normalizedToken>
wie bei 
<taxonomicName id="EFF319AFF1AD0CE71830364F4F9059C0" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="71" phylum="Tracheophyta" rank="species" species="trichophyllus">
<emphasis id="BE219D54A1A2034AF4C287D720B68D07" italics="true" pageId="null" pageNumber="71">R. trichophyllus</emphasis>
</taxonomicName>
(Nr. 1f). 
<normalizedToken id="10FA95A622EDC6591AF3F03ABDA34603" originalValue="Früchtchenkopf" pageId="null" pageNumber="71">Fruechtchenkopf</normalizedToken>
, im Gegensatz zu den 
<normalizedToken id="60AA82A8289449380DCAD9FFDF8419EB" originalValue="übrigen" pageId="null" pageNumber="71">uebrigen</normalizedToken>
Arten, 
<emphasis id="C1EB52C391F01E1BB0E9EBE6FEE532C6" italics="true" pageId="null" pageNumber="71">
nicht kugelig, sondern 
<normalizedToken id="CC1BB0019BB1A5669E6B48A61FBA2EA6" originalValue="eiförmig" pageId="null" pageNumber="71">eifoermig</normalizedToken>
oder zylindrisch.
</emphasis>
<normalizedToken id="F3A74824E3ABB47A9439B1B41FB04954" originalValue="Früchtchen" pageId="null" pageNumber="71">Fruechtchen</normalizedToken>
je Kopf 
<emphasis id="84E3997C00CC15E57DB09311E1B95B5A" italics="true" pageId="null" pageNumber="71">zahlreich</emphasis>
(
<emphasis id="06D868979D9408DEAD92FC5A72C9016B" italics="true" pageId="null" pageNumber="71">50-100</emphasis>
), oval, 1-1,4 mm lang, 0,6-0,8 mm breit, stets 
<emphasis id="908DA53C98E4F24D939011ACED46CF7B" italics="true" pageId="null" pageNumber="71">kahl</emphasis>
, mit 6-8 undeutlichen Querrippen. 
<emphasis id="86D52F41AE04C5C297FC8D0C71A5CB27" italics="true" pageId="null" pageNumber="71">
<normalizedToken id="4BBA9E278A304917CF6A7F65041E892D" originalValue="Blütenboden" pageId="null" pageNumber="71">Bluetenboden</normalizedToken>
zylindrisch
</emphasis>
, behaart.
</paragraph>
<paragraph id="A3F5E8A9031F39AFE74A9E4D808D321A" pageId="null" pageNumber="71">
<emphasis id="FA178B825732867B03C2122A1EDB626B" italics="true" pageId="null" pageNumber="71">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="325D992EFD5D46404655E65D338852C1" italics="true" pageId="null" pageNumber="71">16:</emphasis>
Material aus 
<normalizedToken id="7540EE748FEACDD05C26F390F130F4F7" originalValue="Österreich" pageId="null" pageNumber="71">Oesterreich</normalizedToken>
und dem Irak (Cook 1962Cook 1966).
</paragraph>
<paragraph id="3242A1D8CAA34E20C1D75A52F124BB28" pageId="null" pageNumber="71">
<emphasis id="9F98A66F6A16AE7462526A9832768E00" italics="true" pageId="null" pageNumber="71">Standort.</emphasis>
Kollin. Teiche und 
<normalizedToken id="26978493F6EAEB14D50A22D2100D0FDD" originalValue="Tümpel" pageId="null" pageNumber="71">Tuempel</normalizedToken>
.
</paragraph>
<paragraph id="8019FD7D2D861D33C77B47A16794AA9C" pageId="null" pageNumber="71">
<emphasis id="BF3768CBBF7F75060CF17370CC790E25" italics="true" pageId="null" pageNumber="71">Verbreitung. Eurasiatische Pflanze:</emphasis>
Zerstreut in Mitteleuropa; 
<normalizedToken id="2C129D68A189DB3466DE636E2B2FB5FC" originalValue="östliches" pageId="null" pageNumber="71">oestliches</normalizedToken>
Mediterrangebiet, Asien 
<normalizedToken id="9B81416CF5DFA316575935ADB26DC476" originalValue="südlich" pageId="null" pageNumber="71">suedlich</normalizedToken>
des Himalajas und Ostasien. Verbreitungskarte von Cook (1966). - Im Gebiet: Im Wannenweiher bei Rorschach und im Rhonetal von Siders an 
<normalizedToken id="E3E06ED6E869B3703673426431380263" originalValue="abwärts" pageId="null" pageNumber="71">abwaerts</normalizedToken>
bis Fully (in letzter Zeit zahlreiche Fundstellen 
<normalizedToken id="2A65B54C7F12CFAB528DB8A159CD1A31" originalValue="zerstört" pageId="null" pageNumber="71">zerstoert</normalizedToken>
und die Pflanze vielleicht nicht mehr vorhanden).
</paragraph>
</subSubSection>
