3.3. Genus 
<taxonomicName id="39C6B6A3FFF0FFAAFC4076E8DD7CFC6C" authority="PACE, 2013" authorityName="PACE" authorityYear="2013" box="[971,1284,975,1007]" class="Insecta" family="Staphylinidae" genus="Episkiodrusilla" kingdom="Animalia" order="Coleoptera" pageId="65" pageNumber="78" phylum="Arthropoda" rank="genus">
<emphasis id="CCB21132FFF0FFAAFC4076E8DC0FFC6C" box="[971,1143,975,1007]" italics="true" pageId="65" pageNumber="78">Episkiodrusilla</emphasis>
<bibRefCitation id="9A57B0D1FFF0FFAAFBF576E8DD7CFC6C" author="PACE, R." box="[1150,1284,975,1007]" pageId="65" pageNumber="78" pagination="33 - 63" refId="ref78152" refString="PACE, R. 2013: New distributional data, new species and three new genera of Aleocharinae from Malaysia, Vietnam and Taiwan (Coleoptera: Staphylinidae). - Tropical Zoology 26 (1): 33 - 63." type="journal article" year="2013">PACE, 2013</bibRefCitation>
</taxonomicName>
