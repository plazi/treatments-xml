<subSubSection id="8B5FCAF3D4C5F95DAFCD84D17BF1301D" pageId="null" pageNumber="143" type="description">
<paragraph id="B7820CE2F076F09B8042EB5160F6E30C" pageId="null" pageNumber="143">
Ausdauernd, 
<emphasis id="5829D7DD8D24DB362000A67155FFE5E1" italics="true" pageId="null" pageNumber="143">
mit 
<normalizedToken id="879810F1DF777C8AB5A79CB450CF7878" originalValue="verlängerten" pageId="null" pageNumber="143">verlaengerten</normalizedToken>
, weit kriechenden unterirdischen Stengeln
</emphasis>
, oft lockerrasig; 10-20 cm hoch. 
<normalizedToken id="343CAD17E9D40CF7828DDA294F4E86D2" originalValue="Stengelblätter" pageId="null" pageNumber="143">Stengelblaetter</normalizedToken>
2-4mal so lang wie breit. 
<normalizedToken id="BFCCA57D3D6041227FE3D52B6C96A588" originalValue="Kelchblätter" pageId="null" pageNumber="143">Kelchblaetter</normalizedToken>
2-3 mm lang. 
<normalizedToken id="B610E9296B37E43B614EFEC891539734" originalValue="Kronblätter" pageId="null" pageNumber="143">Kronblaetter</normalizedToken>
6-8 mm lang. Staubbeutel nach der 
<normalizedToken id="26A0E4127852BF2C94E757177F8081E4" originalValue="Blüte" pageId="null" pageNumber="143">Bluete</normalizedToken>
gelb. 
<emphasis id="705C562CBBD812F60FF5C3F122E90BD1" italics="true" pageId="null" pageNumber="143">
<normalizedToken id="B8745EE90CD5C0A096F576DC21046F13" originalValue="Früchte" pageId="null" pageNumber="143">Fruechte</normalizedToken>
1-1
</emphasis>
⅓ 
<emphasis id="DA35D427098E556AB6A8C51F9C0133FB" italics="true" pageId="null" pageNumber="143">mal so lang wie breit, vorn mit 1-1,5 mm breitem Rand</emphasis>
, etwa 1 mm tief eingeschnitten, 2-5samig. Griffel 1-2 mm lang. - 
<normalizedToken id="5800359F8FEB9644D33D734DFE1DAA41" originalValue="Blüte" pageId="null" pageNumber="143">Bluete</normalizedToken>
: 
<normalizedToken id="B91CD04733B8D1A689DE9BBE6BAB6951" originalValue="Später" pageId="null" pageNumber="143">Spaeter</normalizedToken>
<normalizedToken id="CB3FEF3B9CAF334D202C05BF2B531841" originalValue="Frühling" pageId="null" pageNumber="143">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="72084A0C3B899187E469F975ED717E4E" pageId="null" pageNumber="143">
<emphasis id="09CB3AADB28FAFFF30715ABE5CA764E4" italics="true" pageId="null" pageNumber="143">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E65BA747A369C03F38B01B88CB042494" italics="true" pageId="null" pageNumber="143">28:</emphasis>
Material aus botanischen 
<normalizedToken id="21B7F6A35119FC56EFB5E4682049CE7F" originalValue="Gärten" pageId="null" pageNumber="143">Gaerten</normalizedToken>
(Jaretzky 1932, Manton 1932), aus Ungarn (Baksay in 
<normalizedToken id="C1D2D80BAA6E945C0E22286A6740C401" originalValue="Löve" pageId="null" pageNumber="143">Loeve</normalizedToken>
und 
<normalizedToken id="37CF21C3DE58CBB4BE05B76B792336C6" originalValue="Löve" pageId="null" pageNumber="143">Loeve</normalizedToken>
1961), von 5 Stellen in 
<normalizedToken id="5E658B7890E40F597FE2486A4F837B81" originalValue="Niederösterreich" pageId="null" pageNumber="143">Niederoesterreich</normalizedToken>
(Polatschek 1966).
</paragraph>
<paragraph id="6858945024CC028D9EF963A7763C51E5" pageId="null" pageNumber="143">
<emphasis id="A31E767352E9FBAEF19A8A86F05744B0" italics="true" pageId="null" pageNumber="143">Standort.</emphasis>
Kollin und montan. Nicht zu trockene, kalkreiche, meist 
<normalizedToken id="8D3DA43175EC2F1BB17F7975A3EE0CD8" originalValue="flachgründige" pageId="null" pageNumber="143">flachgruendige</normalizedToken>
<normalizedToken id="82E0ED378624D262EF8DE6650A72732F" originalValue="Böden" pageId="null" pageNumber="143">Boeden</normalizedToken>
in halbschattigen Lagen. Schattige Felsen, lichte 
<normalizedToken id="2EB61454BE49D619856D2C8D73EB840E" originalValue="Föhren-" pageId="null" pageNumber="143">Foehren-</normalizedToken>
und 
<normalizedToken id="002650D54785712B6EDCEC74A50808D1" originalValue="Laubmischwälder" pageId="null" pageNumber="143">Laubmischwaelder</normalizedToken>
.
</paragraph>
<paragraph id="2359F07E18369C7923B4C59AF91E234E" pageId="null" pageNumber="143">
<emphasis id="DAB211906621CA07E2F5F5237A70977A" italics="true" pageId="null" pageNumber="143">
Verbreitung. Mittel- und 
<normalizedToken id="A4AB367EAA12972ADE58D3689457C7E2" originalValue="südeuropäische" pageId="null" pageNumber="143">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
<normalizedToken id="4C3747243821F561DD43E04C1C23A9CB" originalValue="Pyrenäen" pageId="null" pageNumber="143">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="DD1C6DBFDD1C49D63D114CBB6ED5FDFC" originalValue="mittelfranzösische" pageId="null" pageNumber="143">mittelfranzoesische</normalizedToken>
Gebirge, 
<normalizedToken id="78EC1FE7C6C44FB02C0CB5B84B07EB93" originalValue="Südbelgien" pageId="null" pageNumber="143">Suedbelgien</normalizedToken>
, Jura, mitteldeutsche Gebirge, West- und Ostalpen, Gebirge der Balkanhalbinsel (
<normalizedToken id="347E8E4439E31DAC9BA013CADF9CB26F" originalValue="südwärts" pageId="null" pageNumber="143">suedwaerts</normalizedToken>
bis Mazedonien?, nach Polatschek 1966 in Jugoslawien nicht vorhanden). Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: Savoyen (Champagny), Kalkvorberge der Vogesen (Gegend von Rouffach, angepflanzt am Florimont), Illfurth im Sundgau, ganzer Jura, 
<normalizedToken id="7921A7D93E728BAAAD81B7CD41158B01" originalValue="nördliches" pageId="null" pageNumber="143">noerdliches</normalizedToken>
<normalizedToken id="DFE7D8027741592C4EE48C5C18A2F19E" originalValue="Zürich" pageId="null" pageNumber="143">Zuerich</normalizedToken>
(Bachs), Baar, Hegau, 
<normalizedToken id="20B7A892CFE8E1EA4C06B961E94C8B97" originalValue="Allgäu" pageId="null" pageNumber="143">Allgaeu</normalizedToken>
(Hindelang).
</paragraph>
</subSubSection>
