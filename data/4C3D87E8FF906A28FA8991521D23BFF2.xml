<collectingRegion id="0650F81CFF906A2FF73E9E6D1421B37F" box="[2242,2593,2100,2125]" country="Libya" name="Al Jabal al Akhdar" pageId="107" pageNumber="865">Al Jabal Al Akhdar Dist.</collectingRegion>
