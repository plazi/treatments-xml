ca. 
<quantity id="036C9B1BFF906A2FF77A9E2216DAB3AE" box="[2182,2266,2171,2204]" metricMagnitude="2" metricUnit="m" metricValue="3.3" pageId="107" pageNumber="865" unit="m" value="330.0">330m</quantity>
a. s. 1.”
</materialsCitation>
