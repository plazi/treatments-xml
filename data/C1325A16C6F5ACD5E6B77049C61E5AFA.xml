<subSubSection id="E0E5BAFEEB57ED5785610E21F2AA95E0" pageId="null" pageNumber="646" type="vernacular_names">
<paragraph id="D651EF42685533498BADBA2C3CE2BBFF" pageId="null" pageNumber="646">Alpen-Kreuzblume</paragraph>
</subSubSection>
</title>
<subSubSection id="678D4122655667CB50199995D6CAFC5C" pageId="null" pageNumber="646" type="description">
<paragraph id="E225EBF4C677BF59E92B931FF1F8833A" pageId="null" pageNumber="646">
<emphasis id="9D54C14F22AF401CA53B277C965E4434" italics="true" pageId="null" pageNumber="646">2-6 cm hoch.</emphasis>
Stengel 
<normalizedToken id="433EC480EC89ADBB640DF00F34678198" originalValue="dünn" pageId="null" pageNumber="646">duenn</normalizedToken>
, am Grunde niederliegend. Untere 
<normalizedToken id="4124F5DD97E80342359894985693ABB8" originalValue="Blätter" pageId="null" pageNumber="646">Blaetter</normalizedToken>
<normalizedToken id="30C785B694133AE7C8B8CBDE437060EF" originalValue="wechselständig" pageId="null" pageNumber="646">wechselstaendig</normalizedToken>
, am Ort, wo die Zweige aufsteigen, rosettenartig angeordnet, die obern meist 
<normalizedToken id="68600122DE80A78303F2B98EE207DF84" originalValue="kürzer" pageId="null" pageNumber="646">kuerzer</normalizedToken>
als die untern, 
<emphasis id="61D26CF54819F00A997341D69C158AAF" italics="true" pageId="null" pageNumber="646">0,4 bis 1 cm lang</emphasis>
, oberhalb der Mitte am breitesten. 
<emphasis id="5501AD8C43F9D16086F2B97C4AB73C4E" italics="true" pageId="null" pageNumber="646">
Mitteltrieb der Rosette ohne 
<normalizedToken id="34880C533BD0274F3920AF757352FD33" originalValue="Blüten" pageId="null" pageNumber="646">Blueten</normalizedToken>
</emphasis>
(bei den andern Arten der Gruppe mit 
<normalizedToken id="3718261AF379617F79D36B393BD665F9" originalValue="Blüten" pageId="null" pageNumber="646">Blueten</normalizedToken>
!). 
<normalizedToken id="3B4E0FAF7A6875AE6719215F86BE5AD9" originalValue="Blütenstände" pageId="null" pageNumber="646">Bluetenstaende</normalizedToken>
an den seitlichen Trieben, 5-11 
<normalizedToken id="9ECB084486FE949970C7CE3898630CEF" originalValue="blütig" pageId="null" pageNumber="646">bluetig</normalizedToken>
. 
<emphasis id="94D2A3A4DCEA633CC1531C7480702BDB" italics="true" pageId="null" pageNumber="646">
<normalizedToken id="A3C2F0398D243E708603BC0D43A7FABE" originalValue="Tragblätter" pageId="null" pageNumber="646">Tragblaetter</normalizedToken>
0,7-1 mm lang.
</emphasis>
<normalizedToken id="B41EBF5D732A1B0241A814026B3E8BEF" originalValue="Blüten" pageId="null" pageNumber="646">Blueten</normalizedToken>
<normalizedToken id="0710E08C5084E8C7B49047963079BEF8" originalValue="weiß" pageId="null" pageNumber="646">weiss</normalizedToken>
bis hellblau. Oberstes Kelchblatt 2-3 mm lang. 
<normalizedToken id="7D8DD2554CCAFB55EB581E25F454BCA8" originalValue="Flügel" pageId="null" pageNumber="646">Fluegel</normalizedToken>
3,5-4,8 mm lang und 
<emphasis id="D48326406D9FDF59B5C17AC9145D9557" italics="true" pageId="null" pageNumber="646">1,2-2 mm breit</emphasis>
, mit seitlichen Nerven, die kaum verzweigt sind und nur 0-3 geschlossene Netzmaschen bilden. Frucht 3-4 mm lang, mit 0,2-0,3 mm breitem Rand. Samen 2-2,5 mm lang. - 
<normalizedToken id="DDC096F0CF5A2FB51DC2B74A7715559E" originalValue="Blüte" pageId="null" pageNumber="646">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="48759A3A046771DE7669642B5B715E27" pageId="null" pageNumber="646">
<emphasis id="3F840B030680BD2D414FA5CB10590B58" italics="true" pageId="null" pageNumber="646">Zytologische Angaben. 2n ca. 34:</emphasis>
Material aus der Schweiz (Glendinning 1960).
</paragraph>
<paragraph id="FF0861159254F50C78B8A4DE3A38C1F3" pageId="null" pageNumber="646">
<emphasis id="85ABCF3A9B3DAA3CC38E4EBF35FF45FA" italics="true" pageId="null" pageNumber="646">Standort.</emphasis>
Alpin, seltener subalpin. Trockene, meist kalkreiche 
<normalizedToken id="B1DB8A5BC2114B9EB7DBF062FA2ED970" originalValue="Böden" pageId="null" pageNumber="646">Boeden</normalizedToken>
. Weiden, Rasen.
</paragraph>
<paragraph id="6DD86E625F402B3897850CE28FC700B9" pageId="null" pageNumber="646">
<emphasis id="09323023BDB90060E2442EF0DE35F2BB" italics="true" pageId="null" pageNumber="646">
Verbreitung. 
<normalizedToken id="813F4D969953FC43AF3C5AA50E92AB0F" originalValue="Westalpin-pyrenäische" pageId="null" pageNumber="646">Westalpin-pyrenaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="458DF810D0B03A40FFA9337A3BD94CCA" originalValue="Pyrenäen" pageId="null" pageNumber="646">Pyrenaeen</normalizedToken>
, Westalpen (
<normalizedToken id="F86046587FD751B92375E0647EE704BA" originalValue="ostwärts" pageId="null" pageNumber="646">ostwaerts</normalizedToken>
bis 
<normalizedToken id="C6BF16BB66041360D7BD3658A661E229" originalValue="Mittelbünden" pageId="null" pageNumber="646">Mittelbuenden</normalizedToken>
und 
<normalizedToken id="36AA2B848E570823FE97B7BC13D62D74" originalValue="Südtirol" pageId="null" pageNumber="646">Suedtirol</normalizedToken>
). - Im Gebiet: Zentral- und 
<normalizedToken id="B5693675B0711C2FAE94858848BC9C01" originalValue="Südalpen" pageId="null" pageNumber="646">Suedalpen</normalizedToken>
(in 
<normalizedToken id="C31BBA29A32BFCB7DFD7750AA726617D" originalValue="Graubünden" pageId="null" pageNumber="646">Graubuenden</normalizedToken>
<normalizedToken id="53F5E27988E813812BC21BA6CB3A8655" originalValue="nordwärts" pageId="null" pageNumber="646">nordwaerts</normalizedToken>
bis Lukmanier, Parpan, Albula, Engadin); westliche Nordalpen (bis Freiburger Alpen [Morteys]); nicht 
<normalizedToken id="E2D2B74E1236B750EB88C806ABDF1BDB" originalValue="häufig" pageId="null" pageNumber="646">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
