<taxonomicName id="30371C04F5900537C60BF1388ABE0FF8" authorityName="Bordera &amp; Santos" authorityYear="2022" class="Insecta" family="Ichneumonidae" genus="Piasites" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Piasites seyrigi" order="Hymenoptera" pageId="0" pageNumber="23" phylum="Arthropoda" rank="species" species="seyrigi">
