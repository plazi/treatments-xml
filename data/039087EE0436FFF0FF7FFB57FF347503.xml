<emphasis id="B94DEAEA0437FFF0FF2FFD73FE9273BA" bold="true" box="[199,345,654,680]" pageId="5" pageNumber="326">Distribution</emphasis>
. 
<collectingCountry id="F32E76680437FFF0FE8FFD72FE2F73BB" box="[359,484,655,681]" name="Costa Rica" pageId="5" pageNumber="326">Costa Rica</collectingCountry>
, 
<collectingCountry id="F32E76680437FFF0FE18FD72FDAA73BB" box="[496,609,655,681]" name="Honduras" pageId="5" pageNumber="326">Honduras</collectingCountry>
