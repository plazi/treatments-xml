<subSubSection id="2B6C4DB3663690D1B22D8E27A50B89BF" pageId="null" pageNumber="224" type="description">
<paragraph id="997B3EF2C0BAF01CBB75E596D1C19A9C" pageId="null" pageNumber="224">
Unterscheidet sich von 
<taxonomicName id="D52A1AAC9E477743AA26AC60E5E94274" class="Magnoliopsida" family="Brassicaceae" genus="Sisymbrium" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="224" phylum="Tracheophyta" rank="genus">
<emphasis id="4776ED6115233B3FFB54E087DCB031E4" italics="true" pageId="null" pageNumber="224">Sisymbrium</emphasis>
</taxonomicName>
(S. 218) durch folgende Merkmale: 
<emphasis id="CDE1B254C167F3BBC9C7D41A976E8C4B" italics="true" pageId="null" pageNumber="224">
Kurze, 
<normalizedToken id="6C16CB4BCD24FAF0D0C580A8D077BEBB" originalValue="sternförmige" pageId="null" pageNumber="224">sternfoermige</normalizedToken>
, mehrstrahlige Haare
</emphasis>
und 1fache Haare vorhanden; 
<emphasis id="07CC50F2E9402423C5AEF94BE66D413A" italics="true" pageId="null" pageNumber="224">
<normalizedToken id="E3DC7F728F197A2DE1F5972C1DD7B8E2" originalValue="Kronblätter" pageId="null" pageNumber="224">Kronblaetter</normalizedToken>
vorn etwas ausgerandet, 
<normalizedToken id="82AD95292818F3C25E4072584FB671AB" originalValue="weiß" pageId="null" pageNumber="224">weiss</normalizedToken>
</emphasis>
, 
<normalizedToken id="B37093A465B46F6D2EB937503D446F04" originalValue="Fruchtblätter" pageId="null" pageNumber="224">Fruchtblaetter</normalizedToken>
mit undeutlichen Seitennerven.
</paragraph>
<paragraph id="D0B4753129A4D56D87D96FB4EA356276" pageId="null" pageNumber="224">
Die Gattung 
<taxonomicName id="A26C93C4DB3211F09237E2E6700CAFF6" class="Magnoliopsida" family="Brassicaceae" genus="Murbeckiella" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="224" phylum="Tracheophyta" rank="genus">
<emphasis id="E85D2FEFEBEDB6463B2AC996B66647A9" italics="true" pageId="null" pageNumber="224">Murbeckiella</emphasis>
</taxonomicName>
<normalizedToken id="4D8F41369B3174213F3E2D815D54853B" originalValue="umfaßt" pageId="null" pageNumber="224">umfasst</normalizedToken>
<emphasis id="6841FAF7BD4951F462D2F4DFF019750C" italics="true" pageId="null" pageNumber="224">
6 Arten in 
<normalizedToken id="756ABBB168106BF44C5DC74A27EAD7CE" originalValue="südeuropäischen" pageId="null" pageNumber="224">suedeuropaeischen</normalizedToken>
und vorderasiatischen Gebirgen.
</emphasis>
</paragraph>
