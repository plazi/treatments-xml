<subSubSection id="D9F16554FFAFBA03BC17F11DBBABF908" pageId="19" pageNumber="638" type="discussion">
<paragraph id="915436DFFFAFBA03BC17F11DBBABF908" blockId="19.[2053,2645,1547,1970]" pageId="19" pageNumber="638">
This species was previously placed in the genus 
<taxonomicName id="56EB4D5CFFAFBA03BC73F1C5BAC7F908" authorityName="Peters" authorityYear="1866" box="[2145,2273,1701,1734]" class="Mammalia" family="Molossidae" genus="Molossops" kingdom="Animalia" order="Chiroptera" pageId="19" pageNumber="638" phylum="Chordata" rank="genus">Molossops</taxonomicName>
