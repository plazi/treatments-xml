<subSubSection id="60D670CF7D77D339851150C6F8D63EAC" pageId="null" pageNumber="727" type="description">
<paragraph id="6C7EA72AC7DCA0CD7CD6AF23CFE33858" pageId="null" pageNumber="727">
<emphasis id="445384AA2CF90D91A6ED5B366EDF6448" italics="true" pageId="null" pageNumber="727">
<normalizedToken id="91F7128F97E996E730C92C50919C72AE" originalValue="Blätter" pageId="null" pageNumber="727">Blaetter</normalizedToken>
nicht lederig, 1
</emphasis>
<normalizedToken id="28110BF5FBFF9167FA202FAF52CE12FD" originalValue="½" pageId="null" pageNumber="727">1/2</normalizedToken>
<emphasis id="107F1BCD1C5394CC1D9FD32A81C66E56" italics="true" pageId="null" pageNumber="727">-3</emphasis>
<normalizedToken id="6F6B5FE376036EC828DA75AFA67F755D" originalValue="½" pageId="null" pageNumber="727">1/2</normalizedToken>
<emphasis id="27AC160168B0EBB20C6B32CFCD1A0D72" italics="true" pageId="null" pageNumber="727">mal so lang wie breit</emphasis>
, 0,6-1,2 cm breit, 
<emphasis id="901F1AA3EDF1F040249B64DE7B21D9A5" italics="true" pageId="null" pageNumber="727">am Rande flach</emphasis>
, beiderseits mit sehr wenigen bis zahlreichen 0,5-1,5 mm langen, nach vorn gerichteten Borstenhaaren, 
<emphasis id="14DDAAD6CDADD3BFBA1187666229D3FE" italics="true" pageId="null" pageNumber="727">
ohne Sternhaare. Innere 
<normalizedToken id="527BAD20429AA67C015DD9F27CB22BE4" originalValue="Kelchblätter" pageId="null" pageNumber="727">Kelchblaetter</normalizedToken>
7-10 mm lang, auf den Nerven mit 1-2 mm langen Borstenhaaren, zwischen den mittleren Nerven kahl
</emphasis>
(an den 
<normalizedToken id="14BE9F9C6F65144DEF646174435CE6B6" originalValue="Rändern" pageId="null" pageNumber="727">Raendern</normalizedToken>
mit einigen Sternhaaren). 
<normalizedToken id="A56F2BA7DA2DDF712FF1ACBB91CB8FEC" originalValue="Kronblätter" pageId="null" pageNumber="727">Kronblaetter</normalizedToken>
10-15 mm lang. Staubbeutel 0,5-0,7 mm lang. - 
<normalizedToken id="033549BE615184322B030ED6A3D1DE4B" originalValue="Blüte" pageId="null" pageNumber="727">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="EBA0D275C1D572034C93D8484CC49406" pageId="null" pageNumber="727">
<emphasis id="1ED153A1D4C46B07B1E576612C0707D5" italics="true" pageId="null" pageNumber="727">
<pageBreakToken id="E66603231E5F0732F6AE463C2B2EB563" pageId="null" pageNumber="727">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="B49DB2E427000C7D1B945720035BEB8C" italics="true" pageId="null" pageNumber="727">20:</emphasis>
Material von der Schynigen Platte (Berner Oberland) (Rohner 1954), aus dem Wallis (Proctor 1955).
</paragraph>
<paragraph id="A3C3BBFB5AF849D166D84E43E0982F5D" pageId="null" pageNumber="727">
<emphasis id="B976F106DBDDE6B0AF2B1C3F7B6332C6" italics="true" pageId="null" pageNumber="727">Standort.</emphasis>
Subalpin und alpin, selten montan und kollin. Ziemlich trockene, oft kalkhaltige 
<normalizedToken id="144ACA2FC2FFA5B5B8033AA629B24E72" originalValue="Böden" pageId="null" pageNumber="727">Boeden</normalizedToken>
. Rasen, 
<normalizedToken id="95CB276ED2066C7925F4B68F7A124636" originalValue="Zwergstrauchgebüsch" pageId="null" pageNumber="727">Zwergstrauchgebuesch</normalizedToken>
.
</paragraph>
<paragraph id="2DFF37F473EA7F7218D76309E4BDC007" pageId="null" pageNumber="727">
<emphasis id="A8D64FDB3DC944D2A8CB2CBCFFB73D72" italics="true" pageId="null" pageNumber="727">
Verbreitung. Mittel- und 
<normalizedToken id="C129B780D4440D975A53AE4B6C5797F1" originalValue="südeuropäische" pageId="null" pageNumber="727">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
Nordspanische Gebirge, 
<normalizedToken id="4844CA2E377A582E1D2DD31865CEF8B8" originalValue="Pyrenäen" pageId="null" pageNumber="727">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="64120BEEFCB53C7190908C8C718E04BA" originalValue="Corbières" pageId="null" pageNumber="727">Corbieres</normalizedToken>
, Auvergne, Vogesen, Jura, Alpen, Sudeten, Karpaten, Apennin, Gebirge der Balkanhalbinsel, Kaukasus. - Im Gebiet: Alpen (verbreitet und ziemlich 
<normalizedToken id="415A38A9EA6A34E116FA5C1333A27E01" originalValue="häufig" pageId="null" pageNumber="727">haeufig</normalizedToken>
), Jura (Marchairuz, Chasseral, Pieterlen, 
<normalizedToken id="1AC6B104C0264552BABFBA51D256EBB5" originalValue="Lägern" pageId="null" pageNumber="727">Laegern</normalizedToken>
, Osterfingen, von Fridingen 
<normalizedToken id="20831380B176938603EF3258A5CAF24C" originalValue="nordostwärts" pageId="null" pageNumber="727">nordostwaerts</normalizedToken>
) und Vogesen (Grand Ballon, Hohneck).
</paragraph>
</subSubSection>
