<heading id="894481FBFFC5FFE9A26D7B9F95190AAF" box="[868,1401,197,222]" pageId="12" pageNumber="1224">
SUPERFAMILY 
<taxonomicName id="15B34D14FFC5FFE9A50E7B9F95190AAF" authority="BERRY, 1920" authorityName="BERRY" authorityYear="1920" box="[1031,1401,197,222]" kingdom="Animalia" pageId="12" pageNumber="1224" rank="superFamily" superFamily="Architeuthoidea">
ARCHITEUTHOIDEA 
<bibRefCitation id="B6224B66FFC5FFE9A5EE7B9F95190AAF" author="Berry SS" box="[1255,1401,197,222]" pageId="12" pageNumber="1224" pagination="141 - 169" refId="ref14237" refString="Berry SS. 1920. Light production in cephalopods, I. An introductory survey. Biological Bulletin 38: 141 - 169." type="journal article" year="1920">BERRY, 1920</bibRefCitation>
