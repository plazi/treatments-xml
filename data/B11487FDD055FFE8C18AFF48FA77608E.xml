<heading id="624A8187D055FFE8C18AFF48FD5C66A1" bold="true" box="[136,640,157,184]" fontSize="11" level="1" pageId="7" pageNumber="216" reason="1">
<emphasis id="0BC9EAF9D055FFE8C18AFF48FD5C66A1" bold="true" box="[136,640,157,184]" pageId="7" pageNumber="216">
Key to the Tasmanian species of 
<taxonomicName id="FEBD4D68D055FFE8C309FF4BFD5C66A1" authorityName="Hertel" box="[523,640,157,184]" class="Lecanoromycetes" family="Xylographaceae" genus="Lambiella" kingdom="Fungi" order="Baeomycetales" pageId="7" pageNumber="216" phylum="Ascomycota" rank="genus">
<emphasis id="0BC9EAF9D055FFE8C309FF4BFD5C66A1" bold="true" box="[523,640,157,184]" italics="true" pageId="7" pageNumber="216">Lambiella</emphasis>
</taxonomicName>
</emphasis>
</heading>
</paragraph>
