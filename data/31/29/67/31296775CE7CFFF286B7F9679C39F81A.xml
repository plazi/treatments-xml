species:
</emphasis>
<taxonomicName authority="Mandelstam, 1956" authorityName="Mandelstam" authorityYear="1956" box="[300,742,1769,1794]" class="Ostracoda" family="Cyprididae" genus="Mongolianella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Podocopida" pageId="5" pageNumber="540" phylum="Arthropoda" rank="species" species="palmosa">
<emphasis bold="true" box="[300,547,1769,1793]" italics="true" pageId="5" pageNumber="540">Mongolianella palmosa</emphasis>
<bibRefCitation author="Mandelstam, M. I." box="[553,742,1770,1794]" pageId="5" pageNumber="540" pagination="87 - 144" refId="ref15160" refString="Mandelstam, M. I. (1956) Material on Palaeontology. New families and genera: Ostracoda. Trudy VSEGEI, New Series, Palaeontology, 12, 87 - 144 + 306 - 323." type="journal article" year="1956">Mandelstam, 1956</bibRefCitation>
