<subSubSection id="C3485ED6095BB205EC95FED823154BFB" pageId="15" pageNumber="466" type="etymology">
<paragraph id="8BED0D5D095BB205EC95FED8221F4B6B" blockId="15.[151,1436,260,610]" pageId="15" pageNumber="466">
<emphasis id="B926D14F095BB205EC95FED821294B37" bold="true" box="[151,290,260,286]" pageId="15" pageNumber="466">Etymology:</emphasis>
<taxonomicName id="4C5276DE095BB205ED28FED8217B4B37" authorityName="Hamilton" authorityYear="1822" box="[298,368,260,286]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="15" pageNumber="466" phylum="Chordata" rank="genus">
<emphasis id="B926D14F095BB205ED28FED8217B4B37" box="[298,368,260,286]" italics="true" pageId="15" pageNumber="466">Garra</emphasis>
</taxonomicName>
: named based on a vernacular Indian name, a fish living in mud; 
<taxonomicName id="4C5276DE095BB205E858FED824BE4B37" authorityName="Banister" authorityYear="1987" box="[1114,1205,260,286]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="15" pageNumber="466" phylum="Chordata" rank="species" species="dunsirei">
<emphasis id="B926D14F095BB205E858FED824BE4B37" box="[1114,1205,260,286]" italics="true" pageId="15" pageNumber="466">dunsirei</emphasis>
</taxonomicName>
: named after Mr. 
<taxonomicName id="4C5276DE095BB205E983FED820FC4B6B" authorityName="Banister" authorityYear="1987" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="15" pageNumber="466" phylum="Chordata" rank="species" species="dunsirei">A. Dunsirei</taxonomicName>
who collected the fishes.
</paragraph>
<paragraph id="8BED0D5D095BB205ECC5FE9722584B4F" blockId="15.[151,1436,260,610]" box="[199,595,331,358]" pageId="15" pageNumber="466">
<emphasis id="B926D14F095BB205ECC5FE97218C4B4F" bold="true" box="[199,391,331,358]" pageId="15" pageNumber="466">Common name:</emphasis>
Tawi Atair 
<taxonomicName id="4C5276DE095BB205EE0EFE9022444B4F" authorityName="Hamilton" authorityYear="1822" box="[524,591,332,358]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="15" pageNumber="466" phylum="Chordata" rank="genus">Garra</taxonomicName>
.
</paragraph>
<paragraph id="8BED0D5D095BB205ECC5FEAC23154BFB" blockId="15.[151,1436,260,610]" pageId="15" pageNumber="466">
<emphasis id="B926D14F095BB205ECC5FEAC21454BA3" bold="true" box="[199,334,368,394]" pageId="15" pageNumber="466">Taxonomy:</emphasis>
<taxonomicName id="4C5276DE095BB205ED56FEAC21F74BA3" authorityName="Banister" authorityYear="1987" box="[340,508,368,394]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="15" pageNumber="466" phylum="Chordata" rank="species" species="dunsirei">
<emphasis id="B926D14F095BB205ED56FEAC21F74BA3" box="[340,508,368,394]" italics="true" pageId="15" pageNumber="466">Garra dunsirei</emphasis>
</taxonomicName>
<materialsCitation id="3B3A0700095BB205EE01FEAC23154BFB" ID-GBIF-Occurrence="3766721322" country="Oman" latitude="17.1" location="Jabal Qara (Jabal Samhan) mountains" longLatPrecision="1279" longitude="54.566666" pageId="15" pageNumber="466" specimenCount="1" stateProvince="Zufar">
was originally described by 
<bibRefCitation id="EFC370AC095BB205EF3DFEAC240A4BA3" author="Banister, K. E." box="[831,1025,367,394]" pageId="15" pageNumber="466" pagination="59 - 70" refId="ref22737" refString="Banister, K. E. (1987) Two new species of Garra (Teleostei-Cyprinidae) from the Arabian Peninsula. Bulletin of the British Museum (Natural History) Zoology, 52 (1), 59 - 70. https: // doi. org / 10.5962 / bhl. part. 18301" type="journal article" year="1987">Banister 1987:59</bibRefCitation>
, figs. 1, 2a, 3-5 [Bulletin of the British Museum (Natural History) Zoology v. 52 (no. 1) from a Sinkhole, Tawi Atair [or Attair], 
<geoCoordinate id="EE666B9A095BB205E8A9FE4F25054B84" box="[1195,1294,403,429]" degrees="17" direction="north" minutes="06" orientation="latitude" pageId="15" pageNumber="466" precision="925" value="17.1">17°06’N</geoCoordinate>
, 
<geoCoordinate id="EE666B9A095BB205E918FE4F25714B87" box="[1306,1402,403,430]" degrees="54" direction="east" minutes="34" orientation="longitude" pageId="15" pageNumber="466" precision="925" value="54.566666">54°34’E</geoCoordinate>
, in the 
<location id="8E8D5B86095BB205ECC2FE6422604BFB" LSID="urn:lsid:plazi:treatment:03FBBC4B095BB205EC95FF4B233C4D7C:8E8D5B86095BB205ECC2FE6422604BFB" box="[192,619,440,467]" country="Oman" latitude="17.1" longLatPrecision="1279" longitude="54.566666" name="Jabal Qara (Jabal Samhan) mountains" pageId="15" pageNumber="466" stateProvince="Zufar">Jabal Qara (Jabal Samhan) mountains</location>
, 
<collectingRegion id="4996C3BF095BB205EE77FE6422CD4BFB" box="[629,710,440,466]" country="Oman" name="Zufar" pageId="15" pageNumber="466">Dhofar</collectingRegion>
, 
<collectingCountry id="F3454DCD095BB205EED0FE6423114BFB" box="[722,794,440,466]" name="Oman" pageId="15" pageNumber="466">Oman</collectingCountry>
.
</materialsCitation>
</paragraph>
</subSubSection>
<subSubSection id="C3485ED6095BB205ECC5FE002494484B" pageId="15" pageNumber="466" type="materials_examined">
<paragraph id="8BED0D5D095BB205ECC5FE0024074BDF" blockId="15.[151,1436,260,610]" box="[199,1036,475,502]" pageId="15" pageNumber="466">
<materialsCitation id="3B3A0700095BB205ECC5FE00223D4BDF" ID-GBIF-Occurrence="3766721364" box="[199,566,475,502]" collectionCode="BMNH" pageId="15" pageNumber="466" specimenCode="BMNH 1984" specimenCount="1" typeStatus="holotype">
<emphasis id="B926D14F095BB205ECC5FE0021364BDF" bold="true" box="[199,317,476,502]" pageId="15" pageNumber="466">
<typeStatus id="54E9B3FF095BB205ECC5FE0021334BDF" box="[199,312,476,502]" pageId="15" pageNumber="466">Holotype</typeStatus>
:
</emphasis>
<specimenCode id="DBF4A526095BB205ED46FE0021D74BDF" box="[324,476,475,502]" collectionCode="BMNH" pageId="15" pageNumber="466">BMNH 1984</specimenCode>
.3.6.571
</materialsCitation>
. 
<materialsCitation id="3B3A0700095BB205EE42FE0024034BDF" ID-GBIF-Occurrence="3766721301" box="[576,1032,475,502]" collectionCode="BMNH" pageId="15" pageNumber="466" specimenCount="1" typeStatus="paratype">
<typeStatus id="54E9B3FF095BB205EE42FE0022BA4BDF" box="[576,689,476,502]" pageId="15" pageNumber="466">Paratypes</typeStatus>
: 
<collectionCode id="ED439598095BB205EEBEFE00231B4BDF" box="[700,784,476,502]" pageId="15" pageNumber="466">BMNH</collectionCode>
1984.3.6.572-576 (6)
</materialsCitation>
.
</paragraph>
<paragraph id="8BED0D5D095BB205ECC5FE232494484B" blockId="15.[151,1436,260,610]" pageId="15" pageNumber="466">
<emphasis id="B926D14F095BB205ECC5FE2321AB4830" bold="true" box="[199,416,511,537]" pageId="15" pageNumber="466">Short description:</emphasis>
It is distinguished from the other 
<taxonomicName id="4C5276DE095BB205EF1FFDDC23B04833" box="[797,955,512,538]" pageId="15" pageNumber="466">
<emphasis id="B926D14F095BB205EF1FFDDC23684833" box="[797,867,512,538]" italics="true" pageId="15" pageNumber="466">Garra</emphasis>
species
</taxonomicName>
in the region by having the highly unusual shape of neural spines below the dorsal fin, being very short and not penetrating between dorsal pterygiophores, whitish or pink body, very small eye, absence or reduction of scales on breast and abdomen.
</paragraph>
</subSubSection>
<caption id="DF2D5DD5095BB205EC95F9B822344C88" ID-DOI="http://doi.org/10.5281/zenodo.6541599" ID-Zenodo-Dep="6541599" httpUri="https://zenodo.org/record/6541599/files/figure.png" pageId="15" pageNumber="466" startId="15.[151,250,1636,1660]" targetBox="[151,1435,701,1611]" targetPageId="15">
<paragraph id="8BED0D5D095BB205EC95F9B822344C88" blockId="15.[151,1436,1636,1697]" pageId="15" pageNumber="466">
<emphasis id="B926D14F095BB205EC95F9B821144C55" bold="true" box="[151,287,1636,1660]" pageId="15" pageNumber="466">FIGURE 16.</emphasis>
<taxonomicName id="4C5276DE095BB205ED27F9B921B64C54" authorityName="Banister" authorityYear="1987" box="[293,445,1637,1661]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="15" pageNumber="466" phylum="Chordata" rank="species" species="dunsirei">
<emphasis id="B926D14F095BB205ED27F9B921B64C54" box="[293,445,1637,1661]" italics="true" pageId="15" pageNumber="466">Garra dunsirei</emphasis>
</taxonomicName>
, an endemic fish from Tawi Atair Sinkhole, Oman. Upper, redrawn by Rhian Kendall from 
<bibRefCitation id="EFC370AC095BB205E958F9B920F54C88" author="Banister, K. E." pageId="15" pageNumber="466" pagination="59 - 70" refId="ref22737" refString="Banister, K. E. (1987) Two new species of Garra (Teleostei-Cyprinidae) from the Arabian Peninsula. Bulletin of the British Museum (Natural History) Zoology, 52 (1), 59 - 70. https: // doi. org / 10.5962 / bhl. part. 18301" type="journal article" year="1987">Banister (1987)</bibRefCitation>
, lower photo by Klaus Rudloff.
</paragraph>
</caption>
<subSubSection id="C3485ED6095BB205ECC5F912233C4D7C" pageId="15" pageNumber="466" type="distribution">
<paragraph id="8BED0D5D095BB205ECC5F912227F4D18" blockId="15.[151,1436,1742,1877]" pageId="15" pageNumber="466">
<emphasis id="B926D14F095BB205ECC5F91221684CC1" bold="true" box="[199,355,1742,1768]" pageId="15" pageNumber="466">Distribution:</emphasis>
<taxonomicName id="4C5276DE095BB205ED68F913221A4CC0" authorityName="Banister" authorityYear="1987" box="[362,529,1743,1769]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="15" pageNumber="466" phylum="Chordata" rank="species" species="dunsirei">
<emphasis id="B926D14F095BB205ED68F913221A4CC0" box="[362,529,1743,1769]" italics="true" pageId="15" pageNumber="466">Garra dunsirei</emphasis>
</taxonomicName>
is restricted to a sinkhole at Tawi Attair, in the Jabal Qara (Jabal Samhan) mountains, 
<collectingRegion id="4996C3BF095BB205ECDBF92F21214D24" box="[217,298,1779,1805]" country="Oman" name="Zufar" pageId="15" pageNumber="466">Dhofar</collectingRegion>
, 
<collectingCountry id="F3454DCD095BB205ED36F92F21734D24" box="[308,376,1779,1805]" name="Oman" pageId="15" pageNumber="466">Oman</collectingCountry>
(
