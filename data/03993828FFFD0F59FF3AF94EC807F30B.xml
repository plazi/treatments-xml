<subSubSection id="C32ADAB5FFFD0F59FC9FF734C939F76C" pageId="15" pageNumber="198" type="multiple">
<caption id="DF4FD9B6FFFD0F59FC9FF734C939F76C" ID-DOI="http://doi.org/10.5281/zenodo.6600462" ID-Zenodo-Dep="6600462" httpUri="https://zenodo.org/record/6600462/files/figure.png" inLine="true" pageId="15" pageNumber="198" targetBox="[168,759,1961,2374]" targetPageId="15">
<paragraph id="8B8F893EFFFD0F59FC9FF734C939F76C" blockId="15.[781,1374,1954,2373]" pageId="15" pageNumber="198">
<emphasis id="B944552CFFFD0F59FC9FF734CFCEF70B" bold="true" box="[783,955,2187,2216]" pageId="15" pageNumber="198">Distribution.</emphasis>
