<accessionNumber box="[484,629,152,178]" httpUri="http://www.ncbi.nlm.nih.gov/protein/MCZ40085" pageId="18" pageNumber="19">
<collectionCode box="[484,549,152,178]" country="USA" httpUri="http://biocol.org/urn:lsid:biocol.org:col:33791" lsid="urn:lsid:biocol.org:col:33791" name="Museum of Comparative Zoology" pageId="18" pageNumber="19" type="Museum">MCZ</collectionCode>
