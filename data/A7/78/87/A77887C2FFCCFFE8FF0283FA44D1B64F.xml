<location LSID="urn:lsid:plazi:treatment:A77887C2FFCCFFE8FF0283FA44D1B64F:2A0E600FFFCFFFE8FD7880D5427AB787" box="[749,824,152,178]" country="Kenya" name="Island" pageId="18" pageNumber="19" stateProvince="Lamu">Island</location>
