<collectingCountry box="[339,442,432,458]" name="Kenya" pageId="33" pageNumber="34">KENYA</collectingCountry>
. Gede Ruins NMK/O. 2858, 3201; Jilore Forest NMK/O. 936–7; Kikuyu 
<accessionNumber httpUri="http://www.ncbi.nlm.nih.gov/protein/ZMB22036" pageId="33" pageNumber="34">ZMB 22036</accessionNumber>
; Pangani 
<accessionNumber box="[345,502,472,498]" httpUri="http://www.ncbi.nlm.nih.gov/protein/NMW32079" pageId="33" pageNumber="34">NMW 32079</accessionNumber>
(3). 
<collectingCountry box="[561,714,472,498]" name="Tanzania" pageId="33" pageNumber="34">TANZANIA</collectingCountry>
. Amani Nature Reserve NMZB 16147; Bamba Ridge Forest Reserve NMZB 17169; Kambai Forest 
<accessionNumber box="[647,806,512,538]" httpUri="http://www.ncbi.nlm.nih.gov/protein/KMH12737" pageId="33" pageNumber="34">KMH 12737</accessionNumber>
, ZMUC/R. 5315; Kulumezi Caves, 
<collectingRegion box="[1261,1332,512,538]" country="Tanzania" name="Tanga" pageId="33" pageNumber="34">Tanga</collectingRegion>
MNHN 1923.118; Magrotto Hill 
<accessionNumber box="[445,596,552,578]" httpUri="http://www.ncbi.nlm.nih.gov/protein/KMH11208" pageId="33" pageNumber="34">KMH 11208</accessionNumber>
, NMZB 13730; Manga Forest Reserve NMZB 14102; Mchungu Forest Reserve NMZB 10455; Mkwaja Forests NMZB 11352; Semdoe Forest Reserve NMZB 15610.
