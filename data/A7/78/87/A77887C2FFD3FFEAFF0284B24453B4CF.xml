. 
<emphasis bold="true" box="[884,987,1833,1857]" pageId="15" pageNumber="16">Figure 2.</emphasis>
<taxonomicName box="[996,1268,1833,1856]" class="Reptilia" family="Leptotyphlopidae" genus="Leptotyphlops" kingdom="Animalia" order="Squamata" pageId="15" pageNumber="16" phylum="Chordata" rank="species" species="reticulatus">
