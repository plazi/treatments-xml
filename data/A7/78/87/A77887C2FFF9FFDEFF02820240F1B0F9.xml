(
<figureCitation box="[1031,1115,1890,1916]" captionStart="PLATE 5" captionStartId="13.[151,238,1737,1761]" captionTargetBox="[268,1322,271,1704]" captionTargetId="figure-152@13.[264,1323,266,1713]" captionTargetPageId="13" captionText="PLATE 5. Leptotyphlops. Distribution of the Leptotyphlops parkeri, L. reticulatus, L. longicaudus and L. nigricans species groups in northeastern Africa and southwestern Arabia." pageId="36" pageNumber="37">Plate 5</figureCitation>
