<caption id="379749C91F61FF9AFFEBF982FD1835A6" ID-DOI="http://doi.org/10.5281/zenodo.5371171" ID-Zenodo-Dep="5371171" httpUri="https://zenodo.org/record/5371171/files/figure.png" pageId="42" pageNumber="321" startId="42.[113,124,1635,1652]" targetBox="[122,1207,219,1601]" targetPageId="42">
<paragraph id="635719411F61FF9AFFEBF982FD1835A6" blockId="42.[113,1211,1635,1697]" pageId="42" pageNumber="321">
FIG. 14. — 
<taxonomicName id="A4E862C21F61FF9AFF57F982FDA23573" authority="M.Schmid" authorityName="M. Schmid" authorityYear="2012" box="[205,520,1635,1652]" class="Magnoliopsida" family="Primulaceae" genus="Tapeinosperma" kingdom="Plantae" order="Ericales" pageId="42" pageNumber="321" phylum="Tracheophyta" rank="species" species="amieuense" status="sp. nov.">
<emphasis id="519CC5531F61FF9AFF57F982FE013573" box="[205,427,1635,1652]" italics="true" pageId="42" pageNumber="321">Tapeinosperma amieuense</emphasis>
M.Schmid
</taxonomicName>
, 
<taxonomicNameLabel id="4AAF78281F61FF9AFD8AF982FDF93573" box="[528,595,1635,1652]" pageId="42" pageNumber="321" rank="species">sp. nov.</taxonomicNameLabel>
: 
<emphasis id="519CC5531F61FF9AFDFBF982FDC43573" bold="true" box="[609,622,1635,1652]" pageId="42" pageNumber="321">A</emphasis>
, rameau florifère; 
<emphasis id="519CC5531F61FF9AFC92F982FCBF3573" bold="true" box="[776,789,1635,1652]" pageId="42" pageNumber="321">B</emphasis>
, fleur; 
<emphasis id="519CC5531F61FF9AFCCBF982FCF53573" bold="true" box="[849,863,1635,1652]" pageId="42" pageNumber="321">C</emphasis>
, calice et gynécée; 
<emphasis id="519CC5531F61FF9AFB92F982FBBC3573" bold="true" box="[1032,1046,1635,1652]" pageId="42" pageNumber="321">D</emphasis>
, fleur, pétales ôtés, montrant l’androcée; 
<emphasis id="519CC5531F61FF9AFEB0F998FE9C358D" bold="true" box="[298,310,1657,1674]" pageId="42" pageNumber="321">E</emphasis>
, détail d’une portion d’axe inflorescentiel; 
<emphasis id="519CC5531F61FF9AFD3FF998FD1A358D" bold="true" box="[677,688,1657,1674]" pageId="42" pageNumber="321">F</emphasis>
