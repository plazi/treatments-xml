<taxonomicName id="4C034D70FF90FFC15E7EF9488D6D0AE2" baseAuthorityName="Fallen" baseAuthorityYear="1823" box="[556,787,1730,1752]" class="Insecta" family="Piophilidae" genus="Mycetaulus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Diptera" pageId="1" pageNumber="114" phylum="Arthropoda" rank="species" species="bipunctatus">
