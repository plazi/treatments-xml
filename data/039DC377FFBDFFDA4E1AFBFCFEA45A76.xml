(
<tableCitation id="C6B647DAFFBDFFD94EF3FACBFBC85A61" box="[978,1077,1382,1404]" captionStart="Table 1" captionStartId="3.[144,208,419,441]" captionTargetPageId="3" captionText="Table 1. Specimens from the Southern Hemisphere used in this study, with specimen identification number, region of the collection site, GenBank accession numbers for the seven genetic markers, and voucher numbers (with museum acronym)" httpUri="http://table.plazi.org/id/DF4B22E9FFB3FFD74DB1FE0EFBE15ECA" pageId="13" pageNumber="1116" tableUuid="DF4B22E9FFB3FFD74DB1FE0EFBE15ECA">Table S1</tableCitation>
