<collectingCountry id="3FD1B8A3FFB6FF80A4F3FC8EE4448FE3" box="[980,1048,1723,1746]" name="Nepal" pageId="7" pageNumber="328">Nepal</collectingCountry>
: 
<collectingRegion id="850236D1FFB6FF80A305FC8EE43E8FE3" box="[1058,1122,1723,1746]" country="Nepal" name="Kosi" pageId="7" pageNumber="328">Koshi</collectingRegion>
(= 
<collectingRegion id="850236D1FFB6FF80A3A0FC8EE4E78FE3" box="[1159,1211,1723,1746]" country="Nepal" name="Kosi" pageId="7" pageNumber="328">Kosi</collectingRegion>
) Zone (
<figureCitation id="DFFDE4B6FFB6FF80A229FC8EE50C8FE3" box="[1294,1360,1723,1746]" captionStart="Fig" captionStartId="7.[1049,1082,757,776]" captionTargetBox="[152,1032,189,801]" captionTargetId="figure-635@7.[152,1035,189,801]" captionTargetPageId="7" captionText="Fig.7. Map showing the distribution of Cuccodorodes species." figureDoi="http://doi.org/10.5281/zenodo.4504770" httpUri="https://zenodo.org/record/4504770/files/figure.png" pageId="7" pageNumber="328">Fig. 7</figureCitation>
).
</paragraph>
