<subSubSection id="62EC656EFF89F41EFF5CFB65FF22FAE8" pageId="20" pageNumber="175" type="description">
<paragraph id="2A4936E5FF89F41EFF5CFB65FF22FAE8" blockId="20.[151,1437,1122,2013]" pageId="20" pageNumber="175">
<emphasis id="1882EAF7FF89F41EFF5CFB65FE41FB0C" bold="true" box="[199,384,1231,1257]" pageId="20" pageNumber="175">Measurements:</emphasis>
Body length: male 
<quantity id="ED0E9B00FF89F41EFDFBFB65FD76FB0C" box="[608,695,1231,1257]" metricMagnitude="-3" metricUnit="m" metricValue="2.9" pageId="20" pageNumber="175" unit="mm" value="2.9">2.9 mm</quantity>
(
<quantity id="ED0E9B00FF89F41EFD5DFB64FCDFFB0C" box="[710,798,1230,1257]" metricMagnitude="-3" metricUnit="m" metricValue="5.3" pageId="20" pageNumber="175" unit="mm" value="5.3">5.3 mm</quantity>
including wings) (N=1). Forewing length: male 
<quantity id="ED0E9B00FF89F41EFADDFB64FA5CFB0C" box="[1350,1437,1230,1257]" metricMagnitude="-3" metricUnit="m" metricValue="4.5" pageId="20" pageNumber="175" unit="mm" value="4.5">4.5 mm</quantity>
