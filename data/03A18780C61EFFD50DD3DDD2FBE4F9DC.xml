<typeStatus id="54B38834C61EFFD50DD3DC0AFF49FA9E" box="[151,201,1303,1324]" pageId="86" pageNumber="87">Type</typeStatus>
species: 
<taxonomicName id="4C084D15C61EFFD50C62DC0BFD85FA9E" authority="KITS &amp; MARSHALL, 2013" authorityName="KITS &amp; MARSHALL" authorityYear="2013" box="[294,517,1302,1324]" class="Insecta" family="Sphaeroceridae" genus="Coloantrops" higherTaxonomySource="GBIF" kingdom="Animalia" order="Diptera" pageId="86" pageNumber="87" phylum="Arthropoda" rank="species" species="daedalus" status="sp. nov.">
