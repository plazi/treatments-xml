<subSubSection id="C9EE35C2C1CE24B86A5BF2C307E9FF09" pageId="null" pageNumber="438" type="description">
<paragraph id="94DAC23394329CFA137100803220EE96" pageId="null" pageNumber="438">
10-60 cm hoch; bis 1 m lange, 
<normalizedToken id="CFA0E4F5C2521F44D00FD09A3F717544" originalValue="dünne" pageId="null" pageNumber="438">duenne</normalizedToken>
(1-1,5 mm dicke), unterirdische 
<normalizedToken id="CA9592B107C84163C89CEE8B4F33E637" originalValue="Ausläufer" pageId="null" pageNumber="438">Auslaeufer</normalizedToken>
treibend. 
<normalizedToken id="A72557C5CF249AD14DA771921E51A481" originalValue="Grundständige" pageId="null" pageNumber="438">Grundstaendige</normalizedToken>
Scheiden braun. 
<normalizedToken id="4B72DD1D1D31F96090DF2911B82F3A7F" originalValue="Blätter" pageId="null" pageNumber="438">Blaetter</normalizedToken>
schmal (1-1,5 mm breit), schlaff, so lang wie der Stengel oder 
<normalizedToken id="5421C2DCDA6DA53EF7D907C2D4996F2F" originalValue="länger" pageId="null" pageNumber="438">laenger</normalizedToken>
. Stengel 3kantig, nur im obern Teil rauh. 
<normalizedToken id="474F8A6710B42BA950173F7A9E4B961D" originalValue="Blütenstand" pageId="null" pageNumber="438">Bluetenstand</normalizedToken>
1-2 cm lang, aus 3-6 
<normalizedToken id="FECA1BC5B845E41AD32D3583B70396A8" originalValue="gedrängt" pageId="null" pageNumber="438">gedraengt</normalizedToken>
stehenden, 0,5-1 cm langen 
<normalizedToken id="1AFD4C661CB467D43906B5DA4F162FBF" originalValue="Ähren" pageId="null" pageNumber="438">Aehren</normalizedToken>
bestehend; alle 
<normalizedToken id="5340AFCBB77180000D9591B51004CD63" originalValue="Ähren" pageId="null" pageNumber="438">Aehren</normalizedToken>
unten ♂, oben ♀. 
<normalizedToken id="A36AE48D9ADFA2D91E7124336A8EDD7D" originalValue="Hochblätter" pageId="null" pageNumber="438">Hochblaetter</normalizedToken>
<normalizedToken id="A9DA82CC2E40F4861C430E29922EF1E4" originalValue="tragblattähnlich" pageId="null" pageNumber="438">tragblattaehnlich</normalizedToken>
. 
<normalizedToken id="0453CB0907E7E4A27AE6D84B11102592" originalValue="Tragblätter" pageId="null" pageNumber="438">Tragblaetter</normalizedToken>
so lang wie die reifen 
<normalizedToken id="1D6936E3286CEDA632AE113868E32B75" originalValue="Fruchtschläuche" pageId="null" pageNumber="438">Fruchtschlaeuche</normalizedToken>
, spitz, 
<emphasis id="A7561744B6DCAF95443FEB31A6162551" italics="true" pageId="null" pageNumber="438">braun</emphasis>
, mit hellem Rand und 
<normalizedToken id="F46C7DFCA3209BB5C7CF53702466E19E" originalValue="grünem" pageId="null" pageNumber="438">gruenem</normalizedToken>
Mittelnerv. 
<normalizedToken id="7889CAC84113AB2DDFD9FB6704CD6763" originalValue="Fruchtschläuche" pageId="null" pageNumber="438">Fruchtschlaeuche</normalizedToken>
<emphasis id="023A564C040426D41E8AD271FE35C766" italics="true" pageId="null" pageNumber="438">3</emphasis>
- 
<emphasis id="A577DF87FF9E5A8CCC77FCA6437E0248" italics="true" pageId="null" pageNumber="438">3,5 mm</emphasis>
lang, im untersten Drittel am breitesten (
<emphasis id="E51E92ACB8672AEC065669E532BE7353" italics="true" pageId="null" pageNumber="438">2</emphasis>
- 
<emphasis id="639CBA8C1B60E81DD6E1CE4D62CA981B" italics="true" pageId="null" pageNumber="438">2,5 mm</emphasis>
), innerseits flach, ohne oder mit 5-8 undeutlichen Nerven, 
<normalizedToken id="466A6FD92974652C490EE3A46D673D33" originalValue="außerseits" pageId="null" pageNumber="438">ausserseits</normalizedToken>
kugelig 
<normalizedToken id="834DE40800B04F2FEE38897885BC109B" originalValue="gewölbt" pageId="null" pageNumber="438">gewoelbt</normalizedToken>
, mit 10-14 deutlichen Nerven, 
<emphasis id="817B37937286FC077B008FF583E35AA5" italics="true" pageId="null" pageNumber="438">
am Rande vom Grunde her mit 
<normalizedToken id="D41825CC438E6C98ECF1B7B28FAC2677" originalValue="allmählich" pageId="null" pageNumber="438">allmaehlich</normalizedToken>
breiter werdendem
</emphasis>
(0,1-0,5 mm breitem), 
<emphasis id="56B232A886830ABE2229B6F8FDEA7368" italics="true" pageId="null" pageNumber="438">
fein 
<normalizedToken id="9F9C711A4171BF60EB98E34D44F920DE" originalValue="gezähntem" pageId="null" pageNumber="438">gezaehntem</normalizedToken>
, 
<normalizedToken id="8F656ADFB157596669A674312634266D" originalValue="grünem" pageId="null" pageNumber="438">gruenem</normalizedToken>
<normalizedToken id="BFC72CEA0DA9E26CF23532664B985256" originalValue="Flügel" pageId="null" pageNumber="438">Fluegel</normalizedToken>
</emphasis>
, gelbbraun, matt, 
<emphasis id="B7BBFDC4A27C6A7AD660CD38A1D338AF" italics="true" pageId="null" pageNumber="438">
<normalizedToken id="159BCD89754E08291D6FFD83A86F35D1" originalValue="plötzlich" pageId="null" pageNumber="438">ploetzlich</normalizedToken>
in den Schnabel 
<normalizedToken id="538401606D9946E6B1DC148DCADE66CE" originalValue="verschmälert" pageId="null" pageNumber="438">verschmaelert</normalizedToken>
.
</emphasis>
Narben 2.
</paragraph>
<paragraph id="6556D69A27CA01468C5F92DA9691430E" pageId="null" pageNumber="438">
<emphasis id="33043BCA2E30B1A22056E9934B6E1269" italics="true" pageId="null" pageNumber="438">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="DD1AA88450F99767AC1A973AD53FD335" pageId="null" pageNumber="438">
<emphasis id="CCAB2EA63B69ABCB16F966A6B5F34446" italics="true" pageId="null" pageNumber="438">Standort.</emphasis>
Kollin und montan. Trockene, kalkhaltige, sandige, 
<normalizedToken id="CB02BA3E31D044E3B5EEB59AC9CDAEBF" originalValue="flachgründige" pageId="null" pageNumber="438">flachgruendige</normalizedToken>
<normalizedToken id="C0CE378518E7723EA75A4E6217DBBC36" originalValue="Böden" pageId="null" pageNumber="438">Boeden</normalizedToken>
. 
<normalizedToken id="47AE207D84A89283754D8E4E124D1D9B" originalValue="Wärmeliebend" pageId="null" pageNumber="438">Waermeliebend</normalizedToken>
, 
<normalizedToken id="EC45C62491BB5DBB55214901C38A07C1" originalValue="große" pageId="null" pageNumber="438">grosse</normalizedToken>
Temperaturextreme ertragende Wiesengesellschaften (Walliser Schwingel-Wiesen); diese bei uns nur als Relikte vorhanden (Hauptverbreitung in Ost- und 
<normalizedToken id="DA41834DBA14A443AA7916D76615929F" originalValue="Südosteuropa" pageId="null" pageNumber="438">Suedosteuropa</normalizedToken>
); auch an Ruderalstellen (
<normalizedToken id="AF07E996AA5F4E8A6AEA82E8CEAAD892" originalValue="Wegränder" pageId="null" pageNumber="438">Wegraender</normalizedToken>
).
</paragraph>
<paragraph id="5AD8E3075B4BBE1E9ED7DB62E1194B36" pageId="null" pageNumber="438">
<emphasis id="4BBAB54F56D48CA783523D4E01D013AC" italics="true" pageId="null" pageNumber="438">
Verbreitung. 
<normalizedToken id="986DCDB21F2AC9D6BFFCD2E417187C54" originalValue="Osteuropäisch-asiatische" pageId="null" pageNumber="438">Osteuropaeisch-asiatische</normalizedToken>
Pflanze:
</emphasis>
In Mittel- und Westeuropa selten, 
<normalizedToken id="85313F1321C5456BBB4322113671525E" originalValue="nordwärts" pageId="null" pageNumber="438">nordwaerts</normalizedToken>
bis Norddeutschland, vereinzelte Fundstellen im Mediterrangebiet (
<normalizedToken id="8735E5BE7EC726C75670B6DB8B9AE5B0" originalValue="südwärts" pageId="null" pageNumber="438">suedwaerts</normalizedToken>
bis Mittelspanien, Korsika, Griechenland), Hauptvorkommen in Ost- und 
<normalizedToken id="DEE236C731C80FC4426A6BA8602BCE02" originalValue="Südosteuropa" pageId="null" pageNumber="438">Suedosteuropa</normalizedToken>
, West-, Zentral- und Ostasien (besonders zwischen 50 und 60° NB). Verbreitungskarte von Meusel (1964). - Im Gebiet: Oberrheinische Tiefebene, Vorberge des Schwarzwaldes, Hohentwiel (?), bei Buchs (St. Gallen) nur adventiv, 
<normalizedToken id="FC6DDB30D6994CB7AD1E0FB76BCAE43F" originalValue="Graubünden" pageId="null" pageNumber="438">Graubuenden</normalizedToken>
(Zernez), Vintschgau, Piemont (Val Vogna im Gebiet des Valsesia, nach Bertolani-Marchetti 1954), Como (alte Angabe).
</paragraph>
</subSubSection>
