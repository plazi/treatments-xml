<taxonomicName id="C0E2CC3FF6234ED71ED4E99A0D309FAA" authority="L." class="Magnoliopsida" family="Apiaceae" genus="Laserpitium" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="814" phylum="Tracheophyta" rank="species" species="peucedanoides">
