<paragraph id="84585F48FFFB014763A5F76691DA833F" blockId="25.[151,760,1894,2077]" pageId="25" pageNumber="48">
<emphasis id="B693835AFFFB014763A5F76692688C5F" bold="true" box="[151,281,1894,1917]" pageId="25" pageNumber="48">Comments.</emphasis>
<bibRefCitation id="E07622B9FFFB0147622CF76692BA8C5F" author="DUVIVIER A." box="[286,459,1894,1917]" firstAuthor="DUVIVIER" journalOrPublisher="Bulletin ou Comptes-Rendus des Sceances de la Societe Entomologique de Belgique" pageId="25" pageNumber="48" pagination="cccx-cccxx" part="1884" refId="ref30757" refString="DUVIVIER A. 1884: Description de quelques phytophages nouveaux et notes rectificatives. Bulletin ou Comptes-Rendus des Sceances de la Societe Entomologique de Belgique 1884: cccx-cccxx." title="Description de quelques phytophages nouveaux et notes rectificatives" type="journal volume" year="1884">DUVIVIER (1884)</bibRefCitation>
described this species based on one female from Borneo. Subsequent authors followed its classification in 
<taxonomicName id="43E724CBFFFB01476242F7A692838C9F" authorityName="Baly" authorityYear="1864" box="[368,498,1958,1981]" class="Insecta" family="Chrysomelidae" genus="Platyxantha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="25" pageNumber="48" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFFB01476242F7A692838C9F" box="[368,498,1958,1981]" italics="true" pageId="25" pageNumber="48">Platyxantha</emphasis>
</taxonomicName>
(
<bibRefCitation id="E07622B9FFFB01476131F7A691E88C9F" author="WILCOX J. A." box="[515,665,1958,1981]" editor="WILCOX J. A." firstAuthor="WILCOX" journalOrPublisher="Editio seconda. W. Junk, ' s-Gravenhage" pageId="25" pageNumber="48" pagination="433 - 664" refId="ref33616" refString="WILCOX J. A. 1973: Chrysomelidae: Galerucinae: Luperini: Luperina. In: WILCOX J. A. (ed.): Coleopterorum Catalogus Supplementa. Pars 78 (3). Editio seconda. W. Junk, ' s-Gravenhage, pp. 433 - 664." title="Chrysomelidae: Galerucinae: Luperini: Luperina" type="book chapter" volumeTitle="Coleopterorum Catalogus Supplementa. Pars 78 (3)." year="1973">WILCOX 1973</bibRefCitation>
, 
<bibRefCitation id="E07622B9FFFB01476195F7A693A08CFF" author="KIMOTO S." firstAuthor="KIMOTO" journalOrPublisher="Kurume University Journal" pageId="25" pageNumber="48" pagination="201 - 237" part="39" refId="ref31701" refString="KIMOTO S. 1990: Check-list of Chrysomelidae of south east Asia, south of Thailand and west of Irian-Jaya of Indonesia, VI. Galerucinae, 2. Kurume University Journal 39: 201 - 237." title="Check-list of Chrysomelidae of south east Asia, south of Thailand and west of Irian-Jaya of Indonesia, VI. Galerucinae, 2." type="journal article" year="1990">KIMOTO 1990</bibRefCitation>
). 
<bibRefCitation id="E07622B9FFFB014763D0F7C692108CFF" author="REID C. A. M." box="[226,353,1990,2013]" firstAuthor="REID" journalOrPublisher="Australian Journal of Entomology" pageId="25" pageNumber="48" pagination="1 - 9" part="38" refId="ref33192" refString="REID C. A. M. 1999: Reappraisal of the genus Taumacera Thunberg with descriptions of two new species from South-East Asia (Coleoptera: Chrysomelidae: Galerucinae). Australian Journal of Entomology 38: 1 - 9." title="Reappraisal of the genus Taumacera Thunberg with descriptions of two new species from South-East Asia (Coleoptera: Chrysomelidae: Galerucinae)" type="journal article" year="1999">REID (1999)</bibRefCitation>
transferred it to 
<taxonomicName id="43E724CBFFFB01476123F7C691F98CFF" authorityName="Thunberg" authorityYear="1814" box="[529,648,1990,2013]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="25" pageNumber="48" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFFB01476123F7C691F98CFF" box="[529,648,1990,2013]" italics="true" pageId="25" pageNumber="48">Taumacera</emphasis>
</taxonomicName>
. Based on the general appearence of the 
<typeStatus id="5B5CE1EAFFFB014762EAF7E691448CDF" box="[472,565,2022,2045]" pageId="25" pageNumber="48">holotype</typeStatus>
and presence of a metafemoral spine, I transfer it to 
<taxonomicName id="43E724CBFFFB01476131F80691D5833F" authorityName="Laboissiere" authorityYear="1933" box="[515,676,2054,2077]" class="Insecta" family="Chrysomelidae" genus="Hoplosaenidea" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="25" pageNumber="48" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFFB01476131F80691D5833F" box="[515,676,2054,2077]" italics="true" pageId="25" pageNumber="48">Hoplosaenidea</emphasis>
</taxonomicName>
.
</paragraph>
