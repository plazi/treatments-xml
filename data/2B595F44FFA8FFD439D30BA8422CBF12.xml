<location id="A62FB889FFA8FFD43BEF08EC4404B8DB" LSID="urn:lsid:plazi:treatment:2B595F44FFA8FFD439D30BA8422CBF12:A62FB889FFA8FFD43BEF08EC4404B8DB" box="[692,810,986,1012]" country="Brazil" county="Mata" municipality="Manaus-Itacoatiara Highway" name="Amazonas" pageId="38" pageNumber="265">Amazonas</location>
