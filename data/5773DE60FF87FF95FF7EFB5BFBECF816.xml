<taxonomicName id="18DA14F5FF86FF95FDB7F9ADFD6FF96C" authorityName="Petagna" authorityYear="1787" box="[577,664,1655,1677]" class="Magnoliopsida" family="Plantaginaceae" genus="Callitriche" kingdom="Plantae" order="Lamiales" pageId="7" pageNumber="250" phylum="Tracheophyta" rank="species" species="brutia">
