<emphasis id="61B6EAB4FFFFFFE1E1FD028DFE2FFD32" bold="true" box="[199,396,726,753]" italics="true" pageId="7" pageNumber="32">M. phoebe dorae</emphasis>
<bibRefCitation id="37534B57FFFFFFE1E0AF028DFD8FFD32" author="Graves, P." box="[405,556,726,753]" pageId="7" pageNumber="32" pagination="17 - 126" refId="ref9143" refString="Graves, P. (1925) The Rhopalocera and Grypocera of Palestine and Transjordania. Transactions of the entomological Society of London, 73, 17 - 126, plates 4, 5." type="journal article" year="1925">Graves, 1925</bibRefCitation>
</taxonomicName>
</paragraph>
