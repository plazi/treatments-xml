</tr>
<tr id="45B7C23384A3B5CB4D1E32DC9D5375E6" pageId="null" pageNumber="162">
<td id="01CBE19C70310ADA37F1DB230D1150EC" align="left" pageId="null" pageNumber="162" valign="top">
3*. 
<normalizedToken id="B4B7421A8514D0CD333B91C743025BC0" originalValue="Früchte" pageId="null" pageNumber="162">Fruechte</normalizedToken>
mit einzelnen kurzen, 1fachen Haaren, an den Enden gerundet
</td>
<td id="DA42D65B999735427D2DBC39FB3505FE" align="left" pageId="null" pageNumber="162" valign="bottom">
<taxonomicName id="B31136AAE109BBAF692E322877759AF6" class="Magnoliopsida" family="Brassicaceae" genus="Draba" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="162" phylum="Tracheophyta" rank="species" species="tomentosa">
<italic id="4567397EEF86B73D91547534AB025A09" pageId="null" pageNumber="162">D. tomentosa</italic>
