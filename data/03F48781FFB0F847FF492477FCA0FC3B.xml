<taxonomicName id="4C5D4D14FFB0F847FBF42572FB46FCC0" authorityName="Eschscholtz" authorityYear="1829" box="[1066,1195,835,861]" class="Insecta" family="Buprestidae" genus="Stigmodera" kingdom="Animalia" order="Coleoptera" pageId="1" pageNumber="436" phylum="Arthropoda" rank="genus">
