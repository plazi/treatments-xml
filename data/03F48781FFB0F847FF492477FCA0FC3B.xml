<taxonomicName id="4C5D4D14FFB0F847FCA8252EFBEBFCA4" authorityName="Mannerheim" authorityYear="1837" box="[886,1030,799,825]" class="Insecta" family="Buprestidae" genus="Conognatha" kingdom="Animalia" order="Coleoptera" pageId="1" pageNumber="436" phylum="Arthropoda" rank="species" species="auricollis">L. auricollis</taxonomicName>
