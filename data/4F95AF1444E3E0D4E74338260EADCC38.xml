<subSubSection id="97F96B03083D6EB97042F364668563FB" pageId="null" pageNumber="12" type="description">
<paragraph id="461686CB05C78FC9C900F68F05808987" pageId="null" pageNumber="12">
Bis 5 m hoher Strauch. 
<normalizedToken id="A6E1BDB7A08D6E4747CB8499E024BF2A" originalValue="Blätter" pageId="null" pageNumber="12">Blaetter</normalizedToken>
<normalizedToken id="FA595FDD3B866AAB6AC8371705DFB92E" originalValue="sommergrün" pageId="null" pageNumber="12">sommergruen</normalizedToken>
(selten erst im 
<normalizedToken id="E624616B26755887209D08102785CD61" originalValue="Frühjahr" pageId="null" pageNumber="12">Fruehjahr</normalizedToken>
abfallend), 
<emphasis id="ED1F51BF734E210774A0B50AF5DF3620" italics="true" pageId="null" pageNumber="12">kurz gestielt</emphasis>
(
<emphasis id="200F2CD9FAD40BB31F83E7CD4128A3BE" italics="true" pageId="null" pageNumber="12">
Stiel 
<normalizedToken id="88068B73FA32CDA79DCF4D62E4E2CD89" originalValue="höchstens" pageId="null" pageNumber="12">hoechstens</normalizedToken>
⅙ so lang wie die Spreite
</emphasis>
), 
<emphasis id="766F2075708B93B08CB59211DC8CCC0A" italics="true" pageId="null" pageNumber="12">lanzettlich</emphasis>
, ganzrandig, kahl. 
<normalizedToken id="B9F1E49988B29801D4FA8F541722E650" originalValue="Blütenstiele" pageId="null" pageNumber="12">Bluetenstiele</normalizedToken>
kurzhaarig. 
<normalizedToken id="B28ECB68E89578779B0BD719C079244F" originalValue="Blüten" pageId="null" pageNumber="12">Blueten</normalizedToken>
stark duftend. 
<emphasis id="62A45EF7B5006E8C028C2DBAC0CC68B3" italics="true" pageId="null" pageNumber="12">Kelch fast ganzrandig</emphasis>
(
<normalizedToken id="E5BB29F375C1BE8A92D9727E24240CAE" originalValue="Zähne" pageId="null" pageNumber="12">Zaehne</normalizedToken>
sehr undeutlich). 
<emphasis id="295A69F4CB632F8E7154ECA8F466F89C" italics="true" pageId="null" pageNumber="12">
Krone mit etwa 5 mm langer 
<normalizedToken id="5F2F1E3114F72266B585F13DD223FC80" originalValue="Röhre" pageId="null" pageNumber="12">Roehre</normalizedToken>
, 
<normalizedToken id="635128E9B9A7E972D24F5C284192BBC4" originalValue="weiß" pageId="null" pageNumber="12">weiss</normalizedToken>
. Frucht 0,5
</emphasis>
- 
<emphasis id="3C75E443C71157F76ED0655E3234D7B3" italics="true" pageId="null" pageNumber="12">1 cm dick, schwarz.</emphasis>
- 
<normalizedToken id="EF443D5FFAA01BA110ACF113C11E2495" originalValue="Blüte" pageId="null" pageNumber="12">Bluete</normalizedToken>
: 
<normalizedToken id="194022DE19535717A8D1984696DC9D6F" originalValue="Später" pageId="null" pageNumber="12">Spaeter</normalizedToken>
<normalizedToken id="2ADED62CAEC920E26B024D128B6C7ACB" originalValue="Frühling" pageId="null" pageNumber="12">Fruehling</normalizedToken>
und 
<normalizedToken id="A3BA7939E966FE0D57A6ACA56BD44900" originalValue="früher" pageId="null" pageNumber="12">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="671F04794EEE2C3986BAC6C0D62E1AE8" pageId="null" pageNumber="12">
<emphasis id="1A3CAB6171F5931091D861122254FE02" italics="true" pageId="null" pageNumber="12">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="80B797A6A5F0814E72B182F43672A55B" italics="true" pageId="null" pageNumber="12">46:</emphasis>
Material aus botanischen 
<normalizedToken id="F788CDF9ECD6EDCFCA74643DF827D8D0" originalValue="Gärten" pageId="null" pageNumber="12">Gaerten</normalizedToken>
(Sax und Abbe 1932, Taylor 1945), aus den Niederlanden (Gadella und Kliphuis 1966), aus Bulgarien (Markova 1970).
</paragraph>
<paragraph id="814E0117FE97D156CE02B02FC4079675" pageId="null" pageNumber="12">
<emphasis id="526E124F57CD51FD01D66BD3F699FC3C" italics="true" pageId="null" pageNumber="12">Standort.</emphasis>
Kollin, seltener montan. Ziemlich feuchte oder wechselfeuchte, meist kalkhaltige, steinige und lehmige 
<normalizedToken id="6ECD00E2B281E5808815B5281B320021" originalValue="Böden" pageId="null" pageNumber="12">Boeden</normalizedToken>
in 
<normalizedToken id="B5E613E128DC43DD022BFF01C639B582" originalValue="wärmeren" pageId="null" pageNumber="12">waermeren</normalizedToken>
Lagen. Lichte Laub- und 
<normalizedToken id="AD8C1C63871CFFE9EED6638379BC5E5B" originalValue="Föhrenwälder" pageId="null" pageNumber="12">Foehrenwaelder</normalizedToken>
, 
<normalizedToken id="76A0C842FF2FDFDDFCA32593346BCF8C" originalValue="Waldränder" pageId="null" pageNumber="12">Waldraender</normalizedToken>
, 
<normalizedToken id="9A811FB385BC9C0C00207FA6744DBF73" originalValue="Gebüsche" pageId="null" pageNumber="12">Gebuesche</normalizedToken>
, Hecken. 
<emphasis id="CB0A72649D937E251C5B6CC587D56E6C" italics="true" pageId="null" pageNumber="12">Ligustro-Prunetum</emphasis>
Tx. 1952.
</paragraph>
<paragraph id="425A2B023BB977C433662EB90122B90C" pageId="null" pageNumber="12">
<emphasis id="2AC33A42BB8BAB3AE3FCF2AE00970C24" italics="true" pageId="null" pageNumber="12">
Verbreitung. 
<normalizedToken id="5A900CD78FB30DC230831BC4D511E2E4" originalValue="Europäisch-westasiatische" pageId="null" pageNumber="12">Europaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="BA8949F279EFBE966B03695421616FAD" originalValue="Nordwärts" pageId="null" pageNumber="12">Nordwaerts</normalizedToken>
bis 
<normalizedToken id="E169EA3298D7EA9228C964F24FE5D060" originalValue="Südirland" pageId="null" pageNumber="12">Suedirland</normalizedToken>
, England, 
<normalizedToken id="C998911D88289855CFD0425F9E52B746" originalValue="Südskandinavien" pageId="null" pageNumber="12">Suedskandinavien</normalizedToken>
, Baltikum, Schlesien; 
<normalizedToken id="09F6759525468520C73BA1FB750FC1D8" originalValue="südwärts" pageId="null" pageNumber="12">suedwaerts</normalizedToken>
bis Kaukasus, Kleinasien, Nordwestafrika (?). - Im Gebiet verbreitet und 
<normalizedToken id="A57D8FD546F74ED2735574750EB7CF00" originalValue="häufig" pageId="null" pageNumber="12">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
