<paragraph id="E5C0A4C2D9A902EB19DD0B67BDF25BBB" pageId="null" pageNumber="11">
<taxonomicName id="D600F253F05DA94C5026691F88DA80E5" authority="(Thunb.) Vahl" class="Magnoliopsida" family="Oleaceae" genus="Forsythia" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="11" phylum="Tracheophyta" rank="species" species="suspensa">
Forsythia 
<normalizedToken id="B40DDC93B8A2E6A22918903FB3396BE8" originalValue="suspénsa" pageId="null" pageNumber="11">suspensa</normalizedToken>
(Thunb.) Vahl
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="A063C8E4CD8355C7C30178046FA9E481" pageId="null" pageNumber="11" type="vernacular_names">
<paragraph id="F38B8BBCD1EEB6DFC6FDA9A021083B41" pageId="null" pageNumber="11">Chinesische Forsythie</paragraph>
</subSubSection>
</title>
<subSubSection id="8B5BB9F49159811FC50150E1AADFE0BD" pageId="null" pageNumber="11" type="description">
<paragraph id="122566E716B96FC5A52F8779ECA63973" pageId="null" pageNumber="11">
1,5-3 m hoher Strauch. 
<emphasis id="BE495E93B73E933AE9687A22830B945A" italics="true" pageId="null" pageNumber="11">
<normalizedToken id="ABC6ED098394DB99117CED2C73881A8F" originalValue="Ältere" pageId="null" pageNumber="11">Aeltere</normalizedToken>
<normalizedToken id="BCBB4EDD6FA1C5F9B36B1428D7F24692" originalValue="Äste" pageId="null" pageNumber="11">Aeste</normalizedToken>
<normalizedToken id="E10BF877C5F5D23AC098A6C0F8D2F202" originalValue="überhängend" pageId="null" pageNumber="11">ueberhaengend</normalizedToken>
</emphasis>
. 
<normalizedToken id="C077FC5B296DAB4DFFE59AF186A050D1" originalValue="Blätter" pageId="null" pageNumber="11">Blaetter</normalizedToken>
ungeteilt und lanzettlich, seltener 3teilig oder aus 3 
<normalizedToken id="05F0FADC7CC37811FC0CF338CB3F4155" originalValue="Teilblättern" pageId="null" pageNumber="11">Teilblaettern</normalizedToken>
zusammengesetzt, 
<normalizedToken id="F6002FCD85009F5184C09D64BE5330BA" originalValue="gezähnt" pageId="null" pageNumber="11">gezaehnt</normalizedToken>
(
<emphasis id="8D6D65170106658B68567516E04C73B0" italics="true" pageId="null" pageNumber="11">
<normalizedToken id="2091CB5A3DBF2F633B101B3CA1395B66" originalValue="Zähne" pageId="null" pageNumber="11">Zaehne</normalizedToken>
nach vorn gerichtet
</emphasis>
). 
<emphasis id="5704FBF4E396E019D84279F1E1C67F1E" italics="true" pageId="null" pageNumber="11">
<normalizedToken id="6A84B21BD739BF44C8E77A9DCDFDAAF2" originalValue="Blüten" pageId="null" pageNumber="11">Blueten</normalizedToken>
vor den 
<normalizedToken id="C34A1AD78CEF8DB1E271AA42EA9EA49B" originalValue="Blättern" pageId="null" pageNumber="11">Blaettern</normalizedToken>
erscheinend
</emphasis>
. Krone 1,5-2,5 cm lang und 
<emphasis id="6732F6181ADDF53A3FD34648AF2F7F49" italics="true" pageId="null" pageNumber="11">2</emphasis>
- 
<emphasis id="345E253BAC124BD32E1B7245701C87E1" italics="true" pageId="null" pageNumber="11">3 cm im Durchmesser</emphasis>
, gelb. - 
<normalizedToken id="8B47AD9BB345B63DC51D2577AD7EEB35" originalValue="Blüte" pageId="null" pageNumber="11">Bluete</normalizedToken>
: 
<normalizedToken id="DF58A823617B1312AC00B50A146317FB" originalValue="Früher" pageId="null" pageNumber="11">Frueher</normalizedToken>
<normalizedToken id="A08B10EF721CBB1BF8B1BE57A1BE86B1" originalValue="Frühling" pageId="null" pageNumber="11">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="13A9EC6753281021308C9AA55F42019A" pageId="null" pageNumber="11">
<emphasis id="FA1AC17F0D8907AE2FBF743123D3BF88" italics="true" pageId="null" pageNumber="11">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5D70FAE716BA5B6924358A7D9A65A432" italics="true" pageId="null" pageNumber="11">28:</emphasis>
Material aus 
<normalizedToken id="6E165B62623ECD0CD8123228935DC12B" originalValue="Gärten" pageId="null" pageNumber="11">Gaerten</normalizedToken>
(
<normalizedToken id="27C753A19EA5F8183F07A2CA4DD0C2D5" originalValue="O’Mara" pageId="null" pageNumber="11">O'Mara</normalizedToken>
1930, Sax und Abbe 1932).
</paragraph>
<paragraph id="59C8B23A87117FC09913B3A9F7444CD3" pageId="null" pageNumber="11">
<emphasis id="C3F9D8AD977803BF84673E2E19B469DA" italics="true" pageId="null" pageNumber="11">Standort</emphasis>
. Kollin. Lockere 
<normalizedToken id="35395A893F2A2B04078CFB7711161AE9" originalValue="Böden" pageId="null" pageNumber="11">Boeden</normalizedToken>
in warmen Lagen.
</paragraph>
<paragraph id="FABCAE1FE2353F6FF4085874EA94C241" pageId="null" pageNumber="11">
<emphasis id="7B3F605F97CA4A040112EA5D41379EAB" italics="true" pageId="null" pageNumber="11">Verbreitung</emphasis>
. 
<normalizedToken id="8C4F0FC598BC5B59A518E379C4C2CBDE" originalValue="Ursprünglich" pageId="null" pageNumber="11">Urspruenglich</normalizedToken>
<emphasis id="EAF74C6FBEA2B01D042D268418E6451A" italics="true" pageId="null" pageNumber="11">ostasiatische Pflanze:</emphasis>
Sehr 
<normalizedToken id="44985DD04954ADF5409D5D2DA42A3747" originalValue="häufig" pageId="null" pageNumber="11">haeufig</normalizedToken>
in 
<normalizedToken id="67BED8885DBE49271A32C46EB714882A" originalValue="Gärten" pageId="null" pageNumber="11">Gaerten</normalizedToken>
als Zierstrauch angepflanzt, nur selten verwildert.
</paragraph>
<paragraph id="882FE160563B3FAC100537C62D7AD887" pageId="null" pageNumber="11">
<emphasis id="FC94F4730A04BAC127C862934D136F37" italics="true" pageId="null" pageNumber="11">Bemerkungen</emphasis>
. Sehr 
<normalizedToken id="7F6109F4A652540214F1E50B2D956B95" originalValue="häufig" pageId="null" pageNumber="11">haeufig</normalizedToken>
trifft man in 
<normalizedToken id="C7F9FC32914A2FA0B932A8A2681555BF" originalValue="Gärten" pageId="null" pageNumber="11">Gaerten</normalizedToken>
auch die Art 
<taxonomicName id="442224B913D9D94DDF2B95CA245FA38F" authority="Lindl." authorityName="Lindl." class="Magnoliopsida" family="Oleaceae" genus="Forsythia" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="11" phylum="Tracheophyta" rank="species" species="viridissima">
<emphasis id="D53F40AA34FED5E39F3A5B6ADC841159" italics="true" pageId="null" pageNumber="11">F. viridissima</emphasis>
Lindl.
</taxonomicName>
mit aufrechten 
<normalizedToken id="B7FBCEC5464467E715D6FE7157DCBDB7" originalValue="Ästen" pageId="null" pageNumber="11">Aesten</normalizedToken>
und ungeteilten, oft ganzrandigen 
<normalizedToken id="284943A51E5ED968F1E276637027CFFF" originalValue="Blättern" pageId="null" pageNumber="11">Blaettern</normalizedToken>
sowie den Bastard (
<taxonomicName id="E6E5A331E41EB9E6E8D3B1C92CA11136" authority="Zabel" authorityName="Zabel" class="Magnoliopsida" family="Oleaceae" genus="Forsythia" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="11" phylum="Tracheophyta" rank="species" species="intermedia">
<emphasis id="80C34846994BE32C4DB7FBDAA0214788" italics="true" pageId="null" pageNumber="11">F. intermedia</emphasis>
Zabel
</taxonomicName>
) zwischen 
<taxonomicName id="1C17E6174A04C460DF52E2D3C09F54A3" class="Magnoliopsida" family="Oleaceae" genus="Forsythia" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="11" phylum="Tracheophyta" rank="species" species="suspensa">
<emphasis id="99D118D2E2AE66A760EC6CC51FC10F79" italics="true" pageId="null" pageNumber="11">F. suspensa</emphasis>
</taxonomicName>
und 
<taxonomicName id="0DD22D7533B2DB25B89E9ED5053A924E" class="Magnoliopsida" family="Oleaceae" genus="Forsythia" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="11" phylum="Tracheophyta" rank="species" species="viridissima">
<emphasis id="EB2922EF976D46311D14193AED273E0D" italics="true" pageId="null" pageNumber="11">F. viridissima</emphasis>
</taxonomicName>
.
</paragraph>
</subSubSection>
