Schwimmende 
<taxonomicName id="B255DBE6BA4B3A9E817237D5F62DC9CE" class="Liliopsida" family="Alismataceae" genus="Elisma" higherTaxonomySource="GBIF" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="215" phylum="Tracheophyta" rank="genus">Elisma</taxonomicName>
