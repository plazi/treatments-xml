<subSubSection id="B226BF2E692CF63D2E9E0FB376488C0B" pageId="null" pageNumber="146" type="description">
<paragraph id="C1485F5E158A1A269869E8E0BEDEDE10" pageId="null" pageNumber="146">
Wie 
<taxonomicName id="5FFF536ABF8E162E7A3A32FCCB7BDC08" class="Magnoliopsida" family="Lamiaceae" genus="Origanum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="146" phylum="Tracheophyta" rank="genus">
<emphasis id="E76722D5EEC81189BD6F9A368BC6AA0A" italics="true" pageId="null" pageNumber="146">Origanum</emphasis>
</taxonomicName>
(S. 144), 
<emphasis id="F5D813FC6398DAED4D80C2933C2FB04D" italics="true" pageId="null" pageNumber="146">
der Kelch jedoch auf eine kurz 3 
<normalizedToken id="5F25FDFB0871F49AE8046F5E99522658" originalValue="zähnige" pageId="null" pageNumber="146">zaehnige</normalizedToken>
oder fast ganzrandige Oberlippe reduziert.
</emphasis>
</paragraph>
<paragraph id="D7A6E6BCB5407A05F0CBDA90F82C3F36" pageId="null" pageNumber="146">
Die Gattung 
<emphasis id="148D086E5E85D40301242778BA2308D0" italics="true" pageId="null" pageNumber="146">
<taxonomicName id="3F135BA33EC81CB80096422C9D4580A8" class="Magnoliopsida" family="Lamiaceae" genus="Majorana" higherTaxonomySource="GBIF" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="146" phylum="Tracheophyta" rank="genus">Majorana</taxonomicName>
<normalizedToken id="E37F4DDBE66D48AE549B6B785A60989B" originalValue="umfaßt" pageId="null" pageNumber="146">umfasst</normalizedToken>
etwa 8 meist ostmediterrane Arten
</emphasis>
und sollte wohl mit der Gattung 
<taxonomicName id="F81DDE3FE31FA6D01C162755DBBDE671" class="Magnoliopsida" family="Lamiaceae" genus="Origanum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="146" phylum="Tracheophyta" rank="genus">
<emphasis id="33A2F4C3DD450D367AA4422D18A7814F" italics="true" pageId="null" pageNumber="146">Origanum</emphasis>
</taxonomicName>
vereinigt werden; es treten Gattungsbastarde mit der Gattung 
<taxonomicName id="AD996A099F4E14F5AF0527624B0C2063" class="Magnoliopsida" family="Lamiaceae" genus="Origanum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="146" phylum="Tracheophyta" rank="genus">
<emphasis id="AEC6E0A577B41B610F28D1EBC5D9E64F" italics="true" pageId="null" pageNumber="146">Origanum</emphasis>
</taxonomicName>
auf.
</paragraph>
