<subSubSection id="BAAC4A65B9E25767254D390C346E1B27" pageId="null" pageNumber="839" type="description">
<paragraph id="752181BB9CBABD681A19A52C72C709E4" pageId="null" pageNumber="839">
<emphasis id="24E15620D591E7FAB6E6F67EE8298E22" italics="true" pageId="null" pageNumber="839">
Pflanzen binsenartig. 
<normalizedToken id="0FBAC3D9596568C3E1F7C729F4723F88" originalValue="Blätter" pageId="null" pageNumber="839">Blaetter</normalizedToken>
dem Stengel anliegend
</emphasis>
, ohne 
<normalizedToken id="2C7352BEE08A383DC5749345D2EC4D4D" originalValue="Nebenblätter" pageId="null" pageNumber="839">Nebenblaetter</normalizedToken>
; 
<normalizedToken id="F67EB6E3A49D5423D0A296C04710F575" originalValue="Kelchblätter" pageId="null" pageNumber="839">Kelchblaetter</normalizedToken>
4, frei, spitz, krautig, mit 
<normalizedToken id="4D81ED9A14DEF30C6018A7D2A717BC15" originalValue="häutigem" pageId="null" pageNumber="839">haeutigem</normalizedToken>
Rand. 
<normalizedToken id="FCCA10B33217DEE501BFC3F98F3D1D5E" originalValue="Kronblätter" pageId="null" pageNumber="839">Kronblaetter</normalizedToken>
4, ganzrandig oder kurz 2 
<normalizedToken id="2234B42070934C39589B03B249C13D95" originalValue="zähnig" pageId="null" pageNumber="839">zaehnig</normalizedToken>
, kurz gestielt, 
<normalizedToken id="6F14445193E790865BBA2F8BA10AAA3A" originalValue="weiß" pageId="null" pageNumber="839">weiss</normalizedToken>
. 
<normalizedToken id="291D85FDF5786DFE0ABA3F35628397F7" originalValue="Staubblätter" pageId="null" pageNumber="839">Staubblaetter</normalizedToken>
2-8. 
<emphasis id="E4690A2B0C034778B9CAA1B1520B2929" italics="true" pageId="null" pageNumber="839">
Griffel 2. Kapsel flach, 
<normalizedToken id="2B0C23A6D79B7379C61E4BBFAF133115" originalValue="linsenförmig" pageId="null" pageNumber="839">linsenfoermig</normalizedToken>
</emphasis>
(bei den andern Gattungen des Gebietes 
<normalizedToken id="A9DDAD360ADD1183DB253030B5C19818" originalValue="±" pageId="null" pageNumber="839">+/-</normalizedToken>
zylindrisch bis 
<normalizedToken id="055EBA4B674C392EF011F3BBB7B7FD66" originalValue="kegelförmig" pageId="null" pageNumber="839">kegelfoermig</normalizedToken>
), 
<emphasis id="2CF21DF0C81316A4CC6D64788153732D" italics="true" pageId="null" pageNumber="839">
sich mit 2 Klappen 
<normalizedToken id="DDBD8E2FC3B08C8931E07B2BC1873A28" originalValue="öffnend" pageId="null" pageNumber="839">oeffnend</normalizedToken>
</emphasis>
, 1-2samig. Samen 
<normalizedToken id="09F00C47A22C3F73C04C72EC139E31F8" originalValue="hufeisenförmig" pageId="null" pageNumber="839">hufeisenfoermig</normalizedToken>
, dunkel.
</paragraph>
<paragraph id="044F245AA2F3836648F2D1EA1B8A4BD3" pageId="null" pageNumber="839">
Die Gattung 
<emphasis id="A33289663272800E8C461450DE98AD60" italics="true" pageId="null" pageNumber="839">
<taxonomicName id="095F8CBFBD04049C4D970886239E59C9" class="Magnoliopsida" family="Caryophyllaceae" genus="Buffonia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="839" phylum="Tracheophyta" rank="genus">Buffonia</taxonomicName>
<normalizedToken id="6669F25F41DCF0853EC2D2582F04275F" originalValue="umfaβt" pageId="null" pageNumber="839">umfaβt</normalizedToken>
etwa 15 Arten und hat ihre Hauptverbreitung im 
<normalizedToken id="CB7EADB4A5ECCA8D8587F8C0A03B8055" originalValue="östlichen" pageId="null" pageNumber="839">oestlichen</normalizedToken>
Mittelmeergebiet
</emphasis>
.
</paragraph>
</subSubSection>
