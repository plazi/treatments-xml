<subSubSection id="F1DA4EF765662C20D545436BA66DC49E" pageId="null" pageNumber="232" type="description">
<paragraph id="3AD9F5D3CEE74C458EDA99CF1D5555F7" pageId="null" pageNumber="232">
<emphasis id="CACA32559FC8D16E822E44192FF6E3D2" italics="true" pageId="null" pageNumber="232">Meist ausdauernd</emphasis>
, mit 
<normalizedToken id="E0E5B1CF7344BEDAAD2611FF766D21A4" originalValue="dünnen" pageId="null" pageNumber="232">duennen</normalizedToken>
, kurzen unterirdischen Stengeln und Blattrosetten; 10-35 cm hoch. Stengel aufsteigend oder aufrecht, meist unverzweigt, mit kurz gestielten, 2-4strahligen Haaren. 
<normalizedToken id="EA50B78EEE780B540BE37D82BC9F7EF6" originalValue="Grundständige" pageId="null" pageNumber="232">Grundstaendige</normalizedToken>
<normalizedToken id="BC36A6329636AE6A803AA3CAC59F1F3E" originalValue="Blätter" pageId="null" pageNumber="232">Blaetter</normalizedToken>
in einen kurzen Stiel 
<normalizedToken id="1C1EEED5D2F44CE4A2F98CD88C1B5FB9" originalValue="verschmälert" pageId="null" pageNumber="232">verschmaelert</normalizedToken>
, oval, ganzrandig oder entfernt 
<normalizedToken id="D9571F98B8FAFC00C66F33CEBB6727D5" originalValue="gezähnt" pageId="null" pageNumber="232">gezaehnt</normalizedToken>
, beiderseits mit 2-4strahligen Haaren; am Blattstiel auch mit 1fachen Haaren; 
<emphasis id="6DB69D7E2FE84F1C191377CA360A80F8" italics="true" pageId="null" pageNumber="232">
<normalizedToken id="F7036FBE8227E7C226455B9B7FD9FAB9" originalValue="Stengelblätter" pageId="null" pageNumber="232">Stengelblaetter</normalizedToken>
3-8, mit 
<normalizedToken id="5DC564DD31EF0C48EA81C0D1CB0730E9" originalValue="verschmälertem" pageId="null" pageNumber="232">verschmaelertem</normalizedToken>
Grunde sitzend.
</emphasis>
<normalizedToken id="A958C4422EE05D7A4F7D18EA38BA60E3" originalValue="Blütenstand" pageId="null" pageNumber="232">Bluetenstand</normalizedToken>
4-15 
<normalizedToken id="D471B11A2C6C9FF02C115D9A97075C12" originalValue="blütig" pageId="null" pageNumber="232">bluetig</normalizedToken>
, nach der 
<normalizedToken id="F07F5DBAE68CB220D2E2FF7B876A4DAD" originalValue="Blüte" pageId="null" pageNumber="232">Bluete</normalizedToken>
<normalizedToken id="099630D69770343FD21A60958212B9FE" originalValue="verlängert" pageId="null" pageNumber="232">verlaengert</normalizedToken>
. 
<normalizedToken id="07C40838BE311B6FC5CCDE979BA8D5CD" originalValue="Kelchblätter" pageId="null" pageNumber="232">Kelchblaetter</normalizedToken>
2,5-3 mm lang, gegen die Spitze meist mit einzelnen 2-4strahligen Haaren. 
<normalizedToken id="BE01D6CA9BB965FA05AE66A94C50D4B7" originalValue="Kronblätter" pageId="null" pageNumber="232">Kronblaetter</normalizedToken>
5-5,5 mm lang, 
<normalizedToken id="7228F62E78576A7086530B36B826158C" originalValue="weiß" pageId="null" pageNumber="232">weiss</normalizedToken>
. Fruchtstiele aufrecht abstehend, 1/7-⅕ so lang wie die 
<normalizedToken id="6C95A631D9C5C7F47D111A0F22652402" originalValue="Früchte" pageId="null" pageNumber="232">Fruechte</normalizedToken>
, kahl. 
<normalizedToken id="89655EBB4E88D2183539BFCC45F35F4C" originalValue="Früchte" pageId="null" pageNumber="232">Fruechte</normalizedToken>
oft nach oben abgewinkelt, 20-30 mm lang und 0,8-1,1 mm breit, kahl; jedes Fruchtblatt mit 
<normalizedToken id="586BCB2F58F76F070C555B4B4722B569" originalValue="±" pageId="null" pageNumber="232">+/-</normalizedToken>
deutlichem Mittelnerv und undeutlichen Seitennerven; Griffel 0,5-1 mm lang. Samen 1-1,2 mm lang, 
<emphasis id="1462804F5159C2E2BA8342B1D3B54B48" italics="true" pageId="null" pageNumber="232">
ohne 
<normalizedToken id="9CE1C008CBD1AF92E333E14DCF9319FA" originalValue="flügelförmigen" pageId="null" pageNumber="232">fluegelfoermigen</normalizedToken>
Rand.
</emphasis>
- 
<normalizedToken id="AA22E8C72C17246E69CDC43B9DBA81A0" originalValue="Blüte" pageId="null" pageNumber="232">Bluete</normalizedToken>
: 
<normalizedToken id="A4A280469640757A2D1661B6AE5092D4" originalValue="Früher" pageId="null" pageNumber="232">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="E62123DA58F776239B4C256B7BE257A5" pageId="null" pageNumber="232">
<emphasis id="AC9C0AC04301DFB10857923D8B36B578" italics="true" pageId="null" pageNumber="232">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B32930F512E79FDBCE86184E524F9966" italics="true" pageId="null" pageNumber="232">16:</emphasis>
Material aus dem Jura (La 
<normalizedToken id="37F1B3875516083D09B29441246200D9" originalValue="Dôle" pageId="null" pageNumber="232">Dole</normalizedToken>
) (Favarger und Huynh in 
<normalizedToken id="3197617A91E87B8A2BC24AFB61FB188B" originalValue="Löve" pageId="null" pageNumber="232">Loeve</normalizedToken>
und Solbrig 1964Favarger und Huynh in 
<normalizedToken id="99D506AEA24C21C8C0EB9B71358B1C31" originalValue="Löve" pageId="null" pageNumber="232">Loeve</normalizedToken>
und Solbrig 1964a, Favarger 1965, 
<normalizedToken id="FE19805B5F0A60F079238E2F1612D966" originalValue="Bürdet" pageId="null" pageNumber="232">Buerdet</normalizedToken>
1967), aus botanischem Garten und vom Berner Oberland (Kandersteg) (
<normalizedToken id="FA673D08A3E053B1F3A6E0A922ADB8A2" originalValue="Bürdet" pageId="null" pageNumber="232">Buerdet</normalizedToken>
1967).
</paragraph>
<paragraph id="DDDA6428CCEC3C4BD87F28992B2BF758" pageId="null" pageNumber="232">
<emphasis id="7B7583B56A28FDA2837931E2E3064E8C" italics="true" pageId="null" pageNumber="232">Standort.</emphasis>
Montan, subalpin und alpin. Ziemlich feuchte, steinige, kalkreiche 
<normalizedToken id="15294C70E1DDF912E2E9C7C34D4D9969" originalValue="Böden" pageId="null" pageNumber="232">Boeden</normalizedToken>
. Felsschutt, Felsspalten.
</paragraph>
<paragraph id="623F97A320624BA7342FB054E96B2FB6" pageId="null" pageNumber="232">
<emphasis id="ED8EAB91408949ADF6EBBF9C89D09032" italics="true" pageId="null" pageNumber="232">
Verbreitung. 
<normalizedToken id="6B2575EA4D8643CEC7388DB006EEA732" originalValue="Alpin-pyrenäische" pageId="null" pageNumber="232">Alpin-pyrenaeische</normalizedToken>
Pflanze:
</emphasis>
Valencia (?), 
<normalizedToken id="30563DECDC3D1533CE7589B0320C7606" originalValue="Pyrenäen" pageId="null" pageNumber="232">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="AC4C22113F39B649215BD98D84D92009" originalValue="südlicher" pageId="null" pageNumber="232">suedlicher</normalizedToken>
Jura, Alpen (
<normalizedToken id="9A928F7385C11434B185B4FA0BDA6A5A" originalValue="ostwärts" pageId="null" pageNumber="232">ostwaerts</normalizedToken>
bis Schwyz und Venetien). Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: 
<normalizedToken id="AC39C3354BCCB9116F8FAFE6F2FC8BA6" originalValue="Südlicher" pageId="null" pageNumber="232">Suedlicher</normalizedToken>
Jura (
<normalizedToken id="8F8A50AB9DC2657CDA7CB75FECF6C17B" originalValue="nordostwärts" pageId="null" pageNumber="232">nordostwaerts</normalizedToken>
bis Les Rousses und Gimel [Waadt]), westliche Nordalpen mit Vorland (
<normalizedToken id="915F9912D8539812800F59CD6750810E" originalValue="ostwrärts" pageId="null" pageNumber="232">ostwraerts</normalizedToken>
bis zum 
<normalizedToken id="8EA61C0179D123DDE12F51CE1E22417C" originalValue="Wägital" pageId="null" pageNumber="232">Waegital</normalizedToken>
), Zentralalpen (
<normalizedToken id="8F9E89F54FCE62D8C4A231382BEECDD2" originalValue="Großer" pageId="null" pageNumber="232">Grosser</normalizedToken>
St. Bernhard), 
<normalizedToken id="31C88C9148F9460441A077FE232CC577" originalValue="Südalpen" pageId="null" pageNumber="232">Suedalpen</normalizedToken>
(Kette der Denti della Vecchia, Bergamasker Alpen [z. B. Presolana, Rovetta]), zerstreut, nicht 
<normalizedToken id="F8B74A8B786980BFB31258F8185B71CB" originalValue="häufig" pageId="null" pageNumber="232">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
