, fig. 17), 
<specimenCount id="F1DEE7A14757F5AB6363003EB8A78E59" type="generic" typeStatus="paratypes">6 paratypes</specimenCount>
of 
<taxonomicName id="72C93ADD970DF98FBAA75AD67E8D43AE" genus="Ot." lsidName="Ot. schattenbergi" pageId="0" pageNumber="51" rank="species" species="schattenbergi">
