<taxonomicName id="4C6D4D5EED7E381AFE6AF9ADFDE2F9BC" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[431,551,1635,1661]" class="Maxillopoda" family="Notodelphyidae" genus="Gallincola" kingdom="Animalia" order="Cyclopoida" pageId="559" pageNumber="560" phylum="Arthropoda" rank="genus" status="gen. nov.">
<emphasis id="B919EACFED7E381AFE6AF9ADFDE2F9BC" box="[431,551,1635,1661]" italics="true" pageId="559" pageNumber="560">Gallincola</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A22A57B4ED7E381AFDF7F9AAFD65F9BF" box="[562,672,1636,1662]" pageId="559" pageNumber="560" rank="genus">
<emphasis id="B919EACFED7E381AFDF7F9AAFD5EF9BF" bold="true" box="[562,667,1636,1662]" pageId="559" pageNumber="560">gen. nov</emphasis>
.
