<taxonomicName id="4C6D4D5EED7E381AFF4DF98FFEC5F99A" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[136,256,1601,1627]" class="Maxillopoda" family="Notodelphyidae" genus="Gallincola" kingdom="Animalia" order="Cyclopoida" pageId="559" pageNumber="560" phylum="Arthropoda" rank="genus" status="gen. nov.">
