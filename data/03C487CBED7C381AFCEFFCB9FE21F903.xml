</taxonomicName>
<taxonomicNameLabel id="A22A57B4ED7E381AFEC8F98CFEB9F99D" box="[269,380,1602,1628]" pageId="559" pageNumber="560" rank="genus">
<emphasis id="B919EACFED7E381AFEC8F98CFEB3F99D" bold="true" box="[269,374,1602,1628]" pageId="559" pageNumber="560">gen. nov</emphasis>
.
