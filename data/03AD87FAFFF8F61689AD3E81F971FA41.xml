<emphasis id="B970EAFEFFF8F6168A113F5BFC0EF4F3" bold="true" box="[783,939,2887,2920]" pageId="60" pageNumber="118">Taxonomy.</emphasis>
<taxonomicName id="4C044D6FFFF8F6168AA43F5BFAFAF4F3" authority="Irwin, 2017" authorityName="Irwin" authorityYear="2017" box="[954,1375,2887,2920]" class="Mammalia" family="Pteropodidae" genus="Nyctimene" kingdom="Animalia" order="Chiroptera" pageId="60" pageNumber="118" phylum="Chordata" rank="species" species="wrightae">Nyctimene wrightae Irwin, 2017</taxonomicName>
, 
<materialsCitation id="3B6C3CB1FFF8F6168A0F3F6FFBC2F444" pageId="60" pageNumber="118">
“Namosado (
<geoCoordinate id="EE30502BFFF8F6168AC43F6FFBE0F40B" box="[986,1093,2931,2960]" degrees="06" direction="south" minutes="15" orientation="latitude" pageId="60" pageNumber="118" precision="925" value="-6.25">06°15’S</geoCoordinate>
