, 
<quantity id="4CFC9B09FFF8F6168DE13F6FFAC1F40B" box="[1279,1380,2931,2960]" metricMagnitude="2" metricUnit="m" metricValue="5.0" pageId="60" pageNumber="118" unit="m" value="500.0">500 m</quantity>
