<taxonomicName id="4C6A4D06FFC0FFD6FB2BFC12BA99CB1E" authority="Kakish." authorityName="Kakish." box="[1162,1452,1022,1048]" class="Pucciniomycetes" family="Pucciniaceae" genus="Puccinia" kingdom="Fungi" order="Pucciniales" pageId="19" pageNumber="240" phylum="Basidiomycota" rank="species" species="kawakamiensis">
