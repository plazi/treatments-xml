<taxonomicName id="4C234D23FF9EF815FF13FAB4DD0C9269" authority="(Janson, 1907)" baseAuthorityName="Janson" baseAuthorityYear="1907" box="[151,596,1302,1329]" class="Insecta" family="Cetoniidae" genus="Oxythyrea" kingdom="Animalia" order="Coleoptera" pageId="27" pageNumber="178" phylum="Arthropoda" rank="species" species="scintillans">
<emphasis id="B957EAB2FF9EF815FF13FAB4DD0C9269" bold="true" box="[151,596,1302,1329]" pageId="27" pageNumber="178">
<emphasis id="B957EAB2FF9EF815FF13FAB4DEC09268" bold="true" box="[151,408,1302,1329]" italics="true" pageId="27" pageNumber="178">Oxythyrea scintillans</emphasis>
