<bibRefCitation author="Moczar, L." pageId="7" pageNumber="8" pagination="25 - 44" refId="ref59165" refString="Moczar, L. (1997) Revision of the Cleptes nitidulus group of the world (Hymenoptera, Chrysididae, Cleptinae). Entomofauna, 18, 25 - 44." type="journal article" year="1997">Móczár 1997</bibRefCitation>
