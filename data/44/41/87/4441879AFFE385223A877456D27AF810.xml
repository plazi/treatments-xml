<taxonomicName authorityName="Kishida &amp; Wang" authorityYear="2017" box="[652,778,1957,1983]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="miranda">
