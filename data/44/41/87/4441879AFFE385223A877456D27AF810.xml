<collectingCountry box="[675,742,1921,1947]" name="China" pageId="3" pageNumber="81">China</collectingCountry>
(
<collectingRegion box="[758,996,1921,1947]" country="China" name="Guangdong" pageId="3" pageNumber="81">Guangdong Province</collectingRegion>
and 
<collectingRegion box="[1050,1239,1921,1947]" country="China" name="Guangxi" pageId="3" pageNumber="81">Guangxi Zhuang</collectingRegion>
Autonomous Region) (
<bibRefCitation author="Mell, R." box="[225,346,1957,1984]" pageId="3" pageNumber="81" pagination="113 - 129" refId="ref4119" refString="Mell, R. (1922) Neue sudchinesische Lepidoptera. Deutsche entomologische Zeitschrift, 1922, 113 - 129. [in German]" type="journal article" year="1922">Mell 1922</bibRefCitation>
