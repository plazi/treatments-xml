<emphasis box="[844,967,941,967]" italics="true" pageId="2" pageNumber="80">B. pardalis</emphasis>
</taxonomicName>
(
<figureCitation box="[981,1095,941,967]" captionStart="FIGURES 9–16" captionStartId="5.[151,264,1891,1915]" captionTargetBox="[164,1422,193,1850]" captionTargetId="figure-25@5.[155,1432,181,1867]" captionTargetPageId="5" captionText="FIGURES 9–16. Adults of Barsine spp. Depositories of the specimens: 9, 10 in MfN; 11 in SCAU; 12–16 in MWM/ZSM." figureDoi="http://doi.org/10.5281/zenodo.6796815" httpUri="https://zenodo.org/record/6796815/files/figure.png" pageId="2" pageNumber="80">Figs 9, 10</figureCitation>
, 
<figureCitation box="[1106,1136,941,967]" captionStart="FIGURES 17–20" captionStartId="6.[151,264,1845,1869]" captionTargetBox="[165,1423,190,1807]" captionTargetId="figure-19@6.[155,1432,181,1821]" captionTargetPageId="6" captionText="FIGURES 17–20. Male genitalia of Barsine spp. Depositories of the slides: 17 in SCAU; 18 in CHSY; 19 in MfN; 20 in MWM/ ZSM." figureDoi="http://doi.org/10.5281/zenodo.6796819" httpUri="https://zenodo.org/record/6796819/files/figure.png" pageId="2" pageNumber="80">19</figureCitation>
, 
<figureCitation box="[1148,1220,941,967]" captionStart="FIGURES 21–27" captionStartId="7.[151,264,1584,1608]" captionTargetBox="[164,1423,187,1547]" captionTargetId="figure-25@7.[161,1427,181,1560]" captionTargetPageId="7" captionText="FIGURES 21–27. Female genitalia of Barsine spp. Depositories of the slides: 21 in SCAU; 22 in CHSY; 23 in MfN; 24 in the private collection of Yasunori Kishida; 25 in ZFMK; 26, 27 in MWM/ZSM." figureDoi="http://doi.org/10.5281/zenodo.6796821" httpUri="https://zenodo.org/record/6796821/files/figure.png" pageId="2" pageNumber="80">23, 24</figureCitation>
), 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[1240,1345,941,967]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[1240,1345,941,967]" italics="true" pageId="2" pageNumber="80">B. hoenei</emphasis>
</taxonomicName>
(
<figureCitation captionStart="FIGURES 1–8" captionStartId="4.[151,264,1763,1787]" captionTargetBox="[158,1429,189,1730]" captionTargetId="figure-19@4.[151,1437,181,1739]" captionTargetPageId="4" captionText="FIGURES 1–8. Adults of Barsine spp. Depositories of the specimens: 1, 3 in SCAU; 2, 4–6 in CHSY; 7 in ZFMK; 8 in MWM/ ZSM." figureDoi="http://doi.org/10.5281/zenodo.6796813" httpUri="https://zenodo.org/record/6796813/files/figure.png" pageId="2" pageNumber="80">Figs 7, 8</figureCitation>
, 
<figureCitation box="[180,251,977,1004]" captionStart="FIGURES 21–27" captionStartId="7.[151,264,1584,1608]" captionTargetBox="[164,1423,187,1547]" captionTargetId="figure-25@7.[161,1427,181,1560]" captionTargetPageId="7" captionText="FIGURES 21–27. Female genitalia of Barsine spp. Depositories of the slides: 21 in SCAU; 22 in CHSY; 23 in MfN; 24 in the private collection of Yasunori Kishida; 25 in ZFMK; 26, 27 in MWM/ZSM." figureDoi="http://doi.org/10.5281/zenodo.6796821" httpUri="https://zenodo.org/record/6796821/files/figure.png" pageId="2" pageNumber="80">25, 26</figureCitation>
) and 
<taxonomicName baseAuthorityName="Walker" baseAuthorityYear="1864" box="[316,430,978,1003]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="roseata">
<emphasis box="[316,430,978,1003]" italics="true" pageId="2" pageNumber="80">B. roseata</emphasis>
</taxonomicName>
(
<figureCitation box="[446,575,977,1003]" captionStart="FIGURES 9–16" captionStartId="5.[151,264,1891,1915]" captionTargetBox="[164,1422,193,1850]" captionTargetId="figure-25@5.[155,1432,181,1867]" captionTargetPageId="5" captionText="FIGURES 9–16. Adults of Barsine spp. Depositories of the specimens: 9, 10 in MfN; 11 in SCAU; 12–16 in MWM/ZSM." figureDoi="http://doi.org/10.5281/zenodo.6796815" httpUri="https://zenodo.org/record/6796815/files/figure.png" pageId="2" pageNumber="80">Figs 11–16</figureCitation>
, 
<figureCitation box="[587,618,977,1003]" captionStart="FIGURES 17–20" captionStartId="6.[151,264,1845,1869]" captionTargetBox="[165,1423,190,1807]" captionTargetId="figure-19@6.[155,1432,181,1821]" captionTargetPageId="6" captionText="FIGURES 17–20. Male genitalia of Barsine spp. Depositories of the slides: 17 in SCAU; 18 in CHSY; 19 in MfN; 20 in MWM/ ZSM." figureDoi="http://doi.org/10.5281/zenodo.6796819" httpUri="https://zenodo.org/record/6796819/files/figure.png" pageId="2" pageNumber="80">20</figureCitation>
, 
<figureCitation box="[629,658,977,1003]" captionStart="FIGURES 21–27" captionStartId="7.[151,264,1584,1608]" captionTargetBox="[164,1423,187,1547]" captionTargetId="figure-25@7.[161,1427,181,1560]" captionTargetPageId="7" captionText="FIGURES 21–27. Female genitalia of Barsine spp. Depositories of the slides: 21 in SCAU; 22 in CHSY; 23 in MfN; 24 in the private collection of Yasunori Kishida; 25 in ZFMK; 26, 27 in MWM/ZSM." figureDoi="http://doi.org/10.5281/zenodo.6796821" httpUri="https://zenodo.org/record/6796821/files/figure.png" pageId="2" pageNumber="80">27</figureCitation>
) but is distinguished by the combination of the following characters. (1) The dorsal side of the abdomen is thoroughly reddish, similar to 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[912,1035,1012,1038]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[912,1035,1012,1038]" italics="true" pageId="2" pageNumber="80">B. pardalis</emphasis>
</taxonomicName>
and 
<taxonomicName baseAuthorityName="Walker" baseAuthorityYear="1864" box="[1089,1203,1013,1038]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="roseata">
<emphasis box="[1089,1203,1013,1038]" italics="true" pageId="2" pageNumber="80">B. roseata</emphasis>
</taxonomicName>
, while it is bearing a blackish band in 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[341,447,1048,1074]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[341,447,1048,1074]" italics="true" pageId="2" pageNumber="80">B. hoenei</emphasis>
</taxonomicName>
. (2) The forewing is less elongate and slightly broader than in 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[1147,1252,1048,1074]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[1147,1252,1048,1074]" italics="true" pageId="2" pageNumber="80">B. hoenei</emphasis>
</taxonomicName>
and 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[1306,1429,1048,1074]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[1306,1429,1048,1074]" italics="true" pageId="2" pageNumber="80">B. pardalis</emphasis>
</taxonomicName>
, similar to that of 
<taxonomicName baseAuthorityName="Walker" baseAuthorityYear="1864" box="[346,461,1085,1110]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="roseata">
<emphasis box="[346,461,1085,1110]" italics="true" pageId="2" pageNumber="80">B. roseata</emphasis>
</taxonomicName>
. (3) The postmedial band of the forewing is interrupted into two spots at the costa and dorsum (similar to 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[364,469,1120,1146]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[364,469,1120,1146]" italics="true" pageId="2" pageNumber="80">B. hoenei</emphasis>
</taxonomicName>
), while it is interrupted into three spots in 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[942,1065,1120,1146]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[942,1065,1120,1146]" italics="true" pageId="2" pageNumber="80">B. pardalis</emphasis>
</taxonomicName>
and continuous in 
<taxonomicName baseAuthorityName="Walker" baseAuthorityYear="1864" box="[1276,1390,1120,1145]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="roseata">
<emphasis box="[1276,1390,1120,1145]" italics="true" pageId="2" pageNumber="80">B. roseata</emphasis>
</taxonomicName>
. (4) The interior margin of the dull yellowish terminal band of the forewing forms a large, trapezoid protrusion at the middle point of termen, similar to that in 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[606,711,1191,1217]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[606,711,1191,1217]" italics="true" pageId="2" pageNumber="80">B. hoenei</emphasis>
</taxonomicName>
, while the interior margin of the marginal band in 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[1267,1390,1191,1217]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[1267,1390,1191,1217]" italics="true" pageId="2" pageNumber="80">B. pardalis</emphasis>
</taxonomicName>
and 
<taxonomicName baseAuthorityName="Walker" baseAuthorityYear="1864" box="[151,265,1228,1253]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="roseata">
<emphasis box="[151,265,1228,1253]" italics="true" pageId="2" pageNumber="80">B. roseata</emphasis>
</taxonomicName>
is smooth. (5) The marginal band of the hindwing is broad and well-developed, similar to 
<taxonomicName baseAuthorityName="Walker" baseAuthorityYear="1864" box="[1275,1389,1228,1253]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="roseata">
<emphasis box="[1275,1389,1228,1253]" italics="true" pageId="2" pageNumber="80">B. roseata</emphasis>
</taxonomicName>
and 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[151,274,1263,1289]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[151,274,1263,1289]" italics="true" pageId="2" pageNumber="80">B. pardalis</emphasis>
</taxonomicName>
, while the hindwing of 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[543,649,1263,1289]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[543,649,1263,1289]" italics="true" pageId="2" pageNumber="80">B. hoenei</emphasis>
</taxonomicName>
is almost totally pinkish with black diffusion present only at the veins around the apex. (6) In the female genitalia, the ductus bursae is significantly longer than in 
<taxonomicName baseAuthorityName="Walker" baseAuthorityYear="1864" box="[1174,1288,1299,1324]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="roseata">
<emphasis box="[1174,1288,1299,1324]" italics="true" pageId="2" pageNumber="80">B. roseata</emphasis>
</taxonomicName>
, slightly longer than in 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[276,398,1334,1360]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[276,398,1334,1360]" italics="true" pageId="2" pageNumber="80">B. pardalis</emphasis>
</taxonomicName>
and nearly equal in length to that of 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[804,909,1334,1360]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[804,909,1334,1360]" italics="true" pageId="2" pageNumber="80">B. hoenei</emphasis>
</taxonomicName>
. The corpus bursae of the new species is nearly equal in size to that of 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[414,522,1370,1396]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[414,522,1370,1396]" italics="true" pageId="2" pageNumber="80">B. hoenei</emphasis>
</taxonomicName>
, slightly smaller than in 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[806,931,1370,1396]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[806,931,1370,1396]" italics="true" pageId="2" pageNumber="80">B. pardalis</emphasis>
</taxonomicName>
and significantly smaller than in 
<taxonomicName baseAuthorityName="Walker" baseAuthorityYear="1864" box="[1314,1429,1371,1396]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="roseata">
<emphasis box="[1314,1429,1371,1396]" italics="true" pageId="2" pageNumber="80">B. roseata</emphasis>
</taxonomicName>
. The signum bursae of 
<taxonomicName authority="Huang &amp; Volynkin &amp; Fan &amp; Wang, 2022" authorityName="Huang &amp; Volynkin &amp; Fan &amp; Wang" authorityYear="2022" box="[405,529,1405,1431]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="jingkuni" status="sp. n.">
<emphasis box="[405,529,1405,1431]" italics="true" pageId="2" pageNumber="80">B. jingkuni</emphasis>
</taxonomicName>
<emphasis bold="true" box="[536,601,1406,1432]" pageId="2" pageNumber="80">
<taxonomicNameLabel box="[536,601,1406,1432]" pageId="2" pageNumber="80" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
is absent as in 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[775,898,1405,1431]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[775,898,1405,1431]" italics="true" pageId="2" pageNumber="80">B. pardalis</emphasis>
</taxonomicName>
and 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[955,1062,1405,1431]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[955,1062,1405,1431]" italics="true" pageId="2" pageNumber="80">B. hoenei</emphasis>
</taxonomicName>
, while it is present in 
<taxonomicName baseAuthorityName="Walker" baseAuthorityYear="1864" box="[1314,1429,1406,1431]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="80" phylum="Arthropoda" rank="species" species="roseata">
<emphasis box="[1314,1429,1406,1431]" italics="true" pageId="2" pageNumber="80">B. roseata</emphasis>
</taxonomicName>
. The appendix bursae of the new species is smaller and shorter than in the similar congeners.
</paragraph>
</subSubSection>
<subSubSection lastPageId="3" lastPageNumber="81" pageId="2" pageNumber="80" type="description">
<paragraph blockId="2.[151,1437,798,2040]" pageId="2" pageNumber="80">
<emphasis bold="true" box="[199,443,1477,1503]" pageId="2" pageNumber="80">Description. Female</emphasis>
(
<figureCitation box="[462,568,1477,1503]" captionStart="FIGURES 1–8" captionStartId="4.[151,264,1763,1787]" captionTargetBox="[158,1429,189,1730]" captionTargetId="figure-19@4.[151,1437,181,1739]" captionTargetPageId="4" captionText="FIGURES 1–8. Adults of Barsine spp. Depositories of the specimens: 1, 3 in SCAU; 2, 4–6 in CHSY; 7 in ZFMK; 8 in MWM/ ZSM." figureDoi="http://doi.org/10.5281/zenodo.6796813" httpUri="https://zenodo.org/record/6796813/files/figure.png" pageId="2" pageNumber="80">Figs 3–6</figureCitation>
). Forewing length 
<quantity box="[792,917,1477,1504]" metricMagnitude="-2" metricUnit="m" metricValue="2.35" metricValueMax="2.5" metricValueMin="2.2" pageId="2" pageNumber="80" unit="mm" value="23.5" valueMax="25.0" valueMin="22.0">22–25 mm</quantity>
(n= 
<quantity box="[968,1082,1477,1504]" metricMagnitude="-3" metricUnit="m" metricValue="4.25" pageId="2" pageNumber="80" unit="mm" value="4.25">4, 25 mm</quantity>
in 
<typeStatus box="[1125,1228,1477,1503]" pageId="2" pageNumber="80">holotype</typeStatus>
). Antenna weakly ciliate. Head and patagia covered with reddish hair-like scales. Thorax brownish dorsally, tegulum brownish, surrounded by reddish hair-like scales. Abdomen covered with reddish hair-like scales thoroughly. Forewing ground color brownish-grey, pattern dull yellow. Basal band interrupted into two spots positioned at costa and dorsum. Antemedial band interrupted into two spots positioned at costa and below cell. Medial band interrupted into three spots positioned at costa, at lower angle of cell, and above dorsum. Postmedial band interrupted into narrow spot at dorsum and larger spot at costa fused with marginal band. Marginal band interrupted into triangular spot at distal end of cell Cu 
<subScript attach="left" box="[307,315,1746,1760]" fontSize="6" pageId="2" pageNumber="80">1</subScript>
and large fore spot extending from apex to middle of termen and forming large, trapezoid protrusion posteriorly. Forewing cilia brownish. Hindwing crimson with broad brownish-grey marginal band gradually tapering from apex to anal angle, and crimson suffusion in subapical area. Hindwing cilia brownish.
</paragraph>
<paragraph blockId="2.[151,1437,798,2040]" pageId="2" pageNumber="80">
<emphasis bold="true" box="[199,411,1834,1860]" pageId="2" pageNumber="80">Genitalia. Female</emphasis>
(
<figureCitation box="[426,558,1834,1860]" captionStart="FIGURES 21–27" captionStartId="7.[151,264,1584,1608]" captionTargetBox="[164,1423,187,1547]" captionTargetId="figure-25@7.[161,1427,181,1560]" captionTargetPageId="7" captionText="FIGURES 21–27. Female genitalia of Barsine spp. Depositories of the slides: 21 in SCAU; 22 in CHSY; 23 in MfN; 24 in the private collection of Yasunori Kishida; 25 in ZFMK; 26, 27 in MWM/ZSM." figureDoi="http://doi.org/10.5281/zenodo.6796821" httpUri="https://zenodo.org/record/6796821/files/figure.png" pageId="2" pageNumber="80">Figs 21, 22</figureCitation>
). Papilla analis rectangular with rounded corners. Apophyses moderately long and slender, apophysis posterioris longer than apophysis anterioris. Ductus bursae sclerotized, long and broad, dorso-ventrally flattened, with somewhat dilated posterior half bearing several lengthwise folds, and membranous anterior end. Corpus bursae moderately large, globular with sclerotized posterior section scattered with small cluster of spinulose scobination. Basal section of appendix bursae sclerotized. Appendix bursae short with broad, heavily sclerotized and granulose basal section and narrow conical membranous distal section.
</paragraph>
<paragraph blockId="3.[151,1436,151,645]" box="[199,376,151,177]" pageId="3" pageNumber="81">Male unknown.</paragraph>
</subSubSection>
<subSubSection box="[199,1080,186,213]" pageId="3" pageNumber="81" type="distribution">
<paragraph blockId="3.[151,1436,151,645]" box="[199,1080,186,213]" pageId="3" pageNumber="81">
<emphasis bold="true" box="[199,353,186,212]" pageId="3" pageNumber="81">Distribution.</emphasis>
Currently only known from 
<collectingRegion box="[675,872,187,213]" country="China" name="Sichuan" pageId="3" pageNumber="81">Sichuan Province</collectingRegion>
in Western 
<collectingCountry box="[1005,1076,187,213]" name="China" pageId="3" pageNumber="81">China</collectingCountry>
.
</paragraph>
</subSubSection>
<subSubSection pageId="3" pageNumber="81" type="etymology">
<paragraph blockId="3.[151,1436,151,645]" pageId="3" pageNumber="81">
<emphasis bold="true" box="[199,334,223,249]" pageId="3" pageNumber="81">Etymology.</emphasis>
The new species is dedicated to Mr. Jing-kun Zhang, a friend of the first author and collector of the 
<typeStatus box="[192,303,259,285]" pageId="3" pageNumber="81">paratypes</typeStatus>
.
</paragraph>
</subSubSection>
<subSubSection pageId="3" pageNumber="81" type="discussion">
<paragraph blockId="3.[151,1436,151,645]" pageId="3" pageNumber="81">
<emphasis bold="true" box="[199,315,295,321]" pageId="3" pageNumber="81">Remarks.</emphasis>
(1) The wing pattern of 
<taxonomicName authority="Huang &amp; Volynkin &amp; Fan &amp; Wang, 2022" authorityName="Huang &amp; Volynkin &amp; Fan &amp; Wang" authorityYear="2022" box="[594,717,295,321]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="jingkuni" status="sp. n.">
<emphasis box="[594,717,295,321]" italics="true" pageId="3" pageNumber="81">B. jingkuni</emphasis>
</taxonomicName>
<emphasis bold="true" box="[725,789,295,321]" pageId="3" pageNumber="81">
<taxonomicNameLabel box="[725,789,295,321]" pageId="3" pageNumber="81" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
displays a mixture of characters from both 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[1282,1389,295,321]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[1282,1389,295,321]" italics="true" pageId="3" pageNumber="81">B. hoenei</emphasis>
</taxonomicName>
and 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[151,275,331,357]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[151,275,331,357]" italics="true" pageId="3" pageNumber="81">B. pardalis</emphasis>
</taxonomicName>
, namely a 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[401,476,331,357]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[401,476,331,357]" italics="true" pageId="3" pageNumber="81">hoenei</emphasis>
</taxonomicName>
-like forewing and a 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[713,805,331,357]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[713,805,331,357]" italics="true" pageId="3" pageNumber="81">pardalis</emphasis>
</taxonomicName>
-like hindwing. However, since neither 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[1252,1359,331,357]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[1252,1359,331,357]" italics="true" pageId="3" pageNumber="81">B. hoenei</emphasis>
</taxonomicName>
nor 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis italics="true" pageId="3" pageNumber="81">B. pardalis</emphasis>
</taxonomicName>
were found in 
<collectingRegion box="[410,608,367,393]" country="China" name="Sichuan" pageId="3" pageNumber="81">Sichuan Province</collectingRegion>
, 
<taxonomicName authority="Huang &amp; Volynkin &amp; Fan &amp; Wang, 2022" authorityName="Huang &amp; Volynkin &amp; Fan &amp; Wang" authorityYear="2022" box="[619,741,367,393]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="jingkuni" status="sp. n.">
<emphasis box="[619,741,367,393]" italics="true" pageId="3" pageNumber="81">B. jingkuni</emphasis>
</taxonomicName>
<emphasis bold="true" box="[747,809,367,393]" pageId="3" pageNumber="81">
<taxonomicNameLabel box="[747,809,367,393]" pageId="3" pageNumber="81" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
is considered here as a distinct species and not the result of hybridization between them. (2) In the female genitalia of 
<taxonomicName authority="Huang &amp; Volynkin &amp; Fan &amp; Wang, 2022" authorityName="Huang &amp; Volynkin &amp; Fan &amp; Wang" authorityYear="2022" box="[827,949,403,429]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="jingkuni" status="sp. n.">
<emphasis box="[827,949,403,429]" italics="true" pageId="3" pageNumber="81">B. jingkuni</emphasis>
</taxonomicName>
<emphasis bold="true" box="[955,1017,403,429]" pageId="3" pageNumber="81">
<taxonomicNameLabel box="[955,1017,403,429]" pageId="3" pageNumber="81" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
, 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[1030,1152,403,429]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[1030,1152,403,429]" italics="true" pageId="3" pageNumber="81">B. pardalis</emphasis>
</taxonomicName>
and 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[1205,1310,403,429]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[1205,1310,403,429]" italics="true" pageId="3" pageNumber="81">B. hoenei</emphasis>
</taxonomicName>
, the size of the appendix bursae is somewhat variable (
<figureCitation box="[629,714,439,465]" captionStart="FIGURES 21–27" captionStartId="7.[151,264,1584,1608]" captionTargetBox="[164,1423,187,1547]" captionTargetId="figure-25@7.[161,1427,181,1560]" captionTargetPageId="7" captionText="FIGURES 21–27. Female genitalia of Barsine spp. Depositories of the slides: 21 in SCAU; 22 in CHSY; 23 in MfN; 24 in the private collection of Yasunori Kishida; 25 in ZFMK; 26, 27 in MWM/ZSM." figureDoi="http://doi.org/10.5281/zenodo.6796821" httpUri="https://zenodo.org/record/6796821/files/figure.png" pageId="3" pageNumber="81">Figs 23</figureCitation>
–28), however since the characters found in this structure of each species do not overlap with those in the similar congeners, we consider the morphology of the appendix bursae to be diagnostic. The characters found in appendix bursae of each species are summarized as follows. In 
<taxonomicName authority="Huang &amp; Volynkin &amp; Fan &amp; Wang, 2022" authorityName="Huang &amp; Volynkin &amp; Fan &amp; Wang" authorityYear="2022" box="[1272,1395,511,537]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="jingkuni" status="sp. n.">
<emphasis box="[1272,1395,511,537]" italics="true" pageId="3" pageNumber="81">B. jingkuni</emphasis>
</taxonomicName>
<emphasis bold="true" pageId="3" pageNumber="81">
<taxonomicNameLabel pageId="3" pageNumber="81" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
, it is the narrowest and shortest among these species. The appendix bursae of 
<taxonomicName authorityName="Reich" authorityYear="1937" box="[1040,1145,547,573]" class="Insecta" family="Arctiidae" genus="Miltochrista" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="hoenei">
<emphasis box="[1040,1145,547,573]" italics="true" pageId="3" pageNumber="81">B. hoenei</emphasis>
</taxonomicName>
is somewhat intermediate between 
<taxonomicName authority="Huang &amp; Volynkin &amp; Fan &amp; Wang, 2022" authorityName="Huang &amp; Volynkin &amp; Fan &amp; Wang" authorityYear="2022" box="[253,377,583,609]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="jingkuni" status="sp. n.">
<emphasis box="[253,377,583,609]" italics="true" pageId="3" pageNumber="81">B. jingkuni</emphasis>
</taxonomicName>
<emphasis bold="true" box="[386,450,583,609]" pageId="3" pageNumber="81">
<taxonomicNameLabel box="[386,450,583,609]" pageId="3" pageNumber="81" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
and 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" box="[507,632,583,609]" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis box="[507,632,583,609]" italics="true" pageId="3" pageNumber="81">B. pardalis</emphasis>
</taxonomicName>
, being moderately broad and the longest in the species-complex. In 
<taxonomicName baseAuthorityName="Mell" baseAuthorityYear="1922" class="Insecta" family="Erebidae" genus="Barsine" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="81" phylum="Arthropoda" rank="species" species="pardalis">
<emphasis italics="true" pageId="3" pageNumber="81">B. pardalis</emphasis>
</taxonomicName>
