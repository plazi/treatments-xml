, 
<collectorName pageId="3" pageNumber="285">Ubatuba, SP</collectorName>
, 
<specimenCount box="[193,315,403,429]" pageId="3" pageNumber="285" type="female">13 females</specimenCount>
(genetic voucher) (9 with spermatophore plug), CL 
<quantity box="[901,1057,402,429]" metricMagnitude="-2" metricUnit="m" metricValue="1.45" metricValueMax="1.85" metricValueMin="1.05" pageId="3" pageNumber="285" unit="mm" value="14.5" valueMax="18.5" valueMin="10.5">10.5–18.5mm</quantity>
and 
<specimenCount box="[1111,1200,403,429]" pageId="3" pageNumber="285" type="male">2 males</specimenCount>
