<taxonomicName id="4C444D321F08FFC8268BF833FD29F78C" box="[427,656,2045,2071]" class="Magnoliopsida" family="Asteraceae" genus="Psephellus" kingdom="Plantae" order="Asterales" pageId="13" pageNumber="286" phylum="Tracheophyta" rank="species" species="poluninii">
