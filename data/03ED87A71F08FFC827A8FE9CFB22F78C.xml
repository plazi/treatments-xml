</taxonomicName>
closely resembles 
<taxonomicName id="4C444D321F08FFC82445F830FBAFF78C" box="[869,1046,2045,2071]" class="Magnoliopsida" family="Asteraceae" genus="Psephellus" kingdom="Plantae" order="Asterales" pageId="13" pageNumber="286" phylum="Tracheophyta" rank="species" species="karduchorum">
<emphasis id="B930EAA31F08FFC82445F830FBAFF78C" box="[869,1046,2045,2071]" italics="true" pageId="13" pageNumber="286">P. karduchorum</emphasis>
