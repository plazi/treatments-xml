, SE 
<collectingCountry id="F35376211F08FFC8234FFC14FB06FC6F" box="[1135,1215,986,1012]" name="Turkey" pageId="13" pageNumber="286">Turkey</collectingCountry>
(
<figureCitation id="137F2A341F08FFC823F3FC14FA90FC6F" box="[1235,1321,986,1012]" captionStart="FIGURE 10" captionStartId="13.[136,229,1904,1926]" captionTargetBox="[154,1419,1111,1850]" captionTargetId="figure-395@13.[151,1436,1073,1880]" captionTargetPageId="13" captionText="FIGURE 10. Distribution of Psephellus poluninii." figureDoi="http://doi.org/10.5281/zenodo.5423488" httpUri="https://zenodo.org/record/5423488/files/figure.png" pageId="13" pageNumber="286">Fig. 10</figureCitation>
