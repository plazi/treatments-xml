<subSubSection id="4A94CAEBB610695925896FBB13B26D9D" pageId="null" pageNumber="70" type="description">
<paragraph id="F4048B42BE235A0EAC5D3DDFD89BCDC2" pageId="null" pageNumber="70">
Unterscheidet sich von 
<emphasis id="92C3561F692D53E8811605683E365B62" italics="true" pageId="null" pageNumber="70">P. maculosa</emphasis>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="30D7C27894C3EFC87F03619A71732FBB" italics="true" pageId="null" pageNumber="70">
<normalizedToken id="2874D2691E2DEEA8A974CEB6EFDAD2FA" originalValue="Blätter" pageId="null" pageNumber="70">Blaetter</normalizedToken>
ohne Flecken; Stiel der 
<normalizedToken id="9761F006C5AC994946D15783A02DF9A3" originalValue="Rosettenblätter" pageId="null" pageNumber="70">Rosettenblaetter</normalizedToken>
meist 1
</emphasis>
- 
<emphasis id="DEFA39170F1F4A031373F445F2BA3047" italics="true" pageId="null" pageNumber="70">2mal so lang wie die Blattspreite.</emphasis>
- 
<normalizedToken id="CAD6DE5965141B2F9ABCC7D7640B6527" originalValue="Blüte" pageId="null" pageNumber="70">Bluete</normalizedToken>
: 
<normalizedToken id="8B2E8D1DA86FD0D24C447E04B5D3DF8D" originalValue="Frühling" pageId="null" pageNumber="70">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="6B6A1478A43478861215AC3E13189CF2" pageId="null" pageNumber="70">
<emphasis id="1088B9569219E6D304553C541E113C3E" italics="true" pageId="null" pageNumber="70">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="1641F718F9EC2D5F55D496DB973F97B9" italics="true" pageId="null" pageNumber="70">14</emphasis>
(n = 7): Material aus dem 
<normalizedToken id="151BBCA7BAFB61B1BC587949E6A3EE7F" originalValue="Elsaß" pageId="null" pageNumber="70">Elsass</normalizedToken>
(Tarnavschi 1935), aus Skandinavien (
<normalizedToken id="76CB900CFBFC907A66A12209512B0684" originalValue="Löve" pageId="null" pageNumber="70">Loeve</normalizedToken>
und 
<normalizedToken id="01966505133485870982C3120DAB007C" originalValue="Löve" pageId="null" pageNumber="70">Loeve</normalizedToken>
1944b), aus Ungarn (
<normalizedToken id="AE9B5D2335CD24EAAC88F9ADBE03AF3F" originalValue="Pólya" pageId="null" pageNumber="70">Polya</normalizedToken>
1949), aus Frankreich (Larsen 1954a), aus Schweden (
<normalizedToken id="322D1A64E29C6DE9A60060880A432473" originalValue="Lövkvist" pageId="null" pageNumber="70">Loevkvist</normalizedToken>
1963a), aus Deutschland und der Tschechoslowakei (alle Angaben aus der Literatur mit 2n = 14 
<normalizedToken id="98ABC76289D4E4C4A5692F3B3CF5CC91" originalValue="für" pageId="null" pageNumber="70">fuer</normalizedToken>
<emphasis id="7D7C7A7EE84F0C71C29740DCC8D3E494" italics="true" pageId="null" pageNumber="70">P. maculosa</emphasis>
beziehen sich wohl auf 
<emphasis id="AD1A23A5EA84CDCA4714C95291994BF2" italics="true" pageId="null" pageNumber="70">P. obscura</emphasis>
) (Wolkinger 1967 1968), aus Deutschland (
<normalizedToken id="765AC68FB04625D44E85776BAABBB595" originalValue="Merxmüller" pageId="null" pageNumber="70">Merxmueller</normalizedToken>
und Grau 1969), aus botanischem Garten (Zhukova 1967b). 
<normalizedToken id="8A575DA777D739226A23C00600240308" originalValue="Merxmüller" pageId="null" pageNumber="70">Merxmueller</normalizedToken>
und Grau (1969) geben von Material aus Deutschland zudem 2n = 16 an.
</paragraph>
<paragraph id="0DA763E7CC0CF6732A8D94B80652250F" pageId="null" pageNumber="70">
<emphasis id="68CBAE684E69C70DD27ED6CB206F3549" italics="true" pageId="null" pageNumber="70">Standort.</emphasis>
Kollin und montan. Wie 
<emphasis id="7904F066DB8567797C366D84E4399CAA" italics="true" pageId="null" pageNumber="70">P. maculosa</emphasis>
(Nr. 1).
</paragraph>
<paragraph id="FDEAFEFB9526E7A2AA9804FEC4D902E0" pageId="null" pageNumber="70">
<emphasis id="8387ABDB92C6FD7596482113F70272F8" italics="true" pageId="null" pageNumber="70">
Verbreitung. 
<normalizedToken id="93C2D8B99692498C865F5E1C91F299D0" originalValue="Europäische" pageId="null" pageNumber="70">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="AD6237472A02E97D2B6E6F8B0A2B4328" originalValue="Westwärts" pageId="null" pageNumber="70">Westwaerts</normalizedToken>
bis Grajische Alpen, 
<normalizedToken id="59F903D3F29DB7D242E3AA9624054268" originalValue="südlicher" pageId="null" pageNumber="70">suedlicher</normalizedToken>
Jura, 
<normalizedToken id="BF78EB05E48EE5D4C01DB182656DC470" originalValue="Saônetal" pageId="null" pageNumber="70">Saonetal</normalizedToken>
, Vogesen, Ardennen; 
<normalizedToken id="3540354B36122F9A57AD224BDF6D9FF1" originalValue="nordwärts" pageId="null" pageNumber="70">nordwaerts</normalizedToken>
bis Nordholland (in 
<normalizedToken id="B7EE44D59BF5C71290A001A5E15D9A42" originalValue="Großbritannien" pageId="null" pageNumber="70">Grossbritannien</normalizedToken>
<normalizedToken id="923B6D55649436F66EC8F9A6C8C4BE9F" originalValue="eingebürgert" pageId="null" pageNumber="70">eingebuergert</normalizedToken>
), 
<normalizedToken id="34AA2ECA7C23EAD56060698AAA64D642" originalValue="Südschweden" pageId="null" pageNumber="70">Suedschweden</normalizedToken>
, 
<normalizedToken id="00DEE7134232BDB55886B26101E3C7CF" originalValue="Südfinnland" pageId="null" pageNumber="70">Suedfinnland</normalizedToken>
; 
<normalizedToken id="C0CC201C5DA2ECEEE76122A3EF0C24FE" originalValue="ostwärts" pageId="null" pageNumber="70">ostwaerts</normalizedToken>
bis Dnjepr und 
<normalizedToken id="9D36BAC069911136AFF360EAC8B5757F" originalValue="nördliche" pageId="null" pageNumber="70">noerdliche</normalizedToken>
Wolga (nach Flora URSS Band 
<emphasis id="AA1058E26AED4C19D2EC3C59F69BDE72" italics="true" pageId="null" pageNumber="70">29</emphasis>
1953 nicht im Kaukasus); 
<normalizedToken id="8AB693337BA8AC3EC4FB576E14E49E12" originalValue="südwärts" pageId="null" pageNumber="70">suedwaerts</normalizedToken>
bis Norditalien, Mazedonien, Bulgarien. - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="4334B9ADFDD4E7388E7338455D087346" originalValue="häufig" pageId="null" pageNumber="70">haeufig</normalizedToken>
, wahrscheinlich nicht vorhanden im Wallis, in 
<normalizedToken id="06E617CEF60BEBD3A148E78731537152" originalValue="Graubünden" pageId="null" pageNumber="70">Graubuenden</normalizedToken>
, St. Gallen, Vorarlberg und am 
<normalizedToken id="B843F803E1F77C0C49AA6D917142EFD4" originalValue="Alpensüdfuß" pageId="null" pageNumber="70">Alpensuedfuss</normalizedToken>
.
</paragraph>
<paragraph id="D892EBD37CD6F2213CD52B8CEE6E3FBA" pageId="null" pageNumber="70">
<emphasis id="D9DD30C66954907CF0CE447CF2C88DF7" italics="true" pageId="null" pageNumber="70">Bemerkungen.</emphasis>
Vgl. unter 
<emphasis id="20696412A51D4057372C088A4A51E504" italics="true" pageId="null" pageNumber="70">P. maculosa</emphasis>
(Nr. 1).
</paragraph>
</subSubSection>
