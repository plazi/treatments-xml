<paragraph id="216C3F96D0678CE3F61EE0D8D52DBA11" pageId="null" pageNumber="499">
<taxonomicName id="BFD472903E7D53151802B618AD60BF29" authority="Willd." class="Magnoliopsida" family="Asteraceae" genus="Senecio" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="499" phylum="Tracheophyta" rank="species" species="carniolicus">
Senecio 
<normalizedToken id="C1B954435DAC55701A660F043FFD220D" originalValue="carniólicus" pageId="null" pageNumber="499">carniolicus</normalizedToken>
Willd.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="67480E2BA0152F39BB50CF34A3B14A28" pageId="null" pageNumber="499" type="vernacular_names">
<paragraph id="7FD835FE7CCBA4F1351ABA1CA3F6F8EE" pageId="null" pageNumber="499">Krainer Kreuzkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="885E554D68BEF4BF1CCC312248895E24" pageId="null" pageNumber="499" type="description">
<paragraph id="442CC6A2C542B6DBC56640D57568BC82" pageId="null" pageNumber="499">
<emphasis id="C31B2CEB246162BAE3EB6E3E8D360C7A" italics="true" pageId="null" pageNumber="499">
<normalizedToken id="4399C4655070B1D91F361392A117333D" originalValue="Blätter" pageId="null" pageNumber="499">Blaetter</normalizedToken>
graufilzig, im Alter oft verkahlend, fast ganzrandig, stumpf 
<normalizedToken id="0233CE5BF9B0856ACDDC01CC426B544E" originalValue="gezähnt" pageId="null" pageNumber="499">gezaehnt</normalizedToken>
oder seltener
</emphasis>
(
<emphasis id="D39A6360C9E1A85563B58AE27BF57C30" italics="true" pageId="null" pageNumber="499">besonders die obern</emphasis>
) 
<emphasis id="593A09EBE319C329F7C10EACD14D6308" italics="true" pageId="null" pageNumber="499">
jederseits bis wenig 
<normalizedToken id="BBD6896E7C3A1C12DA85A2A864BD4E45" originalValue="über" pageId="null" pageNumber="499">ueber</normalizedToken>
die Mitte der 
<normalizedToken id="1AD2945362E148E26C2073328CD52893" originalValue="Blatthälfte" pageId="null" pageNumber="499">Blatthaelfte</normalizedToken>
fiederteilig
</emphasis>
, die untern 
<normalizedToken id="4A1B0D79A7B2CDC040A40AE3345CBFC2" originalValue="allmählich" pageId="null" pageNumber="499">allmaehlich</normalizedToken>
in den Stiel 
<normalizedToken id="0BC5E0159F44BF0E2880C323587AB85C" originalValue="verschmälert" pageId="null" pageNumber="499">verschmaelert</normalizedToken>
, die Abschnitte nur selten nochmals 
<normalizedToken id="ADDE9B24AF25E19AE2063F21DA262F0C" originalValue="gezähnt" pageId="null" pageNumber="499">gezaehnt</normalizedToken>
. Innere 
<normalizedToken id="D81643B813B2702D1047F8D2A141301D" originalValue="Hüllblätter" pageId="null" pageNumber="499">Huellblaetter</normalizedToken>
3,5-4,5 mm lang, 
<emphasis id="60201BE0E8B7A20292EC958BC0F125AF" italics="true" pageId="null" pageNumber="499">mit 0,7</emphasis>
- 
<emphasis id="2F086DEE441A49C981BCEE68E6151D65" italics="true" pageId="null" pageNumber="499">1,5 mm langer, roter Spitze.</emphasis>
Sonst wie 
<taxonomicName id="9CD1C65D1F076929DDE4769ED9F34EAC" class="Magnoliopsida" family="Asteraceae" genus="Senecio" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="499" phylum="Tracheophyta" rank="species" species="incanus">
<emphasis id="2B1968991F5060FD824CF04B4C729AE5" italics="true" pageId="null" pageNumber="499">S. incanus</emphasis>
</taxonomicName>
(Nr. 7a). - 
<normalizedToken id="32A1356610047AB3FB802E856A7ED907" originalValue="Blüte" pageId="null" pageNumber="499">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="EAEBABB6FD7DE37FB6F8F9A6FE6E9E87" pageId="null" pageNumber="499">
<emphasis id="2E4A271C7644D66468C70917F98ADF9F" italics="true" pageId="null" pageNumber="499">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="8027013167AE9E2A9DFE6C204F093141" italics="true" pageId="null" pageNumber="499">40:</emphasis>
Material von 2 Stellen aus dem Tirol (Favarger 1967a). 
<emphasis id="2647C59A69FE4CCF3150A979FA19AF46" italics="true" pageId="null" pageNumber="499">2n</emphasis>
= 
<emphasis id="99553A8E15708211BEB253AAE1DE89B3" italics="true" pageId="null" pageNumber="499">120:</emphasis>
Material von 7 Stellen aus 
<normalizedToken id="2C0999F5268C5F0B421ACE640F6B041B" originalValue="Graubünden" pageId="null" pageNumber="499">Graubuenden</normalizedToken>
und 
<normalizedToken id="8BA2F98CCD82D118C48C877A5320427E" originalValue="Österreich" pageId="null" pageNumber="499">Oesterreich</normalizedToken>
(Favarger 1950 1967a).
</paragraph>
<paragraph id="A7958AAB818DB2695A14F40F0803972A" pageId="null" pageNumber="499">
<emphasis id="A19E0C951698DB09BA6B39271CE92573" italics="true" pageId="null" pageNumber="499">Standort.</emphasis>
Wie 
<taxonomicName id="A29E866BA09221316D5784BCEC8B9558" class="Magnoliopsida" family="Asteraceae" genus="Senecio" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="499" phylum="Tracheophyta" rank="species" species="incanus">
<emphasis id="D3EE2027E53B7433DB0CC2E9B6E7446B" italics="true" pageId="null" pageNumber="499">S. incanus</emphasis>
</taxonomicName>
(Nr. 7a).
</paragraph>
<paragraph id="4811BC4ABA5EB15E901A88ECBF7ED880" pageId="null" pageNumber="499">
<emphasis id="50F1C60FB3AF8E8FABB3C5FC2D5158FF" italics="true" pageId="null" pageNumber="499">Verbreitung. Ostalpin-karpatische Pflanze:</emphasis>
Ostalpen (
<normalizedToken id="9D118255F0C7FA68BE520835CAB0FBEB" originalValue="Graubünden" pageId="null" pageNumber="499">Graubuenden</normalizedToken>
bis Karawanken), Karpaten. - Im Gebiet: Zentral- und 
<normalizedToken id="785A1395B0FD9E5E560AEA28AC3BA3EE" originalValue="Südalpen" pageId="null" pageNumber="499">Suedalpen</normalizedToken>
(
<normalizedToken id="B8704B8D9018C305150D8BBB97A8A4F9" originalValue="östlich" pageId="null" pageNumber="499">oestlich</normalizedToken>
der Linie St. 
<normalizedToken id="2FBC5783F402B35A7631CF70BC34C551" originalValue="Antönien-Parpan-Avers-Bergell" pageId="null" pageNumber="499">Antoenien-Parpan-Avers-Bergell</normalizedToken>
; isoliert auf der Furka im Wallis; im Misox, Calanca und im untern Tessin 
<normalizedToken id="FD8F4E3F4116DFF7527E734DEFC99916" originalValue="Übergangsformen" pageId="null" pageNumber="499">Uebergangsformen</normalizedToken>
zu 
<taxonomicName id="B50CA91ADF9D6F61D20B02DE2D414695" class="Magnoliopsida" family="Asteraceae" genus="Senecio" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="499" phylum="Tracheophyta" rank="species" species="incanus">
<emphasis id="1FBFBBCEFA959CE0B1BE0E29815779F8" italics="true" pageId="null" pageNumber="499">S. incanus</emphasis>
</taxonomicName>
(s. bei der Artengruppe), 
<normalizedToken id="541650E024E943A3AEAF077AED26CF31" originalValue="Allgäu" pageId="null" pageNumber="499">Allgaeu</normalizedToken>
(Rappensee, Fellhorn), Vorarlberg; ziemlich 
<normalizedToken id="F310AACDBF9B380C773EA86206494117" originalValue="häufig" pageId="null" pageNumber="499">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
