<heading id="D09C0F52FFE8FFDA424012FF3F890860" box="[623,964,999,1026]" centered="true" fontSize="11" level="2" pageId="121" pageNumber="122" reason="2">
<emphasis id="B91F642CFFE8FFDA424012FF3F890860" bold="true" box="[623,964,999,1026]" pageId="121" pageNumber="122">
Species of the 
<taxonomicName id="4C6BC3BDFFE8FFDA430F12FF3F3E0860" authorityName="Berland" authorityYear="1927" box="[800,883,999,1026]" class="Insecta" family="Vespidae" genus="Sphex" kingdom="Animalia" order="Hymenoptera" pageId="121" pageNumber="122" phylum="Arthropoda" rank="species" species="gaullei">
