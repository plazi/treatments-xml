<taxonomicName id="81B8DEB3C8A8115391F39B2A2197C5B0" LSID="http://zoobank.org/AA0BBF9D-5715-4ADF-895C-0776BF3C9F24" authority="Engel, Tran &amp; Nguyen" authorityName="Tran &amp; Engel &amp; Truong &amp; Nguyen" authorityYear="2022" class="Insecta" family="Megachilidae" genus="Noteriades" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="" order="Hymenoptera" pageId="0" pageNumber="191" phylum="Arthropoda" rank="subTribe" status="subtrib. nov." subTribe="Noteriadina">Noteriadina Engel, Tran &amp; Nguyen</taxonomicName>
