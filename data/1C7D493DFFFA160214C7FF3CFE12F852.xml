, EW 
<quantity id="532C55CEFFFA16021148F9F0FA97F9F9" box="[1304,1393,1627,1654]" metricMagnitude="-3" metricUnit="m" metricValue="5.6" pageId="4" pageNumber="596" unit="mm" value="5.6">5.6 mm</quantity>
