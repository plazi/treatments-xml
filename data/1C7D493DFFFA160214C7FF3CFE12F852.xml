, HL 
<quantity id="532C55CEFFFA16021610F9F0FD7EF9F9" box="[576,664,1627,1654]" metricMagnitude="-3" metricUnit="m" metricValue="2.2" pageId="4" pageNumber="596" unit="mm" value="2.2">2.2 mm</quantity>
