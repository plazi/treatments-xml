<subSubSection id="8C8E6575FFA46A1BFD2690A31D78BCA0" pageId="95" pageNumber="853" type="discussion">
<paragraph id="C42B36FEFFA46A1BFD2690A31D78BCA0" blockId="95.[730,1324,1629,2056]" pageId="95" pageNumber="853">
<taxonomicName id="03944D7DFFA46A1BFD2690A31DE1BC29" authorityName="Imaizumi" authorityYear="1953" box="[730,993,1786,1819]" class="Mammalia" family="Vespertilionidae" genus="Eptesicus" kingdom="Animalia" order="Chiroptera" pageId="95" pageNumber="853" phylum="Chordata" rank="species" species="japonensis">Eptesicus japonensis</taxonomicName>
