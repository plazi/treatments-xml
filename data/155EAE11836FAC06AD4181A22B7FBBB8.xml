<subSubSection id="0AA7915558BCF4CFB03D83B594BCAC58" pageId="null" pageNumber="762" type="description">
<paragraph id="D22F3738CB587FE3884A88A8BEF2718B" pageId="null" pageNumber="762">
<normalizedToken id="D4BD2488419784E6F2BA16510DDE315A" originalValue="Blüten" pageId="null" pageNumber="762">Blueten</normalizedToken>
in 
<normalizedToken id="EE8768B548DA6B4F5E74D6E137A8987F" originalValue="schirmförmigen" pageId="null" pageNumber="762">schirmfoermigen</normalizedToken>
<normalizedToken id="CFAF5152BC745482A27376E6703B53DF" originalValue="Blütenständen" pageId="null" pageNumber="762">Bluetenstaenden</normalizedToken>
oder 
<emphasis id="019E7759954C7A3529F7DD1A2BD9E2F4" italics="true" pageId="null" pageNumber="762">
einzeln in Blattachseln. 
<normalizedToken id="D832DBF37B14F896E9863E2BCF8B142D" originalValue="Kelchblätter" pageId="null" pageNumber="762">Kelchblaetter</normalizedToken>
5. 
<normalizedToken id="ACA44D66BFFC92A32F5DED5E4E0CEED2" originalValue="Kronblätter" pageId="null" pageNumber="762">Kronblaetter</normalizedToken>
5, frei, 
<normalizedToken id="D34AFF00D5299B71690460F92908EE45" originalValue="weiß" pageId="null" pageNumber="762">weiss</normalizedToken>
.
</emphasis>
<normalizedToken id="F8A7F9331363134AA726FFC2AFC55AA8" originalValue="Staubfäden" pageId="null" pageNumber="762">Staubfaeden</normalizedToken>
lang; Staubbeutel auf dem 
<normalizedToken id="F577C93AE8B233D7FFE4F30C9D983B49" originalValue="Rücken" pageId="null" pageNumber="762">Ruecken</normalizedToken>
angewachsen. Frucht eine 2-, selten 3 
<normalizedToken id="B492A1DF18EB1AC7EF38671D6BB6D754" originalValue="fächerige" pageId="null" pageNumber="762">faecherige</normalizedToken>
, 
<normalizedToken id="78DFF15CC464FEA77C2E59E8C347F9AA" originalValue="eiförmige" pageId="null" pageNumber="762">eifoermige</normalizedToken>
Beere.
</paragraph>
<paragraph id="ACB64A6155455DE03901565D7DC534ED" pageId="null" pageNumber="762">
Die Gattung 
<taxonomicName id="676560B74933E3FF2B5C40DD8B14350F" class="Magnoliopsida" family="Myrtaceae" genus="Myrtus" kingdom="Plantae" order="Myrtales" pageId="null" pageNumber="762" phylum="Tracheophyta" rank="genus">
<emphasis id="00B8C4080A5455CE4956A77FE5E0C3F6" italics="true" pageId="null" pageNumber="762">Myrtus</emphasis>
</taxonomicName>
<normalizedToken id="5DB6F5C8AFDFB0E27EE9DF3A7818870F" originalValue="umfaßt" pageId="null" pageNumber="762">umfasst</normalizedToken>
<emphasis id="1CFA71518BB0CF8A1EF5952E72B0A3D3" italics="true" pageId="null" pageNumber="762">
mehrere Arten in den 
<normalizedToken id="6C4D3F9CDFA64E6B3A16619424F669A3" originalValue="außertropischen" pageId="null" pageNumber="762">aussertropischen</normalizedToken>
Gebieten von 
<normalizedToken id="1C77BA2EF2B8251994D15807D117D77E" originalValue="Südamerika" pageId="null" pageNumber="762">Suedamerika</normalizedToken>
, Australien und Neuseeland; einzig 
<taxonomicName id="7B63332C02FE5F7CDDEC874354AF5465" class="Magnoliopsida" family="Myrtaceae" genus="Myrtus" kingdom="Plantae" order="Myrtales" pageId="null" pageNumber="762" phylum="Tracheophyta" rank="species" species="communis">M. communis</taxonomicName>
hat eine mediterrane Verbreitung.
</emphasis>
</paragraph>
