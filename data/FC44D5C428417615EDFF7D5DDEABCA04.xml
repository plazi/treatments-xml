<paragraph id="C9574E9F2A25F2F0CE4CA0D28C43AC62" pageId="null" pageNumber="160">
<pageBreakToken id="A2FA32222E6D334D538F1D91C7AA03F9" pageId="null" pageNumber="160" start="start">Artengruppe</pageBreakToken>
des 
<taxonomicName id="3487ED1F59F2AF54B0D6DAEB271FEC70" authority="L." class="Magnoliopsida" family="Solanaceae" genus="Solanum" kingdom="Plantae" order="Solanales" pageId="null" pageNumber="160" phylum="Tracheophyta" rank="species" species="nigrum">
