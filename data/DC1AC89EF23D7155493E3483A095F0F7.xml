1*. 
<normalizedToken id="1219F464EB95704A2DED1E6C5BD8E379" originalValue="Grundständige" pageId="null" pageNumber="590">Grundstaendige</normalizedToken>
<normalizedToken id="44A1E3BB87E313BE5711E9227BE8DA7A" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
