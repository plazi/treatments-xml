</title>
<subSubSection id="4D8FA9E9112367773A1796970533C9D7" pageId="null" pageNumber="590" type="description">
<paragraph id="BCE4E4C783BC038300FCB40B04199CBA" pageId="null" pageNumber="590">
<normalizedToken id="5EBA2FA98D8BE2DE4719AD82EA2E3CA5" originalValue="Köpfe" pageId="null" pageNumber="590">Koepfe</normalizedToken>
zahlreich, 
<normalizedToken id="3F1532D7B8A03F2E2A49CB0C0A3CE91F" originalValue="vielblütig" pageId="null" pageNumber="590">vielbluetig</normalizedToken>
, 
<emphasis id="4089C664083DFFAA8D3D777C73BC6019" italics="true" pageId="null" pageNumber="590">kurz gestielt oder sitzend</emphasis>
. 
<normalizedToken id="3408F0FE8119ABAB54140F9D680102F6" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
zylindrisch; 
<emphasis id="DD1960F0335556630EC934F9A8B0EAD3" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="6F34FFB71BB91FDA7ED3A8C656EDD94E" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
in 2 Reihen, krautig
</emphasis>
, die 
<normalizedToken id="3C262ACD6F507BC30473019DEBD38B5F" originalValue="äußern" pageId="null" pageNumber="590">aeussern</normalizedToken>
kurz, abstehend, die innern aufrecht, die 
<normalizedToken id="9EA30E81898F4ABC478965268C085424" originalValue="randständigen" pageId="null" pageNumber="590">randstaendigen</normalizedToken>
<normalizedToken id="A7769A0EC287F6FE5EEACCD499950DA2" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
teilweise umfassend, auf der Innenseite 
<normalizedToken id="B6F8864BE7D231A5508F4346F0535DD2" originalValue="±" pageId="null" pageNumber="590">+/-</normalizedToken>
kahl. 
<emphasis id="F7B4F291F048A20F041AF616AA890694" italics="true" pageId="null" pageNumber="590">
Boden des 
<normalizedToken id="A2652DC9C79DD4EDA88AEE04A495774C" originalValue="Blütenkopfes" pageId="null" pageNumber="590">Bluetenkopfes</normalizedToken>
ohne 
<normalizedToken id="0EBC5BAABC7BFD131D1BBDCF37BC1F42" originalValue="Spreublätter" pageId="null" pageNumber="590">Spreublaetter</normalizedToken>
, kahl
</emphasis>
. Krone hellblau (selten rosa oder 
<normalizedToken id="D78FC8AA30BFA424249E7E36CD78101F" originalValue="weiß" pageId="null" pageNumber="590">weiss</normalizedToken>
; nur am Vormittag 
<normalizedToken id="C463E926A8DF3D9809E0FBE8FDDE5807" originalValue="geöffnet" pageId="null" pageNumber="590">geoeffnet</normalizedToken>
); 
<normalizedToken id="BD7332B43CA7AACBE2D0125FE4FC1B35" originalValue="Kronröhre" pageId="null" pageNumber="590">Kronroehre</normalizedToken>
<normalizedToken id="CAAB38BFB8D922FFCF8ECCF23C3FDD17" originalValue="außen" pageId="null" pageNumber="590">aussen</normalizedToken>
im obern Teil kurz behaart. 
<normalizedToken id="0130B7C576569E9569960D918E419957" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
kurz prismatisch, 3-5kantig, kahl. 
<emphasis id="4E6F84EA08D8D8D9169126FE8C9E4542" italics="true" pageId="null" pageNumber="590">
<taxonomicName id="42D1A9B06C72382619AA0E72289C127D" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
2
</emphasis>
- 
<emphasis id="59854E09464E70490D5B870C90D05405" italics="true" pageId="null" pageNumber="590">3reihig, aus sehr kurzen Schuppen bestehend</emphasis>
(nur mit 10facher 
<normalizedToken id="BE06750B22687F58E704EF639F0C36DA" originalValue="Vergrößerung" pageId="null" pageNumber="590">Vergroesserung</normalizedToken>
sichtbar).
</paragraph>
<paragraph id="3B4CFB09553BB96FC4DF282C933997D9" pageId="null" pageNumber="590">
Die Gattung 
<taxonomicName id="D3CDB5D44D9EF4068E0B60CC30F620AC" class="Magnoliopsida" family="Asteraceae" genus="Cichorium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="genus">
<emphasis id="7CB8125DB04A85D1DBC0753777147DC6" italics="true" pageId="null" pageNumber="590">Cichorium</emphasis>
</taxonomicName>
<normalizedToken id="9A190D068BC0BC5AB9FDEE8B3144EFD7" originalValue="umfaßt" pageId="null" pageNumber="590">umfasst</normalizedToken>
etwa 
<emphasis id="24CBEC5D508B9CCC8D2BA634959DB33D" italics="true" pageId="null" pageNumber="590">10 Arten</emphasis>
und hat ihre 
<emphasis id="D665B807FF1C419DD18A818DF8C9B83F" italics="true" pageId="null" pageNumber="590">Hauptverbreitung im Mittelmeergebiet</emphasis>
.
</paragraph>
