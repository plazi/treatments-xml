<taxonomicName id="48E048BAFFFB6029681FC8BDCB73A9A9" authorityName="Cartwright" authorityYear="2008" baseAuthorityName="Cartwright" baseAuthorityYear="2008" box="[623,855,912,937]" class="Insecta" family="Ecnomidae" genus="Daternomina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trichoptera" pageId="16" pageNumber="17" phylum="Arthropoda" rank="species" species="trulla">
