<taxonomicName id="48E048BAFFFB60296F3EC8CDC8CBAE21" class="Insecta" family="Ecnomidae" genus="Daternomina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trichoptera" pageId="16" pageNumber="17" phylum="Arthropoda" rank="genus">
