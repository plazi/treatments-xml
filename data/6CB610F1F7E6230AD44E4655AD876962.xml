<subSubSection id="9ACA73485B4250EB974D2FFF7C696ADE" pageId="null" pageNumber="78" type="description">
<paragraph id="A72B6723CA67DA0D8F259E8FFE1F061F" pageId="null" pageNumber="78">
Ausdauernd; bis 20 cm hoch, aufrecht, kahl. Rhizom und Wurzeln wie bei 
<taxonomicName id="3EB2486FCDEABDC3EC4CEE45A6BDE0CB" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="78" phylum="Tracheophyta" rank="species" species="thora">
<emphasis id="B6054A2BC512F6275D22C9792434D7F9" italics="true" pageId="null" pageNumber="78">R. Thora</emphasis>
</taxonomicName>
(Nr. 9). 
<emphasis id="F364ED4FC8FFB985CD2AEC924F5F727D" italics="true" pageId="null" pageNumber="78">
<normalizedToken id="97A951497CBF8D08D59E5FB826A2F056" originalValue="Grundständige" pageId="null" pageNumber="78">Grundstaendige</normalizedToken>
<normalizedToken id="3A1662248915CCCACFC1571E556B5100" originalValue="Blätter" pageId="null" pageNumber="78">Blaetter</normalizedToken>
zur 
<normalizedToken id="B6997BB144B5946199302560DB057D09" originalValue="Blütezeit" pageId="null" pageNumber="78">Bluetezeit</normalizedToken>
meist vorhanden
</emphasis>
(
<emphasis id="196EE366A6EE677B19BFD9B294473773" italics="true" pageId="null" pageNumber="78">1-2</emphasis>
), 
<emphasis id="664B4CC1A7F4B61F41B0D9E584FDBBB5" italics="true" pageId="null" pageNumber="78">
<normalizedToken id="548276609F535C9286490688BF2AF576" originalValue="nierenförmig" pageId="null" pageNumber="78">nierenfoermig</normalizedToken>
</emphasis>
, in den Blattstiel 
<normalizedToken id="1CBFD02806348B15DA15BD9FAF7A0F40" originalValue="verschmälert" pageId="null" pageNumber="78">verschmaelert</normalizedToken>
, gegen die Basis hin ganzrandig, auf den Seiten meist fein 
<normalizedToken id="A04D0525407D15E1BD575EBC6776ADDA" originalValue="gezähnt" pageId="null" pageNumber="78">gezaehnt</normalizedToken>
, gegen die Spitze hin grob 
<normalizedToken id="850E35F4B4FB0A234A83C97437648E00" originalValue="gezähnt" pageId="null" pageNumber="78">gezaehnt</normalizedToken>
. Stengel 1; unterstes Stengelblatt meist unterhalb der Mitte des Stengels, kurz gestielt oder sitzend, von gleicher Form wie die 
<normalizedToken id="5C92AAF28A1688DE11BAAD718AE16298" originalValue="grundständigen" pageId="null" pageNumber="78">grundstaendigen</normalizedToken>
<normalizedToken id="8FEBC77BD1C854E62D9769AE848FC1B8" originalValue="Blätter" pageId="null" pageNumber="78">Blaetter</normalizedToken>
, an der Spitze jedoch meist tiefer (bis auf ⅓) geteilt; die nach oben folgenden 
<normalizedToken id="953C11EACCCF35743AE2A6904679A705" originalValue="Stengelblätter" pageId="null" pageNumber="78">Stengelblaetter</normalizedToken>
wie bei 
<emphasis id="E718363432524AE8C3DECCEB2E03924B" italics="true" pageId="null" pageNumber="78">
<taxonomicName id="512C03401682B7D43F52FA2D8B789151" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="78" phylum="Tracheophyta" rank="species" species="thora">R. Thora</taxonomicName>
.
</emphasis>
<normalizedToken id="68D1856A1FD68C55FA84183586A19443" originalValue="Blütenstiele" pageId="null" pageNumber="78">Bluetenstiele</normalizedToken>
1-3, selten mehr. 
<normalizedToken id="737A8ABC37F6B65124C34D95F2ED4449" originalValue="Blüten" pageId="null" pageNumber="78">Blueten</normalizedToken>
, 
<normalizedToken id="90250FDACA80D536BA361142CF12340E" originalValue="Früchtchen" pageId="null" pageNumber="78">Fruechtchen</normalizedToken>
und 
<normalizedToken id="B4304EAAF12734363B09CAF70D38AA5A" originalValue="Blütenboden" pageId="null" pageNumber="78">Bluetenboden</normalizedToken>
wie bei 
<emphasis id="EF4E6A30A1E3DA2DF33A0FCD0A0D7704" italics="true" pageId="null" pageNumber="78">
<taxonomicName id="7573FD2C112F92A8169938BBCA5A3AD8" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="78" phylum="Tracheophyta" rank="species" species="thora">R. Thora</taxonomicName>
. -
</emphasis>
<normalizedToken id="20F0236BFF890FB81BB64720AFF44B36" originalValue="Blüte" pageId="null" pageNumber="78">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="7A20EFEB96BAC88B8FD6C974D81EE28E" pageId="null" pageNumber="78">
<emphasis id="D554A425D09204F61531B8BCBEC29EF9" italics="true" pageId="null" pageNumber="78">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="C2E667361E179A685C05157C130D688D" italics="true" pageId="null" pageNumber="78">16:</emphasis>
Material aus den Alpen (Mattick in Tischler 1950).
</paragraph>
<paragraph id="E09AADB92B6C3AF1AE466122E34EB939" pageId="null" pageNumber="78">
<emphasis id="16C6FD7A29D3DB5914FBEF33673CE83E" italics="true" pageId="null" pageNumber="78">Standort.</emphasis>
Subalpin und alpin, selten montan. Sonst wie bei 
<taxonomicName id="6ED33A5BFE9CA16B35886FC2B8E28B92" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="78" phylum="Tracheophyta" rank="species" species="thora">
<emphasis id="FC14342512EDFFF7C47B02DFBDEF39C0" italics="true" pageId="null" pageNumber="78">R. Thora</emphasis>
</taxonomicName>
(Nr. 9).
</paragraph>
<paragraph id="C31ABF04459C222FD29C9B165C23F725" pageId="null" pageNumber="78">
<emphasis id="26E33AEDADA18C52484E7332D50C6180" italics="true" pageId="null" pageNumber="78">
Verbreitung. Mittel- und 
<normalizedToken id="26A0104970CCE3E79A8BE1D1CE563D3F" originalValue="südeuropäische" pageId="null" pageNumber="78">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="A1EA5275EFC225E32408E3781D64601A" italics="true" pageId="null" pageNumber="78">
<normalizedToken id="ECA36B1AED792D7894404A43E5ED14B5" originalValue="östlich" pageId="null" pageNumber="78">oestlich</normalizedToken>
</emphasis>
): 
<normalizedToken id="36D86B5D25AA528A9585A05EFCD1FB80" originalValue="Nordöstliche" pageId="null" pageNumber="78">Nordoestliche</normalizedToken>
und 
<normalizedToken id="B0646261FAF712DC224170D3C96F1D0A" originalValue="südöstliche" pageId="null" pageNumber="78">suedoestliche</normalizedToken>
Kalkalpen; isolierter Fundort in Westbosnien; 
<normalizedToken id="DB26E2B382BD2D8F011AD86C11235A61" originalValue="Südkarpaten" pageId="null" pageNumber="78">Suedkarpaten</normalizedToken>
?. Verbreitungskarte von 
<normalizedToken id="320CB28139CD54848698F6A931B6A85F" originalValue="Merxmüller" pageId="null" pageNumber="78">Merxmueller</normalizedToken>
(1952). - Im Gebiet: Veltlin (Valle 
<normalizedToken id="264E7CC51A829BA40A7B151450EB8AD7" originalValue="d’Arigna" pageId="null" pageNumber="78">d'Arigna</normalizedToken>
), Bormio, Stilfserjoch, Bergamasker Alpen (Valle di Scalve, Val Camonica).
</paragraph>
</subSubSection>
