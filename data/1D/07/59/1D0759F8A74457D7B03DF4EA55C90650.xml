<subSubSection pageId="0" pageNumber="41" type="diagnosis">
<paragraph pageId="0" pageNumber="41">Diagnosis.</paragraph>
<paragraph pageId="0" pageNumber="41">
<taxonomicName authorityName="Kang &amp; Whitfield &amp; Owens &amp; Chen" authorityYear="2022" baseAuthorityName="Dabek &amp; Whitfield" baseAuthorityYear="2020" class="Insecta" family="Braconidae" genus="Neocardiochiles" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Neocardiochiles kidonoi" order="Hymenoptera" pageId="0" pageNumber="41" phylum="Arthropoda" rank="species" species="kidonoi">
<emphasis italics="true" pageId="0" pageNumber="41">Neocardiochiles kidonoi</emphasis>
</taxonomicName>
is most similar to 
<taxonomicName class="Insecta" genus="N." kingdom="Animalia" lsidName="N. victoriae" order="Hymenoptera" pageId="0" pageNumber="41" phylum="Arthropoda" rank="species" species="victoriae">
<emphasis italics="true" pageId="0" pageNumber="41">N. victoriae</emphasis>
</taxonomicName>
sp. nov., but members of 
<taxonomicName class="Insecta" genus="N." kingdom="Animalia" lsidName="N. kidodoi" order="Hymenoptera" pageId="0" pageNumber="41" phylum="Arthropoda" rank="species" species="kidodoi">
<emphasis italics="true" pageId="0" pageNumber="41">N. kidodoi</emphasis>
</taxonomicName>
can be distinguished from other 
<taxonomicName authorityName="Szepligeti" authorityYear="1908" class="Insecta" family="Braconidae" genus="Neocardiochiles" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Neocardiochiles" order="Hymenoptera" pageId="0" pageNumber="41" phylum="Arthropoda" rank="genus">
<emphasis italics="true" pageId="0" pageNumber="41">Neocardiochiles</emphasis>
</taxonomicName>
members by possession of the following characters: mesoscutum entirely pale; hind femur bicolored; hind tibia mostly pale.
</paragraph>
</subSubSection>
