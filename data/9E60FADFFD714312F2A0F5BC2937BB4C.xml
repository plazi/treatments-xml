<subSubSection id="87D0EA20245D13AADEA94299D38540F4" pageId="null" pageNumber="324" type="vernacular_names">
<paragraph id="D8161435036A8BD5BC912D1368775770" pageId="null" pageNumber="324">
Gestreiftes 
<normalizedToken id="3DCD400813AF9715807C7AEE0DEFA145" originalValue="Süßgras" pageId="null" pageNumber="324">Suessgras</normalizedToken>
</paragraph>
</subSubSection>
</title>
<subSubSection id="0E93DEC7258827CC490723C6EE885897" pageId="null" pageNumber="324" type="description">
<paragraph id="7E96F2A5905D79D80EDBDC1EB8AA53B4" pageId="null" pageNumber="324">
30-100 cm hoch, aufrecht, unterirdische 
<normalizedToken id="39ADD99B000CF715A1274D4A6368FB9D" originalValue="Ausläufer" pageId="null" pageNumber="324">Auslaeufer</normalizedToken>
treibend. 
<emphasis id="849F95FDA8D0FB3C32D8EAC9AAD4B84F" italics="true" pageId="null" pageNumber="324">
<normalizedToken id="B5B485C27DCE17D9D0834223298C8C8A" originalValue="Blätter" pageId="null" pageNumber="324">Blaetter</normalizedToken>
2-6 mm breit
</emphasis>
, wenig rauh, kurz oder 
<normalizedToken id="CF0AF3AB93CC1D5585EB808B16AD433A" originalValue="allmählich" pageId="null" pageNumber="324">allmaehlich</normalizedToken>
zugespitzt; 
<normalizedToken id="28456F99CED31A2F117F4FBBB87500CD" originalValue="Blatthäutchen" pageId="null" pageNumber="324">Blatthaeutchen</normalizedToken>
ca. 2 mm lang, zerschlitzt, spitz; Blattscheiden glatt. 
<emphasis id="609F65C6569EB5EFC35519DE8D3D4302" italics="true" pageId="null" pageNumber="324">Rispe 10-20 cm lang, locker</emphasis>
, im Habitus wie bei 
<taxonomicName id="455EFEBA132EC9718C693A79059A5A14" class="Liliopsida" family="Poaceae" genus="Glyceria" kingdom="Plantae" order="Poales" pageId="null" pageNumber="324" phylum="Tracheophyta" rank="species" species="maxima">
<emphasis id="F440EC209FE6DA835232A0A36BC52E3C" italics="true" pageId="null" pageNumber="324">G. maxima</emphasis>
</taxonomicName>
(Nr. 1). 
<emphasis id="446968D8B8F32D0E51C9ECFD3DA4B4EF" italics="true" pageId="null" pageNumber="324">
<normalizedToken id="6BCB5CF523F6702BBD422448D009D165" originalValue="Ährchen" pageId="null" pageNumber="324">Aehrchen</normalizedToken>
3-4 mm lang
</emphasis>
, 5-7 
<normalizedToken id="EA3648767A36A9E8C4E4A5768B057C2F" originalValue="blütig" pageId="null" pageNumber="324">bluetig</normalizedToken>
, in der Form wie bei 
<emphasis id="FE6D51F207BCE8A3ED67309A706DF606" italics="true" pageId="null" pageNumber="324">
<taxonomicName id="4CF29886282D6D30EB6E7224E6DE7A0B" class="Liliopsida" family="Poaceae" genus="Glyceria" kingdom="Plantae" order="Poales" pageId="null" pageNumber="324" phylum="Tracheophyta" rank="species" species="maxima">G. maxima</taxonomicName>
. Untere 
<normalizedToken id="EB74B2AE274975443BD2B434F4E85C1E" originalValue="Hüllspelze" pageId="null" pageNumber="324">Huellspelze</normalizedToken>
ca. 1 mm lang
</emphasis>
, ⅗-⅘ so lang wie die obere. 
<emphasis id="B70715F0B05889C5577C0DFF3135C010" italics="true" pageId="null" pageNumber="324">Deckspelzen ca. 2 mm lang</emphasis>
, mit 7 vorstehenden Nerven. - 
<normalizedToken id="B68BFD7544EB3909B0EAA796ADC31ECE" originalValue="Blüte" pageId="null" pageNumber="324">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="4DF947F308C6711CA09A6E7B0D8B9ECC" pageId="null" pageNumber="324">
<emphasis id="326DAF896DD3429804E5E5E0C538DD49" italics="true" pageId="null" pageNumber="324">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="622FB076F069B0AAA123937740BA263F" italics="true" pageId="null" pageNumber="324">20:</emphasis>
Material aus Amerika (Church 1942), aus Westkanada (Packer 1964).
</paragraph>
<paragraph id="DF0C6DBE215A574B3710E82F48DB4109" pageId="null" pageNumber="324">
<emphasis id="8CBAE534B0821CCFECC56A4A8D2CE816" italics="true" pageId="null" pageNumber="324">Standort.</emphasis>
Kollin. 
<normalizedToken id="602DCE7607D4D843D0D3549FA7DDBA45" originalValue="Sümpfe" pageId="null" pageNumber="324">Suempfe</normalizedToken>
.
</paragraph>
<paragraph id="000592CE4C1CD24C353CD4FC4A69F4A3" pageId="null" pageNumber="324">
<emphasis id="117AE60D45F34A77296591F383208BB5" italics="true" pageId="null" pageNumber="324">Verbreitung. Nordamerikanische Pflanze:</emphasis>
In Nordamerika von Neufundland und Britisch-Kolumbien 
<normalizedToken id="B082AAC7CA9EB732923F269734F34B9A" originalValue="südwärts" pageId="null" pageNumber="324">suedwaerts</normalizedToken>
bis Nordflorida, Texas, Arizona und Nordkalifornien. - Im Gebiet eingeschleppt und in Ausbreitung begriffen: 
<normalizedToken id="FD00F69BB9CB4AD03F34D0DBEC1D7E8A" originalValue="Prévessin" pageId="null" pageNumber="324">Prevessin</normalizedToken>
(
<normalizedToken id="3A453D578A756462E1A5A5AA33783997" originalValue="Dép" pageId="null" pageNumber="324">Dep</normalizedToken>
. Ain) nahe der Genfer Grenze, Mategnin bei Genf; Unterwalden (am Wichelsee, Stausee seit 1957, zwischen Alpnach und Sarnen); 
<normalizedToken id="B92BE428AE5BF741FC013BE76FA7D7B5" originalValue="Zürich" pageId="null" pageNumber="324">Zuerich</normalizedToken>
(
<normalizedToken id="A897C033C8C9A088B4B9E5E60E5D5B62" originalValue="Hüttnersee" pageId="null" pageNumber="324">Huettnersee</normalizedToken>
).
</paragraph>
</subSubSection>
