<subSubSection id="DBFD3656E96C52C5E77533567B77BA16" pageId="null" pageNumber="627" type="description">
<paragraph id="1A60983C314E0E639370C4526D78ADF7" pageId="null" pageNumber="627">
20-50 cm hoch. 
<emphasis id="6D17BE859CC509573D3B6C85B92C0ACC" italics="true" pageId="null" pageNumber="627">
<normalizedToken id="3B4A31C8C4BC6905516747AF5F27D84B" originalValue="Blütenstiele" pageId="null" pageNumber="627">Bluetenstiele</normalizedToken>
und Kelch ohne 
<normalizedToken id="465FDB3DA4F47EA2EAFE2EA90A7F2BF1" originalValue="Drüsenhaare" pageId="null" pageNumber="627">Druesenhaare</normalizedToken>
</emphasis>
, 
<normalizedToken id="9184B045BCCA5348506D9AB1AF4A56D5" originalValue="Früchte" pageId="null" pageNumber="627">Fruechte</normalizedToken>
mit einzelnen 
<normalizedToken id="9E1E565725FB609B98327066972E3EF6" originalValue="Drüsenhaaren" pageId="null" pageNumber="627">Druesenhaaren</normalizedToken>
. Untere 
<normalizedToken id="E28CA977DDF3D1EE0741DCBC2633CD1F" originalValue="Blätter" pageId="null" pageNumber="627">Blaetter</normalizedToken>
5-10 cm breit, bis auf ⅙ oder tiefer geteilt; 
<emphasis id="E3E871AFD34C7619327CB46F0B19A8BA" italics="true" pageId="null" pageNumber="627">
<normalizedToken id="06B0FE09068B9E7E0BB994B0DFE09305" originalValue="Zähne" pageId="null" pageNumber="627">Zaehne</normalizedToken>
und Zipfel 2-5mal so lang wie breit.
</emphasis>
<normalizedToken id="FD84CE0D324283DBCA295A0E784A93A7" originalValue="Blütenstiele" pageId="null" pageNumber="627">Bluetenstiele</normalizedToken>
nach dem 
<normalizedToken id="B859ECCDFC216DF00D2C60E83D86D08D" originalValue="Blühen" pageId="null" pageNumber="627">Bluehen</normalizedToken>
und zur Fruchtzeit aufrecht. 
<normalizedToken id="D9D522F3A5A9C718AFD168D6FF475B82" originalValue="Kelchblätter" pageId="null" pageNumber="627">Kelchblaetter</normalizedToken>
mit 1-2 mm langer Spitze, 7-9 mm lang. 
<emphasis id="03BFAF5F9075795A8296E2E093F477FE" italics="true" pageId="null" pageNumber="627">
<normalizedToken id="BEA5C851AF5F6E908831E8767ABFDC09" originalValue="Kronblätter" pageId="null" pageNumber="627">Kronblaetter</normalizedToken>
10-15 mm lang, 
<normalizedToken id="5C22C1262AF9D1A76167177573C5373F" originalValue="weiß" pageId="null" pageNumber="627">weiss</normalizedToken>
, mit roten Nerven.
</emphasis>
<normalizedToken id="F67A531D1503BB214B3D15B2AB87DB4F" originalValue="Staubfäden" pageId="null" pageNumber="627">Staubfaeden</normalizedToken>
am Grunde 
<normalizedToken id="9B6531C003F4474B72108CD4A869B976" originalValue="allmählich" pageId="null" pageNumber="627">allmaehlich</normalizedToken>
auf etwa 1 mm verbreitert, am Rande deutlich bewimpert. - 
<normalizedToken id="C348C5CED4B9B0E0635D057DA1F008E0" originalValue="Blüte" pageId="null" pageNumber="627">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="712AA3CF9E2FEF00173D27034B05D1EB" pageId="null" pageNumber="627">
<emphasis id="BB2D15B7170B81B861E9873C616A4AAA" italics="true" pageId="null" pageNumber="627">
<pageBreakToken id="065CD9284C368C869CC6641B86216935" pageId="null" pageNumber="627">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="F40C06508ACD1A8BFDCE5729FB8350A0" italics="true" pageId="null" pageNumber="627">28:</emphasis>
Material aus dem Wallis (Favarger 1959Favarger 1965).
</paragraph>
<paragraph id="DA2CED6ACE376C6663535114E72F45A0" pageId="null" pageNumber="627">
<emphasis id="A32F9B5AD8277BD95171F1D99F30A832" italics="true" pageId="null" pageNumber="627">Standort.</emphasis>
Subalpin, selten montan und alpin. Kalkarme 
<normalizedToken id="1D899FF6556475BB7DB5A0495AE007E4" originalValue="Böden" pageId="null" pageNumber="627">Boeden</normalizedToken>
. Lichte 
<normalizedToken id="15D0A2EA17A7C6E48CBE99ED5976C87A" originalValue="Nadelwälder" pageId="null" pageNumber="627">Nadelwaelder</normalizedToken>
, 
<normalizedToken id="12044E4D79FD7CFB94F0928E3154F517" originalValue="Gebüsche" pageId="null" pageNumber="627">Gebuesche</normalizedToken>
, 
<normalizedToken id="279918577A6D2867907060DB845FD032" originalValue="Bachränder" pageId="null" pageNumber="627">Bachraender</normalizedToken>
.
</paragraph>
<paragraph id="312C7FCFF0DC20C92800A3F6C71B66E4" pageId="null" pageNumber="627">
<emphasis id="9C1D6112906409BE278943E82141EE72" italics="true" pageId="null" pageNumber="627">Verbreitung. Westalpen-Pflanze:</emphasis>
<normalizedToken id="215E23E40DA0B9C67C482D3AB008FB0B" originalValue="Ostwärts" pageId="null" pageNumber="627">Ostwaerts</normalizedToken>
vereinzelt bis Engadin und 
<normalizedToken id="0040A457D99A31A1D404AE3F9B62AF2B" originalValue="Südtirol" pageId="null" pageNumber="627">Suedtirol</normalizedToken>
. - Im Gebiet: Savoyen, Wallis, Aostatal, Engadin, Albula, 
<normalizedToken id="BD08E3815E6A266CD3BD6AC180DBDB1C" originalValue="Münstertal" pageId="null" pageNumber="627">Muenstertal</normalizedToken>
, Bergamasker Alpen; nicht 
<normalizedToken id="F893BECB8FA3BD5D63B4F129AFE7A46E" originalValue="häufig" pageId="null" pageNumber="627">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
