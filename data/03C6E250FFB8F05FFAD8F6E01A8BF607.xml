<taxonomicName id="4C6F28C5FFB8F05EFDDFF2851A36F292" authority="Ieuoogaston" authorityName="Ieuoogaston" box="[622,863,3395,3419]" class="Mammalia" family="Moschidae" genus="Moschus" kingdom="Animalia" order="Artiodactyla" pageId="2" pageNumber="345" phylum="Chordata" rank="genus">Moschus Ieuoogaston</taxonomicName>
