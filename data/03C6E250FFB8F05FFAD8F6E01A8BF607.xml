<taxonomicName id="4C6F28C5FFB8F05EFBC1F2821DBCF291" box="[1136,1237,3396,3416]" class="Mammalia" family="Moschidae" genus="Moschus" kingdom="Animalia" order="Artiodactyla" pageId="2" pageNumber="345" phylum="Chordata" rank="genus">Moschus</taxonomicName>
cuprousl. 5 Black Musk-deer (
<taxonomicName id="4C6F28C5FFB8F05EF99DF2821FB7F29E" box="[1580,1758,3395,3416]" class="Mammalia" family="Moschidae" genus="Moschus" kingdom="Animalia" order="Artiodactyla" pageId="2" pageNumber="345" phylum="Chordata" rank="species" species="fuscus">Moschus fuscus</taxonomicName>
