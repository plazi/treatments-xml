<subSubSection id="C30E653FC67DA20FFC07F415FAB448AA" pageId="11" pageNumber="238" type="reference_group">
<paragraph id="8BAB36B4C67DA20FFC07F415FAB448AA" blockId="11.[1020,1819,2747,3315]" pageId="11" pageNumber="238">
<taxonomicName id="4C144D37C67DA20FFC07F415FAB248F0" authorityName="Thong, Puechmaille, Denzinger, Dietz, Csorba, Bates, Teeling &amp; Schnitzler" authorityYear="2012" box="[1023,1373,2959,2998]" class="Mammalia" family="Hipposideridae" genus="Hipposideros" kingdom="Animalia" order="Chiroptera" pageId="11" pageNumber="238" phylum="Chordata" rank="species" species="griffini">Hipposideros griffini</taxonomicName>
