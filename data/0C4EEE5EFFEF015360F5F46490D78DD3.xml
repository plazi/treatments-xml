<taxonomicName id="43E724CBFFEF01536633F63A96178D73" baseAuthorityName="KIMOTO" baseAuthorityYear="2003" box="[1281,1382,1594,1617]" class="Insecta" family="Chrysomelidae" genus="Acroxena" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFEF01536633F63A96178D73" box="[1281,1382,1594,1617]" italics="true" pageId="13" pageNumber="36">Acroxena</emphasis>
</taxonomicName>
with 
<taxonomicName id="43E724CBFFEF0153600EF65A90C28D53" authorityName="Thunberg" authorityYear="1814" box="[828,947,1626,1649]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFEF0153600EF65A90C28D53" box="[828,947,1626,1649]" italics="true" pageId="13" pageNumber="36">Taumacera</emphasis>
</taxonomicName>
, 
<taxonomicName id="43E724CBFFEF0153608DF65A96568D53" authority="Kimoto, 1989" authorityName="Kimoto" authorityYear="1989" box="[959,1319,1626,1649]" class="Insecta" family="Chrysomelidae" genus="Acroxena" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="femoralis">
<emphasis id="B693835AFFEF0153608DF65A97FE8D53" box="[959,1167,1626,1649]" italics="true" pageId="13" pageNumber="36">Acroxena femoralis</emphasis>
<bibRefCitation id="E07622B9FFEF015367A6F65A96568D53" author="KIMOTO S." box="[1172,1319,1626,1649]" firstAuthor="Kimoto" journalOrPublisher="Esakia" pageId="13" pageNumber="36" pagination="1 - 241" part="27" refId="ref31672" refString="KIMOTO S. 1989: Chrysomelidae (Coleoptera) of Thailand, Cambodia, Laos and Vietnam. IV. Galerucinae. Esakia 27: 1 - 241." title="Chrysomelidae (Coleoptera) of Thailand, Cambodia, Laos and Vietnam. IV. Galerucinae" type="journal article" year="1989">Kimoto, 1989</bibRefCitation>
</taxonomicName>
becomes a junior secondary homonym of 
<taxonomicName id="43E724CBFFEF015367B3F67A96EC8DB3" authority="(Allard, 1889)" baseAuthorityName="Allard" baseAuthorityYear="1889" box="[1153,1437,1658,1681]" class="Insecta" family="Chrysomelidae" genus="Acroxena" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="femoralis">
<emphasis id="B693835AFFEF015367B3F67A978E8DB3" box="[1153,1279,1658,1681]" italics="true" pageId="13" pageNumber="36">T. femoralis</emphasis>
(
<bibRefCitation id="E07622B9FFEF0153663EF67A96E48DB3" author="ALLARD E." box="[1292,1429,1658,1681]" firstAuthor="Allard" journalOrPublisher="Bulletin ou Comptes-Rendus des Seances de la Societe Entomologique de Belgique" pageId="13" pageNumber="36" pagination="lxvi-lxxxiii" part="1889" refId="ref30146" refString="ALLARD E. 1889 a: Note sur les galerucides, coleopteres phytophages. Bulletin ou Comptes-Rendus des Seances de la Societe Entomologique de Belgique 1889: lxvi-lxxxiii." title="Note sur les galerucides, coleopteres phytophages" type="journal volume" year="1889">Allard, 1889</bibRefCitation>
)
</taxonomicName>
(nowadays synonym of 
<taxonomicName id="43E724CBFFEF0153670FF69A961E8D93" authority="(Jacoby, 1881))" authorityName="Jacoby" authorityYear="1881" baseAuthorityName="Jacoby" baseAuthorityYear="1881" box="[1085,1391,1690,1713]" class="Insecta" family="Chrysomelidae" genus="Neocharis" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="fulvicollis">
<emphasis id="B693835AFFEF0153670FF69A97B08D93" box="[1085,1217,1690,1713]" italics="true" pageId="13" pageNumber="36">T. fulvicollis</emphasis>
(
<bibRefCitation id="E07622B9FFEF015367FDF69A962D8D93" author="JACOBY M." box="[1231,1372,1690,1713]" firstAuthor="Jacoby" journalOrPublisher="Proceedings of the Zoological Society of London" pageId="13" pageNumber="36" pagination="439 - 450" part="1881" refId="ref31060" refString="JACOBY M. 1881: Descriptions of new genera and species of phytophagous Coleoptera. Proceedings of the Zoological Society of London 1881: 439 - 450." title="Descriptions of new genera and species of phytophagous Coleoptera" type="journal article" year="1881">Jacoby, 1881</bibRefCitation>
))
</taxonomicName>
and is replaced here with a new substitute name 
<taxonomicName id="43E724CBFFEF0153661CF6BA96ED8DF3" authorityName="Bezděk" authorityYear="2019" box="[1326,1436,1722,1745]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="kimotoi" status="nom. nov.">
<emphasis id="B693835AFFEF0153661CF6BA96ED8DF3" box="[1326,1436,1722,1745]" italics="true" pageId="13" pageNumber="36">T. kimotoi</emphasis>
</taxonomicName>
<taxonomicNameLabel id="ADA03E21FFEF0153600EF6DA90D78DD3" box="[828,934,1754,1777]" pageId="13" pageNumber="36">nom. nov.</taxonomicNameLabel>
