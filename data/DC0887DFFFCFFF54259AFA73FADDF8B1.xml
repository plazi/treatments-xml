<emphasis id="66D5EADBFFCCFF54259AFB8FFE9BFBC5" bold="true" box="[151,278,1075,1099]" pageId="2" pageNumber="549">FIGURE 1.</emphasis>
<taxonomicName id="93A14D4AFFCCFF542413FB8FFD55FBC5" authority="Bousfield &amp; Hendrycks, 1994" authorityName="Bousfield &amp; Hendrycks" authorityYear="1994" box="[286,728,1075,1099]" class="Malacostraca" family="Pleustidae" kingdom="Animalia" order="Amphipoda" pageId="2" pageNumber="548" phylum="Arthropoda" rank="subFamily" subFamily="Eosymtinae">
Eosymtinae 
<bibRefCitation id="30304B38FFCCFF542492FB8FFD55FBC5" author="Bousfield, E. L. &amp; Hendrycks, E. A." box="[415,728,1075,1099]" pageId="2" pageNumber="549" pagination="17 - 57" refId="ref6232" refString="Bousfield, E. L. &amp; Hendrycks, E. A. (1994) A revision of family Pleustidae (Amphipoda: Gammaridea). Part 1. Systematics and biogeography of component subfamilies. Amphipacifica, 1 (1), 17 - 57." type="journal article" year="1994">Bousfield &amp; Hendrycks, 1994</bibRefCitation>
</taxonomicName>
, lateral view: a— 
<taxonomicName id="93A14D4AFFCCFF54269EFB88FA10FBC5" authority="Bousfield and Hendrycks, 1994" authorityName="Bousfield and Hendrycks" authorityYear="1994" box="[915,1437,1075,1099]" class="Malacostraca" family="Pleustidae" genus="Eosymtes" kingdom="Animalia" order="Amphipoda" pageId="2" pageNumber="549" phylum="Arthropoda" rank="species" species="minutus">
<emphasis id="66D5EADBFFCCFF54269EFB88FBC6FBC5" box="[915,1099,1076,1099]" italics="true" pageId="2" pageNumber="549">Eosymtes minutus</emphasis>
<bibRefCitation id="30304B38FFCCFF542159FB8FFA10FBC5" author="Bousfield, E. L. &amp; Hendrycks, E. A." box="[1108,1437,1075,1099]" pageId="2" pageNumber="549" pagination="17 - 57" refId="ref6232" refString="Bousfield, E. L. &amp; Hendrycks, E. A. (1994) A revision of family Pleustidae (Amphipoda: Gammaridea). Part 1. Systematics and biogeography of component subfamilies. Amphipacifica, 1 (1), 17 - 57." type="journal article" year="1994">Bousfield and Hendrycks, 1994</bibRefCitation>
</taxonomicName>
(from 
<bibRefCitation id="30304B38FFCCFF5425D4FBEBFD96FBE1" author="Bousfield, E. L. &amp; Hendrycks, E. A." box="[217,539,1111,1135]" pageId="2" pageNumber="549" pagination="17 - 57" refId="ref6232" refString="Bousfield, E. L. &amp; Hendrycks, E. A. (1994) A revision of family Pleustidae (Amphipoda: Gammaridea). Part 1. Systematics and biogeography of component subfamilies. Amphipacifica, 1 (1), 17 - 57." type="journal article" year="1994">Bousfield and Hendrycks 1994</bibRefCitation>
: fig. 7), b— 
<taxonomicName id="93A14D4AFFCCFF542796FBE4FC1AFBE1" authority="Labay, 2022" authorityName="Labay" authorityYear="2022" box="[667,919,1111,1135]" class="Malacostraca" family="Pleustidae" genus="Eosymtes" kingdom="Animalia" order="Amphipoda" pageId="2" pageNumber="549" phylum="Arthropoda" rank="species" species="magnumoculis" status="sp. nov.">
<emphasis id="66D5EADBFFCCFF542796FBE4FC1AFBE1" box="[667,919,1111,1135]" italics="true" pageId="2" pageNumber="549">Eosymtes magnumoculis</emphasis>
</taxonomicName>
<emphasis id="66D5EADBFFCCFF542693FBEBFC7DFBE1" bold="true" box="[926,1008,1111,1135]" pageId="2" pageNumber="549">
<taxonomicNameLabel id="7DE657A0FFCCFF542693FBEBFC7DFBE1" box="[926,1008,1111,1135]" pageId="2" pageNumber="549" rank="species">sp. nov.</taxonomicNameLabel>
