<taxonomicName id="93A14D4AFFCCFF542129FBEBFF47FB1D" authority="Labay, 2018" authorityName="Labay" authorityYear="2018" class="Malacostraca" family="Pleustidae" genus="Cognateosymtes" kingdom="Animalia" order="Amphipoda" pageId="2" pageNumber="549" phylum="Arthropoda" rank="species" species="serraticoxae">
