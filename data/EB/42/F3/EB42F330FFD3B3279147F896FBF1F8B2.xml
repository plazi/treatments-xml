<paragraph blockId="4.[605,983,1811,1873]" box="[667,921,1847,1873]" pageId="4" pageNumber="5">
<figureCitation box="[667,730,1847,1873]" captionStart="Fig" captionStartId="5.[189,232,1885,1911]" captionTargetBox="[193,1398,811,1840]" captionTargetId="figure-141@5.[189,1398,807,1843]" captionTargetPageId="5" captionText="Fig. 1. Type specimens of M. lutko Evans, 1932, M. mimetica Higgins, 1940, and M. timandra Coutsis &amp; van Oorschot, 2014. A, C, E. UPS. B, D, F. UNS. A–B. M. lutko, holotype, ♂ (BMNH). C– D. M. mimetica, paratype, ♀ (BMNH). E–F. M. timandra, holotype, ♂ (ZMA). A–D photos by A. Devyatkin; E–F, by Eulalia Gasso Miracle." figureDoi="http://doi.org/10.5281/zenodo.6839849" httpUri="https://zenodo.org/record/6839849/files/figure.png" pageId="4" pageNumber="5">Fig. 1</figureCitation>
–30, 
<tableCitation box="[793,921,1847,1873]" captionStart-0="Table 1" captionStart-1="Table 2" captionStart-2="Table 3" captionStart-3="Table 4" captionStart-4="Table 5" captionStart-5="Table 6" captionStartId-0="14.[189,259,265,291]" captionStartId-1="21.[189,259,265,291]" captionStartId-2="29.[189,259,265,291]" captionStartId-3="35.[189,259,265,291]" captionStartId-4="36.[190,260,265,291]" captionStartId-5="40.[189,259,265,291]" captionText-0="Table 1. Measurements of the egg of M. mimetica Higgins, 1940." captionText-1="Table 2. Measurements of the egg of M. timandra timandra Coutsis &amp; van Oorschot, 2014." captionText-2="Table 3. Measurements of the egg of M. timandra binaludica subsp. nov." captionText-3="Table 4. Measurements of the egg of M. shahvarica sp. nov." captionText-4="Table 5. Distance between the bristles on the head capsule of M. shahvarica sp. nov." captionText-5="Table 6. Distance between the bristles on the head capsule of M. timandra binaludica subsp. nov." pageId="4" pageNumber="5">Tables 1–6</tableCitation>
