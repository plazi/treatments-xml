<location LSID="urn:lsid:plazi:treatment:EB5287DFDF73B30F2799FC5DFCAB2263:66246012DF73B30F26D6FA37FC8D20D7" box="[455,836,1476,1502]" country="United Kingdom" name="University of Granada Herbarium" pageId="3" pageNumber="138">University of Granada Herbarium</location>
