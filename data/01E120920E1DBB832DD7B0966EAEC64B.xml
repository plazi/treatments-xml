<taxonomicName id="4B9B0CE0146561A122293B0651A0D9FE" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Senecio" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="503" phylum="Tracheophyta" rank="species" species="silvaticus">
