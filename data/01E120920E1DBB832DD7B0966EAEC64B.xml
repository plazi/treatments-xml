<subSubSection id="3E4D7AE66B5F5FC45BEAA794E0AB5004" pageId="null" pageNumber="503" type="vernacular_names">
<paragraph id="17BBD520EE7CFD3DECC38C81234865B1" pageId="null" pageNumber="503">Wald-Kreuzkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="C7F0AD0A6F12F80B989A1670C1CEC55D" pageId="null" pageNumber="503" type="description">
<paragraph id="2E6A97695AB59763EA1C9DC8579B909D" pageId="null" pageNumber="503">
15-80 cm hoch. 
<normalizedToken id="533EE459D5B4519DAE5B86117FA31D3C" originalValue="Blätter" pageId="null" pageNumber="503">Blaetter</normalizedToken>
zerstreut spinnwebig behaart und mit 
<normalizedToken id="90C8CF7EA45DA08BF8669D4768C6633A" originalValue="drüsenlosen" pageId="null" pageNumber="503">druesenlosen</normalizedToken>
, mehrzelligen Haaren, erst im Alter verkahlend, jederseits bis fast auf den Mittelnerv fiederteilig, 
<emphasis id="216572F2A81746DEAA08FE740E432E06" italics="true" pageId="null" pageNumber="503">
die obern 
<normalizedToken id="372FDDA1A137FCFBDC1F00599AE0BC80" originalValue="Blätter" pageId="null" pageNumber="503">Blaetter</normalizedToken>
am Grunde mit spitzen, schmalen Zipfeln. 
<normalizedToken id="D6CF5FDE4BD917F5886F4F24F6B39B8E" originalValue="Blütenköpfe" pageId="null" pageNumber="503">Bluetenkoepfe</normalizedToken>
im Durchmesser 0,4
</emphasis>
- 
<emphasis id="E9E3DB6ABB2CA1A985DF6E76E0846F63" italics="true" pageId="null" pageNumber="503">0,6 cm.</emphasis>
<normalizedToken id="6097A6390BF985223F87873C3D4C0FBE" originalValue="Hülle" pageId="null" pageNumber="503">Huelle</normalizedToken>
zylindrisch, 6-8 mm lang und 
<emphasis id="C55A59B2244DE6B88E0293217943D3BA" italics="true" pageId="null" pageNumber="503">ca. 3 mm dick</emphasis>
, 
<normalizedToken id="58EABA2D3B8C7BA5C1D9AD8DEF772A01" originalValue="außen" pageId="null" pageNumber="503">aussen</normalizedToken>
von einzelnen 
<emphasis id="A7FEBCEC536BB8F93D1090834DECA26C" italics="true" pageId="null" pageNumber="503">2</emphasis>
- 
<emphasis id="8F6794DE9F78FE21F11D09DFD5B85E70" italics="true" pageId="null" pageNumber="503">
3 mm langen 
<normalizedToken id="CE6098DB16447376B5D583A127A075DE" originalValue="Blättern" pageId="null" pageNumber="503">Blaettern</normalizedToken>
</emphasis>
umgeben. 
<emphasis id="9A67C8320C4E3185B512906707173DC9" italics="true" pageId="null" pageNumber="503">
Innere 
<normalizedToken id="22DEACB1C64369FC162CCB3B1EC287AE" originalValue="Hüllblätter" pageId="null" pageNumber="503">Huellblaetter</normalizedToken>
ca. 15
</emphasis>
, mit einzelnen mehrzelligen Haaren. 
<normalizedToken id="96405B836533B77BAB7C404E5ACFDF21" originalValue="Randständige" pageId="null" pageNumber="503">Randstaendige</normalizedToken>
Kronen ca. 15, meist 
<normalizedToken id="05BE60906CD06DACA380024EDEB984A3" originalValue="zungenförmig" pageId="null" pageNumber="503">zungenfoermig</normalizedToken>
, 
<emphasis id="777A723068DBBF5B2666866AF5606460" italics="true" pageId="null" pageNumber="503">
kaum 
<normalizedToken id="92C2E56DE43FD48B5803DF3B9B7F8FF2" originalValue="länger" pageId="null" pageNumber="503">laenger</normalizedToken>
als die 
<normalizedToken id="94FBFD15F9A0769E6D8BF5176DE9D27F" originalValue="Hülle" pageId="null" pageNumber="503">Huelle</normalizedToken>
</emphasis>
(
<emphasis id="A924585D4245CD1F658F6892D612CEB7" italics="true" pageId="null" pageNumber="503">etwa 0,5 cm lang</emphasis>
), 
<emphasis id="4F1EF7E4CDA4C1D577FDE22E48DDB68E" italics="true" pageId="null" pageNumber="503">
mit 
<normalizedToken id="3B148A3E19090706834A307C4CA914C1" originalValue="zurückgerollter" pageId="null" pageNumber="503">zurueckgerollter</normalizedToken>
Zunge.
</emphasis>
<normalizedToken id="F8CBF367B40B673092F5BC2BC50A5076" originalValue="Früchte" pageId="null" pageNumber="503">Fruechte</normalizedToken>
2-3 mm lang. 
<taxonomicName id="A99F4CC95BCDF9981AF587D1B3C98B93" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="503" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
ca. 5 mm lang. - 
<normalizedToken id="6779EDA3DC4A1374AAE4276B37F33C86" originalValue="Blüte" pageId="null" pageNumber="503">Bluete</normalizedToken>
: Sommer, 
<normalizedToken id="320F660BF41F5188AAEAD9CD152B6CB5" originalValue="früher" pageId="null" pageNumber="503">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="CF27B8DBCC8AE2882BAD3499767FD4C0" pageId="null" pageNumber="503">
<emphasis id="B1C08B3754A94E90F1DDA169F1712847" italics="true" pageId="null" pageNumber="503">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="CF4B7281F41A547EAD19413A06FBC2EF" italics="true" pageId="null" pageNumber="503">40:</emphasis>
Material aus botanischen 
<normalizedToken id="456603EA968F1A17B943A95B81B590CE" originalValue="Gärten" pageId="null" pageNumber="503">Gaerten</normalizedToken>
(Afzelius 1924), aus Nordamerika (Ornduff et al. 1963, Palmblad 1965, Taylor und Mulligan 1968).
</paragraph>
<paragraph id="D5B3CAFF06FCD81EE07D535819727C78" pageId="null" pageNumber="503">
<emphasis id="88C9D6C7EE655FE5537287B4B5EBE553" italics="true" pageId="null" pageNumber="503">Standort.</emphasis>
Kollin und montan, selten subalpin. 
<normalizedToken id="3C591F6F8F8153F77494015C8358A0FA" originalValue="Mäßig" pageId="null" pageNumber="503">Maessig</normalizedToken>
feuchte, lockere, 
<normalizedToken id="7BF5A08085B3B1D5227A862ECD12D2BF" originalValue="nährstoffreiche" pageId="null" pageNumber="503">naehrstoffreiche</normalizedToken>
, meist kalkarme, humose 
<normalizedToken id="C72CA62F62FF56F9E48E37023B8974A9" originalValue="Böden" pageId="null" pageNumber="503">Boeden</normalizedToken>
. 
<normalizedToken id="52D9763B06157F8CBCA7680BA440C577" originalValue="Waldschläge" pageId="null" pageNumber="503">Waldschlaege</normalizedToken>
, Waldwege.
</paragraph>
<paragraph id="66D12F5FE68ED98A675068781398EF74" pageId="null" pageNumber="503">
<emphasis id="B464746362E7AB3783C4BEAF19802445" italics="true" pageId="null" pageNumber="503">Verbreitung. Eurasiatische Pflanze:</emphasis>
<normalizedToken id="654F3A3C50ECB82773F0049AAB7C19E6" originalValue="Nordwärts" pageId="null" pageNumber="503">Nordwaerts</normalizedToken>
bis Orkneys, 
<normalizedToken id="2E0EDAD6AE8E0445C404BDC71F7E4D80" originalValue="Südskandinavien" pageId="null" pageNumber="503">Suedskandinavien</normalizedToken>
, Karelien; 
<normalizedToken id="61BA6067566450829057375CDC86B0D8" originalValue="ostwärts" pageId="null" pageNumber="503">ostwaerts</normalizedToken>
bis Ostasien; 
<normalizedToken id="E0D7D77C08493131AFADC0285F106F77" originalValue="südwärts" pageId="null" pageNumber="503">suedwaerts</normalizedToken>
bis Spanien, Mittelitalien, Serbien, Bulgarien; in Amerika eingeschleppt. - Im Gebiet ziemlich verbreitet, stellenweise 
<normalizedToken id="BFC65809EBD3EA2B5F284D4C18B348D7" originalValue="häufig" pageId="null" pageNumber="503">haeufig</normalizedToken>
; 
<normalizedToken id="ACB9603EEFA2D146CC6DEE43838D9522" originalValue="unbeständig" pageId="null" pageNumber="503">unbestaendig</normalizedToken>
.
</paragraph>
</subSubSection>
