<quantity id="036C9B1BFFE66A59F74D97991714BAD3" box="[2225,2324,448,481]" metricMagnitude="3" metricUnit="m" metricValue="1.286" pageId="29" pageNumber="787" unit="m" value="1286.0">1286 m</quantity>
