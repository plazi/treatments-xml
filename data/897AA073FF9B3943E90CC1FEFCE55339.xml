<subSubSection id="49C942EEFF9B3943EBD2C023FCE55339" pageId="53" pageNumber="54" type="discussion">
<paragraph id="016C1165FF9B3943EBD2C023FEAA5C1C" blockId="53.[227,341,1808,1834]" box="[227,341,1808,1834]" pageId="53" pageNumber="54">
<heading id="5A24A609FF9B3943EBD2C023FEAA5C1C" bold="true" box="[227,341,1808,1834]" fontSize="11" level="3" pageId="53" pageNumber="54" reason="3">
<emphasis id="33A7CD77FF9B3943EBD2C023FEAA5C1C" bold="true" box="[227,341,1808,1834]" pageId="53" pageNumber="54">Remarks</emphasis>
</heading>
</paragraph>
<paragraph id="016C1165FF9B3943EBD2C00CFCE55339" blockId="53.[225,1437,1855,2063]" pageId="53" pageNumber="54">
The 
<taxonomicName id="C6D36AE6FF9B3943EA26C00CFE5E5C6F" authorityName="Goode &amp; Bean" authorityYear="1885" box="[279,417,1855,1881]" class="Actinopterygii" family="Ophidiidae" genus="Neobythites" kingdom="Animalia" order="Ophidiiformes" pageId="53" pageNumber="54" phylum="Chordata" rank="genus">
<emphasis id="33A7CD77FF9B3943EA26C00CFE5E5C6F" box="[279,417,1855,1881]" italics="true" pageId="53" pageNumber="54">Neobythites</emphasis>
</taxonomicName>
-like otolith group includes three American species that are more closely related to each other than to anything else, and correspond to the extinct genus 
<taxonomicName id="C6D36AE6FF9B3943E8DFC050FA625C48" authority="Schwarzhans, 1981" authorityName="Schwarzhans" authorityYear="1981" box="[1006,1437,1891,1918]" class="Actinopterygii" family="Phycidae" genus="Symmetrosulcus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Gadiformes" pageId="53" pageNumber="54" phylum="Chordata" rank="genus">
<emphasis id="33A7CD77FF9B3943E8DFC050FB535C4B" box="[1006,1196,1891,1917]" italics="true" pageId="53" pageNumber="54">Symmetrosulcus</emphasis>
<bibRefCitation id="65426C94FF9B3943EF84C050FA625C48" author="Schwarzhans W." box="[1205,1437,1891,1918]" pageId="53" pageNumber="54" pagination="77 - 91" refId="ref56652" refString="Schwarzhans W. 1981 a. Die Entwicklung der Familie Pterothrissidae (Elopomorpha; Pisces), rekonstruiert nach Otolithen. Senckenbergiana lethaea 62 (2 - 6): 77 - 91." type="journal article" year="1981">Schwarzhans, 1981</bibRefCitation>
</taxonomicName>
(
<typeStatus id="DE68AFC7FF9B3943EBDAC0BBFEE05C94" box="[235,287,1928,1954]" pageId="53" pageNumber="54">type</typeStatus>
species: 
<taxonomicName id="C6D36AE6FF9B3943EAB8C0BBFC515C94" authority="Schubert, 1916" authorityName="Schubert" authorityYear="1916" box="[393,942,1927,1954]" class="Actinopterygii" family="Sciaenidae" genus="Otolithus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Perciformes" pageId="53" pageNumber="54" phylum="Chordata" rank="species" species="dimidiatus" subGenus="Ophidiidarum">
<emphasis id="33A7CD77FF9B3943EAB8C0BBFE515C94" box="[393,430,1928,1954]" italics="true" pageId="53" pageNumber="54">Ot.</emphasis>
(
<emphasis id="33A7CD77FF9B3943EA8EC0BBFD9A5C94" box="[447,613,1928,1954]" italics="true" pageId="53" pageNumber="54">Ophidiidarum</emphasis>
) 
<emphasis id="33A7CD77FF9B3943E947C0BBFD0D5C94" box="[630,754,1928,1954]" italics="true" pageId="53" pageNumber="54">dimidiatus</emphasis>
Schubert, 1916
</taxonomicName>
). They are: 
<taxonomicName id="C6D36AE6FF9B3943EF07C0BBFB465C94" authority="Lin &amp; Nolf &amp; Steurbaut, 2022" authorityName="Lin &amp; Nolf &amp; Steurbaut" authorityYear="2022" box="[1078,1209,1928,1954]" class="Actinopterygii" family="Phycidae" genus="Symmetrosulcus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Gadiformes" pageId="53" pageNumber="54" phylum="Chordata" rank="species" species="dockeryi" status="sp. nov.">
<emphasis id="33A7CD77FF9B3943EF07C0BBFB465C94" box="[1078,1209,1928,1954]" italics="true" pageId="53" pageNumber="54">S. dockeryi</emphasis>
</taxonomicName>
<taxonomicNameLabel id="2894700CFF9B3943EF8EC0BBFAE35C94" box="[1215,1308,1928,1954]" pageId="53" pageNumber="54" rank="species">sp. nov.</taxonomicNameLabel>
, 
<taxonomicName id="C6D36AE6FF9B3943EE16C0BBFDF25CF1" authority="(Dante &amp; Frizzell, 1965)" baseAuthorityName="Dante &amp; Frizzell" baseAuthorityYear="1965" class="Actinopterygii" family="Phycidae" genus="Symmetrosulcus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Gadiformes" pageId="53" pageNumber="54" phylum="Chordata" rank="species" species="stintoni">
<emphasis id="33A7CD77FF9B3943EE16C0BBFA635C97" box="[1319,1436,1928,1954]" italics="true" pageId="53" pageNumber="54">S. stintoni</emphasis>
(Dante &amp; 
<bibRefCitation id="65426C94FF9B3943EA6AC09FFDFC5CF1" author="Frizzell D. L." box="[347,515,1964,1991]" pageId="53" pageNumber="54" pagination="85 - 110" refId="ref53928" refString="Frizzell D. L. 1965. Otolith-based genera and lineages of fossil bonefishes (Clupeiformes, Albulidae). Senckenbergiana Lethaea 46 a: 85 - 110." type="book chapter" year="1965">Frizzell, 1965</bibRefCitation>
)
</taxonomicName>
, and 
<taxonomicName id="C6D36AE6FF9B3943E97EC09FFC895CF0" authority="(Koken, 1888)" baseAuthorityName="Koken" baseAuthorityYear="1888" box="[591,886,1964,1990]" class="Actinopterygii" family="Phycidae" genus="Symmetrosulcus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Gadiformes" pageId="53" pageNumber="54" phylum="Chordata" rank="species" species="meyeri">
<emphasis id="33A7CD77FF9B3943E97EC09FFD435CF0" box="[591,700,1964,1990]" italics="true" pageId="53" pageNumber="54">S. meyeri</emphasis>
(
<bibRefCitation id="65426C94FF9B3943E9FCC09FFC935CF0" author="Koken" box="[717,876,1964,1990]" firstAuthor="Koken" pageId="53" pageNumber="54" pagination="274 - 305" refId="ref54599" refString="Koken E. 1888. Neue Untersuchungen an tertiaren Fisch-Otolithen. Zeitschrift der deutschen geologischen Gesellschaft 40: 274 - 305." type="journal article" year="1888">Koken, 1888</bibRefCitation>
)
</taxonomicName>
. The European 
<taxonomicName id="C6D36AE6FF9B3943EF02C09FFA635CF1" authority="(Schubert, 1916)" baseAuthorityName="Schubert" baseAuthorityYear="1916" box="[1075,1436,1964,1991]" class="Actinopterygii" family="Sciaenidae" genus="Otolithus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Perciformes" pageId="53" pageNumber="54" phylum="Chordata" rank="species" species="dimidiatus">
<emphasis id="33A7CD77FF9B3943EF02C09FFB315CF0" box="[1075,1230,1964,1990]" italics="true" pageId="53" pageNumber="54">S. dimidiatus</emphasis>
(Schubert, 1916)
</taxonomicName>
from the Bartonian of southern 
<collectingCountry id="79C451F5FF9B3943E97CC0E3FD505CDC" box="[589,687,2000,2026]" name="United Kingdom" pageId="53" pageNumber="54">England</collectingCountry>
and 
<taxonomicName id="C6D36AE6FF9B3943E9D1C0E3FC455CDC" authority="Nolf, 1980" authorityName="Nolf" authorityYear="1980" box="[736,954,2000,2026]" class="Actinopterygii" family="Phycidae" genus="Symmetrosulcus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Gadiformes" pageId="53" pageNumber="54" phylum="Chordata" rank="species" species="fitchi">
<emphasis id="33A7CD77FF9B3943E9D1C0E3FCC95CDC" box="[736,822,2000,2026]" italics="true" pageId="53" pageNumber="54">S. fitchi</emphasis>
<bibRefCitation id="65426C94FF9B3943E80CC0E3FC455CDC" author="Nolf" box="[829,954,2000,2026]" firstAuthor="Nolf" pageId="53" pageNumber="54" pagination="71 - 195" refId="ref55640" refString="Nolf D. 1980. Etude monographique des otolithes des Ophidiiformes actuels et revision des especes fossiles (Pisces, Teleostei). Mededelingen van de Werkgroep voor Tertiaire en Kwartaire Geologie 17 (2): 71 - 195." type="journal article" year="1980">Nolf, 1980</bibRefCitation>
</taxonomicName>
from the Ypresian Gan Clay of Aquitaine, SW 
<collectingCountry id="79C451F5FF9B3943EA25C0C6FE9B5339" box="[276,356,2037,2063]" name="France" pageId="53" pageNumber="54">France</collectingCountry>
are also closely related to this group.
</paragraph>
