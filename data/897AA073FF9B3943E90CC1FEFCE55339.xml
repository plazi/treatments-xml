Genus 
<taxonomicName id="C6D36AE6FF9B3943E9A1C1FEFBBD5DD1" authority="Schwarzhans, 1981" authorityName="Schwarzhans" authorityYear="1981" box="[656,1090,1741,1768]" class="Actinopterygii" family="Phycidae" genus="Symmetrosulcus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Gadiformes" pageId="53" pageNumber="54" phylum="Chordata" rank="genus">
<emphasis id="33A7CD77FF9B3943E9A1C1FEFCA85DDE" bold="true" box="[656,855,1741,1768]" italics="true" pageId="53" pageNumber="54">Symmetrosulcus</emphasis>
<bibRefCitation id="65426C94FF9B3943E86FC1FEFBBD5DD1" author="Schwarzhans W." box="[862,1090,1741,1767]" pageId="53" pageNumber="54" pagination="77 - 91" refId="ref56652" refString="Schwarzhans W. 1981 a. Die Entwicklung der Familie Pterothrissidae (Elopomorpha; Pisces), rekonstruiert nach Otolithen. Senckenbergiana lethaea 62 (2 - 6): 77 - 91." type="journal article" year="1981">Schwarzhans, 1981</bibRefCitation>
