<subSubSection id="15E49286BD1BC65FD22EB01FFEF955CA" pageId="null" pageNumber="497" type="vernacular_names">
<paragraph id="EF90DD87104E5F0E66A79002CE0B123D" pageId="null" pageNumber="497">Alpen-Goldregen</paragraph>
</subSubSection>
</title>
<subSubSection id="9D0C8DBF8B3D202BD75E72382A58FD84" pageId="null" pageNumber="497" type="description">
<paragraph id="3965316D9438879AC7A69226D5EC3BA3" pageId="null" pageNumber="497">
1,5-4m hoch. 
<emphasis id="05D1265FB1FCE960942787967B105A6B" italics="true" pageId="null" pageNumber="497">
Junge Zweige und 
<normalizedToken id="85FA9CD2E213CBFDFCE6682B59F5D208" originalValue="Blätter" pageId="null" pageNumber="497">Blaetter</normalizedToken>
kahl oder mit einzelnen abstehenden, 0,5-1 mm langen Haaren
</emphasis>
(besonders am Blattrand und unterseits auf den Nerven). 
<normalizedToken id="F99963ED7CB88C4FDBFB51D1B99C491B" originalValue="Teilblätter" pageId="null" pageNumber="497">Teilblaetter</normalizedToken>
lanzettlich, oberseits 
<normalizedToken id="FC0EAC2597F0511B5267AEA62F46B5C1" originalValue="dunkelgrün" pageId="null" pageNumber="497">dunkelgruen</normalizedToken>
. 
<emphasis id="BDE5563898DB6ACCF36E511B21118D05" italics="true" pageId="null" pageNumber="497">
<normalizedToken id="1F63D79EC77397FC3E59DD5F219512A8" originalValue="Blütenstiele" pageId="null" pageNumber="497">Bluetenstiele</normalizedToken>
und Kelch mit 0,5-1 mm langen, meist abstehenden Haaren. Krone 1,4 bis 1,7 cm lang. Frucht kahl, 2-5
</emphasis>
cm lang und 0,6-1 cm breit, 
<emphasis id="EE9C379046324BD525A1D33CE3A5833C" italics="true" pageId="null" pageNumber="497">
am obern Rand 
<normalizedToken id="AEA12A0AC45DFF5E79C6F2048E8042EF" originalValue="geflügelt" pageId="null" pageNumber="497">gefluegelt</normalizedToken>
</emphasis>
(
<normalizedToken id="98C6D86A9EE7CB45CD689E382C167393" originalValue="Flügel" pageId="null" pageNumber="497">Fluegel</normalizedToken>
bis 2 mm breit). - 
<normalizedToken id="FC247984E92E03C0CF6866FCC43A54BC" originalValue="Blüte" pageId="null" pageNumber="497">Bluete</normalizedToken>
: 
<normalizedToken id="BAB77563040554842715C79178D898F7" originalValue="Früher" pageId="null" pageNumber="497">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="66CF7303FED0E6FE95B9C75CA08A6B86" pageId="null" pageNumber="497">
<emphasis id="6EB858ADFB967143800829356E243A10" italics="true" pageId="null" pageNumber="497">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D7C2F9DE3463A868093971092D1A763A" italics="true" pageId="null" pageNumber="497">48:</emphasis>
Material aus botanischen 
<normalizedToken id="4519E7D50D51753498E725097BCF6B24" originalValue="Gärten" pageId="null" pageNumber="497">Gaerten</normalizedToken>
(Tschechow 1931, Gilot 1965).
</paragraph>
<paragraph id="6A0D9C26D413765EFBDF55F03626F322" pageId="null" pageNumber="497">
<emphasis id="92C0FEFC6ADFCFCA4F91A81BF3FF5245" italics="true" pageId="null" pageNumber="497">Standort.</emphasis>
Kollin und montan, selten subalpin. Steinige, nicht zu trockene 
<normalizedToken id="A1581CEA220802738EC6CD74186CBA8A" originalValue="Böden" pageId="null" pageNumber="497">Boeden</normalizedToken>
in warmen Lagen. Lichte 
<normalizedToken id="B929BA6670B28CFDE5C19E7B6FB106B6" originalValue="Wälder" pageId="null" pageNumber="497">Waelder</normalizedToken>
, buschige 
<normalizedToken id="D479555E12666113EB0AC6EC43840936" originalValue="Hänge" pageId="null" pageNumber="497">Haenge</normalizedToken>
, Felsen.
</paragraph>
<paragraph id="ACD40F764C74CE13796648B49E0B64A1" pageId="null" pageNumber="497">
<emphasis id="B104EDE7C3665DAD2EDCEE572D804391" italics="true" pageId="null" pageNumber="497">
Verbreitung. Mittel- und 
<normalizedToken id="3F32D60B55FF436B83B123E7DB926E09" originalValue="südeuropäische" pageId="null" pageNumber="497">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="FCC8B00AE8796C5D03C79427B4DF2AA0" italics="true" pageId="null" pageNumber="497">
<normalizedToken id="F0FF2340E7FCF04A73D155902E211206" originalValue="östlich" pageId="null" pageNumber="497">oestlich</normalizedToken>
</emphasis>
)
<emphasis id="FA4C723E938FA224932C69392DDE7BC5" italics="true" pageId="null" pageNumber="497">:</emphasis>
<normalizedToken id="520F1691C4FFC1B1BA6ECBED82C7733C" originalValue="Südlicher" pageId="null" pageNumber="497">Suedlicher</normalizedToken>
Jura, 
<normalizedToken id="152FDEA309635C96CDED5FE898113435" originalValue="südliche" pageId="null" pageNumber="497">suedliche</normalizedToken>
Alpen, Apennin (
<normalizedToken id="33927A66564EC135DACC84044A69069F" originalValue="südwärts" pageId="null" pageNumber="497">suedwaerts</normalizedToken>
vereinzelt bis Kalabrien), Istrien, Kroatien, Kleine Karpaten, 
<normalizedToken id="BB8D959F8DE082193C534350B95BF141" originalValue="Südkarpaten" pageId="null" pageNumber="497">Suedkarpaten</normalizedToken>
. - Im Gebiet: 
<normalizedToken id="31CDD8FE5127ECD956A9A657D2442379" originalValue="Südlicher" pageId="null" pageNumber="497">Suedlicher</normalizedToken>
Jura, (
<normalizedToken id="894C6D5B559E83A2CB23D5A51B312659" originalValue="nordostwärts" pageId="null" pageNumber="497">nordostwaerts</normalizedToken>
bis Chaumont), westliche und 
<normalizedToken id="5A46E6C08FABFCED89CD6B30F539DDAF" originalValue="südliche" pageId="null" pageNumber="497">suedliche</normalizedToken>
Alpen (ost- und 
<normalizedToken id="2A62CF25096F88F44AE586C1273721D6" originalValue="nordwärts" pageId="null" pageNumber="497">nordwaerts</normalizedToken>
bis zur Linie Porsei-Montbovon-Saanen-Leuk-Gressoney-Simplon-Onsernone-Roveredo-Bergell-Veltlin); ziemlich 
<normalizedToken id="F35F62F32A51A0F5CA51F79902F54350" originalValue="häufig" pageId="null" pageNumber="497">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
