<taxonomicName class="Mammalia" family="Muridae" genus="Dipodillus" kingdom="Animalia" order="Rodentia" pageId="188" pageNumber="791" phylum="Chordata" rank="species" species="muriculus">Muriculus</taxonomicName>
<taxonomicName authorityName="Ruppell" authorityYear="1842" box="[146,247,1720,1749]" class="Mammalia" family="Muridae" genus="Mus" kingdom="Animalia" order="Rodentia" pageId="188" pageNumber="791" phylum="Chordata" rank="species" species="imberbis">imberbis</taxonomicName>
).
</paragraph>
</subSubSection>
