<subSubSection pageId="255" pageNumber="860" type="activity">
<paragraph blockId="255.[177,1383,1312,2093]" pageId="255" pageNumber="860">
<emphasis bold="true" box="[177,412,1710,1739]" pageId="255" pageNumber="860">Activity patterns.</emphasis>
