<subSubSection pageId="236" pageNumber="841" type="materials_examined">
<paragraph blockId="236.[713,1306,454,877]" pageId="236" pageNumber="841">
<taxonomicName authorityName="Sody" authorityYear="1941" box="[715,901,572,601]" class="Mammalia" family="Muridae" genus="Rattus" kingdom="Animalia" order="Rodentia" pageId="236" pageNumber="841" phylum="Chordata" rank="species" species="pelurus">Rattus pelurus</taxonomicName>
is in the 
<taxonomicName box="[1028,1200,572,601]" class="Mammalia" family="Muridae" genus="Rattus" kingdom="Animalia" order="Rodentia" pageId="236" pageNumber="841" phylum="Chordata" rank="species" species="xanthurus">R. xanthurus</taxonomicName>
species group within 
<taxonomicName box="[907,991,608,642]" class="Mammalia" family="Muridae" genus="Rattus" kingdom="Animalia" order="Rodentia" pageId="236" pageNumber="841" phylum="Chordata" rank="genus">Rattus</taxonomicName>
, although its exact relationship is uncertain and genetic studies are needed. It has been included as a subspecies of 
<taxonomicName box="[867,1042,731,760]" class="Mammalia" family="Muridae" genus="Rattus" kingdom="Animalia" order="Rodentia" pageId="236" pageNumber="841" phylum="Chordata" rank="species" species="xanthurus">R. xanthurus</taxonomicName>
. The 
<taxonomicName box="[1131,1306,731,760]" class="Mammalia" family="Muridae" genus="Rattus" kingdom="Animalia" order="Rodentia" pageId="236" pageNumber="841" phylum="Chordata" rank="species" species="xanthurus">R. xanthurus</taxonomicName>
species group is currently under revision. Monotypic.
</paragraph>
</subSubSection>
<subSubSection pageId="236" pageNumber="841" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6888391" ID-Zenodo-Dep="6888391" httpUri="https://zenodo.org/record/6888391/files/figure.png" inLine="true" pageId="236" pageNumber="841" startId="236.[715,883,848,877]" targetBox="[99,690,462,876]" targetPageId="236">
