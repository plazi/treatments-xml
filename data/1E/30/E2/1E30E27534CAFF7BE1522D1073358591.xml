<taxonomicName authority="Sody, 1941" authorityName="Sody" authorityYear="1941" class="Mammalia" family="Muridae" genus="Rattus" kingdom="Animalia" order="Rodentia" pageId="236" pageNumber="841" phylum="Chordata" rank="subSpecies" species="foramineus" subSpecies="pelurus">Rattus foramineus pelurus Sody, 1941</taxonomicName>
,
