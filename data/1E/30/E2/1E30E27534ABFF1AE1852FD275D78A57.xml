<taxonomicName authority="P. J. Taylor et al., 2011" authorityName="P. J. Taylor" authorityYear="2011" class="Mammalia" family="Muridae" genus="Otomys" kingdom="Animalia" order="Rodentia" pageId="141" pageNumber="742" phylum="Chordata" rank="species" species="yaldeni">Otomys yaldeni P. J. Taylor et al., 2011</taxonomicName>
