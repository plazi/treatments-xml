<taxonomicName authority="Van der Straeten, Lecompte &amp; Denys, 2003" authorityName="Van der Straeten, Lecompte &amp; Denys" authorityYear="2003" box="[265,1074,3403,3432]" class="Mammalia" family="Muridae" genus="Praomys" kingdom="Animalia" order="Rodentia" pageId="207" pageNumber="811" phylum="Chordata" rank="species" species="petteri">
