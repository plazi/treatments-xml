<taxonomicName authorityName="Medway" authorityYear="1965" box="[2061,2355,2396,2425]" class="Mammalia" family="Muridae" genus="Chiropodomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="62" pageNumber="662" phylum="Chordata" rank="species" species="muroides">Chiropodomys muroides</taxonomicName>
