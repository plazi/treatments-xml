<subSubSection pageId="115" pageNumber="715" type="reference_group">
<paragraph blockId="115.[693,1287,612,1040]" pageId="115" pageNumber="715">
<emphasis bold="true" box="[693,848,612,646]" pageId="115" pageNumber="715">Taxonomy.</emphasis>
<taxonomicName authority="Thomas, 1907" authorityName="Thomas" authorityYear="1907" box="[874,1277,612,646]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="anak">Uromys anak Thomas, 1907</taxonomicName>
, 
<materialsCitation ID-GBIF-Occurrence="3864424581" pageId="115" pageNumber="715">“Ifogi [= Efogi], Brown River, N.E. British New Guinea [= Central Province, Papua New Guinea]. Altitude ‘not less than 4000 ft{=1219mj}.’ ©</materialsCitation>
</paragraph>
</subSubSection>
<subSubSection pageId="115" pageNumber="715" type="discussion">
<paragraph blockId="115.[693,1287,612,1040]" pageId="115" pageNumber="715">
Within 
<taxonomicName box="[800,889,818,843]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="genus">Uromys</taxonomicName>
, 
<taxonomicName authorityName="Thomas" authorityYear="1907" box="[906,1004,818,843]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="anak">U. anak</taxonomicName>
is placed under subgenus 
<taxonomicName box="[790,878,853,882]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="genus">Uromys</taxonomicName>
along with U. boeadui, 
<taxonomicName baseAuthorityName="Krefft" baseAuthorityYear="1867" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="caudimaculatus">U. caudimaculatus</taxonomicName>
, 
<taxonomicName authorityName="Groves &amp; Flannery" authorityYear="1994" box="[877,1006,896,921]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="emmae">U. emmae</taxonomicName>
, 
<taxonomicName baseAuthorityName="Winter" baseAuthorityYear="1984" box="[1034,1208,896,921]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="hadrourus">U. hadrourus</taxonomicName>
, and 
<taxonomicName authorityName="Tate &amp; Archbold" authorityYear="1935" box="[698,922,936,961]" class="Mammalia" family="Muridae" genus="Hydromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="neobritannicus">U. neobritannicus</taxonomicName>
, on basis of morphology, 
<taxonomicName authorityName="Thomas" authorityYear="1907" box="[698,798,971,1000]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="anak">U. anak</taxonomicName>
seems to be sister to 
<taxonomicName authorityName="Tate &amp; Archbold" authorityYear="1935" class="Mammalia" family="Muridae" genus="Hydromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="neobritannicus">U. neobritannicus</taxonomicName>
. Three subspecies currently recognized.
</paragraph>
</subSubSection>
<subSubSection pageId="115" pageNumber="715" type="distribution">
