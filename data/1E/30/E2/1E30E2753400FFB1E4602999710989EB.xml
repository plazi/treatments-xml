<paragraph blockId="38.[1366,2574,2023,2808]" box="[1368,1741,2497,2531]" pageId="38" pageNumber="637">
<emphasis bold="true" box="[1368,1502,2497,2531]" pageId="38" pageNumber="637">Breeding.</emphasis>
