<subSubSection pageId="76" pageNumber="676" type="reference_group">
<paragraph blockId="76.[778,1372,1368,1791]" pageId="76" pageNumber="676">
<emphasis bold="true" box="[778,934,1368,1397]" pageId="76" pageNumber="676">Taxonomy.</emphasis>
<taxonomicName authority="Balete, Rickart &amp; Heaney, 2006" authorityName="Balete, Rickart &amp; Heaney" authorityYear="2006" class="Mammalia" family="Muridae" genus="Archboldomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="76" pageNumber="676" phylum="Chordata" rank="species" species="kalinga">Archboldomys kalinga Balete, Rickart &amp; Heaney, 2006</taxonomicName>
