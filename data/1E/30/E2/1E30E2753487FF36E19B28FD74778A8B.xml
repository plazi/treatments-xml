<subSubSection pageId="161" pageNumber="764" type="discussion">
<paragraph blockId="161.[782,1375,1438,1865]" pageId="161" pageNumber="764">
Taxonomy. 
<taxonomicName authority="Thomas &amp; Hinton, 1923" authorityName="Thomas &amp; Hinton" authorityYear="1923" class="Mammalia" family="Muridae" genus="Grammomys" kingdom="Animalia" order="Rodentia" pageId="161" pageNumber="764" phylum="Chordata" rank="species" species="aridulus">Grammomys aridulus Thomas &amp; Hinton, 1923</taxonomicName>
, “Kulme, Wadi Aribo, [Dar-fur, Sudan]. 3300&quot; [= 1005 m].” 
<taxonomicName authorityName="Thomas &amp; Hinton" authorityYear="1923" box="[786,1059,1560,1589]" class="Mammalia" family="Muridae" genus="Grammomys" kingdom="Animalia" order="Rodentia" pageId="161" pageNumber="764" phylum="Chordata" rank="species" species="aridulus">Grammomys aridulus</taxonomicName>
was previously considered a subspecies of 
<taxonomicName authorityName="Wroughton" authorityYear="1907" box="[1083,1266,1599,1628]" class="Mammalia" family="Muridae" genus="Grammomys" kingdom="Animalia" order="Rodentia" pageId="161" pageNumber="764" phylum="Chordata" rank="species" species="macmillani">G. macmillani</taxonomicName>
. Mono-typic.
</paragraph>
</subSubSection>
