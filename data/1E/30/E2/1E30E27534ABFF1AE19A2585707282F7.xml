<subSubSection pageId="141" pageNumber="742" type="reference_group">
<paragraph blockId="141.[783,1376,2581,3003]" pageId="141" pageNumber="742">
<emphasis bold="true" box="[784,939,2581,2610]" pageId="141" pageNumber="742">Taxonomy.</emphasis>
<taxonomicName authority="Thomas, 1918" authorityName="Thomas" authorityYear="1918" box="[958,1367,2581,2610]" class="Mammalia" family="Muridae" genus="Otomys" kingdom="Animalia" order="Rodentia" pageId="141" pageNumber="742" phylum="Chordata" rank="species" species="burtoni">Otomys burtoni Thomas, 1918</taxonomicName>
