FAMILY 
<taxonomicName authority="Plate" authorityName="Plate" box="[188,758,79,111]" class="Mammalia" family="Muridae" kingdom="Animalia" order="Rodentia" pageId="32" pageNumber="631" phylum="Chordata" rank="family">MURIDAE Plate</taxonomicName>
