<paragraph blockId="181.[2042,2662,926,1350]" pageId="181" pageNumber="784">
Taxonomy. 
<taxonomicName authority="Barrett Hamilton, 1900" authorityName="Barrett Hamilton" authorityYear="1900" class="Mammalia" family="Muridae" genus="Mus" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="181" pageNumber="784" phylum="Chordata" rank="subSpecies" species="sylvaticus" subSpecies="draco">Mus sylvaticus draco Barrett Hamilton, 1900</taxonomicName>
