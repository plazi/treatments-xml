<subSubSection box="[1444,2629,2186,2220]" pageId="198" pageNumber="802" type="breeding">
<paragraph blockId="198.[1442,2648,1872,2378]" box="[1444,2629,2186,2220]" pageId="198" pageNumber="802">
<emphasis bold="true" box="[1444,1578,2186,2220]" pageId="198" pageNumber="802">Breeding.</emphasis>
