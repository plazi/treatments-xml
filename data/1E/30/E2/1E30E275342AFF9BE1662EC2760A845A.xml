<subSubSection pageId="12" pageNumber="609" type="discussion">
<paragraph blockId="12.[692,1285,848,1271]" pageId="12" pageNumber="609">
<taxonomicName authorityName="W. Verheyen, Hulselmans, Dierckx &amp; E. Verheyen" authorityYear="2002" box="[694,934,1001,1035]" class="Mammalia" family="Muridae" genus="Lophuromys" kingdom="Animalia" order="Rodentia" pageId="12" pageNumber="609" phylum="Chordata" rank="species" species="dudui">Lophuromys dudui</taxonomicName>
