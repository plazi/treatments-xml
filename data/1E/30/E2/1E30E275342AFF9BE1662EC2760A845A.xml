<paragraph blockId="12.[80,1286,1286,1865]" box="[80,1282,1396,1430]" pageId="12" pageNumber="609">
<emphasis bold="true" box="[80,190,1396,1430]" pageId="12" pageNumber="609">Habitat.</emphasis>
