<taxonomicName baseAuthorityName="True" baseAuthorityYear="1892" box="[879,1014,1080,1114]" class="Mammalia" family="Muridae" genus="Lophuromys" kingdom="Animalia" order="Rodentia" pageId="12" pageNumber="609" phylum="Chordata" rank="species" species="aquilus">L. aquilus</taxonomicName>
(
<taxonomicName authorityName="Thomas" authorityYear="1888" box="[1038,1271,1080,1114]" class="Mammalia" family="Muridae" genus="Lophuromys" kingdom="Animalia" order="Rodentia" pageId="12" pageNumber="609" phylum="Chordata" rank="species" species="flavopunctatus">L. flavopunctatus</taxonomicName>
