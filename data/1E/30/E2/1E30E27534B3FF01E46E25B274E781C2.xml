<taxonomicName authority="Lavrenchenko, 2003" authorityName="Lavrenchenko" authorityYear="2003" class="Mammalia" family="Muridae" genus="Desmomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="149" pageNumber="751" phylum="Chordata" rank="species" species="yaldeni">Desmomys yaldeni Lavrenchenko, 2003</taxonomicName>
