<subSubSection box="[170,836,455,484]" pageId="150" pageNumber="752" type="biology_ecology">
<paragraph blockId="150.[168,1376,260,726]" box="[170,836,455,484]" pageId="150" pageNumber="752">
<emphasis bold="true" box="[170,281,455,484]" pageId="150" pageNumber="752">Habitat.</emphasis>
Disturbed humid Afro-montane forest.
</paragraph>
</subSubSection>
<subSubSection box="[170,1024,490,524]" pageId="150" pageNumber="752" type="food_feeding">
<paragraph blockId="150.[168,1376,260,726]" box="[170,1024,490,524]" pageId="150" pageNumber="752">
<emphasis bold="true" box="[170,432,490,524]" pageId="150" pageNumber="752">Food and Feeding.</emphasis>
Diet may include invertebrates and fruits.
</paragraph>
</subSubSection>
<subSubSection box="[170,544,534,563]" pageId="150" pageNumber="752" type="breeding">
