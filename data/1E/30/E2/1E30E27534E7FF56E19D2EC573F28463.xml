<subSubSection pageId="193" pageNumber="796" type="reference_group">
<paragraph blockId="193.[780,1374,895,1313]" pageId="193" pageNumber="796">
<emphasis bold="true" box="[781,936,895,920]" pageId="193" pageNumber="796">Taxonomy.</emphasis>
<taxonomicName authority="Bonhote, 1898" authorityName="Bonhote" authorityYear="1898" box="[957,1367,895,920]" class="Mammalia" family="Muridae" genus="Mus" kingdom="Animalia" order="Rodentia" pageId="193" pageNumber="796" phylum="Chordata" rank="species" species="famulus">Mus famulus Bonhote, 1898</taxonomicName>
