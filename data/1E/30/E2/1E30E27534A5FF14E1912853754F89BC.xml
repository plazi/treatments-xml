<subSubSection pageId="131" pageNumber="732" type="reference_group">
<paragraph blockId="131.[775,1370,1288,1711]" pageId="131" pageNumber="732">
<emphasis bold="true" box="[776,931,1288,1317]" pageId="131" pageNumber="732">Taxonomy.</emphasis>
<taxonomicName authority="Waite, 1896" authorityName="Waite" authorityYear="1896" class="Mammalia" family="Muridae" genus="Mus" kingdom="Animalia" order="Rodentia" pageId="131" pageNumber="732" phylum="Chordata" rank="species" species="hermannsburgensis">Mus hermannsburgensis Waite, 1896</taxonomicName>
