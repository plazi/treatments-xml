<paragraph blockId="197.[99,1307,2578,3124]" box="[100,1301,2893,2927]" pageId="197" pageNumber="801">
<emphasis bold="true" box="[100,233,2893,2927]" pageId="197" pageNumber="801">Breeding.</emphasis>
