<paragraph blockId="98.[1453,2663,294,1033]" box="[1454,2656,1012,1033]" pageId="98" pageNumber="698">
<emphasis bold="true" box="[1454,1607,1012,1033]" pageId="98" pageNumber="698">Bibliography.</emphasis>
