<taxonomicName baseAuthorityName="Thomas" baseAuthorityYear="1910" box="[2011,2148,2337,2371]" class="Mammalia" family="Muridae" genus="Gerbilliscus" kingdom="Animalia" order="Rodentia" pageId="19" pageNumber="617" phylum="Chordata" rank="species" species="guineae">G. guineae</taxonomicName>
