, 
<materialsCitation ID-GBIF-Occurrence="3864424738" pageId="195" pageNumber="798">“Kandang Badak, Mt. Gedeh, Western Java [Indonesia], 7900 ft. [= 2408 m].”</materialsCitation>
</paragraph>
