</subSubSection>
<subSubSection pageId="159" pageNumber="762" type="discussion">
Described taxon 
<taxonomicName authorityName=": Thomas" authorityYear="1907" box="[2306,2480,3211,3245]" class="Mammalia" family="Muridae" genus="Mus" kingdom="Animalia" order="Rodentia" pageId="159" pageNumber="762" phylum="Chordata" rank="species" species="shortridge">D. shortridge</taxonomicName>
