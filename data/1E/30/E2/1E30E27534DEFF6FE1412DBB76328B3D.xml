<subSubSection box="[114,1050,1785,1819]" pageId="248" pageNumber="853" type="activity">
<paragraph blockId="248.[114,1321,1041,2094]" box="[114,1050,1785,1819]" pageId="248" pageNumber="853">
<emphasis bold="true" box="[114,350,1785,1819]" pageId="248" pageNumber="853">Activity patterns.</emphasis>
The Burmese Tree Rat is nocturnal and arboreal.
</paragraph>
</subSubSection>
<subSubSection box="[115,1054,1824,1858]" pageId="248" pageNumber="853" type="biology_ecology">
<paragraph blockId="248.[114,1321,1041,2094]" box="[115,1054,1824,1858]" pageId="248" pageNumber="853">
<emphasis bold="true" box="[115,816,1824,1858]" pageId="248" pageNumber="853">Movements, Home range and Social organization.</emphasis>
