<subSubSection pageId="227" pageNumber="832" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6888335" ID-Zenodo-Dep="6888335" httpUri="https://zenodo.org/record/6888335/files/figure.png" inLine="true" pageId="227" pageNumber="832" startId="227.[2066,2238,1195,1229]" targetBox="[1452,2043,891,1303]" targetPageId="227">
<paragraph blockId="227.[2066,2659,880,1308]" pageId="227" pageNumber="832">
<emphasis bold="true" box="[2066,2242,1195,1229]" pageId="227" pageNumber="832">Distribution.</emphasis>
