<taxonomicName baseAuthorityName="Thomas &amp; Wroughton" baseAuthorityYear="1908" box="[2070,2202,3093,3127]" class="Mammalia" family="Muridae" genus="Grammomys" kingdom="Animalia" order="Rodentia" pageId="162" pageNumber="765" phylum="Chordata" rank="species" species="cometes">G. cometes</taxonomicName>
