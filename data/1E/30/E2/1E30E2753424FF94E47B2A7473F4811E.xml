<taxonomicName authority="Bate, 1903" authorityName="Bate" authorityYear="1903" box="[2132,2482,1797,1822]" class="Mammalia" family="Muridae" genus="Acomys" kingdom="Animalia" order="Rodentia" pageId="2" pageNumber="599" phylum="Chordata" rank="species" species="nesiotes">Acomys nesiotes Bate, 1903</taxonomicName>
