<subSubSection box="[87,1278,2384,2418]" pageId="142" pageNumber="743" type="activity">
<paragraph blockId="142.[87,1293,1793,2577]" box="[87,1278,2384,2418]" pageId="142" pageNumber="743">
<emphasis bold="true" box="[87,322,2384,2418]" pageId="142" pageNumber="743">Activity patterns.</emphasis>
