<taxonomicName authorityName="W. Verheyen, Dierckx &amp; Hulselmans" authorityYear="2000" class="Mammalia" family="Muridae" genus="Lophuromys" kingdom="Animalia" order="Rodentia" pageId="10" pageNumber="607" phylum="Chordata" rank="species" species="angolensis">Lophuromys angolensis W. N. Ver- heyen, Dierckx &amp; Hulselmans, 2000</taxonomicName>
