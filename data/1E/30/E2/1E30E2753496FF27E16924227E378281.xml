<caption box="[707,1246,2504,2533]" inLine="true" pageId="176" pageNumber="779" startId="176.[707,879,2504,2533]" targetBox="[92,684,2354,2764]" targetPageId="176">Distribution. C highlands of Sri Lanka</caption>
