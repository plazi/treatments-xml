<taxonomicName authority="Mearns, 1905" authorityName="Mearns" authorityYear="1905" class="Mammalia" family="Muridae" genus="Tarsomys" kingdom="Animalia" order="Rodentia" pageId="277" pageNumber="882" phylum="Chordata" rank="species" species="apoensis">Tarsomys apoensis Mearns, 1905</taxonomicName>
