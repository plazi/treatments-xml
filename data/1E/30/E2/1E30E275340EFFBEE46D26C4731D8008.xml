<subSubSection pageId="40" pageNumber="639" type="reference_group">
<paragraph blockId="40.[1977,2573,2897,3320]" pageId="40" pageNumber="639">
<emphasis bold="true" box="[1979,2134,2897,2926]" pageId="40" pageNumber="639">Taxonomy.</emphasis>
<taxonomicName authority="Yerbury &amp; Thomas, 1895" authorityName="Yerbury &amp; Thomas" authorityYear="1895" class="Mammalia" family="Muridae" genus="Gerbillus" kingdom="Animalia" order="Rodentia" pageId="40" pageNumber="639" phylum="Chordata" rank="species" species="poecilops" subGenus="Dipodillus">Gerbillus (Dipodillus) poecilops Yerbury &amp; Thomas, 1895</taxonomicName>
