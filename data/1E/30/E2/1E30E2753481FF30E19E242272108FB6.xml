<subSubSection pageId="167" pageNumber="770" type="discussion">
<paragraph blockId="167.[780,1373,2302,2726]" pageId="167" pageNumber="770">
<taxonomicName authorityName="Eisentraut" authorityYear="1968" box="[782,1094,2420,2449]" class="Mammalia" family="Muridae" genus="Lemniscomys" kingdom="Animalia" order="Rodentia" pageId="167" pageNumber="770" phylum="Chordata" rank="species" species="mittendorfi">Lemniscomys mittendorfi</taxonomicName>
