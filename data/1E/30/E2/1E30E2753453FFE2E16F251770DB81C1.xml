<taxonomicName authority="Thomas, 1888" authorityName="Thomas" authorityYear="1888" box="[870,1187,2510,2535]" class="Mammalia" family="Muridae" genus="Mus" kingdom="Animalia" order="Rodentia" pageId="117" pageNumber="717" phylum="Chordata" rank="species" species="rex">Mus rex Thomas, 1888</taxonomicName>
