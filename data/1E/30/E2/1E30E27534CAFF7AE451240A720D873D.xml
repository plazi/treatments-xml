<subSubSection pageId="237" pageNumber="842" type="biology_ecology">
<paragraph blockId="237.[171,1378,291,1070]" pageId="237" pageNumber="842">
<emphasis bold="true" box="[173,284,647,676]" pageId="237" pageNumber="842">Habitat.</emphasis>
Primary and secondary lowland rainforest, nearvillages, along streams in secondary rainforest, and cocoa plantations.
</paragraph>
</subSubSection>
<subSubSection box="[173,673,725,754]" pageId="237" pageNumber="842" type="food_feeding">
