<paragraph blockId="94.[172,1378,3174,3475]" pageId="94" pageNumber="694">
<emphasis bold="true" box="[172,327,3174,3199]" pageId="94" pageNumber="694">Taxonomy.</emphasis>
<taxonomicName authority="Thomas, 1920" authorityName="Thomas" authorityYear="1920" box="[341,734,3174,3199]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="94" pageNumber="694" phylum="Chordata" rank="species" species="aerosus">Uromys aerosus Thomas, 1920</taxonomicName>
