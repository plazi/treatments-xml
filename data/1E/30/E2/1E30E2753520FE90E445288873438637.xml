<taxonomicName baseAuthorityName="Thomas" baseAuthorityYear="1896" box="[2223,2590,2769,2815]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="262" pageNumber="867" phylum="Chordata" rank="species" species="fratrorum">Bunomys fratrorum</taxonomicName>
French: 
<taxonomicName authority="des Hose" authorityName="des Hose" box="[1476,1671,2833,2854]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="262" pageNumber="867" phylum="Chordata" rank="genus">Bunomys des Hose</taxonomicName>
