<subSubSection pageId="191" pageNumber="794" type="distribution">
<caption inLine="true" pageId="191" pageNumber="794" targetBox="[1845,1849,2831,2852]" targetPageId="191">
<paragraph blockId="191.[2049,2653,1731,2222]" pageId="191" pageNumber="794">
<emphasis bold="true" box="[2058,2234,1878,1907]" pageId="191" pageNumber="794">Distribution.</emphasis>
SE Angola, W Zambia, NE 
<taxonomicName box="[2059,2180,1921,1946]" class="Magnoliopsida" family="Aizoaceae" genus="Namibia" kingdom="Plantae" order="Caryophyllales" pageId="191" pageNumber="794" phylum="Tracheophyta" rank="genus">Namibia</taxonomicName>
, and NW Botswana, with an isolated record from S Botswana.
</paragraph>
</caption>
