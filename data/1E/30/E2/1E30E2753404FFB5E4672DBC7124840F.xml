<paragraph blockId="34.[1360,2569,1035,1820]" box="[1362,2391,1627,1661]" pageId="34" pageNumber="633">
<emphasis bold="true" box="[1362,1597,1627,1661]" pageId="34" pageNumber="633">Activity patterns.</emphasis>
