<taxonomicName baseAuthorityName="Hoffmann" baseAuthorityYear="1887" box="[1071,1262,1995,2024]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="264" pageNumber="869" phylum="Chordata" rank="species" species="chrysocomus">B. chrysocomus</taxonomicName>
species group within 
<taxonomicName box="[991,1107,2030,2064]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="264" pageNumber="869" phylum="Chordata" rank="genus">Bunomys</taxonomicName>
and is sister to 
<taxonomicName authorityName="Musser" authorityYear="2014" box="[733,855,2073,2102]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="264" pageNumber="869" phylum="Chordata" rank="species" species="torajae">B. torajae</taxonomicName>
