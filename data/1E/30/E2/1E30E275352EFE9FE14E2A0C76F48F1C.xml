, 
<materialsCitation pageId="264" pageNumber="869">
“tropical lower montane rain forest at 2600 m near 
<taxonomicName authority="Gandangdewata" authorityName="Gandangdewata" box="[957,1323,1794,1828]" class="Mammalia" family="Muridae" genus="Mallomys" kingdom="Animalia" order="Rodentia" pageId="264" pageNumber="869" phylum="Chordata" rank="species" species="gunung">Gunung Gandangdewata</taxonomicName>
(—2-748253° S, 119-368536° E for the peak, Rano Rano, Kampung Rantepangko, desai Tondok Bakaru, Kabatuan Mamasa).”
</materialsCitation>
<taxonomicName box="[733,849,1995,2024]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="264" pageNumber="869" phylum="Chordata" rank="genus">Bunomys</taxonomicName>
