<taxonomicName authority="Hinton &amp; Kershaw, 1920" authorityName="Hinton &amp; Kershaw" authorityYear="1920" box="[1441,2003,3368,3403]" class="Mammalia" family="Muridae" genus="Acomys" kingdom="Animalia" order="Rodentia" pageId="5" pageNumber="602" phylum="Chordata" rank="subSpecies" species="wilsoni" subSpecies="argillaceus">A. A.w.argillaceusHinton&amp;Kershaw,1920—SSouthSudan.</taxonomicName>
</paragraph>
<paragraph blockId="5.[1441,2583,3289,3481]" pageId="5" pageNumber="602">
