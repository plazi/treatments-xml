<paragraph blockId="155.[694,1288,450,877]" pageId="155" pageNumber="757">
<taxonomicName baseAuthorityName="Thomas" baseAuthorityYear="1902" box="[695,904,529,563]" class="Mammalia" family="Muridae" genus="Aethomys" kingdom="Animalia" order="Rodentia" pageId="155" pageNumber="757" phylum="Chordata" rank="species" species="hindei">Aethomys hindei</taxonomicName>
