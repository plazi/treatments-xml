<paragraph blockId="104.[1456,2663,291,797]" box="[1458,2182,776,797]" pageId="104" pageNumber="704">
<emphasis bold="true" box="[1458,1611,776,797]" pageId="104" pageNumber="704">Bibliography.</emphasis>
