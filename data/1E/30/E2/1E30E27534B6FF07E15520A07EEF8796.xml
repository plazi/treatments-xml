<subSubSection pageId="144" pageNumber="745" type="activity">
<paragraph blockId="144.[1368,2575,729,1157]" pageId="144" pageNumber="745">
<emphasis bold="true" box="[1368,1603,970,999]" pageId="144" pageNumber="745">Activity patterns.</emphasis>
