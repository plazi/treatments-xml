<taxonomicName authorityName="Tate &amp; Archbold" authorityYear="1935" box="[2057,2300,2026,2060]" class="Mammalia" family="Muridae" genus="Hydromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="neobritannicus">U. neobritannicus</taxonomicName>
