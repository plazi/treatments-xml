<taxonomicName baseAuthorityName="Krefft" baseAuthorityYear="1867" box="[2106,2353,2110,2139]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="caudimaculatus">U. caudimaculatus</taxonomicName>
and 
<taxonomicName baseAuthorityName="Winter" baseAuthorityYear="1984" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="hadrourus">U. hadrourus</taxonomicName>
