<subSubSection pageId="115" pageNumber="715" type="discussion">
<paragraph blockId="115.[1966,2566,1716,2139]" lastBlockId="115.[1360,2567,2152,3164]" pageId="115" pageNumber="715">
Within 
<taxonomicName box="[2092,2182,1908,1942]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="genus">Uromys</taxonomicName>
, 
<taxonomicName authorityName="Groves &amp; Flannery" authorityYear="1994" box="[2213,2347,1908,1942]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="emmae">U. emmae</taxonomicName>
is placed under subgenus 
<taxonomicName box="[2181,2271,1948,1982]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="genus">Uromys</taxonomicName>
along with 
<taxonomicName authorityName="Thomas" authorityYear="1907" box="[2451,2557,1948,1982]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="anak">U. anak</taxonomicName>
, 
<taxonomicName authorityName="Groves &amp; Flannery" authorityYear="1994" box="[1976,2103,1996,2021]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="boeadii">U. boeadii</taxonomicName>
, 
<taxonomicName baseAuthorityName="Krefft" baseAuthorityYear="1867" box="[2124,2366,1996,2021]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="caudimaculatus">U. caudimaculatus</taxonomicName>
, 
<taxonomicName baseAuthorityName="Winter" baseAuthorityYear="1984" box="[2387,2557,1996,2021]" class="Mammalia" family="Muridae" genus="Uromys" kingdom="Animalia" order="Rodentia" pageId="115" pageNumber="715" phylum="Chordata" rank="species" species="hadrourus">U. hadrourus</taxonomicName>
