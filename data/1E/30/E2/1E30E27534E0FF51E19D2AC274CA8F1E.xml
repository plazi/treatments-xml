was previously included in 
<taxonomicName box="[824,971,2071,2100]" class="Mammalia" family="Muridae" genus="Hylomyscus" kingdom="Animalia" order="Rodentia" pageId="198" pageNumber="802" phylum="Chordata" rank="genus">Hylomyscus</taxonomicName>
