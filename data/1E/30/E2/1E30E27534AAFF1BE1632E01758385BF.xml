<paragraph blockId="140.[84,1290,1083,1708]" box="[86,460,1522,1551]" pageId="140" pageNumber="741">
<emphasis bold="true" box="[86,220,1522,1551]" pageId="140" pageNumber="741">Breeding.</emphasis>
