<subSubSection pageId="152" pageNumber="754" type="discussion">
<paragraph blockId="152.[2068,2660,692,1116]" pageId="152" pageNumber="754">
<taxonomicName authorityName="Eisentraut" authorityYear="1965" box="[2070,2279,807,841]" class="Mammalia" family="Muridae" genus="Hybomys" kingdom="Animalia" order="Rodentia" pageId="152" pageNumber="754" phylum="Chordata" rank="species" species="basilii">Hybomys basilii</taxonomicName>
