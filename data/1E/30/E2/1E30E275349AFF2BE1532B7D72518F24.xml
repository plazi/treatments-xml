</paragraph>
</subSubSection>
<subSubSection box="[100,974,2975,3009]" pageId="188" pageNumber="791" type="activity">
<paragraph blockId="188.[100,1307,2463,3127]" box="[100,974,2975,3009]" pageId="188" pageNumber="791">
<emphasis bold="true" box="[100,335,2975,3009]" pageId="188" pageNumber="791">Activity patterns.</emphasis>
<taxonomicName authority="Mice" authorityName="Mice" box="[348,559,2975,3009]" class="Mammalia" family="Muridae" genus="Mus" kingdom="Animalia" order="Rodentia" pageId="188" pageNumber="791" phylum="Chordata" rank="species" species="mahomet">Mahomet Mice</taxonomicName>
