<subSubSection pageId="188" pageNumber="791" type="reference_group">
<paragraph blockId="188.[711,1305,2037,2457]" pageId="188" pageNumber="791">
<emphasis bold="true" box="[711,866,2037,2062]" pageId="188" pageNumber="791">Taxonomy.</emphasis>
<taxonomicName authority="Rhoads, 1896" authorityName="Rhoads" authorityYear="1896" box="[889,1296,2037,2062]" class="Mammalia" family="Muridae" genus="Mus" kingdom="Animalia" order="Rodentia" pageId="188" pageNumber="791" phylum="Chordata" rank="species" species="mahomet">Mus mahomet Rhoads, 1896</taxonomicName>
