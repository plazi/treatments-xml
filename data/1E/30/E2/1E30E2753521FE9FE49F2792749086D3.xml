<subSubSection pageId="263" pageNumber="868" type="discussion">
<paragraph blockId="263.[1444,2650,2934,3486]" pageId="263" pageNumber="868">
<taxonomicName authorityName="Musser" authorityYear="1991" box="[1446,1675,3215,3244]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="263" pageNumber="868" phylum="Chordata" rank="species" species="prolatus">Bunomys prolatus</taxonomicName>
is in the 
<taxonomicName baseAuthorityName="Hoffmann" baseAuthorityYear="1887" box="[1811,2005,3215,3244]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="263" pageNumber="868" phylum="Chordata" rank="species" species="chrysocomus">B. chrysocomus</taxonomicName>
