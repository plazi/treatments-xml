<taxonomicName box="[2319,2435,3215,3244]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="263" pageNumber="868" phylum="Chordata" rank="genus">Bunomys</taxonomicName>
and is sister to 
<taxonomicName authorityName="Musser" authorityYear="2014" box="[1447,1570,3251,3285]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="263" pageNumber="868" phylum="Chordata" rank="species" species="torajae">B. torajae</taxonomicName>
. Monotypic.
</paragraph>
</subSubSection>
