<subSubSection pageId="265" pageNumber="870" type="discussion">
<paragraph blockId="265.[776,1369,3016,3439]" pageId="265" pageNumber="870">
Gracilimusis sister to 
<taxonomicName box="[1072,1181,3213,3242]" class="Mammalia" family="Muridae" genus="Waiomys" kingdom="Animalia" order="Rodentia" pageId="265" pageNumber="870" phylum="Chordata" rank="genus">Waiomys</taxonomicName>
, which are in turn sister to 
<taxonomicName authorityName="Musser &amp; Durden" authorityYear="2002" box="[962,1121,3248,3282]" class="Mammalia" family="Muridae" genus="Sommeromys" kingdom="Animalia" order="Rodentia" pageId="265" pageNumber="870" phylum="Chordata" rank="genus">Sommeromys</taxonomicName>
. This Gracilimus + 
<taxonomicName box="[780,889,3288,3322]" class="Mammalia" family="Muridae" genus="Waiomys" kingdom="Animalia" order="Rodentia" pageId="265" pageNumber="870" phylum="Chordata" rank="genus">Waiomys</taxonomicName>
+ 
<taxonomicName authorityName="Musser &amp; Durden" authorityYear="2002" box="[925,1082,3288,3322]" class="Mammalia" family="Muridae" genus="Sommeromys" kingdom="Animalia" order="Rodentia" pageId="265" pageNumber="870" phylum="Chordata" rank="genus">Sommeromys</taxonomicName>
clade is sister to the 
<taxonomicName authorityName="Esselstyn, Achmadi &amp; Rowe" authorityYear="2012" box="[777,965,3331,3360]" class="Mammalia" family="Muridae" genus="Paucidentomys" kingdom="Animalia" order="Rodentia" pageId="265" pageNumber="870" phylum="Chordata" rank="genus">Paucidentomys</taxonomicName>
+ 
<taxonomicName authorityName="Gray" authorityYear="1867" box="[1011,1141,3331,3360]" class="Mammalia" family="Muridae" genus="Echiothrix" kingdom="Animalia" order="Rodentia" pageId="265" pageNumber="870" phylum="Chordata" rank="genus">Echiothrix</taxonomicName>
and 
<taxonomicName authorityName="Musser" authorityYear="1969" box="[1227,1338,3331,3360]" class="Mammalia" family="Muridae" genus="Tateomys" kingdom="Animalia" order="Rodentia" pageId="265" pageNumber="870" phylum="Chordata" rank="genus">Tateomys</taxonomicName>
+ 
<taxonomicName authorityName="Miller &amp; Hollister" authorityYear="1921" box="[778,951,3366,3400]" class="Mammalia" family="Muridae" genus="Melasmothrix" kingdom="Animalia" order="Rodentia" pageId="265" pageNumber="870" phylum="Chordata" rank="genus">Melasmothrix</taxonomicName>
clades. Monotypic.
</paragraph>
</subSubSection>
<subSubSection box="[776,1365,3405,3439]" pageId="265" pageNumber="870" type="distribution">
<caption box="[776,1365,3405,3439]" inLine="true" pageId="265" pageNumber="870" startId="265.[776,948,3405,3439]" targetBox="[162,753,3025,3439]" targetPageId="265">
