<subSubSection box="[1444,2139,3244,3273]" pageId="135" pageNumber="736" type="activity">
<paragraph blockId="135.[1444,2650,2689,3470]" box="[1444,2139,3244,3273]" pageId="135" pageNumber="736">
<emphasis bold="true" box="[1444,1680,3244,3273]" pageId="135" pageNumber="736">Activity patterns.</emphasis>
