<taxonomicName authority="Emmons" authorityName="Emmons" authorityYear="1993" class="Mammalia" family="Muridae" genus="Pithecheirops" kingdom="Animalia" order="Rodentia" pageId="135" pageNumber="736" phylum="Chordata" rank="species" species="otion">Pithecheirops otion Emmons, 1993</taxonomicName>
