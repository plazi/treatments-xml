<taxonomicName baseAuthorityName="Hoffmann" baseAuthorityYear="1887" box="[2346,2536,1523,1552]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="262" pageNumber="867" phylum="Chordata" rank="species" species="chrysocomus">B. chrysocomus</taxonomicName>
