and is sister to 
<taxonomicName baseAuthorityName="Hoffmann" baseAuthorityYear="1887" box="[2005,2198,1598,1632]" class="Mammalia" family="Muridae" genus="Bunomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="262" pageNumber="867" phylum="Chordata" rank="species" species="chrysocomus">B. chrysocomus</taxonomicName>
