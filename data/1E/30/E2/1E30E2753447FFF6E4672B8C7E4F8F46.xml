<paragraph blockId="97.[1360,2566,2534,3157]" box="[1362,1735,2888,2922]" pageId="97" pageNumber="697">
<emphasis bold="true" box="[1362,1496,2888,2922]" pageId="97" pageNumber="697">Breeding.</emphasis>
