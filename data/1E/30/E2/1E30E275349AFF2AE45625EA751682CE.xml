<taxonomicName authorityName="A. Smith" authorityYear="1834" box="[449,637,3447,3481]" class="Mammalia" family="Muridae" genus="Mus" kingdom="Animalia" order="Rodentia" pageId="188" pageNumber="791" phylum="Chordata" rank="species" species="minutoides">M. minutoides</taxonomicName>
