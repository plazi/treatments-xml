<subSubSection pageId="279" pageNumber="884" type="activity">
<paragraph blockId="279.[1441,2646,728,1467]" pageId="279" pageNumber="884">
<emphasis bold="true" box="[1441,1674,1200,1229]" pageId="279" pageNumber="884">Activity patterns.</emphasis>
