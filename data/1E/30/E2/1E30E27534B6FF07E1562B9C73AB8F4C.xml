</paragraph>
</subSubSection>
<subSubSection box="[97,993,2937,2971]" pageId="144" pageNumber="745" type="breeding">
<paragraph blockId="144.[95,1300,2543,3167]" box="[97,993,2937,2971]" pageId="144" pageNumber="745">
<emphasis bold="true" box="[97,231,2937,2971]" pageId="144" pageNumber="745">Breeding.</emphasis>
