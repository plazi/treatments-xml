<subSubSection pageId="215" pageNumber="820" type="multiple">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6888276" ID-Zenodo-Dep="6888276" httpUri="https://zenodo.org/record/6888276/files/figure.png" inLine="true" pageId="215" pageNumber="820" startId="215.[793,965,378,407]" targetBox="[178,769,303,718]" targetPageId="215">
