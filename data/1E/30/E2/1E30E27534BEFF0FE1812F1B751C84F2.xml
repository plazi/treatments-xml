<subSubSection pageId="152" pageNumber="754" type="reference_group">
<paragraph blockId="152.[793,1385,965,1389]" pageId="152" pageNumber="754">
<emphasis bold="true" box="[794,949,965,994]" pageId="152" pageNumber="754">Taxonomy.</emphasis>
<taxonomicName authorityName="Heim de Balsac &amp; Bellier" authorityYear="1967" class="Mammalia" family="Muridae" genus="Dephomys" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Rodentia" pageId="152" pageNumber="754" phylum="Chordata" rank="genus" species="eburneae">Dephomys eburnae Heim de Balsac &amp; Bellier, 1967</taxonomicName>
