<taxonomicName authority="Kershaw, 1921" authorityName="Kershaw" authorityYear="1921" box="[885,1303,2621,2646]" class="Mammalia" family="Muridae" genus="Rattus" kingdom="Animalia" order="Rodentia" pageId="203" pageNumber="807" phylum="Chordata" rank="species" species="pernanus">Rattus pernanus Kershaw, 1921</taxonomicName>
