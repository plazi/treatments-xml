<subSubSection pageId="163" pageNumber="766" type="discussion">
<paragraph blockId="163.[2057,2650,1923,2342]" pageId="163" pageNumber="766">
<taxonomicName baseAuthorityName="Smuts" baseAuthorityYear="1832" box="[2061,2361,1998,2027]" class="Mammalia" family="Muridae" genus="Grammomys" kingdom="Animalia" order="Rodentia" pageId="163" pageNumber="766" phylum="Chordata" rank="species" species="dolichurus">Grammomys dolichurus</taxonomicName>
previously included 
<taxonomicName authorityName="Thomas" authorityYear="1911" box="[2060,2216,2041,2066]" class="Mammalia" family="Muridae" genus="Thamnomys" kingdom="Animalia" order="Rodentia" pageId="163" pageNumber="766" phylum="Chordata" rank="species" species="buntingi">G. buntingi</taxonomicName>
