<subSubSection box="[1393,2580,3372,3401]" pageId="264" pageNumber="869" type="activity">
<paragraph blockId="264.[1393,2600,2975,3481]" box="[1393,2580,3372,3401]" pageId="264" pageNumber="869">
<emphasis bold="true" box="[1393,1628,3372,3401]" pageId="264" pageNumber="869">Activity patterns.</emphasis>
