<paragraph blockId="37.[1434,2642,3015,3483]" box="[1434,2637,3449,3483]" pageId="37" pageNumber="636">
<emphasis bold="true" box="[1434,1656,3449,3483]" pageId="37" pageNumber="636">Activity patterns.</emphasis>
