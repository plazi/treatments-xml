<paragraph blockId="213.[172,1380,254,835]" box="[172,1043,602,636]" pageId="213" pageNumber="818">
<emphasis bold="true" box="[172,408,602,636]" pageId="213" pageNumber="818">Activity patterns.</emphasis>
