<vernacularName box="[507,717,1241,1270]" pageId="174" pageNumber="777">near Upington</vernacularName>
, 
<vernacularName box="[734,1081,1241,1270]" pageId="174" pageNumber="777">Northern Cape Province</vernacularName>
