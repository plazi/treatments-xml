<taxonomicName authorityName="Lataste" authorityYear="1883" box="[2164,2564,1474,1508]" class="Mammalia" family="Muridae" genus="Mus" kingdom="Animalia" order="Rodentia" pageId="186" pageNumber="789" phylum="Chordata" rank="species" species="spretus">Mus spretus lLataste, 1883</taxonomicName>
