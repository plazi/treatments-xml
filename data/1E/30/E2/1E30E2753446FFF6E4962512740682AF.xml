<subSubSection pageId="96" pageNumber="696" type="reference_group">
<paragraph blockId="96.[2051,2646,2544,2968]" pageId="96" pageNumber="696">
<emphasis bold="true" box="[2051,2206,2544,2573]" pageId="96" pageNumber="696">Taxonomy.</emphasis>
<taxonomicName authority="Tate, 1951" authorityName="Tate" authorityYear="1951" class="Mammalia" family="Muridae" genus="Melomys" kingdom="Animalia" order="Rodentia" pageId="96" pageNumber="696" phylum="Chordata" rank="subSpecies" species="lutillus" subSpecies="frigicola">Melomys lutillus frigicola Tate, 1951</taxonomicName>
, 
<materialsCitation pageId="96" pageNumber="696">“Bele River, 18 kilometers north of Lake Habbema, near Mt. Wilhelmina, Netherlands New Guinea [= Papua, Indo-nesia], 2200 meters.”</materialsCitation>
</paragraph>
