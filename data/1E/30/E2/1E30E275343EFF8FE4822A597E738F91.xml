<taxonomicName authority="Sicard, Tranier &amp; Gautun, 1985" authorityName="Sicard, Tranier &amp; Gautun" authorityYear="1985" class="Mammalia" family="Muridae" genus="Taterillus" kingdom="Animalia" order="Rodentia" pageId="24" pageNumber="622" phylum="Chordata" rank="species" species="petteri">Taterillus petteri Sicard, Tranier &amp; Gautun, 1985</taxonomicName>
