<subSubSection pageId="206" pageNumber="810" type="discussion">
<paragraph blockId="206.[786,1382,1585,2012]" pageId="206" pageNumber="810">
<taxonomicName baseAuthorityName="Thomas" baseAuthorityYear="1894" box="[788,1007,1668,1697]" class="Mammalia" family="Muridae" genus="Praomys" kingdom="Animalia" order="Rodentia" pageId="206" pageNumber="810" phylum="Chordata" rank="species" species="tullbergi">Praomys tullbergi</taxonomicName>
is in the 
<taxonomicName baseAuthorityName="Thomas" baseAuthorityYear="1894" box="[1138,1274,1668,1697]" class="Mammalia" family="Muridae" genus="Praomys" kingdom="Animalia" order="Rodentia" pageId="206" pageNumber="810" phylum="Chordata" rank="species" species="tullbergi">P. tullbergi</taxonomicName>
species group and distinguished based on molecular and partially morphometric grounds from 
<taxonomicName baseAuthorityName="Miller" baseAuthorityYear="1900" box="[874,1022,1782,1816]" class="Mammalia" family="Muridae" genus="Praomys" kingdom="Animalia" order="Rodentia" pageId="206" pageNumber="810" phylum="Chordata" rank="species" species="rostratus">P. rostratus</taxonomicName>
