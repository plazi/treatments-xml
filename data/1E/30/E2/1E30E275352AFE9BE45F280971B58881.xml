<taxonomicName box="[1999,2108,1512,1541]" class="Mammalia" family="Muridae" genus="Waiomys" kingdom="Animalia" order="Rodentia" pageId="268" pageNumber="873" phylum="Chordata" rank="genus">Waiomys</taxonomicName>
