<taxonomicName authorityName="Musser &amp; Durden" authorityYear="2002" box="[2406,2563,1512,1541]" class="Mammalia" family="Muridae" genus="Sommeromys" kingdom="Animalia" order="Rodentia" pageId="268" pageNumber="873" phylum="Chordata" rank="genus">Sommeromys</taxonomicName>
