<paragraph blockId="96.[163,1369,296,562]" box="[165,1105,331,365]" pageId="96" pageNumber="696">
<emphasis bold="true" box="[165,866,331,365]" pageId="96" pageNumber="696">Movements, Home range and Social organization.</emphasis>
