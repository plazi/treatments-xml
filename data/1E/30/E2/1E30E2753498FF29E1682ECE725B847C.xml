<vernacularName box="[182,335,2040,2061]" pageId="190" pageNumber="793">Souris hérissée</vernacularName>
/ 
<emphasis bold="true" box="[356,447,2040,2061]" pageId="190" pageNumber="793">German:</emphasis>
<vernacularName box="[457,644,2040,2061]" pageId="190" pageNumber="793">Peters-Zwergmaus</vernacularName>
/ 
