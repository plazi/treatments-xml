<subSubSection box="[1448,2522,1441,1470]" pageId="141" pageNumber="742" type="activity">
<paragraph blockId="141.[1448,2657,1122,1667]" box="[1448,2522,1441,1470]" pageId="141" pageNumber="742">
<emphasis bold="true" box="[1448,1683,1441,1470]" pageId="141" pageNumber="742">Activity patterns.</emphasis>
