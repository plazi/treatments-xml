<taxonomicName authority="Blanford, 1875" authorityName="Blanford" authorityYear="1875" box="[2139,2555,297,326]" class="Mammalia" family="Muridae" genus="Gerbillus" kingdom="Animalia" order="Rodentia" pageId="40" pageNumber="639" phylum="Chordata" rank="species" species="nanus">Gerbillus nanus Blanford, 1875</taxonomicName>
