species by present designation: 
<emphasis id="18DF141BFFB6FFFB6B71F8D1FD72F8E5" box="[529,661,1798,1822]" italics="true" pageId="6" pageNumber="7">
<taxonomicName id="EDABB38AFFB6FFFB6B71F8D1FD6BF8E5" authorityName="Stal" authorityYear="1873" box="[529,652,1798,1822]" class="Insecta" family="Tingidae" genus="Leptodictya" kingdom="Animalia" order="Hemiptera" pageId="6" pageNumber="7" phylum="Arthropoda" rank="genus">Leptodictya</taxonomicName>
?
</emphasis>
<taxonomicName id="EDABB38AFFB6FFFB6BFBF8D1FCB4F8E5" authority="Scott, 1880" authorityName="Scott" authorityYear="1880" box="[667,851,1798,1822]" class="Insecta" family="Tingidae" genus="Limnostatua" kingdom="Animalia" order="Hemiptera" pageId="6" pageNumber="7" phylum="Arthropoda" rank="species" species="lewisi">
<emphasis id="18DF141BFFB6FFFB6BFBF8D1FD31F8E5" box="[667,726,1798,1822]" italics="true" pageId="6" pageNumber="7">lewisi</emphasis>
<bibRefCitation id="4E3AB5F8FFB6FFFB6BBDF8D1FCB4F8E5" author="Scott, J." box="[733,851,1798,1822]" pageId="6" pageNumber="7" pagination="305 - 317" refId="ref40313" refString="Scott, J. (1880) On a collection of Hemiptera from Japan. Transactions of the Entomological Society of London, 1880, 305 - 317. https: // doi. org / 10.1111 / j. 1365 - 2311.1880. tb 02032. x" type="journal article" year="1880">Scott, 1880</bibRefCitation>
