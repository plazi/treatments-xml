<taxonomicName id="CDEA951B2B1AD3C6AD1E201C774CE2D8" authorityName="Bordera &amp; Santos" authorityYear="2022" class="Insecta" family="Ichneumonidae" genus="Piasites" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Piasites orbitalis" order="Hymenoptera" pageId="0" pageNumber="23" phylum="Arthropoda" rank="species" species="orbitalis">
