<emphasis id="F086ABCAEFC3A2C17E7387701AB0AA58" italics="true" pageId="null" pageNumber="196">Krone im Durchmesser 4</emphasis>
- 
<emphasis id="FCBD97F0463E5C1D290959C6F0B81585" italics="true" pageId="null" pageNumber="196">7 mm</emphasis>
