<normalizedToken id="53522EAEF46E9F9F8D882F7A25904D6F" originalValue="Mittelrußland" pageId="null" pageNumber="196">Mittelrussland</normalizedToken>
; 
<normalizedToken id="C204B73AB6054BE6DF5E23932249E9F2" originalValue="ostwärts" pageId="null" pageNumber="196">ostwaerts</normalizedToken>
