<emphasis id="28857F144C37F7956D67C839A43EA610" italics="true" pageId="null" pageNumber="196">Griffel 1</emphasis>
- 
<emphasis id="52C248ED225BDB22FD21D1A0380A6135" italics="true" pageId="null" pageNumber="196">2 mm lang.</emphasis>
- 
<normalizedToken id="415CD890010012DBEB0B160AEDBDBF7A" originalValue="Blüte" pageId="null" pageNumber="196">Bluete</normalizedToken>
: 
<normalizedToken id="9434ECFD60BC4716A767EB7AA13EF011" originalValue="Frühling" pageId="null" pageNumber="196">Fruehling</normalizedToken>
und 
<normalizedToken id="1FC50F98736333B31ED7D319AEF5D18A" originalValue="früher" pageId="null" pageNumber="196">frueher</normalizedToken>
Sommer.
</paragraph>
