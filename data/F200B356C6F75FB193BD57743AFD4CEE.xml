<normalizedToken id="D03B3C80BB5EB86C3FC6441A9A2FC81D" originalValue="Osteuropäisch-westasiatische" pageId="null" pageNumber="196">Osteuropaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="F112A7629B444D3C0EE1417EB59C9DB1" originalValue="Westwärts" pageId="null" pageNumber="196">Westwaerts</normalizedToken>
bis Vogesen, Wallis, Piemont; 
<normalizedToken id="548F9C6C286E229671F114613B5C5103" originalValue="nordwärts" pageId="null" pageNumber="196">nordwaerts</normalizedToken>
