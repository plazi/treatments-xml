<collectingCountry id="49D7763F3635FC17C504DF65FE3CB062" box="[308,403,602,623]" name="Morocco" pageId="12" pageNumber="377">Morocco</collectingCountry>
. However, since it is a female, the presence of 
<taxonomicName id="F6C04D2C3635FC17C7B4DF66FB8EB062" authorityName="ASSING" authorityYear="2003" box="[900,1057,601,623]" class="Insecta" family="Staphylinidae" genus="Oxypoda" kingdom="Animalia" order="Coleoptera" pageId="12" pageNumber="377" phylum="Arthropoda" rank="species" species="andalusiaca">
<emphasis id="03B4EABD3635FC17C7B4DF66FB8EB062" box="[900,1057,601,623]" italics="true" pageId="12" pageNumber="377">O. andalusiaca</emphasis>
</taxonomicName>
