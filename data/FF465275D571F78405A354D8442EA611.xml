<subSubSection id="D4E2BDA3372006FB473E32A97638CD8A" pageId="null" pageNumber="545" type="description">
<paragraph id="0D9831A235EC0ABA2BBD07D3C9ECE424" pageId="null" pageNumber="545">
60-150 cm hoch. Stengel kahl oder 
<normalizedToken id="3AEC8EB150F3D079C1C1FCA2AA915897" originalValue="oberwärts" pageId="null" pageNumber="545">oberwaerts</normalizedToken>
zerstreut behaart. 
<normalizedToken id="E43E2811560F9CBDF04025A76BBC7FDA" originalValue="Blätter" pageId="null" pageNumber="545">Blaetter</normalizedToken>
lanzettlich, mit abgerundetem Grunde sitzend und gelegentlich den Stengel mit 2 kurzen Zipfeln 
<emphasis id="0D7E1B6D1DD20461EFF02DA07E22CA82" italics="true" pageId="null" pageNumber="545">wenig umfassend</emphasis>
(
<emphasis id="3C6351F3DFD8EB73AF78409259AC509E" italics="true" pageId="null" pageNumber="545">
Zipfel 
<normalizedToken id="935672384A5D949FA67A4DC38035EEFF" originalValue="schmäler" pageId="null" pageNumber="545">schmaeler</normalizedToken>
als der Durchmesser des Stengels
</emphasis>
). 
<normalizedToken id="FA3428B1CA445EE0284942A05FDB7CAA" originalValue="Blütenköpfe" pageId="null" pageNumber="545">Bluetenkoepfe</normalizedToken>
in einer Rispe, 
<emphasis id="685746EF1E111358D64E5EC71CF0E78D" italics="true" pageId="null" pageNumber="545">im Durchmesser 2</emphasis>
- 
<emphasis id="A6875BFB638B31990965C7BE74EE17CD" italics="true" pageId="null" pageNumber="545">3 cm.</emphasis>
<normalizedToken id="4ACC92764D047CBDE8C61111FD005136" originalValue="Hülle" pageId="null" pageNumber="545">Huelle</normalizedToken>
4-6 mm lang. 
<normalizedToken id="4338D361108028026C3283EDF8026AA9" originalValue="Hüllblätter" pageId="null" pageNumber="545">Huellblaetter</normalizedToken>
anliegend, 
<emphasis id="002266A6F03365ECB6828F59E1109B93" italics="true" pageId="null" pageNumber="545">
die 
<normalizedToken id="31798CD4F111C9070CD9F0AC90F4CFBF" originalValue="äußern" pageId="null" pageNumber="545">aeussern</normalizedToken>
etwa
</emphasis>
⅓- 
<normalizedToken id="160FD79B7169D9CD2DF9D1FC96206A19" originalValue="½" pageId="null" pageNumber="545">1/2</normalizedToken>
<emphasis id="8F195905D6CF815FF49A5274EFFA1F33" italics="true" pageId="null" pageNumber="545">so lang wie die innern</emphasis>
, am Grunde beiderseits bis auf den Mittelnerv 
<normalizedToken id="85361B6C77B56CF6FEBCAAF6DFA6189E" originalValue="weiß" pageId="null" pageNumber="545">weiss</normalizedToken>
und lederig, am Rande zerstreut behaart, 
<emphasis id="AFBEB6B23A935A538B436765E995E261" italics="true" pageId="null" pageNumber="545">
die innern am Grunde am breitesten und 
<normalizedToken id="7A36414221735190DE6EFB797488BC32" originalValue="allmählich" pageId="null" pageNumber="545">allmaehlich</normalizedToken>
lang zugespitzt. 
<normalizedToken id="97104DCC1E342D0744E4500EABCFC82B" originalValue="Zungenblüten" pageId="null" pageNumber="545">Zungenblueten</normalizedToken>
<normalizedToken id="CA3420D618F274473C72C42D6BE8392B" originalValue="weiß" pageId="null" pageNumber="545">weiss</normalizedToken>
bis lila.
</emphasis>
<taxonomicName id="98DDCB8807517B4560B6836209D71312" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="545" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
ca. 5 mm lang. - 
<normalizedToken id="D7D6635350A3EB38794B010FB6C84787" originalValue="Blüte" pageId="null" pageNumber="545">Bluete</normalizedToken>
: Herbst.
</paragraph>
<paragraph id="842A2053802A56D56E38DEC91AE8FA0E" pageId="null" pageNumber="545">
<emphasis id="EDB3C69873E23FE2F6B181FA83797E7F" italics="true" pageId="null" pageNumber="545">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="FE4260A8CB9A00488D762356A98B3531" pageId="null" pageNumber="545">
<emphasis id="5333FBE759535D20955530D0A7EAC06E" italics="true" pageId="null" pageNumber="545">Standort.</emphasis>
Kollin. 
<normalizedToken id="F2AEC9C9B917265E9F94712930262F03" originalValue="Ähnlich" pageId="null" pageNumber="545">Aehnlich</normalizedToken>
wie 
<emphasis id="A0EAC2E903D02A25756376476FC09FF4" italics="true" pageId="null" pageNumber="545">A. Tradescantii</emphasis>
(Nr. 5a).
</paragraph>
<paragraph id="3D2BAB64C5CCEEDADC7F91E85FE693B2" pageId="null" pageNumber="545">
<emphasis id="19612229FEEE1B7B0EB0AE5E6B4A975E" italics="true" pageId="null" pageNumber="545">Verbreitung. Nordamerikanische Pflanze.</emphasis>
In Europa als Zierpflanze 
<normalizedToken id="F28C3710F7C931E782D6236B6EF836F1" originalValue="eingeführt" pageId="null" pageNumber="545">eingefuehrt</normalizedToken>
. - Im Gebiet gelegentlich als Zierpflanze kultiviert und ziemlich selten verwildert.
</paragraph>
</subSubSection>
</treatment>
