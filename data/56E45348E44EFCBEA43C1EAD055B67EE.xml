<taxonomicName id="86DDCBF3CD86BE4A42147A7178D45B18" authority="Jan" class="Insecta" family="Staphylinidae" genus="Thesium" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="712" phylum="Arthropoda" rank="species" species="divaricatum">
