<subSubSection id="EFEC6BF4C2A3A826CF3B4BE46B33A9A5" pageId="null" pageNumber="110" type="description">
<paragraph id="87EB754438DD18F5EA26CA0267C4DFA4" pageId="null" pageNumber="110">
<emphasis id="9B42B1F0DD51FD7F2B3FA81A97BBA314" italics="true" pageId="null" pageNumber="110">
<normalizedToken id="D47B350EF5BE76B6AE2125D654FBD5BE" originalValue="Blätter" pageId="null" pageNumber="110">Blaetter</normalizedToken>
runzelig.
</emphasis>
Kelch 
<normalizedToken id="B9B3A9CF948999A9EB6FDA0B0A1BA930" originalValue="röhrenförmig" pageId="null" pageNumber="110">roehrenfoermig</normalizedToken>
, meist 10nervig, 
<emphasis id="16537D63F8B10C91EF888344B895029E" italics="true" pageId="null" pageNumber="110">
mit 5 oder 10 starren, stacheligen und hakigen 
<normalizedToken id="4C352EF577339D766844AB67CB422AFD" originalValue="Zähnen" pageId="null" pageNumber="110">Zaehnen</normalizedToken>
.
</emphasis>
Krone mit einer engen 
<normalizedToken id="B736474BABD551C33935D83098A98FEA" originalValue="Röhre" pageId="null" pageNumber="110">Roehre</normalizedToken>
und 21ippigem Rand, behaart; Oberlippe 2teilig, nach oben gebogen, 
<normalizedToken id="01454BF4B4A32A9AED4AB87C12199A37" originalValue="±" pageId="null" pageNumber="110">+/-</normalizedToken>
flach; Unterlippe 3teilig, mit breitem Mittelabschnitt. 
<normalizedToken id="206DDC27A87FDDBDABCCFCB11D90A72A" originalValue="Staubblätter" pageId="null" pageNumber="110">Staubblaetter</normalizedToken>
4, 
<emphasis id="BB7F07B44E980F534E014EC201D001BD" italics="true" pageId="null" pageNumber="110">
wie der Griffel nicht aus der 
<normalizedToken id="DD38DAA559AB2CEDD2152C881D43517D" originalValue="Kronröhre" pageId="null" pageNumber="110">Kronroehre</normalizedToken>
herausragend
</emphasis>
(von 
<normalizedToken id="312B0A7B0F57E68EAEEB3D85D97E54C7" originalValue="außen" pageId="null" pageNumber="110">aussen</normalizedToken>
nicht sichtbar), mit spreizenden 
<normalizedToken id="80B5AC1D50F9668B7C0B1B3D6E84E48B" originalValue="Staubbeutelhälften" pageId="null" pageNumber="110">Staubbeutelhaelften</normalizedToken>
; 
<emphasis id="C9C2DBE270CDD59AF7D469B8921D2FD7" italics="true" pageId="null" pageNumber="110">alle Staubbeutel normal ausgebildet;</emphasis>
<normalizedToken id="143C4B571B446C63B5988BE4A0E1D5BF" originalValue="Teilfrüchte" pageId="null" pageNumber="110">Teilfruechte</normalizedToken>
<normalizedToken id="1E5CBAA2E1D75057A44F35E427CF047B" originalValue="eiförmig" pageId="null" pageNumber="110">eifoermig</normalizedToken>
, etwas 3kantig, glatt.
</paragraph>
<paragraph id="13307DA8A1C6BDB22E0D9D80F6860CC4" pageId="null" pageNumber="110">
Die Gattung 
<emphasis id="C2214F4E16898CEBE7600F450B82E8C7" italics="true" pageId="null" pageNumber="110">
<taxonomicName id="3940DF8364D7F5F3A5473D0FBCEA0E42" class="Magnoliopsida" family="Lamiaceae" genus="Marrubium" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="110" phylum="Tracheophyta" rank="genus">Marrubium</taxonomicName>
<normalizedToken id="37A1BAEE509B8FFD5762B10479DF8396" originalValue="umfaßt" pageId="null" pageNumber="110">umfasst</normalizedToken>
etwa 30 
<normalizedToken id="A81D65631D38F0C3338F6E39614897E6" originalValue="größtenteils" pageId="null" pageNumber="110">groesstenteils</normalizedToken>
mediterrane Arten.
</emphasis>
</paragraph>
