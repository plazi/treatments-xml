<subSubSection id="84FB42BAD5B8F744F678D86E447F571A" pageId="null" pageNumber="536" type="nomenclature">
<paragraph id="7E89505D7846427DBABE5B59726308FB" pageId="null" pageNumber="536">
<taxonomicName id="980096871544B6A59AA6A2BAE06CC280" authority="L." class="Magnoliopsida" family="Fabaceae" genus="Medicago" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="536" phylum="Tracheophyta" rank="species" species="sativa">
<pageBreakToken id="13C991C16C3BD5DD1A7EFE14B58ECB65" pageId="null" pageNumber="536" start="start">Medicago</pageBreakToken>
<normalizedToken id="6E877D897EBFB96CE59DA1C904B4CDA1" originalValue="satíva" pageId="null" pageNumber="536">sativa</normalizedToken>
<authorityName id="7F88D2AD28A84D357F405607335913FB" pageId="null" pageNumber="536">L.</authorityName>
</taxonomicName>
