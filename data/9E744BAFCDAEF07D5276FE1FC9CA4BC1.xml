<subSubSection id="7FE0568B80F6117515EDA8A668D9B773" pageId="null" pageNumber="801" type="description">
<paragraph id="6069A2FBBC66F0924784F9C32BFF0005" pageId="null" pageNumber="801">
Unterscheidet sich von 
<taxonomicName id="BD9418CF945ECA861AE027CBA1E8356E" class="Magnoliopsida" family="Apiaceae" genus="Orlaya" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="801" phylum="Tracheophyta" rank="species" species="grandiflora">
<emphasis id="063EBBFF1F33A3F9288F76B54DBF2EA0" italics="true" pageId="null" pageNumber="801">O. grandiflora</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<normalizedToken id="E38DC9E0EE1C1EF3D78E6E5826BE1D71" originalValue="Hochblätter" pageId="null" pageNumber="801">Hochblaetter</normalizedToken>
1. Ordnung 2-3; 
<emphasis id="4B30DB6DF4569AAF12F1C3EC7C9499F5" italics="true" pageId="null" pageNumber="801">
Dolden 1. Ordnung mit 2-3 Dolden 2. Ordnung; 
<normalizedToken id="A81B64069204ADA2EE104B8A1EDFBD2D" originalValue="Randblüten" pageId="null" pageNumber="801">Randblueten</normalizedToken>
der Dolden 1. Ordnung mit 5 bis 7 mm langem, nach 
<normalizedToken id="1DAF733881C3E6214FCB60613C4C4CB5" originalValue="außen" pageId="null" pageNumber="801">aussen</normalizedToken>
gerichtetem Kronblatt;
</emphasis>
Frucht 10-15 mm lang. - 
<normalizedToken id="BC6F12898D2D1A6A84B188B0A736D93E" originalValue="Blüte" pageId="null" pageNumber="801">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="7AB2124F79C534EF070AF8BE4EED59DC" pageId="null" pageNumber="801">
<emphasis id="E6FF9B0595015621E318FE55C5E93E85" italics="true" pageId="null" pageNumber="801">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D4F262BFA3765923DD104C819E942C50" italics="true" pageId="null" pageNumber="801">16:</emphasis>
Material aus Italien (Larsen 1956a).
</paragraph>
<paragraph id="B8DFF896BC574528E5A0959641829641" pageId="null" pageNumber="801">
<emphasis id="01993239C7C3F95A7901DFC2A1282DBC" italics="true" pageId="null" pageNumber="801">Standort.</emphasis>
Wie 
<taxonomicName id="830469F7EBA36D873BE6869ED874B5EC" class="Magnoliopsida" family="Apiaceae" genus="Orlaya" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="801" phylum="Tracheophyta" rank="species" species="grandiflora">
<emphasis id="EF64E5F93007360688CFEA9D52E41DAF" italics="true" pageId="null" pageNumber="801">O. grandiflora</emphasis>
</taxonomicName>
(Nr. 1).
</paragraph>
<paragraph id="7086737609429583A78C653B95E7E3DF" pageId="null" pageNumber="801">
<emphasis id="AD3EFB1643414BA517F6374124B5B201" italics="true" pageId="null" pageNumber="801">Verbreitung. Mediterrane Pflanze:</emphasis>
Ganzes Mediterrangebiet, 
<normalizedToken id="EAD095D9FED07BBDB02FCCA240E4C9B9" originalValue="ostwärts" pageId="null" pageNumber="801">ostwaerts</normalizedToken>
bis Krim und Kaukasus. Verbreitungskarte von Schubert und Hilbrig (1969). - Im Gebiet: In 
<normalizedToken id="8545742F0ED07AFD4DEADFA17B69597F" originalValue="Äckern" pageId="null" pageNumber="801">Aeckern</normalizedToken>
zusammen mit 
<taxonomicName id="ACC3BB1B089311D28191BB5522CC0D88" class="Magnoliopsida" family="Apiaceae" genus="Orlaya" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="801" phylum="Tracheophyta" rank="species" species="grandiflora">
<emphasis id="31525583C7D2C067E9401BC89CB639D1" italics="true" pageId="null" pageNumber="801">O. grandiflora</emphasis>
</taxonomicName>
(Nr. 1) in der Provinz Bergamo, angegeben von Rodegher und Venanzi (1894).
</paragraph>
<paragraph id="29D39A19FC04E281E8F9F026A22ACABA" pageId="null" pageNumber="801">
<emphasis id="6DE5906C920923120C8191D7270FC1B2" italics="true" pageId="null" pageNumber="801">Bemerkungen.</emphasis>
In &quot;Flora 
<taxonomicName id="2E12921A725E8C56A6C4D9686ED363CE" class="Magnoliopsida" family="Apiaceae" genus="Sanicula" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="801" phylum="Tracheophyta" rank="species" species="europaea">Europaea</taxonomicName>
&quot; 
<emphasis id="708DFF35195FA54E31BBD8A27155685D" italics="true" pageId="null" pageNumber="801">2</emphasis>
(1968) wird der Name 
<taxonomicName id="DC34BF3E044B79D8892BE73C3C5F65C8" authority="Heywood" authorityName="Heywood" class="Magnoliopsida" family="Apiaceae" genus="Orlaya" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="801" phylum="Tracheophyta" rank="species" species="kochii">
<emphasis id="06C95262CAFC1EDE59BD1DF16F56734E" italics="true" pageId="null" pageNumber="801">O. Kochii</emphasis>
Heywood
</taxonomicName>
verwendet.
</paragraph>
</subSubSection>
