<typeStatus id="7D3F37A7FF93FFB40D02F98AFE58F92E" box="[383,495,1646,1672]" pageId="3" pageNumber="128">Lectotype</typeStatus>
<specimenCount id="B482428CFF93FFB40D8AF98AFDBBF92E" box="[503,524,1646,1672]" pageId="3" pageNumber="128" type="female">♀</specimenCount>
from Brazil, Amazonas, Parintins, bearing the locality label ‘Villa\Nova\\55\37’ (
