</paragraph>
</caption>
<subSubSection id="EA9EDA8EFF93FFB30CBAF98AFC36FE77" lastPageId="4" lastPageNumber="129" pageId="3" pageNumber="128" type="materials_examined">
<paragraph id="A23B8905FF93FFB30CBAF98AFC36FE77" blockId="3.[151,1437,1645,2034]" lastBlockId="4.[151,1437,151,501]" lastPageId="4" lastPageNumber="129" pageId="3" pageNumber="128">
