<taxonomicName id="AD2FFF1F5CE4952E91FCE8EA668EEEAA" authorityName="K. D. Hyde, Nova Hedwigia 63 (1 - 2): 91" authorityYear="1996" class="Sordariomycetes" family="Amphisphaeriaceae" genus="Arecophila" higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Arecophila gulubiicola" order="Xylariales" pageId="0" pageNumber="123" phylum="Ascomycota" rank="species" species="gulubiicola">
