<subSubSection id="F41A3FA8232E67E03DF17DBBB6810F25" pageId="null" pageNumber="839" type="description">
<paragraph id="5D560E316F2D0CD40C21D26D24C7657D" pageId="null" pageNumber="839">
Unterscheidet sich von 
<taxonomicName id="A41561B567D1E2DD9AD7BC60BAC0C455" class="Magnoliopsida" family="Caryophyllaceae" genus="Minuartia" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="839" phylum="Tracheophyta" rank="species" species="aretioides">
<emphasis id="DF03E90F6FDEC14C3F552F47BC17A23D" italics="true" pageId="null" pageNumber="839">M. aretioides</emphasis>
</taxonomicName>
(Nr. 17) durch folgendes Merkmal: 
<emphasis id="A19B9AFFC8431EC58F3B86D6A2559F43" italics="true" pageId="null" pageNumber="839">
<normalizedToken id="3ADF510633075B90CE94B7B6AC267E4A" originalValue="Blätter" pageId="null" pageNumber="839">Blaetter</normalizedToken>
am Rande bewimpert.
</emphasis>
- 
<normalizedToken id="6DAFE6BBF5562166BA12290539905589" originalValue="Blüte" pageId="null" pageNumber="839">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="E3AFBD3FFCACE623D30C2E12BEBC28C6" pageId="null" pageNumber="839">
<emphasis id="0EEF14A5B04F1B21BA018E66F0292024" italics="true" pageId="null" pageNumber="839">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="C9A9478725A7572033AC88518C6B5697" pageId="null" pageNumber="839">
<emphasis id="C6DC97100310D4F82BF14080D0BECB49" italics="true" pageId="null" pageNumber="839">Standort.</emphasis>
Alpin. Gneis- und Granitfelsen.
</paragraph>
<paragraph id="D195E0365A40F57569329F69371C5989" pageId="null" pageNumber="839">
<emphasis id="EC1B44E928600F2CA9D1337C95A4BB0E" italics="true" pageId="null" pageNumber="839">
<pageBreakToken id="9B6B8E7EF761BB1B94E7CD67186880AF" pageId="null" pageNumber="839">Verbreitung</pageBreakToken>
. Mittelalpen-Pflanze:
</emphasis>
Wallis (Arolla, Val 
<normalizedToken id="0EA2D0905145F95B3E8931EED80E9DCD" originalValue="d’Anniviers" pageId="null" pageNumber="839">d'Anniviers</normalizedToken>
, 
<normalizedToken id="5D559E1C5355FD55FF0C6B1700C89B12" originalValue="Vispertäler" pageId="null" pageNumber="839">Vispertaeler</normalizedToken>
), Aostatal (
<normalizedToken id="CAE0F49EB4762D1D0429F8B0968BC551" originalValue="Südhang" pageId="null" pageNumber="839">Suedhang</normalizedToken>
des Monte Rosa), Misox (Arbeola), Valle di Grono, Sasso della Paglia, Bormio (Piz Tresero), Ortlergebiet (Mont Vioz, Tonale). Verbreitungskarten von 
<normalizedToken id="D837DB6AFF26E3F752005E64E49DB598" originalValue="Merxmüller" pageId="null" pageNumber="839">Merxmueller</normalizedToken>
(1952) und Meusel (1964).
</paragraph>
<paragraph id="F0D3978B94D3D42DE14353F38FD05FC4" pageId="null" pageNumber="839">
<emphasis id="AA9E3EDD4D8278AC27192A4814086D35" italics="true" pageId="null" pageNumber="839">
Bemerkungen. 
<taxonomicName id="E41B67392C06E3159A7FCE652EE0095F" class="Magnoliopsida" family="Caryophyllaceae" genus="Minuartia" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="839" phylum="Tracheophyta" rank="species" species="aretioides">M. aretioides</taxonomicName>
</emphasis>
und 
<taxonomicName id="8725A8DDAC405741BA2F31755A956E62" class="Magnoliopsida" family="Caryophyllaceae" genus="Minuartia" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="839" phylum="Tracheophyta" rank="species" species="herniarioides">
<emphasis id="59F5AD65A6249156AD62C382057E6FE4" italics="true" pageId="null" pageNumber="839">M. herniarioides</emphasis>
</taxonomicName>
sind morphologisch und zytologisch eingehend zu vergleichen.
</paragraph>
</subSubSection>
