<quantity id="4CD3B6CAFFC2FFE0FB628447FA91F8FC" box="[1250,1338,1876,1902]" metricMagnitude="3" metricUnit="m" metricValue="2.0" pageId="10" pageNumber="100" unit="m" value="2000.0">2000 m</quantity>
