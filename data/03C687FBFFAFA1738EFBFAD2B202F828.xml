Status of 
<taxonomicName id="4C6F4D6EFFAFA1738F61FAD2B1F0FA91" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[269,430,1284,1311]" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
