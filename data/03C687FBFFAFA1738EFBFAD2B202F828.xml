<subSubSection id="C3756566FFAFA1738EFBFA9AB202F828" pageId="12" pageNumber="521" type="reference_group">
<paragraph id="8BD036EDFFAFA1738EFBFA9AB4BBF940" blockId="12.[151,1437,1356,1959]" pageId="12" pageNumber="521">
<taxonomicName id="4C6F4D6EFFAFA1738EFBFA9AB1E6FAE8" authorityName="Van Duzee" authorityYear="1923" box="[151,440,1356,1382]" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="species" species="unipunctata">
<emphasis id="B91BEAFFFFAFA1738EFBFA9AB1E6FAE8" box="[151,440,1356,1382]" italics="true" pageId="12" pageNumber="521">Nymphocixia unipunctata</emphasis>
</taxonomicName>
(
<figureCitation id="13542A68FFAFA1738FABFA9AB248FAE8" box="[455,534,1356,1382]" captionStart="FIGURE 11" captionStartId="13.[151,250,945,969]" captionTargetBox="[151,1436,181,922]" captionTargetId="figure-18@13.[151,1436,181,922]" captionTargetPageId="13" captionText="FIGURE 11. Adult Nymphocixia unipunctata; (A) dorsal view of adult male, (B) lateral view of adult male, (C) dorsal view of adult female, (D) lateral view of adult female, (E) lateral view of terminalia, (F) ventral view of terminalia, (G) left lateral view of aedeagus, (H) right lateral view of aedeagus, (I) ventral view of aedeagus, and (J) dorsal view of aedeagus; scale = 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6531098" httpUri="https://zenodo.org/record/6531098/files/figure.png" pageId="12" pageNumber="521">Fig. 11</figureCitation>
) was described from 
<collectingCountry id="F378767DFFAFA1738D64FA9AB300FAE8" box="[776,862,1356,1382]" name="Mexico" pageId="12" pageNumber="521">Mexico</collectingCountry>
(Isla Espíritu Santo, Gulf of California; 
<bibRefCitation id="EFFE4B1CFFAFA1738B4EFA9BB08EFA04" author="Van Duzee, E. P." pageId="12" pageNumber="521" pagination="123 - 200" refId="ref10036" refString="Van Duzee, E. P. (1923) Expedition of the California Academy of Sciences to the Gulf of California in 1921 - The Hemiptera (True Bugs, etc.). Proceedings of the California Academy of Sciences, Series 4, 12, 123 - 200." type="journal article" year="1923">Van Duzee 1923</bibRefCitation>
) with the genus established to accommodate the species due to characteristics of the head compared to 
<taxonomicName id="4C6F4D6EFFAFA1738B2EFAA6B5C2FA04" authorityName="Stal" authorityYear="1862" box="[1346,1436,1392,1418]" class="Insecta" family="Cixiidae" genus="Oecleus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738B2EFAA6B5C2FA04" box="[1346,1436,1392,1418]" italics="true" pageId="12" pageNumber="521">Oecleus</emphasis>
</taxonomicName>
(greatly elevated lateral carinae of vertex with vertex hiding the pronotum). 
<taxonomicName id="4C6F4D6EFFAFA1738D89FA42B55DFA20" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[997,1283,1428,1454]" class="Insecta" family="Cixiidae" genus="Nymphomyndus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="species" species="caribbea">
<emphasis id="B91BEAFFFFAFA1738D89FA42B55DFA20" box="[997,1283,1428,1454]" italics="true" pageId="12" pageNumber="521">Nymphomyndus caribbea</emphasis>
</taxonomicName>
(
<figureCitation id="13542A68FFAFA1738B7DFA42B53CFA20" box="[1297,1378,1428,1454]" captionStart="FIGURE 12" captionStartId="13.[151,250,1723,1747]" captionTargetBox="[151,1436,1066,1700]" captionTargetId="figure-92@13.[151,1436,1066,1700]" captionTargetPageId="13" captionText="FIGURE 12. Adult Nymphocixia caribbea; (A) dorsal view of adult male, (B) lateral view of adult male, (C) dorsal view of adult female, (D) lateral view of adult female, (E) lateral view of terminalia, (F) ventral view of terminalia, (G) left lateral view of aedeagus, (H) right lateral view of aedeagus, (I) ventral view of aedeagus, and (J) dorsal view of aedeagus; scale = 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6531100" httpUri="https://zenodo.org/record/6531100/files/figure.png" pageId="12" pageNumber="521">Fig. 12</figureCitation>
) was originally described as 
<taxonomicName id="4C6F4D6EFFAFA1738FCEFA6EB2B9FA5C" authority="(Fennah 1971)" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[418,743,1464,1490]" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738FCEFA6EB268FA5C" box="[418,566,1464,1490]" italics="true" pageId="12" pageNumber="521">Nymphocixia</emphasis>
(
<bibRefCitation id="EFFE4B1CFFAFA1738C2AFA6EB280FA5C" author="Fennah, R. G." box="[582,734,1464,1490]" pageId="12" pageNumber="521" pagination="299 - 342" refId="ref9116" refString="Fennah, R. G. (1971) Fulgoroidea from the Cayman Islands and adjacent areas. Journal of Natural History, 5, 299 - 342." type="journal article" year="1971">Fennah 1971</bibRefCitation>
)
</taxonomicName>
, however, 
<bibRefCitation id="EFFE4B1CFFAFA1738D08FA6EB46FFA5C" author="Emeljanov, A. F." box="[868,1073,1464,1490]" pageId="12" pageNumber="521" pagination="107 - 131" refId="ref9021" refString="Emeljanov, A. F. (2007) New and little known taxa of the family Cixiidae (Homoptera, Fulgoroidea). Entomological Review, 87, 287 - 308. [English translation from Entomologicheskoe Obozrenie, 86 (1), 107 - 131 (2007, in Russian)] https: // doi. org / 10.1134 / S 0013873807030062" type="book chapter" year="2007">Emeljanov (2007)</bibRefCitation>
established 
<taxonomicName id="4C6F4D6EFFAFA1738AACFA6EB52DFA5C" authorityName="Emeljanov" authorityYear="2007" box="[1216,1395,1464,1490]" class="Insecta" family="Cixiidae" genus="Nymphomyndus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738AACFA6EB52DFA5C" box="[1216,1395,1464,1490]" italics="true" pageId="12" pageNumber="521">Nymphomyndus</emphasis>
</taxonomicName>
for 
<taxonomicName id="4C6F4D6EFFAFA1738EFBFA0BB140FA78" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[151,286,1500,1526]" class="Insecta" family="Cixiidae" genus="Nymphomyndus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="species" species="caribbea">
<emphasis id="B91BEAFFFFAFA1738EFBFA0BB140FA78" box="[151,286,1500,1526]" italics="true" pageId="12" pageNumber="521">N. caribbea</emphasis>
</taxonomicName>
based on differences in the head. 
<bibRefCitation id="EFFE4B1CFFAFA1738CC0FA0AB327FA78" author="Emeljanov, A. F." box="[684,889,1500,1526]" pageId="12" pageNumber="521" pagination="107 - 131" refId="ref9021" refString="Emeljanov, A. F. (2007) New and little known taxa of the family Cixiidae (Homoptera, Fulgoroidea). Entomological Review, 87, 287 - 308. [English translation from Entomologicheskoe Obozrenie, 86 (1), 107 - 131 (2007, in Russian)] https: // doi. org / 10.1134 / S 0013873807030062" type="book chapter" year="2007">Emeljanov (2007)</bibRefCitation>
discussed 
<taxonomicName id="4C6F4D6EFFAFA1738D94FA0AB4D2FA78" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[1016,1164,1500,1526]" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738D94FA0AB4D2FA78" box="[1016,1164,1500,1526]" italics="true" pageId="12" pageNumber="521">Nymphocixia</emphasis>
</taxonomicName>
in comparison with his new genus 
<taxonomicName id="4C6F4D6EFFAFA1738F75F9D6B192F994" authorityName="Emeljanov" authorityYear="2007" box="[281,460,1536,1562]" class="Insecta" family="Cixiidae" genus="Nymphomyndus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738F75F9D6B192F994" box="[281,460,1536,1562]" italics="true" pageId="12" pageNumber="521">Nymphomyndus</emphasis>
</taxonomicName>
(and the monobasic genus 
<taxonomicName id="4C6F4D6EFFAFA1738D64F9D6B3B9F994" authority="Jacobi" authorityName="Jacobi" authorityYear="1917" box="[776,999,1536,1562]" class="Insecta" family="Cixiidae" genus="Nesomyndus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738D64F9D6B3C8F994" box="[776,918,1536,1562]" italics="true" pageId="12" pageNumber="521">Nesomyndus</emphasis>
Jacobi
</taxonomicName>
from 
<collectingCountry id="F378767DFFAFA1738A43F9D6B4E5F995" box="[1071,1211,1536,1563]" name="Madagascar" pageId="12" pageNumber="521">Madagascar</collectingCountry>
), but provided little for diagnostic comparisons among genera. The key diagnostic differences between the genera appear to be that in 
<taxonomicName id="4C6F4D6EFFAFA1738EFBF99EB114F9EC" authorityName="Emeljanov" authorityYear="2007" box="[151,330,1608,1634]" class="Insecta" family="Cixiidae" genus="Nymphomyndus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738EFBF99EB114F9EC" box="[151,330,1608,1634]" italics="true" pageId="12" pageNumber="521">Nymphomyndus</emphasis>
</taxonomicName>
the lateral margins of the vertex (dorsal view) are anteriorly converging (parallel in 
<taxonomicName id="4C6F4D6EFFAFA1738A94F99EB5D2F9EC" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[1272,1420,1608,1634]" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738A94F99EB5D2F9EC" box="[1272,1420,1608,1634]" italics="true" pageId="12" pageNumber="521">Nymphocixia</emphasis>
</taxonomicName>
), the posterior margin of the vertex does not entirely overlap the pronotum (posterior margin of vertex overlapping in 
<taxonomicName id="4C6F4D6EFFAFA1738EFBF946B175F924" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[151,299,1680,1706]" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738EFBF946B175F924" box="[151,299,1680,1706]" italics="true" pageId="12" pageNumber="521">Nymphocixia</emphasis>
</taxonomicName>
) and in lateral view, anterior profile of head “almost straight in distal three-quarters” (quoting 
<bibRefCitation id="EFFE4B1CFFAFA1738B34F946B13EF940" author="Emeljanov, A. F." pageId="12" pageNumber="521" pagination="107 - 131" refId="ref9021" refString="Emeljanov, A. F. (2007) New and little known taxa of the family Cixiidae (Homoptera, Fulgoroidea). Entomological Review, 87, 287 - 308. [English translation from Entomologicheskoe Obozrenie, 86 (1), 107 - 131 (2007, in Russian)] https: // doi. org / 10.1134 / S 0013873807030062" type="book chapter" year="2007">Emeljanov (2007: 292)</bibRefCitation>
from 
<bibRefCitation id="EFFE4B1CFFAFA1738FC8F962B2DFF940" author="Fennah, R. G." box="[420,641,1716,1742]" pageId="12" pageNumber="521" pagination="299 - 342" refId="ref9116" refString="Fennah, R. G. (1971) Fulgoroidea from the Cayman Islands and adjacent areas. Journal of Natural History, 5, 299 - 342." type="journal article" year="1971">Fennah (1971: 313)</bibRefCitation>
(versus smoothly rounding in 
<taxonomicName id="4C6F4D6EFFAFA1738DB4F962B432F940" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[984,1132,1716,1742]" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738DB4F962B432F940" box="[984,1132,1716,1742]" italics="true" pageId="12" pageNumber="521">Nymphocixia</emphasis>
</taxonomicName>
) (
<figureCitation id="13542A68FFAFA1738AE8F962B486F940" box="[1156,1240,1716,1742]" captionStart="FIGURE 13" captionStartId="14.[151,250,1036,1060]" captionTargetBox="[152,1436,181,1012]" captionTargetId="figure-25@14.[152,1436,181,1012]" captionTargetPageId="14" captionText="FIGURE 13. Adult Nymphocixia unipunctata; (A) lateral view of head, (B) dorsal view of head and (C) frontal view of head; Adult Nymphocixia caribbea; (D) lateral view of head, (E) dorsal view of head and (F) frontal view of head." figureDoi="http://doi.org/10.5281/zenodo.6531102" httpUri="https://zenodo.org/record/6531102/files/figure.png" pageId="12" pageNumber="521">Fig. 13</figureCitation>
).
</paragraph>
<paragraph id="8BD036EDFFAFA1738EABF90EB202F828" blockId="12.[151,1437,1356,1959]" pageId="12" pageNumber="521">
The level of variability between 
<taxonomicName id="4C6F4D6EFFAFA1738C54F90EB292F97C" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[568,716,1752,1778]" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738C54F90EB292F97C" box="[568,716,1752,1778]" italics="true" pageId="12" pageNumber="521">Nymphocixia</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C6F4D6EFFAFA1738D68F90EB3E9F97C" authorityName="Emeljanov" authorityYear="2007" box="[772,951,1752,1778]" class="Insecta" family="Cixiidae" genus="Nymphomyndus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738D68F90EB3E9F97C" box="[772,951,1752,1778]" italics="true" pageId="12" pageNumber="521">Nymphomyndus</emphasis>
</taxonomicName>
for 18S is significantly less than what was observed among other genera, indicating that the separation into these two genera was not warranted. Because the features listed by (Van Duzee as indicative of 
<taxonomicName id="4C6F4D6EFFAFA1738CF0F8F6B36EF8B4" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[668,816,1824,1850]" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738CF0F8F6B36EF8B4" box="[668,816,1824,1850]" italics="true" pageId="12" pageNumber="521">Nymphocixia</emphasis>
</taxonomicName>
are present in 
<taxonomicName id="4C6F4D6EFFAFA1738DBAF8F6B4AAF8B4" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[982,1268,1824,1850]" class="Insecta" family="Cixiidae" genus="Nymphomyndus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="species" species="caribbea">
<emphasis id="B91BEAFFFFAFA1738DBAF8F6B4AAF8B4" box="[982,1268,1824,1850]" italics="true" pageId="12" pageNumber="521">Nymphomyndus caribbea</emphasis>
</taxonomicName>
, lack of strong characters to merit the establishment of 
<taxonomicName id="4C6F4D6EFFAFA1738C3FF892B358F8D0" authorityName="Emeljanov" authorityYear="2007" box="[595,774,1860,1886]" class="Insecta" family="Cixiidae" genus="Nymphomyndus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738C3FF892B358F8D0" box="[595,774,1860,1886]" italics="true" pageId="12" pageNumber="521">Nymphomyndus</emphasis>
</taxonomicName>
as a distinct genus, and strong molecular support that 
<taxonomicName id="4C6F4D6EFFAFA1738B0CF893B0A9F80C" baseAuthorityName="Fennah" baseAuthorityYear="1971" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738B0CF893B0A9F80C" italics="true" pageId="12" pageNumber="521">Nymphocixia</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C6F4D6EFFAFA1738F40F8BEB181F80C" authorityName="Emeljanov" authorityYear="2007" box="[300,479,1896,1922]" class="Insecta" family="Cixiidae" genus="Nymphomyndus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738F40F8BEB181F80C" box="[300,479,1896,1922]" italics="true" pageId="12" pageNumber="521">Nymphomyndus</emphasis>
</taxonomicName>
are closely related, we here synonymize 
<taxonomicName id="4C6F4D6EFFAFA1738DC8F8BEB409F80C" authorityName="Emeljanov" authorityYear="2007" box="[932,1111,1896,1922]" class="Insecta" family="Cixiidae" genus="Nymphomyndus" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738DC8F8BEB409F80C" box="[932,1111,1896,1922]" italics="true" pageId="12" pageNumber="521">Nymphomyndus</emphasis>
</taxonomicName>
under 
<taxonomicName id="4C6F4D6EFFAFA1738ACEF8BEB568F80C" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[1186,1334,1896,1922]" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738ACEF8BEB568F80C" box="[1186,1334,1896,1922]" italics="true" pageId="12" pageNumber="521">Nymphocixia</emphasis>
</taxonomicName>
, with the composition of 
<taxonomicName id="4C6F4D6EFFAFA1738F2BF85AB185F828" baseAuthorityName="Fennah" baseAuthorityYear="1971" box="[327,475,1932,1958]" class="Insecta" family="Cixiidae" genus="Nymphocixia" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="521" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAFFFFAFA1738F2BF85AB185F828" box="[327,475,1932,1958]" italics="true" pageId="12" pageNumber="521">Nymphocixia</emphasis>
</taxonomicName>
as follows.
</paragraph>
