<treatmentCitation id="5B00DD65FFACFFA7FD9F6C179F8FF9DC" author="Castagnoli, M. &amp; Pegazzano, F." box="[555,923,1589,1611]" page="449" pageId="30" pageNumber="31" year="1985">
