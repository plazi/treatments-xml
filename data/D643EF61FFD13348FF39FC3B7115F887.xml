<taxonomicName id="99EA25F4FFD13348FC56F92672D8F887" authority="Aczel, 1958" authorityName="Aczel" authorityYear="1958" class="Insecta" family="Pyrgotidae" genus="Congopyrgota" kingdom="Animalia" order="Diptera" pageId="9" pageNumber="204" phylum="Arthropoda" rank="genus">
<emphasis id="6C9E8265FFD13348FC56F92676B2F966" box="[991,1153,1764,1790]" italics="true" pageId="9" pageNumber="204">Congopyrgota</emphasis>
