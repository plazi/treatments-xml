<taxonomicName id="F8728F1E1E15C2F83721F9237698B410" class="Magnoliopsida" family="Solanaceae" genus="Solanum" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Solanum deflexicarpum" order="Solanales" pageId="0" pageNumber="1" phylum="Tracheophyta" rank="species" species="deflexicarpum">
