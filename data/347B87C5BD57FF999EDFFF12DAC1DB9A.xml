<figureCitation id="24E92A56BD57FF999B1AFE92DAD1DB09" box="[1362,1420,279,301]" captionStart="FIGURE 1" captionStartId="2.[151,250,1978,2002]" captionTargetBox="[188,1399,796,1954]" captionTargetId="figure-394@2.[188,1399,796,1954]" captionTargetPageId="2" captionText="FIGURE 1. Breviterebra apicocrinis sp. nov., holotype, female, habitus." figureDoi="http://doi.org/10.5281/zenodo.6531138" httpUri="https://zenodo.org/record/6531138/files/figure.png" pageId="2" pageNumber="529">Fig. 1</figureCitation>
