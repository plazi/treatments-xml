<taxonomicName id="FEED50FABBFEADCD05EA2C625810C35B" class="Magnoliopsida" family="Solanaceae" genus="Solanum" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Solanum schefferi" order="Solanales" pageId="0" pageNumber="1" phylum="Tracheophyta" rank="species" species="schefferi">
