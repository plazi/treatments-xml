<taxonomicName id="916F14D2FF1E2BFB70F991586B844F33" authority="L." class="Magnoliopsida" family="Gentianaceae" genus="Gentiana" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="25" phylum="Tracheophyta" rank="species" species="asclepiadea">
