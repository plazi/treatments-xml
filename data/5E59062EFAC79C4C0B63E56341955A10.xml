<normalizedToken id="7D4D96F30D9AB80E5259562390D9BEE3" originalValue="Schlüssel" pageId="null" pageNumber="158">Schluessel</normalizedToken>
zur Gattung 
<taxonomicName id="C086F604EF29C71606DA076A7B56C4C8" class="Magnoliopsida" family="Brassicaceae" genus="Cochlearia" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="158" phylum="Tracheophyta" rank="genus">Cochlearia</taxonomicName>
