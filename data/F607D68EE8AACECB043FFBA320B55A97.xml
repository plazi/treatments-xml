<subSubSection id="F872935A3AAC41E4784797119EDFFC1C" pageId="null" pageNumber="770" type="vernacular_names">
<paragraph id="BBF3E9AC3E9CEEE39D9C8A875E3A1A9B" pageId="null" pageNumber="770">Kohl-Portulak</paragraph>
</subSubSection>
</title>
<subSubSection id="320D37C811E592FD7155DFF048CC259B" pageId="null" pageNumber="770" type="description">
<paragraph id="9CD6CE101CED58995E910D2C1B26B2FA" pageId="null" pageNumber="770">
1 
<normalizedToken id="9AB28D42654127A5BA0E9B53C4D1964E" originalValue="jährig" pageId="null" pageNumber="770">jaehrig</normalizedToken>
, niederliegend, bis 30 cm lang, fleischig, kahl. 
<normalizedToken id="E5B5F0C968203D7447FC93048A90CF83" originalValue="Blätter" pageId="null" pageNumber="770">Blaetter</normalizedToken>
oval oder 
<normalizedToken id="2A0CACC5859086795CD9965A1756F5EF" originalValue="spatelförmig" pageId="null" pageNumber="770">spatelfoermig</normalizedToken>
, bis 2 cm lang, am Ende der 
<normalizedToken id="2D41292946B2A72E83A4E60A78556E33" originalValue="Äste" pageId="null" pageNumber="770">Aeste</normalizedToken>
. 
<normalizedToken id="4B1D2DA3A756557AD2E8FD5871C87184" originalValue="Blüten" pageId="null" pageNumber="770">Blueten</normalizedToken>
sitzend, einzeln oder zu 2-3 in den gabeligen Verzweigungen oder zwischen den obersten 
<normalizedToken id="406D240DD005A05F01706700F3386D19" originalValue="Blättern" pageId="null" pageNumber="770">Blaettern</normalizedToken>
, im Durchmesser 4-6 mm, nur an sonnigen Vormittagen 
<normalizedToken id="570A71AF5AF507DDDAAEEB3EB37388E1" originalValue="geöffnet" pageId="null" pageNumber="770">geoeffnet</normalizedToken>
. 
<emphasis id="49D0899953B3D331EA173D85258034D5" italics="true" pageId="null" pageNumber="770">
<normalizedToken id="A26584C19E65E7EC140BDEA409277464" originalValue="Kronblätter" pageId="null" pageNumber="770">Kronblaetter</normalizedToken>
gelb
</emphasis>
, wenig 
<normalizedToken id="E60C3ECF58F580995A02FE52D2F03FE1" originalValue="länger" pageId="null" pageNumber="770">laenger</normalizedToken>
als die 
<normalizedToken id="A1DD30A5158A85D63721C57508B3BBFA" originalValue="Kelchblätter" pageId="null" pageNumber="770">Kelchblaetter</normalizedToken>
, bald abfallend. 
<normalizedToken id="4A178416831BF91AD96098957908378E" originalValue="Staubblätter" pageId="null" pageNumber="770">Staubblaetter</normalizedToken>
7-12. Griffel tief 5-6teilig. - 
<normalizedToken id="EB6D266B360FD499FAEB9044E53BD86B" originalValue="Blüte" pageId="null" pageNumber="770">Bluete</normalizedToken>
; Sommer bis Herbst.
</paragraph>
<paragraph id="E083F192C81CFFFD46739B7E4EA19FD7" pageId="null" pageNumber="770">
<emphasis id="18FA5E1E73EA7DDC007E7E419959F7E3" italics="true" pageId="null" pageNumber="770">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="02BB9275A634C220270C24E09FE14AEA" italics="true" pageId="null" pageNumber="770">54:</emphasis>
Viele 
<normalizedToken id="D16A0DDBBB5A35DE580392D224173EC4" originalValue="Zählungen" pageId="null" pageNumber="770">Zaehlungen</normalizedToken>
, Zusammenstellung der Literatur von Syakudo et al. (1960) und Bouharmont (1965).
</paragraph>
<paragraph id="B32BA025459E493B964209FF43770D7E" pageId="null" pageNumber="770">
<emphasis id="7D25D950C5921860745FE5D135BC1DBA" italics="true" pageId="null" pageNumber="770">Standort.</emphasis>
Kollin. Sommertrockene, sandige, 
<normalizedToken id="7D649E4AB35C94AD43510B8126356CE8" originalValue="nährstoffreiche" pageId="null" pageNumber="770">naehrstoffreiche</normalizedToken>
<normalizedToken id="6B141A9B14E65791A29ABF71E96C9614" originalValue="Böden" pageId="null" pageNumber="770">Boeden</normalizedToken>
in warmen Lagen. Weinberge, 
<normalizedToken id="E12FD8C6A215C0CE36BA258229FA3FF4" originalValue="Wegränder" pageId="null" pageNumber="770">Wegraender</normalizedToken>
, zwischen Pflastersteinen.
</paragraph>
<paragraph id="6B126590A598C60559EEB0BF689E8561" pageId="null" pageNumber="770">
<emphasis id="ED9C84865E05E5C952904CCAD4F37B87" italics="true" pageId="null" pageNumber="770">
Verbreitung. 
<normalizedToken id="22CCA663A02F04ABF99319D395635151" originalValue="Ursprünglich" pageId="null" pageNumber="770">Urspruenglich</normalizedToken>
wahrscheinlich asiatische Pflanze;
</emphasis>
heute in allen warmen Gegenden der Erde. - Im Gebiet seit der 
<normalizedToken id="F0F80442E10796EDC2F92A2B8E29A3FF" originalValue="Römerzeit" pageId="null" pageNumber="770">Roemerzeit</normalizedToken>
in den 
<normalizedToken id="A2197CB49A695DCAC938CE9718858CD7" originalValue="wärmeren" pageId="null" pageNumber="770">waermeren</normalizedToken>
Gegenden. Der 
<normalizedToken id="62C4121C33A92B93D3E6A50264709C5C" originalValue="Unkrautbekämpfung" pageId="null" pageNumber="770">Unkrautbekaempfung</normalizedToken>
wegen ziemlich selten geworden.
</paragraph>
</subSubSection>
</treatment>
