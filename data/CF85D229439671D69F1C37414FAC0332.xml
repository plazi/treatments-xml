<subSubSection id="A2BF802F4AA34813846B5F558ECD9933" pageId="null" pageNumber="489" type="description">
<paragraph id="B2576750C05ADD9D3BE5634194CBD264" pageId="null" pageNumber="489">
5-20 cm hoch. 
<normalizedToken id="47D1E6313F2D9B6CBCE46754F18B4492" originalValue="Blätter" pageId="null" pageNumber="489">Blaetter</normalizedToken>
1,5-2 mm breit, 
<emphasis id="40F64F1277B5A3842B49270B0D6E89A4" italics="true" pageId="null" pageNumber="489">eingerollt</emphasis>
(
<emphasis id="1654084E34418440FFF9A304C6AC4408" italics="true" pageId="null" pageNumber="489">binsenartig</emphasis>
), 
<emphasis id="2934DBDBB3E5DEBE66F56C0122DA30A0" italics="true" pageId="null" pageNumber="489">
<normalizedToken id="47F442AE7909A95F3EB4912044094BB0" originalValue="graugrün" pageId="null" pageNumber="489">graugruen</normalizedToken>
oder 
<normalizedToken id="FE34863EF808DA47FAB34B901BA661DE" originalValue="dunkelgrün" pageId="null" pageNumber="489">dunkelgruen</normalizedToken>
.
</emphasis>
Stengel steif aufrecht. 
<normalizedToken id="C989F466E77612152297C83ABE55B697" originalValue="Blütenstand" pageId="null" pageNumber="489">Bluetenstand</normalizedToken>
3-5 cm lang, aus 1-2 
<emphasis id="F68DCC6AB12CF33C46663E2F8D8B8171" italics="true" pageId="null" pageNumber="489">
<normalizedToken id="BD89FDE6A8362EB70792D6CCA49CE44D" originalValue="abgerückt" pageId="null" pageNumber="489">abgerueckt</normalizedToken>
</emphasis>
stehenden, meist sitzenden, 0,5-1 cm langen und 0,3-0,5 cm dicken, zylindrischen oder kugeligen ♀ 
<normalizedToken id="31164CDF3531F30845FDCAE3186FA458" originalValue="Ähren" pageId="null" pageNumber="489">Aehren</normalizedToken>
; 
<emphasis id="B467F0451FC356AE97247E67A223603D" italics="true" pageId="null" pageNumber="489">Stiel der</emphasis>
♂ 
<emphasis id="FA204A9579398B93ED0C525A3E48360F" italics="true" pageId="null" pageNumber="489">
<normalizedToken id="FFEAEE787178250BB9B95B042389CBCA" originalValue="Ähre" pageId="null" pageNumber="489">Aehre</normalizedToken>
die oberste
</emphasis>
♀ 
<emphasis id="1625BB808CB67E76EB2826B334CE7571" italics="true" pageId="null" pageNumber="489">
<normalizedToken id="C672816745CB5C9AD3384781BC4DC429" originalValue="Ähre" pageId="null" pageNumber="489">Aehre</normalizedToken>
meist deutlich 
<normalizedToken id="56EA427625FE38356DE760EDCE0521D3" originalValue="überragend" pageId="null" pageNumber="489">ueberragend</normalizedToken>
. 
<normalizedToken id="BB3DDFE8C08F3C7D7FC6103A299C3D06" originalValue="Fruchtschläuche" pageId="null" pageNumber="489">Fruchtschlaeuche</normalizedToken>
1,5-2,5 mm lang
</emphasis>
, gerade, stets 
<normalizedToken id="001AB580CD81E875B5A324ECD49BF16F" originalValue="plötzlich" pageId="null" pageNumber="489">ploetzlich</normalizedToken>
in den Schnabel 
<normalizedToken id="A08F6B9ED44E6E4B45B944C8EF7C08ED" originalValue="verschmälert" pageId="null" pageNumber="489">verschmaelert</normalizedToken>
; 
<emphasis id="C04B1187748C603F91E845347916AA06" italics="true" pageId="null" pageNumber="489">
Frucht den Fruchtschlauch 
<normalizedToken id="F8E063BA5FB6F6AEF1C639E9CD43886F" originalValue="vollständig" pageId="null" pageNumber="489">vollstaendig</normalizedToken>
<normalizedToken id="4385FC6F849C3F461A96773BACDDF4D2" originalValue="ausfüllend" pageId="null" pageNumber="489">ausfuellend</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="8BEE0EAAC21ED18B925D8C838669B914" pageId="null" pageNumber="489">
<emphasis id="A4303688B45039283ABD8961880D46B3" italics="true" pageId="null" pageNumber="489">Zytologische Angaben. 2n = 70:</emphasis>
Material aus Schweden (Davies 1955), aus Island (
<normalizedToken id="A4D1DB98D41922AC473EB6D7BCA71D0E" originalValue="Löve" pageId="null" pageNumber="489">Loeve</normalizedToken>
und 
<normalizedToken id="3F7C9C722EE67BC0E2294B91172775A6" originalValue="Löve" pageId="null" pageNumber="489">Loeve</normalizedToken>
1956b).
</paragraph>
<paragraph id="2DF53CE4711E23EC5A3988C8D87434AF" pageId="null" pageNumber="489">
<emphasis id="B23F9A5DDB4E7F72F29F1B852D92D47D" italics="true" pageId="null" pageNumber="489">Standort.</emphasis>
Kollin. Schlammig-sandiger, dichter, nasser, gelegentlich 
<normalizedToken id="10183C72FF4D39E8563294573CC782A3" originalValue="überfluteter" pageId="null" pageNumber="489">ueberfluteter</normalizedToken>
, kalkarmer Boden. 
<emphasis id="034031A8CFD3CA803DD445A619EDEDD8" italics="true" pageId="null" pageNumber="489">Cyperetum flavescentis</emphasis>
W. Koch 1926: Tretgesellschaft, die nackten Boden besiedelt und sich entlang nasser Feldwege und begangener 
<normalizedToken id="792A0ADEA239D8381147DF37433F53EC" originalValue="Grabenränder" pageId="null" pageNumber="489">Grabenraender</normalizedToken>
entwickelt. Nach Rothmaler (1963) im 
<emphasis id="4000F1F33F5870602915AB9B593E376B" italics="true" pageId="null" pageNumber="489">Nanocyperion</emphasis>
(Strandgesellschaften).
</paragraph>
<paragraph id="F0320A9F05D11E25DF366A8ABD8FC4AC" pageId="null" pageNumber="489">
<emphasis id="10EB86866D235619CBA26176A5E4567F" italics="true" pageId="null" pageNumber="489">
Verbreitung. 
<normalizedToken id="5B1C1800EE5B54E860F361C3F949BAA4" originalValue="Mitteleuropäische" pageId="null" pageNumber="489">Mitteleuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="0A08B923744884A49CC23285FF74CEBE" originalValue="Südliches" pageId="null" pageNumber="489">Suedliches</normalizedToken>
Skandinavien, 
<normalizedToken id="5B7C0F04FA80B86CA67201A582F5CE82" originalValue="Nordwestrußland" pageId="null" pageNumber="489">Nordwestrussland</normalizedToken>
, Schottland, vereinzelt in Mitteleuropa. - Im Gebiet: 
<normalizedToken id="BD160B3DEF9C124B06823EC98855343A" originalValue="Zürichsee" pageId="null" pageNumber="489">Zuerichsee</normalizedToken>
(Ufenau, 
<normalizedToken id="A74DD02F4470339297A4887025855CEE" originalValue="früher" pageId="null" pageNumber="489">frueher</normalizedToken>
<normalizedToken id="D2214690CF3F6C1472302210563D39C3" originalValue="Zürichhorn" pageId="null" pageNumber="489">Zuerichhorn</normalizedToken>
), Kaltbrunner Ried (Sulger 
<normalizedToken id="429A4530CF13F8FDD9ADC02CE3133861" originalValue="Büel" pageId="null" pageNumber="489">Bueel</normalizedToken>
<normalizedToken id="AB87A61CE8C3082EA38A55B2927C3479" originalValue="mündlich" pageId="null" pageNumber="489">muendlich</normalizedToken>
), Bodenseeufer, wahrscheinlich weiter verbreitet.
</paragraph>
</subSubSection>
