<subSubSection id="46F30F327EF095A8497E02CBDDAEEBF5" pageId="null" pageNumber="190" type="description">
<paragraph id="F852CF47DCA7C95761D6537B4C58C19A" pageId="null" pageNumber="190">
<normalizedToken id="652A4EA5ACD519D865A7CA5CFB807180" originalValue="Früchte" pageId="null" pageNumber="190">Fruechte</normalizedToken>
7-11 mm lang (mit Schnabel) und 
<normalizedToken id="ECA6CDB29B4940915F7EDF3239D8DCE6" originalValue="½" pageId="null" pageNumber="190">1/2</normalizedToken>
-⅔ so dick wie lang, 
<emphasis id="46C907A1589C1CCC732F7EBFA037B0BC" italics="true" pageId="null" pageNumber="190">
<normalizedToken id="9E54377B7CD2E5AE7B3DD0F36335A4FA" originalValue="plötzlich" pageId="null" pageNumber="190">ploetzlich</normalizedToken>
in den Schnabel 
<normalizedToken id="B43556D50F0C72863B7BED1AA2F49E50" originalValue="verschmälert" pageId="null" pageNumber="190">verschmaelert</normalizedToken>
, von der Schulter nach dem Grunde 
<normalizedToken id="F3CF5A6CC0D25F7EDD0D205EF533A533" originalValue="gleichmäβig" pageId="null" pageNumber="190">gleichmaeβig</normalizedToken>
<normalizedToken id="22D4D309809FE0BF1EFAF10B0EFD35A5" originalValue="verschmälert" pageId="null" pageNumber="190">verschmaelert</normalizedToken>
, 
<normalizedToken id="429A033904BB6A9805E31763048FC33C" originalValue="pyramidenförmig" pageId="null" pageNumber="190">pyramidenfoermig</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="4C082CDC5489F147DCAE3B050F566D4A" pageId="null" pageNumber="190">
<emphasis id="AA9D938E23D36759072662172B17C72F" italics="true" pageId="null" pageNumber="190">Zytologische Angaben.</emphasis>
Siehe unter Artengruppe.
</paragraph>
<paragraph id="BE20736108CD4DE07EDDA5D324A3491D" pageId="null" pageNumber="190">
<emphasis id="35F5F58132B69DDCD1E2EE1DE5A275FF" italics="true" pageId="null" pageNumber="190">Standort.</emphasis>
Kollin und montan. Stehende 
<normalizedToken id="CC3EFEA24C710E9F22002C37E2660330" originalValue="Gewässer" pageId="null" pageNumber="190">Gewaesser</normalizedToken>
<normalizedToken id="C22C8D65A36FC107F2ADCAC68FCC5728" originalValue="über" pageId="null" pageNumber="190">ueber</normalizedToken>
schlammigem bis sandigem Grund; Wassertiefe 0,2-1,5 m. Seebuchten, 
<normalizedToken id="8231410780BCA3D58ADCCFB8B08C847A" originalValue="Altläufe" pageId="null" pageNumber="190">Altlaeufe</normalizedToken>
. 
<emphasis id="F7F48B07DF2179894F407AC31A967E98" italics="true" pageId="null" pageNumber="190">Scirpo-Phragmitetum</emphasis>
W. Koch 1926.
</paragraph>
<paragraph id="814100A24E8D4473C0D801874E50A64D" pageId="null" pageNumber="190">
<emphasis id="D64A3B46E24D01EEBABE6889DAD0F3EB" italics="true" pageId="null" pageNumber="190">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
In 
<taxonomicName id="EAF3B95D7CC409FC21845E961372F589" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="190" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
<normalizedToken id="96103B17A89F1CAA75BB6E4D0C5A8FDF" originalValue="nordwärts" pageId="null" pageNumber="190">nordwaerts</normalizedToken>
bis England, 
<normalizedToken id="BEB8290E74C022F7A251CFC82CC3F094" originalValue="Südschweden" pageId="null" pageNumber="190">Suedschweden</normalizedToken>
und 
<normalizedToken id="EB21ACEB7559ED2DEEECA2B1E7386911" originalValue="Südfinnland" pageId="null" pageNumber="190">Suedfinnland</normalizedToken>
, 
<normalizedToken id="4FA0466D21F2C4DF357E5F485102F921" originalValue="südwärts" pageId="null" pageNumber="190">suedwaerts</normalizedToken>
bis ins Mediterrangebiet, 
<normalizedToken id="E7D1D17445517CFB5993DB09637D2901" originalValue="ostwärts" pageId="null" pageNumber="190">ostwaerts</normalizedToken>
bis Zentralsibirien; in Nordamerika Nordgrenze unbekannt, 
<normalizedToken id="B6EE23F01983C6A4873E540AAB1072A8" originalValue="Südgrenze" pageId="null" pageNumber="190">Suedgrenze</normalizedToken>
in Florida (Cook 1961). - Im Gebiet ziemlich verbreitet, nicht 
<normalizedToken id="07E4A4D7F77CF5C8EE9594490905E253" originalValue="häufig" pageId="null" pageNumber="190">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
