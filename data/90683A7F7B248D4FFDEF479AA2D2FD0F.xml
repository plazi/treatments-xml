<quantity id="DF39268C7B3B8D4FFD764060A113FD9A" box="[717,813,612,639]" metricMagnitude="-3" metricUnit="m" metricValue="1.9" pageId="17" pageNumber="72" unit="mm" value="1.9">1.9 mm</quantity>
; intertegular distance 
<quantity id="DF39268C7B3B8D4FFB894060A6ACFD9A" box="[1074,1170,612,639]" metricMagnitude="-3" metricUnit="m" metricValue="1.5" pageId="17" pageNumber="72" unit="mm" value="1.5">1.5 mm</quantity>
