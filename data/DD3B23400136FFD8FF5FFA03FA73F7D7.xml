Basionym: 
<taxonomicName id="9292E9D50136FFDBFF21FA68FD35FA20" authority="R. F. Castaneda, Revta Jardin" authorityName="R. F. Castaneda, Revta Jardin" baseAuthorityName="R. F. Castaneda" box="[246,717,1480,1502]" class="Ulvophyceae" family="Cladophoraceae" genus="Arnoldiella" kingdom="Fungi" order="Cladophorales" pageId="1" pageNumber="296" phylum="Ascomycota" rank="species" species="robusta">
<emphasis id="67E64E440136FFDBFF21FA68FE49FA23" box="[246,433,1480,1501]" italics="true" pageId="1" pageNumber="296">Arnoldiella robusta</emphasis>
R.F. Castañeda, Revta Jardín
</taxonomicName>
bot. Nac., Univ. 
<collectingRegion id="97565CB40136FFDBFCA7FA68FC41FA20" box="[880,953,1480,1502]" country="Cuba" name="La Habana" pageId="1" pageNumber="296">Habana</collectingRegion>
