</title>
<subSubSection id="7491C925337F73273690D243607600F6" pageId="null" pageNumber="314" type="description">
<paragraph id="B43C6A0F9C3D0FF16BD384D264256C4E" pageId="null" pageNumber="314">
Pflanzen krautig, ausdauernd, 
<emphasis id="EFAC4892FCB6F4CA55296BF56ADBBF15" italics="true" pageId="null" pageNumber="314">1geschlechtig</emphasis>
(2 
<normalizedToken id="F5E19E848F32A33CE7AA1E0058E02AF6" originalValue="häusig" pageId="null" pageNumber="314">haeusig</normalizedToken>
, 
<normalizedToken id="96FD1D815FDC88AAAA49FB27E7B6EC7B" originalValue="diözisch" pageId="null" pageNumber="314">dioezisch</normalizedToken>
). (Bei allen andern Rosaceengattungen unserer Flora 
<normalizedToken id="8EAF7A1731BCFFF30760BF33908E3B34" originalValue="Blüten" pageId="null" pageNumber="314">Blueten</normalizedToken>
zwitterig oder ♂ und ♀ 
<normalizedToken id="C2F7B8E1253E251B3D72DC6FE85EE2CD" originalValue="Blüten" pageId="null" pageNumber="314">Blueten</normalizedToken>
im gleichen 
<normalizedToken id="2CCCD7B04CB90703F1327A03A7A59E44" originalValue="Blütenstand" pageId="null" pageNumber="314">Bluetenstand</normalizedToken>
.) 
<emphasis id="4334CF26B0AA8F49DA13365601419E7C" italics="true" pageId="null" pageNumber="314">
<normalizedToken id="6CCD536602AF8CD621EE9C283CF3BDCD" originalValue="Blätter" pageId="null" pageNumber="314">Blaetter</normalizedToken>
2-3fach gefiedert;
</emphasis>
<normalizedToken id="CEE32CB76363A9BFD7838F64C35FC256" originalValue="Teilblätter" pageId="null" pageNumber="314">Teilblaetter</normalizedToken>
oval, scharf und meist doppelt 
<normalizedToken id="CC7F7B402CADB97742E6D4FFEAADB933" originalValue="gezähnt" pageId="null" pageNumber="314">gezaehnt</normalizedToken>
. 
<emphasis id="AB27BB3CA72BB87402203F4EDC23E4D9" italics="true" pageId="null" pageNumber="314">
<normalizedToken id="1E1FE94FEEBE0AC9938AF6A8DC4DF134" originalValue="Blütenstand" pageId="null" pageNumber="314">Bluetenstand</normalizedToken>
rispig, 
<normalizedToken id="EC70B8D10F65035F5AAFCC4C18912055" originalValue="groß" pageId="null" pageNumber="314">gross</normalizedToken>
. 
<normalizedToken id="810B683C90F281BA3BBF83CDDE4AEAC3" originalValue="Blüten" pageId="null" pageNumber="314">Blueten</normalizedToken>
klein
</emphasis>
(
<emphasis id="F7C0621C3D41808BA0E38590C8C11EC3" italics="true" pageId="null" pageNumber="314">Durchmesser 2-4 mm</emphasis>
), 
<emphasis id="24E78327E9F9C3741BE97B0C049FE226" italics="true" pageId="null" pageNumber="314">
zu Tausenden an den 
<normalizedToken id="28EC904C74066EB1DE29EBE340B21A6D" originalValue="Rispenästen" pageId="null" pageNumber="314">Rispenaesten</normalizedToken>
sitzend oder auf bis 1 mm langen Stielen.
</emphasis>
♂ und ♀ 
<normalizedToken id="5C2F21FCE85237A1EFA311044525A75E" originalValue="Blüten" pageId="null" pageNumber="314">Blueten</normalizedToken>
mit 5 
<normalizedToken id="C2CB0BF10A6A09556596B96573748C51" originalValue="Kelchblättern" pageId="null" pageNumber="314">Kelchblaettern</normalizedToken>
(Kelch 1fach) und 5 
<normalizedToken id="C34A132107116CA5D8334A0BA2CB9CCE" originalValue="Kronblättern" pageId="null" pageNumber="314">Kronblaettern</normalizedToken>
. ♂ 
<normalizedToken id="8E5C95C725FFBF69FE169970E59E814D" originalValue="Blüten" pageId="null" pageNumber="314">Blueten</normalizedToken>
mit zahlreichen (
<normalizedToken id="8103A38CBB354AE2A3AEA47DC694F127" originalValue="über" pageId="null" pageNumber="314">ueber</normalizedToken>
20) 
<normalizedToken id="CDDFE6576DB7956F2BC8E1A17422CF0E" originalValue="Staubblättern" pageId="null" pageNumber="314">Staubblaettern</normalizedToken>
, die die 
<normalizedToken id="E57FA63A2694E00465CF44BF23736D9B" originalValue="Kronblätter" pageId="null" pageNumber="314">Kronblaetter</normalizedToken>
weit 
<normalizedToken id="68E42586A07A9C27CD91DD03AC6DA1C3" originalValue="überragen" pageId="null" pageNumber="314">ueberragen</normalizedToken>
; 
<emphasis id="ECA38C0E9D5ACB47378453D401F8714D" italics="true" pageId="null" pageNumber="314">
<normalizedToken id="76499B033CCBA4BB83E37A63B2DC1B91" originalValue="rudimentäre" pageId="null" pageNumber="314">rudimentaere</normalizedToken>
<normalizedToken id="68F16D11CB2193C9322B81A710CEF311" originalValue="Fruchtblätter" pageId="null" pageNumber="314">Fruchtblaetter</normalizedToken>
vorhanden.
</emphasis>
♀ 
<normalizedToken id="89349896A68C9B7095B76EBCF48BFED0" originalValue="Blüten" pageId="null" pageNumber="314">Blueten</normalizedToken>
mit 3-5 
<normalizedToken id="DBD82418849471DFFB8FDBEA5715A25F" originalValue="Fruchtblättern" pageId="null" pageNumber="314">Fruchtblaettern</normalizedToken>
; 
<emphasis id="65F6DF5F77CE31DA48B91CD821729C09" italics="true" pageId="null" pageNumber="314">
<normalizedToken id="4071DDCE92AC546977866AA7A585809C" originalValue="rudimentäre" pageId="null" pageNumber="314">rudimentaere</normalizedToken>
<normalizedToken id="03EF00E9E9B3C199E1B0D3062BD67CB7" originalValue="Staubblätter" pageId="null" pageNumber="314">Staubblaetter</normalizedToken>
vorhanden
</emphasis>
(diese meist 
<normalizedToken id="4DC1BC1D04812B3174554368E36D8B99" originalValue="kürzer" pageId="null" pageNumber="314">kuerzer</normalizedToken>
als die 
<normalizedToken id="015C7D30826D9096C20E2FFD4A1283D2" originalValue="Kelchblätter" pageId="null" pageNumber="314">Kelchblaetter</normalizedToken>
). 
<emphasis id="F55A6F03D4ADBF4966BA040ED4885260" italics="true" pageId="null" pageNumber="314">
Frucht 
<normalizedToken id="EE1A9E7E7549DFC057BDBFDF37B17D12" originalValue="hängend" pageId="null" pageNumber="314">haengend</normalizedToken>
, 1-3 mm lang, aus 3 mehrsamigen, im untern Teil verwachsenen, nach innen aufspringenden 
<normalizedToken id="2380E3C7EF46A26F8AB8E641349B8D3B" originalValue="Fruchtblättern" pageId="null" pageNumber="314">Fruchtblaettern</normalizedToken>
</emphasis>
bestehend.
</paragraph>
<paragraph id="1265543661D26D58D41E226132DF5407" pageId="null" pageNumber="314">
Die Gattung 
<emphasis id="05BC6B90E564FE73FE08DC9245F0120C" italics="true" pageId="null" pageNumber="314">
<taxonomicName id="96808D7F5F0553B6DF3B4B1873266BE2" class="Magnoliopsida" family="Rosaceae" genus="Aruncus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="314" phylum="Tracheophyta" rank="genus">Aruncus</taxonomicName>
<normalizedToken id="5CE2FA62DB484DA5A9496A322FA8BDD9" originalValue="umfaßt" pageId="null" pageNumber="314">umfasst</normalizedToken>
3 Arten;
</emphasis>
ob die asiatischen Sippen von 
<emphasis id="305AD4D07F9E6D9ABC2CACE8168DD114" italics="true" pageId="null" pageNumber="314">A. Silvester</emphasis>
als Arten abgetrennt werden sollen, ist umstritten.
</paragraph>
</subSubSection>
