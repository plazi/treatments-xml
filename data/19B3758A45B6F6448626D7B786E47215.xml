<subSubSection id="64A4F1896B19D8CC594AC41C1B594B79" pageId="null" pageNumber="158" type="description">
<paragraph id="BEDB39BB4B8DF53551AA84F271BD9C88" pageId="null" pageNumber="158">
<emphasis id="ABF550F558DFB355C3DCC907338C01D7" italics="true" pageId="null" pageNumber="158">
<normalizedToken id="3035F934EB0C3999EE8DBA370A1968BE" originalValue="Blätter" pageId="null" pageNumber="158">Blaetter</normalizedToken>
schmal lanzettlich, 3
</emphasis>
- 
<emphasis id="6B550EC5508C12A540E1326FEE0B3D7F" italics="true" pageId="null" pageNumber="158">7mal so lang wie breit</emphasis>
, 
<normalizedToken id="54E70BC7BBEB697B764892C3CA6B0581" originalValue="allmählich" pageId="null" pageNumber="158">allmaehlich</normalizedToken>
in den kurzen Stiel 
<normalizedToken id="593F8415C0E333B63DCB47E00C54353E" originalValue="verschmälert" pageId="null" pageNumber="158">verschmaelert</normalizedToken>
, 
<emphasis id="CE97C8FC99A68D1BF51E7F4DE9B1462B" italics="true" pageId="null" pageNumber="158">
<normalizedToken id="C54CAE580A52FBDFFEF9BF435A9E8934" originalValue="graugrün" pageId="null" pageNumber="158">graugruen</normalizedToken>
</emphasis>
, kahl. 
<normalizedToken id="69683D03BDD01167E38CC915DA3C728D" originalValue="Blüten" pageId="null" pageNumber="158">Blueten</normalizedToken>
kurz gestielt, zu 1-3 in den Blattachseln, 
<emphasis id="06E6F8AF648DDF5DB9156C7B05232407" italics="true" pageId="null" pageNumber="158">hellpurpurn. Kronzipfel</emphasis>
⅔- 
<normalizedToken id="C54A4198B2D3056749DFB82C14BECB1A" originalValue="¾" pageId="null" pageNumber="158">3/4</normalizedToken>
<emphasis id="5A8644A099B6AFD80C34429D08320052" italics="true" pageId="null" pageNumber="158">
so lang wie die 
<normalizedToken id="4851DECCBAC9BC2348101BDC04ACB5DD" originalValue="Kronröhre" pageId="null" pageNumber="158">Kronroehre</normalizedToken>
.
</emphasis>
<normalizedToken id="B256D33124225BEFB59D57CA18236B58" originalValue="Staubfäden" pageId="null" pageNumber="158">Staubfaeden</normalizedToken>
am Grunde behaart. Frucht 
<normalizedToken id="7EEFB4BAD75FFC1176C1063C12F94D2B" originalValue="eiförmig" pageId="null" pageNumber="158">eifoermig</normalizedToken>
, 
<normalizedToken id="3F4BEF6E7BA7E8C98D4BDCB99E0F9DFD" originalValue="1½" pageId="null" pageNumber="158">11/2</normalizedToken>
-2 cm lang, scharlachrot. - 
<normalizedToken id="4F2F6F13DFDD2509D680CBE40C1C4922" originalValue="Blüte" pageId="null" pageNumber="158">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="B7B97B4B9F8A2EA7242338D3A66FC504" pageId="null" pageNumber="158">
<emphasis id="A3D8839B522EF5B7422E98C45E727CE6" italics="true" pageId="null" pageNumber="158">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A052BFEE29F5217B97D9BC08DE7DD18E" italics="true" pageId="null" pageNumber="158">24:</emphasis>
Material unbekannter Herkunft (Kostoff und Kendall 1929), aus Frankreich (Delay 1967), von 3 Stellen aus Polen; in einer Population wurden auch 2n = 48 
<normalizedToken id="7492BC82CC0CD99899A52B1DEDED60A3" originalValue="gezählt" pageId="null" pageNumber="158">gezaehlt</normalizedToken>
(Skalinska et al. 1971).
</paragraph>
<paragraph id="1CA1225B7A0BAE87718E9733FD74AADE" pageId="null" pageNumber="158">
<emphasis id="4FF14FA15936E874198F85A87A206152" italics="true" pageId="null" pageNumber="158">Standort.</emphasis>
Kollin, seltener montan. Lockere, steinige, 
<normalizedToken id="0BF09D86C18977F8A4220C34369F9A65" originalValue="nährstoffreiche" pageId="null" pageNumber="158">naehrstoffreiche</normalizedToken>
, oft kalkarme 
<normalizedToken id="CC7C839E03C30063956DA9D4D397EF49" originalValue="Böden" pageId="null" pageNumber="158">Boeden</normalizedToken>
in warmen Lagen. Buschige 
<normalizedToken id="77AF22C702FFF78CFF3506A191410B0B" originalValue="Hänge" pageId="null" pageNumber="158">Haenge</normalizedToken>
, Hecken, 
<normalizedToken id="85A923F8537CA35088D9AB305D858483" originalValue="Dämme" pageId="null" pageNumber="158">Daemme</normalizedToken>
.
</paragraph>
<paragraph id="984041B54D9DD13BABE38E22434BF4C0" pageId="null" pageNumber="158">
<emphasis id="89C544E9A959810534F6ACFA98C71BB8" italics="true" pageId="null" pageNumber="158">Verbreitung.</emphasis>
<normalizedToken id="F542B862C3915EDF882BC3706BEA8D54" originalValue="Ursprünglich" pageId="null" pageNumber="158">Urspruenglich</normalizedToken>
<emphasis id="5DDC183EA409D6B63F169AC9B53FD12E" italics="true" pageId="null" pageNumber="158">ostmediterrane Pflanze;</emphasis>
heute in ganz 
<normalizedToken id="664CCCFC37FCBDE6761558F3CAE71789" originalValue="Südeuropa" pageId="null" pageNumber="158">Suedeuropa</normalizedToken>
verwildert. - Im Gebiet oft als Zierstrauch angepflanzt und selten verwildert (z. B. Oberrheinische Tiefebene).
</paragraph>
</subSubSection>
