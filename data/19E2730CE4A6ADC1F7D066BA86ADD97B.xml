<td id="840518AC65C643993A4DBF3FC071997B" align="left" pageId="null" pageNumber="109" valign="top">
1*. Pflanze mit holzigen, verzweigten, unterirdischen Stengeln; 
<normalizedToken id="A0D88B743470843114DE4BB96D9325DF" originalValue="quirlähnliche" pageId="null" pageNumber="109">quirlaehnliche</normalizedToken>
<normalizedToken id="1D06B3478DB1F68A8704DEAD5D7403BE" originalValue="Teilblütenstände" pageId="null" pageNumber="109">Teilbluetenstaende</normalizedToken>
in dichten, 
<normalizedToken id="25093A651E887EE90431E43905392A24" originalValue="ährenähnlichen" pageId="null" pageNumber="109">aehrenaehnlichen</normalizedToken>
<normalizedToken id="76A7160DA4D050C1B104AF86B243B7F9" originalValue="Blütenständen" pageId="null" pageNumber="109">Bluetenstaenden</normalizedToken>
am Ende der Zweige; Kelch 
<normalizedToken id="45FDACFB8099E01EB50F4C4AAB561852" originalValue="regelmäßig" pageId="null" pageNumber="109">regelmaessig</normalizedToken>
5 
<normalizedToken id="F37DF57B02AE2233323143810BEF484A" originalValue="zähnig" pageId="null" pageNumber="109">zaehnig</normalizedToken>
</td>
<td id="B9F7F3F22C8AF5C3114A286ED79AB017" align="left" pageId="null" pageNumber="109" valign="bottom">
<taxonomicName id="771E7CFD233A304F435EA115E467A980" class="Magnoliopsida" family="Lamiaceae" genus="Sideritis" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="109" phylum="Tracheophyta" rank="species" species="hyssopifolia">
<italic id="D439A08C8BDBB94A2D6603B944D73E04" pageId="null" pageNumber="109">S. hyssopifolia</italic>
</taxonomicName>
(Nr. 2)
</td>
