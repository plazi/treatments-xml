<td id="C716A42C57ECBA22E25A4F8428A6D7CB" align="left" pageId="null" pageNumber="109" valign="top">
1. Pflanze 1 
<normalizedToken id="26B1A64AA3D51F8B3C4C36CFE434ECFE" originalValue="jährig" pageId="null" pageNumber="109">jaehrig</normalizedToken>
; 
<normalizedToken id="16BD22D92FE6891786A9E25AFA630427" originalValue="quirlähnliche" pageId="null" pageNumber="109">quirlaehnliche</normalizedToken>
<normalizedToken id="1A3F60A401B158CF759E8F93C5FCD32A" originalValue="Teilblütenstände" pageId="null" pageNumber="109">Teilbluetenstaende</normalizedToken>
locker 
<normalizedToken id="6B5AAC007344A1EE615B8286DE0251EC" originalValue="übereinanderstehend" pageId="null" pageNumber="109">uebereinanderstehend</normalizedToken>
; Kelch 21ippig
</td>
<td id="D255E59BD999C4004FDC745AF47DFA26" align="left" pageId="null" pageNumber="109" valign="bottom">
