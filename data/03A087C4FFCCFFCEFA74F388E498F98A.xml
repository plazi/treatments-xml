<emphasis id="B97DEAC0FFCCFFCDFA71F35AE068F2FF" bold="true" box="[1466,1621,3309,3334]" pageId="9" pageNumber="416">Taxonomy.</emphasis>
<taxonomicName id="4C094D51FFCCFFCDF9A8F35AEE02F2FF" authority="Brooke, 1875" authorityName="Brooke" authorityYear="1875" box="[1635,2111,3309,3334]" class="Mammalia" family="Cervidae" genus="Cervus" kingdom="Animalia" order="Artiodactyla" pageId="9" pageNumber="416" phylum="Chordata" rank="species" species="mesopotamicus">Cervus mesopotamicus Brooke, 1875</taxonomicName>
