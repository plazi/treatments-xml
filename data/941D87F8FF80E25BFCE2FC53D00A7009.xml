<taxonomicName id="DBB44D6DFF87E25AFCDBFD32D6F474BE" baseAuthorityName="Temminck" baseAuthorityYear="1836" box="[770,959,698,720]" class="Amphibia" family="Cryptobranchidae" genus="Andrias" kingdom="Animalia" order="Caudata" pageId="4" pageNumber="303" phylum="Chordata" rank="species" species="japonicus">
