<td id="E1555DD0FF801DA1FF7AF8B7D44F713B" box="[163,260,1855,1877]" gridcol="0" gridrow="17" pageId="3" pageNumber="302">22–23</td>
<td id="E1555DD0FF801DA1FEC2F8B7D7BA713B" box="[283,753,1855,1877]" gridcol="1" gridrow="17" pageId="3" pageNumber="302">Most posterior points of the exoccipital</td>
