<subSubSection id="A477190420E1D28F6A8170801E11730E" pageId="null" pageNumber="580" type="description">
<paragraph id="BFEDF6407F44139ADCA56A2180400ADD" pageId="null" pageNumber="580">
<emphasis id="BC71E71AB994831AF8A93717ED6E5E3E" italics="true" pageId="null" pageNumber="580">
1 
<normalizedToken id="53A9204053792CD9962CF1EC3DB77ECA" originalValue="jährig" pageId="null" pageNumber="580">jaehrig</normalizedToken>
, mit 
<normalizedToken id="12682664A5429F3C947A704526131FB1" originalValue="dünner" pageId="null" pageNumber="580">duenner</normalizedToken>
Pfahlwurzel;
</emphasis>
25-150 cm hoch; aromatisch riechend. Stengel kahl, aufrecht. 
<emphasis id="4674C936C940E40317CD41D8E738232A" italics="true" pageId="null" pageNumber="580">
<normalizedToken id="3ED83AC16C50C2FD16F60A14FAD3D7D5" originalValue="Blätter" pageId="null" pageNumber="580">Blaetter</normalizedToken>
kahl
</emphasis>
oder unterseits zerstreut und kurz filzig behaart, 
<emphasis id="CA4ABB3F3420E8B93179CCA2DF1AED1E" italics="true" pageId="null" pageNumber="580">
<normalizedToken id="222B73DB82D41756FD61CB604A2E35F9" originalValue="regelmäßig" pageId="null" pageNumber="580">regelmaessig</normalizedToken>
<normalizedToken id="DC3244E6DD165BE9DB5C22821FC32981" originalValue="kammförmig" pageId="null" pageNumber="580">kammfoermig</normalizedToken>
, 3
</emphasis>
- 
<emphasis id="0FD07E841CBF5F2CE6E465D97D0BB152" italics="true" pageId="null" pageNumber="580">4fach fiederteilig</emphasis>
(die obersten einfacher), die untern 
<normalizedToken id="97B9B4D0E79F4C6AC77E209E0FE53DAD" originalValue="Blätter" pageId="null" pageNumber="580">Blaetter</normalizedToken>
gestielt, bis 20 cm lang, am Grunde mit geteilten, schmalen Zipfeln; Blattzipfel spitz, ca. 0,5 mm breit. 
<normalizedToken id="3B5322F6971375CEFF623F1CB7B947BC" originalValue="Köpfe" pageId="null" pageNumber="580">Koepfe</normalizedToken>
im Durchmesser 2-4 mm, kurz gestielt (Stiel 
<normalizedToken id="96D75AD0DA64D19DD30C181A1F906283" originalValue="±" pageId="null" pageNumber="580">+/-</normalizedToken>
kahl), nickend, allseitswendig, in dichter Rispe. 
<normalizedToken id="CC6050F4E334A7F30C8301FA9A4DBB4E" originalValue="Hüllblätter" pageId="null" pageNumber="580">Huellblaetter</normalizedToken>
mit 
<normalizedToken id="63532F56D8684D0FAC641DCC0B1772B9" originalValue="weißem" pageId="null" pageNumber="580">weissem</normalizedToken>
, durchscheinendem, 
<normalizedToken id="3EBBBAD2A148904511F348E20D51879E" originalValue="trockenhäutigem" pageId="null" pageNumber="580">trockenhaeutigem</normalizedToken>
Rand, kahl. Boden des 
<normalizedToken id="3E968250D7DC9C2242C8F399E0C5256C" originalValue="Blütenkopfes" pageId="null" pageNumber="580">Bluetenkopfes</normalizedToken>
kahl. 
<normalizedToken id="F32D805ED6AD6064C1D3F26AD7C407DB" originalValue="Blüten" pageId="null" pageNumber="580">Blueten</normalizedToken>
gelb, die innern ⚥, die 
<normalizedToken id="C4EF5260637A42B8D4CD3C7126704DEE" originalValue="äußern" pageId="null" pageNumber="580">aeussern</normalizedToken>
♀. Kronen kahl. - 
<normalizedToken id="1668AAB56D83BF7B2E5FF101FB7486A2" originalValue="Blüte" pageId="null" pageNumber="580">Bluete</normalizedToken>
: 
<normalizedToken id="31532D81B37CD7E2B27CEBF3BBD4F9E5" originalValue="Später" pageId="null" pageNumber="580">Spaeter</normalizedToken>
Sommer und 
<normalizedToken id="42DB79EEEA4BA74A71CCA6C314A63096" originalValue="früher" pageId="null" pageNumber="580">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="4688BC0C2B213D94082322B156CC86A7" pageId="null" pageNumber="580">
<emphasis id="8279C5B80496E8C341511E703A1822C0" italics="true" pageId="null" pageNumber="580">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="22CD571F87CB6C5C46DFE81CB65906D8" italics="true" pageId="null" pageNumber="580">18:</emphasis>
Material aus botanischen 
<normalizedToken id="957BF1D00FCD411DA06DB2871A500DB4" originalValue="Gärten" pageId="null" pageNumber="580">Gaerten</normalizedToken>
(Weinedel 1928; Suzuka 1950a), aus Ungarn (
<normalizedToken id="82EC4B6B4EACDC1FFFD9730FE97F914E" originalValue="Pólya" pageId="null" pageNumber="580">Polya</normalizedToken>
1950), aus Japan (Arano 1968).
</paragraph>
<paragraph id="A30D3764610A2875295CF38953482674" pageId="null" pageNumber="580">
<emphasis id="39C7A966460FD2D74738F20546F3523D" italics="true" pageId="null" pageNumber="580">Standort.</emphasis>
Kollin. Stickstoffreiche, lockere 
<normalizedToken id="B8F644521F09C2F09FC1DE5D41635E1B" originalValue="Böden" pageId="null" pageNumber="580">Boeden</normalizedToken>
in 
<normalizedToken id="E15DC3DF072A2258F3C003EDF2A877A1" originalValue="wärmeren" pageId="null" pageNumber="580">waermeren</normalizedToken>
Lagen. 
<normalizedToken id="BF31715529229D5EC286B3D5C2BF194F" originalValue="Schuttplätze" pageId="null" pageNumber="580">Schuttplaetze</normalizedToken>
, 
<normalizedToken id="0A33BDF8F58C1E16503052A40E1D51F1" originalValue="Äcker" pageId="null" pageNumber="580">Aecker</normalizedToken>
, Bahnareale. 
<taxonomicName id="C476100A02681E6691EC025CABD8E06E" authority="Tx., Lohm. et Prsg. 1950" authorityName="Tx., Lohm. et Prsg." authorityYear="1950" class="Magnoliopsida" family="Brassicaceae" genus="Sisymbrion" higherTaxonomySource="GBIF" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="580" phylum="Tracheophyta" rank="genus">
<emphasis id="6E44C9812920D1F313490014F093420F" italics="true" pageId="null" pageNumber="580">Sisymbrion</emphasis>
Tx., Lohm. et Prsg. 1950
</taxonomicName>
.
</paragraph>
<paragraph id="C8C491E0EDCDD5337ED3B2C5EA7EC18B" pageId="null" pageNumber="580">
<emphasis id="EC58F6BC17BAC30AB393D6F404084D85" italics="true" pageId="null" pageNumber="580">Verbreitung. Eurasiatische Pflanze:</emphasis>
<normalizedToken id="6ACE88EFA8600EA438332943941F5D24" originalValue="Westwärts" pageId="null" pageNumber="580">Westwaerts</normalizedToken>
bis zur obern Donau und zur Weichsel; 
<normalizedToken id="50D6B6800B47C3886BCF7030240F7200" originalValue="ostwärts" pageId="null" pageNumber="580">ostwaerts</normalizedToken>
bis Japan und Korea; oft verschleppt. - Im Gebiet gelegentlich eingeschleppt (so im 
<normalizedToken id="1D69C3AD6EA15A050BCCCB7A5C68D69F" originalValue="südlichen" pageId="null" pageNumber="580">suedlichen</normalizedToken>
Tessin und in den Bergamasker Alpen im Val Camonica) oder adventiv.
</paragraph>
</subSubSection>
