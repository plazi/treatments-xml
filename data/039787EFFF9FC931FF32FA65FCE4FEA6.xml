<subSubSection id="C3246572FF9FC930FF62F94CFD21F8B2" pageId="62" pageNumber="63" type="diagnosis">
<paragraph id="8B8136F9FF9FC930FF62F94CFD21F8B2" blockId="62.[151,1437,1626,2013]" pageId="62" pageNumber="63">
<emphasis id="B94AEAEBFF9FC930FF62F94CFECCF923" bold="true" box="[199,322,1734,1760]" pageId="62" pageNumber="63">Diagnosis.</emphasis>
Females of 
<taxonomicName id="4C3E4D7AFF9FC930FE62F94DFDEAF923" authority="Rheims &amp; Jäger, 2022" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[455,612,1735,1760]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="62" pageNumber="63" phylum="Arthropoda" rank="species" species="tapirapeco" status="spec. nov.">
<emphasis id="B94AEAEBFF9FC930FE62F94DFDEAF923" box="[455,612,1735,1760]" italics="true" pageId="62" pageNumber="63">M. tapirapeco</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFF9FC930FDCCF94DFD54F922" bold="true" box="[617,730,1735,1761]" pageId="62" pageNumber="63">
<taxonomicNameLabel id="A2795790FF9FC930FDCCF94DFD54F922" box="[617,730,1735,1761]" pageId="62" pageNumber="63" rank="species">spec. nov.</taxonomicNameLabel>
</emphasis>
resemble those of 
<taxonomicName id="4C3E4D7AFF9FC930FC0DF94DFBE6F923" authorityName="Rheims &amp; Jäger" authorityYear="2022" baseAuthorityName="Simon" baseAuthorityYear="1898" box="[936,1128,1735,1760]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="62" pageNumber="63" phylum="Arthropoda" rank="species" species="sanctivincenti" status="comb. nov.">
<emphasis id="B94AEAEBFF9FC930FC0DF94DFBE6F923" box="[936,1128,1735,1760]" italics="true" pageId="62" pageNumber="63">M. sanctivincenti</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFF9FC930FBC8F94DFB62F922" bold="true" box="[1133,1260,1735,1761]" pageId="62" pageNumber="63">
<taxonomicNameLabel id="A2795790FF9FC930FBC8F94DFB62F922" box="[1133,1260,1735,1761]" pageId="62" pageNumber="63" rank="species">comb. nov.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13052A7CFF9FC930FB5FF94DFA1BF922" box="[1274,1429,1734,1761]" captionStart="FIGURES 250–252" captionStartId="61.[151,264,1938,1962]" captionTargetBox="[189,1403,1171,1906]" captionTargetId="figure-364@61.[181,1406,1166,1915]" captionTargetPageId="61" captionText="FIGURES 250–252. Meri sanctivincenti (Simon) comb. nov., female (250 epigyne, 251 vulva, 252 schematic course of internal duct system). EP—epigynal pocket; ft—first turn of duct system; FD—fertilization duct; GP—glandular projection; LL—lateral lobe; MS—median septum; SP—spermathecae. Scale line: 1 mm. Modified from Jäger 2020 (94: figs 349–351)." figureDoi="http://doi.org/10.5281/zenodo.6550498" httpUri="https://zenodo.org/record/6550498/files/figure.png" pageId="62" pageNumber="63">Figs 250–252</figureCitation>
) and 
<taxonomicName id="4C3E4D7AFF9FC930FF6DF961FEA0F8C6" authority="Rheims &amp; Jäger, 2022" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[200,302,1771,1797]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="62" pageNumber="63" phylum="Arthropoda" rank="species" species="zeteki" status="spec. nov.">
<emphasis id="B94AEAEBFF9FC930FF6DF961FEA0F8C6" box="[200,302,1771,1797]" italics="true" pageId="62" pageNumber="63">M. zeteki</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFF9FC930FE90F961FE27F8C6" bold="true" box="[309,425,1771,1797]" pageId="62" pageNumber="63">
<taxonomicNameLabel id="A2795790FF9FC930FE90F961FE27F8C6" box="[309,425,1771,1797]" pageId="62" pageNumber="63" rank="species">spec. nov.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13052A7CFF9FC930FE1CF961FDDBF8C6" box="[441,597,1771,1797]" captionStart="FIGURES 309–311" captionStartId="75.[151,264,1172,1196]" captionTargetBox="[177,1410,642,1141]" captionTargetId="figure-185@75.[170,1418,633,1148]" captionTargetPageId="75" captionText="FIGURES 309–311. Meri zeteki spec. nov. female (MCZ 99617, holotype) (309 epigyne, 310 vulva, 311 schematic course of internal duct system). ag—anterior groove; EP—epigynal pocket; FD—fertilization duct; ft—first turn of duct system; GP— glandular projection; LL—lateral lobe; MS—median septum; SP—spermathecae. Scale lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6550416" httpUri="https://zenodo.org/record/6550416/files/figure.png" pageId="62" pageNumber="63">Figs 309–311</figureCitation>
) by the epigyne with EP opening medially on MS. They are distinguished from both species by the MS wider than long (
<figureCitation id="13052A7CFF9FC930FD16F885FC9AF8EA" box="[691,788,1806,1833]" captionStart="FIGURES 253–259" captionStartId="63.[151,264,1813,1837]" captionTargetBox="[163,1422,393,1776]" captionTargetId="figure-80@63.[154,1434,381,1790]" captionTargetPageId="63" captionText="FIGURES 253–259. 253–256 Meri tambor spec. nov., male (INPA 3522), left palp (253 prolateral, 254 ventral, 255 retrolateral, 256 detail of embolus); 257–259 Meri tapirapeco spec. nov., female (INPA) (257 epigyne, 258 vulva, 259 schematic course of internal duct system). C—conductor; E—embolus; EP— epigynal pocket; FD—fertilization duct; ft—first turn of duct system; GP—glandular projection; LL—lateral lobe; MS—median septum; PTA—prolateral tibial apophysis; RpP—retro proximal projection; RTA—retrolateral tibial projection; SdP—subdistal projection; SP—spermathecae; tp—tegular protrusion. Scale lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6550500" httpUri="https://zenodo.org/record/6550500/files/figure.png" pageId="62" pageNumber="63">Fig. 257</figureCitation>
) and internal ducts with FW U-shaped and laterad (
<figureCitation id="13052A7CFF9FC930FACEF885FF75F88E" captionStart="FIGURES 253–259" captionStartId="63.[151,264,1813,1837]" captionTargetBox="[163,1422,393,1776]" captionTargetId="figure-80@63.[154,1434,381,1790]" captionTargetPageId="63" captionText="FIGURES 253–259. 253–256 Meri tambor spec. nov., male (INPA 3522), left palp (253 prolateral, 254 ventral, 255 retrolateral, 256 detail of embolus); 257–259 Meri tapirapeco spec. nov., female (INPA) (257 epigyne, 258 vulva, 259 schematic course of internal duct system). C—conductor; E—embolus; EP— epigynal pocket; FD—fertilization duct; ft—first turn of duct system; GP—glandular projection; LL—lateral lobe; MS—median septum; PTA—prolateral tibial apophysis; RpP—retro proximal projection; RTA—retrolateral tibial projection; SdP—subdistal projection; SP—spermathecae; tp—tegular protrusion. Scale lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6550500" httpUri="https://zenodo.org/record/6550500/files/figure.png" pageId="62" pageNumber="63">Figs 258–259</figureCitation>
) (MS as long as wide and FW sinuous and posteriad in 
