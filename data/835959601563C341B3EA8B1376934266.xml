<subSubSection id="60F651B9ED7B0ECE22368228691F6B19" pageId="null" pageNumber="590" type="description">
<paragraph id="72C6C98AD825589A9A52C3E0ACE68086" pageId="null" pageNumber="590">
1-2 
<normalizedToken id="BC46A1DAA8E31BFC821C52FBB19EB90F" originalValue="jährig" pageId="null" pageNumber="590">jaehrig</normalizedToken>
; 20-100 cm hoch, mit 
<normalizedToken id="B109A301107B13067B5BA8663881CA07" originalValue="dünner" pageId="null" pageNumber="590">duenner</normalizedToken>
Pfahlwurzel. Stengel aufrecht oder 
<normalizedToken id="5D6D322A13CDDBD5EC397B35FF6D0553" originalValue="hängend" pageId="null" pageNumber="590">haengend</normalizedToken>
, verzweigt, kahl. 
<normalizedToken id="9B37DB47C3E5266F900DEED3DC3760A1" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
kahl, 
<normalizedToken id="B7695AF16A6CB78986C5E68C1006439E" originalValue="dunkelgrün" pageId="null" pageNumber="590">dunkelgruen</normalizedToken>
, unterseits blasser, 
<emphasis id="EDF0C09B18349453A833FAF1A22F4269" italics="true" pageId="null" pageNumber="590">bis auf den Mittelnerv fiederteilig</emphasis>
(Abschnitte schmal lanzettlich bis rhombisch, oft nochmals fiederteilig oder mit einzelnen stumpfen 
<normalizedToken id="4B1E2BB4C0D33FD97FDBDBD9630581DE" originalValue="Zähnen" pageId="null" pageNumber="590">Zaehnen</normalizedToken>
); 
<emphasis id="D61198A7B393CE939CF6BFFCF09FE38F" italics="true" pageId="null" pageNumber="590">
untere und mittlere 
<normalizedToken id="627C2CCA4F2AB920D1C2E177B8933F6E" originalValue="Stengelblätter" pageId="null" pageNumber="590">Stengelblaetter</normalizedToken>
gestielt
</emphasis>
, die obern sitzend, den Stengel mit 2 spitzen Zipfeln umfassend. 
<normalizedToken id="0B7072AB42EDC3629468ECAB7B04E192" originalValue="Blütenköpfe" pageId="null" pageNumber="590">Bluetenkoepfe</normalizedToken>
in einer Rispe, die obersten doldenartig 
<normalizedToken id="2419025D8D890160F2F2B54444AC3A8B" originalValue="gehäuft" pageId="null" pageNumber="590">gehaeuft</normalizedToken>
. 
<normalizedToken id="5E932395AE6CFFB3733D7B672EA83139" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
12-15 mm lang, kahl, vor dem 
<normalizedToken id="044211D62C5E5959C6C38947742FCD12" originalValue="Aufblühen" pageId="null" pageNumber="590">Aufbluehen</normalizedToken>
dicht 
<normalizedToken id="5E5BACF3A90C913371B8F7A597860053" originalValue="weißflockig" pageId="null" pageNumber="590">weissflockig</normalizedToken>
behaart, nach dem 
<normalizedToken id="D87F8A9E3669D99C63D8F5FB60CB3181" originalValue="Verblühen" pageId="null" pageNumber="590">Verbluehen</normalizedToken>
bauchig erweitert. Krone gelb, an der Zunge 
<normalizedToken id="FA9F8FD3884090C008D0095D7A79C439" originalValue="außerseits" pageId="null" pageNumber="590">ausserseits</normalizedToken>
<normalizedToken id="12877352E94B9CAF853B533E50B5493B" originalValue="rötlich" pageId="null" pageNumber="590">roetlich</normalizedToken>
, 1,5-2 cm lang. Griffel und Narbe braun. 
<normalizedToken id="48BFCC7F90AB7E64AC8317B1A1C52E17" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
2-3 mm lang, ohne Rand, 
<emphasis id="E7AE9C4E11A8E721BB2E68DEDF42BD10" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="CF27901F24F1D7DE086213A918F1FDF2" originalValue="höckerig" pageId="null" pageNumber="590">hoeckerig</normalizedToken>
</emphasis>
, braun. - 
<normalizedToken id="69C598A6F7E5D6B9B0AEA7D6AB45910B" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="FCCBD145839392A0B352BC2354F7ED7A" pageId="null" pageNumber="590">
<emphasis id="D66A1E7D2A6C61961AAC5D23A8498482" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B1945C5200EA625C8F78EBD805C62B9C" italics="true" pageId="null" pageNumber="590">14:</emphasis>
Material aus botanischem Garten (Stebbins et al. 1953a), aus 
<normalizedToken id="A1D36FC4B293AE5B25FB8F466FA1D76B" originalValue="Süditalien" pageId="null" pageNumber="590">Sueditalien</normalizedToken>
(Larsen 1956a).
</paragraph>
<paragraph id="FCBF10CAEA2FF5114B65C2928E1521D7" pageId="null" pageNumber="590">
<emphasis id="0207AC5B810A0E6478EC77612E454DF1" italics="true" pageId="null" pageNumber="590">Standort</emphasis>
. Kollin. Felsen, Mauern, 
<normalizedToken id="763450847E998D9EB96EBA7D5E967C59" originalValue="Schuttplätze" pageId="null" pageNumber="590">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="FF8D2E921EE722F51DA6C7020C888B57" pageId="null" pageNumber="590">
<emphasis id="D7CFE1C3AB8FA5D6F23AFA9DB16EADDB" italics="true" pageId="null" pageNumber="590">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="50935318F03EF670EA2E2B8B2CA31D13" originalValue="Südeuropa" pageId="null" pageNumber="590">Suedeuropa</normalizedToken>
; 
<normalizedToken id="BB9FC52F78EC811877857770630B6847" originalValue="Südwestasien" pageId="null" pageNumber="590">Suedwestasien</normalizedToken>
(
<normalizedToken id="83804D43955512963B21C03E9D0DCF35" originalValue="ostwärts" pageId="null" pageNumber="590">ostwaerts</normalizedToken>
bis Persien); Nordafrika, Abessinien. - Im Gebiet: Alte Angaben aus dem Val 
<normalizedToken id="A414C0B6525CD871CC18B2A9E549C319" originalValue="d’Ossola" pageId="null" pageNumber="590">d'Ossola</normalizedToken>
, Veltlin und Comerseegebiet, die vielleicht auf Verwechslungen beruhen; selten adventiv.
</paragraph>
</subSubSection>
