and 
<taxonomicName id="03944D7DFF806A3FFC169D121A80B05E" authorityName="Hall &amp; Jones" authorityYear="1961" box="[1002,1152,2891,2924]" class="Liliopsida" family="Poaceae" genus="Lasiurus" kingdom="Plantae" order="Poales" pageId="123" pageNumber="881" phylum="Tracheophyta" rank="species" species="insularis">L. insularis</taxonomicName>
