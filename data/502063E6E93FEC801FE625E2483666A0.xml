<subSubSection id="88BF5D6109BD6C4738CE87EAF636A1F8" pageId="null" pageNumber="297" type="nomenclature">
<paragraph id="949C3D0C5EC4757B9A7F633970865FDE" pageId="null" pageNumber="297">
<taxonomicName id="C6EE714D9A0127E8CC2393D5618B78BF" authority="Ehrend." class="Magnoliopsida" family="Rubiaceae" genus="Galium" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="297" phylum="Tracheophyta" rank="species" species="pseudohelveticum">Galium pseudohelveticum Ehrend.</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="D16FE89CEE9CC15DA485A685954ACFAC" pageId="null" pageNumber="297" type="vernacular_names">
<paragraph id="45CC524ED7B34609AEC57F81FC9EFB26" pageId="null" pageNumber="297">Westalpen-Labkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="22827265E1A756943AD98A0B7B812024" pageId="null" pageNumber="297" type="description">
<paragraph id="E5081309457311E0BCF7D2610356E428" pageId="null" pageNumber="297">
8-12 cm hoch, 
<normalizedToken id="824AAE86D43ADD3E85ABB0EBE1030A2A" originalValue="±" pageId="null" pageNumber="297">+/-</normalizedToken>
dichtrasig. Stengel kriechend (
<emphasis id="E1F7A6EE7E8FD1F48BA3CC0D87F6366C" italics="true" pageId="null" pageNumber="297">Schuttkriecher!</emphasis>
), meist aufsteigend, 
<normalizedToken id="DC48A2C7F834BB555784DBFE6C74058D" originalValue="±" pageId="null" pageNumber="297">+/-</normalizedToken>
kahl. Mittlere 
<normalizedToken id="451D7067964004D62145CA75B0CA1B6C" originalValue="Blätter" pageId="null" pageNumber="297">Blaetter</normalizedToken>
zu 7-8 im Quirl, 
<emphasis id="42B0A3D98AECB3D2D5EA7E3982390EAB" italics="true" pageId="null" pageNumber="297">0,7</emphasis>
- 
<emphasis id="0931FD720F848CED0B92E0B403B21DE4" italics="true" pageId="null" pageNumber="297">1,1 cm lang, 4</emphasis>
<normalizedToken id="1803897EE22FD152E14272368DCB6BE4" originalValue="½-6½" pageId="null" pageNumber="297">1/2-61/2</normalizedToken>
<emphasis id="408A5397BA8C943466D00F88DC75187F" italics="true" pageId="null" pageNumber="297">mal so lang wie breit</emphasis>
, mit der 
<normalizedToken id="11987A96FD5C854370E061E17C58EBCA" originalValue="größten" pageId="null" pageNumber="297">groessten</normalizedToken>
Breite an der Spitze, 
<normalizedToken id="BE0C6C4304BA310EABDFD07A6AF071D0" originalValue="plötzlich" pageId="null" pageNumber="297">ploetzlich</normalizedToken>
in die 0,2-0,3 mm lange, hyaline Spitze 
<normalizedToken id="3821120CC78A24895850B14665BB5519" originalValue="verschmälert" pageId="null" pageNumber="297">verschmaelert</normalizedToken>
, am Rande flach, 
<emphasis id="0681C28E8833151159FFE492D61A7E89" italics="true" pageId="null" pageNumber="297">mit einzelnen, nach vorn gerichteten, kurzen Haaren</emphasis>
, sonst kahl. 
<normalizedToken id="4B20DDA977C42ABC2ACEFD85A0C40173" originalValue="Blütenstände" pageId="null" pageNumber="297">Bluetenstaende</normalizedToken>
wenig- bis 
<normalizedToken id="8F68135DE80CCED9D14097CB60D222F3" originalValue="vielblütig" pageId="null" pageNumber="297">vielbluetig</normalizedToken>
, kurz, mit von den obersten 1-3 Blattquirlen ausgehenden 
<normalizedToken id="2C4E77CABC60ECD131F580EDBFDADBD9" originalValue="Seitenästen" pageId="null" pageNumber="297">Seitenaesten</normalizedToken>
, daher 
<normalizedToken id="903AB0EC460067E2F2ADEA12AD8F0CB8" originalValue="pyramidenförmig" pageId="null" pageNumber="297">pyramidenfoermig</normalizedToken>
bis 
<normalizedToken id="37FBBD019E60A45CACA1ED3432EC3BF6" originalValue="schirmförmig" pageId="null" pageNumber="297">schirmfoermig</normalizedToken>
. Krone 3-4 mm im Durchmesser, 
<normalizedToken id="EB1E0AB9DEC367625B264EFC7DD81DDF" originalValue="gelblichweiß" pageId="null" pageNumber="297">gelblichweiss</normalizedToken>
. 
<normalizedToken id="AF5EDE8C49EFFC4CCB058CDA8BBA571C" originalValue="Früchte" pageId="null" pageNumber="297">Fruechte</normalizedToken>
<normalizedToken id="F2174AD999E6832C4DF1F5108A95E217" originalValue="±" pageId="null" pageNumber="297">+/-</normalizedToken>
glatt, 1,4-1,7 mm hoch. - 
<normalizedToken id="99DB52BD28ED88281CFABCADA16D4018" originalValue="Blüte" pageId="null" pageNumber="297">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="0DA429AA9A4D878DA400C5C752372746" pageId="null" pageNumber="297">
<emphasis id="C23CE43FFC91CEDC67730E6F1086AEBA" italics="true" pageId="null" pageNumber="297">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="89D158EB1C3C3F3A54E68F1EF9AE1257" italics="true" pageId="null" pageNumber="297">44:</emphasis>
Material aus den Westalpen (Ehrendorfer 1960).
</paragraph>
<paragraph id="B4DD6144E322D1FB163BA5A4D4230828" pageId="null" pageNumber="297">
<emphasis id="0EC0273D2DF764366E8707D69D374951" italics="true" pageId="null" pageNumber="297">Standort.</emphasis>
Alpin. Kalkreiche 
<normalizedToken id="E3CEAB9076B93A93BED49F80F59460F8" originalValue="Böden" pageId="null" pageNumber="297">Boeden</normalizedToken>
. Kalk- und Schieferschutt und - 
<normalizedToken id="89A23D030FF6E2C890769F59ADFE0BAA" originalValue="geröll" pageId="null" pageNumber="297">geroell</normalizedToken>
.
</paragraph>
<paragraph id="55EC2A6F72299479699296FF8F48720A" pageId="null" pageNumber="297">
<emphasis id="8B2993A449ABF76840094A3D398E51ED" italics="true" pageId="null" pageNumber="297">Verbreitung. Westalpen-Pflanze:</emphasis>
Basses Alpes bis Nordsavoyen, - Im Gebiet: Savoyen; im Aostatal und in den westlichen Kalkalpen ist auf die Art zu achten!
</paragraph>
<paragraph id="85E4DF8B88E9412495ED9619A009B923" pageId="null" pageNumber="297">
<emphasis id="606C0836BFE1F0BBAA25BC7038214D90" italics="true" pageId="null" pageNumber="297">
Bemerkungen. 
<taxonomicName id="56349FA75F1D0B032EFF051F6B903E52" class="Magnoliopsida" family="Rubiaceae" genus="Galium" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="297" phylum="Tracheophyta" rank="species" species="pseudohelveticum">G. pseudohelveticum</taxonomicName>
</emphasis>
ist wahrscheinlich durch Allopolyploidie aus diploiden Sippen von 
<taxonomicName id="6B392A8C59A79E8DA7B4C2023EB5E220" class="Magnoliopsida" family="Rubiaceae" genus="Galium" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="297" phylum="Tracheophyta" rank="species" species="helveticum">
<emphasis id="3F1D303ECEAE8259E53C693C656BB718" italics="true" pageId="null" pageNumber="297">G. helveticum</emphasis>
</taxonomicName>
und 
<emphasis id="7EE729A800D9B6D019DCA79E3204F0A8" italics="true" pageId="null" pageNumber="297">G. anisophyllum</emphasis>
(
<taxonomicName id="1B864B06E67C8CA5A25E031AE33B0050" authority="Vill." authorityName="Vill." class="Magnoliopsida" family="Rubiaceae" genus="Galium" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="297" phylum="Tracheophyta" rank="species" species="tenue">
<emphasis id="4690FE8A0B34B9A1F2DDE39AD7448E5B" italics="true" pageId="null" pageNumber="297">G. tenue</emphasis>
Vill.
</taxonomicName>
) entstanden (Ehrendorfer 1960).
</paragraph>
</subSubSection>
