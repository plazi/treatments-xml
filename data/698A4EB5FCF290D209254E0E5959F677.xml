<subSubSection id="84AFA3D4C275E1F9301A38C445892F98" lastPageNumber="206" pageId="null" pageNumber="207" type="description">
<paragraph id="6A1B68101924E74728853817BD2603C7" pageId="null" pageNumber="207">
Unterscheidet sich von 
<taxonomicName id="B335035F81125919A55AFE2882298E11" class="Magnoliopsida" family="Brassicaceae" genus="Cardamine" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="207" phylum="Tracheophyta" rank="species" species="kitaibelii">
<emphasis id="651B51CF84F2819478270ABBEB3FB1E6" italics="true" pageId="null" pageNumber="207">C. Kitaibelii</emphasis>
</taxonomicName>
(Nr. 13) durch folgende Merkmale: 30 
<emphasis id="55B54EA0ED97AE984F1FD96ECA0487F6" italics="true" pageId="null" pageNumber="207">-</emphasis>
60 cm hoch; 
<emphasis id="D27DA95F10788D6C8DDF049AEF16FF50" italics="true" pageId="null" pageNumber="207">
Stengel kahl; 
<normalizedToken id="F125B70F0C33E473C7740BBC59DF4094" originalValue="Stengelblätter" pageId="null" pageNumber="207">Stengelblaetter</normalizedToken>
<normalizedToken id="62ACBBC474D2030C52ECDDCCB7673C86" originalValue="wechselständig" pageId="null" pageNumber="207">wechselstaendig</normalizedToken>
; 
<normalizedToken id="4CEAF354AEBA542292FA165C24D8E7A0" originalValue="Kronblätter" pageId="null" pageNumber="207">Kronblaetter</normalizedToken>
<normalizedToken id="81A531F65C94DC0D5076326963818464" originalValue="weiß" pageId="null" pageNumber="207">weiss</normalizedToken>
oder 
<normalizedToken id="65A27004D18D0EC1F6D0E03ACD740690" originalValue="blaßlila" pageId="null" pageNumber="207">blasslila</normalizedToken>
;
</emphasis>
Griffel an der Frucht 3,5 
<emphasis id="FD5E162C6ED1577898AAF3B76322097B" italics="true" pageId="null" pageNumber="207">-</emphasis>
10 mm lang. - 
<normalizedToken id="E05869C23007DF45623777073B7E0C31" originalValue="Blüte" pageId="null" pageNumber="207">Bluete</normalizedToken>
: 
<normalizedToken id="47140B11703B9C53861CC57C799BA628" originalValue="Frühling" pageId="null" pageNumber="207">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="033C11C51D8777A9C0E59CFCABBD2F86" pageId="null" pageNumber="207">
<emphasis id="F49AF5DE275263BA4652987C2155E875" italics="true" pageId="null" pageNumber="207">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="78C01DC0F00D92294B0C9446567902E6" italics="true" pageId="null" pageNumber="207">48:</emphasis>
Material aus der Schweiz (Schwarzenbach 1922).
</paragraph>
<paragraph id="66969C4FF0AE93746487130F0CA012BD" pageId="null" pageNumber="207">
<emphasis id="6233642D89680F7DA81AD91709DF5061" italics="true" pageId="null" pageNumber="207">Standort.</emphasis>
Kollin und montan, selten subalpin. Lockere, ziemlich feuchte, 
<normalizedToken id="B8AEF7853053F217C9A098E5C0DBCA0C" originalValue="nährstoffreiche" pageId="null" pageNumber="207">naehrstoffreiche</normalizedToken>
, meist kalkhaltige, humose, tonige 
<normalizedToken id="7ECA6602CBFD5B1B7922BB52552B1869" originalValue="Böden" pageId="null" pageNumber="207">Boeden</normalizedToken>
in schattigen Lagen. Buchen- und 
<normalizedToken id="60B13CCD0D255DA4E65902E888EE6B52" originalValue="Buchenmischwälder" pageId="null" pageNumber="207">Buchenmischwaelder</normalizedToken>
. 
<emphasis id="6C20E6C508199E75A00B08E521B2CBC2" italics="true" pageId="null" pageNumber="207">Fagion</emphasis>
<normalizedToken id="21B0DD4023662DADFCA158463C19404C" originalValue="Tüxen" pageId="null" pageNumber="207">Tuexen</normalizedToken>
et Diem. 1936.
</paragraph>
<paragraph id="452AF403AEE38C45D85F39C3D6B719AB" lastPageNumber="206" pageId="null" pageNumber="207">
<emphasis id="3809FD521B4CAA03BD2D199A961B0D38" italics="true" pageId="null" pageNumber="207">
Verbreitung. Mittel- und 
<normalizedToken id="249DFD30D7D9CCD976DCCE826518EB5A" originalValue="südeuropäische" pageId="null" pageNumber="207">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="E36D254150ABBEDFAE40EF3E1DA0B04B" italics="true" pageId="null" pageNumber="207">westlich</emphasis>
)
<emphasis id="4FCCDCE365E3545E64B1D29AD7D265B0" italics="true" pageId="null" pageNumber="207">:</emphasis>
<normalizedToken id="B3CE2B67F8B7579610A2CBC1D615CBED" originalValue="Pyrenäen" pageId="null" pageNumber="207">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="0EF4F484D8FB2C39AB77B34F46540A36" originalValue="mittelfranzösische" pageId="null" pageNumber="207">mittelfranzoesische</normalizedToken>
Gebirge, 
<normalizedToken id="3E51997372CE08CC37D0D37B39C0B4B7" originalValue="Südschwarzwald" pageId="null" pageNumber="207">Suedschwarzwald</normalizedToken>
, Jura, Hegau, Alpen und Alpenvorland (
<normalizedToken id="7801BB4B196C785A26D6DC3A45A65061" originalValue="ostwärts" pageId="null" pageNumber="207">ostwaerts</normalizedToken>
bis Bodensee und Monte Baldo), Apennin (
<normalizedToken id="1F240D81B163F3328A5F9A4B39381C35" originalValue="süd-" pageId="null" pageNumber="207">sued-</normalizedToken>
<pageBreakToken id="B0C561B3C99DC19C30E2CA7535685014" pageId="null" pageNumber="206" start="start">
<normalizedToken id="6D54581BE7F907BF9F9288783D27316E" originalValue="wärts" pageId="null" pageNumber="206">waerts</normalizedToken>
</pageBreakToken>
bis Avellino, isoliert am Monte Sila in Kalabrien). -, Sundgau, Vogesen, 
<normalizedToken id="6DA36A4CEB79CE205E2A877105A35665" originalValue="südlicher" pageId="null" pageNumber="206">suedlicher</normalizedToken>
Schwarzwald, Baar, Hegau, Bodenseegebiet, unteres Thurtal, Nord- und Zentralalpen (
<normalizedToken id="058E581DEB2D16752F2477B56769302B" originalValue="ostwärts" pageId="null" pageNumber="206">ostwaerts</normalizedToken>
bis Freiburger Alpen und Val de Bagne), 
<normalizedToken id="B1B158EAE66490B49E80BC67526E7DB2" originalValue="Südalpen" pageId="null" pageNumber="206">Suedalpen</normalizedToken>
(Ivrea bis Bergamasker Alpen, zerstreut).
</paragraph>
<paragraph id="50DFD57AEFD850A2C846D9469078980A" pageId="null" pageNumber="206">
<emphasis id="1545D9453AC8F839576CCF77F263A1EA" italics="true" pageId="null" pageNumber="206">Bemerkungen.</emphasis>
<normalizedToken id="6C58DBE7964827B084D1F650BE30844E" originalValue="Über" pageId="null" pageNumber="206">Ueber</normalizedToken>
die Autornamen von 
<taxonomicName id="1804FDF17035A80D4D5FBB6254F14A25" class="Magnoliopsida" family="Brassicaceae" genus="Dentaria" higherTaxonomySource="GBIF,IPNI" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="206" phylum="Tracheophyta" rank="species" species="heptaphylla">
<emphasis id="D6BA566D6E8AB16E2DAD1B4710E6DD76" italics="true" pageId="null" pageNumber="206">C. heptaphylla</emphasis>
</taxonomicName>
vgl. Widder (1962).
</paragraph>
