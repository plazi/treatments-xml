<paragraph id="DBBF396BAEC09DDFFB2C3FEA3B839C44" pageId="null" pageNumber="172">
<taxonomicName id="437B060CE644225525FB9E11981AA8CD" authority="L." class="Pinopsida" family="Pinaceae" genus="Pinus" kingdom="Plantae" order="Pinales" pageId="null" pageNumber="172" phylum="Tracheophyta" rank="species" species="cembra">
