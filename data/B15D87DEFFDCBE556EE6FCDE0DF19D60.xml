<bibRefCitation id="5D654B39FFDDBE556D07FDB10DC49D60" author="Ng PKL" box="[564,660,559,584]" pageId="55" pageNumber="499" pagination="289 - 294" refId="ref44391" refString="Ng PKL. 2013. A new species of Scandarma (Crustacea: Brachyura: Sesarmidae) from Sabah, Borneo, Malaysia. Zootaxa. 3652 (2): 289 - 294. doi: 10.11646 / zootaxa. 3652.2.6" type="journal article" year="2013">Ng 2013</bibRefCitation>
