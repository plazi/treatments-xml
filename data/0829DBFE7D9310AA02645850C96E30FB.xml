<subSubSection id="DAB6FDF619FC7854AB39AE8F46AB6241" pageId="null" pageNumber="311" type="nomenclature">
<paragraph id="7FB33FA109FC744E484ECD55954BC4DB" pageId="null" pageNumber="311">
<taxonomicName id="211D5CCA8331BE39DD76D704E92BA7B6" authority="(L.) Moench" class="Liliopsida" family="Poaceae" genus="Molinia" kingdom="Plantae" order="Poales" pageId="null" pageNumber="311" phylum="Tracheophyta" rank="species" species="coerulea">
Molinia 
<normalizedToken id="403988C9FFCA149501D071BE08EE1954" originalValue="coerúlea" pageId="null" pageNumber="311">coerulea</normalizedToken>
(
<authorityName id="070E1CD436BA94D4696A3DAAE75086B2" pageId="null" pageNumber="311">L.</authorityName>
) Moench
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="64AC9C725DF33A91970811F69B5CE973" pageId="null" pageNumber="311" type="vernacular_names">
<paragraph id="A2743A464A1E832F7F8CBC3A2A034A1E" pageId="null" pageNumber="311">Blaues Pfeifengras</paragraph>
</subSubSection>
</title>
<subSubSection id="3F5858DA9BCC3F3C907295FC169E84FD" pageId="null" pageNumber="311" type="description">
<paragraph id="D12C953F6F65975972363A5E093DC069" pageId="null" pageNumber="311">
<emphasis id="C78003B8B2408E906EAB24361AE04B9A" italics="true" pageId="null" pageNumber="311">
0,1-1 m hoch. 
<normalizedToken id="2EAA68BD54A8D8559A8E030B80E5AD4C" originalValue="Blätter" pageId="null" pageNumber="311">Blaetter</normalizedToken>
meist 2-6 mm breit
</emphasis>
, 
<normalizedToken id="FCE063080DCAAC98C0DB23C3625B81CF" originalValue="allmählich" pageId="null" pageNumber="311">allmaehlich</normalizedToken>
zugespitzt. Rispe bis 30 cm lang, mit langen, jedoch meist eng anliegenden 
<normalizedToken id="069BAD804BB7609B95B15FFD9B026849" originalValue="Ästen" pageId="null" pageNumber="311">Aesten</normalizedToken>
. 
<emphasis id="72A3DA363709EF8FE5D2A55E1116A74A" italics="true" pageId="null" pageNumber="311">
<normalizedToken id="697329C266D34A104F034C530C4760F4" originalValue="Ährchen" pageId="null" pageNumber="311">Aehrchen</normalizedToken>
bis 6 mm lang. 
<normalizedToken id="C6D56CB0FEE038038CD723FAAD702762" originalValue="Längste" pageId="null" pageNumber="311">Laengste</normalizedToken>
Deckspelzen 3-4 mm lang. -
</emphasis>
<normalizedToken id="C7F42EDD777AD4898CB94F583FE881FC" originalValue="Blüte" pageId="null" pageNumber="311">Bluete</normalizedToken>
: 
<normalizedToken id="0B39C6DC3B2E2FEF4B2BCDF29E8A7CED" originalValue="Später" pageId="null" pageNumber="311">Spaeter</normalizedToken>
Sommer.
</paragraph>
<paragraph id="BAA745D49C4C6FD2F39BD06B4FCAABF9" pageId="null" pageNumber="311">
<emphasis id="64A4AE6D611CD9ECDB45C7E34D7B2249" italics="true" pageId="null" pageNumber="311">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="DA4A4BB84AFF9237B6F67507A60AC101" italics="true" pageId="null" pageNumber="311">36:</emphasis>
Ohne Herkunftsangabe des Materials (Mattick in Tischler 1950), aus Ungarn (
<normalizedToken id="65C07B2689FC7958DABC1A2F4664E6B4" originalValue="Pólya" pageId="null" pageNumber="311">Polya</normalizedToken>
1950), aus verschiedenen Gebieten Frankreichs (Guinochet und 
<normalizedToken id="CE2EBEFF0369848F69BF59F544CDF9FD" originalValue="Lemée" pageId="null" pageNumber="311">Lemee</normalizedToken>
1950), von der Halbinsel Kola (Sokolovskaya und Strelkova 1960).
</paragraph>
<paragraph id="EA4978F6AFBB1C871BE63A19F64981E4" pageId="null" pageNumber="311">
<emphasis id="F5913EB1189F8CD3A5F038A3F1707EC4" italics="true" pageId="null" pageNumber="311">Standort.</emphasis>
Kollin, montan, subalpin, selten alpin. Besonders im 
<normalizedToken id="77BC547F2DEC51F5E0305F92E2CA7EE3" originalValue="Frühjahr" pageId="null" pageNumber="311">Fruehjahr</normalizedToken>
<normalizedToken id="50E47C823D22202D7F15C996C00779F7" originalValue="durchnäßte" pageId="null" pageNumber="311">durchnaesste</normalizedToken>
, im Sommer an der 
<normalizedToken id="687AF302D462D17E9023189978AED732" originalValue="Oberfläche" pageId="null" pageNumber="311">Oberflaeche</normalizedToken>
austrocknende (Grundwasserstand nicht unter 1 m absinkend), basische bis saure, 
<normalizedToken id="900B22CABF2D0597F510F50DBC2B21A9" originalValue="nährstoffreiche" pageId="null" pageNumber="311">naehrstoffreiche</normalizedToken>
, jedoch nie 
<normalizedToken id="666056A5185D229CC621CB55CE3AD729" originalValue="gedüngte" pageId="null" pageNumber="311">geduengte</normalizedToken>
, humose bis torfige 
<normalizedToken id="6A8A6F69A20791F6DC0CA2BCAC266DC0" originalValue="Böden" pageId="null" pageNumber="311">Boeden</normalizedToken>
. Besonders Moore z. B. im 
<emphasis id="F9D2702B315488A3C0D817BEF66524A3" italics="true" pageId="null" pageNumber="311">Molinietum coeruleae</emphasis>
W. Koch 1926. (Die Molinieten lassen sich durch 
<normalizedToken id="A6B08485017766BAEEAB39B02B6B7524" originalValue="Entwässerung" pageId="null" pageNumber="311">Entwaesserung</normalizedToken>
und 
<normalizedToken id="3239FF062E49BE08926349F7C1DD00EB" originalValue="Düngung" pageId="null" pageNumber="311">Duengung</normalizedToken>
in Fettwiesen 
<normalizedToken id="74AAB0366C3F5C09FF65215D9966AAAA" originalValue="überführen" pageId="null" pageNumber="311">ueberfuehren</normalizedToken>
.)
</paragraph>
<paragraph id="ACF9E0D050B447A4A1214E460AE01EEB" pageId="null" pageNumber="311">
<emphasis id="02982C0C22BA7F627E13D4C1999D72C8" italics="true" pageId="null" pageNumber="311">Verbreitung. Eurosibirische Pflanze:</emphasis>
Ganz 
<taxonomicName id="7FD771283A0469064F48D7B6E8E8A69F" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="311" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
(im Mediterrangebiet selten), vereinzelt in Nordafrika, 
<normalizedToken id="6E871581667F4FCFC6BF58BD2229CB0D" originalValue="ostwärts" pageId="null" pageNumber="311">ostwaerts</normalizedToken>
bis Kaukasus, Obgebiet und Zentralasien (Kasachstan); im atlantischen Nordamerika eingeschleppt. Verbreitungskarten von 
<normalizedToken id="CBD2DAF4B8B502BCDE1FAA54692C3ED2" originalValue="Hultén" pageId="null" pageNumber="311">Hulten</normalizedToken>
(1958 und Meusel (1964). - Im Gebiet verbreitet und sehr 
<normalizedToken id="7B68A04D4822A096EE9826825580FC5A" originalValue="häufig" pageId="null" pageNumber="311">haeufig</normalizedToken>
; eines der wichtigsten 
<normalizedToken id="FD767C0641F5E3AAE1F33A19A8F43615" originalValue="Streuegräser" pageId="null" pageNumber="311">Streuegraeser</normalizedToken>
.
</paragraph>
<paragraph id="ADFFC39AA004CB6C0421DB2DA49590DE" pageId="null" pageNumber="311">
<emphasis id="FF9EBC2464DF5663DBC40F716EC52406" italics="true" pageId="null" pageNumber="311">Bemerkungen.</emphasis>
Conert (1961) unterscheidet bei 
<taxonomicName id="B6B8E3201F3D1B31F7963D83F64706E0" class="Liliopsida" family="Poaceae" genus="Molinia" kingdom="Plantae" order="Poales" pageId="null" pageNumber="311" phylum="Tracheophyta" rank="species" species="coerulea">
<emphasis id="E5AAF875C44EF380CD9CA26C9F579BCF" italics="true" pageId="null" pageNumber="311">M. coerulea</emphasis>
</taxonomicName>
12 
<normalizedToken id="4D7F3528A590982DA0816ACFD12BF93C" originalValue="Varietäten" pageId="null" pageNumber="311">Varietaeten</normalizedToken>
(
<normalizedToken id="D22D6456643E0203DEA19D8E2B70C8F1" originalValue="Pflanzenhöhe" pageId="null" pageNumber="311">Pflanzenhoehe</normalizedToken>
, Rispenhabitus, Behaarung der Blattscheiden, Farbmerkmale).
</paragraph>
</subSubSection>
