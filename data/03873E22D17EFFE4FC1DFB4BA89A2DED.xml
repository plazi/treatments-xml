<taxonomicName id="4C2EF4B7D170FFE4FDF4FC68AC922B6D" authority="(COSSMANN, 1913)" baseAuthorityName="COSSMANN" baseAuthorityYear="1913" class="Gastropoda" family="Gordenellidae" genus="Proacirsa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Heterostropha" pageId="8" pageNumber="122" phylum="Mollusca" rank="species" species="bigoti">
