(
<bibRefCitation id="EFBFF2C5D170FFE4FD8AFC6BAC9A2B6D" author="COSSMANN" pageId="8" pageNumber="122" pagination="1 - 263" refId="ref5753" refString="COSSMANN, M. (1913) - Contributions a la paleontologie francaise des terrains jurassiques. III. Cerithiacea et Loxonematacea. Memoires de la Societe geologique de France, serie Paleontologie, 46: 1 - 263." type="journal article" year="1913">COSSMANN, 1913</bibRefCitation>
