<subSubSection id="5C310E48EC1803C412A9C224FB9B6D9E" pageId="null" pageNumber="513" type="description">
<paragraph id="886954637AE9431EF5146040EBDEEAB1" pageId="null" pageNumber="513">
Unterscheidet sich von 
<taxonomicName id="DA14B5005FC57032FA63682A0BFDC262" class="Magnoliopsida" family="Asteraceae" genus="Bidens" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="513" phylum="Tracheophyta" rank="genus">
<emphasis id="1C92DBCFA30E3983E719AE5129D724F0" italics="true" pageId="null" pageNumber="513">Bidens</emphasis>
</taxonomicName>
(S. 508), durch folgende Merkmale: 
<emphasis id="C9347105349F631BB409575CAAC8AA00" italics="true" pageId="null" pageNumber="513">
<normalizedToken id="6C53B33C366171DF6AFCCAF348B03994" originalValue="Früchte" pageId="null" pageNumber="513">Fruechte</normalizedToken>
mit 
<normalizedToken id="C6814C445AC4AEE81717A4429ACBBE64" originalValue="dünnem" pageId="null" pageNumber="513">duennem</normalizedToken>
Schnabel.
</emphasis>
Die Gattung 
<taxonomicName id="06F2C7EC315789B78ED053216E482179" class="Magnoliopsida" family="Asteraceae" genus="Cosmos" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="513" phylum="Tracheophyta" rank="genus">
<emphasis id="37A34DC288F9C4150C7CBF2ED3A57708" italics="true" pageId="null" pageNumber="513">Cosmos</emphasis>
</taxonomicName>
<normalizedToken id="D6C38149C45D7EE661BD64628F3174F3" originalValue="umfaßt" pageId="null" pageNumber="513">umfasst</normalizedToken>
etwa 
<emphasis id="A46AB6301AD5335911650ECC4C594378" italics="true" pageId="null" pageNumber="513">30 amerikanische Arten</emphasis>
, von denen einzelne bei uns kultiviert werden.
</paragraph>
