<taxonomicName id="11AE0FFFE85AA57F589D5266FB08A635" authorityName="Barnhart" authorityYear="1895" baseAuthorityName="R.Br." box="[1156,1254,1830,1856]" class="Liliopsida" family="Poaceae" kingdom="Plantae" order="Poales" pageId="9" pageNumber="46" phylum="Tracheophyta" rank="family">Poaceae</taxonomicName>
