<subSubSection id="8C8E6575FFEF6A50F7F793AC17D2BD56" pageId="20" pageNumber="778" type="discussion">
<paragraph id="C42B36FEFFEF6A50F7F793AC17D2BD56" blockId="20.[2057,2653,1406,1834]" pageId="20" pageNumber="778">
Relationship of 
<taxonomicName id="03944D7DFFEF6A50F71793AC1750BD24" box="[2283,2384,1525,1558]" class="Liliopsida" family="Arecaceae" genus="Pipustrellus" kingdom="Plantae" order="Arecales" pageId="20" pageNumber="778" phylum="Tracheophyta" rank="species" species="endoi">P. endoi</taxonomicName>
