<subSubSection id="067B4F2E246EBCAF9B0681A64CF5B773" pageId="null" pageNumber="156" type="description">
<paragraph id="C0CEE3E97A38C6368D543346B48E3F11" pageId="null" pageNumber="156">
Unterscheidet sich von der Gattung 
<taxonomicName id="24D1192FE1204CA1B47B45F159CF9285" class="Magnoliopsida" family="Brassicaceae" genus="Draba" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="156" phylum="Tracheophyta" rank="genus">
<emphasis id="015D036A304B8E08556A251A9D343A40" italics="true" pageId="null" pageNumber="156">Draba</emphasis>
</taxonomicName>
(S. 159) durch folgende Merkmale: Nur 1fache Haare vorhanden; 
<emphasis id="21C931DEB347EB7319C8F6F934798F53" italics="true" pageId="null" pageNumber="156">
<normalizedToken id="D96045F13078D240535A35ADCAD7E665" originalValue="Blätter" pageId="null" pageNumber="156">Blaetter</normalizedToken>
vorn 3-5teilig; 
<normalizedToken id="71BAC5336824636A25F281C35DD385CE" originalValue="Kronblätter" pageId="null" pageNumber="156">Kronblaetter</normalizedToken>
rosa oder lila;
</emphasis>
<normalizedToken id="F110C50DBE61D74CF5A71931B2895EA7" originalValue="Früchte" pageId="null" pageNumber="156">Fruechte</normalizedToken>
4samig.
</paragraph>
<paragraph id="68FF49320F6000EAA669FBFE207FE8EC" pageId="null" pageNumber="156">
Die Gattung 
<taxonomicName id="E161704262C1FFD9113DEE23B860B2F9" class="Magnoliopsida" family="Brassicaceae" genus="Petrocallis" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="156" phylum="Tracheophyta" rank="genus">
<emphasis id="FE22D4334FF92454929834557E372CF0" italics="true" pageId="null" pageNumber="156">Petrocallis</emphasis>
</taxonomicName>
<normalizedToken id="B247D66B6AFD4513BCC01FD2080DF8EB" originalValue="umfaßt" pageId="null" pageNumber="156">umfasst</normalizedToken>
nur 
<emphasis id="AD7CE9A1FDB14AEC08273B6052F090F5" italics="true" pageId="null" pageNumber="156">2 Arten</emphasis>
, neben unserer Art noch 
<taxonomicName id="B4F04DFFA7C7826AD30A320609D36434" authority="Boiss." authorityName="Boiss." class="Magnoliopsida" family="Brassicaceae" genus="Petrocallis" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="156" phylum="Tracheophyta" rank="species" species="fenestrata">
<emphasis id="C3481E0A3C2157C020F65645CAD2A4BF" italics="true" pageId="null" pageNumber="156">P. fenestrata</emphasis>
Boiss.
</taxonomicName>
im Elburs (Iran).
</paragraph>
