<figureCitation id="57952A2BFFF2FFE8FD6054BDFD072C30" box="[692,767,1777,1803]" captionStart="Fig" captionStartId="14.[189,232,1963,1989]" captionTargetBox="[209,1368,676,1878]" captionTargetId="figure-49@14.[189,1399,664,1897]" captionTargetPageId="14" captionText="Fig. 6. Neostasina demaco sp. nov., holotype, ♀ (MNHNPEJM). A. Habitus, dorsal view. B. Habitus, ventral view. C. Epigyne, ventral view. D. Vulva, dorsal view. Scale bars: A−B = 2 mm; C−D = 0.5 mm." figureDoi="http://doi.org/10.5281/zenodo.6607924" httpUri="https://zenodo.org/record/6607924/files/figure.png" pageId="13" pageNumber="179">Figs 6</figureCitation>
