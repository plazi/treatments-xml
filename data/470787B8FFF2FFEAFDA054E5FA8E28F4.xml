) (
<figureCitation id="57952A2BFFF0FFEAFAC651F9FA9028F4" box="[1298,1384,949,975]" captionStart="Fig" captionStartId="30.[189,232,1208,1234]" captionTargetBox="[189,1398,541,1146]" captionTargetId="figure-40@30.[189,1399,541,1146]" captionTargetPageId="30" captionText="Fig. 19. Distribution map for the genus Neostasina Rheims &amp; Alayón, 2016 (Dominican Republic and Haiti)." figureDoi="http://doi.org/10.5281/zenodo.6607964" httpUri="https://zenodo.org/record/6607964/files/figure.png" pageId="15" pageNumber="181">Fig. 19</figureCitation>
).
</paragraph>
