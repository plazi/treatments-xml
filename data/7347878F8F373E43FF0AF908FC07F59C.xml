<taxonomicName id="3CEE4D1A8F373E43FC3BF2CAFBD5F5CC" authorityName="Thomas" authorityYear="1899" box="[1010,1151,2536,2569]" class="Mammalia" family="Erethizontidae" genus="Coendou" kingdom="Animalia" order="Rodentia" pageId="5" pageNumber="393" phylum="Chordata" rank="species" species="quichua">C. quichua</taxonomicName>
