<taxonomicName id="3CEE4D1A8F373E43FEF0F131FE74F5F5" authorityName="Thomas" authorityYear="1902" box="[313,478,2579,2608]" class="Mammalia" family="Erethizontidae" genus="Coendou" kingdom="Animalia" order="Rodentia" pageId="5" pageNumber="394" phylum="Chordata" rank="species" species="rothschildi">C. rothschildi</taxonomicName>
