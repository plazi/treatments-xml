<subSubSection id="C3485ED60942B212EC95F87525124B35" lastPageId="24" lastPageNumber="475" pageId="22" pageNumber="473" type="etymology">
<paragraph id="8BED0D5D0942B21CEC95F87523F04DCE" blockId="22.[151,1437,1961,2023]" pageId="22" pageNumber="473">
<emphasis id="B926D14F0942B21CEC95F87521294DEA" bold="true" box="[151,290,1961,1987]" pageId="22" pageNumber="473">Etymology:</emphasis>
<taxonomicName id="4C5276DE0942B21CED2BF87521644DEA" box="[297,367,1961,1987]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="22" pageNumber="473" phylum="Chordata" rank="genus">
<emphasis id="B926D14F0942B21CED2BF87521644DEA" box="[297,367,1961,1987]" italics="true" pageId="22" pageNumber="473">Garra</emphasis>
</taxonomicName>
: named based on a vernacular Indian name, a fish living in mud; 
<taxonomicName id="4C5276DE0942B21CE853F87524A34DEA" authorityName="Lyon, Geiger &amp; Freyhof" authorityYear="2016" box="[1105,1192,1961,1987]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="22" pageNumber="473" phylum="Chordata" rank="species" species="sindhae">
<emphasis id="B926D14F0942B21CE853F87524A34DEA" box="[1105,1192,1961,1987]" italics="true" pageId="22" pageNumber="473">sindhae</emphasis>
</taxonomicName>
: named after Cynthia “Sindhi” Diane Powell for her support to the first author (Robert Gary Lyon).
</paragraph>
<caption id="DF2D5DD50943B21DEC95FC922294494F" ID-DOI="http://doi.org/10.5281/zenodo.6541619" ID-Zenodo-Dep="6541619" box="[151,671,846,870]" httpUri="https://zenodo.org/record/6541619/files/figure.png" pageId="23" pageNumber="474" startId="23.[151,250,846,870]" targetBox="[205,1382,181,822]" targetPageId="23">
