<subSubSection id="1FC7DD0E6C974EC86E44E967FB64205C" pageId="null" pageNumber="417" type="nomenclature">
<paragraph id="832CBC8E12A7EE6A86835DEFA8CBC8A3" pageId="null" pageNumber="417">
<taxonomicName id="CF2179E5CB333599752DF54D9F40DAF6" authority="(L.) Scop." class="Magnoliopsida" family="Asteraceae" genus="Cirsium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="417" phylum="Tracheophyta" rank="species" species="acaule">
Cirsium 
<normalizedToken id="1980AB5429E80CDBF75A9500B202BE45" originalValue="acáule" pageId="null" pageNumber="417">acaule</normalizedToken>
(
<authorityName id="A4B6C21FD3321EF08DA801AFD1D714ED" pageId="null" pageNumber="417">L.</authorityName>
) Scop.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="DC49DED8E8B01D24B77C9594A83AE676" pageId="null" pageNumber="417" type="vernacular_names">
<paragraph id="5B0EE139F36CE376C22675941ED5CEFA" pageId="null" pageNumber="417">Stengellose Kratzdistel</paragraph>
</subSubSection>
</title>
<subSubSection id="6556A3677B1CB454CEC7111E7C0AF50F" pageId="null" pageNumber="417" type="description">
<paragraph id="9C69AACB66E447DB80F076F03EB70F45" pageId="null" pageNumber="417">
Ausdauernd, mit Rhizom. 
<emphasis id="33FCFAD8995336C53F4C4F674C891288" italics="true" pageId="null" pageNumber="417">Stengel nicht vorhanden oder nur wenige Zentimeter hoch</emphasis>
(
<emphasis id="9D962064F6935D820EE21B00577C3AF8" italics="true" pageId="null" pageNumber="417">selten bis 30 cm hoch</emphasis>
), einfach, mit mehrzelligen Haaren, ohne Stacheln und ohne herablaufende 
<normalizedToken id="7101FE7C29053027D8B9AA1D9853010D" originalValue="Blattränder" pageId="null" pageNumber="417">Blattraender</normalizedToken>
. 
<normalizedToken id="54385FC605CA9C2858D8A14A1D3A3512" originalValue="Blätter" pageId="null" pageNumber="417">Blaetter</normalizedToken>
rosettig 
<normalizedToken id="C87ED1E967ED010D0D084383F4DAEB53" originalValue="gehäuft" pageId="null" pageNumber="417">gehaeuft</normalizedToken>
, steif, 
<normalizedToken id="0D81DA85B624FD9638C9AA3E6F7C1B81" originalValue="grün" pageId="null" pageNumber="417">gruen</normalizedToken>
, beiderseits besonders auf den Nerven mit mehrzelligen Haaren, fiederteilig, mit im 
<normalizedToken id="BEB727B10C734AFE7B5209438919D632" originalValue="Umriß" pageId="null" pageNumber="417">Umriss</normalizedToken>
breit ovalen, 3-4teiligen, stachelig 
<normalizedToken id="6A61F811300FA45383A19A7D5074BB7C" originalValue="gezähnten" pageId="null" pageNumber="417">gezaehnten</normalizedToken>
Abschnitten. 
<emphasis id="24DF98F6095CC40D25E45468C88BEE06" italics="true" pageId="null" pageNumber="417">
<normalizedToken id="062E831A5CE4D66074C89BBF53071626" originalValue="Blütenkopf" pageId="null" pageNumber="417">Bluetenkopf</normalizedToken>
meist in der 
<normalizedToken id="92DA50E7E1915AF0887AB77B2B8128CE" originalValue="grundständigen" pageId="null" pageNumber="417">grundstaendigen</normalizedToken>
Rosette fast ungestielt. 
<normalizedToken id="4CB283609F9E54EB4C5CEC66DCAA8E70" originalValue="Hülle" pageId="null" pageNumber="417">Huelle</normalizedToken>
der 
<normalizedToken id="0AEFCD1DB8F9D49E03BDCBBFE1CAF615" originalValue="blühenden" pageId="null" pageNumber="417">bluehenden</normalizedToken>
<normalizedToken id="44C164E459165A1835236EAFD8119946" originalValue="Köpfe" pageId="null" pageNumber="417">Koepfe</normalizedToken>
2
</emphasis>
- 
<emphasis id="2C66B3E08F644C7152E60E9ABCAEF59C" italics="true" pageId="null" pageNumber="417">3 cm lang</emphasis>
, rotbraun. 
<normalizedToken id="54308D7A44E2C5BDC72FA885B5B508F7" originalValue="Hüllblätter" pageId="null" pageNumber="417">Huellblaetter</normalizedToken>
mit undeutlicher 
<normalizedToken id="9A2B014D52923FCB00A2201ACD38EDC8" originalValue="Harzdrüse" pageId="null" pageNumber="417">Harzdruese</normalizedToken>
, die 
<normalizedToken id="424DC1C7FBBC4230BC39A500D72B4CE7" originalValue="äußern" pageId="null" pageNumber="417">aeussern</normalizedToken>
mit kurzem, anliegendem, kaum stechendem Stachel. Kronen 2,5-3,5 cm lang, purpurn. 
<normalizedToken id="7A550C62B4430E421022F3A073E07AD7" originalValue="Früchte" pageId="null" pageNumber="417">Fruechte</normalizedToken>
3-4 mm lang, gelbbraun, ohne Flecken. 
<emphasis id="FDC5FA9928816A0CAAA7687EC2543E85" italics="true" pageId="null" pageNumber="417">
<taxonomicName id="33A724EDF164174B4F61C3B6DE7C2FD2" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="417" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
2
</emphasis>
- 
<emphasis id="EAFD8BAE3CCA3807DC52E867B95B5481" italics="true" pageId="null" pageNumber="417">3 cm lang.</emphasis>
- 
<normalizedToken id="CE0BCB5DF74EDE69079ED9FB318D224D" originalValue="Blüte" pageId="null" pageNumber="417">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="BFE7BCD2B20F49C095F9B797948B554B" originalValue="Frühherbst" pageId="null" pageNumber="417">Fruehherbst</normalizedToken>
.
</paragraph>
<paragraph id="9AF5C37B9415DEEB010C7C40D9DE19E0" pageId="null" pageNumber="417">
<emphasis id="323E366C2465BE9B6467D861FAF9E1D4" italics="true" pageId="null" pageNumber="417">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0AC483069EEFF81D0EB48FC5C378DC6E" italics="true" pageId="null" pageNumber="417">34:</emphasis>
Material aus Norddeutschland (Wulff 1937b), aus Polen (Skalinska et al. 1959), aus botanischem Garten (es wurden 6 B-Chromosomen 
<normalizedToken id="FD44E26ED3CFBB9A4453654156FD718D" originalValue="gezählt" pageId="null" pageNumber="417">gezaehlt</normalizedToken>
) (Moore und Frankton 1962), aus botanischem Garten (Chouksanova et al. 1968).
</paragraph>
<paragraph id="D411BD2F45AD9B099789C39472E45029" pageId="null" pageNumber="417">
<emphasis id="03E922A0591DDD3CB9EC0130238798B8" italics="true" pageId="null" pageNumber="417">Standort.</emphasis>
Montan und subalpin, seltener kollin oder alpin. Trockene oder wechselfeuchte, meist kalkhaltige, humose, lehmige 
<normalizedToken id="D1F80BFEEC4B22BAD1B6530A3DCE6C5F" originalValue="Böden" pageId="null" pageNumber="417">Boeden</normalizedToken>
in 
<normalizedToken id="946C7D579B6920622D2240956F42B1EE" originalValue="wärmeren" pageId="null" pageNumber="417">waermeren</normalizedToken>
Lagen. Magerwiesen. Weiden.
</paragraph>
<paragraph id="3E4BF89B4B91FFFEA517B17E1FE93206" pageId="null" pageNumber="417">
<emphasis id="126D219153220B391F9B7BE4B28C43F3" italics="true" pageId="null" pageNumber="417">
Verbreitung. 
<normalizedToken id="2CC8E373BBC6A1B369F3B00BE93E2510" originalValue="Mitteleuropäische" pageId="null" pageNumber="417">Mitteleuropaeische</normalizedToken>
Pflanze:
</emphasis>
West- und 
<normalizedToken id="8C78E36FA7A71F1F1160BCD85545BCC7" originalValue="südwärts" pageId="null" pageNumber="417">suedwaerts</normalizedToken>
bis 
<normalizedToken id="6C318D50D87E4294F8DAEE82C2B8FF7F" originalValue="Südengland" pageId="null" pageNumber="417">Suedengland</normalizedToken>
, 
<normalizedToken id="01FA9217B483DC99293EB757816E5B04" originalValue="Pyrenäen" pageId="null" pageNumber="417">Pyrenaeen</normalizedToken>
(isoliert in Gebirgen Ostspaniens), Mittelapennin, Istrien; nord- und 
<normalizedToken id="32684242EA740587C0C7A87C46169746" originalValue="ostwärts" pageId="null" pageNumber="417">ostwaerts</normalizedToken>
bis 
<normalizedToken id="5EB7C7F9032CE243F5D9FEFA1F9D5E76" originalValue="Südschweden" pageId="null" pageNumber="417">Suedschweden</normalizedToken>
, Estland, Polen, Slowakei, Ostalpen, isoliert in 
<normalizedToken id="3877E77EC4800978D8672F96A6272FDF" originalValue="Rumänien" pageId="null" pageNumber="417">Rumaenien</normalizedToken>
. Verbreitungskarten von Pigott (1968) und 
<normalizedToken id="70A9967A4666EFCADC77EA331A4AD8FD" originalValue="Schönfelder" pageId="null" pageNumber="417">Schoenfelder</normalizedToken>
(1970-1971). - Im Gebiet: Nord- und Zentralalpen, Alpenvorland, Jura ziemlich 
<normalizedToken id="2B8A6D1600985DAE3FA0A3C8A45BB0B4" originalValue="häufig" pageId="null" pageNumber="417">haeufig</normalizedToken>
; sonst selten.
</paragraph>
</subSubSection>
