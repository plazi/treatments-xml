<location id="204679D5102CFFB3DF04FD0C48B1294C" LSID="urn:lsid:plazi:treatment:AD309E18102DFFB3DBB2FAB24E202814:204679D5102CFFB3DF04FD0C48B1294C" box="[1057,1156,583,609]" country="Vietnam" municipality="Bao Loc" name="Dam Bri" pageId="9" pageNumber="110" stateProvince="Lam Dong">Dam Bri</location>
, on bamboo, 
<date id="512709CE102CFFB3DE38FD0C49A9294C" box="[1309,1436,583,609]" pageId="9" pageNumber="110" value="2001-12-28">
