, 
<collectingRegion id="E75DE1EC102CFFB3D9CCFD0C4F92294C" box="[745,935,583,609]" country="Vietnam" name="Lam Dong" pageId="9" pageNumber="110">Lam Dong Prov.</collectingRegion>
, 
<collectingMunicipality id="C542B574102CFFB3D897FD0C4820294C" box="[946,1045,583,609]" pageId="9" pageNumber="110">Bao Loc</collectingMunicipality>
