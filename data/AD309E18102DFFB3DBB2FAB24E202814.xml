<emphasis id="17EDF31C102CFFB3D950FD0D4EEE294D" bold="true" box="[629,731,582,608]" pageId="9" pageNumber="110">
<collectingCountry id="5D8E6F9E102CFFB3D950FD0D4EEE294D" box="[629,731,582,608]" name="Vietnam" pageId="9" pageNumber="110">Vietnam</collectingCountry>
