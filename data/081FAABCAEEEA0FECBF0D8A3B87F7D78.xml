<subSubSection id="171889C68D46F47BC1718527D56B37E3" pageId="null" pageNumber="765" type="vernacular_names">
<paragraph id="74063056DC06A031B059A068BD876245" pageId="null" pageNumber="765">Ausgebreiteter Fuchsschwanz</paragraph>
</subSubSection>
</title>
<subSubSection id="66CE499B89A4134378C6316AB57BD20E" pageId="null" pageNumber="765" type="description">
<paragraph id="32B917709930701808177A9B2DD17863" pageId="null" pageNumber="765">
Unterscheidet sich von 
<taxonomicName id="431D9830EB78AFA707D4177FEE289AB5" class="Magnoliopsida" family="Amaranthaceae" genus="Amaranthus" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="765" phylum="Tracheophyta" rank="species" species="retroflexus">
<emphasis id="4E04FA280F699CAE997773B2242AB57E" italics="true" pageId="null" pageNumber="765">A. retroflexus</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: Pflanze nur im obern Teil flaumig behaart; 
<emphasis id="B5C576521747F6D482156C12CA95927C" italics="true" pageId="null" pageNumber="765">
<normalizedToken id="8D2DBDB7F77D5CFC7A2A59A13EACB2DA" originalValue="Vorblätter" pageId="null" pageNumber="765">Vorblaetter</normalizedToken>
an den normal entwickelten
</emphasis>
♀ 
<emphasis id="AD2F6F1A10F1923AD51273DA8BA525B7" italics="true" pageId="null" pageNumber="765">
<normalizedToken id="7E345CDC0E28ED0DDAF3AE7D8CF9A3FB" originalValue="Blüten" pageId="null" pageNumber="765">Blueten</normalizedToken>
1,3-1,5mal so lang wie die 
<normalizedToken id="728CC52027A444EAFF30F51289A15275" originalValue="Perigonblätter" pageId="null" pageNumber="765">Perigonblaetter</normalizedToken>
; 
<normalizedToken id="B28D00AA393D7E3094A2ECA753A9DBAA" originalValue="Perigonblätter" pageId="null" pageNumber="765">Perigonblaetter</normalizedToken>
an den
</emphasis>
♀ 
<emphasis id="266A9713CF71E903C024328F48ADAAD0" italics="true" pageId="null" pageNumber="765">
<taxonomicName id="DCCD192C78DC03C731476518C910F1D4" family="Chenopodiaceae" genus="Blueten" pageId="null" pageNumber="765" rank="species" species="gegen">
<normalizedToken id="C8BA9CBC3562D61A98212185DD1CCC82" originalValue="Blüten" pageId="null" pageNumber="765">Blueten</normalizedToken>
gegen
</taxonomicName>
die Stachelspitze 
<normalizedToken id="F44C36F8D1B50592E69B88CFC8504315" originalValue="verschmälert" pageId="null" pageNumber="765">verschmaelert</normalizedToken>
, 
<normalizedToken id="914B5D565B36F9A82AB6CAE13C8826C1" originalValue="kürzer" pageId="null" pageNumber="765">kuerzer</normalizedToken>
bis so lang wie die reife Frucht
</emphasis>
(mit Narben). - 
<normalizedToken id="C3B8A6A09D71E0803697AE67B7C8C31A" originalValue="Blüte" pageId="null" pageNumber="765">Bluete</normalizedToken>
: 
<normalizedToken id="9DBB005DC7A42A845A66095658CF2755" originalValue="Später" pageId="null" pageNumber="765">Spaeter</normalizedToken>
Sommer bis Herbst.
</paragraph>
<paragraph id="87A30F0CEE191F062B44A4CF1FD05ABE" pageId="null" pageNumber="765">
<emphasis id="39D919B018378054B1EC150221D727FD" italics="true" pageId="null" pageNumber="765">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="81FB93B1F1A2D1F762BCA426AECF4AEB" pageId="null" pageNumber="765">
<emphasis id="477C121E01C1B80BF03B8DBFCB2BB515" italics="true" pageId="null" pageNumber="765">Standort.</emphasis>
Kollin. Wie 
<taxonomicName id="A7803BB4828612E360626DB8A79E4D40" class="Magnoliopsida" family="Amaranthaceae" genus="Amaranthus" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="765" phylum="Tracheophyta" rank="species" species="retroflexus">
<emphasis id="8AD00D5D8C5AEE6ACC2DF513F26E0678" italics="true" pageId="null" pageNumber="765">A. retroflexus</emphasis>
</taxonomicName>
(Nr. 1).
</paragraph>
<paragraph id="CC249EEB527118F7D84AAC28F7476B80" pageId="null" pageNumber="765">
<emphasis id="E0126E5997FD398144E5C8C9839EC3B5" italics="true" pageId="null" pageNumber="765">
Verbreitung. 
<normalizedToken id="F36919C45C028965E9DCE4B36F0EC6BB" originalValue="Ursprünglich" pageId="null" pageNumber="765">Urspruenglich</normalizedToken>
Mittelamerika und 
<normalizedToken id="9FC85AF0F6B1EA3913EDAF28782E6C78" originalValue="Südstaaten" pageId="null" pageNumber="765">Suedstaaten</normalizedToken>
der USA;
</emphasis>
heute auch im ganzen Mittelmeergebiet verbreitet. - Im Gebiet im 
<normalizedToken id="A9AF090F88A2EC4C7EA18A9EDFDAC743" originalValue="Süden" pageId="null" pageNumber="765">Sueden</normalizedToken>
(Tessin, Puschlav) 
<normalizedToken id="B665E00FA9477EDD15FC65D4CDF1FE44" originalValue="eingebürgert" pageId="null" pageNumber="765">eingebuergert</normalizedToken>
; 
<normalizedToken id="8B6ECEB2B76E6F24424A05C613E96E66" originalValue="nördlich" pageId="null" pageNumber="765">noerdlich</normalizedToken>
der Alpen 
<normalizedToken id="346497310BB38FADBF7A644B52DDB068" originalValue="unbeständig" pageId="null" pageNumber="765">unbestaendig</normalizedToken>
.
</paragraph>
</subSubSection>
