<subSubSection id="606DA9985B4ACD25BF3271F8857EB0DE" pageId="null" pageNumber="587" type="description">
<paragraph id="F75D8F3D2C5508E0B050707D51C14285" pageId="null" pageNumber="587">
Unterscheidet sich durch folgende Merkmale von 
<taxonomicName id="C5FDD082AD6295428EB5FA03FF57ABEB" class="Liliopsida" family="Iridaceae" genus="Crocus" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="587" phylum="Tracheophyta" rank="species" species="albiflorus">
<emphasis id="E4E814E6DD5A45AD502FA272714F9673" italics="true" pageId="null" pageNumber="587">C. albiflorus</emphasis>
</taxonomicName>
(Nr. 2): 
<emphasis id="6762F1DBDEAB4F3CCABF71BAEFCA37B1" italics="true" pageId="null" pageNumber="587">
Knolle von derben 
<normalizedToken id="53C1E76E0AD59F40B80E3A1E18ACA5B4" originalValue="Häuten" pageId="null" pageNumber="587">Haeuten</normalizedToken>
umgeben; 
<normalizedToken id="78D43D9D2C1535719F41C08D161B4CFA" originalValue="Blüten" pageId="null" pageNumber="587">Blueten</normalizedToken>
im Schlund gelb und kahl.
</emphasis>
- 
<normalizedToken id="3CDAB2C342F4EDDFA27D0BA0E22B456A" originalValue="Blüte" pageId="null" pageNumber="587">Bluete</normalizedToken>
: 
<emphasis id="AE10D5AD7A9FBB39CC9B7BF1305BDBE6" italics="true" pageId="null" pageNumber="587">
<normalizedToken id="6FE0D85294562E00C2DC26CB4EAF0648" originalValue="Frühling" pageId="null" pageNumber="587">Fruehling</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="9B3CA2371F5B49AEADAA4A83F18E9FD8" pageId="null" pageNumber="587">
<emphasis id="4BB6EBF4482F14F2C2A399EE66AC3C8D" italics="true" pageId="null" pageNumber="587">Zytologische Angaben. 2n = 7, 8, 15, 20:</emphasis>
Material aus botanischen 
<normalizedToken id="5E473770E6FE067F19898AC21CB119B3" originalValue="Gärten" pageId="null" pageNumber="587">Gaerten</normalizedToken>
(Karasawa 1943).
</paragraph>
<paragraph id="D9F38ABFBA8C6C155CD8C8D1C66832BA" pageId="null" pageNumber="587">
<emphasis id="95B3EDBA6A0B2DC476046E7DA18DC953" italics="true" pageId="null" pageNumber="587">Standort.</emphasis>
Kollin und montan. Steinige, kalkhaltige 
<normalizedToken id="F244CCBFFDA1DB8A8CC2A8C792A3C014" originalValue="Böden" pageId="null" pageNumber="587">Boeden</normalizedToken>
in 
<normalizedToken id="E9DA8D2FFA8DC7D08FC1FBD7D85FFF52" originalValue="südlicher" pageId="null" pageNumber="587">suedlicher</normalizedToken>
Lage. Wiesen.
</paragraph>
<paragraph id="4ACCD29235300D6C04C872EC1284BBE5" pageId="null" pageNumber="587">
<emphasis id="ADAA2D8AB868C4160D1BA4FA3954E008" italics="true" pageId="null" pageNumber="587">
Verbreitung. 
<normalizedToken id="9A752FE4D7035294628B9D85EBE00684" originalValue="Südosteuropäische" pageId="null" pageNumber="587">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="5BC92B7E993CC1FF90B467652CDE70D8" originalValue="Alpensüdfuß" pageId="null" pageNumber="587">Alpensuedfuss</normalizedToken>
(
<normalizedToken id="323733D43D7B31D4D52C2D863ED9211C" originalValue="südliche" pageId="null" pageNumber="587">suedliche</normalizedToken>
Bergamasker Alpen, Arco im 
<normalizedToken id="F538546570DD10D2E0B9A3E4D1D5C8B8" originalValue="Südtirol" pageId="null" pageNumber="587">Suedtirol</normalizedToken>
), Apenninhalbinsel, Elba, Sizilien, Balkanhalbinsel; nahe verwandte Sippen, die neuerdings als Arten 
<normalizedToken id="B24F503C392E8AC02ACDB1371DC88D3F" originalValue="aufgefaßt" pageId="null" pageNumber="587">aufgefasst</normalizedToken>
werden, in 
<normalizedToken id="8666A95E475FAF9FA7DA2029D671BD04" originalValue="Südrußland" pageId="null" pageNumber="587">Suedrussland</normalizedToken>
(Krim, Kaukasus) und in Vorderasien (
<normalizedToken id="C06D20DB8EA134F57A4275001E816D36" originalValue="ostwärts" pageId="null" pageNumber="587">ostwaerts</normalizedToken>
bis Persien). - Im Gebiet: 
<normalizedToken id="57BA5AC689B45621A4F5E30DC116A395" originalValue="Südliche" pageId="null" pageNumber="587">Suedliche</normalizedToken>
Bergamasker Alpen und am Tessin auf italienischem Gebiet (Stucchi in lit. 1963).
</paragraph>
</subSubSection>
