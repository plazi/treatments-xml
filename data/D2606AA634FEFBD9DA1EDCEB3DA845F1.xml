<subSubSection id="4AB05C3F77454E96506A7F4A3A3DBF39" pageId="null" pageNumber="472" type="vernacular_names">
<paragraph id="9AE0AB625DA350CBD3DD3454D0B5715B" pageId="null" pageNumber="472">
Eingriffliger 
<normalizedToken id="EC7EB012FA65E61C7E5690F24EC6B170" originalValue="Weißdorn" pageId="null" pageNumber="472">Weissdorn</normalizedToken>
</paragraph>
</subSubSection>
</title>
<subSubSection id="599355489DA5A068AE4861F7FFBEF8B8" pageId="null" pageNumber="472" type="description">
<paragraph id="BCF7307917CAD58E8D732FA54C9C775C" pageId="null" pageNumber="472">
Bis 4 m hoch. 
<emphasis id="AE716B581EB4256EC2950088C77B4787" italics="true" pageId="null" pageNumber="472">
<normalizedToken id="A53F7334C01A5ECF30A0F0678A744F94" originalValue="Blätter" pageId="null" pageNumber="472">Blaetter</normalizedToken>
meist 5teilig, seltener 3teilig, tief, 
<normalizedToken id="52F54A9F5DFC959DC9F4602FFC9D1AEA" originalValue="über" pageId="null" pageNumber="472">ueber</normalizedToken>
die 
<normalizedToken id="DBDE8C369784592F056499C609029146" originalValue="Hälfte" pageId="null" pageNumber="472">Haelfte</normalizedToken>
geteilt, mit breit offenen Einschnitten; Abschnitte parallelrandig oder nach 
<normalizedToken id="4D4F67B2CDB85D84B2176116B49EDC99" originalValue="außen" pageId="null" pageNumber="472">aussen</normalizedToken>
<normalizedToken id="958924A5A8BA96ACBE8B11BEC9C6FDBE" originalValue="verschmälert" pageId="null" pageNumber="472">verschmaelert</normalizedToken>
, mit spitzen, feinen bis groben
</emphasis>
, 
<emphasis id="4C1A007C1F9DB9D906419744009488A4" italics="true" pageId="null" pageNumber="472">
abstehenden 
<normalizedToken id="CCEF8FB909FB53AF60EAC3B8A525C0B1" originalValue="Zähnen" pageId="null" pageNumber="472">Zaehnen</normalizedToken>
</emphasis>
, unterseits im Herbst wenigstens noch bei den Nervenabzweigungen behaart. 
<emphasis id="837224722FCD27E6FD08470D3DD8D683" italics="true" pageId="null" pageNumber="472">
<normalizedToken id="C66C1E89213A5A558763CFB41CD4584A" originalValue="Blütenstiele" pageId="null" pageNumber="472">Bluetenstiele</normalizedToken>
und Fruchtstiele behaart.
</emphasis>
Durchmesser der 
<normalizedToken id="508C7431DD63F5EBBFCFAB2C197CFE65" originalValue="Kronblätter" pageId="null" pageNumber="472">Kronblaetter</normalizedToken>
0,5-0,6 cm. 
<emphasis id="34BC33B17450C238E3129397E7A1DDFE" italics="true" pageId="null" pageNumber="472">Frucht meist mit 1 Kern</emphasis>
, rot. 
<emphasis id="28BC39755D93FC8AC0F33586A398B3C7" italics="true" pageId="null" pageNumber="472">Griffel meist 1. -</emphasis>
<normalizedToken id="2397D7E3324575BC6CB95F9733836922" originalValue="Blüte" pageId="null" pageNumber="472">Bluete</normalizedToken>
: 
<normalizedToken id="98F1B880D661CA3A35ABBB870F6D2E4A" originalValue="Später" pageId="null" pageNumber="472">Spaeter</normalizedToken>
<normalizedToken id="0D4AD05BE2B5E5E0FC5566D5DB0D8447" originalValue="Frühling" pageId="null" pageNumber="472">Fruehling</normalizedToken>
; reife 
<normalizedToken id="5AA5DBD84DE4C9B4089BBF2AFD5759D0" originalValue="Früchte" pageId="null" pageNumber="472">Fruechte</normalizedToken>
im Herbst (Oktober).
</paragraph>
<paragraph id="C03F7835E83795953BEF3D0E0B24EE56" pageId="null" pageNumber="472">
<emphasis id="C33E9B793B262C72DA1E45A46B9786DF" italics="true" pageId="null" pageNumber="472">Zytologische Angaben. 2n wahrscheinlich 32:</emphasis>
Material aus botanischen 
<normalizedToken id="F97BDDA8C2EC65972A9D727C16182074" originalValue="Gärten" pageId="null" pageNumber="472">Gaerten</normalizedToken>
; Pollenmeiose normal (Longley 1924b). 
<emphasis id="12E5C05A458FA225E340ECAFAAF33440" italics="true" pageId="null" pageNumber="472">2n</emphasis>
= 
<emphasis id="D90DE4244016C9C9A4BB1ED4710951A8" italics="true" pageId="null" pageNumber="472">34:</emphasis>
Moffet aus Tischler (1950). 
<emphasis id="67D7E562FFEF2639D0712F82F41FCAF0" italics="true" pageId="null" pageNumber="472">2n</emphasis>
= 
<emphasis id="95776C5803C1511AA6546C6D18A2F147" italics="true" pageId="null" pageNumber="472">51:</emphasis>
Material von der Krim (Gladkova 1968).
</paragraph>
<paragraph id="5B1DD6BCAC106C53E8E90C5E7B0A6543" pageId="null" pageNumber="472">
<emphasis id="1304C316198C28E73CBC7482DA27D121" italics="true" pageId="null" pageNumber="472">Standort.</emphasis>
Wie 
<taxonomicName id="8BC3B09053E6B4DE17BE7BD21CF4FA5E" class="Magnoliopsida" family="Rosaceae" genus="Crataegus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="472" phylum="Tracheophyta" rank="species" species="oxyacantha">
<emphasis id="4417D820797D84E65C6AFDA43DD77875" italics="true" pageId="null" pageNumber="472">C. Oxyacantha</emphasis>
</taxonomicName>
(Nr. 1), meist trockenere 
<normalizedToken id="9D805E23C54D1295ABB26A92065686E2" originalValue="Böden" pageId="null" pageNumber="472">Boeden</normalizedToken>
und 
<normalizedToken id="776CFDD8ADE614940FFAED490FA658A4" originalValue="wärmere" pageId="null" pageNumber="472">waermere</normalizedToken>
Lagen.
</paragraph>
<paragraph id="6FCE5A533D5B6A10E2B426FCEDAB0BED" pageId="null" pageNumber="472">
<emphasis id="F94E32CF0768EF28B5657D7DC346DCB2" italics="true" pageId="null" pageNumber="472">
Verbreitung. 
<normalizedToken id="927FD27FD04CB45A9612733DC0017D51" originalValue="Europäisch-westasiatische" pageId="null" pageNumber="472">Europaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
Verbreitung in Europa im wesentlichen wie 
<taxonomicName id="ACBF36400C059F043E7487BB30848C7D" class="Magnoliopsida" family="Rosaceae" genus="Crataegus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="472" phylum="Tracheophyta" rank="species" species="oxyacantha">
<emphasis id="3CB88CCFDAFA4D899C64AD1CDC5EF818" italics="true" pageId="null" pageNumber="472">C. Oxyacantha</emphasis>
</taxonomicName>
(Nr. 1); jedoch 
<normalizedToken id="8196E8680E4035B3A96175EE64FEBCC6" originalValue="nordwärts" pageId="null" pageNumber="472">nordwaerts</normalizedToken>
bis Schottland und ganze Iberische Halbinsel; Nordafrika, Kleinasien, 
<normalizedToken id="4B7232E50AF15857B627BC673B03DA47" originalValue="ostwärts" pageId="null" pageNumber="472">ostwaerts</normalizedToken>
bis Nordiran und Wolgagebiet. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet verbreitet und 
<normalizedToken id="EC90B7CB195F916326ACAA89882984F4" originalValue="häufig" pageId="null" pageNumber="472">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
