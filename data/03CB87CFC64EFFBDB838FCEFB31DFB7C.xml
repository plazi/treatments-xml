<taxonomicName id="4C624D5AC64EFFBEB963F87AB574F826" authority="(Kinberg, 1856)" baseAuthorityName="Kinberg" baseAuthorityYear="1856" box="[783,1098,1962,1989]" class="Polychaeta" family="Sigalionidae" genus="Psammolyce" kingdom="Animalia" order="Phyllodocida" pageId="17" pageNumber="18" phylum="Annelida" rank="species" species="petersi">
