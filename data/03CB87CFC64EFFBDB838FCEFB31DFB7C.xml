<taxonomicName id="4C624D5AC64DFFBDB909FE82B58CFE8F" authority="(Hartman, 1939)" baseAuthorityName="Hartman" baseAuthorityYear="1939" box="[869,1202,338,364]" class="Polychaeta" family="Sigalionidae" genus="Neopsammolyce" kingdom="Animalia" order="Phyllodocida" pageId="18" pageNumber="19" phylum="Annelida" rank="species" species="spinosa">
<emphasis id="B916EACBC64DFFBDB909FE82B2DAFE8F" bold="true" box="[869,996,338,364]" italics="true" pageId="18" pageNumber="19">N. spinosa</emphasis>
(
<bibRefCitation id="EFF34B28C64DFFBDB998FE82B597FE8F" author="Hartman O." box="[1012,1193,338,364]" pageId="18" pageNumber="19" pagination="1 - 156" refId="ref29485" refString="Hartman O. 1939. Polychaetous annelids, 1: Aphroditidae to Pisionidae. Allan Hancock Pacific Expeditions 7 (1): 1 - 156." type="journal article" year="1939">Hartman, 1939</bibRefCitation>
)
</taxonomicName>
, Pacific, 
<collectingCountry id="F3757649C64DFFBDBF70FE82B4A2FE8F" box="[1308,1436,338,364]" name="Costa Rica" pageId="18" pageNumber="19">Costa Rica</collectingCountry>
