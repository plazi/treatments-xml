(
<bibRefCitation id="EFF34B28C64EFFBEB9FEF87AB57EF826" author="Kinberg J. G. H." box="[914,1088,1962,1989]" pageId="17" pageNumber="18" pagination="381 - 388" refId="ref29940" refString="Kinberg J. G. H. 1856. Nya slagten och arter af Annelider. Ofversight of Koniglich Vetenskapsakademiens Forhandlingar, Stockholm 12: 381 - 388." type="journal article" year="1856">Kinberg, 1856</bibRefCitation>
