(
<bibRefCitation id="EFF34B28C64DFFBDB9C4FD47B565FD51" author="Augener H." box="[936,1115,663,690]" pageId="18" pageNumber="19" pagination="91 - 196" refId="ref28603" refString="Augener H. 1906. Westindische Polychaeten. Bulletin of the Museum of Comparative Zoology at Harvard College 43: 91 - 196." type="journal article" year="1906">Augener, 1906</bibRefCitation>
)
