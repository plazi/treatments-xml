aff. 
<emphasis id="B916EACBC64DFFBDB983FDF5B55FFDA3" bold="true" box="[1007,1121,549,576]" italics="true" pageId="18" pageNumber="19">floccifera</emphasis>
</taxonomicName>
, 
<collectingCountry id="F3757649C64DFFBDBE1CFDF6B5D9FDA3" box="[1136,1255,550,576]" name="Colombia" pageId="18" pageNumber="19">Colombia</collectingCountry>
, Caribbean Sea
</keyLead>
</paragraph>
<paragraph id="8BDD36D9C64DFFBDBA8BFD9BB4A2FD52" blockId="18.[227,1437,303,690]" pageId="18" pageNumber="19">
