<bibRefCitation id="EFC04B30FD3AFFADFBDBF998FAD0D548" author="Pielowska-Ceranowska, A. &amp; Azar, D. &amp; Szwedo, J." box="[1057,1405,1626,1652]" pageId="0" pageNumber="137" pagination="1 - 9" refId="ref2226" refString="Pielowska-Ceranowska, A., Azar, D. &amp; Szwedo, J. (2021) New fossil biting midge from the Lower Cretaceous amber of Lebanon (Diptera: Ceratopogonidae). Cretaceous Research, 129, 105004, 1 - 9. https: // doi. org / 10.1016 / j. cretres. 2021.105004" type="journal article" year="2021">Pielowska-Ceranowska, 2021</bibRefCitation>
