<bibRefCitation id="EFC04B30FD3BFFACFB01F8C2FA0CD424" author="Dubertret, L." box="[1275,1441,1792,1816]" pageId="1" pageNumber="138" refId="ref1778" refString="Dubertret, L. (1950) Carte geologique au 1: 50 000; Feuille de Djezzine. Republique Libanaise, Ministere des travaux publics, Beyrouth, 1 coloured map + notice 80 pp." type="book" year="1950">Dubertret, 1950</bibRefCitation>
