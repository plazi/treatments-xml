<heading id="D0A681ADFD3AFFADFCD0F998FAD0D548" bold="true" box="[810,1405,1626,1653]" fontSize="10" level="2" pageId="0" pageNumber="137" reason="3">
<taxonomicName id="4C514D42FD3AFFADFCD0F998FAD0D548" authority="Pielowska-Ceranowska, 2021" authorityName="Pielowska-Ceranowska" authorityYear="2021" box="[810,1405,1626,1653]" class="Insecta" family="Ceratopogonidae" genus="Minyohelea" kingdom="Animalia" order="Diptera" pageId="0" pageNumber="137" phylum="Arthropoda" rank="species" species="nexuosa">
