<taxonomicName id="03944D7DFF326A8DFD299C841D2EB1CC" authority="Kaup, 1829" box="[725,814,2781,2814]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="201" pageNumber="963" phylum="Chordata" rank="genus">Myotis</taxonomicName>
