<tr id="FC58312137A28EDA42FDD5388534FD3F" pageId="null" pageNumber="885">
<td id="8A5F2036955A43387BFE448F22EB4E84" align="left" pageId="null" pageNumber="885" valign="top">
1. Unterste 
<normalizedToken id="7B49DB601DFB301B2B394BF532076A72" originalValue="Blätter" pageId="null" pageNumber="885">Blaetter</normalizedToken>
mit auffallend nach unten 
<normalizedToken id="E12614841ADED362A41FC18EAADAE2AA" originalValue="abgerücktem" pageId="null" pageNumber="885">abgeruecktem</normalizedToken>
unterstem Teilblattpaar 1. Ordnung; Blattzipfel nicht 
<normalizedToken id="2A8F5479E35CA8C20DB2AD82619BFDA3" originalValue="fadenförmig" pageId="null" pageNumber="885">fadenfoermig</normalizedToken>
</td>
<td id="67106365BAC4483076BD520A5C4F9DA0" align="left" pageId="null" pageNumber="885" valign="bottom">
<taxonomicName id="34AD3C049DC7B8A4ABDFADF7F926425B" class="Magnoliopsida" family="Apiaceae" genus="Carum" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="885" phylum="Tracheophyta" rank="species" species="carvi">
<italic id="45C01A95BB8F37FF4733F6B7EB0C7F34" pageId="null" pageNumber="885">C. Carvi</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="6995B2A5E3FD5CF5E0A5651C33A7E809" pageId="null" pageNumber="885">
<td id="2566191329D364325D3316654B01E6EA" align="left" pageId="null" pageNumber="885" valign="top">
1*. Unterstes Teilblattpaar 1. Ordnung an den untersten 
<normalizedToken id="36A879ED54ACAE341AB4B14C9688255C" originalValue="Blättern" pageId="null" pageNumber="885">Blaettern</normalizedToken>
nicht nach unten 
<normalizedToken id="CAD844108416EF7E1CDDF5182A3933DD" originalValue="abgerückt" pageId="null" pageNumber="885">abgerueckt</normalizedToken>
; Blattzipfel 
<normalizedToken id="D4220E9F923959226F9D56FC900FE2DC" originalValue="fadenförmig" pageId="null" pageNumber="885">fadenfoermig</normalizedToken>
, die Hauptachse des Blattes quirlartig umgebend
</td>
<td id="A59D1EC659C30BC8AA0F583CFB165059" align="left" pageId="null" pageNumber="885" valign="bottom">
<taxonomicName id="ECFE1E58001F7BB6DC964DE2DCAC05D1" class="Magnoliopsida" family="Apiaceae" genus="Carum" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="885" phylum="Tracheophyta" rank="species" species="verticillatum">
<italic id="32E84637CA2A08753BE5E9024BE6A243" pageId="null" pageNumber="885">C. verticillatum</italic>
</taxonomicName>
(Nr. 2)
</td>
