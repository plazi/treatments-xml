<subSubSection id="CC984F72DC854E289D7861AFF1945645" pageId="null" pageNumber="410" type="description">
<paragraph id="CF37AB8BCD3770491E126C3FA7FDA0A0" pageId="null" pageNumber="410">
1 
<normalizedToken id="00DC519682A569783F2ACE6FB39B202A" originalValue="jährig" pageId="null" pageNumber="410">jaehrig</normalizedToken>
; 5-20 cm hoch, 
<normalizedToken id="BFABC47CA9DF4B8B124B3185A1761A03" originalValue="büschelig" pageId="null" pageNumber="410">bueschelig</normalizedToken>
. 
<normalizedToken id="BF61884D3C1486CAEFF6DF70EC0FF917" originalValue="Blätter" pageId="null" pageNumber="410">Blaetter</normalizedToken>
bis 1 mm breit, flach. Stengel stumpf 3kantig. 
<normalizedToken id="F71CEF41146F32E0F7CA999BF951F6EB" originalValue="Blütenstand" pageId="null" pageNumber="410">Bluetenstand</normalizedToken>
mit teilweise 
<normalizedToken id="E1A03533B3F05C11484A406C87FDC58E" originalValue="blattähnlichen" pageId="null" pageNumber="410">blattaehnlichen</normalizedToken>
<normalizedToken id="E02D477A3878AA7A5705655E6B5CF97D" originalValue="Hochblättern" pageId="null" pageNumber="410">Hochblaettern</normalizedToken>
, die 
<normalizedToken id="AB5BB145398CFD36612E6011B5583A86" originalValue="länger" pageId="null" pageNumber="410">laenger</normalizedToken>
sein 
<normalizedToken id="00AA46D2527D1FBA23F584BB98565302" originalValue="können" pageId="null" pageNumber="410">koennen</normalizedToken>
als der 
<normalizedToken id="269E542F9EF393B0EB22A8C95B640CF4" originalValue="Blütenstand" pageId="null" pageNumber="410">Bluetenstand</normalizedToken>
, aus 
<emphasis id="74AA465C541B862F8BB938B1B4A26CE7" italics="true" pageId="null" pageNumber="410">
3-10 
<normalizedToken id="C73AFFF8EDEF6B1F0FC1C02CBEF1428C" originalValue="Ähren" pageId="null" pageNumber="410">Aehren</normalizedToken>
</emphasis>
bestehend. 
<normalizedToken id="AB9E4CD31D446610AF67EC6F894D3783" originalValue="Ähren" pageId="null" pageNumber="410">Aehren</normalizedToken>
4-7 mm lang, spitz. Reife 
<emphasis id="1AAC3212C0B49BED330FBE0DEF6A7CC7" italics="true" pageId="null" pageNumber="410">Frucht 1</emphasis>
- 
<emphasis id="CC552ABBB786C53E011ED6970468F7A3" italics="true" pageId="null" pageNumber="410">
1,2 mm lang und 0,7-0,9 mm breit, flach, gelblich bis braun, jederseits mit 8-11 
<normalizedToken id="8981BAD14B15DCF0E97F8C33D9BF5735" originalValue="Längsrippen" pageId="null" pageNumber="410">Laengsrippen</normalizedToken>
, die aus den schmalen Seiten der reihenartig angeordneten Zellen gebildet werden;
</emphasis>
Griffelbasis wenig verdickt; 
<emphasis id="64F82568407593CB383EB3AAD5BACBD9" italics="true" pageId="null" pageNumber="410">Narben 2.</emphasis>
<normalizedToken id="6F267C42614E4514B7A8DFB51E1A320A" originalValue="Staubblätter" pageId="null" pageNumber="410">Staubblaetter</normalizedToken>
2. - 
<normalizedToken id="4BF7B1EB701C850111DC2A8ED4C0628C" originalValue="Blüte" pageId="null" pageNumber="410">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="0D30D1680966060270B47CF4056D01F3" pageId="null" pageNumber="410">
<emphasis id="D6E800E0E8897DF4526CAC432D0399D2" italics="true" pageId="null" pageNumber="410">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="1F187EE0642668D54881B74033D0FE2F" pageId="null" pageNumber="410">
<emphasis id="CC5E5C20BB68028CBD96DFB68DC70205" italics="true" pageId="null" pageNumber="410">Standort.</emphasis>
Kollin, Feinsandig-schlammige, kalkfreie, bis in den Hochsommer flach 
<normalizedToken id="136A4DE3FA9895C9EE705D1BF4BD45EB" originalValue="überschwemmte" pageId="null" pageNumber="410">ueberschwemmte</normalizedToken>
Ufer von Seen und 
<normalizedToken id="B5B3975BD2B84A24F946EAB8DA077C2B" originalValue="Tümpeln" pageId="null" pageNumber="410">Tuempeln</normalizedToken>
. 
<emphasis id="2F69B2B0BD2BEFF745F682273E10D5E5" italics="true" pageId="null" pageNumber="410">Eleocharetum ovatae</emphasis>
Hayek 1923 (
<emphasis id="75C4148F2990E49D90EF291915C56D0E" italics="true" pageId="null" pageNumber="410">Eleocharetum ovato-atropurpureae</emphasis>
W. Koch 1926).
</paragraph>
<paragraph id="22241F5A415F0E0C91D0D7B1C6EA674D" pageId="null" pageNumber="410">
<emphasis id="49A21D6A01F618FD8E0522EC8DB93E29" italics="true" pageId="null" pageNumber="410">Verbreitung. Pflanze mit weltweiter Verbreitung:</emphasis>
Tropen und Subtropen der ganzen Erde. In 
<taxonomicName id="CC04E3F70B0C990C26F984E5CF6010F0" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="410" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
im Mediterrangebiet, 
<normalizedToken id="9839928E84D266905A9DD2E876412551" originalValue="nordwärts" pageId="null" pageNumber="410">nordwaerts</normalizedToken>
bis ins Tessin und Meran. - Im Gebiet: Aostatal (z. B. Bollengo), Maggiadelta bei Locarno, Ponte Brolla, Gordola, Magadinoebene bei Quartino (nach 
<normalizedToken id="3FC9BD38EE349A12FC4BAFA375FEC3A2" originalValue="Dübi" pageId="null" pageNumber="410">Duebi</normalizedToken>
in lit. 1963 im Tessin kaum noch vorhanden); Meran (nach Kiem 1962 ist die Art in den Auen zwischen Lana und Marling der Obstkulturen wegen erloschen).
</paragraph>
</subSubSection>
