<subSubSection id="F5EB5BB4F0C98ACE054257C78A141134" pageId="null" pageNumber="42" type="description">
<paragraph id="BC6D2831A5BCE43759A92F681C22BA24" pageId="null" pageNumber="42">
<normalizedToken id="CB6989A77B54AA88B796A3BB86D8830B" originalValue="Kräuter" pageId="null" pageNumber="42">Kraeuter</normalizedToken>
, am Grunde meist verholzt oder 
<normalizedToken id="442EBCA9C430CD1684D79589E73D123F" originalValue="Sträucher" pageId="null" pageNumber="42">Straeucher</normalizedToken>
(oft windend). 
<normalizedToken id="5D179604D97C39B4717A9E64C45A3D1B" originalValue="Blüten" pageId="null" pageNumber="42">Blueten</normalizedToken>
in Dolden oder in Trauben, in Blattachseln oder 
<normalizedToken id="5E24B4503ED5EC01BE97A342DAEA81F1" originalValue="endständig" pageId="null" pageNumber="42">endstaendig</normalizedToken>
, 
<emphasis id="BBD4A8097CB6B92262D4CD14654A0A8D" italics="true" pageId="null" pageNumber="42">
klein, 
<normalizedToken id="390BDEA3C31D804495FDD7DA12F1F0A4" originalValue="weiß" pageId="null" pageNumber="42">weiss</normalizedToken>
, 
<normalizedToken id="A3DC872B23617C376C2C76EB341595AF" originalValue="gelbgrün" pageId="null" pageNumber="42">gelbgruen</normalizedToken>
oder 
<normalizedToken id="9463195E5577CEE5F051E384D752C01A" originalValue="rötlich" pageId="null" pageNumber="42">roetlich</normalizedToken>
.
</emphasis>
<normalizedToken id="901AA2598A2503979D1F88D3B86ED7C8" originalValue="Kelchblätter" pageId="null" pageNumber="42">Kelchblaetter</normalizedToken>
schmal lanzettlich und spitz oder stumpf. Krone sehr vielgestaltig: 
<normalizedToken id="17567C45C0D1312F2AB62709E8980C43" originalValue="röhrenförmig" pageId="null" pageNumber="42">roehrenfoermig</normalizedToken>
, 
<normalizedToken id="6DD6A09A74ED99D7667CB52709B26731" originalValue="glockenförmig" pageId="null" pageNumber="42">glockenfoermig</normalizedToken>
, 
<normalizedToken id="628756DE3C3B21C83207BF9FCF89CDD5" originalValue="trichterförmig" pageId="null" pageNumber="42">trichterfoermig</normalizedToken>
oder flach, die 
<normalizedToken id="F5EF9C101C65BB2DD517FFF33B19BCB3" originalValue="Kronblätter" pageId="null" pageNumber="42">Kronblaetter</normalizedToken>
meist fast bis zum Grunde frei. Nebenkrone am Grunde des Gynostegiums ebenfalls vielgestaltig: 
<emphasis id="81E44101F396F14185E36FE2AD2118AC" italics="true" pageId="null" pageNumber="42">weit hinauf verwachsen</emphasis>
oder bis fast zum Grunde frei. 
<normalizedToken id="F07A68644D1F112B6A5628E37EC3C922" originalValue="Teilfrüchte" pageId="null" pageNumber="42">Teilfruechte</normalizedToken>
meist kahl und glatt. Samen mit Haarschopf.
</paragraph>
<paragraph id="A35ABF5660590B375BF0F6EC47E6EEEF" pageId="null" pageNumber="42">
Die Gattung 
<taxonomicName id="E7D98594C53D0B786769A3CE5C93744B" class="Magnoliopsida" family="Apocynaceae" genus="Vincetoxicum" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="42" phylum="Tracheophyta" rank="genus">
<emphasis id="378D3CB69F6FF4E95850A69B539061F2" italics="true" pageId="null" pageNumber="42">Vincetoxicum</emphasis>
</taxonomicName>
<normalizedToken id="1045A01F9DB75E93A03C10EA99DFDE13" originalValue="umfaßt" pageId="null" pageNumber="42">umfasst</normalizedToken>
<emphasis id="E17C596C311F6E5F904F49ED3000F9E5" italics="true" pageId="null" pageNumber="42">
etwa 150 Arten, die in den subtropischen und 
<normalizedToken id="68D2BFA0CC32F1912B1C65A0AEF77AEB" originalValue="gemäßigten" pageId="null" pageNumber="42">gemaessigten</normalizedToken>
Zonen verbreitet sind.
</emphasis>
Eine 
<normalizedToken id="DA16D15BD0145F0DCC3CAC929C949D3F" originalValue="Übersicht" pageId="null" pageNumber="42">Uebersicht</normalizedToken>
<normalizedToken id="5ADE84C40A6E03EA820E3709E77A6479" originalValue="über" pageId="null" pageNumber="42">ueber</normalizedToken>
die 
<normalizedToken id="ACCE7A0C4C6D76FC3D7F548E1CC870F3" originalValue="südeuropäischen" pageId="null" pageNumber="42">suedeuropaeischen</normalizedToken>
Arten (als 
<taxonomicName id="5CFB17A6B0439442EADAD70A8A877796" authority="L." authorityName="L." class="Magnoliopsida" family="Apocynaceae" genus="Cynanchum" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="42" phylum="Tracheophyta" rank="genus">
<emphasis id="7217199A97EDAD791DE03F110B296A66" italics="true" pageId="null" pageNumber="42">Cynanchum</emphasis>
<authorityName id="5E48A7924D3651383ACF3513A7BC187D" pageId="null" pageNumber="42">L.</authorityName>
</taxonomicName>
bezeichnet) mit 
<normalizedToken id="ECDC178870310649ECFFB16897A68C27" originalValue="Bestimmungsschlüssel" pageId="null" pageNumber="42">Bestimmungsschluessel</normalizedToken>
<normalizedToken id="FF419D2B0EA09D3C4B37B38E660BB64F" originalValue="verfaßten" pageId="null" pageNumber="42">verfassten</normalizedToken>
Borhidi und Priszter (1966).
</paragraph>
</subSubSection>
