<caption id="90EB6676FF3C6A83FA7A92F117FCBFF7" ID-DOI="http://doi.org/10.5281/zenodo.6398890" ID-Zenodo-Dep="6398890" box="[1414,2556,1192,1221]" httpUri="https://zenodo.org/record/6398890/files/figure.png" inLine="true" pageId="199" pageNumber="961" targetBox="[1413,2005,722,1128]" targetPageId="199">
