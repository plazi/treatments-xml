<subSubSection id="9495FF7E9641ABC1B09271153F7733C4" pageId="null" pageNumber="754" type="description">
<paragraph id="528FA539DE3F2E1B542A7C6304802089" pageId="null" pageNumber="754">
Unterscheidet sich von 
<taxonomicName id="8E62D4D2F8419C9F6C4EFF90C51EAF2D" class="Magnoliopsida" family="Amaranthaceae" genus="Chenopodium" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="754" phylum="Tracheophyta" rank="species" species="glaucum">
<emphasis id="2C9DF68414938AC3AC419A3BC257824F" italics="true" pageId="null" pageNumber="754">Ch. glaucum</emphasis>
</taxonomicName>
(Nr. 6) durch folgende Merkmale: 
<emphasis id="12ED6C138C4FAB9A1149FF7E2B8EF849" italics="true" pageId="null" pageNumber="754">
Die meisten 
<normalizedToken id="AC1DD53F438684105E9EFC1E26768766" originalValue="Blätter" pageId="null" pageNumber="754">Blaetter</normalizedToken>
im 
<normalizedToken id="F39FCDA4882C5C5608E071AE030B5E82" originalValue="Umriβ" pageId="null" pageNumber="754">Umriβ</normalizedToken>
rhombisch, 2-8 cm lang, 1-3mal so lang wie breit, beiderseits von gleichem 
<normalizedToken id="2C7CAAB44CADFCF5C9A7556F303FEBA0" originalValue="Grün" pageId="null" pageNumber="754">Gruen</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="3ACB329EC282203BDAE917F2BF21CA44" originalValue="Blüte" pageId="null" pageNumber="754">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="9234BF5BE61924EE4956B8B763AC43B2" pageId="null" pageNumber="754">
<emphasis id="CF0BC32082F07B82E3D72F50EB7EFB50" italics="true" pageId="null" pageNumber="754">
<pageBreakToken id="5B032E0193C87B320DD9C1C9143299CF" pageId="null" pageNumber="754">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="F198C680A828C8C621145654841749DC" italics="true" pageId="null" pageNumber="754">36:</emphasis>
Material aus Schweden (Kjellmark 1934), aus England (Cole 1962), aus botanischen 
<normalizedToken id="739C214825B63CE31AE7CC836976A17F" originalValue="Gärten" pageId="null" pageNumber="754">Gaerten</normalizedToken>
(Kawatani und Ohno 1962).
</paragraph>
<paragraph id="3C948663D11C441D0892F087EDAE236A" pageId="null" pageNumber="754">
<emphasis id="17CBBC94076E074804CAA93E3AD4DBC7" italics="true" pageId="null" pageNumber="754">Standort.</emphasis>
Wie 
<taxonomicName id="064665B9764C46ABA08B980E4B9EBC72" class="Magnoliopsida" family="Amaranthaceae" genus="Chenopodium" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="754" phylum="Tracheophyta" rank="species" species="glaucum">
<emphasis id="420A5154EE42B70A40177FD51EBE4487" italics="true" pageId="null" pageNumber="754">Ch. glaucum</emphasis>
</taxonomicName>
(Nr. 6).
</paragraph>
<paragraph id="4E4DEC9B2017DBC54C7A6E683007AFC4" pageId="null" pageNumber="754">
<emphasis id="6F91C1B7B30ACD6F1922D2614AEC6227" italics="true" pageId="null" pageNumber="754">Verbreitung. Eurasiatisch-nordamerikanische Pflanze:</emphasis>
Wie 
<taxonomicName id="99C2CA0E2730189304425D52E34584B6" class="Magnoliopsida" family="Amaranthaceae" genus="Chenopodium" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="754" phylum="Tracheophyta" rank="species" species="glaucum">
<emphasis id="BDCE31BF647EE4A2A822D083225FD07E" italics="true" pageId="null" pageNumber="754">Ch. glaucum</emphasis>
</taxonomicName>
(Nr. 6), zudem in Nordwestafrika und Nordamerika. - Im Gebiet verbreitet, ziemlich selten.
</paragraph>
</subSubSection>
