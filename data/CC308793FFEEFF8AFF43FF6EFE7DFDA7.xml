<bibRefCitation id="20084B74FFEEFF8AFB61FE04FF51FE66" author="Giray, H." pageId="9" pageNumber="448" pagination="35 - 46" refId="ref6509" refString="Giray, H. 1979. Turkiye Trypetidae (Diptera) faunasina ait ilk liste. Turkiye Bitki Koruma Dergisi, 3, 35 - 46." type="journal article" year="1979">Giray 1979</bibRefCitation>
