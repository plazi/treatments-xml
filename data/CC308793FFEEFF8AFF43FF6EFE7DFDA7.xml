<taxonomicName id="83994D06FFEEFF8AFC04FE04FBE5FE47" box="[1001,1116,388,414]" class="Magnoliopsida" family="Asteraceae" genus="Centaurea" kingdom="Plantae" order="Asterales" pageId="9" pageNumber="448" phylum="Tracheophyta" rank="species" species="calcitrapa">
