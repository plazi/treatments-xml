<taxonomicName id="83994D06FFEEFF8AFD8FFE44FC94FE07" box="[610,813,452,478]" class="Magnoliopsida" family="Asteraceae" genus="Centaurea" kingdom="Plantae" order="Asterales" pageId="9" pageNumber="448" phylum="Tracheophyta" rank="species" species="aspera">
<emphasis id="76EDEA97FFEEFF8AFD8FFE44FC94FE07" box="[610,813,452,478]" italics="true" pageId="9" pageNumber="448">Centaurea aspera</emphasis>
</taxonomicName>
