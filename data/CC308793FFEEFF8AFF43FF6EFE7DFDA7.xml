<taxonomicName id="83994D06FFEEFF8AFD69FE24FB75FE66" authority="(Becker) (White &amp; Marquardt, 1989)" authorityName="White &amp; Marquardt" authorityYear="1989" baseAuthorityName="Becker" box="[644,1228,420,447]" class="Magnoliopsida" family="Asteraceae" genus="Centaurea" kingdom="Plantae" order="Asterales" pageId="9" pageNumber="448" phylum="Tracheophyta" rank="species" species="conjuncta">
