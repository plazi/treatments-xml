<figureCitation id="C4A52A1E8E23FF9C9257B80262666843" box="[519,580,575,602]" captionStart="Fig" captionStartId="3.[174,207,1612,1634]" captionTargetBox="[229,1190,174,1581]" captionTargetId="figure-8@3.[208,1190,174,1582]" captionTargetPageId="3" captionText="Fig. 2. Smears impregnated with silver nitrate (Klein 1958) from Chinese slipper from Ukrainian rivers: a — Trichodina acuta Lom, 1961; b — Trichodina intermedia Lom, 1961; c — Trichodina mutabilis Kazubski et Migala, 1968; d — Trichodina nigra Lom, 1960; e — Trichodina pediculus Ehrenberg, 1838; f — Trichodina perforata Lom, 1976. Scale bar 10 µm." figureDoi="http://doi.org/10.5281/zenodo.6453050" httpUri="https://zenodo.org/record/6453050/files/figure.png" pageId="4" pageNumber="235">fig. 2</figureCitation>
, 
<emphasis id="6EEAEA898E23FF9C921FB802627C6840" box="[591,606,575,601]" italics="true" pageId="4" pageNumber="235">d</emphasis>
