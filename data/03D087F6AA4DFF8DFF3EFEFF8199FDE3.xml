<paragraph id="8BC636E0AA4DFF8DFF3EFEDE8199FE99" blockId="4.[136,1452,266,551]" pageId="4" pageNumber="119">
<keyLead id="308895D5AA4DFF8DFF3EFEDE8199FE99" pageId="4" pageNumber="119">
1. Bracteoles 
<quantity id="4C819B05AA4DFF8DFE8BFEDF8582FE85" box="[317,432,298,320]" metricMagnitude="-3" metricUnit="m" metricValue="8.3" metricValueMax="9.5" metricValueMin="7.1" pageId="4" pageNumber="119" unit="mm" value="8.3" valueMax="9.5" valueMin="7.1">7.1–9.5 mm</quantity>
long, densely pubescent; calyx lobes orbicular; petals 
<quantity id="4C819B05AA4DFF8DFC01FEDE8070FE85" box="[951,1090,299,321]" metricMagnitude="-2" metricUnit="m" metricValue="1.7" metricValueMax="1.71" metricValueMin="1.69" pageId="4" pageNumber="119" unit="mm" value="17.0" valueMax="17.1" valueMin="16.9">16.9–17.1 mm</quantity>
long; hypanthium densely pubescent; stamens 227–235; fruits puberulous-tomentose .............................................................................................................. 
