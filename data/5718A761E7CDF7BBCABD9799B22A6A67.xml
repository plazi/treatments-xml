<subSubSection id="CAE6EEA3ABF180A78D0279C7AD581B06" pageId="null" pageNumber="543" type="vernacular_names">
<paragraph id="B3EEA91C4953BB045AA6677F9286FA5A" pageId="null" pageNumber="543">Neuengland-Aster</paragraph>
</subSubSection>
</title>
<subSubSection id="ED080ADB3D332656A654D93D797EB296" pageId="null" pageNumber="543" type="description">
<paragraph id="DDEA8C9E5FBC05F6EC7F6542E1A6F2FF" pageId="null" pageNumber="543">
Ausdauernd, mit kriechendem Rhizom und 
<normalizedToken id="DCCA2CC0D81F5A6BB11C26E0CB4AF0AE" originalValue="Ausläufern" pageId="null" pageNumber="543">Auslaeufern</normalizedToken>
; 50-150 cm hoch. Stengel 
<emphasis id="36FD7BADF6D0BC250A48B5BFE05277B1" italics="true" pageId="null" pageNumber="543">aufrecht, dicht behaart</emphasis>
(Haare mehrzellig), 
<emphasis id="1CEEB30B7E7BB25B5F87F396662BE7BE" italics="true" pageId="null" pageNumber="543">
im obern Teil auch mit 
<normalizedToken id="BBCEC2C205174AEBA4AEEBAD801CFE73" originalValue="Drüsenhaaren" pageId="null" pageNumber="543">Druesenhaaren</normalizedToken>
</emphasis>
, 
<normalizedToken id="F2ADC1310BE8A47C6EC2659C5249C190" originalValue="vielköpfig" pageId="null" pageNumber="543">vielkoepfig</normalizedToken>
, 
<normalizedToken id="5BDDB645CA52504A0053BB12870C13A5" originalValue="oberwärts" pageId="null" pageNumber="543">oberwaerts</normalizedToken>
verzweigt. 
<emphasis id="D6D54B546CC7ED55D218F6A091757E1C" italics="true" pageId="null" pageNumber="543">
<normalizedToken id="59F383C8B64722E02BE63FCCC914839D" originalValue="Blätter" pageId="null" pageNumber="543">Blaetter</normalizedToken>
beiderseits dicht behaart
</emphasis>
, lanzettlich, ganzrandig, 
<emphasis id="96CE451E88272C74193B1EF324615E2B" italics="true" pageId="null" pageNumber="543">
am Grunde 
<normalizedToken id="E7021EB6D11C7DDD63EC31B3E8596489" originalValue="herzförmig" pageId="null" pageNumber="543">herzfoermig</normalizedToken>
, den Stengel mit 2 breiten Zipfeln
</emphasis>
(
<emphasis id="0A987479C9CAA1C946C97EE81D3772B7" italics="true" pageId="null" pageNumber="543">Zipfel breiter als der Durchmesser des Stengels</emphasis>
) 
<emphasis id="7C81E95D32445A033936B771F9519996" italics="true" pageId="null" pageNumber="543">
umfassend; 
<normalizedToken id="84BFA932794234808C045754BC810A12" originalValue="grundständige" pageId="null" pageNumber="543">grundstaendige</normalizedToken>
<normalizedToken id="BB34FB6153053CA18F1BC8ECA7B1A854" originalValue="Blätter" pageId="null" pageNumber="543">Blaetter</normalizedToken>
zur 
<normalizedToken id="613A5A754B1C2C689EBA6232D55EF3D4" originalValue="Blütezeit" pageId="null" pageNumber="543">Bluetezeit</normalizedToken>
verdorrt. 
<normalizedToken id="D36C269149908597C6545260B935F965" originalValue="Blütenköpfe" pageId="null" pageNumber="543">Bluetenkoepfe</normalizedToken>
in einer doldenartigen Rispe
</emphasis>
, im Durchmesser 3-4 cm. 
<emphasis id="584CEB3BD92546D49E615C6AF618D481" italics="true" pageId="null" pageNumber="543">
<normalizedToken id="BBBA1B1D39AE8561A99889180B36DD6D" originalValue="Hülle" pageId="null" pageNumber="543">Huelle</normalizedToken>
8
</emphasis>
- 
<emphasis id="7A4D1693EEBA1005BD70D1BE12000206" italics="true" pageId="null" pageNumber="543">10 cm lang.</emphasis>
<normalizedToken id="BB184C3887FB6420F0E822CE681BEF49" originalValue="Hüllblätter" pageId="null" pageNumber="543">Huellblaetter</normalizedToken>
anliegend, alle etwa gleich lang, 4-8mal so lang wie breit, 
<emphasis id="F96A44CDD639AA1B23DFFBDAA9ACA1E9" italics="true" pageId="null" pageNumber="543">
<normalizedToken id="0B8276169CBE22A8708F60AAD194AC83" originalValue="allmählich" pageId="null" pageNumber="543">allmaehlich</normalizedToken>
und lang zugespitzt
</emphasis>
, im untersten Drittel am breitesten, 
<emphasis id="265ECA9614796A81BFE5C588AE790245" italics="true" pageId="null" pageNumber="543">
mit 
<normalizedToken id="9A08E65043513E9848D71EE91CB35D12" originalValue="Drüsenhaaren" pageId="null" pageNumber="543">Druesenhaaren</normalizedToken>
</emphasis>
, am Grunde beiderseits bis auf den Mittelnerv 
<normalizedToken id="451A52E43F61F6EAF9E543079E746688" originalValue="weiß" pageId="null" pageNumber="543">weiss</normalizedToken>
und lederig. 
<normalizedToken id="294FE7B1F31BC26EAB6F5A28FCD4A35A" originalValue="Zungenblüten" pageId="null" pageNumber="543">Zungenblueten</normalizedToken>
sehr zahlreich (60-90; bei andern Arten im Gebiet kaum 
<normalizedToken id="1E60F4DBDC88CAC4808F308B9584C0F8" originalValue="über" pageId="null" pageNumber="543">ueber</normalizedToken>
50), violettpurpurn. 
<normalizedToken id="5B87F25E8F1FCAA30B8CDB52DA594D6F" originalValue="Früchte" pageId="null" pageNumber="543">Fruechte</normalizedToken>
2-3 mm lang, 
<emphasis id="7358B68574F34E36A23947D650F611F6" italics="true" pageId="null" pageNumber="543">dicht behaart.</emphasis>
<taxonomicName id="68DC816C6924C8CDCDB4FB32123C40A0" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="543" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
ca. 6 mm lang, 
<emphasis id="B8147D784AE2E7A7E8677E036255660E" italics="true" pageId="null" pageNumber="543">
<normalizedToken id="874FAED395670DBECC45AEA77B729840" originalValue="bräunlich" pageId="null" pageNumber="543">braeunlich</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="BA06AE5F5EB1B0BEEA8D7A6B0E9BABBE" originalValue="Blüte" pageId="null" pageNumber="543">Bluete</normalizedToken>
: Herbst.
</paragraph>
<paragraph id="490EF6C4DBEC63B045AC4C824F2650BC" pageId="null" pageNumber="543">
<emphasis id="1772FC61AFCFB7EE8CFAD7B096B2DA0E" italics="true" pageId="null" pageNumber="543">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="7637C36BD45BC16F0956BE00D0C317EA" italics="true" pageId="null" pageNumber="543">10:</emphasis>
Material aus Nordamerika (Delisle 1937, van Faasen 1963, 
<normalizedToken id="ACCF2973E6C5F7832107FFF0E64E20E6" originalValue="Löve" pageId="null" pageNumber="543">Loeve</normalizedToken>
und 
<normalizedToken id="2718A210F9735F88F8490AEF52DA1BA6" originalValue="Löve" pageId="null" pageNumber="543">Loeve</normalizedToken>
1964), aus 
<normalizedToken id="5D18B888D5586B341B6BB516E6111C27" originalValue="Gärten" pageId="null" pageNumber="543">Gaerten</normalizedToken>
(Annen 1945, zahlreiche weitere Autoren zusammengestellt von Huziwara 1958, 
<normalizedToken id="23DB4296C116B87D2E7C727275CFEFA9" originalValue="Löve" pageId="null" pageNumber="543">Loeve</normalizedToken>
und 
<normalizedToken id="DA1BD2AD79B8ED3855CD9653EE13428A" originalValue="Löve" pageId="null" pageNumber="543">Loeve</normalizedToken>
1961). 
<emphasis id="CEA9A26A05E03CFD69E1816DBD6AE3B0" italics="true" pageId="null" pageNumber="543">2n</emphasis>
= 
<emphasis id="51AFDFFF71C6C3E1108433BE15AD0944" italics="true" pageId="null" pageNumber="543">20:</emphasis>
Material aus Kalifornien (Avers 1954).
</paragraph>
<paragraph id="1D4403CF4F5AC51E841FD792DA2C62DE" pageId="null" pageNumber="543">
<emphasis id="24EF958D0B6F08B6298E810D5DA3756B" italics="true" pageId="null" pageNumber="543">Standort.</emphasis>
Kollin. Feuchte, 
<normalizedToken id="6711928DC5BD079E14028C1243893562" originalValue="nährstoffreiche" pageId="null" pageNumber="543">naehrstoffreiche</normalizedToken>
<normalizedToken id="0E56791B5F1952183DBBB87DF1A1141F" originalValue="Lehmböden" pageId="null" pageNumber="543">Lehmboeden</normalizedToken>
. 
<normalizedToken id="0C97D709DE46A0288BA162F6FFE2BD67" originalValue="Auengehölze" pageId="null" pageNumber="543">Auengehoelze</normalizedToken>
, 
<normalizedToken id="5BDF1BC721244868A90AFEDDFE05927D" originalValue="Schuttplätze" pageId="null" pageNumber="543">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="3D7258B90D2B6D9868354416B7678844" pageId="null" pageNumber="543">
<emphasis id="220E8C9717820FAD9B3F59B2D7066E4F" italics="true" pageId="null" pageNumber="543">Verbreitung.</emphasis>
<normalizedToken id="61BB11090A12514848A6A4B86EBFCCED" originalValue="Ursprünglich" pageId="null" pageNumber="543">Urspruenglich</normalizedToken>
<emphasis id="8CF3C3E46060AEC6B5A2C8906E277881" italics="true" pageId="null" pageNumber="543">nordamerikanische Pflanze;</emphasis>
in Eurasien 
<normalizedToken id="EBE48F9474279862FFCCD4D4868BB0B3" originalValue="eingeführt" pageId="null" pageNumber="543">eingefuehrt</normalizedToken>
. - Im Gebiet gelegentlich in 
<normalizedToken id="B42108B2F6E1DD16E70092875307225E" originalValue="Gärten" pageId="null" pageNumber="543">Gaerten</normalizedToken>
kultiviert und ziemlich selten verwildert.
</paragraph>
</subSubSection>
