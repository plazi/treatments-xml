<taxonomicName id="4C246CDEFFB0FFF580A52F63358D9E71" authority="(Meyl.) Mar. Mey. &amp; Poulain" authorityName="Mar. Mey. &amp; Poulain" authorityYear="2011" baseAuthorityName="Meyl." box="[136,667,266,293]" class="Myxomycetes" family="Physaraceae" genus="Physarum" kingdom="Protozoa" order="Physarales" pageId="8" pageNumber="39" phylum="Mycetozoa" rank="species" species="nivale">
