Key to species of 
<taxonomicName id="989F31ABCE23595FFED7FACFFE43FAE4" authorityName="Raadik" authorityYear="2021" box="[366,456,1297,1324]" class="Malacostraca" family="Parastacidae" genus="Cherax" kingdom="Animalia" order="Decapoda" pageId="23" pageNumber="367" phylum="Arthropoda" rank="genus">
