<subSubSection id="C6330C1504D2AB44F38C64BC92388EBE" pageId="null" pageNumber="590" type="description">
<paragraph id="4CC8EA6AF0EC4F0BF1D75775750E84A8" pageId="null" pageNumber="590">
5-20 cm hoch. Stengel mit 0-2 
<normalizedToken id="428C6F7B023123C497A5FF016B67DDC7" originalValue="Stengelblättern" pageId="null" pageNumber="590">Stengelblaettern</normalizedToken>
, gerade, meist 1 
<normalizedToken id="24DAEAE4103664425C7923AF0478394F" originalValue="köpfig" pageId="null" pageNumber="590">koepfig</normalizedToken>
, nur unter dem Kopf oder auf der ganzen 
<normalizedToken id="C4F7C14697984F03AA9768BACA88DE21" originalValue="Länge" pageId="null" pageNumber="590">Laenge</normalizedToken>
mit 
<normalizedToken id="1E4ED283F19BA92C666EA157B0646B74" originalValue="weißen" pageId="null" pageNumber="590">weissen</normalizedToken>
bis grauen, einfachen Haaren, 
<emphasis id="38D42B3BD7C8D8AC9066B5D8AA6A3117" italics="true" pageId="null" pageNumber="590">mit wenigen bis sehr zahlreichen, 0,2</emphasis>
- 
<emphasis id="ABEE6EBF3708AC7E3233F615F43B835C" italics="true" pageId="null" pageNumber="590">
0,6 mm langen 
<normalizedToken id="B99528BF8AEA16371FE05CB0CD790F01" originalValue="Drüsenhaaren" pageId="null" pageNumber="590">Druesenhaaren</normalizedToken>
.
</emphasis>
Die 
<normalizedToken id="849A006A97198C4C143174EEA923A9A7" originalValue="größeren" pageId="null" pageNumber="590">groesseren</normalizedToken>
<normalizedToken id="982898DD5A3B88D0570E4B1EE4715BAC" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
5-10mal so lang wie breit, 
<emphasis id="D20CC4FE82AC9C8D6C210DE11B3F6876" italics="true" pageId="null" pageNumber="590">
oberseits und an den 
<normalizedToken id="C44B972C82D4DABA3ECBCCCC196FEA86" originalValue="Rändern" pageId="null" pageNumber="590">Raendern</normalizedToken>
und oft auch unterseits mit zahlreichen, einfachen Haaren
</emphasis>
, ohne 
<normalizedToken id="CE08BF5DA012F5A8E0220F1E39CD30DF" originalValue="Drüsenhaare" pageId="null" pageNumber="590">Druesenhaare</normalizedToken>
, 
<emphasis id="7EDB9C9BFC774139329AD3A2BC576B96" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="530260EBA8C8F3F5CE88E8E53F0D5DA1" originalValue="grün" pageId="null" pageNumber="590">gruen</normalizedToken>
.
</emphasis>
<normalizedToken id="7A19A91F41816C0001AB73540D86BA2E" originalValue="Stengelblätter" pageId="null" pageNumber="590">Stengelblaetter</normalizedToken>
klein, etwa in der Mitte am breitesten, mit 
<normalizedToken id="253FF40F76D4F15A0B5AE5056D088C1C" originalValue="verschmälertem" pageId="null" pageNumber="590">verschmaelertem</normalizedToken>
Grunde sitzend. 
<normalizedToken id="CCDA774624E36B229E15A11563DF8667" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
9-15 mm lang, ohne 
<normalizedToken id="F95BE9194EA5C1D13E880306BC206490" originalValue="Drüsenhaare" pageId="null" pageNumber="590">Druesenhaare</normalizedToken>
. 
<normalizedToken id="5DB2FAB1633634894F4788702B2A9262" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
hellgelb. Krone kahl. 
<normalizedToken id="7D56668BB291BC0A77D269F2987C2A99" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
2,5-3 mm lang. - 
<normalizedToken id="AB15AA6ADBDFB1EB9CA7064477C7FC45" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="E907BDC44CE65703CD6720C20B43AEF7" pageId="null" pageNumber="590">
<emphasis id="156258269F49804E656A1AE42CB54E08" italics="true" pageId="null" pageNumber="590">
<pageBreakToken id="DB04A515BD8FA5A41A32FE70ECAD7B96" pageId="null" pageNumber="590">Zytologische</pageBreakToken>
Angaben.
</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="0FED956A3F37CA05DA9F645CF0EA4BFB" pageId="null" pageNumber="590">
<emphasis id="870858335848396730DE02AFFBE852DB" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Alpin, selten subalpin. Steinige, magere, saure, humose 
<normalizedToken id="DDF7E78D0E1EE4385069F1D87106BB16" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
. Lockere Rasen, Steine, 
<normalizedToken id="7AC20010206B350118938844F9D15B31" originalValue="Geröllhalden" pageId="null" pageNumber="590">Geroellhalden</normalizedToken>
, 
<normalizedToken id="C09B4BA93AA398EC1B7A0130AA54980B" originalValue="Moränen" pageId="null" pageNumber="590">Moraenen</normalizedToken>
. 
<emphasis id="7E1D03198F549808285E020123828FE4" italics="true" pageId="null" pageNumber="590">Caricetum curvulae</emphasis>
(Kerner) Brockmann-Jerosch 1907.
</paragraph>
<paragraph id="BAAFCB63F4204691EFAF77983C1E781F" pageId="null" pageNumber="590">
<emphasis id="53FB1ED9F24F0CA51651336EA9AF5034" italics="true" pageId="null" pageNumber="590">
Verbreitung. Mittel- und 
<normalizedToken id="4F9A23A605403E1474F12675FC5E0CC1" originalValue="südeuropäische" pageId="null" pageNumber="590">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
<normalizedToken id="60676BFA6D22C0494F5C160701DF25B3" originalValue="Pyrenäen" pageId="null" pageNumber="590">Pyrenaeen</normalizedToken>
, Auvergne, Alpen, Tatra, Gebirge der Balkanhalbinsel (einzelne isolierte Fundorte). - Im Gebiet: Alpen (besonders Zentral- und 
<normalizedToken id="E21EBE3491B9087407422D554CB602EB" originalValue="Südalpen" pageId="null" pageNumber="590">Suedalpen</normalizedToken>
); ziemlich 
<normalizedToken id="7935ADB1EE2A10652CD0DC2D2E741AE7" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="98137F23E4077CDCD7000A09ECC9B744" pageId="null" pageNumber="590">
<emphasis id="66198D8AA10B1422DC9EC2B05A843B2D" italics="true" pageId="null" pageNumber="590">Bemerkungen.</emphasis>
Pflanzen mit sehr zahlreichen, einfachen Haaren und wenigen 
<normalizedToken id="E81B273D784FD040DE5727E846DC7806" originalValue="Drüsenhaaren" pageId="null" pageNumber="590">Druesenhaaren</normalizedToken>
am Stengel, die im 
<normalizedToken id="D538A49AACEF4C241147A201669114E4" originalValue="übrigen" pageId="null" pageNumber="590">uebrigen</normalizedToken>
aber gleiche 
<normalizedToken id="36444C43B149078060F0FF3173D64DAA" originalValue="Ökologie" pageId="null" pageNumber="590">Oekologie</normalizedToken>
und geographische Verbreitung wie die typischen Pflanzen besitzen, werden als 
<taxonomicName id="C91F73114B66014ACE81700B430556D5" authority="Hoppe" authorityName="Hoppe" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="piliferum">
<emphasis id="24A72811E43F750CEAD01594738B8353" italics="true" pageId="null" pageNumber="590">H. piliferum</emphasis>
Hoppe
</taxonomicName>
bezeichnet. Die unterscheidenden Merkmale stammen wahrscheinlich aus Kreuzungen mit 
<emphasis id="C53CA73884CB1B7CE78C23AC3594E1E8" italics="true" pageId="null" pageNumber="590">
<taxonomicName id="7CEEBFAEA9292B0D036570DE56626806" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="villosum">H. villosum</taxonomicName>
.
</emphasis>
</paragraph>
</subSubSection>
