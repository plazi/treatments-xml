<subSubSection id="C32E54C81601FFEEB59EE66D6F62C8D5" pageId="23" pageNumber="339" type="biology_ecology">
<paragraph id="8B8B07431601FFEEB59EE66D694CC818" blockId="23.[160,1155,1354,1449]" box="[160,533,1354,1380]" pageId="23" pageNumber="339">
<emphasis id="B940DB511601FFEEB59EE66D694CC818" bold="true" box="[160,533,1354,1380]" italics="true" pageId="23" pageNumber="339">Ecological and biological notes</emphasis>
</paragraph>
<paragraph id="8B8B07431601FFEEB59EE6496F62C8D5" blockId="23.[160,1155,1354,1449]" pageId="23" pageNumber="339">This species was collected from a banana farm where the soil was moist and rich in decaying livestock faeces. Several pselaphine beetles were also observed in the same habitat.</paragraph>
</subSubSection>
