mit 
<normalizedToken id="F8E26DB57A339544525359C40B5D38F1" originalValue="großem" pageId="null" pageNumber="551">grossem</normalizedToken>
Endteilblatt und ohne oder mit je 1-6 kleineren seitlichen 
<normalizedToken id="8751E048105C0AECA5D420BE4AE79CFC" originalValue="Teilblättern" pageId="null" pageNumber="551">Teilblaettern</normalizedToken>
; 
<normalizedToken id="2CE6C1B2714D513575F56E78DDF4D86E" originalValue="Teilblätter" pageId="null" pageNumber="551">Teilblaetter</normalizedToken>
