</bibRefCitation>
), 
<collectingCountry id="91D8764D3F70FFE7FBADFAADFB7DFAA4" box="[1100,1181,1323,1349]" name="Cyprus" pageId="69" pageNumber="70">Cyprus</collectingCountry>
(
<bibRefCitation id="8D5E4B2C3F70FFE7FB4CFAADFA70FAA4" author="Kovacic, M. &amp; Sanda, R. &amp; Cekovska, K. &amp; Soukupova, T. &amp; Vukic, J." box="[1197,1424,1323,1349]" pageId="69" pageNumber="70" pagination="285 - 317" refId="ref59357" refString="Kovacic, M., Sanda, R., Cekovska, K., T. Soukupova, T. &amp; Vukic, J. (2021) Zebrus pallaoroi sp. nov.: a new species of goby (Actinopterygii: Gobiidae) from the Mediterranean Sea with a dna-based phylogenetic analysis of the Gobius - lineage. Contributions to Zoology Advance articles, 90 (3), 285 - 317 https: // doi. org / 10.1163 / 18759866 - bja 10018" type="journal article" year="2021">
Kovačić 
<emphasis id="DBBBEACF3F70FFE7FAF2FAADFAA5FAA4" box="[1299,1349,1323,1349]" italics="true" pageId="69" pageNumber="70">et al</emphasis>
. 2021
</bibRefCitation>
), 
<collectingCountry id="91D8764D3F70FFE7FF76FAC9FF35FA88" box="[151,213,1359,1385]" name="Israel" pageId="69" pageNumber="70">Israel</collectingCountry>
