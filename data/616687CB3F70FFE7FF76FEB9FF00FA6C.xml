(
<bibRefCitation id="8D5E4B2C3F70FFE7FADCFB65FF33FAC0" author="Kovacic, M." pageId="69" pageNumber="70" pagination="1 - 24" refId="ref57897" refString="Kovacic, M. (2005) An annotated checklist of the family Gobiidae in the Adriatic Sea. Annales, Series Historia Naturalis, 15, 1 - 24." type="journal article" year="2005">Kovačić 2005</bibRefCitation>
), 
<collectingCountry id="91D8764D3F70FFE7FF06FA81FEA9FAC0" box="[231,329,1287,1313]" name="Slovenia" pageId="69" pageNumber="70">Slovenia</collectingCountry>
(
<bibRefCitation id="8D5E4B2C3F70FFE7FEB6FA81FDFFFAC0" author="Trkov, D. &amp; Mavric, B. &amp; Orlando-Bonaca, M. &amp; Lipej, L." box="[343,543,1287,1313]" pageId="69" pageNumber="70" pagination="59 - 72" refId="ref65518" refString="Trkov, D., Mavric, B., Orlando-Bonaca, M. &amp; Lipej, L. (2019) Marine cryptobenthic fish fauna of Slovenia (Northern Adriatic Sea). Annales, Series Historia Naturalis, 29 (1), 59 - 72. https: // doi. org / 10.19233 / ASHN. 2019.07" type="journal article" year="2019">
