<paragraph pageId="0" pageNumber="1">
Genus 
<taxonomicName LSID="https://zoobank.org/A53F90E1-9ADE-4AA1-8C65-F80165FE0233" authority="Simutnik" authorityName="Simutnik" authorityYear="2022" family="Encyrtidae" genus="Protaphycus" higherTaxonomySource="treatment-meta" kingdom="Animalia" lsidName="Protaphycus" order="Hymenoptera" pageId="0" pageNumber="1" rank="genus" status="gen. nov.">Protaphycus Simutnik</taxonomicName>
