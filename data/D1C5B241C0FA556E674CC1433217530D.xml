<taxonomicName id="EB3AC4584A3D2D59307225163A141243" authority="L." class="Magnoliopsida" family="Brassicaceae" genus="Lepidium" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="133" phylum="Tracheophyta" rank="species" species="virginicum">
