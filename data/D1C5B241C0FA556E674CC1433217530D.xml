<normalizedToken id="0CA557169130FC05D68F6DF035A789D1" originalValue="virgínicum" pageId="null" pageNumber="133">virginicum</normalizedToken>
<authorityName id="D95523BEE0C975C12750A74688D58BAE" pageId="null" pageNumber="133">L.</authorityName>
