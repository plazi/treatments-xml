<subSubSection id="3955199DD3109BFAE04905730260F75B" pageId="null" pageNumber="133" type="vernacular_names">
<paragraph id="C65C918E233581874854B12B9066DFB6" pageId="null" pageNumber="133">Virginische Kresse</paragraph>
</subSubSection>
</title>
<subSubSection id="884C5A25A2AF19F471C070A04F3E9B29" pageId="null" pageNumber="133" type="description">
<paragraph id="DE08E4135E428009F77590EF8200C8C6" pageId="null" pageNumber="133">
<emphasis id="6BAA26640EDF3903729D3F86166B74E6" italics="true" pageId="null" pageNumber="133">
Haare am Stengel ca. 0,1 mm lang, 
<normalizedToken id="5A27647BB79676274D85F99E2EE98810" originalValue="rückwärts" pageId="null" pageNumber="133">rueckwaerts</normalizedToken>
gegen den Stengel 
<normalizedToken id="CFDC99F07F1E1AABA7DDB5F7EEE2734C" originalValue="gekrümmt" pageId="null" pageNumber="133">gekruemmt</normalizedToken>
; Haare an den 
<normalizedToken id="4CA7F2AD68A65820B787F35E6EAB9D28" originalValue="Blatträndern" pageId="null" pageNumber="133">Blattraendern</normalizedToken>
0,1-0,3 mm lang.
</emphasis>
<normalizedToken id="7F7B5FED8CEA07D67094E4BE4DB16B00" originalValue="Blätter" pageId="null" pageNumber="133">Blaetter</normalizedToken>
oberhalb der Stengelmitte 5-15mal so lang wie breit, teilweise 
<normalizedToken id="3E920D06D9C283E5462B89C8D2B0E267" originalValue="gezähnt" pageId="null" pageNumber="133">gezaehnt</normalizedToken>
. 
<emphasis id="86AA31162BB4A6D18569A161EB1EC6B5" italics="true" pageId="null" pageNumber="133">
<normalizedToken id="C9007CF8CA2CC4FA2288096CA41FC714" originalValue="Kronblätter" pageId="null" pageNumber="133">Kronblaetter</normalizedToken>
1-1,5 mm lang, 
<normalizedToken id="5ADD2F2EEC66E74CCFCB4D9FE891C99C" originalValue="länger" pageId="null" pageNumber="133">laenger</normalizedToken>
als die 
<normalizedToken id="8CFBA98BF2444AD9DD07DD76691FA04D" originalValue="Kelchblätter" pageId="null" pageNumber="133">Kelchblaetter</normalizedToken>
.
</emphasis>
Samen deutlich 
<normalizedToken id="CC173ED869772D5DADCE9F7C945D7D07" originalValue="flügelartig" pageId="null" pageNumber="133">fluegelartig</normalizedToken>
berandet (Rand teilweise breiter als 0,1 mm). - 
<normalizedToken id="2F5CD0C6CCCF3AD28B7F5E6F6E6149B5" originalValue="Blüte" pageId="null" pageNumber="133">Bluete</normalizedToken>
: 
<normalizedToken id="04A2C0CF2897848837CDDB01E857A261" originalValue="Später" pageId="null" pageNumber="133">Spaeter</normalizedToken>
<normalizedToken id="3D93A8F87447C67BEB87233312068EE6" originalValue="Frühling" pageId="null" pageNumber="133">Fruehling</normalizedToken>
bis Herbst.
</paragraph>
<paragraph id="1C334B807EF3E3CB5CAA2E9820444260" pageId="null" pageNumber="133">
<emphasis id="206C2AECC149EF99FDFFA4F7CCD116AB" italics="true" pageId="null" pageNumber="133">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="038746104503CBABE9DB230F0517B27C" italics="true" pageId="null" pageNumber="133">32:</emphasis>
Material unbekannter Herkunft oder aus botanischen 
<normalizedToken id="81C385F417126294D0C8478536B8C8F5" originalValue="Gärten" pageId="null" pageNumber="133">Gaerten</normalizedToken>
(Jaretzky 1932, Manton 1932), aus Nordamerika (Smith 1938, Mulligan 1961a, Easterley 1963). Easterley (1963) 
<normalizedToken id="CD6F85BC66F8C74CD416503CCA0929AF" originalValue="zählte" pageId="null" pageNumber="133">zaehlte</normalizedToken>
auch 2n = 16.
</paragraph>
<paragraph id="CA2E7EE88B0E106C6BB2169183BFE8A1" pageId="null" pageNumber="133">
<emphasis id="9A584EA79EB1998455BBC74A98823D70" italics="true" pageId="null" pageNumber="133">Standort.</emphasis>
Kollin und montan. 
<normalizedToken id="9B99BAFD5483713115A3C933362A59F2" originalValue="Ähnlich" pageId="null" pageNumber="133">Aehnlich</normalizedToken>
wie 
<taxonomicName id="AB405903E4511EF9B7F2E3A527D2DFFF" class="Magnoliopsida" family="Brassicaceae" genus="Lepidium" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="133" phylum="Tracheophyta" rank="species" species="ruderale">
<emphasis id="6DDBB783B145980466E4DC8B0308CEE0" italics="true" pageId="null" pageNumber="133">
<authorityName id="6120BBA562602E41DB7A738EFDC7B8E9" pageId="null" pageNumber="133">L.</authorityName>
ruderale
</emphasis>
</taxonomicName>
(Nr. 6).
</paragraph>
<paragraph id="B2346F8CAC878194DDB7D6832608D21B" pageId="null" pageNumber="133">
<emphasis id="2DCEDCF9FA82FF05D62E694C350CF0D2" italics="true" pageId="null" pageNumber="133">Verbreitung.</emphasis>
<normalizedToken id="22CFF06F74BF4628EA0B01B6A1AEE9DE" originalValue="Ursprünglich" pageId="null" pageNumber="133">Urspruenglich</normalizedToken>
<emphasis id="BB4ECB59A7C4E1273A3D860EE668C98D" italics="true" pageId="null" pageNumber="133">nordamerikanische Pflanze</emphasis>
, heute fast 
<normalizedToken id="23295E362D961826A575337E28D24B83" originalValue="über" pageId="null" pageNumber="133">ueber</normalizedToken>
die ganze Erde verbreitet. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet zerstreut, 
<normalizedToken id="CE9C9DCF4B7D4CEFDC16AF6291C69B6A" originalValue="häufig" pageId="null" pageNumber="133">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="567528ED6AF73820AC526D24AE76D8D3" pageId="null" pageNumber="133">
<emphasis id="AAE3BE2EB1BE953C2C08E05B241710D2" italics="true" pageId="null" pageNumber="133">Bemerkungen.</emphasis>
<normalizedToken id="D0F173D1C22A4768CD256933D8F46029" originalValue="Über" pageId="null" pageNumber="133">Ueber</normalizedToken>
Verzweigungen und Fruchtbildung vgl. Schaeppi (1959).
</paragraph>
</subSubSection>
</treatment>
