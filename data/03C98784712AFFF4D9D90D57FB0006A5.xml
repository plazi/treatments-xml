<subSubSection id="C37A6519712AFFF4D9940CF4FB0006A5" pageId="3" pageNumber="488" type="diagnosis">
<paragraph id="8BDF3692712AFFF4D9940CF4FDFC0684" blockId="3.[174,1232,922,1013]" pageId="3" pageNumber="488">
Diagnosis. 
<taxonomicName id="4C604D11712AFFF4D8080CF4FD2306E4" baseAuthorityName="Gravenhorst" baseAuthorityYear="1820" box="[383,658,922,948]" class="Insecta" family="Ichneumonidae" genus="Cylloceria" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="488" phylum="Arthropoda" rank="species" species="melancholica">
<emphasis id="B914EA80712AFFF4D8080CF4FD2306E4" box="[383,658,922,948]" italics="true" pageId="3" pageNumber="488">Cylloceria melancholica</emphasis>
</taxonomicName>
is similar to 
<taxonomicName id="4C604D11712AFFF4DA500CF4FC1306E4" baseAuthorityName="Gravenhorst" baseAuthorityYear="1829" box="[807,930,922,948]" class="Insecta" family="Ichneumonidae" genus="Cylloceria" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="488" phylum="Arthropoda" rank="species" species="caligata">
<emphasis id="B914EA80712AFFF4DA500CF4FC1306E4" box="[807,930,922,948]" italics="true" pageId="3" pageNumber="488">C. caligata</emphasis>
</taxonomicName>
, but it differs by the black coxae, trochanters and trochantelli.
</paragraph>
<paragraph id="8BDF3692712AFFF4D9940CB4FB0006A5" blockId="3.[174,1232,922,1013]" box="[227,1201,986,1013]" pageId="3" pageNumber="488">
