<collectingCountry id="F3657635935E8E03F6ABFDFEFB30FD4D" box="[1174,1249,620,646]" name="Russia" pageId="7" pageNumber="491">Russia</collectingCountry>
mer. Tauria”, “v Godet”, “ 
<collectionCode id="ED63AE60935E8E03F33DFD02FE98FD61" box="[256,329,656,682]" pageId="7" pageNumber="491">TYPE</collectionCode>
