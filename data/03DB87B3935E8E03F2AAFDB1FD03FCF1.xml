<taxonomicName id="4C724D26935E8E03F011FD02FC4BFD61" authority="Dejean, 1829" authorityName="Dejean" authorityYear="1829" box="[556,922,656,682]" class="Insecta" family="Carabidae" genus="Harpalus" kingdom="Animalia" order="Coleoptera" pageId="7" pageNumber="491" phylum="Arthropoda" rank="species" species="saxicola">
