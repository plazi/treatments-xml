<paragraph id="C36347A80F4BA78AF4B3D718E66C824E" pageId="null" pageNumber="131">
<taxonomicName id="9FC169A8AE8CE122D19E70730135E4E3" authority="L." class="Magnoliopsida" family="Lamiaceae" genus="Stachys" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="131" phylum="Tracheophyta" rank="species" species="germanica">
