<bibRefCitation id="0C094B54FFA4D473FD72F40EFC7AFAE4" author="Bellinger, P. F. &amp; Christiansen, K. A. &amp; Janssens, F." box="[724,962,1339,1366]" pageId="59" pageNumber="60" refId="ref126264" refString="Bellinger, P. F., Christiansen, K. A. &amp; Janssens, F. (1996 - 2022) Checklist of the Collembola of the World. Available from http: // www. collembola. org (accessed 30 January 2022)" type="url" year="1996">
