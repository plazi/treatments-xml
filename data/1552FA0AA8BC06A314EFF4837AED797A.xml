<subSubSection id="BC13BDAF923E19E5F21586C945BEE7ED" pageId="null" pageNumber="552" type="nomenclature">
<paragraph id="2BA16DCE288E974CE337B2434B75609B" pageId="null" pageNumber="552">
<taxonomicName id="BF7B9EA4C0F454D91E2A97D83F85B3BD" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Santolina" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="552" phylum="Tracheophyta" rank="species" species="chamaecyparissus">
Santolina 
<normalizedToken id="EC369185652053B33E2203D2C8A58428" originalValue="Chamaecyparíssus" pageId="null" pageNumber="552">Chamaecyparissus</normalizedToken>
