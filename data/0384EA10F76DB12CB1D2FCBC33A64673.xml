<paragraph id="8B925B06F76DB12CB182FC5033A040AC" blockId="24.[151,1437,907,1330]" pageId="24" pageNumber="545">
CURRENT STATUS: Synonym of 
<taxonomicName id="4C2D2085F76DB12CB364FC503662408B" authority="(A. Smith, 1843)" baseAuthorityName="A. Smith" baseAuthorityYear="1843" box="[545,1115,943,969]" class="Aves" family="Cisticolidae" genus="Cisticola" higherTaxonomySource="GBIF" kingdom="Animalia" order="Passeriformes" pageId="24" pageNumber="545" phylum="Chordata" rank="subSpecies" species="natalensis" subSpecies="natalensis">
