<taxonomicName id="16ECE4E9FFACFF99FC21FA306266D2B9" authority="FRITZ, 1938, p. 91" authorityName="FRITZ" authorityPageNumber="91" authorityYear="1938" box="[898,1344,1460,1482]" class="Stenolaemata" family="Semicosciniidae" genus="Anastomopora" higherTaxonomySource="GBIF" kingdom="Animalia" order="Fenestrida" pageId="6" pageNumber="6" phylum="Bryozoa" rank="species" species="quebecensis">
