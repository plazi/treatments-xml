<paragraph id="8BD936A3FFB3FF91FF41FAB5FE74051D" blockId="1.[151,1437,1027,1593]" pageId="1" pageNumber="448">
This species is native to South America (
<collectingCountry id="F3717633FFB3FF91FD16FAB5FD7F0619" box="[656,764,1317,1341]" name="Argentina" pageId="1" pageNumber="448">Argentina</collectingCountry>
and 
<collectingCountry id="F3717633FFB3FF91FCB0FAB5FCF80619" box="[822,891,1317,1341]" name="Brazil" pageId="1" pageNumber="448">Brazil</collectingCountry>
), and has been introduced in several countries of Europe (
<collectingCountry id="F3717633FFB3FF91FF72FAD9FED20645" box="[244,337,1353,1377]" name="United Kingdom" pageId="1" pageNumber="448">England</collectingCountry>
, 
<collectingCountry id="F3717633FFB3FF91FEDBFAD9FE1F0645" box="[349,412,1353,1377]" name="Spain" pageId="1" pageNumber="448">Spain</collectingCountry>
, 
<collectingCountry id="F3717633FFB3FF91FE2FFADAFE770645" box="[425,500,1354,1377]" name="France" pageId="1" pageNumber="448">France</collectingCountry>
, 
<collectingCountry id="F3717633FFB3FF91FD86FAD9FDDC0645" box="[512,607,1353,1377]" name="Belgium" pageId="1" pageNumber="448">Belgium</collectingCountry>
, 
<collectingCountry id="F3717633FFB3FF91FDEDFAD9FD1E0645" box="[619,669,1353,1377]" name="Italy" pageId="1" pageNumber="448">Italy</collectingCountry>
, 
<collectingCountry id="F3717633FFB3FF91FD2FFAD9FD740645" box="[681,759,1353,1377]" name="Ireland" pageId="1" pageNumber="448">Ireland</collectingCountry>
, and 
<collectingCountry id="F3717633FFB3FF91FCB4FAD9FC0C0645" box="[818,911,1353,1377]" name="Portugal" pageId="1" pageNumber="448">Portugal</collectingCountry>
, including 
<collectingRegion id="49A2F841FFB3FF91FB8EFAD9FBE70645" box="[1032,1124,1353,1377]" country="Portugal" name="Madeira" pageId="1" pageNumber="448">Madeira</collectingRegion>
