<collectingCountry id="F3717633FFB3FF91FDA3FA6DFD110531" box="[549,658,1533,1557]" name="Argentina" pageId="1" pageNumber="448">Argentina</collectingCountry>
, as well as sequences from 
<collectingCountry id="F3717633FFB3FF91FC3AFA6DFC6E0531" box="[956,1005,1533,1557]" name="Italy" pageId="1" pageNumber="448">Italy</collectingCountry>
(
<bibRefCitation id="EFF74B52FFB3FF91FC7DFA6DFB330531" author="Mori, E. &amp; Magoga, G. &amp; Panella, M. &amp; Montagna, M. &amp; Winsor, L. &amp; Justine, J. &amp; Lou &amp; Menchetti, M. &amp; Schifani, E. &amp; Melone, B. &amp; Mazza, G." box="[1019,1200,1533,1557]" pageId="1" pageNumber="448" pagination="205 - 216" refId="ref3172" refString="Mori, E., Magoga, G., Panella, M., Montagna, M., Winsor, L., Justine, J. Lou, Menchetti, M., Schifani, E., Melone, B. &amp; Mazza, G. (2022) Discovering the Pandora's box: the invasion of alien flatworms in Italy. Biological Invasions, 24, 205 - 216. https: // doi. org / 10.1007 / s 10530 - 021 - 02638 - w" type="journal article" year="2022">
Mori 
