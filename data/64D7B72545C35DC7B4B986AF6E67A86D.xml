<taxonomicName id="19DFE30D2452D5419BA070EF476060A7" authorityName="A. Lemoinier, Ann. Soc. Hort. Dep. N. 13: 7" authorityYear="1841" class="Liliopsida" family="Liliaceae" genus="Lilium" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Lilium brownii" order="Liliales" pageId="0" pageNumber="29" phylum="Tracheophyta" rank="species" species="brownii">Lilium brownii</taxonomicName>
[unranked] 
<emphasis id="38E812483E92B82918D8B053BA29F744" italics="true" pageId="0" pageNumber="29">brevifolium</emphasis>
