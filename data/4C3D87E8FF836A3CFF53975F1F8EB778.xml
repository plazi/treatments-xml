<collectingRegion id="0650F81CFF836A3CFCEF94731D42B975" box="[787,834,554,583]" country="South Sudan" name="Lakes" pageId="120" pageNumber="878">See</collectingRegion>
<taxonomicName id="03944D7DFF836A3CFCB394731DDAB975" baseAuthorityName="Peters" baseAuthorityYear="1870" box="[847,986,554,583]" class="Liliopsida" family="Poaceae" genus="Lasiurus" kingdom="Plantae" order="Poales" pageId="120" pageNumber="878" phylum="Tracheophyta" rank="species" species="egregius">L. egregius</taxonomicName>
. 
<taxonomicName id="03944D7DFF836A3CFC1094731AE6B975" baseAuthorityName="Rhoads" baseAuthorityYear="1895" box="[1004,1254,554,583]" class="Liliopsida" family="Poaceae" genus="Lasiurus" kingdom="Plantae" order="Poales" pageId="120" pageNumber="878" phylum="Tracheophyta" rank="species" species="seminolus">Lasiurus seminolus</taxonomicName>
