<taxonomicName id="C0EAD9E0FF51FF1BA7ADFC37FCFFDFF0" authority="Rahmadi et al., 2010: 11 - 13" authorityName="Rahmadi et al." authorityPageNumber="11 - 13" authorityYear="2010" box="[189,825,983,1010]" class="Arachnida" family="Charinidae" genus="Sarax" kingdom="Animalia" order="Amblypygi" pageId="200" pageNumber="201" phylum="Arthropoda" rank="species" species="sangkulirangensis">
<emphasis id="359E7E71FF51FF1BA7ADFC37FE24DFF0" box="[189,482,983,1010]" italics="true" pageId="200" pageNumber="201">Sarax sangkulirangensis</emphasis>
<bibRefCitation id="637BDF92FF51FF1BA6F9FC38FCFFDFF0" author="Rahmadi C. &amp; Kojima J." box="[489,825,983,1010]" etAl="et al." firstAuthor="Rahmadi" journalOrPublisher="Journal of Arachnology" page="11 - 13" pageId="200" pageNumber="201" pagination="475 - 484" part="38" refId="ref152642" refString="Rahmadi C. &amp; Kojima J. - i. 2010. Whip spiders of the genus Sarax in the Papuan region, with description of two new species (Amblypygi: Charinidae). Journal of Arachnology 38: 475 - 484. https: // doi. org / 10.1636 / Ha 09 - 95.1" title="Whip spiders of the genus Sarax in the Papuan region, with description of two new species (Amblypygi: Charinidae)" type="journal article" year="2010">
