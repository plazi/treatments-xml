<taxonomicName id="BCEC4D286E34FFC24460E6B1826FFA15" authority="Daday, 1905" authorityName="Daday" authorityYear="1905" box="[266,569,1418,1445]" family="Dasydytidae" kingdom="Animalia" order="Chaetonotida" pageId="5" pageNumber="354" phylum="Gastrotricha" rank="family">
<emphasis id="4998EAB96E34FFC24460E6B181F4FA14" bold="true" box="[266,418,1418,1444]" pageId="5" pageNumber="354">Dasydytidae</emphasis>
Daday, 1905
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="33F665206E34FFC145C4E6918385FDE5" lastPageId="6" lastPageNumber="355" pageId="5" pageNumber="354" type="description">
<paragraph id="7B5336AB6E34FFC245C4E691827AFA74" blockId="5.[174,687,1418,1508]" box="[174,556,1449,1476]" pageId="5" pageNumber="354">
