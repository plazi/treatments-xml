<subSubSection id="2264FD1A9AA884C900BB912E22A79C1C" pageId="null" pageNumber="475" type="vernacular_names">
<paragraph id="91CE5332972223250E5B8B504A028D3E" pageId="null" pageNumber="475">Zwerg-Eberesche, Zwergmispel</paragraph>
</subSubSection>
</title>
<subSubSection id="65D0F8A76F145E43EB00836F813309AA" pageId="null" pageNumber="475" type="description">
<paragraph id="BC63CF872862641908564472E83BC133" pageId="null" pageNumber="475">
1-3 m hoher Strauch. 
<normalizedToken id="BDF2F105E3CCE890B35E1D40D45D8DA6" originalValue="Blätter" pageId="null" pageNumber="475">Blaetter</normalizedToken>
ungeteilt oval, 5-10 cm lang, etwa 2mal so lang wie breit, lederig, 
<emphasis id="D5ACAE2D09BEDAC6144D644E9D11E015" italics="true" pageId="null" pageNumber="475">
oberseits 
<normalizedToken id="9D8BC7A0707A8FECD1FB7A67BF6723A8" originalValue="dunkelgrün" pageId="null" pageNumber="475">dunkelgruen</normalizedToken>
, unterseits 
<normalizedToken id="6D890866D20FD1B894DCD9065BDE311B" originalValue="blaugrün" pageId="null" pageNumber="475">blaugruen</normalizedToken>
</emphasis>
, mit 6-8 auffallend hervortretenden Nerven, 
<emphasis id="409512467DDB4A9B5CD53EB7BC2F7E29" italics="true" pageId="null" pageNumber="475">beiderseits kahl</emphasis>
(wenigstens die 
<normalizedToken id="8D48D4432E941E2EFC7D1A441F830C84" originalValue="älteren" pageId="null" pageNumber="475">aelteren</normalizedToken>
<normalizedToken id="C37DD61B530718831381EBB085003C23" originalValue="Blätter" pageId="null" pageNumber="475">Blaetter</normalizedToken>
); 
<emphasis id="5B303DF1E51FC357914B70478DC78CFD" italics="true" pageId="null" pageNumber="475">
Rand 1fach 
<normalizedToken id="C458377F1FC9DC492025153AD8B50C7D" originalValue="gezähnt" pageId="null" pageNumber="475">gezaehnt</normalizedToken>
</emphasis>
(
<emphasis id="12992E6F01D91B94D86C5A976B87A34A" italics="true" pageId="null" pageNumber="475">
einzelne 
<normalizedToken id="F3081FCD910AF6F5429E868FD639B82F" originalValue="Blätter" pageId="null" pageNumber="475">Blaetter</normalizedToken>
doppelt 
<normalizedToken id="5561209C3D9D10B7FE3B475BBEBAA531" originalValue="gezähnt" pageId="null" pageNumber="475">gezaehnt</normalizedToken>
</emphasis>
); 
<emphasis id="35541A049C5B4F125AE3A83C6C524C33" italics="true" pageId="null" pageNumber="475">
<normalizedToken id="1BE5A5B3E9E02C4DD01A0C51BB4BB0AA" originalValue="Zähne" pageId="null" pageNumber="475">Zaehne</normalizedToken>
etwa 1 mm lang, spitz.
</emphasis>
<normalizedToken id="43F4E7516F81AC5E8794B8539AC6DC3A" originalValue="Kronblätter" pageId="null" pageNumber="475">Kronblaetter</normalizedToken>
4-5 mm lang, 
<emphasis id="C8673A2CEF3088EB1D05D26ED7C47C56" italics="true" pageId="null" pageNumber="475">rot.</emphasis>
Griffel 2. Frucht 
<normalizedToken id="E5968C7FB12790F34DC3A5B981D19721" originalValue="eiförmig" pageId="null" pageNumber="475">eifoermig</normalizedToken>
, rot oder braunrot. - 
<normalizedToken id="22E94BF5AB4DED7B91CC651EA6D26E38" originalValue="Blüte" pageId="null" pageNumber="475">Bluete</normalizedToken>
: 
<normalizedToken id="2CD0D9497F96F8FC7EEA9F9A7CF0262A" originalValue="Später" pageId="null" pageNumber="475">Spaeter</normalizedToken>
<normalizedToken id="427D9320BBCC9B8E660E162E529711AF" originalValue="Frühling" pageId="null" pageNumber="475">Fruehling</normalizedToken>
und 
<normalizedToken id="5E0CAA92DA8BA9E7D21FA9FEC6008FFB" originalValue="früher" pageId="null" pageNumber="475">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="A9061DE5025799BB6EDAA752D6D245B5" pageId="null" pageNumber="475">
<emphasis id="6261687E651AFA216572C88D5DB01863" italics="true" pageId="null" pageNumber="475">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="1672B1116F7682F26C12EA5456E0BC69" italics="true" pageId="null" pageNumber="475">34:</emphasis>
Material aus den Alpen; sexuell normale Fortpflanzung. 
<emphasis id="EC6B8177ACA93A539C849067364AD5DE" italics="true" pageId="null" pageNumber="475">2n</emphasis>
= 
<emphasis id="D8665DDA60FC23E0A57808E92C88A4D5" italics="true" pageId="null" pageNumber="475">51:</emphasis>
Material aus den Nordalpen (Schweiz, Deutschland, 
<normalizedToken id="B40BE30761FE29231152322ADDC8F5E2" originalValue="Österreich" pageId="null" pageNumber="475">Oesterreich</normalizedToken>
); apomiktische Fortpflanzung; Sippe autotriploid (Liljefors 1953Liljefors 1955).
</paragraph>
<paragraph id="9B596E10A0F76F512C6FA5218CA597F8" pageId="null" pageNumber="475">
<emphasis id="6E20B1A6315F1A7A8C364D1F244DE8E9" italics="true" pageId="null" pageNumber="475">Standort.</emphasis>
Subalpin. Kalkhaltige, trockene 
<normalizedToken id="022C07BA523F929B577D4388DE99221A" originalValue="Böden" pageId="null" pageNumber="475">Boeden</normalizedToken>
. 
<normalizedToken id="6539C06326CBBB4F38131C807BDDEF49" originalValue="Föhrenwälder" pageId="null" pageNumber="475">Foehrenwaelder</normalizedToken>
, seltener 
<normalizedToken id="892E290F579833044C6CAFE0239E8161" originalValue="Arvenwälder" pageId="null" pageNumber="475">Arvenwaelder</normalizedToken>
und 
<normalizedToken id="D8328973CB419AF187C1CFEA0E7ABFC8" originalValue="Zwergstrauch-bestände" pageId="null" pageNumber="475">Zwergstrauch-bestaende</normalizedToken>
.
</paragraph>
<paragraph id="799ADDD902601D35AE324D830AE672A5" pageId="null" pageNumber="475">
<emphasis id="83CBA8A3681FE2DC81A61FF3C79040F6" italics="true" pageId="null" pageNumber="475">
Verbreitung. Mittel- und 
<normalizedToken id="F284CF3B15DDEFAEC383846B8F8E2590" originalValue="südeuropäische" pageId="null" pageNumber="475">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
<normalizedToken id="FC3118B21D95E60D66806FDECDAC8E4D" originalValue="Pyrenäen" pageId="null" pageNumber="475">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="4C3D8ED96C15893DAB18BBDB3D6AB101" originalValue="zentralfranzösische" pageId="null" pageNumber="475">zentralfranzoesische</normalizedToken>
Gebirge, Alpen, Jura, Vogesen, Schwarzwald, Sudeten, Karpaten, 
<normalizedToken id="BB7CB489B92870DCE86F0D7D2999C211" originalValue="nördlicher" pageId="null" pageNumber="475">noerdlicher</normalizedToken>
Apennin, Gebirge der Balkanhalbinsel. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: Alpen (in den Silikatgebieten sehr selten), 
<normalizedToken id="5B2B3E65C93F447672AF93AC799FA0AA" originalValue="südlicher" pageId="null" pageNumber="475">suedlicher</normalizedToken>
und mittlerer Hochjura, Vogesen, Schwarzwald (Feldberg).
</paragraph>
<paragraph id="0A1FBD5A794C025A6726602B97C03CFB" pageId="null" pageNumber="475">
<emphasis id="57157490AAC7493925B54D406C1374FF" italics="true" pageId="null" pageNumber="475">Bemerkungen.</emphasis>
Nach Liljefors (1953) sind di- und triploide Sippen am Herbarmaterial nicht zu unterscheiden; auch sonst werden keine Unterschiede angegeben.
</paragraph>
</subSubSection>
