<taxonomicName id="4C5276DE0944B21AE863F9DA24DD4C09" authorityName="Krupp" authorityYear="1988" box="[1121,1238,1542,1568]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="16" pageNumber="467" phylum="Chordata" rank="species" species="gallagheri">
