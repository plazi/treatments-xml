<paragraph id="8BED0D5D0944B21AEC95F9DA22F14C6D" blockId="16.[151,1437,1542,2036]" pageId="16" pageNumber="467">
<emphasis id="B926D14F0944B21AEC95F9DA21294C09" bold="true" box="[151,290,1542,1568]" pageId="16" pageNumber="467">Etymology:</emphasis>
<taxonomicName id="4C5276DE0944B21AED28F9DA217B4C09" authorityName="Hamilton" authorityYear="1822" box="[298,368,1542,1568]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="16" pageNumber="467" phylum="Chordata" rank="genus">
<emphasis id="B926D14F0944B21AED28F9DA217B4C09" box="[298,368,1542,1568]" italics="true" pageId="16" pageNumber="467">Garra</emphasis>
</taxonomicName>
