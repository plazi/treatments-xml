<taxonomicName id="43E724CBFFED015166BBF36E90DC8887" authorityName="Bezděk" authorityYear="2019" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="15" pageNumber="38" phylum="Arthropoda" rank="species" species="medvedevi" status="nom. nov.">
