<emphasis id="B693835AFFED01516633F30E96178807" box="[1281,1382,782,805]" italics="true" pageId="15" pageNumber="38">Acroxena</emphasis>
</taxonomicName>
with 
<taxonomicName id="43E724CBFFED0151600EF32E90C28867" authorityName="Thunberg" authorityYear="1814" box="[828,947,814,837]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="15" pageNumber="38" phylum="Arthropoda" rank="genus">
