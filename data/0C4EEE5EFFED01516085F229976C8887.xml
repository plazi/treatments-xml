<taxonomicName id="43E724CBFFED015160F2F32E962B8867" authority="Medvedev, 1992" authorityName="Medvedev" authorityYear="1992" box="[960,1370,814,837]" class="Insecta" family="Chrysomelidae" genus="Acroxena" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="15" pageNumber="38" phylum="Arthropoda" rank="species" species="nigricornis">
<emphasis id="B693835AFFED015160F2F32E97D28867" box="[960,1187,814,837]" italics="true" pageId="15" pageNumber="38">Acroxena nigricornis</emphasis>
<bibRefCitation id="E07622B9FFED0151679BF32E962B8867" author="MEDVEDEV L. N." bookContentInfo="264 pp." box="[1193,1370,814,837]" editor="MEDVEDEV L. N." firstAuthor="Medvedev" journalOrPublisher="Nauka, Moskva" pageId="15" pageNumber="38" pagination="71 - 77" refId="ref32180" refString="MEDVEDEV L. N. 1992: Novye i maloizvestnye vidy listoedov (Coleoptera, Chrysomelidae) s ostrovov Vietnamskogo poberezhiya. (New and little-known chrysomelid species (Coleoptera, Chrysomelidae) from Vietnamese coastal islands). Pp. 71 - 77. In: MEDVEDEV L. N. (ed.): Sistematika i ekologiya nasekomykh Vietnama. (Systematization [sic!] and ecology of insects of Vietnam). Nauka, Moskva, 264 pp." title="Novye i maloizvestnye vidy listoedov (Coleoptera, Chrysomelidae) s ostrovov Vietnamskogo poberezhiya. (New and little-known chrysomelid species (Coleoptera, Chrysomelidae) from Vietnamese coastal islands)." type="book chapter" volumeTitle="Sistematika i ekologiya nasekomykh Vietnama. (Systematization [sic!] and ecology of insects of Vietnam)" year="1992">Medvedev, 1992</bibRefCitation>
