<taxonomicName id="43E724CBFFED015167F6F34E900B88A7" authority="(Baly, 1864)" baseAuthorityName="Baly" baseAuthorityYear="1864" class="Insecta" family="Chrysomelidae" genus="Acroxena" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="15" pageNumber="38" phylum="Arthropoda" rank="species" species="nigricornis">
<emphasis id="B693835AFFED015167F6F34E97A28847" box="[1220,1235,846,869]" italics="true" pageId="15" pageNumber="38">T</emphasis>
. 
<emphasis id="B693835AFFED015167D2F34E96268847" box="[1248,1367,846,869]" italics="true" pageId="15" pageNumber="38">nigricornis</emphasis>
(
<bibRefCitation id="E07622B9FFED01516656F34E900288A7" author="BALY J. S." firstAuthor="Baly" journalOrPublisher="Transactions of the Entomological Society London" pageId="15" pageNumber="38" pagination="223 - 243" part="2" refId="ref30277" refString="BALY J. S. 1864: Descriptions of uncharacterized genera and species of Phytophaga. Transactions of the Entomological Society London, 3 rd Series 2: 223 - 243." title="Descriptions of uncharacterized genera and species of Phytophaga" type="journal article" year="1864">Baly, 1864</bibRefCitation>
