<paragraph id="15CE58DABD985811360B3FB82B92E36B" pageId="null" pageNumber="545">
Bunte 
<taxonomicName id="943DDCEAC2AD8E64ED75A60B87D81FD9" class="Magnoliopsida" family="Asteraceae" genus="Aster" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="545" phylum="Tracheophyta" rank="genus">Aster</taxonomicName>
