<subSubSection id="2DFB784253A98234520033966C8ABAA6" pageId="null" pageNumber="767" type="description">
<paragraph id="3E81592A51D8655F4C91AC48B335A424" pageId="null" pageNumber="767">
<normalizedToken id="0720F18ECA3ED2F74F51E77424330253" originalValue="Bäume" pageId="null" pageNumber="767">Baeume</normalizedToken>
, 
<normalizedToken id="AB937069AAE15F590ED31268AF6803D6" originalValue="Sträucher" pageId="null" pageNumber="767">Straeucher</normalizedToken>
oder ausdauernde 
<normalizedToken id="BBD9E5744995B1842F7B635AE1807D59" originalValue="Kräuter" pageId="null" pageNumber="767">Kraeuter</normalizedToken>
. 
<normalizedToken id="BE4810BDCC9EDCA3CE77D8E0BC8356B5" originalValue="Blätter" pageId="null" pageNumber="767">Blaetter</normalizedToken>
<normalizedToken id="0104045E59430F54DBE0A5D4DD6DAFB9" originalValue="wechselständig" pageId="null" pageNumber="767">wechselstaendig</normalizedToken>
, ganzrandig, ohne 
<normalizedToken id="7628087852D0EAA7960D59D426EAFBC2" originalValue="Nebenblätter" pageId="null" pageNumber="767">Nebenblaetter</normalizedToken>
. 
<normalizedToken id="A16F53C909CA5EF6AD5ADCFA52976360" originalValue="Blüten" pageId="null" pageNumber="767">Blueten</normalizedToken>
zwitterig, in traubigen, 
<normalizedToken id="09295585B841C11E76FAE379DB5893A7" originalValue="endständigen" pageId="null" pageNumber="767">endstaendigen</normalizedToken>
oder end- und 
<normalizedToken id="2FB67F608D81E6BE1C98942BACA4C2F4" originalValue="seitenständigen" pageId="null" pageNumber="767">seitenstaendigen</normalizedToken>
<normalizedToken id="D5EAB8CED89E7C69E5CCBB4BE3DF1B3F" originalValue="Blütenständen" pageId="null" pageNumber="767">Bluetenstaenden</normalizedToken>
. 
<normalizedToken id="2A0DE6FD168D750D8FB908ECBA14EA50" originalValue="Perigonblätter" pageId="null" pageNumber="767">Perigonblaetter</normalizedToken>
5, frei, 
<emphasis id="92573F0FC5D265F1264F88D85DBCF058" italics="true" pageId="null" pageNumber="767">
bunt 
<normalizedToken id="F5116A8A66EDDF09FA10B7EE1D55E5D6" originalValue="gefärbt" pageId="null" pageNumber="767">gefaerbt</normalizedToken>
.
</emphasis>
<normalizedToken id="BBD1E00EFE0753891C4D5938C4F7D9C5" originalValue="Staubblätter" pageId="null" pageNumber="767">Staubblaetter</normalizedToken>
5-30. 
<normalizedToken id="527534C9BF9FF2EA432C73367A33597A" originalValue="Fruchtblätter" pageId="null" pageNumber="767">Fruchtblaetter</normalizedToken>
<normalizedToken id="8DBC95314F29E6DA160CAC2BB2DF6BAD" originalValue="ringförmig" pageId="null" pageNumber="767">ringfoermig</normalizedToken>
angeordnet, jedes Fruchtblatt mit 1 Griffel. 
<emphasis id="38B905FF1BD4C6BFAA0092671C9F4897" italics="true" pageId="null" pageNumber="767">Frucht eine 5</emphasis>
- 
<emphasis id="0384887BF50AB5CA65753BD26C556120" italics="true" pageId="null" pageNumber="767">
12 
<normalizedToken id="30C6BF83E53A8CBF994F0E3415C0B783" originalValue="fächerige" pageId="null" pageNumber="767">faecherige</normalizedToken>
Beere; in jedem Fach mit 1 Samen.
</emphasis>
</paragraph>
<paragraph id="AB203CEFBF16A4F0DCF97011DCEFC3EC" pageId="null" pageNumber="767">
Die Gattung 
<taxonomicName id="9E8531308E585616A24797F40C611FEA" class="Magnoliopsida" family="Phytolaccaceae" genus="Phytolacca" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="767" phylum="Tracheophyta" rank="genus">
<emphasis id="4CFBD1544A9CFD018521AE99DBE9FBC0" italics="true" pageId="null" pageNumber="767">Phytolacca</emphasis>
</taxonomicName>
<normalizedToken id="996869C0C0056D40924CFE573DB0F0F0" originalValue="umfaßt" pageId="null" pageNumber="767">umfasst</normalizedToken>
etwa 
<emphasis id="AE59BE5E9EA6044E1FD8F892D7F21D87" italics="true" pageId="null" pageNumber="767">35 Arten</emphasis>
, die in den 
<emphasis id="39E70B0106E930DDD8FC70476B4F940D" italics="true" pageId="null" pageNumber="767">Tropen und Subtropen der ganzen Welt verbreitet</emphasis>
sind. In Mitteleuropa nur 
<taxonomicName id="F32FB13BB66C253E4E6986E246C61410" class="Liliopsida" family="Asparagaceae" genus="Agave" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="767" phylum="Tracheophyta" rank="species" species="americana">
<emphasis id="80F462F82E169814B3656EE6B3BDAFBB" italics="true" pageId="null" pageNumber="767">Ph. americana</emphasis>
</taxonomicName>
als verwilderte Nutzpflanze.
</paragraph>
</subSubSection>
