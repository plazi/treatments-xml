<subSubSection id="C3246572FF8DC922FF62FD5CFB8DFC9E" pageId="44" pageNumber="45" type="diagnosis">
<paragraph id="8B8136F9FF8DC922FF62FD5CFB8DFC9E" blockId="44.[151,1437,618,862]" pageId="44" pageNumber="45">
<emphasis id="B94AEAEBFF8DC922FF62FD5CFECCFD33" bold="true" box="[199,322,726,752]" pageId="44" pageNumber="45">Diagnosis.</emphasis>
Males of 
<taxonomicName id="4C3E4D7AFF8DC922FE15FD5DFD8DFD33" authority="Rheims &amp; Jäger, 2022" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[432,515,727,752]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="44" pageNumber="45" phylum="Arthropoda" rank="species" species="guri" status="spec. nov.">
<emphasis id="B94AEAEBFF8DC922FE15FD5DFD8DFD33" box="[432,515,727,752]" italics="true" pageId="44" pageNumber="45">M. guri</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFF8DC922FDACFD5DFDF5FD32" bold="true" box="[521,635,727,753]" pageId="44" pageNumber="45">
<taxonomicNameLabel id="A2795790FF8DC922FDACFD5DFDF5FD32" box="[521,635,727,753]" pageId="44" pageNumber="45" rank="species">spec. nov.</taxonomicNameLabel>
</emphasis>
resemble those of 
<taxonomicName id="4C3E4D7AFF8DC922FCEEFD5DFC34FD33" authority="Rheims &amp; Jäger, 2022" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[843,954,727,752]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="44" pageNumber="45" phylum="Arthropoda" rank="species" species="jaraua" status="spec. nov.">
<emphasis id="B94AEAEBFF8DC922FCEEFD5DFC34FD33" box="[843,954,727,752]" italics="true" pageId="44" pageNumber="45">M. jaraua</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFF8DC922FC65FD5DFBBCFD32" bold="true" box="[960,1074,727,753]" pageId="44" pageNumber="45">
<taxonomicNameLabel id="A2795790FF8DC922FC65FD5DFBBCFD32" box="[960,1074,727,753]" pageId="44" pageNumber="45" rank="species">spec. nov.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13052A7CFF8DC922FBE5FD5DFB55FD31" box="[1088,1243,727,754]" captionStart="FIGURES 169–172" captionStartId="46.[151,264,1537,1561]" captionTargetBox="[162,1426,604,1505]" captionTargetId="figure-229@46.[152,1435,597,1513]" captionTargetPageId="46" captionText="FIGURES 169–172. Meri jaraua spec. nov., male (IBSP 165050, paratype), left palp (169 prolateral, 170 ventral, 171 retrolateral, 172 detail of embolus). C—conductor; E—embolus; mr—membranous region; PTA—prolateral tibial apophysis; RTA—retrolateral tibial apophysis; ST—subtegulum. Scale lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6550317" httpUri="https://zenodo.org/record/6550317/files/figure.png" pageId="44" pageNumber="45">Figs 169–172</figureCitation>
) by the palp with tegulum strongly indented prolaterally and embolus C-shaped with long membranous region (
<figureCitation id="13052A7CFF8DC922FB14FD71FADEFCD6" box="[1201,1360,762,789]" captionStart="FIGURES 162–165" captionStartId="44.[151,264,1752,1776]" captionTargetBox="[176,1410,892,1728]" captionTargetId="figure-263@44.[166,1421,885,1728]" captionTargetPageId="44" captionText="FIGURES 162–165. Meri guri spec. nov., male (AMNH), left palp (162 prolateral, 163 ventral, 164 retrolateral, 165 detail of embolus). C—conductor; E—embolus; mr—membranous region; PTA—prolateral tibial projection; RpP—retro proximal projection; RTA—retrolateral tibial projection; ST—subtegulum. Scale lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6550311" httpUri="https://zenodo.org/record/6550311/files/figure.png" pageId="44" pageNumber="45">Figs 163, 165</figureCitation>
). They are distinguished from the latter species by the RTA with rounded base abruptly narrowed medially towards tip (
<figureCitation id="13052A7CFF8DC922FACAFC95FF4CFC9D" captionStart="FIGURES 162–165" captionStartId="44.[151,264,1752,1776]" captionTargetBox="[176,1410,892,1728]" captionTargetId="figure-263@44.[166,1421,885,1728]" captionTargetPageId="44" captionText="FIGURES 162–165. Meri guri spec. nov., male (AMNH), left palp (162 prolateral, 163 ventral, 164 retrolateral, 165 detail of embolus). C—conductor; E—embolus; mr—membranous region; PTA—prolateral tibial projection; RpP—retro proximal projection; RTA—retrolateral tibial projection; ST—subtegulum. Scale lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6550311" httpUri="https://zenodo.org/record/6550311/files/figure.png" pageId="44" pageNumber="45">Fig. 164</figureCitation>
) (RTA gradually tapering in 
<taxonomicName id="4C3E4D7AFF8DC922FDA0FCC9FDFBFC9F" authority="Rheims &amp; Jäger, 2022" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[517,629,835,860]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="44" pageNumber="45" phylum="Arthropoda" rank="species" species="jaraua" status="spec. nov.">
<emphasis id="B94AEAEBFF8DC922FDA0FCC9FDFBFC9F" box="[517,629,835,860]" italics="true" pageId="44" pageNumber="45">M. jaraua</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFF8DC922FDD9FCC9FD60FC9E" bold="true" box="[636,750,835,861]" pageId="44" pageNumber="45">
<taxonomicNameLabel id="A2795790FF8DC922FDD9FCC9FD60FC9E" box="[636,750,835,861]" pageId="44" pageNumber="45" rank="species">spec. nov.</taxonomicNameLabel>
</emphasis>
). Females are unknown.
</paragraph>
</subSubSection>
