<figureCitation id="13052A7CFF8CC923FD5EFEADFCD3FE81" box="[763,861,295,322]" captionStart="FIGURES 315–318" captionStartId="76.[151,264,1371,1395]" captionTargetBox="[156,1431,489,1348]" captionTargetId="figure-159@76.[156,1431,489,1348]" captionTargetPageId="76" captionText="FIGURES 315–318. Distribution maps for species of Meri gen. nov. 315 (M. martinique spec. nov., M. sanctivincenti (Simon) comb. nov., M. trinitatis (Strand) comb. nov., M. carabobo spec. nov., M. kaieteur spec. nov.); 316 (M. jaraua spec. nov., M. arraijan spec. nov., M. formosus (Banks) comb. nov., M. guri spec. nov., M. tumatumari spec. nov.); 317 (M. zeteki spec. nov., M. manaos spec. nov., M. yaciba spec. nov., M. tapirapeco spec. nov., M. abuna spec. nov.); 318 (M. mathani (Simon) comb. nov., M. pictitarsis (Simon) comb. nov., M. conduri spec. nov., M. paiaia spec. nov., M. tambor spec. nov.);" figureDoi="http://doi.org/10.5281/zenodo.6550426" httpUri="https://zenodo.org/record/6550426/files/figure.png" pageId="45" pageNumber="46">Fig. 316</figureCitation>
