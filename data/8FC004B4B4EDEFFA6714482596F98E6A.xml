<subSubSection id="7CBA4BCD12695E3F794779584306CF15" pageId="null" pageNumber="468" type="vernacular_names">
<paragraph id="AB3BF77FE5A7C1FE1A154DF3904BBC18" pageId="null" pageNumber="468">Alpenlattich</paragraph>
</subSubSection>
</title>
<subSubSection id="C5275C632AFAFAC8A025D1A058B7E8ED" pageId="null" pageNumber="468" type="description">
<paragraph id="00A8DF2434BDEE9E916989E43A861836" pageId="null" pageNumber="468">
Ausdauernd, mit kriechendem Rhizom. 
<emphasis id="36C3F138FFF693ED4C52507B69D6F7E8" italics="true" pageId="null" pageNumber="468">
<normalizedToken id="1F5A39D4A135AA58D589CF004CDDA9CB" originalValue="Grundständige" pageId="null" pageNumber="468">Grundstaendige</normalizedToken>
<normalizedToken id="0DD171D042E0A1AC71635003F3E57E5C" originalValue="Blätter" pageId="null" pageNumber="468">Blaetter</normalizedToken>
klein, rundlich bis 
<normalizedToken id="485A36FC79DF2966979B9248479D5183" originalValue="nierenförmig" pageId="null" pageNumber="468">nierenfoermig</normalizedToken>
, 
<normalizedToken id="A6EE4DE99AE7FF80571E6135C19B9916" originalValue="gezähnt" pageId="null" pageNumber="468">gezaehnt</normalizedToken>
, gestielt.
</emphasis>
Stengel aufrecht, mit wenigen kleinen, 
<emphasis id="E288033307E0F97C6EEB53B764329D18" italics="true" pageId="null" pageNumber="468">
<normalizedToken id="E0219FB6221BEED93857390E6FE9821D" originalValue="schuppenförmigen" pageId="null" pageNumber="468">schuppenfoermigen</normalizedToken>
<normalizedToken id="4E7F2D4DAB532066FE4069570636C65B" originalValue="Blättern" pageId="null" pageNumber="468">Blaettern</normalizedToken>
und 1 
<normalizedToken id="20DF1C03E4BCF42483F465CC8256923C" originalValue="Blütenkopf" pageId="null" pageNumber="468">Bluetenkopf</normalizedToken>
. 
<normalizedToken id="CBFBB1CFA88361AE4DDDF2F5D254C583" originalValue="Hülle" pageId="null" pageNumber="468">Huelle</normalizedToken>
zylindrisch, aus 1 Reihe etwa gleich langer
</emphasis>
, 
<normalizedToken id="AE0891400F9D374FB5311D5D83ABFA55" originalValue="±" pageId="null" pageNumber="468">+/-</normalizedToken>
<emphasis id="B5A60DC7F2B57443EF3E677C8802CFBC" italics="true" pageId="null" pageNumber="468">
stumpfer 
<normalizedToken id="2ED27667BA9A50CFF80EB5E5EFFAAD6F" originalValue="Hüllblätter" pageId="null" pageNumber="468">Huellblaetter</normalizedToken>
bestehend
</emphasis>
, nach dem Abfallen der 
<normalizedToken id="9864FA0A81893122BF7D6CF2FB0EDAF9" originalValue="Früchte" pageId="null" pageNumber="468">Fruechte</normalizedToken>
<normalizedToken id="87A94ACB7C20AC320EF79971E4F2348D" originalValue="zurückgebogen" pageId="null" pageNumber="468">zurueckgebogen</normalizedToken>
, 
<normalizedToken id="EB0DAFD6FDED04085D7BEC1CC9FE0011" originalValue="außen" pageId="null" pageNumber="468">aussen</normalizedToken>
gelegentlich von kleinen, 
<normalizedToken id="7006C7D032CDE92D2E9FC5CCD589654B" originalValue="schuppenförmigen" pageId="null" pageNumber="468">schuppenfoermigen</normalizedToken>
<normalizedToken id="6B9AD7D5D3A62726A8AD90C2AE45D41A" originalValue="Stengelblättern" pageId="null" pageNumber="468">Stengelblaettern</normalizedToken>
umgeben. Boden des 
<normalizedToken id="6839257EB220E436C50D2972BDFE343B" originalValue="Blütenkopfes" pageId="null" pageNumber="468">Bluetenkopfes</normalizedToken>
ohne 
<normalizedToken id="66CC8487F46B72D6DDA7279C834F1206" originalValue="Spreublätter" pageId="null" pageNumber="468">Spreublaetter</normalizedToken>
und ohne Haare. 
<emphasis id="F426F2FD3F3E4F9760E06EB4952A1C09" italics="true" pageId="null" pageNumber="468">
<normalizedToken id="6F42D911D994CA5A255B8ADB61562D8E" originalValue="Blüten" pageId="null" pageNumber="468">Blueten</normalizedToken>
alle 
<normalizedToken id="3FF543F60AD106142DC105EEF826D25E" originalValue="röhrenförmig" pageId="null" pageNumber="468">roehrenfoermig</normalizedToken>
</emphasis>
, die 
<normalizedToken id="49013D6A91606E98AC060E61691DA855" originalValue="randständigen" pageId="null" pageNumber="468">randstaendigen</normalizedToken>
nur ♀. Staubbeutel am Grunde spitz. 
<normalizedToken id="93B633D014EE8004BB147FF74D474390" originalValue="Früchte" pageId="null" pageNumber="468">Fruechte</normalizedToken>
zylindrisch, kahl, mit 
<normalizedToken id="0E7A40F4E4CBBFDF94D29C931D6C4258" originalValue="weißem" pageId="null" pageNumber="468">weissem</normalizedToken>
<normalizedToken id="3B00FFE1281F13FD01D2899EDB6D0E0A" originalValue="gezähntem" pageId="null" pageNumber="468">gezaehntem</normalizedToken>
Rand (Pappusansatzstelle). 
<taxonomicName id="D3F78C72E2FA37B15F36F4D3676E5E9C" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="468" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
aus mehreren Reihen rauher Borsten bestehend.
</paragraph>
<paragraph id="C578396FD870EBF9DE9B195D92A4F685" pageId="null" pageNumber="468">
Die Gattung 
<taxonomicName id="4E8684675F3BA38B92FCBCA2A2DC3526" class="Magnoliopsida" family="Asteraceae" genus="Homogyne" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="468" phylum="Tracheophyta" rank="genus">
<emphasis id="C557D0A4B3A2D80774FDA027831D0DFB" italics="true" pageId="null" pageNumber="468">Homogyne</emphasis>
</taxonomicName>
<normalizedToken id="43517CD72E9AE9B4C802545D4EFDAB30" originalValue="umfaßt" pageId="null" pageNumber="468">umfasst</normalizedToken>
<emphasis id="70DBF9640F61677C30F24E593F798261" italics="true" pageId="null" pageNumber="468">3 Arten</emphasis>
und ist auf 
<emphasis id="C4729F6C3207E1175EB0A0A8417EEAA6" italics="true" pageId="null" pageNumber="468">
mittel- und 
<normalizedToken id="CBB42AFC229DF1A55B88BDD9A7665329" originalValue="südeuropäische" pageId="null" pageNumber="468">suedeuropaeische</normalizedToken>
Gebirge
</emphasis>
<normalizedToken id="8034E4FD7A1205127E213972781711EA" originalValue="beschränkt" pageId="null" pageNumber="468">beschraenkt</normalizedToken>
.
</paragraph>
</subSubSection>
</treatment>
