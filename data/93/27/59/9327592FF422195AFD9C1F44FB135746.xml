<heading bold="true" box="[227,431,912,938]" fontSize="11" level="3" pageId="8" pageNumber="75" reason="3">
<emphasis bold="true" box="[227,431,912,938]" pageId="8" pageNumber="75">Included species</emphasis>
</heading>
</paragraph>
<paragraph blockId="8.[227,1436,958,1055]" pageId="8" pageNumber="75">
<taxonomicName authority="Korn &amp; Bockwinkel, 2022" authorityName="Korn &amp; Bockwinkel" authorityYear="2022" box="[227,570,958,984]" class="Cephalopoda" family="Trigonoceratidae" genus="Stroborineceras" higherTaxonomySource="GBIF" kingdom="Animalia" order="Nautilida" pageId="8" pageNumber="75" phylum="Mollusca" rank="species" species="insalahensis" status="gen. et sp. nov.">
<emphasis box="[227,570,958,984]" italics="true" pageId="8" pageNumber="75">Stroborineceras insalahensis</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[580,766,959,985]" pageId="8" pageNumber="75" rank="species">gen. et sp. nov.</taxonomicNameLabel>
, 
<collectingCountry box="[779,871,958,984]" name="Algeria" pageId="8" pageNumber="75">Algeria</collectingCountry>
; 
<taxonomicName authority="Korn &amp; Bockwinkel, 2022" authorityName="Korn &amp; Bockwinkel" authorityYear="2022" box="[885,1132,958,984]" class="Cephalopoda" family="Trigonoceratidae" genus="Stroborineceras" higherTaxonomySource="GBIF" kingdom="Animalia" order="Nautilida" pageId="8" pageNumber="75" phylum="Mollusca" rank="species" species="felis" status="gen. et sp. nov.">
<emphasis box="[885,1132,958,984]" italics="true" pageId="8" pageNumber="75">Stroborineceras felis</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[1141,1327,959,985]" pageId="8" pageNumber="75" rank="species">gen. et sp. nov.</taxonomicNameLabel>
, 
<collectingCountry box="[1340,1432,958,984]" name="Algeria" pageId="8" pageNumber="75">Algeria</collectingCountry>
; and questionably 
<taxonomicName authority="Meekianus Winchell, 1862" authorityName="Meekianus Winchell" authorityYear="1862" box="[456,1121,993,1020]" class="Cephalopoda" family="Nautilidae" genus="Nautilus" kingdom="Animalia" order="Nautilida" pageId="8" pageNumber="75" phylum="Mollusca" rank="subGenus" subGenus="Trematodiscus">
<emphasis box="[456,555,993,1019]" italics="true" pageId="8" pageNumber="75">Nautilus</emphasis>
(
<emphasis box="[584,754,993,1019]" italics="true" pageId="8" pageNumber="75">Trematodiscus</emphasis>
) 
<emphasis box="[783,910,993,1019]" italics="true" pageId="8" pageNumber="75">Meekianus</emphasis>
Winchell, 1862
</taxonomicName>
, Michigan and 
<taxonomicName authority="Winchell, 1862" authorityName="Winchell" authorityYear="1862" class="Cephalopoda" family="Nautilidae" genus="Nautilus" kingdom="Animalia" order="Nautilida" pageId="8" pageNumber="75" phylum="Mollusca" rank="species" species="strigatus" subGenus="Trematodiscus">
<emphasis box="[1337,1436,993,1019]" italics="true" pageId="8" pageNumber="75">Nautilus</emphasis>
(
<emphasis box="[237,407,1028,1054]" italics="true" pageId="8" pageNumber="75">Trematodiscus</emphasis>
) 
<emphasis box="[424,527,1029,1054]" italics="true" pageId="8" pageNumber="75">strigatus</emphasis>
Winchell, 1862
</taxonomicName>
