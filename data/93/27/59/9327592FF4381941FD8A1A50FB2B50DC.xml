<subSubSection pageId="18" pageNumber="85" type="diagnosis">
<paragraph blockId="18.[227,348,1260,1286]" box="[227,348,1260,1286]" pageId="18" pageNumber="85">
<heading bold="true" box="[227,348,1260,1286]" fontSize="11" level="3" pageId="18" pageNumber="85" reason="3">
