<paragraph blockId="12.[227,1437,654,786]" pageId="12" pageNumber="79">
<taxonomicName authority="Korn &amp; Bockwinkel, 2022" authorityName="Korn &amp; Bockwinkel" authorityYear="2022" box="[227,472,654,680]" class="Cephalopoda" family="Trigonoceratidae" genus="Stroborineceras" higherTaxonomySource="GBIF" kingdom="Animalia" order="Nautilida" pageId="12" pageNumber="79" phylum="Mollusca" rank="species" species="felis" status="gen. et sp. nov.">
