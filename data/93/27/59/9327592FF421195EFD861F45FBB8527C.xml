<taxonomicName authority="Korn &amp; Bockwinkel, 2022" authorityName="Korn &amp; Bockwinkel" authorityYear="2022" box="[816,993,654,680]" class="Cephalopoda" family="Trigonoceratidae" genus="Stroborineceras" higherTaxonomySource="GBIF" kingdom="Animalia" order="Nautilida" pageId="12" pageNumber="79" phylum="Mollusca" rank="species" species="insalahensis" status="gen. et sp. nov.">
S. 
<emphasis box="[848,993,654,680]" italics="true" pageId="12" pageNumber="79">insalahensis</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[1001,1179,655,681]" pageId="12" pageNumber="79" rank="species">gen. et sp. nov.</taxonomicNameLabel>
by the less depressed whorl profile (ww/wh ~ 
<quantity box="[516,600,689,716]" metricMagnitude="-2" metricUnit="m" metricValue="3.175" pageId="12" pageNumber="79" unit="in" value="1.25">1.25 in</quantity>
<taxonomicName authority="Korn &amp; Bockwinkel, 2022" authorityName="Korn &amp; Bockwinkel" authorityYear="2022" box="[609,690,689,716]" class="Cephalopoda" family="Trigonoceratidae" genus="Stroborineceras" higherTaxonomySource="GBIF" kingdom="Animalia" order="Nautilida" pageId="12" pageNumber="79" phylum="Mollusca" rank="species" species="felis" status="gen. et sp. nov.">
<emphasis box="[609,690,689,716]" italics="true" pageId="12" pageNumber="79">S. felis</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[699,882,690,716]" pageId="12" pageNumber="79" rank="species">gen. et sp. nov.</taxonomicNameLabel>
but ~ 
<quantity box="[958,1041,689,716]" metricMagnitude="-2" metricUnit="m" metricValue="3.937" pageId="12" pageNumber="79" unit="in" value="1.55">1.55 in</quantity>
<taxonomicName authority="Korn &amp; Bockwinkel, 2022" authorityName="Korn &amp; Bockwinkel" authorityYear="2022" box="[1051,1227,689,716]" class="Cephalopoda" family="Trigonoceratidae" genus="Stroborineceras" higherTaxonomySource="GBIF" kingdom="Animalia" order="Nautilida" pageId="12" pageNumber="79" phylum="Mollusca" rank="species" species="insalahensis" status="gen. et sp. nov.">
<emphasis box="[1051,1227,689,716]" italics="true" pageId="12" pageNumber="79">S. insalahensis</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[1237,1420,690,716]" pageId="12" pageNumber="79" rank="species">gen. et sp. nov.</taxonomicNameLabel>
), by the concave venter (flattened or weakly convex in 
<taxonomicName authority="Korn &amp; Bockwinkel, 2022" authorityName="Korn &amp; Bockwinkel" authorityYear="2022" box="[867,946,724,751]" class="Cephalopoda" family="Trigonoceratidae" genus="Stroborineceras" higherTaxonomySource="GBIF" kingdom="Animalia" order="Nautilida" pageId="12" pageNumber="79" phylum="Mollusca" rank="species" species="felis" status="gen. et sp. nov.">
<emphasis box="[867,946,724,751]" italics="true" pageId="12" pageNumber="79">S. felis</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[955,1135,725,751]" pageId="12" pageNumber="79" rank="species">gen. et sp. nov.</taxonomicNameLabel>
) and by the considerably weaker spiral lines (coarse and sharp in 
<taxonomicName authority="Korn &amp; Bockwinkel, 2022" authorityName="Korn &amp; Bockwinkel" authorityYear="2022" box="[697,871,760,786]" class="Cephalopoda" family="Trigonoceratidae" genus="Stroborineceras" higherTaxonomySource="GBIF" kingdom="Animalia" order="Nautilida" pageId="12" pageNumber="79" phylum="Mollusca" rank="species" species="insalahensis" status="gen. et sp. nov.">
<emphasis box="[697,871,760,786]" italics="true" pageId="12" pageNumber="79">S. insalahensis</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[878,1055,760,786]" pageId="12" pageNumber="79" rank="species">gen. et sp. nov.</taxonomicNameLabel>
).
