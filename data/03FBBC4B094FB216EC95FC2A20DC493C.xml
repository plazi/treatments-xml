<subSubSection id="C3485ED6094FB216EC95FBBF25844830" lastPageId="28" lastPageNumber="479" pageId="27" pageNumber="478" type="etymology">
<paragraph id="8BED0D5D094FB211EC95FBBF24914E54" blockId="27.[151,1437,1123,1257]" box="[151,1178,1123,1149]" pageId="27" pageNumber="478">
<emphasis id="B926D14F094FB211EC95FBBF21294E54" bold="true" box="[151,290,1123,1149]" pageId="27" pageNumber="478">Etymology:</emphasis>
The Greek, 
<emphasis id="B926D14F094FB211EDACFBBF21E04E54" box="[430,491,1123,1149]" italics="true" pageId="27" pageNumber="478">ophis</emphasis>
= serpent, 
<emphasis id="B926D14F094FB211EE62FBBF22984E54" box="[608,659,1123,1149]" italics="true" pageId="27" pageNumber="478">kara</emphasis>
= face; 
<taxonomicName id="4C5276DE094FB211EEE5FBBF23784E54" baseAuthorityName="Valenciennes" baseAuthorityYear="1837" box="[743,883,1123,1149]" class="Actinopterygii" family="Eleotridae" genus="Ophiocara" kingdom="Animalia" order="Perciformes" pageId="27" pageNumber="478" phylum="Chordata" rank="species" species="porocephala">
<emphasis id="B926D14F094FB211EEE5FBBF23784E54" box="[743,883,1123,1149]" italics="true" pageId="27" pageNumber="478">porocephala</emphasis>
</taxonomicName>
: refers to the snout shape.
</paragraph>
<paragraph id="8BED0D5D094FB211ECC5FB5A23834E88" blockId="27.[151,1437,1123,1257]" box="[199,904,1158,1185]" pageId="27" pageNumber="478">
<emphasis id="B926D14F094FB211ECC5FB5A218C4E88" bold="true" box="[199,391,1158,1185]" pageId="27" pageNumber="478">Common name:</emphasis>
Spangled Gudgeon, Northern Mud Gudgeon.
</paragraph>
<paragraph id="8BED0D5D094FB211ECC5FB7723784EC0" blockId="27.[151,1437,1123,1257]" pageId="27" pageNumber="478">
<emphasis id="B926D14F094FB211ECC5FB7721454EEC" bold="true" box="[199,334,1195,1221]" pageId="27" pageNumber="478">Taxonomy:</emphasis>
<taxonomicName id="4C5276DE094FB211ED5AFB7722434EEC" authorityName="Valenciennes" authorityYear="1837" box="[344,584,1195,1221]" class="Actinopterygii" family="Eleotridae" genus="Eleotris" kingdom="Animalia" order="Perciformes" pageId="27" pageNumber="478" phylum="Chordata" rank="species" species="porocephala">
<emphasis id="B926D14F094FB211ED5AFB7722434EEC" box="[344,584,1195,1221]" italics="true" pageId="27" pageNumber="478">Eleotris porocephala</emphasis>
</taxonomicName>
was originally described by Valenciennes [A.] in 
<bibRefCitation id="EFC370AC094FB211E890FB77210A4EC0" author="Cuvier, G. &amp; Valenciennes, A." pageId="27" pageNumber="478" pagination="344 - 368" refId="ref22993" refString="Cuvier, G. &amp; Valenciennes, A. (1837) Histoire naturelle des poissons. Tome douzieme. Suite du livre quatorzieme. Gobioides. Livre quinzieme. Acanthopterygiens a pectorales pediculees, 12, i - xxiv + 1 - 507 + 1, pls. 344 - 368." type="journal article" year="1837">Cuvier &amp; Valenciennes 1837:237</bibRefCitation>
[Histoire naturelle des poissons v. 12] from 
<collectingCountry id="F3454DCD094FB211EEF1FB1323654EC0" box="[755,878,1231,1257]" name="Seychelles" pageId="27" pageNumber="478">Seychelles</collectingCountry>
