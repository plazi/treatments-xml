<taxonomicName id="4C5276DE094FB211EFF3F87D25564D95" authority="Montrouzier, 1857" authorityName="Montrouzier" authorityYear="1857" box="[1009,1373,1953,1980]" class="Actinopterygii" family="Eleotridae" genus="Eleotris" kingdom="Animalia" order="Perciformes" pageId="27" pageNumber="478" phylum="Chordata" rank="species" species="kuak">
<emphasis id="B926D14F094FB211EFF3F87D248E4D92" box="[1009,1157,1953,1979]" italics="true" pageId="27" pageNumber="478">Eleotris kuak</emphasis>
Montrouzier, 1857
