<emphasis id="B907EA91FFDDFFB03C67FCC5FC62FCFF" box="[811,945,783,810]" italics="true" pageId="2" pageNumber="109">
<taxonomicName id="4C734D00FFDDFFB03C67FCC5FC7EFCFF" authorityName="Zerova" authorityYear="1970" box="[811,941,783,810]" class="Insecta" family="Eurytomidae" genus="Systole" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="109" phylum="Arthropoda" rank="species" species="elongata">S. elongata</taxonomicName>
