<taxonomicName id="4C734D00FFDCFFB13FA0FB8DFDF7FBB8" authority="Zerova et Fursov" authorityName="Zerova et Fursov" authorityYear="2019" box="[236,548,1112,1134]" class="Insecta" family="Eurytomidae" genus="Systole" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="110" phylum="Arthropoda" rank="species" species="dzintari" status="sp. n.">
