<taxonomicName id="4C734D00FFDDFFB03D10FCC5FD21FCFF" authorityName="Zerova" authorityYear="1972" box="[604,754,783,810]" class="Insecta" family="Eurytomidae" genus="Systole" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="109" phylum="Arthropoda" rank="species" species="prangicola">
<emphasis id="B907EA91FFDDFFB03D10FCC5FD21FCFF" box="[604,754,783,810]" italics="true" pageId="2" pageNumber="109">S. prangicola</emphasis>
</taxonomicName>
