<subSubSection id="C37468B4FFBEFFDDFF10FC086A543A07" box="[136,790,1801,1828]" pageId="7" pageNumber="27" type="nomenclature">
<paragraph id="8BD13B3FFFBEFFDDFF10FC086A543A07" blockId="7.[136,790,1801,1828]" box="[136,790,1801,1828]" pageId="7" pageNumber="27">
<heading id="D0998C53FFBEFFDDFF10FC086A543A07" bold="true" box="[136,790,1801,1828]" fontSize="11" level="1" pageId="7" pageNumber="27" reason="1">
<emphasis id="B91AE72DFFBEFFDDFF10FC086A543A07" bold="true" box="[136,790,1801,1828]" pageId="7" pageNumber="27">
Key to 
<taxonomicName id="4C6E40BCFFBEFFDDFF46FC0B68383A07" authority="Ruiz &amp; Pavon (1794: 9)" authorityName="Ruiz &amp; Pavon" authorityPageNumber="9" authorityYear="1794" box="[222,378,1801,1828]" class="Liliopsida" family="Pontederiaceae" genus="Heteranthera" kingdom="Plantae" order="Commelinales" pageId="7" pageNumber="27" phylum="Tracheophyta" rank="genus">
<emphasis id="B91AE72DFFBEFFDDFF46FC0B68383A07" bold="true" box="[222,378,1801,1828]" italics="true" pageId="7" pageNumber="27">Heteranthera</emphasis>
</taxonomicName>
in the Mexican 
<collectingRegion id="49AAF5DDFFBEFFDDFDAFFC086BD83A07" box="[567,666,1802,1828]" country="Mexico" name="Yucatan" pageId="7" pageNumber="27">Yucatan</collectingRegion>
Peninsula
</emphasis>
</heading>
</paragraph>
