, 
<collectingCountry id="F36476CB95671876FB73B00717951C41" box="[1179,1232,1338,1364]" name="Italy" pageId="3" pageNumber="26">Italy</collectingCountry>
(
<collectingRegion id="49B7F8B995671876FF5EB064125B1C61" box="[182,286,1369,1396]" country="Italy" name="Sardegna" pageId="3" pageNumber="26">Sardinia</collectingRegion>
