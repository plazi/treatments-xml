<taxonomicName id="4C044D63FFF3FF83B6C60AB3FDD632C1" baseAuthorityName="Kriechbaumer" baseAuthorityYear="1887" box="[477,594,912,934]" class="Insecta" family="Ichneumonidae" genus="Exeristes" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="12" phylum="Arthropoda" rank="species" species="arundinis">E. arundinis</taxonomicName>
</emphasis>
, habitus (lateral view); 
<emphasis id="B970EAF2FFF3FF83B4290AB2FC4D32C1" box="[818,969,912,934]" italics="true" pageId="3" pageNumber="12">
2 — 
<taxonomicName id="4C044D63FFF3FF83B4450AB3FC4D32C1" baseAuthorityName="Ratzeburg" baseAuthorityYear="1844" box="[862,969,912,934]" class="Insecta" family="Ichneumonidae" genus="Exeristes" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="12" phylum="Arthropoda" rank="species" species="longiseta">E. longiseta</taxonomicName>
</emphasis>
, habitus (lateral view); 
<emphasis id="B970EAF2FFF3FF83B3B20AB2FE9332A4" italics="true" pageId="3" pageNumber="12">
3 — 
<taxonomicName id="4C044D63FFF3FF83B7B50A89FE9332A4" baseAuthorityName="Gravenhorst" baseAuthorityYear="1829" box="[174,279,939,960]" class="Insecta" family="Ichneumonidae" genus="Exeristes" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="12" phylum="Arthropoda" rank="species" species="ruficollis">E. ruficollis</taxonomicName>
</emphasis>
, head and mesosoma (lateral view); 
<emphasis id="B970EAF2FFF3FF83B5680A89FC9632A4" box="[627,786,939,961]" italics="true" pageId="3" pageNumber="12">
4 — 
<taxonomicName id="4C044D63FFF3FF83B5840A89FC9632A4" baseAuthorityName="Fabricius" baseAuthorityYear="1793" box="[671,786,939,960]" class="Insecta" family="Ichneumonidae" genus="Exeristes" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="12" phylum="Arthropoda" rank="species" species="roborator">E. roborator</taxonomicName>
</emphasis>
, clypeus (frontal view); 
<emphasis id="B970EAF2FFF3FF83B4E30A89FB1C32A4" box="[1016,1176,939,961]" italics="true" pageId="3" pageNumber="12">
5 — 
<taxonomicName id="4C044D63FFF3FF83B33F0A89FB1C32A4" baseAuthorityName="Kriechbaumer" baseAuthorityYear="1887" box="[1060,1176,939,960]" class="Insecta" family="Ichneumonidae" genus="Exeristes" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="12" phylum="Arthropoda" rank="species" species="arundinis">E. arundinis</taxonomicName>
</emphasis>
, hind tarsus (lateral view); 
<emphasis id="B970EAF2FFF3FF83B66E0AE7FD9132BE" box="[373,533,965,987]" italics="true" pageId="3" pageNumber="12">
6 — 
<taxonomicName id="4C044D63FFF3FF83B6B90AE4FD9132BE" baseAuthorityName="Fabricius" baseAuthorityYear="1793" box="[418,533,965,987]" class="Insecta" family="Ichneumonidae" genus="Exeristes" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="12" phylum="Arthropoda" rank="species" species="roborator">E. roborator</taxonomicName>
</emphasis>
