(
<bibRefCitation id="017B82DBFFF8FFC7FE65F988FDDFF9DA" author="Walker, F." box="[387,546,1626,1652]" pageId="16" pageNumber="17" pagination="325 - 378" refId="ref41141" refString="Walker, F. (1869) On some lepidopterous insects from Congo. Proceedings of the Natural History Society of Glasgow, Series 2, 1, 325 - 378." type="journal article" year="1869">Walker, 1869</bibRefCitation>
