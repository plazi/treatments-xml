<subSubSection id="25992689F3E841BE1BE83C296C68DF55" pageId="null" pageNumber="355" type="description">
<paragraph id="87E6FB5D170202A137F760D69DFB4C4D" pageId="null" pageNumber="355">
Unterscheidet sich von 
<taxonomicName id="ABCA5C1EFA7520A41B3182D773275561" class="Liliopsida" family="Poaceae" genus="Festuca" kingdom="Plantae" order="Poales" pageId="null" pageNumber="355" phylum="Tracheophyta" rank="species" species="ovina">
<emphasis id="5CAC763474AC84E6FBA8631F9820781D" italics="true" pageId="null" pageNumber="355">F. ovina</emphasis>
</taxonomicName>
(Nr. 19c) durch folgende Merkmale: 
<emphasis id="E978D833082D79A7253750299919DC3C" italics="true" pageId="null" pageNumber="355">
20-40 cm hoch. 
<normalizedToken id="68DBEE2C533EDF11BC8811A771A7BDD5" originalValue="Blätter" pageId="null" pageNumber="355">Blaetter</normalizedToken>
0,2-0,4 mm dick. Deckspelzen 2,5-3 mm lang, mit feiner Spitze, nicht begrannt.
</emphasis>
- 
<normalizedToken id="D77C4AC955DBBB2E776B6EC32706743B" originalValue="Blüte" pageId="null" pageNumber="355">Bluete</normalizedToken>
: 
<normalizedToken id="8E82CC6E8B74AE0E0568EE4D885EFB9A" originalValue="Früher" pageId="null" pageNumber="355">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="342EAFAA4B2D3F477AEA563DB95ED794" pageId="null" pageNumber="355">
<emphasis id="135BAAAABE9CAE445089DE689CC6DD8D" italics="true" pageId="null" pageNumber="355">Zytologische Angaben. 2n = 14:</emphasis>
Material aus ganz 
<taxonomicName id="BA1B3F820438EB156F3600538DC4F55A" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="355" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
; Zusammenstellung der Literatur von Watson (1958)
</paragraph>
<paragraph id="DADB8D7FBFFEA1AC51574C6F182B2780" pageId="null" pageNumber="355">
<emphasis id="AEAD0BD27201CDC67825B34188F2603B" italics="true" pageId="null" pageNumber="355">Standort.</emphasis>
Kollin und montan. Saure, sandige, 
<normalizedToken id="82B3C24467D821E453C83F3B418926FA" originalValue="nährstoffarme" pageId="null" pageNumber="355">naehrstoffarme</normalizedToken>
<normalizedToken id="ADC7C6CD032DA80F4403523CB1E22A06" originalValue="Böden" pageId="null" pageNumber="355">Boeden</normalizedToken>
. Lichte 
<normalizedToken id="E6CC01355CEC6752867F1801BE4AE67E" originalValue="Laubmischwälder" pageId="null" pageNumber="355">Laubmischwaelder</normalizedToken>
, 
<normalizedToken id="D75C781801B38526BEEB05121F5FE4EC" originalValue="Kastanienwälder" pageId="null" pageNumber="355">Kastanienwaelder</normalizedToken>
(
<emphasis id="D1AEB502A1A54E3B449AE7D8FBD8FB0C" italics="true" pageId="null" pageNumber="355">
Castaneetum 
<normalizedToken id="C3ED1F6B12AECE49884B47F294D8C38F" originalValue="insübricum" pageId="null" pageNumber="355">insuebricum</normalizedToken>
</emphasis>
<normalizedToken id="DE5F88C9F1D222EEB4388DF95F0204F6" originalValue="Lüdi" pageId="null" pageNumber="355">Luedi</normalizedToken>
1941).
</paragraph>
<paragraph id="E5098618853B81BB1FAAB44E4B9510D0" pageId="null" pageNumber="355">
<emphasis id="D0BC9D693DECFDE64EAD0F9256343CEC" italics="true" pageId="null" pageNumber="355">
Verbreitung. 
<normalizedToken id="36B5C0775D747656FD9513EDA533785D" originalValue="Westeuropäische" pageId="null" pageNumber="355">Westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="E9370744D0FAB8F92775DA49AB81A650" originalValue="Nordwärts" pageId="null" pageNumber="355">Nordwaerts</normalizedToken>
bis auf die Shetlandinseln, 
<normalizedToken id="66CF20374876D4950DC78F17C482D910" originalValue="Südskandinavien" pageId="null" pageNumber="355">Suedskandinavien</normalizedToken>
, 
<normalizedToken id="F91D755BEE02C68606CFE259B389BFD0" originalValue="südwärts" pageId="null" pageNumber="355">suedwaerts</normalizedToken>
bis Nordspanien, mittleres Italien, Balkanhalbinsel (Bosnien); Ostgrenze in 
<normalizedToken id="D766988DE6802E243F8406EB49AB9A00" originalValue="Westrußland" pageId="null" pageNumber="355">Westrussland</normalizedToken>
. - Verbreitungskarte von Meusel (1964). - Im Gebiet: 
<normalizedToken id="3C3D22DAF21473AAAD10CD5E362BCB45" originalValue="Dép" pageId="null" pageNumber="355">Dep</normalizedToken>
. Jura, Vogesen, Oberrheinische Tiefebene, 
<normalizedToken id="2100D54E1824DCF82124ECD6AEB1BB68" originalValue="südlicher" pageId="null" pageNumber="355">suedlicher</normalizedToken>
Schwarzwald, Nordschweiz (eingeschleppt), Vorderrheintal, 
<normalizedToken id="3D0D73F947E25E75D3B39ABA2E0E05CF" originalValue="Alpensüdseite" pageId="null" pageNumber="355">Alpensuedseite</normalizedToken>
.
</paragraph>
<paragraph id="F9D885E93B8F92E9BBDC282F01421C45" pageId="null" pageNumber="355">
<emphasis id="4847DF52B9F52928C10E7AA6BBFD693B" italics="true" pageId="null" pageNumber="355">Bemerkungen.</emphasis>
Anstelle von 
<taxonomicName id="A7109D4586DF42CE24ADDAFAF6DFADBB" class="Liliopsida" family="Poaceae" genus="Festuca" kingdom="Plantae" order="Poales" pageId="null" pageNumber="355" phylum="Tracheophyta" rank="species" species="capillata">
<emphasis id="34EB0489F06BB37483C4C4E3EB1BCFAE" italics="true" pageId="null" pageNumber="355">F. capillata</emphasis>
</taxonomicName>
wird auch der Name 
<taxonomicName id="5CD68787EC95CC1C779216C698578D44" authority="Sibt." authorityName="Sibt." class="Liliopsida" family="Poaceae" genus="Festuca" kingdom="Plantae" order="Poales" pageId="null" pageNumber="355" phylum="Tracheophyta" rank="species" species="tenuifolia">
<emphasis id="85C71167275362BB2AED401122E3928E" italics="true" pageId="null" pageNumber="355">F. tenuifolia</emphasis>
Sibt.
</taxonomicName>
verwendet.
</paragraph>
</subSubSection>
