<subSubSection id="B3E819AF0021D975FF35E768FA100043" pageId="7" pageNumber="127" type="diagnosis">
<paragraph id="FB4D4A240021D975FF35E768FCF00F2A" blockId="7.[136,778,1838,2093]" lastBlockId="7.[810,1452,1839,2093]" pageId="7" pageNumber="127">
<emphasis id="C98696360021D975FF35E768FEBF0FD1" bold="true" box="[189,312,1914,1940]" pageId="7" pageNumber="127">Diagnosis.</emphasis>
<materialsCitation id="4B9A40790021D975FEC9E768FCF30F2A" ID-GBIF-Occurrence="3763881301" collectionCode="R" pageId="7" pageNumber="127" specimenCount="1">
Differs from the 
<typeStatus id="2449F4860021D975FD8DE769FDB20FD0" box="[517,565,1915,1941]" pageId="7" pageNumber="127">type</typeStatus>
species (
<taxonomicName id="3CF231A70021D975FD2AE769FC8D0FD1" authority="RASNITSYN &amp; MAALOUF &amp; MAALOUF &amp; AZAR, 2022" authorityName="RASNITSYN &amp; MAALOUF &amp; MAALOUF &amp; AZAR" authorityYear="2022" box="[674,778,1914,1940]" class="Insecta" family="Serphitidae" genus="Leptoserphites" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="7" pageNumber="127" phylum="Arthropoda" rank="species" species="pabloi" status="sp. nov.">
<emphasis id="C98696360021D975FD2AE769FC8D0FD1" box="[674,778,1914,1940]" italics="true" pageId="7" pageNumber="127">L. pabloi</emphasis>
</taxonomicName>
<emphasis id="C98696360021D975FF00E7B2FF630FFF" bold="true" box="[136,228,1952,1978]" pageId="7" pageNumber="127">
<taxonomicNameLabel id="D2B52B4D0021D975FF00E7B2FF630FFF" box="[136,228,1952,1978]" pageId="7" pageNumber="127" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
) in having antenna 11-segmented with no clear traces of fusion of two basal flagellomeres into one, flagellomeres longer, propodeum transridged, pterostigma wider, 2r-rs shorter, no tubular structures present but 
<collectionCode id="9DE3D2E10021D975FD7FE801FC8D0068" box="[759,778,2067,2093]" country="Chile" name="Departamento de Geologia, Universidad de Chile" pageId="7" pageNumber="127">R</collectionCode>
and pterostigma, hind wing with no r-m, petiolar segments longer
</materialsCitation>
.
</paragraph>
<paragraph id="FB4D4A240021D975FCD7E768FA100043" blockId="7.[810,1452,1839,2093]" pageId="7" pageNumber="127">
<emphasis id="C98696360021D975FCD7E768FBE00FD1" bold="true" box="[863,1127,1914,1941]" pageId="7" pageNumber="127">Locality and horizon.</emphasis>
