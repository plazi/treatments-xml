<taxonomicName id="4C7C4D75FFA04401D2ECF832FDEFF859" authorityName="Breuning" authorityYear="1944" box="[400,563,1987,2013]" class="Insecta" family="Cerambycidae" genus="Paranhammus" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="81" phylum="Arthropoda" rank="genus">
<emphasis id="B908EAE4FFA04401D2ECF832FDEFF859" box="[400,563,1987,2013]" italics="true" pageId="2" pageNumber="81">Paranhammus</emphasis>
</taxonomicName>
