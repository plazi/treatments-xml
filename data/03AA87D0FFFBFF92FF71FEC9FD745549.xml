</taxonomicName>
(
<taxonomicName id="4C034D45FFFBFF92FEF9FE01FE7F56A6" box="[328,434,424,451]" class="Arachnida" family="Ctenidae" kingdom="Animalia" order="Araneae" pageId="14" pageNumber="13" phylum="Arthropoda" rank="family">Ctenidae</taxonomicName>
