<taxonomicName id="4C034D45FFFBFF92FA96FE2CFA6F56FA" box="[1319,1442,389,415]" class="Arachnida" family="Ctenidae" genus="Phoneutria" kingdom="Animalia" order="Araneae" pageId="14" pageNumber="13" phylum="Arthropoda" rank="genus">
