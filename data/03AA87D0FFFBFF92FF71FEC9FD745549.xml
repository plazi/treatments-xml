? 
<taxonomicName id="4C034D45FFFBFF92FF7AFE01FEF556A6" authority="Perty" authorityName="Perty" authorityYear="1833" box="[203,312,424,451]" class="Arachnida" family="Ctenidae" genus="Phoneutria" kingdom="Animalia" order="Araneae" pageId="14" pageNumber="13" phylum="Arthropoda" rank="species" species="fera">
