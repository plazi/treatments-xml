<quantity id="036C9B1BFF576AE8FC3990931A1ABDD9" box="[965,1050,1738,1771]" metricMagnitude="2" metricUnit="m" metricValue="1.0" pageId="172" pageNumber="934" unit="m" value="100.0">100 m</quantity>
.”
</materialsCitation>
