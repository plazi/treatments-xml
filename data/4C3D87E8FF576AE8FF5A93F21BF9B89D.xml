<taxonomicName id="03944D7DFF576AE8FC4190751B52BD7F" authority="Thomas, 1901" authorityName="Thomas" authorityYear="1901" box="[957,1362,1580,1613]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="172" pageNumber="934" phylum="Chordata" rank="species" species="simus">Myotis simus Thomas, 1901</taxonomicName>
, 
<materialsCitation id="74FC3CA3FF576AE8FCF7900D1A2CBDD9" ID-GBIF-Occurrence="3783319709" pageId="172" pageNumber="934">
“Sarayacu, 
<collectingCountry id="BC83766EFF576AE8FC52900D1DF1BD47" box="[942,1009,1620,1653]" name="Peru" pageId="172" pageNumber="934">Peru</collectingCountry>
.” Expanded from holotype information by R. K. LaVal in 1973b to “Sarayacu, 
<collectingRegion id="0650F81CFF576AE8FC2490F21A81BDF6" box="[984,1153,1707,1732]" country="Peru" name="Ucayali" pageId="172" pageNumber="934">Rio Ucayali</collectingRegion>
, 
<collectingRegion id="0650F81CFF576AE8FB6B90F21AF7BDF6" box="[1175,1271,1707,1732]" country="Peru" name="Loreto" pageId="172" pageNumber="934">Loreto</collectingRegion>
