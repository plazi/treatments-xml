</taxonomicName>
and 
<taxonomicName id="45B44D3DFFC8FFA3FF7BF908FD9EF955" box="[189,563,1748,1774]" class="Diplopoda" family="Mastigophorophyllidae" genus="Matigophorophyllon" kingdom="Animalia" order="Chordeumatida" pageId="116" pageNumber="117" phylum="Arthropoda" rank="species" species="saxonicum">
<emphasis id="B0C0EAACFFC8FFA3FF7BF908FD9EF955" box="[189,563,1748,1774]" italics="true" pageId="116" pageNumber="117">Matigophorophyllon saxonicum</emphasis>
</taxonomicName>
) extending north into the Baltic countries.
</paragraph>
