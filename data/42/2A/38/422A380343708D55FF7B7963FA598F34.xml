<taxonomicName authority="Linnaeus (1759: 1261)" authorityName="Linnaeus (1759:" authorityPageNumber="1261" authorityYear="1261" box="[242,669,1174,1201]" class="Liliopsida" family="Poaceae" genus="Olyra" kingdom="Plantae" order="Poales" pageId="15" pageNumber="114" phylum="Tracheophyta" rank="species" species="latifolia">
