<taxonomicName genus="D." lsidName="D. podocarpi-macrophylli" pageId="0" pageNumber="25" rank="species" species="podocarpi-macrophylli">
<emphasis italics="true" pageId="0" pageNumber="25">D. podocarpi-macrophylli</emphasis>
</taxonomicName>
, in shorter alpha conidia.
</paragraph>
