<taxonomicName authorityName="Theel" authorityYear="1886" class="Holothuroidea" family="Synallactidae" genus="Paelopatides" kingdom="Animalia" lsidName="Paelopatides" order="Synallactida" pageId="0" pageNumber="1" phylum="Echinodermata" rank="genus">
