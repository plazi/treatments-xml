<taxonomicName id="4C244D39CC56FFE1FEE4CBC8FD8FF873" authority="Xue &amp; Liu, 2022" authorityName="Xue &amp; Liu" authorityYear="2022" box="[283,587,1978,2002]" class="Arachnida" family="Eriophyidae" genus="Calepitrimerus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trombidiformes" pageId="6" pageNumber="285" phylum="Arthropoda" rank="species" species="cryptocaryaer" status="sp. nov.">
