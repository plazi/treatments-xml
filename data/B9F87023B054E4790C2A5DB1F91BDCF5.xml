<subSubSection id="6E266D1F19BEF656F580D0940A179CEC" pageId="null" pageNumber="763" type="description">
<paragraph id="A69BAD2E25932A996E646134890F1FA9" pageId="null" pageNumber="763">
1 
<normalizedToken id="A3B96F172FB33C22E3DDB26BBB329D7D" originalValue="jährig" pageId="null" pageNumber="763">jaehrig</normalizedToken>
, bis 1,2 m hoch, reich verzweigt. 
<normalizedToken id="8784F38E1CB0D84C8A12820E300A11BA" originalValue="Blätter" pageId="null" pageNumber="763">Blaetter</normalizedToken>
meist 
<normalizedToken id="30ED9C2A5E38B6D58B99C668908353E8" originalValue="wechselständig" pageId="null" pageNumber="763">wechselstaendig</normalizedToken>
, im 
<normalizedToken id="02EA4A98B2B4E1780C15C098D74046A3" originalValue="Umriß" pageId="null" pageNumber="763">Umriss</normalizedToken>
meist rhombisch, 
<normalizedToken id="D80C46DCBB4EBE0F96DC52F6F238ABC1" originalValue="1½" pageId="null" pageNumber="763">11/2</normalizedToken>
-3mal so lang wie breit (
<normalizedToken id="ED704E39C66C7ABB491F7557D13B8246" originalValue="größte" pageId="null" pageNumber="763">groesste</normalizedToken>
Breite nahe dem Grunde), grob und geschweift 
<normalizedToken id="433A3EA631D137B5AE765722FE2912F5" originalValue="gezähnt" pageId="null" pageNumber="763">gezaehnt</normalizedToken>
, am Grunde oft 
<normalizedToken id="CC0CACFA34D54EC795C2FD82DD02D893" originalValue="spießförmig" pageId="null" pageNumber="763">spiessfoermig</normalizedToken>
, junge 
<normalizedToken id="C80E961BB88364971BBEF2299B294139" originalValue="Blätter" pageId="null" pageNumber="763">Blaetter</normalizedToken>
grau, 
<normalizedToken id="D38645F520838434C7C8E57EA66BDE30" originalValue="ältere" pageId="null" pageNumber="763">aeltere</normalizedToken>
<normalizedToken id="841F80F18D19619FDEA2FD1E3DAAF83F" originalValue="grün" pageId="null" pageNumber="763">gruen</normalizedToken>
; Blattstiel ca. 1 cm lang. ♂ 
<normalizedToken id="EB52F7342BA50441FE41E6004E4AA671" originalValue="Blüten" pageId="null" pageNumber="763">Blueten</normalizedToken>
klein, meist nicht zahlreich. 
<emphasis id="F7880AF0A06A8677ACEFA7BF5AAF75A8" italics="true" pageId="null" pageNumber="763">Nur 1 Typ von</emphasis>
♀ 
<emphasis id="78F7FD7271954BAEC542A4C697726790" italics="true" pageId="null" pageNumber="763">
<normalizedToken id="8258A8CBA0AC0AC18FCA2965C61D8FC3" originalValue="Blüten" pageId="null" pageNumber="763">Blueten</normalizedToken>
vorhanden: Alle
</emphasis>
♀ 
<emphasis id="F8D8063E4D034E87EA5A6A07958DDE2D" italics="true" pageId="null" pageNumber="763">
<normalizedToken id="6A02E3CE4EC49AC71460D71F7955B60A" originalValue="Blüten" pageId="null" pageNumber="763">Blueten</normalizedToken>
ohne 
<normalizedToken id="A978558837B0380096B73B76FABCC908" originalValue="Perigonblätter" pageId="null" pageNumber="763">Perigonblaetter</normalizedToken>
, mit 2 
<normalizedToken id="4BB4A1800BAEC4BA44C72FEE7F294E63" originalValue="Vorblättern" pageId="null" pageNumber="763">Vorblaettern</normalizedToken>
; 
<normalizedToken id="CE339F8950BC0F5184070DF4611F160B" originalValue="Vorblätter" pageId="null" pageNumber="763">Vorblaetter</normalizedToken>
im 
<normalizedToken id="20AFC81FCAF3676CDE15B02302222829" originalValue="Umriβ" pageId="null" pageNumber="763">Umriβ</normalizedToken>
3eckig oder rhombisch
</emphasis>
, 3-12 mm lang, etwa 
<normalizedToken id="4E677818568E8A926107FEE02D1D9990" originalValue="1½" pageId="null" pageNumber="763">11/2</normalizedToken>
mal so lang wie breit, 
<emphasis id="39844105D73E8B9078AA7CE4BA1DFDF5" italics="true" pageId="null" pageNumber="763">am Grunde verwachsen</emphasis>
, ganzrandig oder nahe dem Grunde jederseits mit 1 Zahn, 
<emphasis id="B617785F214498A1BAC6C60CE58D68F0" italics="true" pageId="null" pageNumber="763">
nie mit 
<normalizedToken id="D55699EC15F7508797AC38D536353F2D" originalValue="Anhängseln" pageId="null" pageNumber="763">Anhaengseln</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="DCFB7BF1EACA6B0CFF9CD15D1EAE314E" originalValue="Blüte" pageId="null" pageNumber="763">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="39FFC61DB6FBD59FD4C092E2C00C9A57" pageId="null" pageNumber="763">
<emphasis id="B907964AF16F08F670DCBB0054F323B3" italics="true" pageId="null" pageNumber="763">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="723AC07A7D6748EB9CE86032D55B012E" pageId="null" pageNumber="763">
<emphasis id="216AA1AE421EB40E182E0B5554A64F62" italics="true" pageId="null" pageNumber="763">Standort.</emphasis>
Kollin. Ruderalstellen in Trockengebieten.
</paragraph>
<paragraph id="16B00F770E74848D33A4523874E41F80" pageId="null" pageNumber="763">
<emphasis id="86F88870B728A87B15A6776E0B5B8375" italics="true" pageId="null" pageNumber="763">
Verbreitung. 
<normalizedToken id="C7086BEEF36AE38FF13B99EEBBAC7DC8" originalValue="Ursprünglich" pageId="null" pageNumber="763">Urspruenglich</normalizedToken>
west- und zentralasiatische Pflanze;
</emphasis>
heute weithin verschleppt (auch in Nordamerika). In 
<taxonomicName id="E713A99B789B00DCDB8D0D3FE03810BE" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="763" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
<normalizedToken id="37DF0BD73BA5373AF142092F8F8EC894" originalValue="westwärts" pageId="null" pageNumber="763">westwaerts</normalizedToken>
bis ins Rheingebiet, Jugoslawien und Griechenland, 
<normalizedToken id="7DFEF9FC8B34C73C2CDCFE65F01304EC" originalValue="nordwärts" pageId="null" pageNumber="763">nordwaerts</normalizedToken>
bis Norddeutschland. Verbreitungskarte von Meusel (1964). - Im Gebiet: Im 
<normalizedToken id="FABD51EEEBB105FAA65083365424F5AB" originalValue="Elsaß" pageId="null" pageNumber="763">Elsass</normalizedToken>
<normalizedToken id="FDABC2973AE37C16F36EFA9FCA64B7F2" originalValue="eingebürgert" pageId="null" pageNumber="763">eingebuergert</normalizedToken>
, sonst selten und 
<normalizedToken id="64F8E32FA6757CB507E6CD47E7003FF4" originalValue="unbeständig" pageId="null" pageNumber="763">unbestaendig</normalizedToken>
auf 
<normalizedToken id="4DF91D796DE29C5642E24AE28C09C4B8" originalValue="Bahnhöfen" pageId="null" pageNumber="763">Bahnhoefen</normalizedToken>
.
</paragraph>
</subSubSection>
