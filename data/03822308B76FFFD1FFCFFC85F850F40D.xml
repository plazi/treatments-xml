<taxonomicName id="4C2BE99DB76FFFD1FFCDF96FFE1CF0AB" authority="Thomas, 1906" authorityName="Thomas" authorityYear="1906" box="[102,471,1748,1781]" class="Mammalia" family="Leporidae" genus="Lepus" kingdom="Animalia" order="Lagomorpha" pageId="40" pageNumber="147" phylum="Chordata" rank="subSpecies" species="brachyurus" subSpecies="okiensis">L. b. okiensis Thomas, 1906</taxonomicName>
