<taxonomicName id="4B7E5C8475391667E08900EF761B3099" LSID="45206A6E-E9DA-53B2-95B5-23EE89E7AD22" authority="Karaman, 2008" authorityName="Karaman" authorityYear="2008" class="Insecta" family="Formicidae" genus="Crematogaster" kingdom="Animalia" lsidName="Crematogaster gordani" order="Hymenoptera" pageId="0" pageNumber="83658" phylum="Arthropoda" rank="species" species="gordani">Crematogaster gordani Karaman, 2008</taxonomicName>
