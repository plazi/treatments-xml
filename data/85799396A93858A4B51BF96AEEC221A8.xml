<paragraph id="82322B3FBF5F60C21EDF04BBC0273BD3" pageId="0" pageNumber="1">
<figureCitation id="1FAF77DB45091D82D9D1382652EB54C8" captionStart="Figure 16" captionStartId="F16" captionText="Figure 16. Mesosoma in lateral view A C. imitator (CASENT 0452849) B C. mahafaly (CASENT 0115287)." figureDoi="10.3897/zookeys.1098.73223.figure16" httpUri="https://binary.pensoft.net/fig/678075" pageId="0" pageNumber="1">Fig. 16A</figureCitation>
