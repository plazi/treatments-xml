<emphasis id="B918CD75FFE6FFD2FC9D59A659DDFE44" bold="true" box="[801,956,431,464]" pageId="11" pageNumber="563">Taxonomy.</emphasis>
<taxonomicName id="4C6C6AE4FFE6FFD2FC6C59A65EFAFE63" authority="Pessoa, de Oliveira &amp; dos Reis, 1992" authorityName="Pessoa, de Oliveira, dos Reis" authorityYear="1992" class="Mammalia" family="Echimyidae" genus="Proechimys" kingdom="Animalia" order="Rodentia" pageId="11" pageNumber="563" phylum="Chordata" rank="species" species="moojeni">Proechimys moojeni Pessoa, de Oliveira &amp; dos Reis, 1992</taxonomicName>
, 
<materialsCitation id="3B041B3AFFE6FFD2FB0F59D75F60FDD2" ID-GBIF-Occurrence="3804303379" pageId="11" pageNumber="563">“Mata do Dr. Daniel, Conceicao do Mato Dentro, Minas Gerais, Brazil; 19° 01°S, 43° 25°'W.”</materialsCitation>
</paragraph>
<paragraph id="8BD31167FFE6FFD2FC995A445E70FD70" blockId="11.[799,1392,431,858]" pageId="11" pageNumber="563">
<taxonomicName id="4C6C6AE4FFE6FFD2FC995A445E66FDFA" baseAuthorityName="Pessoa, de Oliveira &amp; dos Reis" baseAuthorityYear="1992" box="[805,1031,589,622]" class="Mammalia" family="Echimyidae" genus="Trinomys" kingdom="Animalia" order="Rodentia" pageId="11" pageNumber="563" phylum="Chordata" rank="species" species="moojeni">Trinomys moojeni</taxonomicName>
