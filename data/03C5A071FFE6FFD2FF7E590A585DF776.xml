<taxonomicName id="4C6C6AE4FFE6FFD2FC7B5A7D5E31FD01" authorityName="J. A. Allen" authorityYear="1899" box="[967,1104,628,661]" class="Mammalia" family="Echimyidae" genus="Proechimys" kingdom="Animalia" order="Rodentia" pageId="11" pageNumber="563" phylum="Chordata" rank="genus">Proechimys</taxonomicName>
