<specimenCount id="9D74FD2C935B8E06F025F807FDADF865" box="[536,636,1940,1967]" pageId="2" pageNumber="486" type="male">one male</specimenCount>
and 
<specimenCount id="9D74FD2C935B8E06F08CF807FCFFF865" box="[689,814,1940,1967]" pageId="2" pageNumber="486" type="female">one female</specimenCount>
, as stated in the original description. 
<location id="8EAD607E935B8E06F6F5F807FB38F864" LSID="urn:lsid:plazi:treatment:03DB87B3935B8E07F2AAF972FCA1FF32:8EAD607E935B8E06F6F5F807FB38F864" box="[1224,1257,1941,1967]" country="Portugal" municipality="Il" name="He" pageId="2" pageNumber="486">He</location>
