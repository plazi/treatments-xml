<materialsCitation id="3B1A3CF8935B8E06F2FAF806FD1BF819" ID-GBIF-Occurrence="3798147339" country="Portugal" location="He" municipality="Il" pageId="2" pageNumber="486" specimenCount="2" specimenCount-female="1" specimenCount-male="1">
<bibRefCitation id="EFE34B54935B8E06F2FAF806FEB6F865" author="Dejean, P. F. M. A." box="[199,359,1940,1966]" pageId="2" pageNumber="486" pagination="113 - 400" refId="ref10772" refString="Dejean, P. F. M. A. (1830) New taxa. In: Dejean P. F. M. A. &amp; Boisduval J. B. A., Iconographie et histoire naturelle des coleopteres d'Europe. Tome Premier. Mequignon-Marvis, Paris, pp. 113 - 400." type="book chapter" year="1830">Dejean (1830)</bibRefCitation>
