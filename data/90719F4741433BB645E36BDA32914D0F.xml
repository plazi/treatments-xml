<subSubSection id="959F99DD22050DC708E1A155C8577E37" pageId="null" pageNumber="758" type="description">
<paragraph id="150D482B5B7A090A6DDD28F21D3A8D03" pageId="null" pageNumber="758">
1 
<normalizedToken id="8BFC0BE9AB42BCD25F88E807FDFF7CB3" originalValue="jährige" pageId="null" pageNumber="758">jaehrige</normalizedToken>
oder ausdauernde 
<normalizedToken id="408BE9E35E976DEB4F5A7C5702435B48" originalValue="Kräuter" pageId="null" pageNumber="758">Kraeuter</normalizedToken>
, 20-150 cm hoch. Wurzeln 
<normalizedToken id="89DC85DE394FCDA04B3B477A3CD9867C" originalValue="dünn" pageId="null" pageNumber="758">duenn</normalizedToken>
und holzig oder Wurzeln und Hypokotyl dick und fleischig (
<normalizedToken id="9CC4C84154D7A52187B5A1C7198B0000" originalValue="Rüben" pageId="null" pageNumber="758">Rueben</normalizedToken>
). Stengel aufrecht, kantig gefurcht, kahl, verzweigt. 
<normalizedToken id="8452A01E1581B627B12FA9C9B8A921BB" originalValue="Blätter" pageId="null" pageNumber="758">Blaetter</normalizedToken>
stets mit deutlicher Spreite; 
<normalizedToken id="E2471B6AE7736264F8E5663413506CD9" originalValue="grundständige" pageId="null" pageNumber="758">grundstaendige</normalizedToken>
<normalizedToken id="AEF9A9A2A19E6FD4E1BDEEA9F467F6C4" originalValue="Blätter" pageId="null" pageNumber="758">Blaetter</normalizedToken>
rosettenartig, oval, am Grunde 
<normalizedToken id="F33DFF2E02824C0A8828D5BE7BC68744" originalValue="herzförmig" pageId="null" pageNumber="758">herzfoermig</normalizedToken>
, gestutzt oder in den Stiel 
<normalizedToken id="6252BA20B7B884F97FB51D16720ED379" originalValue="verschmälert" pageId="null" pageNumber="758">verschmaelert</normalizedToken>
; am Rande wellig bis kraus; Blattstiel lang. Untere 
<normalizedToken id="CCE49B46C67AC9DF6807928A2D21615A" originalValue="Stengelblätter" pageId="null" pageNumber="758">Stengelblaetter</normalizedToken>
von 
<normalizedToken id="A1A2E096F89FAB4F0A52939E263787F0" originalValue="ähnlicher" pageId="null" pageNumber="758">aehnlicher</normalizedToken>
Form, jedoch kleiner. 
<normalizedToken id="1304107126D07D85278BDAC8AC06B083" originalValue="Hochblätter" pageId="null" pageNumber="758">Hochblaetter</normalizedToken>
meist lanzettlich, sitzend, klein (1-4 cm lang). 
<normalizedToken id="05374F41D5E434751EF128544C89755A" originalValue="Blüten" pageId="null" pageNumber="758">Blueten</normalizedToken>
zwitterig, meist mit 2 
<normalizedToken id="9A4E2B76A2A3CD523BA64ED2AB3E7ADF" originalValue="Vorblättern" pageId="null" pageNumber="758">Vorblaettern</normalizedToken>
, einzeln oder bis zu 8 in einer Blattachsel, sitzend, 
<emphasis id="0E2BA5E9646FDD70C76F696779FFE830" italics="true" pageId="null" pageNumber="758">miteinander verwachsen.</emphasis>
<normalizedToken id="96BE1F0FC47E2ABAF7D5C87433C73477" originalValue="Gesamtblütenstand" pageId="null" pageNumber="758">Gesamtbluetenstand</normalizedToken>
rispig. 
<normalizedToken id="2898BBA544AEC6366A466F5A0A0096A1" originalValue="Perigonblätter" pageId="null" pageNumber="758">Perigonblaetter</normalizedToken>
5, 
<emphasis id="52E1C5AF562BFD352AEED45C2E38C52D" italics="true" pageId="null" pageNumber="758">
in der untern 
<normalizedToken id="E13B88EF2D539A383159F1E4434EDC4B" originalValue="Hälfte" pageId="null" pageNumber="758">Haelfte</normalizedToken>
mit dem Fruchtknoten verwachsen;
</emphasis>
freie Zipfel zungen- oder 
<normalizedToken id="951A2C3475A45AACD52A9EA84A793075" originalValue="spatelförmig" pageId="null" pageNumber="758">spatelfoermig</normalizedToken>
, ganzrandig oder gefranst, gekielt, 
<normalizedToken id="13961329E5A632F2FC719073D1C28C32" originalValue="grünlich" pageId="null" pageNumber="758">gruenlich</normalizedToken>
, 
<normalizedToken id="17D5667AF808F66EAC5E639882C9D7CB" originalValue="weiß" pageId="null" pageNumber="758">weiss</normalizedToken>
, gelb oder rot, zur 
<normalizedToken id="15777A82BC713D7F34747F4D71E771FB" originalValue="Blütezeit" pageId="null" pageNumber="758">Bluetezeit</normalizedToken>
abstehend, 
<normalizedToken id="B9B3EED1C7B5EFA46367B56BB72090F9" originalValue="später" pageId="null" pageNumber="758">spaeter</normalizedToken>
zusammenneigend und zur 
<emphasis id="25048B3FC878AC2F144D0A61EB5EDB6C" italics="true" pageId="null" pageNumber="758">Fruchtzeit hart.</emphasis>
<normalizedToken id="4AA5115A2A676848E9D128551DE50913" originalValue="Staubblätter" pageId="null" pageNumber="758">Staubblaetter</normalizedToken>
5. 
<emphasis id="9E2B73677F8CFD243C889EB0B71BC336" italics="true" pageId="null" pageNumber="758">
Fruchtknoten halb 
<normalizedToken id="1AFF24431C760DA918A835A486ED2D3F" originalValue="unterständig" pageId="null" pageNumber="758">unterstaendig</normalizedToken>
;
</emphasis>
Griffel 2-5. 
<emphasis id="BC917DD5712C9EF2A6A34B60EE7B75F5" italics="true" pageId="null" pageNumber="758">
Frucht von der harten 
<normalizedToken id="B17C8DED2E23FB6481876701ADDD9243" originalValue="Blütenhülle" pageId="null" pageNumber="758">Bluetenhuelle</normalizedToken>
umgeben.
</emphasis>
</paragraph>
<paragraph id="EEF3F3AD31BEFC414D10EB746022CA86" pageId="null" pageNumber="758">
Die Gattung 
<taxonomicName id="4D38D9F08FFAA1F154D31ADA18D613CF" class="Magnoliopsida" family="Amaranthaceae" genus="Beta" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="758" phylum="Tracheophyta" rank="genus">
<emphasis id="00F38535C35CF7741CF16924E7B8468F" italics="true" pageId="null" pageNumber="758">Beta</emphasis>
</taxonomicName>
<normalizedToken id="189D5E0C3B4599A8943172ED40752493" originalValue="umfaßt" pageId="null" pageNumber="758">umfasst</normalizedToken>
etwa 
<emphasis id="A067DB120931DF590680CBDC6575C859" italics="true" pageId="null" pageNumber="758">
12 Arten, die im Mittelmeergebiet und durch die Steppen 
<normalizedToken id="32452FEF63998B5206263DFAFE308813" originalValue="ostwärts" pageId="null" pageNumber="758">ostwaerts</normalizedToken>
bis Zentralasien und Vorderindien verbreitet sind.
</emphasis>
In 
<taxonomicName id="030E30E7127025D3413401DEF2828EE7" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="758" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
nur 
<taxonomicName id="F0CE6CF09E7497359FF9ED927DFB6F43" class="Magnoliopsida" family="Amaranthaceae" genus="Beta" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="758" phylum="Tracheophyta" rank="species" species="vulgaris">
<emphasis id="B1C41A5F49D96191189096872F2BB952" italics="true" pageId="null" pageNumber="758">Beta vulgaris</emphasis>
</taxonomicName>
<normalizedToken id="06A614A26DEEE3B25ABCE915304C30E6" originalValue="ursprünglich" pageId="null" pageNumber="758">urspruenglich</normalizedToken>
.
</paragraph>
</subSubSection>
