<subSubSection id="3796656070D7FF31FF23E917892FF8BB" pageId="169" pageNumber="170" type="discussion">
<paragraph id="7F3336EB70D7FF31FF23E917892FF8BB" blockId="169.[151,1436,1822,1919]" pageId="169" pageNumber="170">
<emphasis id="4DF8EAF970D7FF31FF23E9178B44F89E" bold="true" box="[199,335,1858,1883]" inLineHeading="true" pageId="169" pageNumber="170" reason="1">Comments.</emphasis>
While 
<bibRefCitation id="1B1D4B1A70D7FF31FE41E917886CF89F" author="Shattuck, S. O." box="[421,615,1858,1882]" pageId="169" pageNumber="170" pagination="13 - 18" refId="ref112320" refString="Shattuck, S. O. (1992 a) Review of the dolichoderine ant genus Iridomyrme x Mayr with descriptions of three new genera (Hymenoptera: Formicidae). Journal of the Australian Entomological Society, 31, 13 - 18." type="journal article" year="1992">
<taxonomicName id="B88C4D6870D7FF31FE41E917880CF89F" authority="Heterick &amp; Shattuck, 2011" authorityName="Heterick &amp; Shattuck" authorityYear="2011" box="[421,519,1858,1882]" genus="Shattuck" pageId="169" pageNumber="170" rank="genus" status="gen. n.">Shattuck</taxonomicName>
(1992a)
</bibRefCitation>
considered this species to belong to 
<taxonomicName id="B88C4D6870D7FF31FBF5E9168E96F89E" authorityName="Mayr" authorityYear="1866" box="[1041,1181,1859,1883]" class="Insecta" family="Formicidae" genus="Linepithema" kingdom="Animalia" order="Hymenoptera" pageId="169" pageNumber="170" phylum="Arthropoda" rank="genus">
<emphasis id="4DF8EAF970D7FF31FBF5E9168E96F89E" box="[1041,1181,1859,1883]" italics="true" pageId="169" pageNumber="170">Linepithema</emphasis>
</taxonomicName>
, more recent work by 
<bibRefCitation id="1B1D4B1A70D7FF31FF73E9338B9CF8BB" author="Wild, A. L. &amp; Cuezzo, F." box="[151,407,1894,1918]" pageId="169" pageNumber="170" pagination="57 - 68" refId="ref113216" refString="Wild, A. L. &amp; Cuezzo, F. (2006) Rediscovery of a fossil dolichoderine ant lineage and a description of a new genus from South America. Zootaxa, 1142, 57 - 68." type="journal article" year="2006">Wild &amp; Cuezzo (2006)</bibRefCitation>
places it in their genus 
<taxonomicName id="B88C4D6870D7FF31FD45E9338916F8BB" authorityName="Wild &amp; Cuezzo" authorityYear="2006" box="[673,797,1894,1918]" class="Insecta" family="Formicidae" genus="Gracilidris" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="169" pageNumber="170" phylum="Arthropoda" rank="genus">
<emphasis id="4DF8EAF970D7FF31FD45E9338916F8BB" box="[673,797,1894,1918]" italics="true" pageId="169" pageNumber="170">Gracilidris</emphasis>
</taxonomicName>
.
</paragraph>
