<subSubSection id="E0A38FA0E28C594549C0F0015C17EB6A" pageId="null" pageNumber="535" type="nomenclature">
<paragraph id="7205374F0C844654380FC50606B0ADC3" pageId="null" pageNumber="535">
<taxonomicName id="78C49AAEC43C2468F6200DA2FF20F4CF" authority="Jacq." class="Magnoliopsida" family="Fabaceae" genus="Medicago" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="535" phylum="Tracheophyta" rank="species" species="carstiensis">
<pageBreakToken id="EEB620B2DC89013910B705FEE7DFBC53" pageId="null" pageNumber="535">Medicago</pageBreakToken>
<normalizedToken id="A939CC505DFFD27CEFA9BCB071D9F009" originalValue="carstiénsis" pageId="null" pageNumber="535">carstiensis</normalizedToken>
Jacq.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="B94D6F12FB2E20E4509605D3EE4CF16B" pageId="null" pageNumber="535" type="vernacular_names">
<paragraph id="6B3259F7EE6D73C2874D9B84B4AC4FF5" pageId="null" pageNumber="535">Karst-Schneckenklee</paragraph>
</subSubSection>
</title>
<subSubSection id="47AD147828680CFB9EAF4FE63D5C4CA0" pageId="null" pageNumber="535" type="description">
<paragraph id="D462FBEDA3EC0935440DF2CF536249BF" pageId="null" pageNumber="535">
Ausdauernd, mit kurzen unterirdischen 
<normalizedToken id="53E80F9308B7C484DE4FD3BD2866986A" originalValue="Ausläufern" pageId="null" pageNumber="535">Auslaeufern</normalizedToken>
; 30-60 cm hoch. Stengel aufrecht oder aufsteigend, verzweigt, kahl, oder zerstreut behaart. 
<normalizedToken id="718D97EE843377F4517596BA679C2D39" originalValue="Teilblätter" pageId="null" pageNumber="535">Teilblaetter</normalizedToken>
1-2mal so lang wie breit, 
<emphasis id="97E5CA64E46260AFB636694D9D71A5F6" italics="true" pageId="null" pageNumber="535">
mit der 
<normalizedToken id="AC9504238E7365AEBCC4829E6B19B26F" originalValue="größten" pageId="null" pageNumber="535">groessten</normalizedToken>
Breite meist im untersten Drittel
</emphasis>
(bei den andern Arten des Gebiets 
<normalizedToken id="0F08B9D0DFBA1D2189074069064E62BD" originalValue="größte" pageId="null" pageNumber="535">groesste</normalizedToken>
Breite in der Mitte oder im obersten Drittel!), meist kahl. 
<normalizedToken id="02F0C384E503470E95D1206A76E1157B" originalValue="Nebenblätter" pageId="null" pageNumber="535">Nebenblaetter</normalizedToken>
<normalizedToken id="22C43F10197B4EC693DD4C5ADCFEC0DF" originalValue="gezähnt" pageId="null" pageNumber="535">gezaehnt</normalizedToken>
oder bis fast zur Mitte gegen den Mittelnerv hin in schmale Zipfel geteilt. 
<normalizedToken id="119DDC9D0BAD2933489C6CA9CC2F19A7" originalValue="Blütenstand" pageId="null" pageNumber="535">Bluetenstand</normalizedToken>
3-20 
<normalizedToken id="67260C0A5C40F227281BFC927079AB43" originalValue="blütig" pageId="null" pageNumber="535">bluetig</normalizedToken>
. Krone 6-8 mm lang, gelb. 
<emphasis id="BB812BB78788FF24C495682AC4424CC8" italics="true" pageId="null" pageNumber="535">Frucht mit meist 5 schraubenartigen Windungen</emphasis>
, kurz zylindrisch, mit geringen 
<normalizedToken id="CC508B8A5005BA47356DD38C96B97E75" originalValue="Zwischenräumen" pageId="null" pageNumber="535">Zwischenraeumen</normalizedToken>
, 8-10 mm im Durchmesser (ohne Stacheln), 
<emphasis id="EF45D1656D677C50469F884E83F823E9" italics="true" pageId="null" pageNumber="535">
dicht mit 2-7 mm langen, an der Spitze oft 
<normalizedToken id="69EE0E6258C1C8FA98FFACCA4925BF52" originalValue="gekrümmten" pageId="null" pageNumber="535">gekruemmten</normalizedToken>
<normalizedToken id="D19B9E78ABE0C508DAB816FD103CCA2E" originalValue="hakenförmigen" pageId="null" pageNumber="535">hakenfoermigen</normalizedToken>
Stacheln besetzt
</emphasis>
, kahl. - 
<normalizedToken id="4996BE6F8F1779CBE6E9C2FA684A086D" originalValue="Blüte" pageId="null" pageNumber="535">Bluete</normalizedToken>
: 
<normalizedToken id="51029E4C1DDF7E04EA62B339A04CBB03" originalValue="Später" pageId="null" pageNumber="535">Spaeter</normalizedToken>
<normalizedToken id="D526987D8017E860A2CAC73E23EB6743" originalValue="Frühling" pageId="null" pageNumber="535">Fruehling</normalizedToken>
und 
<normalizedToken id="67F6208BB2D603F16CBB635B4AD4808D" originalValue="früher" pageId="null" pageNumber="535">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="CE10EE14A10F1B661C9E9A96C463A22B" pageId="null" pageNumber="535">
<emphasis id="929AE3443979D3F18D4AE9ED6AD92F5F" italics="true" pageId="null" pageNumber="535">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="F29B3026A47BFCFC66C17A76D25D200B" italics="true" pageId="null" pageNumber="535">16:</emphasis>
Material aus botanischen 
<normalizedToken id="3CD23E6D9A166E36DE7C4E2F5979786E" originalValue="Gärten" pageId="null" pageNumber="535">Gaerten</normalizedToken>
(Fryer 1930, Clement 1962).
</paragraph>
<paragraph id="B61803A31D0189A21A2CB170D9DC6AD5" pageId="null" pageNumber="535">
<emphasis id="2DD271CA8D7B3B8E6CDCC93F59826A54" italics="true" pageId="null" pageNumber="535">Standort.</emphasis>
Kollin. Trockene, steinige 
<normalizedToken id="B10AE0EE1B81DEB7DDE01D18459E85C7" originalValue="Böden" pageId="null" pageNumber="535">Boeden</normalizedToken>
in warmen, oft schattigen Lagen. 
<normalizedToken id="362276311D703EFD47F888DDD1DA3ACC" originalValue="Gebüsche" pageId="null" pageNumber="535">Gebuesche</normalizedToken>
, 
<normalizedToken id="AE48BF3DB53C1168E68C19F60FCC9067" originalValue="Waldränder" pageId="null" pageNumber="535">Waldraender</normalizedToken>
, 
<normalizedToken id="A515F3407BC99C5A55FFF8DE33B9B179" originalValue="Felshänge" pageId="null" pageNumber="535">Felshaenge</normalizedToken>
.
</paragraph>
<paragraph id="7A088CD29F0EF738E362A6AB44FF6F51" pageId="null" pageNumber="535">
<emphasis id="4AB63A65FD093CEC8715843E29BF0CEE" italics="true" pageId="null" pageNumber="535">
Verbreitung. 
<normalizedToken id="D7EB75214ABB48F90D20CF3596A173BF" originalValue="Südostalpin-illyrische" pageId="null" pageNumber="535">Suedostalpin-illyrische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="0B226857439C1B0FBD4FFED2ECD57AF9" originalValue="Südostalpen" pageId="null" pageNumber="535">Suedostalpen</normalizedToken>
vom Comersee bis Krain und Steiermark, Gebirge der Balkanhalbinsel (
<normalizedToken id="44F035D93353C9564C50B15779963AD3" originalValue="südwärts" pageId="null" pageNumber="535">suedwaerts</normalizedToken>
bis Albanien und Bulgarien). Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: Grigna und 
<normalizedToken id="48620DF1E89DFDDCFE7228A7DBE67D36" originalValue="Südfuß" pageId="null" pageNumber="535">Suedfuss</normalizedToken>
der Bergamasker Alpen.
</paragraph>
</subSubSection>
