<subSubSection id="00ED7FEBEDA404B5BD8693018C737770" pageId="null" pageNumber="522" type="description">
<paragraph id="3C5A6C91D1CE03551E60B27F01153B6C" pageId="null" pageNumber="522">
Unterscheidet sich von 
<taxonomicName id="5B4A0B65ADA00B6A417A935665BFFC7D" class="Magnoliopsida" family="Asteraceae" genus="Buphthalmum" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="522" phylum="Tracheophyta" rank="genus">
<emphasis id="DE8E0831A18E609E797F0723C1E12A9B" italics="true" pageId="null" pageNumber="522">Buphthalmum</emphasis>
</taxonomicName>
(S. 519) durch folgende Merkmale: 
<emphasis id="FA172542A50E218FB928834214988535" italics="true" pageId="null" pageNumber="522">1</emphasis>
- 
<emphasis id="13EE29A1348B79640328561C658D8A73" italics="true" pageId="null" pageNumber="522">
2 
<normalizedToken id="DEBE66BB41D9F68DD09318D5A580C913" originalValue="jährig" pageId="null" pageNumber="522">jaehrig</normalizedToken>
; 
<normalizedToken id="6783E4C6FFD129C45604C0C288E0F94F" originalValue="Hüllblätter" pageId="null" pageNumber="522">Huellblaetter</normalizedToken>
ungleich, die 
<normalizedToken id="F96E0F9DBF2424CD8F13E27AB7FF3948" originalValue="äußern" pageId="null" pageNumber="522">aeussern</normalizedToken>
<normalizedToken id="6DFD8FE5178D2CAB9EE16E75C9C209DB" originalValue="länger" pageId="null" pageNumber="522">laenger</normalizedToken>
als die innern und 
<normalizedToken id="5ADAD69E05E4F73463BF6D907EEAB0E3" originalValue="sternförmig" pageId="null" pageNumber="522">sternfoermig</normalizedToken>
ausgebreitet, deutlich 
<normalizedToken id="9209C38E7CD0183A134C09DE9D467643" originalValue="länger" pageId="null" pageNumber="522">laenger</normalizedToken>
als die 
<normalizedToken id="946AB9152308D6B4537C7EA39B78C945" originalValue="randständigen" pageId="null" pageNumber="522">randstaendigen</normalizedToken>
, 
<normalizedToken id="E9A162629F657EAD8C6660600710BC24" originalValue="zungenförmigen" pageId="null" pageNumber="522">zungenfoermigen</normalizedToken>
<normalizedToken id="CBE56B16E03C68CD1DD30C4B30336BD2" originalValue="Blüten" pageId="null" pageNumber="522">Blueten</normalizedToken>
</emphasis>
.
</paragraph>
<paragraph id="394C69C740BA5CCCBAEAF4A42F0BDA45" pageId="null" pageNumber="522">
Die Gattung 
<taxonomicName id="478B48F74C3DA8266D6CEDADC8B679EC" class="Asteroidea" family="Asterinidae" genus="Asteriscus" kingdom="Animalia" order="Valvatida" pageId="null" pageNumber="522" phylum="Echinodermata" rank="genus">
<emphasis id="8A518C7524E13EDBA965954F1274290F" italics="true" pageId="null" pageNumber="522">Asteriscus</emphasis>
</taxonomicName>
<normalizedToken id="77A3EB313FBF801969426DA1F344A431" originalValue="umfaßt" pageId="null" pageNumber="522">umfasst</normalizedToken>
etwa 
<emphasis id="F8E6D7F53E9AC51081A948DBCD3A86CE" italics="true" pageId="null" pageNumber="522">15 Arten</emphasis>
und hat 
<emphasis id="C282BDAA2BE9B4523B8F337CA92FC9F7" italics="true" pageId="null" pageNumber="522">mediterrane Verbreitung</emphasis>
.
</paragraph>
