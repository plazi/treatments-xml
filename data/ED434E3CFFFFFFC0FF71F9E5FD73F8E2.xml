<heading id="3E1D4846FFFFFFC0FF71F9E5FDFBF9FE" bold="true" box="[151,518,1590,1617]" fontSize="11" level="2" pageId="23" pageNumber="24" reason="4">
<taxonomicName id="A2EA84A9FFFFFFC0FF71F9E5FDFBF9FE" authority="Hampson, 1926" authorityName="Hampson" authorityYear="1926" box="[151,518,1590,1617]" class="Insecta" family="Noctuidae" genus="Ferenta" kingdom="Animalia" order="Lepidoptera" pageId="23" pageNumber="24" phylum="Arthropoda" rank="species" species="incaya">
<emphasis id="579E2338FFFFFFC0FF71F9E5FDFBF9FE" bold="true" box="[151,518,1590,1617]" pageId="23" pageNumber="24">
<emphasis id="579E2338FFFFFFC0FF71F9E5FEBBF9FE" bold="true" box="[151,326,1590,1617]" italics="true" pageId="23" pageNumber="24">Ferenta incaya</emphasis>
<bibRefCitation id="017B82DBFFFFFFC0FEABF9E4FDFBF9FE" author="Hampson, G. F." box="[333,518,1590,1616]" pageId="23" pageNumber="24" refId="ref37961" refString="Hampson, G. F. (1926) Descriptions of new genera and species of Lepidoptera Phalaenae of the subfamily Noctuinae (Noctuidae) in the British Museum (Natural History). Taylor and Francis, London, 641 pp." type="book" year="1926">Hampson, 1926</bibRefCitation>
