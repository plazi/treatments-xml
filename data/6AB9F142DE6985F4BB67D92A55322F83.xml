<subSubSection id="F3863CE61CABE25B34C526FCDF5A24BB" pageId="null" pageNumber="580" type="description">
<paragraph id="06A2416EC61C5474794793BEE4591DAB" pageId="null" pageNumber="580">
<emphasis id="12F92F8B668B16426416D15C8518630B" italics="true" pageId="null" pageNumber="580">
<normalizedToken id="A962FB5EAE1E1E7F61D8A4EB7A70A245" originalValue="Blätter" pageId="null" pageNumber="580">Blaetter</normalizedToken>
mit 6-12 
<normalizedToken id="A713276E7D7289D7FBA87A7DBC84DD7A" originalValue="Teilblättern" pageId="null" pageNumber="580">Teilblaettern</normalizedToken>
; 
<normalizedToken id="D4DAE7F39E7E0E3E0C03DB8887A8855E" originalValue="Teilblätter" pageId="null" pageNumber="580">Teilblaetter</normalizedToken>
vorn gerundet, mit kurzer, aufgesetzter Spitze;
</emphasis>
<normalizedToken id="7B282A5687E487FD9EF1640780701BE1" originalValue="Nebenblätter" pageId="null" pageNumber="580">Nebenblaetter</normalizedToken>
am Grunde mit 1 schmalen Zipfel. 
<normalizedToken id="31785362CA77BE9B44998CB5983EEEE3" originalValue="Blütenstände" pageId="null" pageNumber="580">Bluetenstaende</normalizedToken>
meist 1 
<normalizedToken id="9B21B0A745D9542C7CE42F4064ED5290" originalValue="blütig" pageId="null" pageNumber="580">bluetig</normalizedToken>
. 
<emphasis id="569CCC162681ED9169ECBF639766633C" italics="true" pageId="null" pageNumber="580">
Stiel des 
<normalizedToken id="1FB90ACFFC9206CD2645D2361E4DBEC7" originalValue="Blütenstandes" pageId="null" pageNumber="580">Bluetenstandes</normalizedToken>
fast ohne Fortsatz
</emphasis>
(
<normalizedToken id="086E42AFF049926BF364B32F4B10D5D7" originalValue="±" pageId="null" pageNumber="580">+/-</normalizedToken>
direkt in den Stiel der einzigen [oder obersten] 
<normalizedToken id="B7223C1635F77798F3BB749400F36D8A" originalValue="Blüte" pageId="null" pageNumber="580">Bluete</normalizedToken>
<normalizedToken id="CCA067E768BF3E834B471F6C8F04AA69" originalValue="übergehend" pageId="null" pageNumber="580">uebergehend</normalizedToken>
), ⅓ 
<normalizedToken id="EF256BD36096BEFC5099651A56F685A5" originalValue="¾" pageId="null" pageNumber="580">3/4</normalizedToken>
<emphasis id="7B2589566D3A718EEFBA7B47CC54DE05" italics="true" pageId="null" pageNumber="580">
so lang wie das 
<normalizedToken id="85BA4E089D27177F7F5298B3A89B6E01" originalValue="nächststehende" pageId="null" pageNumber="580">naechststehende</normalizedToken>
Blatt.
</emphasis>
Kelch ⅓- 
<normalizedToken id="AFE56E22DCABCA5F0FF6E0156A19D0EC" originalValue="½" pageId="null" pageNumber="580">1/2</normalizedToken>
so lang wie die Krone; 
<emphasis id="450B245C46B22830ACA3643454A36937" italics="true" pageId="null" pageNumber="580">
<normalizedToken id="4259F487F5E83D391AA556C2348C6A22" originalValue="Kelchzähne" pageId="null" pageNumber="580">Kelchzaehne</normalizedToken>
<normalizedToken id="2FF2387C02400115667C61C115687F6A" originalValue="kürzer" pageId="null" pageNumber="580">kuerzer</normalizedToken>
als die 
<normalizedToken id="282071511C0BB89CF288A166F7758DCA" originalValue="Kelchröhre" pageId="null" pageNumber="580">Kelchroehre</normalizedToken>
.
</emphasis>
Krone 0,4-0,7 cm lang. Frucht 0,8-1,6 cm lang, 
<emphasis id="03E4F0E46323529CCB8AB2CF4FD6CF60" italics="true" pageId="null" pageNumber="580">kahl, meist 4samig.</emphasis>
Samen etwa 1 mm lang. - 
<normalizedToken id="678E122FADE1E19FBE3BD1FAC8E31F44" originalValue="Blüte" pageId="null" pageNumber="580">Bluete</normalizedToken>
: 
<normalizedToken id="5559E10170D2A91808870FD149349FE9" originalValue="Später" pageId="null" pageNumber="580">Spaeter</normalizedToken>
<normalizedToken id="FF21C3F0DD73D0C8883E3F3BC1430812" originalValue="Frühling" pageId="null" pageNumber="580">Fruehling</normalizedToken>
und 
<normalizedToken id="CBA375C59B5AB535F8345686A0BBCA7B" originalValue="früher" pageId="null" pageNumber="580">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="E6FA5DA0B49DF86A242BA8A11DC7FC78" pageId="null" pageNumber="580">
<emphasis id="41361F95EB5FEA7EFB0687E8AA0D5823" italics="true" pageId="null" pageNumber="580">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="913F118DB3C09D840E1A9A8A0A1EF6EF" italics="true" pageId="null" pageNumber="580">14:</emphasis>
Material aus Kulturen oder unbekannter Herkunft (Kawakami 1930, Srivastava 1963), aus Japan (Huziwara und Kondo 1963), aus der Slowakei (
<normalizedToken id="CD6A1A9E7AB6FCDE5B9166C6857869AC" originalValue="Činčura" pageId="null" pageNumber="580">Cincura</normalizedToken>
1963), aus Indien (Bir und Sidhu 1967), aus Holland (Gadella und Kliphuis 1966).
</paragraph>
<paragraph id="8E71652DB77C8C29394763818E85A34E" pageId="null" pageNumber="580">
<emphasis id="FCAC368D82910628D49827FC130EC411" italics="true" pageId="null" pageNumber="580">Standort.</emphasis>
Kollin und montan, selten subalpin. Lockere, kalkarme, sandige 
<normalizedToken id="3AC030EA128FF06B02E22BA65F2932BE" originalValue="Lehmböden" pageId="null" pageNumber="580">Lehmboeden</normalizedToken>
. Trockenwiesen, Getreidefelder, 
<normalizedToken id="BC293EB18C3E5CA10DE1E5501D929A33" originalValue="Äcker" pageId="null" pageNumber="580">Aecker</normalizedToken>
.
</paragraph>
<paragraph id="994868D008B87CC4BE11FF4289E15171" pageId="null" pageNumber="580">
<emphasis id="BDE6E374917B639224B1C3F75A386CD0" italics="true" pageId="null" pageNumber="580">
<pageBreakToken id="C248AF2017BA470C8E30DD7B3F32371C" pageId="null" pageNumber="580">Verbreitung</pageBreakToken>
. Eurasiatische Pflanze:
</emphasis>
Mittel- und 
<normalizedToken id="5A514648195DDEDC9503FFB91A3D19BF" originalValue="Südeuropa" pageId="null" pageNumber="580">Suedeuropa</normalizedToken>
(
<normalizedToken id="8949F1C9BB6904EC843D1C2A33B30B36" originalValue="nordwärts" pageId="null" pageNumber="580">nordwaerts</normalizedToken>
vereinzelt bis 
<normalizedToken id="344288EB9ECD928B186B4BBBCB4C7374" originalValue="Großbritannien" pageId="null" pageNumber="580">Grossbritannien</normalizedToken>
, 
<normalizedToken id="403D93C199D290D9347AB1D856C015FA" originalValue="Südskandinavien" pageId="null" pageNumber="580">Suedskandinavien</normalizedToken>
, Baltikum); Kaukasus, Kleinasien, 
<normalizedToken id="24770117CD9837754FBA39EEA3BDF9BF" originalValue="Südsibirien" pageId="null" pageNumber="580">Suedsibirien</normalizedToken>
(
<normalizedToken id="BC92E3444475E090394436DEDB7E772F" originalValue="ostwärts" pageId="null" pageNumber="580">ostwaerts</normalizedToken>
bis Baikalsee), Zentralasien; Nordwestafrika. - Im Gebiet ziemlich verbreitet, meist 
<normalizedToken id="317BF19063120DDD4C499A2117A68CDB" originalValue="häufig" pageId="null" pageNumber="580">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
