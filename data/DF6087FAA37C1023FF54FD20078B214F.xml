<bibRefCitation id="33584B1DA37E1023FE21F98A06102148" author="Lyon, R. J." box="[482,608,1617,1644]" pageId="15" pageNumber="16" pagination="181 - 192" refId="ref48106" refString="Lyon, R. J. (1996) New cynipid wasps from the Southwestern United States (Hymenoptera: Cynipidae). The Pan-Pacific Entomologist, 72 (4), 181 - 192." type="journal article" year="1996">Lyon 1996</bibRefCitation>
