<subSubSection id="D504C190170DAFBF93225B2E01FCB9F3" pageId="null" pageNumber="772" type="description">
<paragraph id="EDE49F3559827F069DA8970E68A326F3" pageId="null" pageNumber="772">
<normalizedToken id="FB7EC8DC3D701AFCA55D7FA05AF17C0D" originalValue="Blätter" pageId="null" pageNumber="772">Blaetter</normalizedToken>
ohne 
<normalizedToken id="E256B1BBE25E79DEFE7D2832AD0EFAFB" originalValue="Nebenblätter" pageId="null" pageNumber="772">Nebenblaetter</normalizedToken>
. 
<normalizedToken id="0FE9BE01349986F023F4F129B6416B10" originalValue="Kelchblätter" pageId="null" pageNumber="772">Kelchblaetter</normalizedToken>
verwachsen; Kelch 
<normalizedToken id="09A3812D5F347BA912A04E9039B6FF82" originalValue="röhrenförmig" pageId="null" pageNumber="772">roehrenfoermig</normalizedToken>
, oben etwas verengt, mit 
<normalizedToken id="B30D16F7152D660BD0AA60095D808A8D" originalValue="verlängerten" pageId="null" pageNumber="772">verlaengerten</normalizedToken>
<normalizedToken id="76C7EA173E53E37B1D4741BD0E5105AB" originalValue="Zähnen" pageId="null" pageNumber="772">Zaehnen</normalizedToken>
, 10rippig, am Grunde nicht von 
<normalizedToken id="894986A0B2070B63C45AABF9DF6A6F7C" originalValue="schuppenförmigen" pageId="null" pageNumber="772">schuppenfoermigen</normalizedToken>
<normalizedToken id="AF8A67C82EF8C17138DBAD820FA9C02E" originalValue="Blättern" pageId="null" pageNumber="772">Blaettern</normalizedToken>
<normalizedToken id="4EF80B3AAC692B55E7F50AE3DDCC3D81" originalValue="umhüllt" pageId="null" pageNumber="772">umhuellt</normalizedToken>
. 
<emphasis id="0F79F65E76ACD2312E34133BBF46C7A1" italics="true" pageId="null" pageNumber="772">
<normalizedToken id="0342C43745CF0C31F742893A5E38D084" originalValue="Kronblätter" pageId="null" pageNumber="772">Kronblaetter</normalizedToken>
<normalizedToken id="1BD4C4AEA2BEA6F9D80B956B7C748F8B" originalValue="kürzer" pageId="null" pageNumber="772">kuerzer</normalizedToken>
als der Kelch
</emphasis>
, ungeteilt, lang stielartig 
<normalizedToken id="AE62307F7C496FE1E24394F8FA95AB80" originalValue="verschmälert" pageId="null" pageNumber="772">verschmaelert</normalizedToken>
, ohne Schuppen (Nebenkrone) am Schlundeingang. 
<normalizedToken id="ED6D7715C2CC232987A1FE6B4B98053F" originalValue="Staubblätter" pageId="null" pageNumber="772">Staubblaetter</normalizedToken>
10. Griffel 5 (selten 4); Narbe behaart. Kapsel sich mit 5 
<normalizedToken id="8863B60B3E747F9BA25A84428E7D85A1" originalValue="Zähnen" pageId="null" pageNumber="772">Zaehnen</normalizedToken>
<normalizedToken id="1580FC27995EB8541F9B133A60DBD173" originalValue="öffnend" pageId="null" pageNumber="772">oeffnend</normalizedToken>
. 
<normalizedToken id="854F93F0C3FF4295D81C48AE3E748E99" originalValue="Fruchtblätter" pageId="null" pageNumber="772">Fruchtblaetter</normalizedToken>
zwischen den 
<normalizedToken id="A27A344D6F9B09DCDA0B8378EB2B759D" originalValue="Kelchblättern" pageId="null" pageNumber="772">Kelchblaettern</normalizedToken>
stehend (bei den verwandten Gattungen vor den 
<normalizedToken id="8BD29FC357C468B8C6D9C029F5F1C34A" originalValue="Kelchblättern" pageId="null" pageNumber="772">Kelchblaettern</normalizedToken>
). Samen 
<normalizedToken id="29B9ED3A790DE101EEB90782DC8ABE1C" originalValue="nierenförmig" pageId="null" pageNumber="772">nierenfoermig</normalizedToken>
, kaum abgeflacht, 
<normalizedToken id="DB546F69207E726482D8548BB939EBA2" originalValue="höckerig" pageId="null" pageNumber="772">hoeckerig</normalizedToken>
.
</paragraph>
<paragraph id="FB3AF24CF47A9A888E957DB2ACB84216" pageId="null" pageNumber="772">
Die Gattung 
<emphasis id="667DD047B50A7E276749DAC568111AC9" italics="true" pageId="null" pageNumber="772">
<taxonomicName id="E44132D276D676DAE96317C1532DEA2A" class="Magnoliopsida" family="Caryophyllaceae" genus="Agrostemma" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="772" phylum="Tracheophyta" rank="genus">Agrostemma</taxonomicName>
<normalizedToken id="273FACD8893B458628E7E2B7CE42CA8A" originalValue="umfaßt" pageId="null" pageNumber="772">umfasst</normalizedToken>
nur wenige ostmediterrane Arten
</emphasis>
.
</paragraph>
</subSubSection>
