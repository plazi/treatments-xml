<emphasis id="B955D64F6710E066B39DF9C9FEFB091A" bold="true" box="[151,276,1587,1613]" pageId="19" pageNumber="80">Diagnosis:</emphasis>
<materialsCitation id="3B4900006710E066B211F9C9FB620919" ID-GBIF-Occurrence="3763882302" box="[283,1165,1587,1614]" country="Switzerland, Italy, France" location="Switzerland, Italy, France" pageId="19" pageNumber="80" specimenCount="83" specimenCount-female="37" specimenCount-male="46">
