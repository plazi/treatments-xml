<taxonomicName id="00954D19FFBAFFC4C63707399797FE87" authorityName="Tikader" authorityYear="1977" box="[559,700,331,357]" class="Arachnida" family="Salticidae" genus="Rhene" kingdom="Animalia" order="Araneae" pageId="13" pageNumber="402" phylum="Arthropoda" rank="species" species="decoratus">
