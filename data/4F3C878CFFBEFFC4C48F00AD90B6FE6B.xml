<taxonomicName id="00954D19FFBAFFC4C6EB073996AEFE87" authorityName="Biswas &amp; Biswas" authorityYear="1992" box="[755,901,331,357]" class="Arachnida" family="Salticidae" genus="Rhene" kingdom="Animalia" order="Araneae" pageId="13" pageNumber="402" phylum="Arthropoda" rank="species" species="pantharae">
