<taxonomicName id="00954D19FFBAFFC4C60806E59670FF53" authority="(Thorell, 1895)" authorityName="Caleb &amp; Sanap &amp; Tripathi &amp; Sampathkumar &amp; Dharmaraj &amp; Packiam" authorityYear="2022" baseAuthorityName="Thorell" baseAuthorityYear="1895" box="[528,859,150,177]" class="Arachnida" family="Salticidae" genus="Rhene" kingdom="Animalia" order="Araneae" pageId="13" pageNumber="402" phylum="Arthropoda" rank="species" species="pallida" status="comb. n.">
<emphasis id="F5E1EA88FFBAFFC4C60806E59780FF53" box="[528,683,151,177]" italics="true" pageId="13" pageNumber="402">Rhene pallida</emphasis>
(
<bibRefCitation id="A3044B6BFFBAFFC4C6A106E59678FF53" author="Thorell, T." box="[697,851,150,177]" pageId="13" pageNumber="402" refId="ref8470" refString="Thorell, T. (1895) Descriptive catalogue of the spiders of Burma, based upon the collection made by Eugene W. Oates and preserved in the British Museum. Printed by order of the Trustees, London, 406 pp." type="book" year="1895">Thorell, 1895</bibRefCitation>
