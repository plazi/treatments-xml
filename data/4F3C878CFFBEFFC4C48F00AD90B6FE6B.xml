<bibRefCitation id="A3044B6BFFBBFFC5C03601C99016F837" author="Biswas, B. &amp; Biswas, K." box="[1070,1341,1979,2005]" pageId="12" pageNumber="401" pagination="357 - 500" refId="ref6755" refString="Biswas, B. &amp; Biswas, K. (1992) Araneae: Spiders. State Fauna Series 3: Fauna of West Bengal, 3, 357 - 500." type="journal article" year="1992">Biswas &amp; Biswas, 1992</bibRefCitation>
</taxonomicName>
