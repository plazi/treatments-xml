<collectingRegion id="0551F878FFBBFFC5C4CD01C9944FF837" box="[213,356,1979,2005]" country="India" name="West Bengal" pageId="12" pageNumber="401">West Bengal</collectingRegion>
(
<bibRefCitation id="A3044B6BFFBBFFC5C56B01C997A7F837" author="Tikader, B. K. &amp; Biswas, B." box="[371,652,1979,2005]" pageId="12" pageNumber="401" pagination="1 - 149" refId="ref8620" refString="Tikader, B. K. &amp; Biswas, B. (1981) Spider fauna of Calcutta and vicinity: Part-I. Records of the Zoological Survey of India, Occasional Paper, 30, 1 - 149." type="journal article" year="1981">Tikader &amp; Biswas, 1981</bibRefCitation>
; 
<bibRefCitation id="A3044B6BFFBBFFC5C68101C99679F837" author="Roy, T. K. &amp; Saha, S. &amp; Raychaudhuri, D." box="[665,850,1978,2005]" pageId="12" pageNumber="401" pagination="1 - 66" refId="ref7934" refString="Roy, T. K., Saha, S. &amp; Raychaudhuri, D. (2016) A treatise on the jumping spiders (Araneae: Salticidae) of tea ecosystem of Dooars, West Bengal, India. World Scientific News, 53 (1), 1 - 66." type="journal article" year="2016">
