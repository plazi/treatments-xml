<figureCitation id="5FAE2A1FFFBAFFC4C0AF0771901EFEFF" box="[1207,1333,259,285]" captionStart="FIGURES 42–50" captionStartId="11.[151,264,1908,1932]" captionTargetBox="[188,1396,189,1856]" captionTargetId="figure-17@11.[187,1401,181,1884]" captionTargetPageId="11" captionText="FIGURES 42–50. Somatic morphology and copulatory organs of Rhene decorata Tikader, 1977: 42—holotype female habitus, dorsal view; 43—ditto, front view; 44—epigyne, ventral view; 45—vulva, dorsal view; 46—paratype female habitus, dorsal view; 47—ditto, front view; 48—ditto, epigyne, ventral view; 49, 50—label. Scale bars: (44, 45, 48) 0.1 mm, (42, 43, 46, 47) 0.5 mm." figureDoi="http://doi.org/10.5281/zenodo.6450933" httpUri="https://zenodo.org/record/6450933/files/figure.png" pageId="13" pageNumber="402">Figs 42–48</figureCitation>
