<emphasis id="F5E1EA88FFBBFFC5C6C801C99629F837" box="[720,770,1979,2005]" italics="true" pageId="12" pageNumber="401">et al</emphasis>
., 2016
</bibRefCitation>
) and 
<taxonomicName id="00954D19FFBBFFC5C78A01C99016F837" authority="Biswas &amp; Biswas, 1992" authorityName="Biswas &amp; Biswas" authorityYear="1992" box="[914,1341,1979,2005]" class="Arachnida" family="Salticidae" genus="Rhene" kingdom="Animalia" order="Araneae" pageId="12" pageNumber="401" phylum="Arthropoda" rank="species" species="pantharae">
