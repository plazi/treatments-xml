<figureCitation id="5FAE2A1FFFBAFFC4C174077195F6FEA3" captionStart="FIGURES 51–56" captionStartId="12.[151,264,1620,1644]" captionTargetBox="[151,1436,190,1594]" captionTargetId="figure-19@12.[151,1436,181,1596]" captionTargetPageId="12" captionText="FIGURES 51–56. Somatic morphology and copulatory organs of Rhene pantharae Biswas &amp; Biswas, 1992, holotype female: 51—habitus, dorsal view; 52—ditto, lateral view; 53—ditto, front view; 54—epigyne, ventral view; 55—vulva, dorsal view; 56—label. Scale bars: (54, 55) 0.05 mm, (51–53) 0.5 mm." figureDoi="http://doi.org/10.5281/zenodo.6450937" httpUri="https://zenodo.org/record/6450937/files/figure.png" pageId="13" pageNumber="402">Figs 51–55</figureCitation>
with figs 
<quantity id="006D9B7FFFBAFFC4C54007549489FEA3" box="[344,418,294,321]" metricMagnitude="-1" metricUnit="m" metricValue="1.651" metricValueMax="2.032" metricValueMin="1.27" pageId="13" pageNumber="402" unit="in" value="6.5" valueMax="8.0" valueMin="5.0">5–8 in</quantity>
<bibRefCitation id="A3044B6BFFBAFFC4C5B3075597BBFEA3" author="Wesolowska, W." box="[427,656,295,321]" pageId="13" pageNumber="402" pagination="45 - 83" refId="ref8762" refString="Wesolowska, W. (1981) Salticidae (Aranei) from North Korea, China and Mongolia. Annales Zoologici, Warszawa, 36, 45 - 83." type="journal article" year="1981">Wesołowska (1981)</bibRefCitation>
, illustrations in 
<bibRefCitation id="A3044B6BFFBAFFC4C75507559173FEA3" author="Proszynski, J." box="[845,1112,295,321]" pageId="13" pageNumber="402" pagination="1 - 177" refId="ref7795" refString="Proszynski, J. (1984) Atlas rysunkow diagnostycznych mniej znanych Salticidae (Araneae). Zeszyty Naukowe Wyzszej Szkoly Rolniczo-Pedagogicznej w Siedlcach, 2, 1 - 177." type="journal article" year="1984">Proszynski (1984: 123)</bibRefCitation>
and figs 
<quantity id="006D9B7FFFBAFFC4C0D207549067FEA3" box="[1226,1356,294,321]" metricMagnitude="1" metricUnit="m" metricValue="1.6357599999999999" metricValueMax="1.6382999999999999" metricValueMin="1.6332200000000001" pageId="13" pageNumber="402" unit="in" value="644.0" valueMax="645.0" valueMin="643.0">643–645 in</quantity>
<bibRefCitation id="A3044B6BFFBAFFC4C14E075595C5FE87" author="Zabka, M." pageId="13" pageNumber="402" pagination="197 - 485" refId="ref8837" refString="Zabka, M. (1985) Systematic and zoogeographic study on the family Salticidae (Araneae) from Viet-Nam. Annales Zoologici, Warszawa, 39, 197 - 485." type="journal article" year="1985">Zabka (1985))</bibRefCitation>
