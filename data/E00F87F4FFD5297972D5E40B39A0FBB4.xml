Saussure, 1869
</taxonomicName>
[
<taxonomicName id="AFA64D61FFD5297973C9E40B39CAFC15" box="[404,505,883,906]" class="Insecta" family="Acontistidae" genus="Acontista" kingdom="Animalia" order="Mantodea" pageId="2" pageNumber="263" phylum="Arthropoda" rank="genus">
