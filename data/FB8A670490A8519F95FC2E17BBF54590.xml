<geoCoordinate id="CD5D46C1AD50F0B1BDA111DACE275B5E" degrees="29" direction="north" minutes="40" orientation="latitude" precision="15" seconds="43" value="29.67861">29°40'43&quot;N</geoCoordinate>
, 
<geoCoordinate id="B4EAC30132003B11F83D06A6505B25F7" degrees="109" direction="east" minutes="44" orientation="longitude" precision="15" seconds="60" value="109.75">109°44'60&quot;E</geoCoordinate>
, 1610 m, 29 June 2021, 
<emphasis id="7EB417DCA0CC728E7154B6623BA84532" italics="true" pageId="0" pageNumber="127">Z.Y. Niu</emphasis>
NZY109 (IBSC).
</paragraph>
</subSubSection>
