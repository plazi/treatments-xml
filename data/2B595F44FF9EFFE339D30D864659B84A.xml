<emphasis id="91843240FF9FFFE338E40BF44538BBF3" box="[447,534,194,220]" italics="true" pageId="17" pageNumber="244">Vainilla</emphasis>
, 
<emphasis id="91843240FF9FFFE33B730BF44551BBF3" box="[552,639,194,220]" italics="true" pageId="17" pageNumber="244">Vainillo</emphasis>
</taxonomicName>
, 
<emphasis id="91843240FF9FFFE33BCB0BF54438BBF2" box="[656,790,195,221]" italics="true" pageId="17" pageNumber="244">
<collectingRegion id="613420B0FF9FFFE33BCB0BF54438BBF2" box="[656,790,195,221]" country="Costa Rica" name="Guanacaste" pageId="17" pageNumber="244">Guanacaste</collectingRegion>
</emphasis>
, 
<emphasis id="91843240FF9FFFE33A7C0BF544A8BBF2" box="[807,902,195,221]" italics="true" pageId="17" pageNumber="244">Guinazo</emphasis>
, 
<emphasis id="91843240FF9FFFE33ACC0BF4432BBBF3" box="[919,1029,194,220]" italics="true" pageId="17" pageNumber="244">Gallinazo</emphasis>
(
<collectingCountry id="DBE7AEC2FF9FFFE33D430BF443B2BBF2" box="[1048,1180,194,221]" name="Costa Rica" pageId="17" pageNumber="244">Costa Rica</collectingCountry>
); 
<emphasis id="91843240FF9FFFE33DE90BF44285BBF3" box="[1202,1451,194,220]" italics="true" pageId="17" pageNumber="244">Guachipelín-colorado</emphasis>
(
<collectingCountry id="DBE7AEC2FF9FFFE339CB0BD04624BA2E" box="[144,266,230,257]" name="Nicaragua" pageId="17" pageNumber="244">Nicaragua</collectingCountry>
