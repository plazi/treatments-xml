<subSubSection id="37FB61CF5DEF2BC3A2A4CD3B3474AED6" pageId="null" pageNumber="469" type="description">
<paragraph id="BB5C9E2E67C5BC4CB820D54F20F4A8E9" pageId="null" pageNumber="469">
Strauch bis 1,5 m hoch, aufrecht, selten niederliegend. 
<normalizedToken id="D854437176F24AEF0D270520DD89C13C" originalValue="Blätter" pageId="null" pageNumber="469">Blaetter</normalizedToken>
oval, 1,5-4 cm lang, 
<normalizedToken id="0A1914B9638E7B86B54047A3929C316E" originalValue="1½" pageId="null" pageNumber="469">11/2</normalizedToken>
-2mal so lang wie breit, mit der 
<normalizedToken id="58D0E5CF6AB485896331F1E6F168525A" originalValue="größten" pageId="null" pageNumber="469">groessten</normalizedToken>
Breite in oder unterhalb der Mitte, 
<emphasis id="9BD7970FDBC725DA98A8D5134D5154D3" italics="true" pageId="null" pageNumber="469">oberseits kahl</emphasis>
, 
<normalizedToken id="C4A3DF25A23BAE4534D20B04F9561078" originalValue="grün" pageId="null" pageNumber="469">gruen</normalizedToken>
, unterseits dicht filzig behaart, grau bis 
<normalizedToken id="D6AF1FA63F469991A2ED2AA1FAA18CB7" originalValue="weiß" pageId="null" pageNumber="469">weiss</normalizedToken>
. 
<normalizedToken id="942543FAFC593760411A379C6AB29844" originalValue="Blütenstände" pageId="null" pageNumber="469">Bluetenstaende</normalizedToken>
1-5 
<normalizedToken id="721F7432BC3077509700CF3814983BAC" originalValue="blütig" pageId="null" pageNumber="469">bluetig</normalizedToken>
. 
<emphasis id="1ABA37A5D5D897049B00CA26F23113BA" italics="true" pageId="null" pageNumber="469">
Kelchbecher und 
<normalizedToken id="9E537D81D20F7B199411C9C52F81A8E0" originalValue="Kelchblätter" pageId="null" pageNumber="469">Kelchblaetter</normalizedToken>
<normalizedToken id="78ACE3B1B8BCC72A1D82ED30436CA8D4" originalValue="außerseits" pageId="null" pageNumber="469">ausserseits</normalizedToken>
kahl
</emphasis>
, rotbraun; 
<normalizedToken id="B9D27EAED9825D57712D38F27E858011" originalValue="Kelchblätter" pageId="null" pageNumber="469">Kelchblaetter</normalizedToken>
1,5-2 mm lang. 
<normalizedToken id="F5F5572D9F99CA0A63F6125129BF30FB" originalValue="Kronblätter" pageId="null" pageNumber="469">Kronblaetter</normalizedToken>
rund, die 
<normalizedToken id="1AA4CCC10E7844E36F848D80F0136EC0" originalValue="Kelchblätter" pageId="null" pageNumber="469">Kelchblaetter</normalizedToken>
<normalizedToken id="EB020ED8F9FC5C00BB953432D787F241" originalValue="überragend" pageId="null" pageNumber="469">ueberragend</normalizedToken>
, 
<normalizedToken id="AFF5E7B0EA081317586E584D7F20B7A7" originalValue="weiß" pageId="null" pageNumber="469">weiss</normalizedToken>
bis blaurot. 
<normalizedToken id="9C692733DEE93C07C32FFCC9B0A65357" originalValue="Staubblätter" pageId="null" pageNumber="469">Staubblaetter</normalizedToken>
20. Griffel meist 2, seltener 4-5. Scheinfrucht rot, 
<emphasis id="811B15C4D8D612E55C1BDCF79641D57A" italics="true" pageId="null" pageNumber="469">kahl</emphasis>
, kugelig, im Durchmesser 6-8 mm. - 
<normalizedToken id="AE90797C1A6DB3A6AE1B20AE0D67C34F" originalValue="Blüte" pageId="null" pageNumber="469">Bluete</normalizedToken>
: 
<normalizedToken id="4F22E2609B0DD3E74600DA29A18F85E6" originalValue="Frühling" pageId="null" pageNumber="469">Fruehling</normalizedToken>
und 
<normalizedToken id="164F2485034747705F5D8094B2AC4E1C" originalValue="früher" pageId="null" pageNumber="469">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="DDBA2131DAF53A80DBF038872C65D5D4" pageId="null" pageNumber="469">
<emphasis id="AB7A4274459AB8FCD1F8E1F1FC7B96DB" italics="true" pageId="null" pageNumber="469">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A8AC56BEC7120DFC7CEE914027F207F2" italics="true" pageId="null" pageNumber="469">34:</emphasis>
Material aus den Westalpen (Favarger 1969). 
<emphasis id="C26FCC6A0FC4C36C837B4FB8F7D230DD" italics="true" pageId="null" pageNumber="469">2n</emphasis>
= 
<emphasis id="0AB3A75ABCDC8DAE54AFBD45379D6E83" italics="true" pageId="null" pageNumber="469">51:</emphasis>
Material aus botanischen 
<normalizedToken id="7188ED034E393B6FD5BE7449E8DA9075" originalValue="Gärten" pageId="null" pageNumber="469">Gaerten</normalizedToken>
, apomiktische Fortpflanzung (Sax 1954), von der Krim (Gladkova 1968). 
<emphasis id="1AD0AD85510ED620B8D7DE24203F916A" italics="true" pageId="null" pageNumber="469">2n</emphasis>
= 
<emphasis id="678B42C7E37B7BCC9CD57D7CFA690C88" italics="true" pageId="null" pageNumber="469">68:</emphasis>
Material aus 
<normalizedToken id="C514D89F42811F3584DF9184B72C3982" originalValue="Rußland" pageId="null" pageNumber="469">Russland</normalizedToken>
(Gladkova 1968). 
<emphasis id="780ED3770925476E4E345BCB13D9A9E9" italics="true" pageId="null" pageNumber="469">2n ca. 68:</emphasis>
Gegend von Neuenburg (Favarger 1969).
</paragraph>
<paragraph id="E3D9351124A41C6189BA4047EE1A3A38" pageId="null" pageNumber="469">
<emphasis id="42C7B140470889F9860D6DAE1232A971" italics="true" pageId="null" pageNumber="469">Standort.</emphasis>
Montan und subalpin, selten alpin. Kalkhaltige, aber auch saure, trockene, 
<normalizedToken id="5E70BECDCE8307D86628BA53D8CE1262" originalValue="flachgründige" pageId="null" pageNumber="469">flachgruendige</normalizedToken>
<normalizedToken id="9AD992D1AD5C9FDAD7DDE80EE1A911DA" originalValue="Böden" pageId="null" pageNumber="469">Boeden</normalizedToken>
in 
<normalizedToken id="924B9F3CDB6021C55CBF8FF7C9AEBD66" originalValue="wärmeren" pageId="null" pageNumber="469">waermeren</normalizedToken>
Lagen. 
<normalizedToken id="9312DF593F080EE71F2D8CE33473AE68" originalValue="Felsbänder" pageId="null" pageNumber="469">Felsbaender</normalizedToken>
, Felsspalten und Blockschutt, 
<normalizedToken id="8B8AF785C9E6AC8AFCA5D9FFE2164D9A" originalValue="Wälder" pageId="null" pageNumber="469">Waelder</normalizedToken>
, 
<normalizedToken id="5419EF62B8F8D877C58980F3D3ED3B4B" originalValue="Gebüsch" pageId="null" pageNumber="469">Gebuesch</normalizedToken>
. Besonders 
<emphasis id="D210184386ECAEF9B2026162B38D28EF" italics="true" pageId="null" pageNumber="469">Cotoneastro-Amelanchieretum</emphasis>
Fab. 1936.
</paragraph>
<paragraph id="21958399238ECE09B2AB51B8C914B8CC" pageId="null" pageNumber="469">
<emphasis id="CFFC479870CD05A093265798CEC700DD" italics="true" pageId="null" pageNumber="469">
Verbreitung. 
<normalizedToken id="3347B26FDB249162DBD87C64D9581E3A" originalValue="Europäisch-südwestasiatische" pageId="null" pageNumber="469">Europaeisch-suedwestasiatische</normalizedToken>
Pflanze:
</emphasis>
Nordgrenze durch England, Mittelskandinavien, 
<normalizedToken id="16A076A720528C06FF5D10995D80DE93" originalValue="Südfinnland" pageId="null" pageNumber="469">Suedfinnland</normalizedToken>
(
<normalizedToken id="4716CDAAFCA0293EA774071414B8E59B" originalValue="Küstengebiete" pageId="null" pageNumber="469">Kuestengebiete</normalizedToken>
); 
<normalizedToken id="06E6877084336702E47F6F73242BDC6A" originalValue="Südgrenze" pageId="null" pageNumber="469">Suedgrenze</normalizedToken>
durch die Gebirge von Nordspanien, 
<normalizedToken id="111300D1631E537C99C8FD1872432929" originalValue="Süditalien" pageId="null" pageNumber="469">Sueditalien</normalizedToken>
, der Balkanhalbinsel und des 
<normalizedToken id="A22C04101C2DB901C02FF692886C65A3" originalValue="nördlichen" pageId="null" pageNumber="469">noerdlichen</normalizedToken>
Kleinasien; 
<normalizedToken id="EE6AA97FA3AFFDCBFFFADF6DB7D84B84" originalValue="ostwärts" pageId="null" pageNumber="469">ostwaerts</normalizedToken>
bis Kaukasus und Nordiran. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet verbreitet, besonders in den Alpen 
<normalizedToken id="8893686A60A54960B1D1ACA67972155D" originalValue="häufig" pageId="null" pageNumber="469">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
