<paragraph pageId="0" pageNumber="103">
<taxonomicName LSID="E9A18FF0-8FCE-54B7-856D-47E562340DB7" authority="sp. 1" authorityName="sp. 1" class="Actinopterygii" family="Myctophidae" genus="Diaphus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Diaphus" order="Myctophiformes" pageId="0" pageNumber="103" phylum="Chordata" rank="genus">Diaphus sp.1</taxonomicName>
