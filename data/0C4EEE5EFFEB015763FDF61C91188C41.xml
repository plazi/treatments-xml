<subSubSection id="CCFD0CC3FFEB015763A5F6CC91188C41" pageId="9" pageNumber="32" type="discussion">
<paragraph id="84585F48FFEB015763A5F6CC91188C41" blockId="9.[151,760,1740,1891]" pageId="9" pageNumber="32">
<emphasis id="B693835AFFEB015763A5F6CC92688DC1" bold="true" box="[151,281,1740,1763]" pageId="9" pageNumber="32">Comments.</emphasis>
To date 
<taxonomicName id="43E724CBFFEB0157624AF6CC912A8DC1" authorityName="Baly" authorityYear="1888" box="[376,603,1740,1763]" class="Insecta" family="Chrysomelidae" genus="Platyxantha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="32" phylum="Arthropoda" rank="species" species="clypeata">
<emphasis id="B693835AFFEB0157624AF6CC912A8DC1" box="[376,603,1740,1763]" italics="true" pageId="9" pageNumber="32">Platyxantha clypeata</emphasis>
</taxonomicName>
was classified in 
<taxonomicName id="43E724CBFFEB01576381F6EC92698C21" authorityName="Baly" authorityYear="1879" box="[179,280,1772,1795]" class="Insecta" family="Chrysomelidae" genus="Acroxena" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="32" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFEB01576381F6EC92698C21" box="[179,280,1772,1795]" italics="true" pageId="9" pageNumber="32">Acroxena</emphasis>
</taxonomicName>
(
<bibRefCitation id="E07622B9FFEB0157621AF6EC92CA8C21" author="MAULIK S." bookContentInfo="xiv + 648 pp. + 1 pl." box="[296,443,1772,1795]" editor="SEWELL R. B. S." firstAuthor="MAULIK" journalOrPublisher="Taylor and Francis, London" pageId="9" pageNumber="32" refId="ref32093" refString="MAULIK S. 1936: Coleoptera, Chrysomelidae (Galerucinae). In: SEWELL R. B. S. (ed.): The fauna of British India including Ceylon and Burma. Taylor and Francis, London, xiv + 648 pp. + 1 pl." title="Coleoptera, Chrysomelidae (Galerucinae)" type="book chapter" volumeTitle="The fauna of British India including Ceylon and Burma" year="1936">MAULIK 1936</bibRefCitation>
, 
<bibRefCitation id="E07622B9FFEB015762F4F6EC91298C21" author="WILCOX J. A." box="[454,600,1772,1795]" editor="WILCOX J. A." firstAuthor="WILCOX" journalOrPublisher="Editio seconda. W. Junk, ' s-Gravenhage" pageId="9" pageNumber="32" pagination="433 - 664" refId="ref33616" refString="WILCOX J. A. 1973: Chrysomelidae: Galerucinae: Luperini: Luperina. In: WILCOX J. A. (ed.): Coleopterorum Catalogus Supplementa. Pars 78 (3). Editio seconda. W. Junk, ' s-Gravenhage, pp. 433 - 664." title="Chrysomelidae: Galerucinae: Luperini: Luperina" type="book chapter" volumeTitle="Coleopterorum Catalogus Supplementa. Pars 78 (3)." year="1973">WILCOX 1973</bibRefCitation>
). Based on the presence of a metasternal process and strongly modified head in the male 
<typeStatus id="5B5CE1EAFFEB01576277F72C92EB8C61" box="[325,410,1836,1859]" pageId="9" pageNumber="32">syntype</typeStatus>
, I hereby transfer it to 
<taxonomicName id="43E724CBFFEB015761B3F72C91868C61" authorityName="Thunberg" authorityYear="1814" box="[641,759,1836,1859]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="32" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFEB015761B3F72C91868C61" box="[641,759,1836,1859]" italics="true" pageId="9" pageNumber="32">Taumacera</emphasis>
</taxonomicName>
and assign it to the 
<taxonomicName id="43E724CBFFEB01576254F74C92B68C41" authorityName="Baly" authorityYear="1879" box="[358,455,1868,1891]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="32" phylum="Arthropoda" rank="species" species="nasuta">
<emphasis id="B693835AFFEB01576254F74C92B68C41" box="[358,455,1868,1891]" italics="true" pageId="9" pageNumber="32">T. nasuta</emphasis>
</taxonomicName>
species-group.
</paragraph>
