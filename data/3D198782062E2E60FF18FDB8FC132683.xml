<paragraph id="B50F3694062C2E60FF48FE81FC132683" blockId="6.[151,1437,151,969]" box="[199,1017,942,969]" pageId="6" pageNumber="307">
<emphasis id="87C4EA86062C2E60FF48FE81FEB32682" bold="true" box="[199,345,942,968]" pageId="6" pageNumber="307">Distribution</emphasis>
. Known only from northwestern 
<collectingCountry id="CDA77604062C2E60FD40FE80FCD32683" box="[719,825,943,969]" name="Australia" pageId="6" pageNumber="307">Australia</collectingCountry>
. Depth 
<quantity id="72489B71062C2E60FC00FE80FC1F2683" box="[911,1013,943,969]" metricMagnitude="1" metricUnit="m" metricValue="4.25" metricValueMax="4.9" metricValueMin="3.6" pageId="6" pageNumber="307" unit="m" value="42.5" valueMax="49.0" valueMin="36.0">
36– 
<specimenCount id="A3B6FD1D062C2E60FC36FE80FC1F2683" box="[953,1013,943,969]" pageId="6" pageNumber="307" type="generic">49 m</specimenCount>
</quantity>
.
</paragraph>
