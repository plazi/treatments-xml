<paragraph id="016C1165FFB13969EBD2C0F7FDCA5CE8" blockId="31.[227,565,1988,2014]" box="[227,565,1988,2014]" pageId="31" pageNumber="32">
<heading id="5A24A609FFB13969EBD2C0F7FDCA5CE8" bold="true" box="[227,565,1988,2014]" fontSize="11" level="3" pageId="31" pageNumber="32" reason="3">
<emphasis id="33A7CD77FFB13969EBD2C0F7FDCA5CE8" bold="true" box="[227,565,1988,2014]" pageId="31" pageNumber="32">
Dimensions of the 
<typeStatus id="DE68AFC7FFB13969EAF8C0F7FDCA5CE8" box="[457,565,1988,2014]" pageId="31" pageNumber="32">holotype</typeStatus>
</emphasis>
</heading>
</paragraph>
<paragraph id="016C1165FFB13969EBD2C0C7FC555339" blockId="31.[227,938,2036,2063]" box="[227,938,2036,2063]" pageId="31" pageNumber="32">
Length = 2.00 mm; height = 
<quantity id="C62BBC80FFB13969E904C0C7FD5E5339" box="[565,673,2036,2063]" metricMagnitude="-3" metricUnit="m" metricValue="1.91" pageId="31" pageNumber="32" unit="mm" value="1.91">1.91 mm</quantity>
; thickness = 
<quantity id="C62BBC80FFB13969E80BC0C7FC5A5339" box="[826,933,2036,2063]" metricMagnitude="-3" metricUnit="m" metricValue="1.43" pageId="31" pageNumber="32" unit="mm" value="1.43">1.43 mm</quantity>
