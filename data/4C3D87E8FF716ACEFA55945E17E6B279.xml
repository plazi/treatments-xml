<taxonomicName id="03944D7DFF716ACEF6FF957C1400B874" box="[2307,2560,805,838]" class="Mammalia" family="Vespertilionidae" genus="Kerivoula" kingdom="Animalia" order="Chiroptera" pageId="138" pageNumber="898" phylum="Chordata" rank="species" species="krauensis">Kerivoula krauensis</taxonomicName>
