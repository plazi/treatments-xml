<taxonomicName id="4C424D5686096B2FF7A28045F76FF3C3" authorityName="Yoo" authorityYear="1994" box="[2170,2293,3121,3160]" class="Gastropoda" family="Elasmonematidae" genus="Kimina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Vetigastropoda" pageId="27" pageNumber="90" phylum="Mollusca" rank="genus">
