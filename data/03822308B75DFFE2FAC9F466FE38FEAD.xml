<taxonomicName id="4C2BE99DB75CFFE2FF68FB11FDABF295" authority="Blanford, 1875" authorityName="Blanford" authorityYear="1875" box="[195,608,1194,1227]" class="Mammalia" family="Leporidae" genus="Lepus" kingdom="Animalia" order="Lagomorpha" pageId="27" pageNumber="134" phylum="Chordata" rank="subSpecies" species="tibetanus" subSpecies="craspedotis">L.t.craspedotisBlanford,1875—BalochistanProvince(Pakistan).</taxonomicName>
</paragraph>
<paragraph id="8B94921EB75CFFE2FF68FB6AFB5DF2AC" blockId="27.[190,1400,722,2291]" box="[195,1174,1233,1266]" pageId="27" pageNumber="134">
<taxonomicName id="4C2BE99DB75CFFE2FF68FB6AFD91F2AC" authority="Gunther, 1875" authorityName="Gunther" authorityYear="1875" box="[195,602,1233,1266]" class="Mammalia" family="Leporidae" genus="Lepus" kingdom="Animalia" order="Lagomorpha" pageId="27" pageNumber="134" phylum="Chordata" rank="subSpecies" species="tibetanus" subSpecies="pamirensis">L.t.pamirensisGunther,1875—ETajikistanandSWXinjiang(China).</taxonomicName>
</paragraph>
<paragraph id="8B94921EB75CFFE2FF68FB47FC07F347" blockId="27.[190,1400,722,2291]" box="[195,972,1276,1305]" pageId="27" pageNumber="134">
<taxonomicName id="4C2BE99DB75CFFE2FF68FB47FDBAF347" authority="Blanford, 1875" authorityName="Blanford" authorityYear="1875" box="[195,625,1276,1305]" class="Mammalia" family="Leporidae" genus="Lepus" kingdom="Animalia" order="Lagomorpha" pageId="27" pageNumber="134" phylum="Chordata" rank="subSpecies" species="tibetanus" subSpecies="stoliczkanus">L. t. stoliczkanus Blanford, 1875</taxonomicName>
— NW Xinjiang (China).
