<subSubSection id="9BB96018F1FDADE2D62FD8284AB22498" pageId="null" pageNumber="657" type="vernacular_names">
<paragraph id="880FCA514D0928C4DDA5EAFA3CA0BA1E" pageId="null" pageNumber="657">Gefleckte Wolfsmilch</paragraph>
</subSubSection>
</title>
<subSubSection id="5EA5BA643B9AB21196AEE1C37651D04D" pageId="null" pageNumber="657" type="description">
<paragraph id="41596067676628AB1875B78C7F1362AE" pageId="null" pageNumber="657">
Pflanze meist flaumig behaart. 
<normalizedToken id="4FD4E6117C27A569C3B52D0A6C4A136D" originalValue="Blätter" pageId="null" pageNumber="657">Blaetter</normalizedToken>
0,5-1 cm lang, 
<emphasis id="B7D2B5BCB900BD17853A9EF91904CD35" italics="true" pageId="null" pageNumber="657">2</emphasis>
<normalizedToken id="B77E2D483EE310124D58B548CFB97837" originalValue="½" pageId="null" pageNumber="657">1/2</normalizedToken>
- 
<emphasis id="397DDC4C84A9DAB3F4AB5E94609836B1" italics="true" pageId="null" pageNumber="657">3mal so lang wie breit</emphasis>
, oberseits 
<normalizedToken id="3D9C3734F6CEADF2C59CB9BACFEA157F" originalValue="häufig" pageId="null" pageNumber="657">haeufig</normalizedToken>
mit rotem Fleck (die andern Arten selten mit Fleck). 
<normalizedToken id="F4427B26CE2033FC897F4582E17D5D92" originalValue="Hüllbecher" pageId="null" pageNumber="657">Huellbecher</normalizedToken>
und Frucht 
<normalizedToken id="4E2258DD95C2E8B04759EC9FC71DBB58" originalValue="überall" pageId="null" pageNumber="657">ueberall</normalizedToken>
und meist locker behaart. Samen 0,7-1 mm lang, 0,5-0,7 mm dick, stumpfkantig, 
<emphasis id="C4BDDED3AE53FA24D9854A8A217B4169" italics="true" pageId="null" pageNumber="657">
mit 3-6 oft undeutlichen, stumpfen 
<normalizedToken id="4BB6055D592119BE1ED7D3F95423E40B" originalValue="Querwülsten" pageId="null" pageNumber="657">Querwuelsten</normalizedToken>
</emphasis>
auf jeder 
<normalizedToken id="AE1231A17BB2E27BD2FA63FAE6516B5D" originalValue="Fläche" pageId="null" pageNumber="657">Flaeche</normalizedToken>
(10fache 
<normalizedToken id="15D5FE7E59119D6409170CE54BC60245" originalValue="Vergrößerung" pageId="null" pageNumber="657">Vergroesserung</normalizedToken>
!), 
<normalizedToken id="1FA99CD3F39D995FDB0FF2BBF9F1785F" originalValue="rötlich" pageId="null" pageNumber="657">roetlich</normalizedToken>
.
</paragraph>
<paragraph id="A76F26BEA755FFCE1ED362A01F0D0595" pageId="null" pageNumber="657">
<emphasis id="6DEB53B6D1DC0BACDAA25183AA08DE24" italics="true" pageId="null" pageNumber="657">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D2F815AE0AAECD21C036EA2C93502E24" italics="true" pageId="null" pageNumber="657">28:</emphasis>
Material aus Virginia, USA (Perry 1943).
</paragraph>
<paragraph id="22E3C99183372FB22E2DD9307FDF23E6" pageId="null" pageNumber="657">
<emphasis id="60E7CFC2A3DDCD91163D939BE92188B8" italics="true" pageId="null" pageNumber="657">Standort</emphasis>
. Kollin, Trockene. steinige 
<normalizedToken id="0BE09387E01836ACADEAEB3FED8C07E4" originalValue="Böden" pageId="null" pageNumber="657">Boeden</normalizedToken>
. Gartenwege, 
<normalizedToken id="15B242780930B67EFEDEE1FCCF08ABF9" originalValue="Straßenpflaster" pageId="null" pageNumber="657">Strassenpflaster</normalizedToken>
, Bahnareale, Ruderalsstellen.
</paragraph>
<paragraph id="2904B7551C454FC34324D372ED794AAD" pageId="null" pageNumber="657">
<emphasis id="643865EDA5A7999478CDBAEFBD138FF7" italics="true" pageId="null" pageNumber="657">Verbreitung</emphasis>
. 
<normalizedToken id="E3CE67F158B1658BBFCA9190D13F1923" originalValue="Ursprünglich" pageId="null" pageNumber="657">Urspruenglich</normalizedToken>
<emphasis id="D19D24D268A99AEEE40A7ED9963E98FB" italics="true" pageId="null" pageNumber="657">nordamerikanische Pflanze;</emphasis>
heute weit verbreitet. - Im Gebiet verbreitet, besonders in den 
<normalizedToken id="318B711784587F0BED24DC4EBCD64E53" originalValue="wärmeren" pageId="null" pageNumber="657">waermeren</normalizedToken>
Gegenden ziemlich 
<normalizedToken id="4FA46BC21354B73CAC12DABEACAA2E92" originalValue="häufig" pageId="null" pageNumber="657">haeufig</normalizedToken>
und 
<normalizedToken id="86CDD2AE793BAD4306CCEE5B8B1605FD" originalValue="eingebürgert" pageId="null" pageNumber="657">eingebuergert</normalizedToken>
.
</paragraph>
<paragraph id="126E0101B058A2EF30CE04C185A877E5" pageId="null" pageNumber="657">
<emphasis id="C0C34D1C8266AE3F16D0EE91188F38F6" italics="true" pageId="null" pageNumber="657">Bemerkungen</emphasis>
. Von Janchen (1963) wird 
<normalizedToken id="A6BC059F03710B6D03375444FA9D1652" originalValue="für" pageId="null" pageNumber="657">fuer</normalizedToken>
<taxonomicName id="6997DF75B80FAEA4E812044931B45C38" authority="der Name" authorityName="der Name" class="Magnoliopsida" family="Euphorbiaceae" genus="Euphorbia" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="657" phylum="Tracheophyta" rank="species" species="maculata">
<emphasis id="4D9D40F8FD68C33ECAA466AF93B5F748" italics="true" pageId="null" pageNumber="657">E. maculata</emphasis>
der Name
</taxonomicName>
<taxonomicName id="FCB07897DEC8D2C983CE68D2A1573BC8" authority="Rafin." authorityName="Rafin." class="Magnoliopsida" family="Euphorbiaceae" genus="Euphorbia" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="657" phylum="Tracheophyta" rank="species" species="supina">
<emphasis id="E28D97A381B4A24667D541DB396C9665" italics="true" pageId="null" pageNumber="657">E. supina</emphasis>
Rafin.
</taxonomicName>
vorgeschlagen.
</paragraph>
</subSubSection>
