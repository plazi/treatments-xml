<subSubSection id="C374652CFFC9FFA2D4CCFC2508C5FB12" pageId="52" pageNumber="53" type="diagnosis">
<paragraph id="8BD136A7FFC9FFA2D4CCFC2508C5FB12" blockId="52.[151,1437,766,2017]" pageId="52" pageNumber="53">
<emphasis id="B91AEAB5FFC9FFA2D4CCFC250C1AFC3B" bold="true" box="[199,322,910,936]" pageId="52" pageNumber="53">Diagnosis.</emphasis>
Males of 
<taxonomicName id="4C6E4D24FFC9FFA2D5B9FC240E27FC3A" authority="Jocque &amp; Baert, 2002" authorityName="Jocque &amp; Baert" authorityYear="2002" box="[434,895,911,937]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="52" pageNumber="53" phylum="Arthropoda" rank="species" species="peckorum">
<emphasis id="B91AEAB5FFC9FFA2D5B9FC240FD9FC3A" box="[434,641,911,937]" italics="true" pageId="52" pageNumber="53">Tenedos peckorum</emphasis>
<bibRefCitation id="EFFF4B56FFC9FFA2D683FC240E27FC3A" author="Jocque, R. &amp; Baert, L." box="[648,895,911,937]" pageId="52" pageNumber="53" pagination="67 - 173" refId="ref79332" refString="Jocque, R. &amp; Baert, L. (2002) A revision of the Neotropical spider genera Tenedos O. P. - Cambridge and Ishania Chamberlin (Araneae, Zodariidae). Bulletin de l'Institut Royal des Sciences Naturelles de Belgique, Entomologie, 72, 67 - 173." type="journal article" year="2002">Jocqué &amp; Baert, 2002</bibRefCitation>
</taxonomicName>
, resemble those of 
<taxonomicName id="4C6E4D24FFC9FFA2D05DFC24098AFC3A" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" box="[1110,1234,911,937]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="52" pageNumber="53" phylum="Arthropoda" rank="species" species="henrardi" status="sp. n.">
<emphasis id="B91AEAB5FFC9FFA2D05DFC24098AFC3A" box="[1110,1234,911,937]" italics="true" pageId="52" pageNumber="53">T. henrardi</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFC9FFA2D0D2FC240840FC3A" bold="true" box="[1241,1304,911,937]" pageId="52" pageNumber="53">
<taxonomicNameLabel id="A22957CEFFC9FFA2D0D2FC240840FC3A" box="[1241,1304,911,937]" pageId="52" pageNumber="53" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
and 
<taxonomicName id="4C6E4D24FFC9FFA2D145FC240DBAFC5E" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="52" pageNumber="53" phylum="Arthropoda" rank="species" species="guacharos" status="sp. n.">
<emphasis id="B91AEAB5FFC9FFA2D145FC240DBAFC5E" italics="true" pageId="52" pageNumber="53">T. guacharos</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFC9FFA2D4E1FC180C72FC5E" bold="true" box="[234,298,947,973]" pageId="52" pageNumber="53">
<taxonomicNameLabel id="A22957CEFFC9FFA2D4E1FC180C72FC5E" box="[234,298,947,973]" pageId="52" pageNumber="53" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
, by having bifid median apophysis (MA), quadrangular-shaped anterior branch (aMA); complex retrolateral tibial apophysis (RTA) (see 
<bibRefCitation id="EFFF4B56FFC9FFA2D63EFC7C0E3AFC62" author="Jocque, R. &amp; Baert, L." box="[565,866,983,1009]" pageId="52" pageNumber="53" pagination="67 - 173" refId="ref79332" refString="Jocque, R. &amp; Baert, L. (2002) A revision of the Neotropical spider genera Tenedos O. P. - Cambridge and Ishania Chamberlin (Araneae, Zodariidae). Bulletin de l'Institut Royal des Sciences Naturelles de Belgique, Entomologie, 72, 67 - 173." type="journal article" year="2002">Jocqué &amp; Baert, 2002: 111</bibRefCitation>
, fig. 29A–B; figs 34C–F; 36A–D; 37A–B; 39C–F; 40C–D; 42A–D; 43A–B; 44A–F), but differ by large median apophysis, posterior branch (pMA) longer than anterior one, straight; posterior branch of retrolateral tibial apophysis (pRTA) long, wide, with thin longitudinal furrow, small apical denticles on ventral edge (
<figureCitation id="13552A22FFC9FFA2D64AFBE80F90FBCE" box="[577,712,1091,1117]" captionStart="FIGURE 34" captionStartId="53.[151,250,1465,1489]" captionTargetBox="[178,1421,181,1441]" captionTargetId="figure-19@53.[151,1436,181,1441]" captionTargetPageId="53" captionText="FIGURE 34. Tenedos peckorum Jocqué &amp; Baert, 2002.A–B. Male habitus (AMNH_IZC 00217588):A. Dorsal view. B. Ventral view. C–F. Male right palp: C. Ventral view. D. Prolateral view. E. Retroventral view. F. Retrolateral view. Scale bars: A–B: 2mm; C–D: 200µm; E–F: 500µm." figureDoi="http://doi.org/10.5281/zenodo.6520848" httpUri="https://zenodo.org/record/6520848/files/figure.png" pageId="52" pageNumber="53">Figs 34C–F</figureCitation>
; 
<figureCitation id="13552A22FFC9FFA2D6DAFBE80E7FFBCE" box="[721,807,1091,1117]" captionStart="FIGURE 36" captionStartId="55.[151,250,1943,1967]" captionTargetBox="[240,1348,189,1920]" captionTargetId="figure-19@55.[240,1348,181,1920]" captionTargetPageId="55" captionText="FIGURE 36. Tenedos peckorum Jocqué &amp; Baert, 2002. A–D. Male palp (MPUJ_ENT 0070625): A. Prolateral view. B. Retroventral view. C. Ventral view. D. Retrolateral view. E–F. Female epigyne (IAvH-I-3765): C. Ventral view. D. Dorsal view. Scale bars: A–D: 300µm; E–F: 200µm." figureDoi="http://doi.org/10.5281/zenodo.6520854" httpUri="https://zenodo.org/record/6520854/files/figure.png" pageId="52" pageNumber="53">36A–D</figureCitation>
; 
<figureCitation id="13552A22FFC9FFA2D73AFBE80EDEFBCE" box="[817,902,1091,1117]" captionStart="FIGURE 37" captionStartId="56.[151,250,1505,1529]" captionTargetBox="[161,1436,186,1470]" captionTargetId="figure-27@56.[151,1436,181,1481]" captionTargetPageId="56" captionText="FIGURE 37. Tenedos peckorum Jocqué &amp; Baert, 2002. A–B. Male palp (MPUJ_ENT 0070625): A. Ventral view. B. Retrolateral view. C–D. Female epigyne (IAvH-I-3765): C. Ventral view. D. Dorsal view. Scale bars: A–B: 200µm; C–D: 500µm. Abbreviations: aMA, anterior branch of the median apophysis; C, conductor; CD, copulatory ducts; FD, fertilization ducts; pRTA, posterior branch of the retrolateral tibial apophysis; pMA, posterior branch of the median apophysis; MFP, median field plate; S, spermathecae; SD, spermatic ducts; SR, seminal receptacles; T, tegulum." figureDoi="http://doi.org/10.5281/zenodo.6520858" httpUri="https://zenodo.org/record/6520858/files/figure.png" pageId="52" pageNumber="53">37A–B</figureCitation>
). Females are characterized by very thin seminal receptacles (SR); laminar, quadrangular median field plate (MFP); small spermathecae (S) (
<figureCitation id="13552A22FFC9FFA2D0ACFBCC0876FB12" box="[1191,1326,1127,1153]" captionStart="FIGURE 36" captionStartId="55.[151,250,1943,1967]" captionTargetBox="[240,1348,189,1920]" captionTargetId="figure-19@55.[240,1348,181,1920]" captionTargetPageId="55" captionText="FIGURE 36. Tenedos peckorum Jocqué &amp; Baert, 2002. A–D. Male palp (MPUJ_ENT 0070625): A. Prolateral view. B. Retroventral view. C. Ventral view. D. Retrolateral view. E–F. Female epigyne (IAvH-I-3765): C. Ventral view. D. Dorsal view. Scale bars: A–D: 300µm; E–F: 200µm." figureDoi="http://doi.org/10.5281/zenodo.6520854" httpUri="https://zenodo.org/record/6520854/files/figure.png" pageId="52" pageNumber="53">Figs 36E–F</figureCitation>
; 
<figureCitation id="13552A22FFC9FFA2D130FBCC08C8FB12" box="[1339,1424,1127,1153]" captionStart="FIGURE 37" captionStartId="56.[151,250,1505,1529]" captionTargetBox="[161,1436,186,1470]" captionTargetId="figure-27@56.[151,1436,181,1481]" captionTargetPageId="56" captionText="FIGURE 37. Tenedos peckorum Jocqué &amp; Baert, 2002. A–B. Male palp (MPUJ_ENT 0070625): A. Ventral view. B. Retrolateral view. C–D. Female epigyne (IAvH-I-3765): C. Ventral view. D. Dorsal view. Scale bars: A–B: 200µm; C–D: 500µm. Abbreviations: aMA, anterior branch of the median apophysis; C, conductor; CD, copulatory ducts; FD, fertilization ducts; pRTA, posterior branch of the retrolateral tibial apophysis; pMA, posterior branch of the median apophysis; MFP, median field plate; S, spermathecae; SD, spermatic ducts; SR, seminal receptacles; T, tegulum." figureDoi="http://doi.org/10.5281/zenodo.6520858" httpUri="https://zenodo.org/record/6520858/files/figure.png" pageId="52" pageNumber="53">37C–D</figureCitation>
).
</paragraph>
</subSubSection>
<subSubSection id="C374652CFFC9FFA3D4CCFB2109FCF859" lastPageId="53" lastPageNumber="54" pageId="52" pageNumber="53" type="description">
<paragraph id="8BD136A7FFC9FFA2D4CCFB210857F872" blockId="52.[151,1437,766,2017]" pageId="52" pageNumber="53">
<emphasis id="B91AEAB5FFC9FFA2D4CCFB210C2DFB37" bold="true" box="[199,373,1162,1188]" pageId="52" pageNumber="53">Redescription.</emphasis>
<emphasis id="B91AEAB5FFC9FFA2D577FB200CEEFB36" box="[380,438,1163,1189]" italics="true" pageId="52" pageNumber="53">Male</emphasis>
(
<typeStatus id="54D58805FFC9FFA2D5CFFB200F69FB36" box="[452,561,1163,1189]" pageId="52" pageNumber="53">Holotype</typeStatus>
, AMNH_IZC 00217588). 
<materialsCitation id="3B063CFAFFC9FFA2D751FB200853F872" collectionCode="II, III, RPC, T, EB, BTM, VTA, RTA" collectorName="Coloration &amp; Chelicerae &amp; Endites &amp; Labium &amp; Legs &amp; Femora I &amp; Patellae I &amp; Tibia I" pageId="52" pageNumber="53" specimenCount="1">
<collectorName id="269B5371FFC9FFA2D751FB200E8AFB36" box="[858,978,1163,1189]" pageId="52" pageNumber="53">Coloration</collectorName>
(
<figureCitation id="13552A22FFC9FFA2D7EAFB200936FB36" box="[993,1134,1163,1189]" captionStart="FIGURE 34" captionStartId="53.[151,250,1465,1489]" captionTargetBox="[178,1421,181,1441]" captionTargetId="figure-19@53.[151,1436,181,1441]" captionTargetPageId="53" captionText="FIGURE 34. Tenedos peckorum Jocqué &amp; Baert, 2002.A–B. Male habitus (AMNH_IZC 00217588):A. Dorsal view. B. Ventral view. C–F. Male right palp: C. Ventral view. D. Prolateral view. E. Retroventral view. F. Retrolateral view. Scale bars: A–B: 2mm; C–D: 200µm; E–F: 500µm." figureDoi="http://doi.org/10.5281/zenodo.6520848" httpUri="https://zenodo.org/record/6520848/files/figure.png" pageId="52" pageNumber="53">Figs 34A–B</figureCitation>
; 
<figureCitation id="13552A22FFC9FFA2D072FB210988FB36" box="[1145,1232,1162,1189]" captionStart="FIGURE 35" captionStartId="54.[151,250,1943,1967]" captionTargetBox="[257,1331,181,1919]" captionTargetId="figure-27@54.[257,1331,181,1919]" captionTargetPageId="54" captionText="FIGURE 35. Tenedos peckorum Jocqué &amp; Baert, 2002. A–B. Male habitus (MPUJ_ENT 0070625): A. Dorsal view. B. Ventral view. C–D. Female habitus (IAvH-I-3765): C. Dorsal view. D. Ventral view. Scale bar: A–D: 2.5mm." figureDoi="http://doi.org/10.5281/zenodo.6520852" httpUri="https://zenodo.org/record/6520852/files/figure.png" pageId="52" pageNumber="53">35A–B</figureCitation>
): carapace brownreddish, dark brown in margins. 
<collectorName id="269B5371FFC9FFA2D5F5FB040F2EFB5A" box="[510,630,1199,1225]" pageId="52" pageNumber="53">Chelicerae</collectorName>
with paturon dark brown on base and brown-reddish fangs. 
<collectorName id="269B5371FFC9FFA2D104FB04083BFB5A" box="[1295,1379,1199,1225]" pageId="52" pageNumber="53">Endites</collectorName>
light brown, white on anterior region. 
<collectorName id="269B5371FFC9FFA2D604FB780F3EFB7E" box="[527,614,1235,1261]" pageId="52" pageNumber="53">Labium</collectorName>
and sternum brown. 
<collectorName id="269B5371FFC9FFA2D753FB780ECBFB7E" box="[856,915,1235,1261]" pageId="52" pageNumber="53">Legs</collectorName>
: coxae I–IV light yellow. 
<collectorName id="269B5371FFC9FFA2D0B1FB780879FB7E" box="[1210,1313,1235,1261]" pageId="52" pageNumber="53">Femora I</collectorName>
–IV brown with light spots. 
<collectorName id="269B5371FFC9FFA2D547FB5C0CEBFA82" box="[332,435,1271,1297]" pageId="52" pageNumber="53">Patellae I</collectorName>
–IV light brown. 
<collectorName id="269B5371FFC9FFA2D664FB5C0FEFFA82" box="[623,695,1271,1297]" pageId="52" pageNumber="53">Tibia I</collectorName>
yellow, 
<collectionCode id="ED7FAE62FFC9FFA2D718FB5C0E7DFA82" box="[787,805,1271,1297]" pageId="52" pageNumber="53">II</collectionCode>
–IV light brown, metatarsi-tarsi 
<collectionCode id="ED7FAE62FFC9FFA2D08CFB5C09C1FA82" box="[1159,1177,1271,1297]" pageId="52" pageNumber="53">II</collectionCode>
–IV light brown.Abdomen: dorsally dark gray with five white guanine spots organized as follows: two small and rounded spots very close to each other, anteriorly positioned; two rounded spots and larger than ones, medially positioned; one transversal and wide band, posteriorly positioned. Laterally gray without spots. Ventrally gray with three longitudinal and very thin stripes. Measurements: total length 6.16, carapace length 3.46, width 2.01, height 1.39. Clypeus height 0.66. Eye diameters and interdistances: AME 0.11, ALE 0.13, PME 0.11, PLE 0.15; AME–AME 0.27, AME–ALE 0.28, AME–PME 0.33, PME–PME 0.31, PME–PLE 0.43, ALE–PLE 0.31. Chelicerae length 1.14 length. Sternum length 1.23, width 1.19. Legs: I—femur 1.86/ patella 0.51/ tibia 2.26/ metatarsus 2.09/ tarsus 1.24/ total 7.96; 
<collectionCode id="ED7FAE62FFC9FFA2D13EFA58081FF99E" box="[1333,1351,1523,1549]" pageId="52" pageNumber="53">II</collectionCode>
—1.63/ 0.45/ 1.73/ 1.74/ 0.94/ 6.49; 
<collectionCode id="ED7FAE62FFC9FFA2D5D0F9BC0CAFF9A2" box="[475,503,1559,1585]" pageId="52" pageNumber="53">III</collectionCode>
—1.81/ 0.53/ 1.59/ 1.87/ 0.89/ 6.69; IV—2.31/ 0.73/ 1.93/ 2.83/ 1.12/ 8.92. Abdomen length 2.73. Legs spines pattern (only the differences from the general pattern): 
<collectionCode id="ED7FAE62FFC9FFA2D049F9900905F9C6" box="[1090,1117,1595,1621]" pageId="52" pageNumber="53">III</collectionCode>
—femur r0-1-1d, metatarsus p0-1-2; IV—femur p1d-0-1d, r0, metatarsus d1p-1p-0. Palp: retrolateral process of cymbium (
<collectionCode id="ED7FAE62FFC9FFA2D0A4F9F409BFF9EA" box="[1199,1255,1631,1657]" pageId="52" pageNumber="53">RPC</collectionCode>
) long, widening towards base, external edge rounded; tegulum (
<collectionCode id="ED7FAE62FFC9FFA2D6B8F9280F9EF90E" box="[691,710,1667,1693]" name="Tavera, Department of Geology and Geophysics" pageId="52" pageNumber="53">T</collectionCode>
) small, rounded, longer than wide; subtegulum (St) longer than wide, covered by conductor in ventral view, rounded external edge; conductor (C) developed, wide, with small basal projection, with short, wide sclerotized region on distal side; appendix (ApC) long, apically sharp; embolus (E) long, filiform towards apex; base of embolus (
<collectionCode id="ED7FAE62FFC9FFA2D6ACF9440F95F89A" box="[679,717,1775,1801]" pageId="52" pageNumber="53">EB</collectionCode>
) approximately as long as three times basal tegular membrane, with small rounded projection; basal tegular membrane (
<collectionCode id="ED7FAE62FFC9FFA2D71FF8B80E0CF8BE" box="[788,852,1811,1837]" pageId="52" pageNumber="53">BTM</collectionCode>
) originated proximally on tegulum, proximally flattened, ending as appendix apically squared; spermatic ducts (SD) S-shaped, both folds full open, thin; ventral tibial apophysis (
<collectionCode id="ED7FAE62FFC9FFA2D512F8F00C0CF8E6" box="[281,340,1883,1909]" country="France" name="Jardin Botanique de la Villa Thuret" pageId="52" pageNumber="53" type="Herbarium">VTA</collectionCode>
) small, short, anteriorly projected; median apophysis (MA) large, bifid, anterior branch (aMA) squared-shaped, laminar, large, rounded at anterior edge, posterior branch (pMA) long, wide at base; retrolateral tibial apophysis (
<collectionCode id="ED7FAE62FFC9FFA2D552F8080CC9F82E" box="[345,401,1955,1981]" pageId="52" pageNumber="53">RTA</collectionCode>
) very large, posterior branch (pRTA) very wide provided, rounded at apex, anterior branch (aRTA) thin, laminar, longer than palpal tibia, surpassing external side (
<figureCitation id="13552A22FFC9FFA2D7B2F86C091AF872" box="[953,1090,1991,2017]" captionStart="FIGURE 34" captionStartId="53.[151,250,1465,1489]" captionTargetBox="[178,1421,181,1441]" captionTargetId="figure-19@53.[151,1436,181,1441]" captionTargetPageId="53" captionText="FIGURE 34. Tenedos peckorum Jocqué &amp; Baert, 2002.A–B. Male habitus (AMNH_IZC 00217588):A. Dorsal view. B. Ventral view. C–F. Male right palp: C. Ventral view. D. Prolateral view. E. Retroventral view. F. Retrolateral view. Scale bars: A–B: 2mm; C–D: 200µm; E–F: 500µm." figureDoi="http://doi.org/10.5281/zenodo.6520848" httpUri="https://zenodo.org/record/6520848/files/figure.png" pageId="52" pageNumber="53">Figs 34C–F</figureCitation>
; 
