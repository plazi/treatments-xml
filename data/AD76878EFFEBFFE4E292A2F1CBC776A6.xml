<taxonomicName id="E2DF4D1BFFEBFFE7E319A52ECCF7730A" authority="(Cockerell, 1914)" baseAuthorityName="Cockerell" baseAuthorityYear="1914" box="[284,695,1864,1888]" class="Insecta" family="Chrysopidae" genus="Archaeochrysa" kingdom="Animalia" order="Neuroptera" pageId="5" pageNumber="306" phylum="Arthropoda" rank="species" species="fracta">
<emphasis id="17ABEA8AFFEBFFE7E319A52ECFBA730A" box="[284,506,1864,1888]" italics="true" pageId="5" pageNumber="306">Archaeochrysa fracta</emphasis>
(
<bibRefCitation id="414E4B69FFEBFFE7E00DA52ECCF0730A" author="Cockerell, T. D. A." box="[520,688,1864,1888]" pageId="5" pageNumber="306" pagination="714 - 724" refId="ref23258" refString="Cockerell, T. D. A. (1914) New and little-known insects from the Miocene of Florissant, Colorado. Journal of Geology, 22, 714 - 724. https: // doi. org / 10.1086 / 622186" type="journal article" year="1914">Cockerell, 1914</bibRefCitation>
