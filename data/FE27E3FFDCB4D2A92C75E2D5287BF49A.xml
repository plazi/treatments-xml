<subSubSection id="3FE9AD8C59678735FD846A2B30FE3B56" pageId="null" pageNumber="335" type="description">
<paragraph id="1F7C60B3472A613A880F67BAC1BBDBD8" pageId="null" pageNumber="335">
Unterscheidet sich von 
<taxonomicName id="2D1202357111C2B6A2CC87443D5D20A0" class="Magnoliopsida" family="Caprifoliaceae" genus="Valerianella" kingdom="Plantae" order="Dipsacales" pageId="null" pageNumber="335" phylum="Tracheophyta" rank="species" species="carinata">
<emphasis id="8E49FA2CC0C71B79D3486F9571809422" italics="true" pageId="null" pageNumber="335">V. carinata</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<normalizedToken id="07D41471332BD53E0A03F7EC4F4EDD14" originalValue="Grundständige" pageId="null" pageNumber="335">Grundstaendige</normalizedToken>
<normalizedToken id="56890E3BD5528EDAB7D3D48C75C3821F" originalValue="Blätter" pageId="null" pageNumber="335">Blaetter</normalizedToken>
oft lanzettlich, 
<emphasis id="10B808DA9EB7E03DD280E962125F6FE9" italics="true" pageId="null" pageNumber="335">4</emphasis>
- 
<emphasis id="3F7EE9035965828908E01E3E5AA65DE6" italics="true" pageId="null" pageNumber="335">8mal so lang wie breit</emphasis>
, die obern 
<normalizedToken id="6AEE7445660B2B9E6604BE5A11F2A678" originalValue="Stengelblätter" pageId="null" pageNumber="335">Stengelblaetter</normalizedToken>
stets spitz, am Grunde meist mit einzelnen 
<normalizedToken id="8752D08D2F3628DE4A362344A895672C" originalValue="Zähnen" pageId="null" pageNumber="335">Zaehnen</normalizedToken>
(
<normalizedToken id="0CCDE3D68C2AC90BEFDEA951823CC62B" originalValue="Zähne" pageId="null" pageNumber="335">Zaehne</normalizedToken>
<normalizedToken id="8630F4712919F183A98EB23ADB130A35" originalValue="½" pageId="null" pageNumber="335">1/2</normalizedToken>
-2mal so lang wie die Blattbreite); 
<emphasis id="0EC5D47A47ACCF36A5C4C8899424CAAA" italics="true" pageId="null" pageNumber="335">
<normalizedToken id="8A54D564D018701F4C2ACCEBE8E1DD85" originalValue="Teilfruchtstände" pageId="null" pageNumber="335">Teilfruchtstaende</normalizedToken>
<normalizedToken id="DDC6BAC2B8423622376074A4B0ECD14F" originalValue="schirmförmig" pageId="null" pageNumber="335">schirmfoermig</normalizedToken>
;
</emphasis>
<normalizedToken id="1206E5A33B9B8083659646A15A70B15B" originalValue="Früchte" pageId="null" pageNumber="335">Fruechte</normalizedToken>
mit Kelch 2,5-3 mm lang, meist kahl; 
<emphasis id="161DFC283BC79D74798BB2ED3AB38AE5" italics="true" pageId="null" pageNumber="335">
die beiden sterilen 
<normalizedToken id="C89763456727115ACCA6D6972BAEA9E4" originalValue="Fruchtfächer" pageId="null" pageNumber="335">Fruchtfaecher</normalizedToken>
so 
<normalizedToken id="0BC2FAAF6FE985C9A24AFC35AECBCC9A" originalValue="groß" pageId="null" pageNumber="335">gross</normalizedToken>
wie das fertile Fach; zwischen den sterilen 
<normalizedToken id="EB44AD7AB32E3E6103A1EF97F6259D40" originalValue="Fächern" pageId="null" pageNumber="335">Faechern</normalizedToken>
eine schmale Furche; Kelch auf der Frucht fast nur 
<normalizedToken id="451D93F02D65C607AA6FC96546DF994C" originalValue="über" pageId="null" pageNumber="335">ueber</normalizedToken>
dem fertilen Fach entwickelt; aus einem 0,4
</emphasis>
- 
<emphasis id="FB18959B7DF7A31DE8A9EDAE206E2E42" italics="true" pageId="null" pageNumber="335">0,5 mm langen Zahn bestehend</emphasis>
(
<emphasis id="6D3AB48609D645BFA9F896A575F23C02" italics="true" pageId="null" pageNumber="335">am Grunde des Zahns gelegentlich noch jederseits mit 1</emphasis>
- 
<emphasis id="E0B96D3301960F1E834B6B120FF75CF8" italics="true" pageId="null" pageNumber="335">
2 bis 0,1 mm langen 
<normalizedToken id="8278E0DD2D19458A44224E35DE314CBC" originalValue="Zähnen" pageId="null" pageNumber="335">Zaehnen</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="E731D1DCE3FB04BCA44CCD249A1E85F2" originalValue="Blüte" pageId="null" pageNumber="335">Bluete</normalizedToken>
: 
<normalizedToken id="46A7D46A8745BE6D78274BDE9C94B87D" originalValue="Später" pageId="null" pageNumber="335">Spaeter</normalizedToken>
<normalizedToken id="32A678082614AB5D4CA85A9831A20956" originalValue="Frühling" pageId="null" pageNumber="335">Fruehling</normalizedToken>
und 
<normalizedToken id="359A9843B438A1406BBD6A0D075A259C" originalValue="früher" pageId="null" pageNumber="335">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="980675AB5F021E4210C56BC38D6012AD" pageId="null" pageNumber="335">
<emphasis id="872EB21D19B5FF18043DC9953C544D58" italics="true" pageId="null" pageNumber="335">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="FAABCDCD706240CFECD58605C5713A7E" italics="true" pageId="null" pageNumber="335">14:</emphasis>
Material aus botanischem Garten (Elvers 1932a).
</paragraph>
<paragraph id="01CA4CAA0D1763BD6387450A1C0723B1" pageId="null" pageNumber="335">
<emphasis id="94ED3DFA20AC81623F7573672390FAA5" italics="true" pageId="null" pageNumber="335">Standort.</emphasis>
Kollin und montan. 
<normalizedToken id="A2487A600D9CEB139D95C0CE8EA0E684" originalValue="Nährstoffreiche" pageId="null" pageNumber="335">Naehrstoffreiche</normalizedToken>
, oft kalkarme, lehmige 
<normalizedToken id="D0B08E9948A733A7DF79A74A23DB2E75" originalValue="Böden" pageId="null" pageNumber="335">Boeden</normalizedToken>
in 
<normalizedToken id="5E5DF3A4603FDA9D3BC1C8B62FBD6CED" originalValue="wärmeren" pageId="null" pageNumber="335">waermeren</normalizedToken>
Lagen. 
<normalizedToken id="94DAE72B80EA6B6E81F1814662E31797" originalValue="Äcker" pageId="null" pageNumber="335">Aecker</normalizedToken>
, Getreidefelder.
</paragraph>
<paragraph id="866FF1549A26C7F062C82C5BBE0C4FEA" pageId="null" pageNumber="335">
<emphasis id="2CCDE7637C79810EE5593F2E7618A0B5" italics="true" pageId="null" pageNumber="335">
Verbreitung. 
<normalizedToken id="8BDC04BAE6AB9536B0718B0BEBB6C544" originalValue="Westeuropäisch-mediterrane" pageId="null" pageNumber="335">Westeuropaeisch-mediterrane</normalizedToken>
Pflanze:
</emphasis>
Europa (
<normalizedToken id="2EC786327D72A842770CAF2DEB7FD6DF" originalValue="nordwärtsbis" pageId="null" pageNumber="335">nordwaertsbis</normalizedToken>
England, Norddeutschland, Westpolen); Kaukasus; Nordwestafrika. - Im Gebiet zerstreut (besonders im westlichen und 
<normalizedToken id="30C30DDF15EECCB325F800606CAC45BE" originalValue="nördlichen" pageId="null" pageNumber="335">noerdlichen</normalizedToken>
Teil), nicht 
<normalizedToken id="0639F7A690CF429167DAF314EDC1D2C0" originalValue="häufig" pageId="null" pageNumber="335">haeufig</normalizedToken>
, heute an vielen Orten verschwunden.
</paragraph>
</subSubSection>
