<paragraph id="8BE88677E10C1E61D2837549FAFFF9F7" blockId="5.[136,1452,1571,2065]" box="[136,1377,1571,1597]" pageId="5" pageNumber="279">
<emphasis id="B9235A65E10C1E61D2837549FE97F9F7" bold="true" box="[136,265,1571,1597]" pageId="5" pageNumber="279">Etymology</emphasis>
. 
<taxonomicName id="4C57FDF4E10C1E61D31C7549FE0BF9F7" box="[279,405,1571,1597]" class="Sordariomycetes" family="Pestalotiopsidaceae" genus="Pseudopestalotiopsis" kingdom="Fungi" order="Amphisphaeriales" pageId="5" pageNumber="279" phylum="Ascomycota" rank="species" species="indocalami">
