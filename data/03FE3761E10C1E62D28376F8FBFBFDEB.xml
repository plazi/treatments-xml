</taxonomicName>
, refers to the host plant (
<taxonomicName id="4C57FDF4E10C1E61D0A57549FC24F9F7" box="[686,954,1571,1597]" class="Liliopsida" family="Poaceae" genus="Indocalamus" kingdom="Plantae" order="Poales" pageId="5" pageNumber="279" phylum="Tracheophyta" rank="species" species="tessellatus">
