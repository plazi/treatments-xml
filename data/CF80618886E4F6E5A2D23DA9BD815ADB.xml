<subSubSection id="0F6DA37B8F3ED62F223764A106D9EB40" pageId="null" pageNumber="657" type="vernacular_names">
<paragraph id="63A7489A12332D89A89E65586B8C3657" pageId="null" pageNumber="657">Niederliegende Wolfsmilch</paragraph>
</subSubSection>
</title>
<subSubSection id="E275D2BD2150EED523D2D4B974BC28A2" pageId="null" pageNumber="657" type="description">
<paragraph id="7CB083B655C224621EDA10B6BAC2BFBA" pageId="null" pageNumber="657">
Pflanze stets 
<normalizedToken id="20532B11FFBB3F2455C120215CBF44D5" originalValue="vollständig" pageId="null" pageNumber="657">vollstaendig</normalizedToken>
kahl. 
<normalizedToken id="3774BAABC4CE214796E747A695856372" originalValue="Blätter" pageId="null" pageNumber="657">Blaetter</normalizedToken>
bis 1 cm lang, 
<emphasis id="541431C13A8A4B66F1227B24A701694B" italics="true" pageId="null" pageNumber="657">
<normalizedToken id="3A74BFDB802671A290E800EF5077D5CD" originalValue="länger" pageId="null" pageNumber="657">laenger</normalizedToken>
als breit, 
<normalizedToken id="46E20B2BB71971FFEE190AAD753717AB" originalValue="höchstens" pageId="null" pageNumber="657">hoechstens</normalizedToken>
2mal so lang wie breit
</emphasis>
. 
<normalizedToken id="1F1498537FFBA1CFD337FDE5F292D770" originalValue="Hüllbecher" pageId="null" pageNumber="657">Huellbecher</normalizedToken>
und Frucht 
<normalizedToken id="BA926BA54E01ABFD5602A46CE5427605" originalValue="vollständig" pageId="null" pageNumber="657">vollstaendig</normalizedToken>
kahl. Samen 1-1,3 mm lang, 0,6-0,8 mm dick, mit 3 oder 4 stumpfen Kanten, 
<emphasis id="10C71E4278F7C68E10D78345C7837698" italics="true" pageId="null" pageNumber="657">glatt</emphasis>
(bei 25facher 
<normalizedToken id="26ABCBC67291D9ADCB5624A7E294635D" originalValue="Vergrößerung" pageId="null" pageNumber="657">Vergroesserung</normalizedToken>
<normalizedToken id="C9306F4F69604F0048103833875F5D18" originalValue="Oberfläche" pageId="null" pageNumber="657">Oberflaeche</normalizedToken>
fein und 
<normalizedToken id="FCDA8115F0E1A43D1C510AA06373ED65" originalValue="regelmäßig" pageId="null" pageNumber="657">regelmaessig</normalizedToken>
punktiert), 
<normalizedToken id="0E2EE7E0FB5588234E4CFC5210A8E424" originalValue="weiß" pageId="null" pageNumber="657">weiss</normalizedToken>
bis graubraun.
</paragraph>
<paragraph id="39DE9C198F743D58F5374CABAF03008F" pageId="null" pageNumber="657">
<emphasis id="16E4AC3629173AD23E1BC611F1ADE6D7" italics="true" pageId="null" pageNumber="657">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="47E9ACCBA17085C7076194E789306B52" italics="true" pageId="null" pageNumber="657">22:</emphasis>
Material aus botanischem Garten (Reese in 
<normalizedToken id="7CB20078D06F0D4CBC75DA0D3E318C87" originalValue="Löve" pageId="null" pageNumber="657">Loeve</normalizedToken>
und 
<normalizedToken id="776FCE76D669641E39F1579161648DBF" originalValue="Löve" pageId="null" pageNumber="657">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="9D22F09B2222913F4A2EECA26E7483D2" pageId="null" pageNumber="657">
<emphasis id="93759BEED4C35464B93F7407E1164E56" italics="true" pageId="null" pageNumber="657">Standort</emphasis>
. Kollin. Sommertrockene, steinige 
<normalizedToken id="91C909371A7927541697FE9544876779" originalValue="Böden" pageId="null" pageNumber="657">Boeden</normalizedToken>
. Bahnareale, 
<normalizedToken id="5644ED316BA479C2F9F9516A77272D1B" originalValue="Ödland" pageId="null" pageNumber="657">Oedland</normalizedToken>
, 
<normalizedToken id="231F22316FE4213F085D05EFF4F745F7" originalValue="Straßenpflaster" pageId="null" pageNumber="657">Strassenpflaster</normalizedToken>
.
</paragraph>
<paragraph id="C39C7F71697ABB3C04F9A7E2BD1D8DF4" pageId="null" pageNumber="657">
<emphasis id="5B447C5BA4A8CB58F194B3ED0FCD84E3" italics="true" pageId="null" pageNumber="657">Verbreitung</emphasis>
. 
<normalizedToken id="AD5AE879641EB45FA0CC6788D325934C" originalValue="Ursprünglich" pageId="null" pageNumber="657">Urspruenglich</normalizedToken>
<emphasis id="9DBFB2EA28A446B223FDE926E6E0990F" italics="true" pageId="null" pageNumber="657">asiatische Pflanze:</emphasis>
West- bis Ostasien; heute als Unkraut weit verschleppt. - Im Gebiet verbreitet, meist selten.
</paragraph>
</subSubSection>
