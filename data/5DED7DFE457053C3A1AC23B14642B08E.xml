<subSubSection id="36A6E3CFCC1B0F7B5CDC9CA85BB792DD" pageId="0" pageNumber="17" type="etymology">
<paragraph id="C398EA68A16BC406A59FF0B632A248A0" pageId="0" pageNumber="17">Etymology.</paragraph>
<paragraph id="7002E8271927B2CA57959B26599A3849" pageId="0" pageNumber="17">
The specific epithet &quot; 
<taxonomicName id="7F3CFE0865EBC4AE7055C71DEA32D870" authorityName="Bo Li &amp; B. Chen" authorityYear="2022" class="Magnoliopsida" family="Mazaceae" genus="Mazus" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Mazus danxiacola" order="Lamiales" pageId="0" pageNumber="17" phylum="Tracheophyta" rank="species" species="danxiacola">
<emphasis id="C24588B19EF8FE87912CDDD4354355F4" italics="true" pageId="0" pageNumber="17">Mazus danxiacola</emphasis>
</taxonomicName>
&quot; refers to the species inhabiting in Danxia landform.
</paragraph>
</subSubSection>
