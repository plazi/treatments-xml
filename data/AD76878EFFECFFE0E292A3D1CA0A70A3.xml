); 
<taxonomicName id="E2DF4D1BFFECFFE0E057A6EDCDCF70CC" authority="(Carpenter, 1935)" baseAuthorityName="Carpenter" baseAuthorityYear="1935" box="[594,911,1163,1190]" class="Insecta" family="Chrysopidae" genus="Palaeochrysa" kingdom="Animalia" order="Neuroptera" pageId="2" pageNumber="303" phylum="Arthropoda" rank="species" species="creedei">
<emphasis id="17ABEA8AFFECFFE0E057A6EDCC8270CF" box="[594,706,1163,1189]" italics="true" pageId="2" pageNumber="303">A. creedei</emphasis>
(
<bibRefCitation id="414E4B69FFECFFE0E0D4A6EDCDC770CC" author="Carpenter, F. M." box="[721,903,1163,1190]" pageId="2" pageNumber="303" pagination="259 - 271" refId="ref22778" refString="Carpenter, F. M. (1935) Tertiary insects of the family Chrysopidae. Journal of Paleontology, 9, 259 - 271." type="journal article" year="1935">Carpenter, 1935</bibRefCitation>
