<taxonomicName id="87B1A2E69B01291DD5260B64D2D2957C" class="Magnoliopsida" family="Simaroubaceae" genus="Ailanthus" kingdom="Plantae" order="Sapindales" phylum="Tracheophyta" rank="genus">
