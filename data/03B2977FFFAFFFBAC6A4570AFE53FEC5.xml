<subSubSection id="C30175E2FFA9FFBAC6F451A5FD4CFF59" pageId="29" pageNumber="230" type="etymology">
<paragraph id="8BA42669FFA9FFBAC6F451A5FC2CFF11" blockId="29.[151,1437,150,357]" box="[199,929,150,177]" pageId="29" pageNumber="230">
<emphasis id="B96FFA7BFFA9FFBAC6F451A5FEC3FF10" bold="true" box="[199,334,150,176]" pageId="29" pageNumber="230">Etymology.</emphasis>
