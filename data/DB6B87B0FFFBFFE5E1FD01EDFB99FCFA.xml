<taxonomicName id="94C24D25FFFBFFE5E1FD01EDFE9CFE12" baseAuthorityName="Denis &amp; Schiffermuller" baseAuthorityYear="1775" box="[199,319,438,465]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="phoebe">
