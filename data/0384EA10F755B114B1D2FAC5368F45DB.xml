<emphasis id="B9598714F755B114B581FA10335E456E" italics="true" pageId="32" pageNumber="553">
<taxonomicName id="4C2D2085F755B114B581FA10377E454A" box="[1220,1351,1519,1544]" class="Amphibia" family="Microhylidae" genus="Unicus" kingdom="Animalia" order="Anura" pageId="32" pageNumber="553" phylum="Chordata" rank="species" species="mas">Unicus mas</taxonomicName>
