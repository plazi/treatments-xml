A comparison of 
<taxonomicName id="23884D73FFA3FFC7FE21FF13FD403DE7" box="[447,721,159,183]" class="Liliopsida" family="Orchidaceae" genus="Amitostigma" higherTaxonomySource="GBIF" kingdom="Plantae" order="Asparagales" pageId="3" pageNumber="118" phylum="Tracheophyta" rank="species" species="kaiyangense">
<emphasis id="D6FCEAE2FFA3FFC7FE21FF13FD403DE7" box="[447,721,159,183]" italics="true" pageId="3" pageNumber="118">Amitostigma kaiyangense</emphasis>
</taxonomicName>
and 
<taxonomicName id="23884D73FFA3FFC7FC9BFF13FC3A3DE7" box="[773,939,159,183]" class="Liliopsida" family="Orchidaceae" genus="Amitostigma" higherTaxonomySource="GBIF" kingdom="Plantae" order="Asparagales" pageId="3" pageNumber="118" phylum="Tracheophyta" rank="species" species="pinguiculum">A. pinguiculum</taxonomicName>
.
</paragraph>
</caption>
