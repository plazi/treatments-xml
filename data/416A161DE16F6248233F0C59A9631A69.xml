<subSubSection id="CEF10F2BB78EA37DB30AD9985D3018D1" pageId="null" pageNumber="81" type="description">
<paragraph id="8641824F4F220B21055EA32D83849B96" pageId="null" pageNumber="81">
Sehr 
<normalizedToken id="5C3D13F619F406F25E416B80BC67395F" originalValue="ähnlich" pageId="null" pageNumber="81">aehnlich</normalizedToken>
<taxonomicName id="D408A749E13F92F99260B5A8C5336768" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="81" phylum="Tracheophyta" rank="species" species="flammula">
<emphasis id="C5400E97DD8A1D7369B9C5D0257ABD5C" italics="true" pageId="null" pageNumber="81">R. Flammula</emphasis>
</taxonomicName>
(Nr. 13a), aber meist 1 
<normalizedToken id="FED18FB379E9A1AD9630F8B2BE09CEA2" originalValue="jährig" pageId="null" pageNumber="81">jaehrig</normalizedToken>
. Die 
<normalizedToken id="6D7E95DB9F05E4C35806ABC1EE2C6B52" originalValue="grundständigen" pageId="null" pageNumber="81">grundstaendigen</normalizedToken>
<normalizedToken id="705DC10DF52E4BEBB309C214380A49B1" originalValue="Blätter" pageId="null" pageNumber="81">Blaetter</normalizedToken>
sind bei 
<taxonomicName id="609DDCF179ED483BE6839040CE38A140" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="81" phylum="Tracheophyta" rank="species" species="ophioglossifolius">
<emphasis id="D557ABAB1AD02036513B3FB4DDE090A9" italics="true" pageId="null" pageNumber="81">R. ophioglossifolius</emphasis>
</taxonomicName>
meist etwas breiter und am Grunde 
<normalizedToken id="D738DB49C46AF3690A02884DBA07402F" originalValue="herzförmig" pageId="null" pageNumber="81">herzfoermig</normalizedToken>
oder abgerundet. Einzig sicheres Unterscheidungsmerkmal: 
<emphasis id="0B48EEA179C030F03CA2F52845E29259" italics="true" pageId="null" pageNumber="81">
<taxonomicName id="D7265CCC95A25DBFCA3BC7F91D3EDD05" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="81" phylum="Tracheophyta" rank="species" species="ophioglossifolius">R. ophioglossifolius</taxonomicName>
hat deutliche
</emphasis>
, 
<normalizedToken id="A471AC934CA3F3E6C349F46003679520" originalValue="±" pageId="null" pageNumber="81">+/-</normalizedToken>
<emphasis id="B436DB80E3AD584410EF9B06121E0F9E" italics="true" pageId="null" pageNumber="81">
dichte hyaline Warzen auf beiden 
<normalizedToken id="66A5F265D471605F0A44E27DFB747A8A" originalValue="Seitenflächen" pageId="null" pageNumber="81">Seitenflaechen</normalizedToken>
der 
<normalizedToken id="765E438B461FA644C1B70A2C72B9F92A" originalValue="Früchtchen" pageId="null" pageNumber="81">Fruechtchen</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="6A1370D7D62BF4B78DC219C779B95EAD" originalValue="Blüte" pageId="null" pageNumber="81">Bluete</normalizedToken>
: 
<normalizedToken id="6A5E029FAA1F6A0CAF919E09E0FE5ACA" originalValue="Früher" pageId="null" pageNumber="81">Frueher</normalizedToken>
Sommer bis Herbst.
</paragraph>
<paragraph id="BCFD09FB289B8C75014B79CDC2E30C4C" pageId="null" pageNumber="81">
<emphasis id="61D703C3851D6EA1451BF0A82290D578" italics="true" pageId="null" pageNumber="81">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B173F3967F312FE90538B6A12144FEBD" italics="true" pageId="null" pageNumber="81">16:</emphasis>
Material aus botanischen 
<normalizedToken id="67D7788953119782F480FEB76D7A2C2C" originalValue="Gärten" pageId="null" pageNumber="81">Gaerten</normalizedToken>
(Langlet 1927, Larter 1932) und von verschiedenen Fundorten in Portugal (Neves 1945).
</paragraph>
<paragraph id="39EE6F65DEEF464F6660383FA8CFEA94" pageId="null" pageNumber="81">
<emphasis id="EEDB909C6D55FF6CC424695D82B5A14E" italics="true" pageId="null" pageNumber="81">Standort.</emphasis>
Wie 
<taxonomicName id="F9F35A416A6DD373DCF1DB132F630612" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="81" phylum="Tracheophyta" rank="species" species="flammula">
<emphasis id="BD3B80C287118F208CF219B2B37FC861" italics="true" pageId="null" pageNumber="81">R. Flammula</emphasis>
</taxonomicName>
, jedoch nur kollin.
</paragraph>
<paragraph id="EF98132C71EFA9DA7F8522A536748A57" pageId="null" pageNumber="81">
<emphasis id="1D197A325C381531BF71F6DF2E8764FB" italics="true" pageId="null" pageNumber="81">
Verbreitung. 
<normalizedToken id="DB0B7B3FF48BBA725F6CAF6AC2FB2658" originalValue="Mediterran-westeuropäische" pageId="null" pageNumber="81">Mediterran-westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Ganzes Mediterrangebiet (auch Nordafrika), Frankreich, Britische Inseln, 
<normalizedToken id="14B97357602127D0C4829FDF31F02FFB" originalValue="Südschweden" pageId="null" pageNumber="81">Suedschweden</normalizedToken>
(nur Gotland), 
<normalizedToken id="C9050F7FFF6CEAC2031F08BB60C55C9B" originalValue="ostwärts" pageId="null" pageNumber="81">ostwaerts</normalizedToken>
bis Krim und Kaukasus. Aus dem Gebiet nicht bekannt; vielleicht 
<normalizedToken id="AC4EE2F878A959A24ED059E7FF259C09" originalValue="übersehen" pageId="null" pageNumber="81">uebersehen</normalizedToken>
.
</paragraph>
</subSubSection>
