<paragraph id="3B72D7DA1746F9158B05D5F1B4B43084" pageId="null" pageNumber="630">
<taxonomicName id="50EC188F92C17B7D627D9AC026AF0182" authority="L." class="Liliopsida" family="Orchidaceae" genus="Orchis" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="630" phylum="Tracheophyta" rank="species" species="militaris">
Orchis 
<normalizedToken id="476739EDC6B974F8107124AAB6DE0BDA" originalValue="militáris" pageId="null" pageNumber="630">militaris</normalizedToken>
<authorityName id="D2E79FC399F1C0D78AA9AD821F1F4BD1" pageId="null" pageNumber="630">L.</authorityName>
