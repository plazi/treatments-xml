<subSubSection id="EED7DB1BE46D2157AA9A68F7DF5B7CA7" pageId="null" pageNumber="494" type="vernacular_names">
<paragraph id="7569BEC3E2F7D61F511ACF7AB5A49CC4" pageId="null" pageNumber="494">Ganzrandiges Kreuzkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="32D907C3E6330FBE95724ED8444D805F" pageId="null" pageNumber="494" type="description">
<paragraph id="BEEA0EDBB58101801AB15FD8CADE337F" pageId="null" pageNumber="494">
Unterscheidet sich von 
<emphasis id="86CF957B41737FEF1973DFCA501F9053" italics="true" pageId="null" pageNumber="494">S. capitatus</emphasis>
(Nr. 2a) durch folgende Merkmale: 
<emphasis id="69A03D0C53D7D35E6F625CDB2A8ABD1A" italics="true" pageId="null" pageNumber="494">20</emphasis>
- 
<emphasis id="7A512434C8F71BDDD6B37EC352A16699" italics="true" pageId="null" pageNumber="494">50 cm</emphasis>
hoch; 
<normalizedToken id="85DEF47909B99CDEE4D6DA6CB87DFE61" originalValue="Blütenkopfstiele" pageId="null" pageNumber="494">Bluetenkopfstiele</normalizedToken>
meist 
<normalizedToken id="6783D4F2FBAC1AE04EE70D3CE7421C78" originalValue="länger" pageId="null" pageNumber="494">laenger</normalizedToken>
als 2 cm; 
<emphasis id="C840E8D0812F91ED79BA130D3A3BC441" italics="true" pageId="null" pageNumber="494">
<normalizedToken id="A2063AFBF130EFCE8A77681FC8CBB4AB" originalValue="Hüllblätter" pageId="null" pageNumber="494">Huellblaetter</normalizedToken>
<normalizedToken id="C2383A0DA34229300416AE72F7821C02" originalValue="grün" pageId="null" pageNumber="494">gruen</normalizedToken>
, oder nur an der Spitze purpurn; Kronen gelb
</emphasis>
. - 
<normalizedToken id="926B3266C9F7F51F7D543C5B4DF1FFEA" originalValue="Blüte" pageId="null" pageNumber="494">Bluete</normalizedToken>
: 
<normalizedToken id="A196861D5AC9B69321D2304DCA216A5C" originalValue="Später" pageId="null" pageNumber="494">Spaeter</normalizedToken>
<normalizedToken id="C30DBD11B000A00A807B64196BB7F4B8" originalValue="Frühling" pageId="null" pageNumber="494">Fruehling</normalizedToken>
und 
<normalizedToken id="1C01E961E64DE944A077E02F1A2C9A3E" originalValue="früher" pageId="null" pageNumber="494">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="236546FBB52403B4752C3D945AABD375" pageId="null" pageNumber="494">
<emphasis id="6B656F1FA5FB16419124BB9A8379DC66" italics="true" pageId="null" pageNumber="494">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="06D6F2FE1BF6AD5566D9AC9A3BF1AFAC" italics="true" pageId="null" pageNumber="494">48:</emphasis>
Material aus botanischen 
<normalizedToken id="8052B2CC92B278667DB2432D217DB0B3" originalValue="Gärten" pageId="null" pageNumber="494">Gaerten</normalizedToken>
(Okabe 1931), aus England (Rutland 1941). 
<emphasis id="A3E0D0F3D833226CC0C2B7AD5B2137B3" italics="true" pageId="null" pageNumber="494">2n&gt; 90:</emphasis>
Material aus 
<normalizedToken id="CF54B341CB1ECEFD740A33FABE6F3243" originalValue="Nordrußland" pageId="null" pageNumber="494">Nordrussland</normalizedToken>
(Sokolovskaya und Strelkova 1960).
</paragraph>
<paragraph id="18D71E3653CD89F26C4EF1C9EA01D384" pageId="null" pageNumber="494">
<emphasis id="5E3A18D3E3EA03D6DCBE7DFC62D0DF4F" italics="true" pageId="null" pageNumber="494">Standort</emphasis>
. Kollin, montan und subalpin. Trockene oder sommertrockene, kalkhaltige, tonige 
<normalizedToken id="3B03F18FC588498D6D1021CC530973DE" originalValue="Böden" pageId="null" pageNumber="494">Boeden</normalizedToken>
in 
<normalizedToken id="F6566F4DE807C1DC51BF08B7023455D2" originalValue="wärmeren" pageId="null" pageNumber="494">waermeren</normalizedToken>
Lagen. Weiden, Trockenwiesen.
</paragraph>
<paragraph id="B536F380A6259FD2CF85D8897FC4AAA9" pageId="null" pageNumber="494">
<emphasis id="A0AC14CF36072538EA5C16F34273BDE9" italics="true" pageId="null" pageNumber="494">Verbreitung. Eurasiatische Pflanze:</emphasis>
<normalizedToken id="3ADB03F3112B8482FF85E676AFFEE59F" originalValue="Nordwärts" pageId="null" pageNumber="494">Nordwaerts</normalizedToken>
bis 
<normalizedToken id="D117DE92A787EDEFB16B5AA59A1BDB01" originalValue="Südengland" pageId="null" pageNumber="494">Suedengland</normalizedToken>
, 
<normalizedToken id="D471EE551E3C57CBDB64E202BEC9E43B" originalValue="Südskandinavien" pageId="null" pageNumber="494">Suedskandinavien</normalizedToken>
; 
<normalizedToken id="E564B48DAFB3DE073AA209F34345FCC9" originalValue="ostwärts" pageId="null" pageNumber="494">ostwaerts</normalizedToken>
bis Japan; 
<normalizedToken id="8A838D087FFF299318CE2F93F256C1E5" originalValue="südwärts" pageId="null" pageNumber="494">suedwaerts</normalizedToken>
bis 
<normalizedToken id="DD60A5025DDC2C358C308664BFB248DD" originalValue="Pyrenäen" pageId="null" pageNumber="494">Pyrenaeen</normalizedToken>
, Mittelitalien, Griechenland, Kaukasus. - Im Gebiet: 
<normalizedToken id="F40AFD45F5A6A1C3D0513C1FB3A42D69" originalValue="Waadtländer" pageId="null" pageNumber="494">Waadtlaender</normalizedToken>
Jura, 
<normalizedToken id="70D630EC71233404D17F672AEB491644" originalValue="Dép" pageId="null" pageNumber="494">Dep</normalizedToken>
. Jura, 
<normalizedToken id="6D4EC45B5BFCD295449EDB70CAFFA6B0" originalValue="Dép" pageId="null" pageNumber="494">Dep</normalizedToken>
. Ain, ziemlich selten.
</paragraph>
<paragraph id="E887D255EA34CC8F8C30F79FD9DC53A4" pageId="null" pageNumber="494">
<emphasis id="FC3007556B0D7DE83A7FFB0EFE52DBBD" italics="true" pageId="null" pageNumber="494">Bemerkungen</emphasis>
. Ob es sich bei den Jurapflanzen wirklich um 
<taxonomicName id="5F13FD87C819EEAD384B7AD3FD493147" class="Magnoliopsida" family="Asteraceae" genus="Senecio" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="494" phylum="Tracheophyta" rank="species" species="integrifolius">
<emphasis id="26F136036D68969A767B1AC12E567DEB" italics="true" pageId="null" pageNumber="494">S. integrifolius</emphasis>
</taxonomicName>
handelt, ist nicht sicher. Es ist zu 
<normalizedToken id="4ED71E2EDD2093B3989CC55150EB87D8" originalValue="prüfen" pageId="null" pageNumber="494">pruefen</normalizedToken>
, ob nicht 
<emphasis id="4268CA657DE506DF35383BC64F8A2874" italics="true" pageId="null" pageNumber="494">S. capitatus</emphasis>
(Nr. 2a) dort ein isoliertes Vorkommen aufweist, wobei die Pflanzen durch Genintrogressionen verschiedene Merkmale von dem in der Gegend wachsenden 
<taxonomicName id="91BA5151E8D6F5AB204FFDF98766B4ED" class="Magnoliopsida" family="Asteraceae" genus="Senecio" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="494" phylum="Tracheophyta" rank="species" species="spathulifolius">
<emphasis id="FCADFD80191404A6B38537A0DC043137" italics="true" pageId="null" pageNumber="494">S. spathulifolius</emphasis>
</taxonomicName>
(Nr. 2d) erhalten 
<normalizedToken id="37F8DD3964129A1A2EB8970777BAE64F" originalValue="hätten" pageId="null" pageNumber="494">haetten</normalizedToken>
.
</paragraph>
</subSubSection>
