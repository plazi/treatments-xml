<taxonomicName id="66DC4D1C075DFFC6173502D2FB1CAFD4" baseAuthorityName="Feldmann &amp; Haggart" baseAuthorityYear="2007" box="[1035,1156,215,242]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="walkerae">
