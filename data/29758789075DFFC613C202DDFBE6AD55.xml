, 
<taxonomicName id="66DC4D1C075DFFC6106402D2FC56AFD4" baseAuthorityName="Stenzel" baseAuthorityYear="1945" box="[858,974,215,242]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="triglypta">
