. It is also slightly curved contrary to 
<taxonomicName id="66DC4D1C075DFFC6115805BBFE55A8CE" authority="(Cronier &amp; Courville, 2004)" baseAuthorityName="Cronier &amp; Courville" baseAuthorityYear="2004" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="burgundiaca">
