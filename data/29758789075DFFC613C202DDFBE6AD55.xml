<taxonomicName id="66DC4D1C075DFFC6160B037DFA30AEB4" baseAuthorityName="Secretan" baseAuthorityYear="1964" box="[1333,1448,375,401]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="australis">
<emphasis id="93A8EA8D075DFFC6160B037DFA30AEB4" box="[1333,1448,375,401]" italics="true" pageId="37" pageNumber="60">S. australis</emphasis>
</taxonomicName>
, 
<taxonomicName id="66DC4D1C075DFFC61013039DFC4FAE95" baseAuthorityName="Cronier &amp; Courville" baseAuthorityYear="2004" box="[813,983,406,433]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="burgundiaca">
<emphasis id="93A8EA8D075DFFC61013039DFC4FAE95" box="[813,983,406,433]" italics="true" pageId="37" pageNumber="60">S. burgundiaca</emphasis>
</taxonomicName>
, 
<taxonomicName id="66DC4D1C075DFFC610D7039DFB16AE95" baseAuthorityName="Moret" baseAuthorityYear="1946" box="[1001,1166,406,433]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="delphinensis">
<emphasis id="93A8EA8D075DFFC610D7039DFB16AE95" box="[1001,1166,406,433]" italics="true" pageId="37" pageNumber="60">S. delphinensis</emphasis>
</taxonomicName>
, 
<taxonomicName id="66DC4D1C075DFFC6179E039DFAA0AE95" baseAuthorityName="Secretan" baseAuthorityYear="1964" box="[1184,1336,406,433]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="granulifera">
<emphasis id="93A8EA8D075DFFC6179E039DFAA0AE95" box="[1184,1336,406,433]" italics="true" pageId="37" pageNumber="60">S. granulifera</emphasis>
</taxonomicName>
, 
<taxonomicName id="66DC4D1C075DFFC61674039DFA3FAE95" baseAuthorityName="Wright" baseAuthorityYear="1881" box="[1354,1447,407,433]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="guisei">
<emphasis id="93A8EA8D075DFFC61674039DFA3FAE95" box="[1354,1447,407,433]" italics="true" pageId="37" pageNumber="60">S. guisei</emphasis>
</taxonomicName>
, 
<taxonomicName id="66DC4D1C075DFFC6101303BDFC27AEF5" baseAuthorityName="Hyzny, Schlogl, Charbonnier, Schweigert, Rulleau &amp; Gouttenoire" baseAuthorityYear="2015" box="[813,959,438,465]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="lagardettei">
<emphasis id="93A8EA8D075DFFC6101303BDFC27AEF5" box="[813,959,438,465]" italics="true" pageId="37" pageNumber="60">S. lagardettei</emphasis>
