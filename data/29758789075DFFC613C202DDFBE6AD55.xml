, and 
<taxonomicName id="66DC4D1C075DFFC612BC0598FF54A8EE" authority="(Feldmann &amp; Haggart, 2007)" baseAuthorityName="Feldmann &amp; Haggart" baseAuthorityYear="2007" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="walkerae">
