(
<bibRefCitation id="C54D4B6E075DFFC61135059BFF5CA8EE" author="FELDMANN R. M. &amp; HAGGART J. W." pageId="37" pageNumber="60" pagination="1791 - 1796" refId="ref31894" refString="FELDMANN R. M. &amp; HAGGART J. W. 2007. - A new species of lobster (Astacidea, Erymidae) from the Smithers Formation (Middle Jurassic) of British Columbia, Canada. Canadian Journal of Earth Sciences 44: 1791 - 1796. https: // doi. org / 10.1139 / e 07 - 058" type="journal article" year="2007">Feldmann &amp; Haggart, 2007</bibRefCitation>
)
