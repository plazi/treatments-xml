(
<bibRefCitation id="C54D4B6E075DFFC6166B033DFCF3AE54" author="WRIGHT T." pageId="37" pageNumber="60" pagination="56 - 59" refId="ref36444" refString="WRIGHT T. 1881. - On a new Astacomorphous crustacean from the middle coral reef of Leckhampton Hill. Proceedings of the Cotteswold naturalists' Field Club 8: 56 - 59." type="journal article" year="1881">Wright, 1881</bibRefCitation>
)
</taxonomicName>
, 
<taxonomicName id="66DC4D1C075DFFC61040035DFB92AE54" baseAuthorityName="Hyzny, Schlogl, Charbonnier, Schweigert, Rulleau &amp; Gouttenoire" baseAuthorityYear="2015" box="[894,1034,343,369]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="lagardettei">
