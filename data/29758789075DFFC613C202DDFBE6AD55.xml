, 
<taxonomicName id="66DC4D1C075DFFC6177E033DFB4EAE74" baseAuthorityName="Secretan" baseAuthorityYear="1964" box="[1088,1238,311,337]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="granulifera">
<emphasis id="93A8EA8D075DFFC6177E033DFB4EAE74" box="[1088,1238,311,337]" italics="true" pageId="37" pageNumber="60">S. granulifera</emphasis>
</taxonomicName>
, 
<taxonomicName id="66DC4D1C075DFFC617D6033DFCECAE54" authority="(Wright, 1881)" baseAuthorityName="Wright" baseAuthorityYear="1881" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="guisei">
