<taxonomicName id="66DC4D1C075DFFC61013031DFC7FAE14" baseAuthorityName="Van Straelen" baseAuthorityYear="1925" box="[813,999,279,305]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="deslongchampsi">
<emphasis id="93A8EA8D075DFFC61013031DFC7FAE14" box="[813,999,279,305]" italics="true" pageId="37" pageNumber="60">S. deslongchampsi</emphasis>
</taxonomicName>
) or both ω and χ areas are inflated in some others (
<taxonomicName id="66DC4D1C075DFFC610B8033DFBB6AE74" baseAuthorityName="Cronier &amp; Courville" baseAuthorityYear="2004" box="[902,1070,311,337]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="37" pageNumber="60" phylum="Arthropoda" rank="species" species="burgundiaca">
<emphasis id="93A8EA8D075DFFC610B8033DFBB6AE74" box="[902,1070,311,337]" italics="true" pageId="37" pageNumber="60">S. burgundiaca</emphasis>
