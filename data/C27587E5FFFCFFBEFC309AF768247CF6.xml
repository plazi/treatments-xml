<taxonomicName id="8DDC4D70FFFCFFBDFC289BCC6DCD7AFF" authority="(D'ORBIGNY)" baseAuthorityName="D'ORBIGNY" baseAuthorityYear="1840" box="[898,1216,1928,1950]" class="Nodosariata" family="Nodosariidae" genus="Dentalina" kingdom="Chromista" order="Nodosariida" pageId="17" pageNumber="31" phylum="Foraminifera" rank="species" species="gracilis">
