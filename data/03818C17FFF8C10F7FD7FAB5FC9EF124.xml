<taxonomicName id="4C284682FFF8C10E7C96F993FB07F06B" authorityName="Brotherus" authorityYear="1923" box="[969,1182,1569,1595]" class="Bryopsida" family="Entodontaceae" genus="Entodon" kingdom="Plantae" order="Hypnales" pageId="8" pageNumber="233" phylum="Bryophyta" rank="species" species="obtusatus">
