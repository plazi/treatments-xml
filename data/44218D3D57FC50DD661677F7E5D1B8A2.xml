<subSubSection id="EB9C1B0D495623EDAD878FF8CE1B74BE" pageId="null" pageNumber="158" type="description">
<paragraph id="EAAE82FE31C3C3545EB5784E1242E9AC" pageId="null" pageNumber="158">
Unterscheidet sich von 
<taxonomicName id="AEDE126941F848612C744772ED51F765" class="Magnoliopsida" family="Brassicaceae" genus="Cochlearia" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="158" phylum="Tracheophyta" rank="species" species="officinalis">
<emphasis id="D2A9A8CBE65B903671140D1C240DBB0B" italics="true" pageId="null" pageNumber="158">C. officinalis</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="8825DEC5F93D07FC40794EFD1C0EF9DF" italics="true" pageId="null" pageNumber="158">
Ausdauernd, mit langem, 
<normalizedToken id="1C649AEB1F4FCE44833931C564E44D89" originalValue="dünnem" pageId="null" pageNumber="158">duennem</normalizedToken>
Rhizom;
</emphasis>
10-30 cm hoch; 
<normalizedToken id="3B5CCC0F10835AFDF20EB257ED95B049" originalValue="grundständige" pageId="null" pageNumber="158">grundstaendige</normalizedToken>
<normalizedToken id="61A57FF7378504B7C74A72217A5A38E2" originalValue="Blätter" pageId="null" pageNumber="158">Blaetter</normalizedToken>
bis 3 cm lang; 
<normalizedToken id="A454C7985F521E152B6B37F4CF9B3E4A" originalValue="Kelchblätter" pageId="null" pageNumber="158">Kelchblaetter</normalizedToken>
2-3 mm lang; 
<normalizedToken id="DAB41C3ADB9D12BA39116CBFD0994B82" originalValue="Kronblätter" pageId="null" pageNumber="158">Kronblaetter</normalizedToken>
4-8 mm lang; 
<emphasis id="40B94328B603DF06F3DB8A0D815B4415" italics="true" pageId="null" pageNumber="158">Fruchtstiele</emphasis>
⅔ 
<emphasis id="DC61FFCEEF417A6BB504A62C74B4DA17" italics="true" pageId="null" pageNumber="158">
-1mal so lang wie die 
<normalizedToken id="4B693E6BD0F450455FBC0857B07CFEBC" originalValue="Früchte" pageId="null" pageNumber="158">Fruechte</normalizedToken>
, aufrecht abstehend, mit der Achse einen Winkel von 45-60° bildend; 
<normalizedToken id="21FCC3A8A184AF602687F5577B5D46D5" originalValue="Früchte" pageId="null" pageNumber="158">Fruechte</normalizedToken>
beidseits zugespitzt
</emphasis>
, 5-8 mm lang. - 
<normalizedToken id="AE4ED7D2C9562CA7CA3CB35ED8C554BD" originalValue="Blüte" pageId="null" pageNumber="158">Bluete</normalizedToken>
: 
<normalizedToken id="C844D67E9D5A51AF02581A22B0E23994" originalValue="Früher" pageId="null" pageNumber="158">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="4FA005CC908F94052DC3E27FC3AF67D7" pageId="null" pageNumber="158">
<emphasis id="1E489A9C83217E7E823C4F0E8F89419F" italics="true" pageId="null" pageNumber="158">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="7FA55969432929F2B012B58F44C38524" italics="true" pageId="null" pageNumber="158">12:</emphasis>
Material aus dem Berner Oberland (Rohner 1954), von der 
<normalizedToken id="B139D594183E9F1656D5E70FB937DA4F" originalValue="Rhön" pageId="null" pageNumber="158">Rhoen</normalizedToken>
in Mitteldeutschland (Dersch 1968).
</paragraph>
<paragraph id="8BDBEB5C605D7F6BB71C731E0FCE8C73" pageId="null" pageNumber="158">
<emphasis id="383AB2D1D9D15F72C4B0488871720B6F" italics="true" pageId="null" pageNumber="158">Standort.</emphasis>
Montan und subalpin. Nasse, kalkhaltige, torfige 
<normalizedToken id="BCA1D469332E90901B894463C5EE27EB" originalValue="Böden" pageId="null" pageNumber="158">Boeden</normalizedToken>
. Quellfluren, 
<normalizedToken id="4516DA1CDF79B560618BD664D4AF1E58" originalValue="Bachränder" pageId="null" pageNumber="158">Bachraender</normalizedToken>
. Bildet eine besondere Quellmoorgesellschaft (
<emphasis id="424AD22CFA195F5E4DF4FFC996686CEE" italics="true" pageId="null" pageNumber="158">Cratoneuro-Cochlearietum</emphasis>
Th. 
<normalizedToken id="DEF85AF13B2E211BE6CA9855C9FF20DB" originalValue="Müller" pageId="null" pageNumber="158">Mueller</normalizedToken>
1961).
</paragraph>
<paragraph id="D6ABF9509A59F47283DEF3201060BF44" pageId="null" pageNumber="158">
<emphasis id="6C096DC7432F906BCE1DB33BEC062EEB" italics="true" pageId="null" pageNumber="158">
Verbreitung. 
<normalizedToken id="18179620EBBF4EC6414DDE74025B0F84" originalValue="Europäische" pageId="null" pageNumber="158">Europaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
<normalizedToken id="8F114C3873048D4FAD6602ABE649BC0D" originalValue="Pyrenäen" pageId="null" pageNumber="158">Pyrenaeen</normalizedToken>
, Plateau Central, Irland, 
<normalizedToken id="E2D79C81EA1B0B82D42C908A8493CDC5" originalValue="Großbritannien" pageId="null" pageNumber="158">Grossbritannien</normalizedToken>
, 
<normalizedToken id="DE00A10AD094A12386C3649A03D35586" originalValue="südbelgische" pageId="null" pageNumber="158">suedbelgische</normalizedToken>
und mitteldeutsche Gebirge, Nordalpen, 
<normalizedToken id="2E0E48505941CEC0964ED5F88B2E2998" originalValue="östliche" pageId="null" pageNumber="158">oestliche</normalizedToken>
Karpaten. - Im Gebiet: Nordalpen im Kt. Bern (zwischen Kaiseregg und Hohgant, Kandersteg, Rosenlaui) und im 
<normalizedToken id="966D511C0250154E81DC882EEC2C9658" originalValue="Allgäu" pageId="null" pageNumber="158">Allgaeu</normalizedToken>
(Einzelfundorte bei Winterhoff und Huber 1967).
</paragraph>
</subSubSection>
