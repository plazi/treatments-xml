<taxonomicName id="4C284D3BFFA9FFEFEAAB275BFCB5FA9F" authorityName="Simon" authorityYear="1897" box="[715,843,1365,1387]" class="Arachnida" family="Liocranidae" genus="Argistes" kingdom="Animalia" order="Araneae" pageId="3" pageNumber="366" phylum="Arthropoda" rank="species" species="velox">
