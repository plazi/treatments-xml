<subSubSection id="C7D06578FFE9E020FF185F56F8AEFEC4" lastPageId="1" lastPageNumber="186" pageId="0" pageNumber="185" type="description">
<paragraph id="8F7536F3FFE9E020FF185F56F8AEFEC4" blockId="0.[170,1229,1632,1852]" lastBlockId="1.[174,1233,175,298]" lastPageId="1" lastPageNumber="186" pageId="0" pageNumber="185">
Salticid spider 
<taxonomicName id="48CA4D70FFE9E021FE485F56FA9DF994" authorityName="Logunov" authorityYear="2000" box="[399,486,1632,1659]" class="Arachnida" family="Salticidae" genus="Sibianor" kingdom="Animalia" order="Araneae" pageId="0" pageNumber="185" phylum="Arthropoda" rank="species" species="larae">
<emphasis id="BDBEEAE1FFE9E021FE485F56FA9DF994" box="[399,486,1632,1659]" italics="true" pageId="0" pageNumber="185">S. larae</emphasis>
</taxonomicName>
is a Palearctic species (
<bibRefCitation id="EB5B4B02FFE9E021FD385F56F8D7F992" author="Platnick, N. I." box="[767,940,1633,1660]" pageId="0" pageNumber="185" refId="ref1548" refString="Platnick, N. I. The world spider catalog, version 15. American Museum of Natural History. - 2014. - http: // http: // research. amnh. org / iz / spiders / catalog / INTRO 3. html" type="url" year="2014">Platnick, 2014</bibRefCitation>
). In the first description D. 
<bibRefCitation id="EB5B4B02FFE9E021FF0B5FB6FAFFF972" author="Logunov, D. V." box="[204,388,1665,1692]" pageId="0" pageNumber="185" pagination="221 - 286" refId="ref1451" refString="Logunov, D. V. A redefinition of the genera Bianor Peckham &amp; Peckham, 1885 and Harmochirus Simon, 1885, with the establishment of a new genus Sibianor gen. n. (Aranei: Salticidae) // Arthropoda Selecta. - 2000. - N 4. - P. 221 - 286." type="journal article" year="2000">Logunov (2000)</bibRefCitation>
characterized this species as Euro-Siberian temperate species distributed in Fennoscandia and 
<collectingCountry id="F7DD7663FFE9E021FE6E5F96F979F952" box="[425,514,1697,1724]" name="Estonia" pageId="0" pageNumber="185">Estonia</collectingCountry>
, through the middle Urals and Siberia, eastward to Sakhalin (
<bibRefCitation id="EB5B4B02FFE9E021FF755FF6FA1CF932" author="Logunov, D. V." box="[178,359,1729,1756]" pageId="0" pageNumber="185" pagination="221 - 286" refId="ref1451" refString="Logunov, D. V. A redefinition of the genera Bianor Peckham &amp; Peckham, 1885 and Harmochirus Simon, 1885, with the establishment of a new genus Sibianor gen. n. (Aranei: Salticidae) // Arthropoda Selecta. - 2000. - N 4. - P. 221 - 286." type="journal article" year="2000">Logunov, 2000</bibRefCitation>
). Also 
<taxonomicName id="48CA4D70FFE9E021FE7C5FF6F968F934" authorityName="Logunov" authorityYear="2000" box="[443,531,1728,1755]" class="Arachnida" family="Salticidae" genus="Sibianor" kingdom="Animalia" order="Araneae" pageId="0" pageNumber="185" phylum="Arthropoda" rank="species" species="larae">
<emphasis id="BDBEEAE1FFE9E021FE7C5FF6F968F934" box="[443,531,1728,1755]" italics="true" pageId="0" pageNumber="185">S. larae</emphasis>
</taxonomicName>
was registered in 
<collectingCountry id="F7DD7663FFE9E021FD285FF6F82BF932" box="[751,848,1729,1756]" name="Belgium" pageId="0" pageNumber="185">Belgium</collectingCountry>
(
<bibRefCitation id="EB5B4B02FFE9E021FCA65FF6FF25F932" author="Keer van, K. &amp; Oger, P. &amp; Maingeot, M." box="[865,1118,1729,1756]" pageId="0" pageNumber="185" pagination="46 - 49" refId="ref1675" refString="Keer van, K., Oger, P., Maingeot, M. First record of Sibianor larae Logunov 2001 (Araneae: Salticidae) for Belgium // Nieuwsbrief Belgische Arachnologische Vereniging. - 2010. - 25, N 1. - P. 46 - 49." type="journal article" year="2010">Keer van et al., 2010</bibRefCitation>
), 
<collectingCountry id="F7DD7663FFE9E021FBB45FF6FFB7F932" box="[1139,1228,1729,1756]" name="Sweden" pageId="0" pageNumber="185">Sweden</collectingCountry>
(
<bibRefCitation id="EB5B4B02FFE9E021FF755FD6FA1AF912" author="Logunov, D. V." box="[178,353,1761,1788]" pageId="0" pageNumber="185" pagination="221 - 286" refId="ref1451" refString="Logunov, D. V. A redefinition of the genera Bianor Peckham &amp; Peckham, 1885 and Harmochirus Simon, 1885, with the establishment of a new genus Sibianor gen. n. (Aranei: Salticidae) // Arthropoda Selecta. - 2000. - N 4. - P. 221 - 286." type="journal article" year="2000">Logunov, 2000</bibRefCitation>
; 
<bibRefCitation id="EB5B4B02FFE9E021FEAD5FD6F965F912" author="Almquist, S." box="[362,542,1761,1788]" pageId="0" pageNumber="185" pagination="285 - 601" refId="ref1070" refString="Almquist, S. Swedish Araneae, part 2. Families Dictynidae to Salticida // Insect Syst. Evol. - Suppl. - 2006. - 63. - P. 285 - 601." type="book chapter" year="2006">Almquist, 2006</bibRefCitation>
), 
<collectingCountry id="F7DD7663FFE9E021FDE85FD6F9E7F912" box="[559,668,1761,1788]" name="Germany" pageId="0" pageNumber="185">Germany</collectingCountry>
(
<bibRefCitation id="EB5B4B02FFE9E021FD6E5FD6F8E9F912" author="Keer van, K. &amp; Oger, P. &amp; Maingeot, M." box="[681,914,1761,1788]" pageId="0" pageNumber="185" pagination="46 - 49" refId="ref1675" refString="Keer van, K., Oger, P., Maingeot, M. First record of Sibianor larae Logunov 2001 (Araneae: Salticidae) for Belgium // Nieuwsbrief Belgische Arachnologische Vereniging. - 2010. - 25, N 1. - P. 46 - 49." type="journal article" year="2010">Keer van et al., 2010</bibRefCitation>
; 
<bibRefCitation id="EB5B4B02FFE9E021FC5C5FD6FF57F912" author="Staudt, A." box="[923,1068,1761,1788]" pageId="0" pageNumber="185" refId="ref1635" refString="Staudt, A. Nachweiskarten der Spinnen tiere Deutschlands (Arachnida: Araneae Opiliones, Pseudoscorpiones). Arachnologische Gesellschaft. - 2011. - http: // www. spiderling. de / arages / index 2. htm" type="url" year="2011">Staudt, 2011</bibRefCitation>
), 
<collectingCountry id="F7DD7663FFE9E021FBF95FD6FFB7F912" box="[1086,1228,1761,1788]" name="Netherlands" pageId="0" pageNumber="185">Netherlands</collectingCountry>
(
<bibRefCitation id="EB5B4B02FFE9E021FF755E36FA31F8F2" author="Vogels, J." box="[178,330,1793,1820]" pageId="0" pageNumber="185" pagination="254 - 258" refId="ref1726" refString="Vogels, J. First record of the salticid spider Sibianor larae (Araneae: Salticidae) in the Netherlands // Ent. Berichten. - 2012. - 72. - P. 254 - 258." type="book chapter" year="2012">Vogels, 2012</bibRefCitation>
). Notably, the specimens of the species were mainly found in dry open biotopes: semi-shrubby meadow, low-lying meadow, sheep-grazed wet heath, dry heath etc. (
<bibRefCitation id="EB5B4B02FFE9E020FB9A5E16FB93FF24" author="Logunov, D. V." lastPageId="1" lastPageNumber="186" pageId="0" pageNumber="185" pagination="221 - 286" refId="ref1451" refString="Logunov, D. V. A redefinition of the genera Bianor Peckham &amp; Peckham, 1885 and Harmochirus Simon, 1885, with the establishment of a new genus Sibianor gen. n. (Aranei: Salticidae) // Arthropoda Selecta. - 2000. - N 4. - P. 221 - 286." type="journal article" year="2000">Logunov, 2000</bibRefCitation>
; 
<bibRefCitation id="EB5B4B02FFE8E020FF325998FAF1FF24" author="Vogels, J." box="[245,394,175,202]" pageId="1" pageNumber="186" pagination="254 - 258" refId="ref1726" refString="Vogels, J. First record of the salticid spider Sibianor larae (Araneae: Salticidae) in the Netherlands // Ent. Berichten. - 2012. - 72. - P. 254 - 258." type="book chapter" year="2012">Vogels 2012</bibRefCitation>
). Both specimens were found on sphagnum of the wet bog and in the shaded pine-birch forest. Although the species habitat is vast, the finds of 
<taxonomicName id="48CA4D70FFE8E020FC3A59E7FF2AFF07" authorityName="Logunov" authorityYear="2000" box="[1021,1105,207,234]" class="Arachnida" family="Salticidae" genus="Sibianor" kingdom="Animalia" order="Araneae" pageId="1" pageNumber="186" phylum="Arthropoda" rank="species" species="larae">
<emphasis id="BDBEEAE1FFE8E020FC3A59E7FF2AFF07" box="[1021,1105,207,234]" italics="true" pageId="1" pageNumber="186">S. larae</emphasis>
</taxonomicName>
specimens are rare and small in numbers (
<bibRefCitation id="EB5B4B02FFE8E020FDEE59D8F9A7FEE4" author="Logunov, D. V." box="[553,732,239,266]" pageId="1" pageNumber="186" pagination="221 - 286" refId="ref1451" refString="Logunov, D. V. A redefinition of the genera Bianor Peckham &amp; Peckham, 1885 and Harmochirus Simon, 1885, with the establishment of a new genus Sibianor gen. n. (Aranei: Salticidae) // Arthropoda Selecta. - 2000. - N 4. - P. 221 - 286." type="journal article" year="2000">Logunov, 2000</bibRefCitation>
; 
<bibRefCitation id="EB5B4B02FFE8E020FD2D59D8F8FFFEE4" author="Vogels, J." box="[746,900,239,266]" pageId="1" pageNumber="186" pagination="254 - 258" refId="ref1726" refString="Vogels, J. First record of the salticid spider Sibianor larae (Araneae: Salticidae) in the Netherlands // Ent. Berichten. - 2012. - 72. - P. 254 - 258." type="book chapter" year="2012">Vogels, 2012</bibRefCitation>
). In 
<collectingCountry id="F7DD7663FFE8E020FC7A59D8FF5BFEE4" box="[957,1056,239,266]" name="Belgium" pageId="1" pageNumber="186">Belgium</collectingCountry>
, 
<collectingCountry id="F7DD7663FFE8E020FBE959D8FFE0FEE4" box="[1070,1179,239,266]" name="Germany" pageId="1" pageNumber="186">Germany</collectingCountry>
and 
<collectingCountry id="F7DD7663FFE8E020FF695838FA47FEC4" box="[174,316,271,298]" name="Netherlands" pageId="1" pageNumber="186">Netherlands</collectingCountry>
<taxonomicName id="48CA4D70FFE8E020FE855827FAEEFEC7" authorityName="Logunov" authorityYear="2000" box="[322,405,271,298]" class="Arachnida" family="Salticidae" genus="Sibianor" kingdom="Animalia" order="Araneae" pageId="1" pageNumber="186" phylum="Arthropoda" rank="species" species="larae">
<emphasis id="BDBEEAE1FFE8E020FE855827FAEEFEC7" box="[322,405,271,298]" italics="true" pageId="1" pageNumber="186">S. larae</emphasis>
</taxonomicName>
was characterized as a rare species (
<bibRefCitation id="EB5B4B02FFE8E020FCF75838F8B1FEC4" author="Vogels, J." box="[816,970,271,298]" pageId="1" pageNumber="186" pagination="254 - 258" refId="ref1726" refString="Vogels, J. First record of the salticid spider Sibianor larae (Araneae: Salticidae) in the Netherlands // Ent. Berichten. - 2012. - 72. - P. 254 - 258." type="book chapter" year="2012">Vogels, 2012</bibRefCitation>
).
</paragraph>
