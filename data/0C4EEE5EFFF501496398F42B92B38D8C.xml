<subSubSection id="CCFD0CC3FFF5014963A5F49792B38D8C" pageId="23" pageNumber="46" type="discussion">
<paragraph id="84585F48FFF5014963A5F49792B38D8C" blockId="23.[151,760,1175,1710]" pageId="23" pageNumber="46">
<emphasis id="B693835AFFF5014963A5F49792668F8C" bold="true" box="[151,279,1175,1198]" pageId="23" pageNumber="46">Comments.</emphasis>
<bibRefCitation id="E07622B9FFF501496229F49792D68F8C" author="CHUJO M." bookContentInfo="466 pp." box="[283,423,1175,1198]" editor="KIRA T. &amp; UMESAO T." firstAuthor="CHUJO" journalOrPublisher="Fauna and Flora Research Society, Kyoto" pageId="23" pageNumber="46" pagination="252 - 315" refId="ref30706" refString="CHUJO M. 1964: 32. Family Chrysomelidae. Pp. 252 - 315. In: KIRA T. &amp; UMESAO T. (eds): Nature and life in Southeast Asia, Vol. 3. Fauna and Flora Research Society, Kyoto, 466 pp." title="32. Family Chrysomelidae" type="book chapter" volumeTitle="Nature and life in Southeast Asia, Vol. 3" year="1964">CHÛJÔ (1964)</bibRefCitation>
described a new subgenus 
<taxonomicName id="43E724CBFFF501496188F49792D18FEC" authority="Chujo, 1964" authorityName="Chujo" authorityYear="1964" class="Insecta" family="Chrysomelidae" genus="Luperomorpha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="subGenus" subGenus="Luperomorphella">
<emphasis id="B693835AFFF501496188F497926B8FEC" italics="true" pageId="23" pageNumber="46">Luperomorphella</emphasis>
<bibRefCitation id="E07622B9FFF50149622DF4B792D18FEC" author="CHUJO M." bookContentInfo="466 pp." box="[287,416,1207,1230]" editor="KIRA T. &amp; UMESAO T." firstAuthor="Chujo" journalOrPublisher="Fauna and Flora Research Society, Kyoto" pageId="23" pageNumber="46" pagination="252 - 315" refId="ref30706" refString="CHUJO M. 1964: 32. Family Chrysomelidae. Pp. 252 - 315. In: KIRA T. &amp; UMESAO T. (eds): Nature and life in Southeast Asia, Vol. 3. Fauna and Flora Research Society, Kyoto, 466 pp." title="32. Family Chrysomelidae" type="book chapter" volumeTitle="Nature and life in Southeast Asia, Vol. 3" year="1964">Chûjô, 1964</bibRefCitation>
</taxonomicName>
of the alticine genus 
<taxonomicName id="43E724CBFFF50149614BF4B792398FCC" authority="Weise, 1887" authorityName="Weise" authorityYear="1887" class="Insecta" family="Chrysomelidae" genus="Luperomorpha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFF50149614BF4B793CE8FCC" italics="true" pageId="23" pageNumber="46">Luperomorpha</emphasis>
Weise, 1887
</taxonomicName>
, together with a new species 
<taxonomicName id="43E724CBFFF50149614AF4D791CA8E2C" authority="Chujo, 1964" authorityName="Chujo" authorityYear="1964" class="Insecta" family="Chrysomelidae" genus="Luperomorpha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="species" species="albomaculata" subGenus="Luperomorphella">
<emphasis id="B693835AFFF50149614AF4D793CE8E2C" italics="true" pageId="23" pageNumber="46">Luperomorpha</emphasis>
(
<emphasis id="B693835AFFF5014963E2F4F792FB8E2C" box="[208,394,1271,1294]" italics="true" pageId="23" pageNumber="46">Luperomorphella</emphasis>
) 
<emphasis id="B693835AFFF5014962A9F4F7915F8E2C" box="[411,558,1271,1294]" italics="true" pageId="23" pageNumber="46">albomaculata</emphasis>
<bibRefCitation id="E07622B9FFF501496104F4F791CA8E2C" author="CHUJO M." bookContentInfo="466 pp." box="[566,699,1271,1294]" editor="KIRA T. &amp; UMESAO T." firstAuthor="Chujo" journalOrPublisher="Fauna and Flora Research Society, Kyoto" pageId="23" pageNumber="46" pagination="252 - 315" refId="ref30706" refString="CHUJO M. 1964: 32. Family Chrysomelidae. Pp. 252 - 315. In: KIRA T. &amp; UMESAO T. (eds): Nature and life in Southeast Asia, Vol. 3. Fauna and Flora Research Society, Kyoto, 466 pp." title="32. Family Chrysomelidae" type="book chapter" volumeTitle="Nature and life in Southeast Asia, Vol. 3" year="1964">Chûjô, 1964</bibRefCitation>
</taxonomicName>
from 
<collectingCountry id="FCF01FD8FFF5014963A5F51793888E0C" box="[151,249,1303,1326]" name="Thailand" pageId="23" pageNumber="46">Thailand</collectingCountry>
. 
<bibRefCitation id="E07622B9FFF501496236F51792D08E0C" author="KIMOTO S." box="[260,417,1303,1326]" firstAuthor="KIMOTO" journalOrPublisher="Bulletin of the Institute of Comparative Studies of Inernational Cultures and Societies" pageId="23" pageNumber="46" pagination="103 - 299" part="26" refId="ref31739" refString="KIMOTO S. 2000: Chrysomelidae (Coleoptera) of Thailand, Cambodia, Laos and Vietnam. VII. Alticinae. Bulletin of the Institute of Comparative Studies of Inernational Cultures and Societies 26: 103 - 299." title="Chrysomelidae (Coleoptera) of Thailand, Cambodia, Laos and Vietnam. VII. Alticinae" type="journal article" year="2000">KIMOTO (2000)</bibRefCitation>
synonymized 
<taxonomicName id="43E724CBFFF50149610CF51791898E0C" authorityName="Chujo" authorityYear="1964" box="[574,760,1303,1326]" class="Insecta" family="Chrysomelidae" genus="Luperomorpha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="subGenus" subGenus="Luperomorphella">
<emphasis id="B693835AFFF50149610CF51791898E0C" box="[574,760,1303,1326]" italics="true" pageId="23" pageNumber="46">Luperomorphella</emphasis>
</taxonomicName>
with 
<taxonomicName id="43E724CBFFF5014963FFF53792358E6C" authorityName="Thunberg" authorityYear="1814" box="[205,324,1335,1358]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFF5014963FFF53792358E6C" box="[205,324,1335,1358]" italics="true" pageId="23" pageNumber="46">Taumacera</emphasis>
</taxonomicName>
and, consequently, proposed a new combination 
<taxonomicName id="43E724CBFFF5014963C0F55791EB8E4C" authority="(Chujo, 1964)" baseAuthorityName="Chujo" baseAuthorityYear="1964" box="[242,666,1367,1390]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="species" species="albomaculata">
<emphasis id="B693835AFFF5014963C0F557928F8E4C" box="[242,510,1367,1390]" italics="true" pageId="23" pageNumber="46">Taumacera albomaculata</emphasis>
(
<bibRefCitation id="E07622B9FFF501496139F55791E08E4C" author="CHUJO M." bookContentInfo="466 pp." box="[523,657,1367,1390]" editor="KIRA T. &amp; UMESAO T." firstAuthor="Chujo" journalOrPublisher="Fauna and Flora Research Society, Kyoto" pageId="23" pageNumber="46" pagination="252 - 315" refId="ref30706" refString="CHUJO M. 1964: 32. Family Chrysomelidae. Pp. 252 - 315. In: KIRA T. &amp; UMESAO T. (eds): Nature and life in Southeast Asia, Vol. 3. Fauna and Flora Research Society, Kyoto, 466 pp." title="32. Family Chrysomelidae" type="book chapter" volumeTitle="Nature and life in Southeast Asia, Vol. 3" year="1964">Chûjô, 1964</bibRefCitation>
)
</taxonomicName>
. I did not examine the type material of 
<taxonomicName id="43E724CBFFF5014962F2F57791808EAC" authorityName="Chujo" authorityYear="1964" box="[448,753,1399,1422]" class="Insecta" family="Chrysomelidae" genus="Luperomorpha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="species" species="albomaculata">
<emphasis id="B693835AFFF5014962F2F57791808EAC" box="[448,753,1399,1422]" italics="true" pageId="23" pageNumber="46">Luperomorpha albomaculata</emphasis>
</taxonomicName>
, however, the original description is accompanied with a photograph of the 
<typeStatus id="5B5CE1EAFFF501496266F5B792C58EEC" box="[340,436,1463,1486]" pageId="23" pageNumber="46">holotype</typeStatus>
. The pronotum has a transverse depression and the specific structure of the antennae with short and robuster antennomeres as well as an expanded antennomere IV are characteristic of the genus 
<taxonomicName id="43E724CBFFF50149614DF61791808D0C" authorityName="Chevrolat" authorityYear="1836" box="[639,753,1559,1582]" class="Insecta" family="Chrysomelidae" genus="Cerophysa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFF50149614DF61791808D0C" box="[639,753,1559,1582]" italics="true" pageId="23" pageNumber="46">Cerophysa</emphasis>
</taxonomicName>
. Therefore I remove 
<taxonomicName id="43E724CBFFF50149624FF637914A8D6C" authorityName="Chujo" authorityYear="1964" box="[381,571,1591,1614]" class="Insecta" family="Chrysomelidae" genus="Luperomorpha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="subGenus" subGenus="Luperomorphella">
<emphasis id="B693835AFFF50149624FF637914A8D6C" box="[381,571,1591,1614]" italics="true" pageId="23" pageNumber="46">Luperomorphella</emphasis>
</taxonomicName>
from synonymy with 
<taxonomicName id="43E724CBFFF5014963F9F65792338D4C" authorityName="Thunberg" authorityYear="1814" box="[203,322,1623,1646]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFF5014963F9F65792338D4C" box="[203,322,1623,1646]" italics="true" pageId="23" pageNumber="46">Taumacera</emphasis>
</taxonomicName>
and synonymize it with 
<taxonomicName id="43E724CBFFF501496172F65791C38D4C" authorityName="Chevrolat" authorityYear="1836" box="[576,690,1623,1646]" class="Insecta" family="Chrysomelidae" genus="Cerophysa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFF501496172F65791C38D4C" box="[576,690,1623,1646]" italics="true" pageId="23" pageNumber="46">Cerophysa</emphasis>
</taxonomicName>
, thus I also propose a new combination 
<taxonomicName id="43E724CBFFF5014962DFF677925C8D8C" authority="(Chujo, 1964)" authorityName="Bezděk" authorityYear="2019" baseAuthorityName="Chujo" baseAuthorityYear="1964" class="Insecta" family="Chrysomelidae" genus="Cerophysa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="46" phylum="Arthropoda" rank="species" species="albomaculata">
<emphasis id="B693835AFFF5014962DFF67791898DAC" box="[493,760,1655,1678]" italics="true" pageId="23" pageNumber="46">Cerophysa albomaculata</emphasis>
(
<bibRefCitation id="E07622B9FFF5014963ACF69792578D8C" author="CHUJO M." bookContentInfo="466 pp." box="[158,294,1687,1710]" editor="KIRA T. &amp; UMESAO T." firstAuthor="Chujo" journalOrPublisher="Fauna and Flora Research Society, Kyoto" pageId="23" pageNumber="46" pagination="252 - 315" refId="ref30706" refString="CHUJO M. 1964: 32. Family Chrysomelidae. Pp. 252 - 315. In: KIRA T. &amp; UMESAO T. (eds): Nature and life in Southeast Asia, Vol. 3. Fauna and Flora Research Society, Kyoto, 466 pp." title="32. Family Chrysomelidae" type="book chapter" volumeTitle="Nature and life in Southeast Asia, Vol. 3" year="1964">Chûjô, 1964</bibRefCitation>
)
</taxonomicName>
(comb. nov.).
</paragraph>
