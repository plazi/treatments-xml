<subSubSection id="BAE8264099698DA45F96D9194DD6B273" pageId="null" pageNumber="494" type="description">
<paragraph id="E979F70656C74E62817CB230FD1D177F" pageId="null" pageNumber="494">
Ausdauernd, mit knollig verdicktem Rhizom. 
<normalizedToken id="E96B12649254FFBFAF5A815290DCE452" originalValue="Blätter" pageId="null" pageNumber="494">Blaetter</normalizedToken>
in Spreite und Stiel gegliedert; Spreite mit netzigen Nerven. 
<normalizedToken id="4FF95E7F512145E1F36A0601C6645099" originalValue="Blütenstand" pageId="null" pageNumber="494">Bluetenstand</normalizedToken>
<normalizedToken id="2597B618F6A5A80AB515AE0A0C6BDE11" originalValue="endständig" pageId="null" pageNumber="494">endstaendig</normalizedToken>
. Hochblatt (
<taxonomicName id="1520AEBF9DC211547FEA8965CA4347F6" class="Bivalvia" family="Iridinidae" genus="Spatha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Unionida" pageId="null" pageNumber="494" phylum="Mollusca" rank="genus">Spatha</taxonomicName>
) den Kolben 
<normalizedToken id="213C9C8E2FD6D9ADB5AD62850C5BCA39" originalValue="umhüllend" pageId="null" pageNumber="494">umhuellend</normalizedToken>
. 
<emphasis id="EB9286CEA69FBE3B07D1429BD46628CD" italics="true" pageId="null" pageNumber="494">
Kolbenachse im obern Teil ohne 
<normalizedToken id="A4BF0B2A02F324A013D5578BFCCBD7A9" originalValue="Blüten" pageId="null" pageNumber="494">Blueten</normalizedToken>
. Alle 
<normalizedToken id="EF387F47077440CCA560679C3825644D" originalValue="Blüten" pageId="null" pageNumber="494">Blueten</normalizedToken>
1 geschlechtig; die untern 
<normalizedToken id="5A7AFAF9B3CE3952F018BD1F3703C9D6" originalValue="Blüten" pageId="null" pageNumber="494">Blueten</normalizedToken>
</emphasis>
♀, 
<emphasis id="9F3E575CD22732738A85BA8A6732A8F7" italics="true" pageId="null" pageNumber="494">die obern</emphasis>
♂
<emphasis id="7091998BA5CA3C4B128E15DB112F7568" italics="true" pageId="null" pageNumber="494">;</emphasis>
zwischen den ♂ und ♀ 
<normalizedToken id="88FFB1C5EF3E7CDD2B4B1032D1A18AA6" originalValue="Blüten" pageId="null" pageNumber="494">Blueten</normalizedToken>
an der Kolbenachse ein kleiner Abstand. Kein Perigon vorhanden. Fruchtknoten 1 
<normalizedToken id="9639F22E074192DEF34ADCED8DEAC203" originalValue="fächerig" pageId="null" pageNumber="494">faecherig</normalizedToken>
, mit mehreren Samenanlagen. Narbe sitzend.
</paragraph>
<paragraph id="C8E3228AC76B1A892980D1C70C39946C" pageId="null" pageNumber="494">
Die Gattung 
<taxonomicName id="1970A090546F71D4F679E7B948A00A69" class="Liliopsida" family="Araceae" genus="Arum" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="494" phylum="Tracheophyta" rank="genus">
<emphasis id="C6388EBDA32755D4B6918AAB7A23BD2D" italics="true" pageId="null" pageNumber="494">Arum</emphasis>
</taxonomicName>
<normalizedToken id="2A31ADC4BF00B7213138B41E7BC2F3CF" originalValue="umfaßt" pageId="null" pageNumber="494">umfasst</normalizedToken>
etwa 
<emphasis id="CEFA1F096D632F926098D36FF6E777F6" italics="true" pageId="null" pageNumber="494">
12 Arten, die in 
<taxonomicName id="8816F8ADC72BD79C4C1A14603DCE1585" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="494" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
und vor allem im Mediterrangebiet verbreitet sind
</emphasis>
(
<normalizedToken id="78914634C652D6287F9D2AEE3DBED92A" originalValue="ostwärts" pageId="null" pageNumber="494">ostwaerts</normalizedToken>
bis in den Kaukasus, 1 Art noch in Turkestan). Monographische Bearbeitung von Engler (1920).
</paragraph>
<paragraph id="1F6CCAC5935FE9B95865E9BB523009D3" pageId="null" pageNumber="494">
<table id="EA819C7A933F5626B80E8E890B3D8960" frame="void" pageId="null" pageNumber="494" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="5AC37A56D38B164BAD05DE8D2AEDC126" pageId="null" pageNumber="494">
<tr id="781090D2787CED6E4767E28F36487F13" pageId="null" pageNumber="494">
<td id="2DEB3B0B3CF2F846202D5132F82C307F" align="left" pageId="null" pageNumber="494" valign="top">
1. 
<normalizedToken id="2DDF3114EA64A9D410147BC43D68B80D" originalValue="Blätter" pageId="null" pageNumber="494">Blaetter</normalizedToken>
im 
<normalizedToken id="1F667DE8EB98B48632B0E07CE28DB41B" originalValue="Frühling" pageId="null" pageNumber="494">Fruehling</normalizedToken>
erscheinend, 
<normalizedToken id="387A8A04C2713C4C99805B0C056D6B9C" originalValue="gleichmäßig" pageId="null" pageNumber="494">gleichmaessig</normalizedToken>
<normalizedToken id="D55281A93643D29C020E4AD3CD56BF71" originalValue="grün" pageId="null" pageNumber="494">gruen</normalizedToken>
oder oberseits dunkel gefleckt; der nicht mit 
<normalizedToken id="48D5604285672992795CEC3BC6616E89" originalValue="Blüten" pageId="null" pageNumber="494">Blueten</normalizedToken>
besetzte, oberste Teil der Kolbenachse purpurn oder violett
</td>
<td id="EAC4F482C20E1F9D163490F33D74B365" align="left" pageId="null" pageNumber="494" valign="bottom">
<taxonomicName id="5BC2431DC78CC165DB1B590E63D4C1CD" class="Liliopsida" family="Araceae" genus="Arum" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="494" phylum="Tracheophyta" rank="species" species="maculatum">
<italic id="1295C846E29023F45FF28D544251F3C5" pageId="null" pageNumber="494">A. maculatum</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="895E3A495C0485321A9CC139AD7E8519" pageId="null" pageNumber="494">
<td id="CCA799ED9399F53EFD1F71387D7A950D" align="left" pageId="null" pageNumber="494" valign="top">
1*. 
<normalizedToken id="C16C8F7A3C2CE754A714E8AE452FC60F" originalValue="Blätter" pageId="null" pageNumber="494">Blaetter</normalizedToken>
im 
<normalizedToken id="329C4D8499826D21977AD853A61F3B68" originalValue="Spätherbst" pageId="null" pageNumber="494">Spaetherbst</normalizedToken>
erscheinend, oberseits den Nerven entlang 
<normalizedToken id="99A474E4541C8BD0A31D2CF62715E550" originalValue="weißlich" pageId="null" pageNumber="494">weisslich</normalizedToken>
; der nicht mit 
<normalizedToken id="A102BF7B95100E2B7337641F256003F7" originalValue="Blüten" pageId="null" pageNumber="494">Blueten</normalizedToken>
besetzte, oberste Teil der Kolbenachse meist gelb
</td>
<td id="92FD89A0A12F7396F702D2B7115B8A42" align="left" pageId="null" pageNumber="494" valign="bottom">
<taxonomicName id="41F2AC5F17EA1FBC82470FD5A8779165" class="Liliopsida" family="Poaceae" genus="Lolium" kingdom="Plantae" order="Poales" pageId="null" pageNumber="494" phylum="Tracheophyta" rank="species" species="italicum">
<italic id="7AE17CED4FABBB47CA41FC5D48115EA0" pageId="null" pageNumber="494">A. italicum</italic>
</taxonomicName>
(Nr. 2)
</td>
</tr>
</tbody>
</table>
</paragraph>
