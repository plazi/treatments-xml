<subSubSection id="E81BBDEAA8B74AD268FD268D2ECD6850" pageId="null" pageNumber="582" type="description">
<paragraph id="FD770A44996AEA0FCFB4C74C4C4E31FA" pageId="null" pageNumber="582">
Zwiebel vorhanden. 
<normalizedToken id="A4F927CD3B9A6AA9F99FB2BA5F6EBA73" originalValue="Blätter" pageId="null" pageNumber="582">Blaetter</normalizedToken>
<normalizedToken id="E144D1B511838633254CCA1DD2D4931D" originalValue="grundständig" pageId="null" pageNumber="582">grundstaendig</normalizedToken>
, 
<normalizedToken id="614D0BE79AD6F9D72F7399194D2EF85C" originalValue="grasähnlich" pageId="null" pageNumber="582">grasaehnlich</normalizedToken>
, fleischig. Stengel mit 1 
<normalizedToken id="31A99F3233754835B64C8694E0143BC3" originalValue="Blüte" pageId="null" pageNumber="582">Bluete</normalizedToken>
. 
<normalizedToken id="642F1D740238539438526230DB4B8CBC" originalValue="Blüte" pageId="null" pageNumber="582">Bluete</normalizedToken>
nickend, von einem 
<normalizedToken id="DBD13668F0B76EBD10DDBF089307F32B" originalValue="Hüllblatt" pageId="null" pageNumber="582">Huellblatt</normalizedToken>
<normalizedToken id="7DD1D8000A551F433C7222C7E0FD6FF4" originalValue="überragt" pageId="null" pageNumber="582">ueberragt</normalizedToken>
, das die scheinbare Stengelfortsetzung bildet. 
<emphasis id="44CB4F5B6E01B02B7DC92E42895E1F69" italics="true" pageId="null" pageNumber="582">
<normalizedToken id="152D61CF3369E011D3D88B2FF623E9F4" originalValue="Äuβere" pageId="null" pageNumber="582">Aeuβere</normalizedToken>
3 
<normalizedToken id="BE121F97419A6A5B306898ACEC31C793" originalValue="Perigonblätter" pageId="null" pageNumber="582">Perigonblaetter</normalizedToken>
<normalizedToken id="44A804171A44E7140605869EF73CDAEE" originalValue="±" pageId="null" pageNumber="582">+/-</normalizedToken>
waagrecht abstehend, 
<normalizedToken id="738BD1C60A2681679348CE274A82B12B" originalValue="weiβ" pageId="null" pageNumber="582">weiβ</normalizedToken>
, innere 3 
<normalizedToken id="AAB37A2F044950F4C8D4BBBBBDB3C3BD" originalValue="Perigonblätter" pageId="null" pageNumber="582">Perigonblaetter</normalizedToken>
zusammenneigend.
</emphasis>
<normalizedToken id="17FD4CA8AB19B66B46820D8A5E9DF1D1" originalValue="Staubblätter" pageId="null" pageNumber="582">Staubblaetter</normalizedToken>
6. Frucht eine 3 
<normalizedToken id="D3519895AF87F814338D7F4DC987071E" originalValue="fächrige" pageId="null" pageNumber="582">faechrige</normalizedToken>
Kapsel; in jedem Fach mehrere Samen; Griffel 1.
</paragraph>
<paragraph id="D4F5EA70BBB47F55A4C97AB71B3D8E37" pageId="null" pageNumber="582">
Die Gattung 
<taxonomicName id="5F9B0CDD93E1843DDB290A03D93E1CA2" class="Liliopsida" family="Amaryllidaceae" genus="Galanthus" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="582" phylum="Tracheophyta" rank="genus">
<emphasis id="43220186F598A8B3E42798689D91FF58" italics="true" pageId="null" pageNumber="582">Galanthus</emphasis>
</taxonomicName>
<normalizedToken id="50363788024C00D20CCE0272AD31AE6B" originalValue="umfaßt" pageId="null" pageNumber="582">umfasst</normalizedToken>
<emphasis id="70265FABAFEE4A862776F68BE110B6F8" italics="true" pageId="null" pageNumber="582">
10 Arten; Zentrum der Gattung im 
<normalizedToken id="17BB60B7CF23A284DB7EAC24732ADAA9" originalValue="östlichen" pageId="null" pageNumber="582">oestlichen</normalizedToken>
Mittelmeer gebiet undKaukasus
</emphasis>
(Verbreitungskarte von Meusel 1964).
</paragraph>
<paragraph id="36D51885B427D91A158586535221FC61" pageId="null" pageNumber="582">
Die meisten Arten haben 
<emphasis id="5A15C8C77489A58D35F84CDB975911DE" italics="true" pageId="null" pageNumber="582">2n</emphasis>
= 
<emphasis id="6EF04887F9445AE3CAF444E49C9ABA69" italics="true" pageId="null" pageNumber="582">24 Chromosomen; Polyploidie</emphasis>
(2n = 36, 48) und 
<emphasis id="7DD455D4D9E66D6C79CE98EBF79A4AE3" italics="true" pageId="null" pageNumber="582">aneuploide</emphasis>
Chromosomenzahlen (2n = 25, 28) sind selten.
</paragraph>
