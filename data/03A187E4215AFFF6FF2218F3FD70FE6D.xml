(
<figureCitation id="13332A77215AFFF7FF2A1F1EFEB9FBD1" box="[159,295,1051,1077]" captionStart="FIGURE 1" captionStartId="3.[151,250,1866,1890]" captionTargetBox="[171,1412,191,1824]" captionTargetId="figure-20@3.[171,1416,181,1841]" captionTargetPageId="3" captionText="FIGURE 1. Grammedessa. A–B: G. hamata comb.n. A: Dorsal view. B: Ventral view. C–D: G. nigricava sp.n. C: Dorsal view. D: Ventral view. E–F: G. longispina sp.n. E: Dorsal view. F: Ventral view. G–H: G. fundicava sp.n. G: Dorsal view. H: Ventral view. I–J: G. graciligramma sp.n. I: Dorsal view. J: Ventral view. K–L: G. stichtocephala sp.n. K: Dorsal view. L: Ventral view. M–N: G. acalyptoprocta sp.n. M: Dorsal view. N: Ventral view. Scale = 10 mm." figureDoi="http://doi.org/10.5281/zenodo.6500667" httpUri="https://zenodo.org/record/6500667/files/figure.png" pageId="8" pageNumber="219">Figs. 1G–H</figureCitation>
; 
<figureCitation id="13332A77215AFFF7FE871F1FFEE8FBD1" box="[306,374,1050,1077]" captionStart="FIGURE 5" captionStartId="9.[151,250,1773,1797]" captionTargetBox="[168,1419,449,1738]" captionTargetId="figure-111@9.[156,1431,417,1750]" captionTargetPageId="9" captionText="FIGURE 5. Male genitalia of G. fundicava sp.n. A: Pygophore in dorsal view. B: Pygophore in ventral view. C: Pygophore in posterior view. Scale = 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6500683" httpUri="https://zenodo.org/record/6500683/files/figure.png" pageId="8" pageNumber="219">5A–C</figureCitation>
)
