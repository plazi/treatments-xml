<caption id="DDE76614072FFF80FCD3FAB16A584028" ID-DOI="http://doi.org/10.5281/zenodo.6603817" ID-Zenodo-Dep="6603817" httpUri="https://zenodo.org/record/6603817/files/figure.png" inLine="true" pageId="3" pageNumber="237" targetBox="[186,776,1002,1415]" targetPageId="3">
