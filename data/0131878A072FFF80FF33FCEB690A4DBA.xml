<subSubSection id="C1826517072FFF80FCD2FC106FB34343" pageId="3" pageNumber="237" type="reference_group">
<paragraph id="8927369C072FFF80FCD2FC1068C942C8" blockId="3.[800,1392,1001,1425]" pageId="3" pageNumber="237">
<emphasis id="BBECEA8E072FFF80FCD2FC1068B34204" bold="true" box="[801,956,1001,1030]" pageId="3" pageNumber="237">Taxonomy.</emphasis>
<taxonomicName id="4E984D1F072FFF80FC3CFC10686A422C" authority="Merriam" authorityName="Merriam" authorityYear="1901" class="Mammalia" family="Geomyidae" genus="Thomomys" kingdom="Animalia" order="Rodentia" pageId="3" pageNumber="237" phylum="Chordata" rank="species" species="idahoensis">Thomomys idahoensis Merriam, 1901</taxonomicName>
, 
<materialsCitation id="39F03CC1072FFF80FC77FBE868C942C8" ID-GBIF-Occurrence="3799834329" pageId="3" pageNumber="237">“Birch Creek, Idaho.” Restricted by J. L. Patton in 2005 to “USA, Idaho, Clark Co., Birch Creek (10 mi [16 km] S Nicholia [Lemhi Co.], about 6,400 ft. [1940 m]).”</materialsCitation>
</paragraph>
<paragraph id="8927369C072FFF80FCD2FB2B6FB34343" blockId="3.[800,1392,1001,1425]" pageId="3" pageNumber="237">
Placed into subgenus 
<taxonomicName id="4E984D1F072FFF80FBAEFB2B6FEE42F1" authorityName="Wied-Neuwied" authorityYear="1839" box="[1117,1249,1234,1267]" class="Mammalia" family="Geomyidae" genus="Thomomys" kingdom="Animalia" order="Rodentia" pageId="3" pageNumber="237" phylum="Chordata" rank="genus">Thomomys</taxonomicName>
. Originally regarded as a subspecies of 
<taxonomicName id="4E984D1F072FFF80FB25FB006E654318" baseAuthorityName="Richardson" baseAuthorityYear="1828" box="[1238,1386,1273,1306]" class="Mammalia" family="Geomyidae" genus="Thomomys" kingdom="Animalia" order="Rodentia" pageId="3" pageNumber="237" phylum="Chordata" rank="species" species="talpoides">T. talpoides</taxonomicName>
. Three subspecies recognized.
</paragraph>
</subSubSection>
