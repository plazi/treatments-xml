<subSubSection id="85A6D497907BCF2B38BE0312846355CF" pageId="null" pageNumber="878" type="description">
<paragraph id="7BB7674156A964D66DE4760FD618BBC1" pageId="null" pageNumber="878">
Ausdauernde 
<normalizedToken id="2B43C9AC75E7610D396B4687DF45E3AF" originalValue="Kräuter" pageId="null" pageNumber="878">Kraeuter</normalizedToken>
. Unterste 
<normalizedToken id="10AE2751083001E6A9B09F5FB7F9B4C4" originalValue="Blätter" pageId="null" pageNumber="878">Blaetter</normalizedToken>
3 
<normalizedToken id="1858B9662B64BF2612F689E4487D1978" originalValue="zählig" pageId="null" pageNumber="878">zaehlig</normalizedToken>
oder 2fach gefiedert, mit breit lanzettlichen, 
<normalizedToken id="332A7A27BA56152D1CB601CFA7E18C3F" originalValue="gezähnten" pageId="null" pageNumber="878">gezaehnten</normalizedToken>
<normalizedToken id="1064625F249E55EDC54411B026C00314" originalValue="Teilblättern" pageId="null" pageNumber="878">Teilblaettern</normalizedToken>
. Dolden 1. und 2. Ordnung vorhanden. 
<emphasis id="64B94717C25D4DA5DCA149B7BD03F0BE" italics="true" pageId="null" pageNumber="878">
Keine 
<normalizedToken id="422D8773AE6FCD49067A6133D2D25ACD" originalValue="Hochblätter" pageId="null" pageNumber="878">Hochblaetter</normalizedToken>
1. und 2. Ordnung.
</emphasis>
<normalizedToken id="4770DD4246CEB8D18AA5D930860413B5" originalValue="Blüten" pageId="null" pageNumber="878">Blueten</normalizedToken>
⚥ und ♂ aktinomorph, 
<normalizedToken id="D87CCCC9F0150BE31AA305049EA6008E" originalValue="weiß" pageId="null" pageNumber="878">weiss</normalizedToken>
. Frucht weniger als 2mal so lang wie dick, wenig abgeflacht (
<normalizedToken id="25C962B19E5F637839E9F3D15E72F246" originalValue="Fugenfläche" pageId="null" pageNumber="878">Fugenflaeche</normalizedToken>
verkleinert!), mit 
<normalizedToken id="825A2945F306FF8826105431385F0269" originalValue="fadenförmigen" pageId="null" pageNumber="878">fadenfoermigen</normalizedToken>
Hauptrippen; 
<emphasis id="6C72805173EADBDDF3179193468893C1" italics="true" pageId="null" pageNumber="878">
Griffelpolster 
<normalizedToken id="B7B9CD537E5173830F64191706230F5F" originalValue="groß" pageId="null" pageNumber="878">gross</normalizedToken>
, etwa
</emphasis>
⅕ 
<emphasis id="7B154BD71C7EFE898A2BE9D17A4936F4" italics="true" pageId="null" pageNumber="878">so lang wie die Frucht;</emphasis>
Griffel wenigstens 2mal so lang wie das Griffelpolster; Narbe 
<normalizedToken id="BF93A020D2987E05465E52D557BA6D6C" originalValue="zurückgebogen" pageId="null" pageNumber="878">zurueckgebogen</normalizedToken>
.
</paragraph>
<paragraph id="710EB089CC7FB689BB6D077044EDA73A" pageId="null" pageNumber="878">
Die Gattung 
<taxonomicName id="BC7FB432939B4D86044C80678B0ACBD7" class="Magnoliopsida" family="Apiaceae" genus="Aegopodium" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="878" phylum="Tracheophyta" rank="genus">
<emphasis id="DB1CD7E898DB9A3CC4A8F72ECDA83249" italics="true" pageId="null" pageNumber="878">Aegopodium</emphasis>
</taxonomicName>
<normalizedToken id="44B754646C575F3ADB38266480678AC8" originalValue="umfaßt" pageId="null" pageNumber="878">umfasst</normalizedToken>
<emphasis id="66FF533F71578D9DEF8C6110DAC0F7CD" italics="true" pageId="null" pageNumber="878">5 Arten</emphasis>
(nach Flora URSS Bd. 16) 
<emphasis id="4A938A493ABA6778A8CC8060FBAC5120" italics="true" pageId="null" pageNumber="878">mit eurosibirischer Verbreitung;</emphasis>
in Europa nur 
<emphasis id="020F071780EAD31AC24C9DF6C7F28BBE" italics="true" pageId="null" pageNumber="878">
Ae. 
<taxonomicName id="5A7B3EF1CFEC753141E38EF2CF380996" class="Magnoliopsida" family="Apiaceae" genus="Aegopodium" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="878" phylum="Tracheophyta" rank="species" species="podagraria">Podagraria</taxonomicName>
.
</emphasis>
</paragraph>
