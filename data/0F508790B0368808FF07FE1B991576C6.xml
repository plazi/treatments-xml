<subSubSection id="CFE3650DB0368808FF7AFE3B991576C6" pageId="8" pageNumber="479" type="biology_ecology">
<paragraph id="87463686B0368808FF7AFE3B992B75E6" blockId="8.[166,1225,399,746]" box="[219,884,431,458]" pageId="8" pageNumber="479">Hosts: European mouflon (P = 20 %; I = 1015 (1–2029)).</paragraph>
<paragraph id="87463686B0368808FF7AFE5B98BC75C6" blockId="8.[166,1225,399,746]" box="[219,739,463,490]" pageId="8" pageNumber="479">Site of infection: abomasum, small intestine.</paragraph>
<paragraph id="87463686B0368808FF07FE7B9B347626" blockId="8.[166,1225,399,746]" box="[166,363,495,522]" pageId="8" pageNumber="479">
<taxonomicName id="40F94D05B0368808FF07FE7B9B347626" box="[166,363,495,522]" class="Secernentea" family="Molineidae" genus="Nematodirus" kingdom="Animalia" order="Strongylida" pageId="8" pageNumber="479" phylum="Nematoda" rank="species" species="undetermined">
<emphasis id="B58DEA94B0368808FF07FE7B9B1B7626" bold="true" box="[166,324,495,522]" italics="true" pageId="8" pageNumber="479">Nematodirus</emphasis>
sp.
</taxonomicName>
</paragraph>
<paragraph id="87463686B0368808FF7AFD9B998F76E6" blockId="8.[166,1225,399,746]" pageId="8" pageNumber="479">Hosts: American bison (P = 9.1 %; I = 4); Ankole-Watusi (P = 100 %; I = 3); Siberian ibex (P = 100 %; I = 2); common eland (P = 28.9 %; I = 686.2 (1–4,420)); blackbuck (P = 62.5 %; I = 272.8 (5–599)); Barbary sheep (P = 60 %; I = 55 (14–131)); saiga antelope (P = 34.8 %; I = 42.4 (1–194)); markhor (P = 63.6 %; I = 167.6 (2–340)); red deer (P = 33.3 %; I = 2 (1–3)); guanaco (P = 66.7 %; I = 102.1 (75–130)); llama (P = 66.7 %; I = 234 (12–456)); alpaca (P = 100 %; I = 8); nilgai (P = 14.3 %; I = 1).</paragraph>
<paragraph id="87463686B0368808FF7AFD5B991576C6" blockId="8.[166,1225,399,746]" box="[219,842,719,746]" pageId="8" pageNumber="479">Site of infection: abomasum, small intestine, caecum.</paragraph>
</subSubSection>
