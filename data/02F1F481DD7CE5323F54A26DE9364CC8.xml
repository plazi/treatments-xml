<subSubSection id="418A9E8A50276E70CE1500869040EDB7" pageId="null" pageNumber="241" type="description">
<paragraph id="9EB56744601928CA8E311A653DA46218" pageId="null" pageNumber="241">
1 
<normalizedToken id="2E6951F8CE5A548F9BDDCC824B3F3DFE" originalValue="jährig" pageId="null" pageNumber="241">jaehrig</normalizedToken>
, mit Pfahlwurzel; 15-30 cm hoch. Stengel aufrecht, 1fach oder verzweigt, mit einzelnen anliegenden 2strahligen Haaren. 
<normalizedToken id="01281A7DA07DF8D189DE6774F31C8166" originalValue="Blätter" pageId="null" pageNumber="241">Blaetter</normalizedToken>
schmal lanzettlich, die untern gestielt und 
<emphasis id="BFC9CB12C8AB541EF5FC0AFECE30FA7E" italics="true" pageId="null" pageNumber="241">
buchtig 
<normalizedToken id="D5D38AA3224B63D92A26AECE93F2D113" originalValue="gezähnt" pageId="null" pageNumber="241">gezaehnt</normalizedToken>
bis fiederteilig
</emphasis>
(
<emphasis id="27AB9A98D035F765267C275467C5DBEE" italics="true" pageId="null" pageNumber="241">Abschnitte 3eckig</emphasis>
), die obern mit 
<normalizedToken id="B274BCB9A56ADD8026BC075DB2E783BA" originalValue="verschmälertem" pageId="null" pageNumber="241">verschmaelertem</normalizedToken>
Grunde sitzend und 
<normalizedToken id="86DAEC21A6855684BCD7D58002B11742" originalValue="±" pageId="null" pageNumber="241">+/-</normalizedToken>
ganzrandig, 
<emphasis id="CB1F0E587F6DDA8A49CA2A9AC43B5D1C" italics="true" pageId="null" pageNumber="241">10-20mal so lang wie breit</emphasis>
, beiderseits mit anliegenden 2strahligen und vereinzelten 3strahligen Haaren. 
<normalizedToken id="D42403F2FDF26E91F4EEF4DFFFD5DF0F" originalValue="Kelchblätter" pageId="null" pageNumber="241">Kelchblaetter</normalizedToken>
3-5 mm lang, am Grunde nicht ausgebuchtet, zerstreut und anliegend behaart. 
<normalizedToken id="F04C4A603F5938264160493E67D9E3C8" originalValue="Kronblätter" pageId="null" pageNumber="241">Kronblaetter</normalizedToken>
6-10 mm lang, hellgelb. 
<emphasis id="327632C6440DBB3E0835E31827B74BB4" italics="true" pageId="null" pageNumber="241">Staubbeutel 0,8-1,2 mm lang. Fruchtstiele</emphasis>
1/20-1/15 
<emphasis id="66558C0B09F7322DED98B097E15F8E07" italics="true" pageId="null" pageNumber="241">
so lang wie die 
<normalizedToken id="5AFE80722322BBF85E0E901C3050E34E" originalValue="Früchte" pageId="null" pageNumber="241">Fruechte</normalizedToken>
</emphasis>
, etwa so dick wie die 
<normalizedToken id="DB695169FBC5B168C06EB186DAF74310" originalValue="Früchte" pageId="null" pageNumber="241">Fruechte</normalizedToken>
(bei den andern Arten aus dem Gebiet deutlich 
<normalizedToken id="00338E72A7CD4D97D05DE45C94313A64" originalValue="dünner" pageId="null" pageNumber="241">duenner</normalizedToken>
), 
<emphasis id="00F35E3B1D76FAE4044C7A17D005C976" italics="true" pageId="null" pageNumber="241">fast waagrecht abstehend</emphasis>
, anliegend behaart. 
<normalizedToken id="4ED9735837A6018779504A0FB7FB6662" originalValue="Früchte" pageId="null" pageNumber="241">Fruechte</normalizedToken>
45-100 mm lang und 1-1,5 mm dick, anliegend behaart; Griffel 2-5 mm lang, mit 
<normalizedToken id="8D7A5033B80209361E4ED2C9BCA2FBE8" originalValue="±" pageId="null" pageNumber="241">+/-</normalizedToken>
ungeteilter Narbe. Samen 1,2-1,7 mm lang, 
<normalizedToken id="F1F6901DC5FBDB7DBF576AB09B243AD3" originalValue="bootförmig" pageId="null" pageNumber="241">bootfoermig</normalizedToken>
, mit 0,2-0,4 mm breitem 
<normalizedToken id="ABE7059D154E18D8212FF071EEF9DD27" originalValue="flügelförmigem" pageId="null" pageNumber="241">fluegelfoermigem</normalizedToken>
Rand. - 
<normalizedToken id="3EB7A05DF3A71EA89453718C911F8A5D" originalValue="Blüte" pageId="null" pageNumber="241">Bluete</normalizedToken>
: 
<normalizedToken id="1D523763FA6E307D45FBCBC31769E44C" originalValue="Später" pageId="null" pageNumber="241">Spaeter</normalizedToken>
<normalizedToken id="6D56866A06F2136F1CF86486BFC4E487" originalValue="Frühling" pageId="null" pageNumber="241">Fruehling</normalizedToken>
und 
<normalizedToken id="9233E77F686CAE6B1F60AF83F4851A49" originalValue="früher" pageId="null" pageNumber="241">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="03E19453E891EEAE356463F36021893C" pageId="null" pageNumber="241">
<emphasis id="001184C970B423DE9CCBEE5537E5E1B2" italics="true" pageId="null" pageNumber="241">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D80952C392AE437487EAE2A1FE8D8B1A" italics="true" pageId="null" pageNumber="241">16:</emphasis>
Material aus Island (
<normalizedToken id="F89DE52D2A050767321FF13580CA81CD" originalValue="Löve" pageId="null" pageNumber="241">Loeve</normalizedToken>
und 
<normalizedToken id="4CD506C89F0DA84C2B0E26FB371C597C" originalValue="Löve" pageId="null" pageNumber="241">Loeve</normalizedToken>
1956b), aus Ungarn (Baksay in 
<normalizedToken id="474A774213010759B9390F8E8996CDDC" originalValue="Löve" pageId="null" pageNumber="241">Loeve</normalizedToken>
und 
<normalizedToken id="B1507781E1437907FBB8A658AB5F2B50" originalValue="Löve" pageId="null" pageNumber="241">Loeve</normalizedToken>
1961), aus dem Burgenland (Polatschek 1966), aus Kanada (Mulligan 1966). 
<emphasis id="5A544C4C6F4C0532E215E1FAE51A81B8" italics="true" pageId="null" pageNumber="241">2n</emphasis>
= 
<emphasis id="E52DB4A839FCDE05289E0B6B2E7C03AA" italics="true" pageId="null" pageNumber="241">14-16:</emphasis>
Material aus botanischem Garten (Manton 1932). 
<emphasis id="3C35DB976C40030846B100A5E8B82CA6" italics="true" pageId="null" pageNumber="241">2n</emphasis>
= 
<emphasis id="A85BDF0B105B820EA3D7F8D664974923" italics="true" pageId="null" pageNumber="241">14</emphasis>
und 
<emphasis id="229DA0421A338C0077A25E53A054C375" italics="true" pageId="null" pageNumber="241">28:</emphasis>
Material aus den USA (Easterly 1963).
</paragraph>
<paragraph id="3A8D33DE1E6D9F9F6FB1D8E2529428F4" pageId="null" pageNumber="241">
<emphasis id="D7D0F263875360C69658B105E92132DE" italics="true" pageId="null" pageNumber="241">Standort.</emphasis>
Kollin. Ziemlich trockene, 
<normalizedToken id="2FBADBF97DAD4ECBFBAF4B5C9B293EDB" originalValue="nährstoffreiche" pageId="null" pageNumber="241">naehrstoffreiche</normalizedToken>
, tonige 
<normalizedToken id="837EBC97891A71055221994F103B8B28" originalValue="Böden" pageId="null" pageNumber="241">Boeden</normalizedToken>
in 
<normalizedToken id="9E8B3FF6209D3C9306BE029566403ABF" originalValue="wärmeren" pageId="null" pageNumber="241">waermeren</normalizedToken>
Lagen. 
<normalizedToken id="980FEEF2014D6AEA5CD5794592199E11" originalValue="Äcker" pageId="null" pageNumber="241">Aecker</normalizedToken>
, Schuttstellen, 
<normalizedToken id="0DC2E235267734CCBBA520852FB97D1D" originalValue="Wegränder" pageId="null" pageNumber="241">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="E963D055AB9569A6AC392C11D7D227FC" pageId="null" pageNumber="241">
<emphasis id="C595FFC2B5EB2781FC9E6515FA74E335" italics="true" pageId="null" pageNumber="241">
Verbreitung. 
<normalizedToken id="32038F25C0AD8BF51D1D0F2F0F35DD60" originalValue="Südosteuropäische" pageId="null" pageNumber="241">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
West- und 
<normalizedToken id="69F8791E4BF992DE132ABE88A4B73BFD" originalValue="nordwärts" pageId="null" pageNumber="241">nordwaerts</normalizedToken>
bis Ostalpen, 
<normalizedToken id="8BCDB26CFC1E7BAD4D210E4C7AB6F57C" originalValue="Mähren" pageId="null" pageNumber="241">Maehren</normalizedToken>
, 
<normalizedToken id="02E2C3F6ABD77AA039170D0E5AE21ED9" originalValue="Siebenbürgen" pageId="null" pageNumber="241">Siebenbuergen</normalizedToken>
, Ukraine; 
<normalizedToken id="A1084C53D1962F47C03DA2C4D6310B51" originalValue="ostwärts" pageId="null" pageNumber="241">ostwaerts</normalizedToken>
bis Kaukasus und Persien. - Im Gebiet gelegentlich adventiv.
</paragraph>
