<subSubSection id="D557101A33C006A5A2861A616FE46966" pageId="null" pageNumber="592" type="vernacular_names">
<paragraph id="ADE05637358B0EF11980BD5271F62C48" pageId="null" pageNumber="592">Saat-Gladiole</paragraph>
</subSubSection>
</title>
<subSubSection id="44040A4E3C61682A8F38FB702641FEB6" pageId="null" pageNumber="592" type="description">
<paragraph id="3381E0C007A4781E5FD9A6EDFDC0192E" pageId="null" pageNumber="592">
30-60 cm hoch. Fasern der 
<normalizedToken id="59C743C12C8E91D4C0099BA78E09BEF5" originalValue="Knollenhäute" pageId="null" pageNumber="592">Knollenhaeute</normalizedToken>
im obern Teil der Knolle fast parallel laufend; Maschen des Netzes deshalb sehr lang und schmal. 
<normalizedToken id="C94F33221007CD8E157832456529E5DE" originalValue="Blätter" pageId="null" pageNumber="592">Blaetter</normalizedToken>
bis 2 cm breit, 
<normalizedToken id="DE75FCAC04253A7F6DC55D33B341E8C5" originalValue="allmählich" pageId="null" pageNumber="592">allmaehlich</normalizedToken>
zugespitzt. 
<normalizedToken id="4F4B9B20D9C84A23D9C4BDA967F7F1B0" originalValue="Blütenstand" pageId="null" pageNumber="592">Bluetenstand</normalizedToken>
5-10 
<normalizedToken id="13066C540C15A1666A6FC55D4B1598FF" originalValue="blütig" pageId="null" pageNumber="592">bluetig</normalizedToken>
. 
<normalizedToken id="28F3D8FCE8C210152C0C478368F3CF28" originalValue="Blüten" pageId="null" pageNumber="592">Blueten</normalizedToken>
blaurot. 
<normalizedToken id="9A227B10BD724B48C352B237E48286E7" originalValue="Perigonblätter" pageId="null" pageNumber="592">Perigonblaetter</normalizedToken>
4-6 cm lang. 
<emphasis id="8C2649DC1F992BB43F96877DE215BDE4" italics="true" pageId="null" pageNumber="592">
Staubbeutel wenig 
<normalizedToken id="DEA3553BD9A39D184C49936DC7477224" originalValue="länger" pageId="null" pageNumber="592">laenger</normalizedToken>
als die 
<normalizedToken id="9883A382E551203D2B5ACB3C7D84CADD" originalValue="Staubfäden" pageId="null" pageNumber="592">Staubfaeden</normalizedToken>
. Samen nicht 
<normalizedToken id="5D0BD809209ABD2FC935B735BE323B79" originalValue="geflügelt" pageId="null" pageNumber="592">gefluegelt</normalizedToken>
. -
</emphasis>
<normalizedToken id="3C346279176F87AECA7BC7CCB06AAFDC" originalValue="Blüte" pageId="null" pageNumber="592">Bluete</normalizedToken>
: 
<normalizedToken id="74ED1938522D6400AAAFFC6C49BFE141" originalValue="Frühling" pageId="null" pageNumber="592">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="2B374B9915BA8E9AE26DD0A6F49CCB3D" pageId="null" pageNumber="592">
<emphasis id="A7488AB26776855292EB7AD1F80DD8B8" italics="true" pageId="null" pageNumber="592">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="6E10A1F7748A550863D42560FE1DC8F6" italics="true" pageId="null" pageNumber="592">120</emphasis>
(Bamford aus Darlington und Wylie 1955).
</paragraph>
<paragraph id="66DD7B05314EFAFF17CBF262DF1D7CFC" pageId="null" pageNumber="592">
<emphasis id="4CF7F23222AC7D51DB1046FF8966D5DE" italics="true" pageId="null" pageNumber="592">Standort.</emphasis>
Kollin. 
<normalizedToken id="DF6EF3CDC8DC9A34772B12E476788CD9" originalValue="Äcker" pageId="null" pageNumber="592">Aecker</normalizedToken>
in warmen Lagen.
</paragraph>
<paragraph id="9C76942D0FD67203658585ED9F927637" pageId="null" pageNumber="592">
<emphasis id="58FF36F67F395C373260EC874D14F05B" italics="true" pageId="null" pageNumber="592">Verbreitung. Mediterran-asiatische Pflanze:</emphasis>
In 
<taxonomicName id="B07D4427A0B82BCAC09139916D515883" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="592" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
<normalizedToken id="1BFC5BEA392183B0C5E91AB6589C3F19" originalValue="nordwärts" pageId="null" pageNumber="592">nordwaerts</normalizedToken>
bis 
<normalizedToken id="7AEC74347D9A805B473A529109BBBD96" originalValue="Vendée" pageId="null" pageNumber="592">Vendee</normalizedToken>
, 
<normalizedToken id="FB5ECD9F63BDE778F2577A06DB07C055" originalValue="Puy-de-Dôme" pageId="null" pageNumber="592">Puy-de-Dome</normalizedToken>
, Genf, 
<normalizedToken id="9A873723888E4362F38D38B0C9EB4EEC" originalValue="südliches" pageId="null" pageNumber="592">suedliches</normalizedToken>
Tessin, Etschtal (Rovereto), 
<normalizedToken id="E9C0AA8AEF88CBEA4B657A481B7FDDCD" originalValue="Küstengebiete" pageId="null" pageNumber="592">Kuestengebiete</normalizedToken>
der Balkanhalbinsel, Krim; Kaukasus, 
<normalizedToken id="5F6DE5C1083BC279B8B42559FE777C4E" originalValue="ostwärts" pageId="null" pageNumber="592">ostwaerts</normalizedToken>
bis Zentralasien und Persien; Nordafrika. Verbreitungskarte von Meusel (1964). - Im Gebiet: 
<normalizedToken id="3E6A4774FE37F3B602485DC26FA44263" originalValue="Früher" pageId="null" pageNumber="592">Frueher</normalizedToken>
in Savoyen, bei Genf, im Tessin (Locarno, Lugano, Gandria, Viganello, Loco im Onsernonetal) und angrenzenden Gebieten (
<normalizedToken id="09F9DF815436651CCABB6BC137B9B9A7" originalValue="früher" pageId="null" pageNumber="592">frueher</normalizedToken>
verbreitet und ziemlich 
<normalizedToken id="8F4A563A30C6D13F2032F68D521D1D76" originalValue="häufig" pageId="null" pageNumber="592">haeufig</normalizedToken>
); heute wahrscheinlich 
<normalizedToken id="C916078A8FF179A7A9125FC06DEB3634" originalValue="überall" pageId="null" pageNumber="592">ueberall</normalizedToken>
erloschen.
</paragraph>
<paragraph id="44E87168C28F0176A605B314837E4412" pageId="null" pageNumber="592">
Neuerdings wird 
<normalizedToken id="3D0EDF2B4145785400B7CC38AA17E5E4" originalValue="für" pageId="null" pageNumber="592">fuer</normalizedToken>
<taxonomicName id="4D4D0DBDDE76793D46410AB6728428D3" authority="der Name" authorityName="der Name" class="Liliopsida" family="Iridaceae" genus="Gladiolus" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="592" phylum="Tracheophyta" rank="species" species="segetum">
<emphasis id="83CA5EABCF834540BB1E2A340CDBF608" italics="true" pageId="null" pageNumber="592">G. segetum</emphasis>
der Name
</taxonomicName>
<taxonomicName id="92D71293DB310E48AE209B9068A4E397" authority="Miller" authorityName="Miller" class="Liliopsida" family="Iridaceae" genus="Gladiolus" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="592" phylum="Tracheophyta" rank="species" species="italicus">
<emphasis id="1380ED8338213A71CEC8099B50080645" italics="true" pageId="null" pageNumber="592">G. italicus</emphasis>
Miller
</taxonomicName>
als 
<normalizedToken id="1C0D9A2A4B96448E92EB8A6B37ECC1F2" originalValue="gültig" pageId="null" pageNumber="592">gueltig</normalizedToken>
<normalizedToken id="E8E11B0185FE02E3A6925C952005BEC4" originalValue="erklärt" pageId="null" pageNumber="592">erklaert</normalizedToken>
(vgl. dazu Becherer, 
<normalizedToken id="F95C9AD4100A8931F87BF5C6673E195F" originalValue="«Fortschritte»" pageId="null" pageNumber="592">&quot;Fortschritte&quot;</normalizedToken>
1964).
</paragraph>
</subSubSection>
