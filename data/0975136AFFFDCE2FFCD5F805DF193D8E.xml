<taxonomicName id="46DCD9FFFFFCCE2CFD0DF853DB833B91" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="113" pageNumber="114" phylum="Arthropoda" rank="species" species="utinga">
