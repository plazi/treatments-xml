<taxonomicName id="46DCD9FFFFFCCE2CFEFBF83FDA253426" baseAuthorityName="Lucas" baseAuthorityYear="1834" box="[260,374,2030,2056]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="113" pageNumber="114" phylum="Arthropoda" rank="species" species="rufipes">
