<taxonomicName id="46DCD9FFFFFCCE2CFBBCF9C2DF993A02" baseAuthorityName="Doleschall" baseAuthorityYear="1871" box="[1091,1226,1555,1581]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="113" pageNumber="114" phylum="Arthropoda" rank="species" species="nattereri">
