<taxonomicName id="46DCD9FFFFFCCE2CFC87F9C2D88A3A02" baseAuthorityName="Doleschall" baseAuthorityYear="1871" box="[888,985,1555,1580]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="113" pageNumber="114" phylum="Arthropoda" rank="species" species="nattereri">
