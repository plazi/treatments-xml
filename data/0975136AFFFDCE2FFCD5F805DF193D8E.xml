</taxonomicName>
and 
<taxonomicName id="46DCD9FFFFFCCE2CFD0DF83FDB833402" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="113" pageNumber="114" phylum="Arthropoda" rank="species" species="utinga">
<emphasis id="B3A87E6EFFFCCE2CFD0DF83FDB833402" italics="true" pageId="113" pageNumber="114">A. utinga</emphasis>
</taxonomicName>
