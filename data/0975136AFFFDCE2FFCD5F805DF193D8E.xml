<taxonomicName id="46DCD9FFFFFCCE2CFDC5F83FD9E13426" box="[570,690,2030,2056]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="113" pageNumber="114" phylum="Arthropoda" rank="species" species="harveyi">
