<taxonomicName id="FEBD4D68D056FFEBC00BFD40FEA164A9" box="[265,381,662,688]" class="Pinopsida" family="Cupressaceae" genus="Athrotaxis" kingdom="Plantae" order="Pinales" pageId="4" pageNumber="213" phylum="Tracheophyta" rank="genus">
<emphasis id="0BC9EAF9D056FFEBC00BFD40FEA164A9" box="[265,381,662,688]" italics="true" pageId="4" pageNumber="213">Athrotaxis</emphasis>
</taxonomicName>
; also known from 
<collectingCountry id="41AA767BD056FFEBC350FD41FD3564A9" box="[594,745,662,689]" name="New Zealand" pageId="4" pageNumber="213">New Zealand</collectingCountry>
and southern South America. 
<collectionCode id="5FACAE2ED056FFEBC53FFD40FB8C64A9" box="[1085,1104,662,688]" country="USA" lsid="urn:lsid:biocol.org:col:15406" name="Harvard University - Arnold Arboretum" pageId="4" pageNumber="213" type="Herbarium">A</collectionCode>
