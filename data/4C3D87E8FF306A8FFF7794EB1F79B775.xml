<subSubSection id="8C8E6575FF306A8FFD1395811CABBE1D" pageId="203" pageNumber="965" type="discussion">
<paragraph id="C42B36FEFF306A8FFD1395811CABBE1D" blockId="203.[749,1347,869,1289]" lastBlockId="203.[132,1344,1294,3143]" pageId="203" pageNumber="965">
Subgenus 
<taxonomicName id="03944D7DFF306A8FFC5F95811DFAB8C7" authority="Kaup, 1829" box="[931,1018,984,1013]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="203" pageNumber="965" phylum="Chordata" rank="genus">Myotis</taxonomicName>
; 
<taxonomicName id="03944D7DFF306A8FFBC895811AB4B8C7" baseAuthorityName="Horsfield" baseAuthorityYear="1855" box="[1076,1204,984,1013]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="203" pageNumber="965" phylum="Chordata" rank="species" species="siligorensis">siligorensis</taxonomicName>
species group. 
<taxonomicName id="03944D7DFF306A8FFC9C95A21A1FBF2E" authorityName="Topal" authorityYear="1998" box="[864,1055,1019,1052]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="203" pageNumber="965" phylum="Chordata" rank="species" species="csorbai">Myotis csorbai</taxonomicName>
is morphologically very similar to 
<taxonomicName id="03944D7DFF306A8FFC33927B1A6ABF71" baseAuthorityName="Dobson" baseAuthorityYear="1873" box="[975,1130,1058,1091]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="203" pageNumber="965" phylum="Chordata" rank="species" species="longipes">M. longipes</taxonomicName>
, and its sister-group is the 
<taxonomicName id="03944D7DFF306A8FFC3292131A50BF59" baseAuthorityName="Bonaparte" baseAuthorityYear="1837" box="[974,1104,1098,1131]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="203" pageNumber="965" phylum="Chordata" rank="species" species="capaccinii">capaccinii</taxonomicName>
species group. Records from NE 
<collectingCountry id="BC83766EFF306A8FFBF9922F1A50BFA1" box="[1029,1104,1142,1171]" name="India" pageId="203" pageNumber="965">India</collectingCountry>
(
<collectingRegion id="0650F81CFF306A8FFB91922F1B0EBFA1" box="[1133,1294,1142,1171]" country="India" name="Meghalaya" pageId="203" pageNumber="965">Meghalaya</collectingRegion>
), S 
<collectingCountry id="BC83766EFF306A8FFD1392C01D45BF88" box="[751,837,1177,1210]" name="China" pageId="203" pageNumber="965">China</collectingCountry>
(
<collectingRegion id="0650F81CFF306A8FFC9B92C01DDEBF88" box="[871,990,1177,1210]" country="China" name="Sichuan" pageId="203" pageNumber="965">Sichuan</collectingRegion>
, 
<collectingRegion id="0650F81CFF306A8FFC0792C01A9EBF88" box="[1019,1182,1177,1210]" country="China" name="Chongqing" pageId="203" pageNumber="965">Chongqing</collectingRegion>
, 
<collectingRegion id="0650F81CFF306A8FFB4792C01B37BF88" box="[1211,1335,1177,1210]" country="China" name="Guizhou" pageId="203" pageNumber="965">Guizhou</collectingRegion>
, and 
<collectingRegion id="0650F81CFF306A8FFCCB92901DB7BFD0" box="[823,951,1225,1250]" country="China" name="Guangxi" pageId="203" pageNumber="965">Guangxi</collectingRegion>
), and C 
<collectingCountry id="BC83766EFF306A8FFBB792901A8CBFD0" box="[1099,1164,1225,1250]" name="Laos" pageId="203" pageNumber="965">Laos</collectingCountry>
need additional taxonomic assessment to confirm their identity as 
<taxonomicName id="03944D7DFF306A8FFE8F93571FFBBE1D" authorityName="Topal" authorityYear="1998" box="[371,507,1294,1327]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="203" pageNumber="965" phylum="Chordata" rank="species" species="csorbai">M. csorbai</taxonomicName>
. Monotypic.
</paragraph>
</subSubSection>
<subSubSection id="8C8E6575FF306A8FFF74936C1D2EBE64" box="[136,814,1333,1366]" pageId="203" pageNumber="965" type="distribution">
<caption id="90EB6676FF306A8FFF74936C1D2EBE64" ID-DOI="http://doi.org/10.5281/zenodo.6398912" ID-Zenodo-Dep="6398912" box="[136,814,1333,1366]" httpUri="https://zenodo.org/record/6398912/files/figure.png" inLine="true" pageId="203" pageNumber="965" targetBox="[135,726,870,1284]" targetPageId="203">
