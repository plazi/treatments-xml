<figureCitation id="08DA2A7AFFFCBD561C22A887936A0368" box="[780,847,498,520]" captionStart="Map 1" captionStartId="1.[178,223,1523,1543]" captionTargetBox="[178,1085,675,1512]" captionTargetId="figure-165@1.[178,1085,675,1512]" captionTargetPageId="1" captionText="Map 1: Distributions of Orsunius immsi (white circles), O. parvexcisus (black diamonds), O. yunnanus (white triangles), O. pravus (black triangles), O. wunderlei (white star), O. excisus (black square), and O. prolongatus (black star)." figureDoi="http://doi.org/10.5281/zenodo.5305059" httpUri="https://zenodo.org/record/5305059/files/figure.png" pageId="3" pageNumber="464">Map 1</figureCitation>
