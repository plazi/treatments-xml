<taxonomicName id="64F095D1FFA1FFDD39C60F36458CBF34" authority="Arruda (Koster 1816: 500)" authorityName="Arruda (Koster" authorityYear="1816" box="[157,674,1023,1051]" class="Magnoliopsida" family="Fabaceae" genus="Mimosa" kingdom="Plantae" order="Fabales" pageId="47" pageNumber="274" phylum="Tracheophyta" rank="species" species="virginalis">
<emphasis id="91843240FFA1FFDD39C60F364640BF35" bold="true" box="[157,366,1023,1050]" italics="true" pageId="47" pageNumber="274">Mimosa virginalis</emphasis>
Arruda (
<bibRefCitation id="C76193A3FFA1FFDD38890F3645B4BF34" author="Koster, H." box="[466,666,1024,1051]" pageId="47" pageNumber="274" refId="ref42743" refString="Koster, H. (1816) Travels in Brazil. Longman, Hurst, Rees, Orme and Brown, London, 501 pp. https: // doi. org / 10.5962 / bhl. title. 60564" type="book" year="1816">Koster 1816: 500</bibRefCitation>
