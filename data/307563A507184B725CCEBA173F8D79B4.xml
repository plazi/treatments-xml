<subSubSection id="A19B0FC2E8777C33E491E2D96FB03234" pageId="null" pageNumber="156" type="description">
<paragraph id="31D1C3410213C2803855211BC8E507E1" pageId="null" pageNumber="156">
2-10 cm hoch. Triebe kurz, 
<emphasis id="69F4AD35384A7F6D57A32B3531FBC267" italics="true" pageId="null" pageNumber="156">
nur 2-10 cm weit oberirdisch kriechend, mit zahlreichen Wurzeln im Boden fest verankert. Jedes Jahr meist nur 1, seltener mehrere, senkrecht stehende Triebe mit 1 
<normalizedToken id="8CCDC51C3F3822A3ECE9B42095514B6B" originalValue="Sporangienähre" pageId="null" pageNumber="156">Sporangienaehre</normalizedToken>
an der Spitze treibend.
</emphasis>
<normalizedToken id="B4A32C46AE94499563C652FF50F0E3AF" originalValue="Blätter" pageId="null" pageNumber="156">Blaetter</normalizedToken>
an den kriechenden Stengeln schmal lanzettlich, 5-8 mm lang und 0,5-1 mm breit, ganzrandig, spitz, vom Boden abgewendet; 
<normalizedToken id="EA924E83E1570ACDDA8E3B047051BEB8" originalValue="Blätter" pageId="null" pageNumber="156">Blaetter</normalizedToken>
an den senkrechten Trieben von gleicher Form und 
<normalizedToken id="2491BD5F667AA03521D397B697C8BAD5" originalValue="Größe" pageId="null" pageNumber="156">Groesse</normalizedToken>
, allseitig locker abstehend. 
<emphasis id="8099CD23983BB14DDCEDA4D6D4B053A6" italics="true" pageId="null" pageNumber="156">
<normalizedToken id="B68AFCDD64A0EA766DDF7F640EABDD72" originalValue="Sporangienähren" pageId="null" pageNumber="156">Sporangienaehren</normalizedToken>
nicht gestielt, einzeln auf der Spitze der aufsteigenden Triebe sitzend
</emphasis>
, bis 5 cm lang. 
<emphasis id="85C93D3A2F3C42D196131B914796CFD7" italics="true" pageId="null" pageNumber="156">
Sporangientragende 
<normalizedToken id="D6B03BE5F9684E599CBBC18E310366AD" originalValue="Blätter" pageId="null" pageNumber="156">Blaetter</normalizedToken>
etwa so lang und von gleicher Form wie die anderen 
<normalizedToken id="6347F3BBAB693E355AE8F187DF602830" originalValue="Blätter" pageId="null" pageNumber="156">Blaetter</normalizedToken>
</emphasis>
, am Grunde 
<normalizedToken id="FDE7E4166E46BD69C49B954E8C17EFB7" originalValue="unregelmäßig" pageId="null" pageNumber="156">unregelmaessig</normalizedToken>
<normalizedToken id="F7B77BDA833FAC5E6556F4676949F49A" originalValue="gezähnt" pageId="null" pageNumber="156">gezaehnt</normalizedToken>
(
<normalizedToken id="BC2E772CEB22D9F5CE00F59082FFE50D" originalValue="Zähne" pageId="null" pageNumber="156">Zaehne</normalizedToken>
bis 0,5 mm lang), sonst ganzrandig. - Sporenreife: Sommer.
</paragraph>
<paragraph id="71F728F37CFC3D112123D6ED8AE39506" pageId="null" pageNumber="156">
<emphasis id="54F7EB78C0D5DDCEC1C8AC7034E9F182" italics="true" pageId="null" pageNumber="156">Zytologische Angaben. 2n = 156:</emphasis>
Material aus Schottland (Manton 1950), aus Kanada (Quebec und Manitoba) und Island (
<normalizedToken id="88483DE1008391D7A886A2327C6CE0B6" originalValue="Löve" pageId="null" pageNumber="156">Loeve</normalizedToken>
und 
<normalizedToken id="5265664785B6EB8A097E36C0C2B67806" originalValue="Löve" pageId="null" pageNumber="156">Loeve</normalizedToken>
1958c), aus Finnland (Sorsa 1958 1962).
</paragraph>
<paragraph id="10EBCAB0E9D23FDEC5665FA738F078C9" pageId="null" pageNumber="156">
<emphasis id="B48D9527B13A734596D2D0B070E95537" italics="true" pageId="null" pageNumber="156">Standort.</emphasis>
Kollin, montan und subalpin. Nasse, zeitweise 
<normalizedToken id="413BA1B8291151E20C576CA94144170C" originalValue="überschwemmte" pageId="null" pageNumber="156">ueberschwemmte</normalizedToken>
, saure, torfige, schlammige 
<normalizedToken id="A19A2714A3AC93EF27503C9862E861B3" originalValue="Böden" pageId="null" pageNumber="156">Boeden</normalizedToken>
(
<normalizedToken id="182F0518BD2C5317E64428C34ED0720E" originalValue="Torfschlammböden" pageId="null" pageNumber="156">Torfschlammboeden</normalizedToken>
). Hochmoore: 
<taxonomicName id="BBF9268546F6A21B194614E9EC926E2C" authority="Br." authorityName="Br." class="Lycopodiopsida" family="Lycopodiaceae" genus="Caricetum" kingdom="Plantae" order="Lycopodiales" pageId="null" pageNumber="156" phylum="Tracheophyta" rank="species" species="limosae">
<emphasis id="B955ED98D60D2C1A9DCEEF8E93348F7A" italics="true" pageId="null" pageNumber="156">Caricetum limosae</emphasis>
Br.
</taxonomicName>
-Bl. 1921 (in Schlenken) und 
<emphasis id="83643560B57F3D4886DBBA43B72FB247" italics="true" pageId="null" pageNumber="156">Rhynchosporetum albae</emphasis>
W. Koch 1926 (auf Schwingrasen).
</paragraph>
<paragraph id="BD450BEF2B625AE4C5648F3B61B89DB0" pageId="null" pageNumber="156">
<emphasis id="65F2EBD2941D9CC19C622EAB36A8E737" italics="true" pageId="null" pageNumber="156">
<pageBreakToken id="BC81E569D4F64EC18B07ACB55F99ADAB" pageId="null" pageNumber="156">Verbreitung</pageBreakToken>
. 
<normalizedToken id="6614DB080C1AFCF15ED96EE62C1F8722" originalValue="Europäisch-ostasiatisch-nordamerikanische" pageId="null" pageNumber="156">Europaeisch-ostasiatisch-nordamerikanische</normalizedToken>
Pflanze:
</emphasis>
Nordgrenze in Skandinavien und Finnland bei 67° NB, 
<normalizedToken id="99CFACF931A4F14CCECBC6799823E621" originalValue="ostwärts" pageId="null" pageNumber="156">ostwaerts</normalizedToken>
bis ins Gebiet der Wolga; 
<normalizedToken id="7A83F4D1924E563E579E1AFD32D2EA44" originalValue="Südgrenze" pageId="null" pageNumber="156">Suedgrenze</normalizedToken>
durch Kastilien, Norditalien, 
<normalizedToken id="5100B9A5A9D8A56F1104C70011A308EE" originalValue="Rumänien" pageId="null" pageNumber="156">Rumaenien</normalizedToken>
, 
<normalizedToken id="0D27591CE84EC673DA5F7EDC945B3AE0" originalValue="Südrußland" pageId="null" pageNumber="156">Suedrussland</normalizedToken>
, Schwarzmeergebiet; in Ostasien aus Japan angegeben; in Nordamerika im Westen und Osten zwischen 40 und 60° NB. Verbreitungskarten von 
<normalizedToken id="4F36BB5F5AAC45678D2957D8C02B63BF" originalValue="Hultén" pageId="null" pageNumber="156">Hulten</normalizedToken>
(1958) und Meusel (1964). - Im Gebiet der speziellen Standorte wegen selten und im 
<normalizedToken id="3DF0CA6704AB559DDA344C21E13778E6" originalValue="Rückgang" pageId="null" pageNumber="156">Rueckgang</normalizedToken>
(Meliorationen).
</paragraph>
</subSubSection>
