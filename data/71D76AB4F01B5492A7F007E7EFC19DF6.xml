<taxonomicName id="179E772DFB9E6B70A077A1519B4AD65F" authorityName="Titova" authorityYear="1975" class="Chilopoda" family="Mecistocephalidae" genus="Krateraspis" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Krateraspis sselivanovi" order="Geophilomorpha" pageId="0" pageNumber="143" phylum="Arthropoda" rank="species" species="sselivanovi">
