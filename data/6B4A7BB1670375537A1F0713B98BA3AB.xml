<subSubSection id="59CC014F87F2D1722C46176278739B3B" pageId="null" pageNumber="723" type="description">
<paragraph id="F0AFD13844CA11C589F3B8E957F51636" pageId="null" pageNumber="723">
Meist 
<emphasis id="3155CB4E54C76E44E758C3EFE8878CF9" italics="true" pageId="null" pageNumber="723">
1 
<normalizedToken id="B9BA7AC30A0D1CDB6D57E795D8300344" originalValue="jährige" pageId="null" pageNumber="723">jaehrige</normalizedToken>
<normalizedToken id="23451D903BF7BC45CE914AB9D92BB0CB" originalValue="Kräuter" pageId="null" pageNumber="723">Kraeuter</normalizedToken>
.
</emphasis>
<normalizedToken id="26A43CD4E7F5B28B88FFC60B9545CA78" originalValue="Blätter" pageId="null" pageNumber="723">Blaetter</normalizedToken>
<normalizedToken id="7EEA61681B2F738657EED883176FAC84" originalValue="gegenständig" pageId="null" pageNumber="723">gegenstaendig</normalizedToken>
oder die obersten 
<normalizedToken id="33FC3A9EC217BD2C971FE842A2535C4C" originalValue="wechselständig" pageId="null" pageNumber="723">wechselstaendig</normalizedToken>
, nicht 
<normalizedToken id="0FC0A733A86F1B8AE715E0192C17A0DF" originalValue="nadelförmig" pageId="null" pageNumber="723">nadelfoermig</normalizedToken>
, 
<emphasis id="44C332EA097892A499E3403BE09701A8" italics="true" pageId="null" pageNumber="723">
ungestielt, mit 3 
<normalizedToken id="B82FC5658D4620A54EFB46DC1CC1D2BF" originalValue="Längsnerven" pageId="null" pageNumber="723">Laengsnerven</normalizedToken>
</emphasis>
(
<emphasis id="F446712B7572E723ABCDEBBF4EDC16AB" italics="true" pageId="null" pageNumber="723">am Grunde auch 5 Nerven</emphasis>
), ohne 
<normalizedToken id="83C78BF008A12E504E3F07F208E365BA" originalValue="Nebenblätter" pageId="null" pageNumber="723">Nebenblaetter</normalizedToken>
oder die obern mit 
<normalizedToken id="59ED7B8701A92162ED4B293E5B423B2C" originalValue="Nebenblättern" pageId="null" pageNumber="723">Nebenblaettern</normalizedToken>
. 
<normalizedToken id="F5E7ED1EE430178F1B403F113F9900D7" originalValue="Kelchblätter" pageId="null" pageNumber="723">Kelchblaetter</normalizedToken>
5, ungleich 
<normalizedToken id="24037EB09E217963448684D37458F205" originalValue="groß" pageId="null" pageNumber="723">gross</normalizedToken>
, die beiden 
<normalizedToken id="99E23CBCCA5BD65054DBCBFEAB4F76A4" originalValue="äußern" pageId="null" pageNumber="723">aeussern</normalizedToken>
meist kleiner als die 3 innern. 
<normalizedToken id="2E71B8B33E588AB7E45C8E6C568FE825" originalValue="Kronblätter" pageId="null" pageNumber="723">Kronblaetter</normalizedToken>
klein, 
<normalizedToken id="198CE6BA49D16AD5ECE7FFA1B035C982" originalValue="kürzer" pageId="null" pageNumber="723">kuerzer</normalizedToken>
als 1 cm, gelb oder orange, am Grunde oft mit dunklem Fleck. Alle 
<normalizedToken id="7A68639F34824348CF93AA16D2F75C60" originalValue="Staubblätter" pageId="null" pageNumber="723">Staubblaetter</normalizedToken>
mit Staubbeuteln. Fruchtknoten aus 3 
<normalizedToken id="5F463E2713A8A41FE15F03C4DA8F253A" originalValue="Fruchtblättern" pageId="null" pageNumber="723">Fruchtblaettern</normalizedToken>
, 3 
<normalizedToken id="AC02E11505CF57A5CD41CB6F0C5A6107" originalValue="fächerig" pageId="null" pageNumber="723">faecherig</normalizedToken>
. Narbe ungeteilt oder undeutlich 3teilig, 
<emphasis id="8876458F410D1A5CD945EE78F9D3A6D5" italics="true" pageId="null" pageNumber="723">sitzend</emphasis>
(
<emphasis id="72DA27BB24C8A5D583642D3667A6F040" italics="true" pageId="null" pageNumber="723">kein deutlicher Griffel!</emphasis>
). Frucht nach unten gebogen.
</paragraph>
<paragraph id="AD7C91C2AD90E45EFA35B21685A10BBC" pageId="null" pageNumber="723">
Die Gattung 
<emphasis id="8295B3923EC52FAFACB45607ACAA0C27" italics="true" pageId="null" pageNumber="723">
<taxonomicName id="C40CA800B2FED1108BAD5AF06989A114" class="Magnoliopsida" family="Cistaceae" genus="Tuberaria" kingdom="Plantae" order="Malvales" pageId="null" pageNumber="723" phylum="Tracheophyta" rank="genus">Tuberaria</taxonomicName>
<normalizedToken id="005D7A35097195AC9E9FFB36142B63B2" originalValue="umfaßt" pageId="null" pageNumber="723">umfasst</normalizedToken>
11 Arten und ist 
<normalizedToken id="210D7880D3D12DF13D094B9794A90C64" originalValue="hauptsächlich" pageId="null" pageNumber="723">hauptsaechlich</normalizedToken>
im Mittelmeergebiet verbreitet. Chromosomengrundzahl
</emphasis>
wahrscheinlich n = 12.
</paragraph>
</subSubSection>
