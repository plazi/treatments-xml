, E 
<collectingCountry id="E9FC764FFFB2BA1EBC7EF29CBA89F9D7" box="[2156,2223,1532,1561]" name="Peru" pageId="14" pageNumber="633">Peru</collectingCountry>
, 
<collectingCountry id="E9FC764FFFB2BA1EBCD2F29CBB37F9D7" box="[2240,2321,1532,1561]" name="Brazil" pageId="14" pageNumber="633">Brazil</collectingCountry>
, and N 
