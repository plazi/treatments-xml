<collectingCountry id="E9FC764FFFB2BA1EBC01F2B5BAB8FA3C" box="[2067,2206,1493,1522]" name="Colombia" pageId="14" pageNumber="633">Colombia</collectingCountry>
, S 
<collectingCountry id="E9FC764FFFB2BA1EBCC0F2B5BB43FA3C" box="[2258,2405,1493,1522]" name="Venezuela" pageId="14" pageNumber="633">Venezuela</collectingCountry>
, 
<collectingCountry id="E9FC764FFFB2BA1EBD6FF2B5BBCFFA3C" box="[2429,2537,1493,1522]" name="Guyana" pageId="14" pageNumber="633">Guyana</collectingCountry>
