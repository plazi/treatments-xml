) and paratype of 
<taxonomicName id="48D44D295F395215FD5FFA65FBC7174B" authority="LAST" authorityName="LAST" authorityYear="1984" box="[765,1034,1519,1540]" class="Insecta" family="Staphylinidae" genus="Lathrobium" kingdom="Animalia" order="Coleoptera" pageId="7" pageNumber="1126" phylum="Arthropoda" rank="species" species="maculatum">
<emphasis id="BDA0EAB85F395215FD5FFA65FC1E174C" box="[765,979,1519,1540]" italics="true" pageId="7" pageNumber="1126">Lathrobium maculatum</emphasis>
