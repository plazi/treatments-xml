<figureCitation id="398E07DCBF54FF9419F0FAF99CC3FA09" box="[1186,1269,1405,1431]" captionStart="FIGURE 81" captionStartId="43.[151,250,2008,2032]" captionTargetBox="[229,1358,1062,1978]" captionTargetId="figure-47@43.[224,1364,1054,1983]" captionTargetPageId="43" captionText="FIGURE 81. Map of distribution of Copelatus in China Mainland." figureDoi="http://doi.org/10.5281/zenodo.6411120" httpUri="https://zenodo.org/record/6411120/files/figure.png" pageId="9" pageNumber="260">Fig. 81</figureCitation>
).
</paragraph>
</subSubSection>
