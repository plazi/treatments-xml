<collectingDate id="C54FC471BF54FF94184FFD719DAEFC91" box="[1309,1432,757,783]" pageId="9" pageNumber="260" value="2021-09-10">10.ix.2021</collectingDate>
</date>
, 
<collectorName id="0C407E8FBF54FF941DC5FC9E98C2FCAD" box="[151,244,793,820]" pageId="9" pageNumber="260">D. Zhou</collectorName>
leg. (
<collectionCode id="C7A4839CBF54FF941C66FC9D99B7FCAD" box="[308,385,793,819]" pageId="9" pageNumber="260">SYSU</collectionCode>
