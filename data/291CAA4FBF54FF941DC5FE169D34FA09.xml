<collectingCountry id="D9A25BC9BF54FF941F35FAFA9A9CFA06" box="[615,682,1406,1432]" name="Japan" pageId="9" pageNumber="260">Japan</collectingCountry>
, 
<collectingCountry id="D9A25BC9BF54FF941FE6FAF99B77FA06" box="[692,833,1405,1432]" name="South Korea" pageId="9" pageNumber="260">South Korea</collectingCountry>
and eastern 
<collectingCountry id="D9A25BC9BF54FF941E9CFAF99C27FA09" box="[974,1041,1405,1431]" name="China" pageId="9" pageNumber="260">China</collectingCountry>
(
<collectingRegion id="6371D5BBBF54FF94194DFAF99CBCFA06" box="[1055,1162,1405,1432]" country="China" name="Shanghai" pageId="9" pageNumber="260">Shanghai</collectingRegion>
