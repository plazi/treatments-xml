<subSubSection id="62B95AFF4D7D06CF6E38FA1071CFB7E6" pageId="null" pageNumber="555" type="description">
<paragraph id="A588FFD0DCA1EEF3A36F42E63C65AE58" pageId="null" pageNumber="555">
15-50 cm hoch, ziemlich dicht behaart. 
<normalizedToken id="B4F25A9AAF3EC64C92A9CB3197BA0DD8" originalValue="Grundständige" pageId="null" pageNumber="555">Grundstaendige</normalizedToken>
<normalizedToken id="70F08FE6F8A866A7D8E8D7949FC83385" originalValue="Blätter" pageId="null" pageNumber="555">Blaetter</normalizedToken>
0,3-1 cm breit. 
<emphasis id="DE206339CE041840B47CC25CBFC89BB4" italics="true" pageId="null" pageNumber="555">
<normalizedToken id="49E3EA922D5D45F72F8C839E5BF34556" originalValue="Längs" pageId="null" pageNumber="555">Laengs</normalizedToken>
der obersten 12 cm des Stengels unterhalb der untersten Verzweigung des 
<normalizedToken id="DA150303C0D6796E8D5706A13AD4F41B" originalValue="Blütenstandes" pageId="null" pageNumber="555">Bluetenstandes</normalizedToken>
8
</emphasis>
- 
<emphasis id="5C7098480734C8CCA6FF5A8D7103242C" italics="true" pageId="null" pageNumber="555">
12 
<normalizedToken id="C51D6B7BB833A409F3E7CA9E53684A84" originalValue="Stengelblätter" pageId="null" pageNumber="555">Stengelblaetter</normalizedToken>
.
</emphasis>
<normalizedToken id="8F0FA74DD069FC08B0E7706A9D5E8D3B" originalValue="Stengelblätter" pageId="null" pageNumber="555">Stengelblaetter</normalizedToken>
mit nicht 
<normalizedToken id="1C183A61ADAE11E4F8E9E0E989487760" originalValue="geflügelter" pageId="null" pageNumber="555">gefluegelter</normalizedToken>
, nicht 
<normalizedToken id="45DDA2AD0A3FD91FA8B42B5713864C26" originalValue="gezähnter" pageId="null" pageNumber="555">gezaehnter</normalizedToken>
, 0,6-1 mm breiter Mittelrippe, mit aufge- 
<pageBreakToken id="8C188F03721EBBB696EB7F1C00CB857E" pageId="null" pageNumber="555">stellten</pageBreakToken>
(nicht flach ausgebreiteten), an der Basis 0,1-0,3 mm breiten, bis an den Mittelnerv geteilten Abschnitten und 
<emphasis id="AFCD7E20035DBB35009774518A41BA6D" italics="true" pageId="null" pageNumber="555">mit an der Basis 0,1</emphasis>
- 
<emphasis id="16674CEEE7615E5409B7208CC30EA1B3" italics="true" pageId="null" pageNumber="555">0,3 mm breiten, sehr schmal lanzettlichen Zipfeln.</emphasis>
<normalizedToken id="02D177C9F83C96BDD8A9D814E4112592" originalValue="Hülle" pageId="null" pageNumber="555">Huelle</normalizedToken>
2-3,5 mm lang. 
<normalizedToken id="8E0EAD0172B6CEF62278B99BABF985C7" originalValue="Äußere" pageId="null" pageNumber="555">Aeussere</normalizedToken>
<normalizedToken id="4BEC30DE6AA79CA2F54BE922EB06550A" originalValue="Hüllblätter" pageId="null" pageNumber="555">Huellblaetter</normalizedToken>
0,7-0,9 mm breit. 
<normalizedToken id="B3BE7DE8F4A727802D94ACB22318B7A5" originalValue="Zungenförmige" pageId="null" pageNumber="555">Zungenfoermige</normalizedToken>
<normalizedToken id="B8477E359D5131EE49B873F1DDDFA8F0" originalValue="Blüten" pageId="null" pageNumber="555">Blueten</normalizedToken>
<normalizedToken id="7542B4F9D388D3CB3F3B31E2FC4635CF" originalValue="weiß" pageId="null" pageNumber="555">weiss</normalizedToken>
, seltener 
<normalizedToken id="7C2EB1AF608164FB8BCB563ACB7F8A78" originalValue="gelblich-weiß" pageId="null" pageNumber="555">gelblich-weiss</normalizedToken>
. 
<normalizedToken id="15503075E58CC8F8FB9E22251D316A19" originalValue="Früchte" pageId="null" pageNumber="555">Fruechte</normalizedToken>
1-1,3 mm lang. - 
<normalizedToken id="BD065D909CCE492085FB0A6BF9BD2730" originalValue="Blüte" pageId="null" pageNumber="555">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="40E3CC2A476E6FBE2FF05741C4A97BA3" originalValue="früher" pageId="null" pageNumber="555">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="2337D2B248F0E1EA1C873842D47FAFF7" pageId="null" pageNumber="555">
<emphasis id="56F329816CAB0AC8D102115690D2591C" italics="true" pageId="null" pageNumber="555">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="F909DAA2B7A986D23ADBDB88222C94C6" italics="true" pageId="null" pageNumber="555">18:</emphasis>
Material aus Ungarn (
<normalizedToken id="67B8CBE7F653A20D34A9130BA1161442" originalValue="Pólya" pageId="null" pageNumber="555">Polya</normalizedToken>
1950), aus dem Burgenland und dem Wallis (Ehrendorfer 1953a 1959c, z. T. 
<normalizedToken id="FB746EA06ABBE87F1E22D1F37A777633" originalValue="Störungen" pageId="null" pageNumber="555">Stoerungen</normalizedToken>
in der Pollenmeiose vermischt mit 
<normalizedToken id="B0496AA31D6ABC309AC96560710067B2" originalValue="völlig" pageId="null" pageNumber="555">voellig</normalizedToken>
normalen Meiosen); einzelne Pflanzen mit B-Chromosomen (Ehrendorfer 1960a), aus Griechenland (Contandriopoulos und Martin 1967), aus der 
<normalizedToken id="41E86C7FD7F82087B215E1253C73C5BC" originalValue="Türkei" pageId="null" pageNumber="555">Tuerkei</normalizedToken>
(Martin-Noguet 1969), aus dem Aostatal (Gadella und Kliphuis 1970).
</paragraph>
<paragraph id="97C89903BDE56EE35B1AF42148D97FEC" pageId="null" pageNumber="555">
<emphasis id="E2058A6FCD6674AFF4F785D9810B4DD8" italics="true" pageId="null" pageNumber="555">Standort.</emphasis>
Kollin und montan (selten subalpin). Trockene, lockere, kalkarme, sandige 
<normalizedToken id="72EA25FE4F308F514CA17407612660AB" originalValue="Böden" pageId="null" pageNumber="555">Boeden</normalizedToken>
in warmen Lagen. Felsensteppen, Trockenrasen.
</paragraph>
<paragraph id="34470AA5616DB6BB97C71D2EC6BD1AC4" pageId="null" pageNumber="555">
<emphasis id="9307D42A57540B853BDE436D15F07F74" italics="true" pageId="null" pageNumber="555">
Verbreitung. 
<normalizedToken id="DEA9EFF09C2B69BA4FA7391453B37D21" originalValue="Südosteuropäische" pageId="null" pageNumber="555">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Nord- und 
<normalizedToken id="658F4B2325A4B5DF84A936BBC6EA6C73" originalValue="westwärts" pageId="null" pageNumber="555">westwaerts</normalizedToken>
bis Schlesien, Mitteldeutschland, Westalpen; 
<normalizedToken id="0A3AB42346CB15D48D7830E48B311F49" originalValue="irrtümliche" pageId="null" pageNumber="555">irrtuemliche</normalizedToken>
Angaben aus den 
<normalizedToken id="A8FC634AE20B0B8524C881654164A295" originalValue="Pyrenäen" pageId="null" pageNumber="555">Pyrenaeen</normalizedToken>
und aus Spanien. Verbreitungskarte von Ehrendorfer (1962b) - Im Gebiet: Maurienne, Tarentaise, Wallis, Aostatal, 
<normalizedToken id="68A6C1768DF873A490A33F18B34E666E" originalValue="südliches" pageId="null" pageNumber="555">suedliches</normalizedToken>
Tessin, Comerseegebiet, 
<normalizedToken id="FC392CF43DE2BED9DC382C9BD10FD7E7" originalValue="südliche" pageId="null" pageNumber="555">suedliche</normalizedToken>
Bergamasker Alpen, Veltlin (Sondrio), Puschlav (?), Vintschgau (?); nicht 
<normalizedToken id="EEB32FB8646458110A23BD22E80E9880" originalValue="häufig" pageId="null" pageNumber="555">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
