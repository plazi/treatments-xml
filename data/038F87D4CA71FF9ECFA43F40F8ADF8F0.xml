<subSubSection id="C33C6549CA71FF9EC2433868F686FADA" pageId="33" pageNumber="652" type="description">
<paragraph id="8B9936C2CA71FF9EC2433868F686FADA" blockId="33.[2086,2672,967,1389]" pageId="33" pageNumber="652">
<emphasis id="B952EAD0CA71FF9EC2433868F6A1FB1D" box="[2086,2343,1120,1153]" pageId="33" pageNumber="652">Descriptive notes.</emphasis>
Head-body 
<quantity id="4CDE9B27CA71FF9EC38D3868F7D7FB34" metricMagnitude="-1" metricUnit="m" metricValue="3.09" metricValueMax="3.21" metricValueMin="2.9699999999999998" pageId="33" pageNumber="652" unit="cm" value="30.9" valueMax="32.1" valueMin="29.7">29.7-32.1 cm</quantity>
, tail 
<quantity id="4CDE9B27CA71FF9EC2CD388FF6C8FB34" box="[2216,2382,1159,1192]" metricMagnitude="-1" metricUnit="m" metricValue="1.53" metricValueMax="1.7" metricValueMin="1.3599999999999999" pageId="33" pageNumber="652" unit="cm" value="15.3" valueMax="17.0" valueMin="13.6">13.6-17 cm</quantity>
; weight 
<quantity id="4CDE9B27CA71FF9EC3B6388FF5ECFB34" box="[2515,2666,1159,1192]" metricMagnitude="-1" metricUnit="kg" metricValue="3.175" metricValueMax="3.4" metricValueMin="2.95" pageId="33" pageNumber="652" unit="g" value="317.5" valueMax="340.0" valueMin="295.0">295-340 g</quantity>
. Indonesian Mountain Weasels resemble European Mink in both size and color.; The pelage is brown throughout, with no facial markings.
</paragraph>
</subSubSection>
<subSubSection id="C33C6549CA71FF9EC2433944F8E7FA08" pageId="33" pageNumber="652" type="biology_ecology">
