<quantity id="4CDE9B27CA71FF9ECCC1397BF8DAFA08" box="[1700,1884,1395,1428]" metricMagnitude="3" metricUnit="m" metricValue="1.6" metricValueMax="2.2" metricValueMin="1.0" pageId="33" pageNumber="652" unit="m" value="1600.0" valueMax="2200.0" valueMin="1000.0">1000-2200 m</quantity>
.
</paragraph>
</subSubSection>
