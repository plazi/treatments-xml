<subSubSection id="CA367217B51F047AA14825179967463A" pageId="null" pageNumber="453" type="description">
<paragraph id="793292ABF431CF4FB125BDF670A5079C" pageId="null" pageNumber="453">
Unterscheidet sich von 
<emphasis id="E4E449DF7DBB8DD9E426D62D0D02C509" italics="true" pageId="null" pageNumber="453">
C. 
<taxonomicName id="CE2F849A387704CE44908ECFF4AC583A" class="Magnoliopsida" family="Asteraceae" genus="Jacea" higherTaxonomySource="GBIF" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="453" phylum="Tracheophyta" rank="genus">Jacea</taxonomicName>
</emphasis>
(Nr. 7c) durch folgende Merkmale: Meist mit dicht 
<normalizedToken id="94203F2FE27291A3941A8B0E41065636" originalValue="weißfilziger" pageId="null" pageNumber="453">weissfilziger</normalizedToken>
Behaarung; 
<emphasis id="AC8CD7EE5D15A43A45E05C94A2AD44DA" italics="true" pageId="null" pageNumber="453">
Stengel unterhalb der 
<normalizedToken id="D68DF4CD85DBE0F5D154E986B079E0F2" originalValue="Köpfe" pageId="null" pageNumber="453">Koepfe</normalizedToken>
reich 
<normalizedToken id="08E508D788A66DA154B2C0FD041B6C7D" originalValue="beblättert" pageId="null" pageNumber="453">beblaettert</normalizedToken>
;
</emphasis>
untere 
<normalizedToken id="B15BB8477DF607E204C168E1A0269CE8" originalValue="Blätter" pageId="null" pageNumber="453">Blaetter</normalizedToken>
lanzettlich, ungeteilt, fein 
<normalizedToken id="958194607477E82416F14E7FFCB32959" originalValue="gezähnt" pageId="null" pageNumber="453">gezaehnt</normalizedToken>
, die obern schmal lanzettlich, 3-20mal so lang wie breit. 
<emphasis id="889AEA75BAA1202DAA1A294CE0DD294B" italics="true" pageId="null" pageNumber="453">
<normalizedToken id="3576ABBE5A6718D6B1674D9DE0CD6C28" originalValue="Anhängsel" pageId="null" pageNumber="453">Anhaengsel</normalizedToken>
der mittleren 
<normalizedToken id="6E7FC5D73E280E8D0C36A359F112B299" originalValue="Hüllblätter" pageId="null" pageNumber="453">Huellblaetter</normalizedToken>
meist mehr als 5 mm lang, hellbraun bis 
<normalizedToken id="D1519E0D6363F0A0C500B2DF017E3AAF" originalValue="weiß" pageId="null" pageNumber="453">weiss</normalizedToken>
, ganzrandig oder nur wenige Male eingerissen;
</emphasis>
<normalizedToken id="0E9CC3E1D4E6D374E88180A9FAC7602F" originalValue="Früchte" pageId="null" pageNumber="453">Fruechte</normalizedToken>
ca. 2 mm lang. - 
<normalizedToken id="D222595FE36F3A2985C2BE6CCB952A92" originalValue="Blüte" pageId="null" pageNumber="453">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="1A0F222338FDD8532EB42EB56AD58298" pageId="null" pageNumber="453">
<emphasis id="C808A440F04710BFC07DF647D6657167" italics="true" pageId="null" pageNumber="453">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="59A14858CF1B626F51B6FCBF1E7D3BA7" italics="true" pageId="null" pageNumber="453">22:</emphasis>
Material von Sondrio im Veltlin (Gardou 1967a), aus den Alpes Maritimes (als 
<taxonomicName id="0128F0961F92294BE4256C347F66630F" authority="Guin." authorityName="Guin." class="Magnoliopsida" family="Asteraceae" genus="Centaurea" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="453" phylum="Tracheophyta" rank="variety" species="angustifolia" variety="diploidea">
<emphasis id="CADF105D695F942CDEBCD5E76459994F" italics="true" pageId="null" pageNumber="453">C. angustifolia</emphasis>
var. 
<emphasis id="1624E8E379AB764063ED8038EFAB7752" italics="true" pageId="null" pageNumber="453">diploidea</emphasis>
Guin.
</taxonomicName>
bezeichnet) (Guinochet 1957), aus den Alpes Maritimes, aus dem Apennin, aus den 
<normalizedToken id="6D1F3102BD42A5E74F94E8634D925C41" originalValue="Südalpen" pageId="null" pageNumber="453">Suedalpen</normalizedToken>
; an Material von 
<normalizedToken id="B0F318F2EDFBEF94070A90CBA8292FC1" originalValue="Südostfrankreich" pageId="null" pageNumber="453">Suedostfrankreich</normalizedToken>
wurde auch 2n = 44 
<normalizedToken id="A3814CC979A63F4B4D27CAD90C7EE352" originalValue="gezählt" pageId="null" pageNumber="453">gezaehlt</normalizedToken>
(Baltardive-Gardou 1970).
</paragraph>
<paragraph id="134452E1D5EB87BEFB3449A1F1D876D9" pageId="null" pageNumber="453">
<emphasis id="50DE658629E71A35D730F0E35D7CF49F" italics="true" pageId="null" pageNumber="453">Standort</emphasis>
. Kollin, montan und subalpin. Warme, trockene, steinige 
<normalizedToken id="2142B194536696B3BED2821CCE9D516B" originalValue="Hänge" pageId="null" pageNumber="453">Haenge</normalizedToken>
. Magere Wiesen, lichte 
<normalizedToken id="12ADB5DE5311580F06297FAE37375D76" originalValue="Wälder" pageId="null" pageNumber="453">Waelder</normalizedToken>
. 
<emphasis id="F5D3598897F243EA37DFDC634814FB4D" italics="true" pageId="null" pageNumber="453">Xerobromion</emphasis>
Br.-Bl. et Moor 1938 (nach Gardou 1971).
</paragraph>
<paragraph id="3FE031B1781B32BB5C63D3C73F2FA208" pageId="null" pageNumber="453">
<emphasis id="4550590F615AB8648C86961F3929C845" italics="true" pageId="null" pageNumber="453">
Verbreitung. 
<normalizedToken id="90AC2E65F241F1F8DB5F4903BFA035DB" originalValue="Südalpen-Pflanze" pageId="null" pageNumber="453">Suedalpen-Pflanze</normalizedToken>
:
</emphasis>
<normalizedToken id="13A948EB38F221B6926C3BD3EF82623F" originalValue="Südseite" pageId="null" pageNumber="453">Suedseite</normalizedToken>
der Alpen von den Seealpen bis zum Isonzo, Kroatien, Apennin. - Im Gebiet: Unteres Valsesia, Gegend von Varese, 
<normalizedToken id="944EF415CA6E4E54525115921BB7F5FD" originalValue="südliches" pageId="null" pageNumber="453">suedliches</normalizedToken>
Tessin, Comerseegebiet, Bergamasker Alpen, Veltlin, Puschlav, Vintschgau (Gegend von Meran).
</paragraph>
</subSubSection>
