<bibRefCitation author="Smissen, J van der" journalOrPublisher="Verein fuer Naturwissenschaftliche Heimatforschung zu Hamburg" pageId="0" pageNumber="375" pagination="1 - 426" refId="B62" refString="Smissen, J van der, 2010. Bilanz aus 20 Jahren entomologischer Aktivitaeten (1987-2007) (Hymenoptera Aculeata). Verein fuer Naturwissenschaftliche Heimatforschung zu Hamburg 43: 1 - 426" title="Bilanz aus 20 Jahren entomologischer Aktivitaeten (1987 - 2007) (Hymenoptera Aculeata)." volume="43" year="2010">2010</bibRefCitation>
