. 
<location LSID="urn:lsid:plazi:treatment:389C624B842D51428C8CFDB36115E707:8EF7E455DB609F9C14FE55DBA92F18B8" country="United Kingdom" county="For" municipality="International Commission on Zoological Nomenclature" name="The" stateProvince="Surrey">The</location>
female specimen proposed to be the 
<typeStatus>neotype</typeStatus>
has been collected in 
<collectingRegion country="United Kingdom" name="Surrey">Surrey</collectingRegion>
, some 
<quantity metricMagnitude="5" metricUnit="m" metricValue="1.3" unit="km" value="130.0">130 km</quantity>
