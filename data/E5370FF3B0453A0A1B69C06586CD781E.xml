<subSubSection id="993D9620AA481EDFA475088BC33BA79C" pageId="null" pageNumber="158" type="description">
<paragraph id="615DC10A74FF72CBB40C15E949849E8B" pageId="null" pageNumber="158">
3-10 cm hoch. 
<emphasis id="FBE9C1A3537E12A11810406656C94FA4" italics="true" pageId="null" pageNumber="158">Triebe unterirdisch kriechend</emphasis>
, bis 1 m lang, locker mit 
<normalizedToken id="BB8694EA5C717EA72AA8E7832632D982" originalValue="Schuppenblättern" pageId="null" pageNumber="158">Schuppenblaettern</normalizedToken>
bedeckt, meist ohne 
<normalizedToken id="C15F9521140B08AC4865B00444FD9AA9" originalValue="Blattgrün" pageId="null" pageNumber="158">Blattgruen</normalizedToken>
. Aufgerichtete Triebe 
<normalizedToken id="3A3F5BB76F1BDE0BADF6677C94734AE5" originalValue="über" pageId="null" pageNumber="158">ueber</normalizedToken>
dem Boden reich verzweigt, lockere 
<normalizedToken id="E905D02C26FC2ED74B2882BABECD6070" originalValue="Büschel" pageId="null" pageNumber="158">Bueschel</normalizedToken>
bildend. 
<emphasis id="C021954A70F787627D7DDC9F637BB71B" italics="true" pageId="null" pageNumber="158">Triebe deutlich 4kantig.</emphasis>
<normalizedToken id="16FF106109282598E3D3C913B056281B" originalValue="Blätter" pageId="null" pageNumber="158">Blaetter</normalizedToken>
4reihig, 
<emphasis id="FB8C585CC6190FD16401862276A24149" italics="true" pageId="null" pageNumber="158">
alle 
<normalizedToken id="3B3F74D2978FF71C0A5993800BF192E0" originalValue="Blätter" pageId="null" pageNumber="158">Blaetter</normalizedToken>
gleich, locker anliegend
</emphasis>
, sonst wie bei 
<emphasis id="02507782E83D7B2DA26D7EFC70491B15" italics="true" pageId="null" pageNumber="158">
<authorityName id="5B0924CBD75E3A5CC792429C441F2F11" pageId="null" pageNumber="158">L.</authorityName>
Chamaecyparissus
</emphasis>
(Nr.5). Triebe mit 
<normalizedToken id="6A501209A46E3475B2F66764120AE128" originalValue="Sporangienähren" pageId="null" pageNumber="158">Sporangienaehren</normalizedToken>
etwas lockerer 
<normalizedToken id="01EA5B00F4796B373C52BE1A51414C5B" originalValue="beblättert" pageId="null" pageNumber="158">beblaettert</normalizedToken>
; 
<emphasis id="040B51AE4DC057CC5973A56D4F405D73" italics="true" pageId="null" pageNumber="158">
<normalizedToken id="1F25D62243A3C094E83F835CE02DAA52" originalValue="Sporangienähren" pageId="null" pageNumber="158">Sporangienaehren</normalizedToken>
einzeln, sitzend
</emphasis>
, an der Spitze der Triebe, 1-2 cm lang. 
<emphasis id="9C27564A521DB702B5E44DCD4EE0A83C" italics="true" pageId="null" pageNumber="158">
Sporangientragende 
<normalizedToken id="548ECFCD553309848551BCA286911A3C" originalValue="Blätter" pageId="null" pageNumber="158">Blaetter</normalizedToken>
vom Grunde an 
<normalizedToken id="68EC9053DE2941924E3405C3D9A9E0E8" originalValue="verschmälert" pageId="null" pageNumber="158">verschmaelert</normalizedToken>
und 
<normalizedToken id="FBE2DAE865625A6C0D0ED1EA1A2B6D20" originalValue="allmählich" pageId="null" pageNumber="158">allmaehlich</normalizedToken>
zugespitzt.
</emphasis>
- Sporenreife: Sommer.
</paragraph>
<paragraph id="08A80B4A7D35B92E44286F28F1A9F793" pageId="null" pageNumber="158">
<emphasis id="678C4A5CB728932DBC71246D87D74720" italics="true" pageId="null" pageNumber="158">Zytologische Angaben. 2n ca. 38-40:</emphasis>
Material aus der Tatra (Hadac und Haskova 1956 aus 
<normalizedToken id="361D6906E24ADBD02C8AEF96900F4065" originalValue="Löve" pageId="null" pageNumber="158">Loeve</normalizedToken>
und 
<normalizedToken id="23E1013AA6B207572B92E5BCC770B10B" originalValue="Löve" pageId="null" pageNumber="158">Loeve</normalizedToken>
1958c). 
<emphasis id="97CA8EEE47486C463C7CE3C7C65AC9A8" italics="true" pageId="null" pageNumber="158">2n = 44:</emphasis>
Material aus Skandinavien (Harmsen aus 
<normalizedToken id="3DCCCD3E806AD15ACDF13B8EC983813D" originalValue="Löve" pageId="null" pageNumber="158">Loeve</normalizedToken>
und 
<normalizedToken id="4F3F460A0F14C24BC20D9003BFD6ADAE" originalValue="Löve" pageId="null" pageNumber="158">Loeve</normalizedToken>
1948). 
<emphasis id="D3F9ACB8699199BE708721237BDCF4C0" italics="true" pageId="null" pageNumber="158">2n = 46:</emphasis>
Material aus Schweden (
<normalizedToken id="2D514EFF97E4CB211CFA5EC2606ED96E" originalValue="Löve" pageId="null" pageNumber="158">Loeve</normalizedToken>
und 
<normalizedToken id="7764A0D8E772DB618A7CB75841DC11AF" originalValue="Löve" pageId="null" pageNumber="158">Loeve</normalizedToken>
1961, Wilce 1965). 
<emphasis id="B054AAF36A94A3ACACA13E6C7DD500EE" italics="true" pageId="null" pageNumber="158">2n ca. 48:</emphasis>
Material aus England (Manton 1950). 
<emphasis id="2069ED62D221EDB3759DF4537DB2ABDE" italics="true" pageId="null" pageNumber="158">2n = 44-48</emphasis>
(n = 22-24): Material aus Finnland (Sorsa 1963). 
<emphasis id="31391A4934133516682F2F3BF000BA69" italics="true" pageId="null" pageNumber="158">2n = 48:</emphasis>
Material aus Island, Kanada (Quebec) und den Rocky Mountains (
<normalizedToken id="BD43E6C0BFD75DFCE379E3DE075924CB" originalValue="Löve" pageId="null" pageNumber="158">Loeve</normalizedToken>
und 
<normalizedToken id="E4AB124C35EA7CF315FB5242F5F3F943" originalValue="Löve" pageId="null" pageNumber="158">Loeve</normalizedToken>
1958c).
</paragraph>
<paragraph id="9EFDAF7E35DC60A22441E95FAE733FC9" pageId="null" pageNumber="158">
<emphasis id="951DAAB91ACD69EB571B0A9DABE761B9" italics="true" pageId="null" pageNumber="158">Standort.</emphasis>
Subalpin und alpin. Saure, trockene, humose 
<normalizedToken id="49DC86232C076377144FB47723F8A375" originalValue="Böden" pageId="null" pageNumber="158">Boeden</normalizedToken>
. Magerwiesen, Zwergstrauchgesellschaften.
</paragraph>
<paragraph id="3AC844315C4775E7FC2B01BE8FBE2E56" pageId="null" pageNumber="158">
<emphasis id="6E388476AFD30A05C569D942E8B5E176" italics="true" pageId="null" pageNumber="158">Verbreitung. Arktisch-alpine Pflanze:</emphasis>
Island, 
<normalizedToken id="D6A4E887A67866C458431FE250CFA032" originalValue="Großbritannien" pageId="null" pageNumber="158">Grossbritannien</normalizedToken>
, Skandinavien, Nordsibirien; 
<normalizedToken id="0ECEF122B4041CE538B23D401D9F1D6E" originalValue="mitteleuropäische" pageId="null" pageNumber="158">mitteleuropaeische</normalizedToken>
Gebirge, 
<normalizedToken id="354FA5FAE6E4DE88872AC9A8680632EA" originalValue="südwärts" pageId="null" pageNumber="158">suedwaerts</normalizedToken>
bis 
<normalizedToken id="198184BE59E63514BE59C9DC52FEAC44" originalValue="Pyrenäen" pageId="null" pageNumber="158">Pyrenaeen</normalizedToken>
, Apuanische Alpen, Gebirge der Balkanhalbinsel, Kaukasus, Altai, Kamtschatka, Mandschurei, Japan, Sachalin, 
<normalizedToken id="7EEA6651F35EA41CDBB7F3D135530D6A" originalValue="Alëuten" pageId="null" pageNumber="158">Aleuten</normalizedToken>
; im westlichen Nordamerika von der 
<normalizedToken id="F791433B411B2C50CFEE159DB36C44A4" originalValue="Beringstraße" pageId="null" pageNumber="158">Beringstrasse</normalizedToken>
<normalizedToken id="B8EC02D6F5FCCD87EB64DE199F77686F" originalValue="südwärts" pageId="null" pageNumber="158">suedwaerts</normalizedToken>
bis etwa 45° NB; 
<normalizedToken id="DA4ACAB4AB009B777A75F4F527A099CA" originalValue="östliches" pageId="null" pageNumber="158">oestliches</normalizedToken>
Kanada; 
<normalizedToken id="9EE8963F0B2A34B2EC1D86437318E3CF" originalValue="Grönland" pageId="null" pageNumber="158">Groenland</normalizedToken>
. Verbreitungskarten von 
<normalizedToken id="C91E38A47EA1EFEBAD2C23BB5019798C" originalValue="Hultén" pageId="null" pageNumber="158">Hulten</normalizedToken>
(1958) und Meusel (1964). - Im Gebiet: Alpen und Alpenvorland, Jura (
<normalizedToken id="77424D70BEC8DFAE593C243BFE350391" originalValue="nordostwärts" pageId="null" pageNumber="158">nordostwaerts</normalizedToken>
bis Chasseral), Vogesen, Schwarzwald.
</paragraph>
</subSubSection>
