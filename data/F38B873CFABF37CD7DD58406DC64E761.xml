<subSubSection id="5B689EF8661739758C92B452F25BE4CB" pageId="null" pageNumber="587" type="description">
<paragraph id="666F631962A903D95363F733210B466C" pageId="null" pageNumber="587">
Stengel meist aufrecht, 10-30 cm hoch. 
<normalizedToken id="4DE5F0C148E6D7255C1BA36E44B80678" originalValue="Blätter" pageId="null" pageNumber="587">Blaetter</normalizedToken>
wie bei 
<taxonomicName id="BDC40A824AF07ACCC297D02F9F9F93ED" class="Magnoliopsida" family="Asteraceae" genus="Artemisia" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="587" phylum="Tracheophyta" rank="species" species="glacialis">
<emphasis id="61471FAA477822D63C189CEB4D581FE1" italics="true" pageId="null" pageNumber="587">A. glacialis</emphasis>
</taxonomicName>
(Nr. 14a). 
<normalizedToken id="831704162BAC0D7244641C6937C39C3A" originalValue="Köpfe" pageId="null" pageNumber="587">Koepfe</normalizedToken>
3-15, 
<emphasis id="1C5B18B1CB959C3EB0625893242C7BCA" italics="true" pageId="null" pageNumber="587">im Durchmesser 6</emphasis>
- 
<emphasis id="FBA00C5F9CC47EC1B3AD2EC0CA386E72" italics="true" pageId="null" pageNumber="587">8 mm</emphasis>
, 15-30 
<normalizedToken id="1FAEEF1884A1FFC8CDF63A94BF8B5410" originalValue="blütig" pageId="null" pageNumber="587">bluetig</normalizedToken>
, 
<emphasis id="FDCEEB6C18C14B8E242E039BC4266952" italics="true" pageId="null" pageNumber="587">nickend, einseitswendig</emphasis>
, einzeln, entlang des Stengels angeordnet (meist erst in der obern 
<normalizedToken id="2E149CBF450D90EF80CD2836A4ED41C3" originalValue="Hälfte" pageId="null" pageNumber="587">Haelfte</normalizedToken>
). Innere 
<normalizedToken id="E3A7A2F748A9340A95C64E967AE67A95" originalValue="Hüllblätter" pageId="null" pageNumber="587">Huellblaetter</normalizedToken>
mit braunem Rand. 
<emphasis id="AA28C65C5FDBE51221D93ABB8701320E" italics="true" pageId="null" pageNumber="587">
Boden des 
<normalizedToken id="1CA4B8F53E6D52384A7186D14B9F3798" originalValue="Blütenkopfes" pageId="null" pageNumber="587">Bluetenkopfes</normalizedToken>
kurz behaart
</emphasis>
(
<emphasis id="ADBF449CB33B57D8D2392159CE0F98D7" italics="true" pageId="null" pageNumber="587">
Haare meist 
<normalizedToken id="23F97F876AF10672D3FDE2E21BB8A843" originalValue="kürzer" pageId="null" pageNumber="587">kuerzer</normalizedToken>
als 1 mm
</emphasis>
)
<emphasis id="20477323CD35920A50AB436447B8DA2E" italics="true" pageId="null" pageNumber="587">. Kronen zerstreut behaart.</emphasis>
<normalizedToken id="E0557B4F5CA142EB2E697568171ADD36" originalValue="Früchte" pageId="null" pageNumber="587">Fruechte</normalizedToken>
kahl. - 
<normalizedToken id="71298678D76ECBFF3E22F3947B00237D" originalValue="Blüte" pageId="null" pageNumber="587">Bluete</normalizedToken>
: 
<normalizedToken id="B2154925939DFF327BFFDB4AC94DAA3A" originalValue="Später" pageId="null" pageNumber="587">Spaeter</normalizedToken>
Sommer.
</paragraph>
<paragraph id="DB0E69CE36FFB483069F45705DB72D74" pageId="null" pageNumber="587">
<emphasis id="B4ECA43AF879DCC638212C90EE5E1DF4" italics="true" pageId="null" pageNumber="587">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5526E5AE0D582543E33355DF68299FC7" italics="true" pageId="null" pageNumber="587">27:</emphasis>
Material vom Val Gardena (Alto Adige); die Art ist 
<emphasis id="FA006D97C291459EF5CA20E898A78FDF" italics="true" pageId="null" pageNumber="587">triploid</emphasis>
und 
<emphasis id="975A109407460DC3AA3B17DC442E0FA3" italics="true" pageId="null" pageNumber="587">apomiktisch</emphasis>
(Chiarugi 1926). 
<emphasis id="BF76D601DAF18DC1FEC298CC88625D87" italics="true" pageId="null" pageNumber="587">2n</emphasis>
= 
<emphasis id="D6774A5E27003DCD62CDF64E9484D1F1" italics="true" pageId="null" pageNumber="587">54:</emphasis>
Material aus botanischem Garten (Kawatani und Ohno 1964).
</paragraph>
<paragraph id="EA750B4108D0E0DA6884FC4CD20DB00D" pageId="null" pageNumber="587">
<emphasis id="1D4C43A8764DF872D05EDC0491871A54" italics="true" pageId="null" pageNumber="587">Standort.</emphasis>
Subalpin, selten montan. Felsen und felsige 
<normalizedToken id="48A209D574A204D773DC207A30ADE2E6" originalValue="Hänge" pageId="null" pageNumber="587">Haenge</normalizedToken>
, auf Dolomit (seltener auf Kalk).
</paragraph>
<paragraph id="67B9D210CDC178826B9472D578361FF4" pageId="null" pageNumber="587">
<emphasis id="5E0873FD4EB83A894C39A47EA0DC64E8" italics="true" pageId="null" pageNumber="587">
Verbreitung. 
<normalizedToken id="E4B692551E07CF907D50AAE5088A4104" originalValue="Südalpin-apenninische" pageId="null" pageNumber="587">Suedalpin-apenninische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="C4758F34A67BC5417BAEF74D21AE2C97" originalValue="Südalpen" pageId="null" pageNumber="587">Suedalpen</normalizedToken>
(zwischen Bergamasker Alpen und Dolomiten, krainische Alpen), Apuanische Alpen. - Im Gebiet: Bergamasker Alpen, Veltlin (Val Malenco?), Vintschgau (Tisens).
</paragraph>
</subSubSection>
