<paragraph id="8B9B975A754BD70F8D0AFD6C5822FD1D" blockId="4.[2062,2656,568,987]" box="[2064,2652,643,672]" pageId="4" pageNumber="384">
<taxonomicName id="4C24ECD9754BD70F8D0AFD6C5AB6FD1D" authorityName="K. Andersen" authorityYear="1912" box="[2064,2248,643,672]" class="Mammalia" family="Nycteridae" genus="Nycteris" kingdom="Animalia" order="Chiroptera" pageId="4" pageNumber="384" phylum="Chordata" rank="species" species="aurita">Nycteris aurita</taxonomicName>
belongs to the 
<taxonomicName id="4C24ECD9754BD70F8C85FD6C5B85FD1D" baseAuthorityName="Schreber" baseAuthorityYear="1775" box="[2463,2555,643,672]" class="Mammalia" family="Nycteridae" genus="Nycteris" kingdom="Animalia" order="Chiroptera" pageId="4" pageNumber="384" phylum="Chordata" rank="species" species="hispida">hispida</taxonomicName>
