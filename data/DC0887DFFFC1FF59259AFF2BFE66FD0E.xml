<emphasis id="66D5EADBFFC1FF5925CAFE32FEA1FE26" bold="true" box="[199,300,398,424]" pageId="15" pageNumber="562">Ecology.</emphasis>
<taxonomicName id="93A14D4AFFC1FF59243EFE32FDF2FE26" authorityName="Labay" authorityYear="2018" box="[307,639,398,424]" class="Malacostraca" family="Pleustidae" genus="Cognateosymtes" kingdom="Animalia" order="Amphipoda" pageId="15" pageNumber="562" phylum="Arthropoda" rank="species" species="serraticoxae">
