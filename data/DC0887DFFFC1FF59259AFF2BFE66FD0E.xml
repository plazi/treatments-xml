<subSubSection id="1CBB6542FFC1FF5925CAFE69FBA8FD9A" pageId="15" pageNumber="562" type="distribution">
<paragraph id="541E36C9FFC1FF5925CAFE69FBA8FD9A" blockId="15.[151,1437,325,640]" pageId="15" pageNumber="562">
<emphasis id="66D5EADBFFC1FF5925CAFE69FED4FE61" bold="true" box="[199,345,469,495]" pageId="15" pageNumber="562">Distribution</emphasis>
: The shelf of Sakhalin Island, Sea of 
<collectingCountry id="2CB67659FFC1FF59260CFE6AFCCCFE7E" box="[769,833,470,496]" name="Japan" pageId="15" pageNumber="562">Japan</collectingCountry>
(
<bibRefCitation id="30304B38FFC1FF59265DFE6AFC51FE7E" author="Labay, V. S." box="[848,988,470,496]" pageId="15" pageNumber="562" pagination="220 - 230" refId="ref6589" refString="Labay, V. S. (2018) Cognateosymtes serraticoxae, new genus, new species, a pleustid amphipod from the Sea of Japan (Crustacea: Amphipoda: Gammaridea: Pleustidae: Eosymtinae). Zootax a, 4521 (2), 220 - 230. https: // doi. org / 10.11646 / zootaxa. 4521.2.4" type="journal article" year="2018">Labay 2018</bibRefCitation>
