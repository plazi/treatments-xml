<figureCitation id="CC9A2A4CFFC1FF5926CBFE46FB9AFD9A" box="[966,1047,506,532]" captionStart="FIGURE 11" captionStartId="14.[151,250,1979,2003]" captionTargetBox="[151,1435,489,1956]" captionTargetId="figure-158@14.[151,1436,489,1956]" captionTargetPageId="14" captionText="FIGURE 11. Distribution of Eosymtinae species in Far Eastern Region" figureDoi="http://doi.org/10.5281/zenodo.6457392" httpUri="https://zenodo.org/record/6457392/files/figure.png" pageId="15" pageNumber="562">Fig. 11</figureCitation>
