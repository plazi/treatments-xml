<subSubSection id="F9433DAE2114E93A305338E6C411A5B4" pageId="null" pageNumber="55" type="description">
<paragraph id="9AE5DDD4C22845FC8C6627FCD6ECC646" pageId="null" pageNumber="55">
Unterscheidet sich durch folgende Merkmale von 
<taxonomicName id="75221F30B27478688D9377EBC5522144" class="Magnoliopsida" family="Boraginaceae" genus="Cynoglossum" kingdom="Plantae" order="Boraginales" pageId="null" pageNumber="55" phylum="Tracheophyta" rank="species" species="officinale">
<emphasis id="CE4E6F1499DB9E4886AD3191B09A1FB0" italics="true" pageId="null" pageNumber="55">C. officinale</emphasis>
</taxonomicName>
(Nr. 1): 
<normalizedToken id="A5C96F53B4F6168E7D1B7C5BB75C4451" originalValue="Blätter" pageId="null" pageNumber="55">Blaetter</normalizedToken>
unterseits meist rauh, die obersten 
<normalizedToken id="9D95EA9071A7203296900B6D09FEC649" originalValue="Stengelblätter" pageId="null" pageNumber="55">Stengelblaetter</normalizedToken>
oft nur 2-3mal so lang wie breit und am Grunde 
<normalizedToken id="2C8CA3343CF86022E3D005D3D33EF7C6" originalValue="herzförmig" pageId="null" pageNumber="55">herzfoermig</normalizedToken>
oder breit abgerundet; Kelchzipfel stumpf; 
<emphasis id="FBED3B601E0EB871ABD2EC3E52201433" italics="true" pageId="null" pageNumber="55">
<normalizedToken id="3E191E81B71C2F3FB9CA0D1113D76963" originalValue="Blütenstiele" pageId="null" pageNumber="55">Bluetenstiele</normalizedToken>
nach der 
<normalizedToken id="DFB50774AA91400B37E0ADB6B57AEFA2" originalValue="Blüte" pageId="null" pageNumber="55">Bluete</normalizedToken>
nickend; 
<normalizedToken id="AF9778423003D65C4F992E8AF6AF4CA5" originalValue="Teilfrüchte" pageId="null" pageNumber="55">Teilfruechte</normalizedToken>
ohne Randwulst, 
<normalizedToken id="FD283AF3D98B5CF6204F14D42F9BEDC2" originalValue="überall" pageId="null" pageNumber="55">ueberall</normalizedToken>
<normalizedToken id="B82BCD09278AC10F9B2D14996DAD5DED" originalValue="gleichmäßig" pageId="null" pageNumber="55">gleichmaessig</normalizedToken>
mit 0,5
</emphasis>
- 
<emphasis id="D00369808E1C05337B84EA41942B3C5F" italics="true" pageId="null" pageNumber="55">0,8 mm langen Stacheln besetzt, die an der Spitze Widerhaken tragen.</emphasis>
- 
<normalizedToken id="6BFC3F8CFCA203CDE1821255DE9540EB" originalValue="Blüte" pageId="null" pageNumber="55">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="991F465DCD2E4D7C0C9133DC0C318B57" pageId="null" pageNumber="55">
<emphasis id="35A3089B3EBFA3B851F0600B4D661352" italics="true" pageId="null" pageNumber="55">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="34FDB47A428B6C67B3462063C4BA6ECC" italics="true" pageId="null" pageNumber="55">24:</emphasis>
Material aus Deutschland (Kassel) (Dersch 1968).
</paragraph>
<paragraph id="D317B77D71D69F626840AA5D0E864CCC" pageId="null" pageNumber="55">
<emphasis id="F0492F6177051B14457E7648CBCFF317" italics="true" pageId="null" pageNumber="55">Standort.</emphasis>
Montan. Stickstoffreiche, frische, meist kalkhaltige 
<normalizedToken id="9B0283B111F101A42A65E5029DC1C52F" originalValue="Böden" pageId="null" pageNumber="55">Boeden</normalizedToken>
in warmen Lagen. Waldunkrautgesellschaften mit 
<emphasis id="BF4C8E0C24B2BC638691969F58C15B88" italics="true" pageId="null" pageNumber="55">
<taxonomicName id="0F94D115E356876C96F6922F771FF9FE" class="Magnoliopsida" family="Brassicaceae" genus="Alliaria" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="55" phylum="Tracheophyta" rank="species" species="officinalis">Alliaria officinalis</taxonomicName>
;
</emphasis>
besonders im 
<emphasis id="7D5B60995643F3A63207653AFCC744E0" italics="true" pageId="null" pageNumber="55">Alliario-Chaerophylletum temuli</emphasis>
(Kreh 1935) Lohm. 1949.
</paragraph>
<paragraph id="03C6476BDC44A19AD952EF9F0E8DEC25" pageId="null" pageNumber="55">
<emphasis id="192D69EA3E6793D94E7AA6E578EEA495" italics="true" pageId="null" pageNumber="55">
Verbreitung. 
<normalizedToken id="D8121E4C3542DBD5187EBA4143592F02" originalValue="Europäische" pageId="null" pageNumber="55">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="D334F61CF44210663DABA6C436655DDB" originalValue="Nordwärts" pageId="null" pageNumber="55">Nordwaerts</normalizedToken>
bis England, Mitteldeutschland, Karpaten, Krim; 
<normalizedToken id="939D7E746D05F172F5B5798BEC8401AD" originalValue="ostwärts" pageId="null" pageNumber="55">ostwaerts</normalizedToken>
bis in den Kaukasus; 
<normalizedToken id="F2DD0EF38201D8603ECD33D89E14656B" originalValue="südwärts" pageId="null" pageNumber="55">suedwaerts</normalizedToken>
bis 
<normalizedToken id="DED619784CE419500FAF83705AE58B80" originalValue="Pyrenäen" pageId="null" pageNumber="55">Pyrenaeen</normalizedToken>
, Cevennen, Alpen. - Im Gebiet von 
<normalizedToken id="97C9CF19F275454A580547A8CC8CAD12" originalValue="Südwesten" pageId="null" pageNumber="55">Suedwesten</normalizedToken>
durch den Jura bis 
<normalizedToken id="248A58E23AE651C71F9529FAEE2394EE" originalValue="Weißenstein" pageId="null" pageNumber="55">Weissenstein</normalizedToken>
und Waldenburg; Gegend von Belfort, mittlere Vogesen, 
<normalizedToken id="8C0055514AD10663DC18E70D5F4A5007" originalValue="Salève" pageId="null" pageNumber="55">Saleve</normalizedToken>
(Savoyen); keine gesicherten Angaben aus dem Wallis und aus 
<normalizedToken id="5E6CC5AA6663B58C84AFC38719845591" originalValue="Graubünden" pageId="null" pageNumber="55">Graubuenden</normalizedToken>
; wahrscheinlich 
<normalizedToken id="3C0B18809D69317301550E1F584EB8FF" originalValue="außerhalb" pageId="null" pageNumber="55">ausserhalb</normalizedToken>
der 
<normalizedToken id="520F891B9C3522A853C67EAD75883089" originalValue="erwähnten" pageId="null" pageNumber="55">erwaehnten</normalizedToken>
Gegenden nur selten und 
<normalizedToken id="3A0E9DA0A29C621B3EB0B84D5506BB04" originalValue="bloß" pageId="null" pageNumber="55">bloss</normalizedToken>
<normalizedToken id="43572813CF83BC663F3632BEBB657815" originalValue="vorübergehend" pageId="null" pageNumber="55">voruebergehend</normalizedToken>
adventiv.
</paragraph>
<paragraph id="F0D2D09D84BA90A9640B55939589D61D" pageId="null" pageNumber="55">
<emphasis id="615AD9B3A418114DECB69DF2C7499171" italics="true" pageId="null" pageNumber="55">Bemerkungen.</emphasis>
Die Gesamtverbreitung von 
<taxonomicName id="6BBC8109CC148978A2BF3DD9913220A6" class="Magnoliopsida" family="Boraginaceae" genus="Cynoglossum" kingdom="Plantae" order="Boraginales" pageId="null" pageNumber="55" phylum="Tracheophyta" rank="species" species="germanicum">
<emphasis id="72BA1A65875AEE1A8DD9C23AFE7B1203" italics="true" pageId="null" pageNumber="55">C. germanicum</emphasis>
</taxonomicName>
und die Verbreitung im Gebiet sind unsicher, da oft Verwechslungen mit 
<emphasis id="58C8C3C0980F2DC6FB4EF36C157E8E7D" italics="true" pageId="null" pageNumber="55">
<taxonomicName id="866D5C5224C626C4D03851A9B64DAEB9" class="Magnoliopsida" family="Boraginaceae" genus="Cynoglossum" kingdom="Plantae" order="Boraginales" pageId="null" pageNumber="55" phylum="Tracheophyta" rank="species" species="officinale">C. officinale</taxonomicName>
.
</emphasis>
</paragraph>
</subSubSection>
