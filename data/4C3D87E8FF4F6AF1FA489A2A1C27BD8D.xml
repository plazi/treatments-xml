<taxonomicName id="03944D7DFF4F6AF0F7429B29178EB6BF" authorityName="G. S. Miller" authorityYear="1902" box="[2238,2446,3440,3469]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="180" pageNumber="942" phylum="Chordata" rank="species" species="dominicensis">M. dominicensis</taxonomicName>
