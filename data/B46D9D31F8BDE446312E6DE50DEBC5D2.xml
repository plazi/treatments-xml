<subSubSection id="33BA78FFF0F7E227ABBF89DA11CC59C6" pageId="null" pageNumber="303" type="description">
<paragraph id="17E92CEBF7F2E0701C725648D9DD55E3" pageId="null" pageNumber="303">
25-70 cm hoch, aufrecht, mit kurzen 
<normalizedToken id="6F3ABC42736E931F1903444B95711F33" originalValue="Ausläufern" pageId="null" pageNumber="303">Auslaeufern</normalizedToken>
. Stengel drahtig, mit kurzen seitlichen Verzweigungen (
<emphasis id="52C4F9DA3706D602B743009A8C144A8B" italics="true" pageId="null" pageNumber="303">
sterile seitliche Verzweigungen oft 
<normalizedToken id="090C2E0593C664C0202609697CD61A3F" originalValue="länger" pageId="null" pageNumber="303">laenger</normalizedToken>
als die Verzweigungen im 
<normalizedToken id="751B7F3CB79335C8E6D62315414F7B99" originalValue="Blütenstand" pageId="null" pageNumber="303">Bluetenstand</normalizedToken>
</emphasis>
), 
<emphasis id="B21715699E5B6C8C7B05953BA972CFE0" italics="true" pageId="null" pageNumber="303">an der Basis kahl, seltener mit 0,2</emphasis>
- 
<emphasis id="D69AA4D73D599FAFFA3A891B420016CA" italics="true" pageId="null" pageNumber="303">
0,5 mm langen Haaren. Mittlere 
<normalizedToken id="561607D29DE45423932440AD58BD386E" originalValue="Blätter" pageId="null" pageNumber="303">Blaetter</normalizedToken>
1
</emphasis>
- 
<emphasis id="1A0F905B127AFA5B4543C3CB1AB31CFE" italics="true" pageId="null" pageNumber="303">2 mm breit und bis 25 mm</emphasis>
<emphasis id="37F6C5A98E0C6F1506700F4B1A32F8DE" italics="true" pageId="null" pageNumber="303">
<pageBreakToken id="1BE653316ABDFD5B3F03C7F5E353B3F5" pageId="null" pageNumber="303">lang</pageBreakToken>
</emphasis>
, 8-15mal so lang wie breit, fleischig, 
<normalizedToken id="1BA509829A9423B91CB6F1AA87249B38" originalValue="glänzend" pageId="null" pageNumber="303">glaenzend</normalizedToken>
, 
<normalizedToken id="A88EF33351DAEADB737631312ED19BD0" originalValue="±" pageId="null" pageNumber="303">+/-</normalizedToken>
flach; 
<emphasis id="C258AAA1B8156FFCC2C5AD72D9671F60" italics="true" pageId="null" pageNumber="303">
Nerv 
<normalizedToken id="DFDA4F4911E761E07D63BB1E600F414F" originalValue="schmäler" pageId="null" pageNumber="303">schmaeler</normalizedToken>
als die halbe Blattbreite.
</emphasis>
<normalizedToken id="3E3EB3EC23499346E0511C0BBDCD7D13" originalValue="Blütenstand" pageId="null" pageNumber="303">Bluetenstand</normalizedToken>
schmal, dicht. 
<normalizedToken id="6A4DA0E53ECC72067D78C1BE612E25DC" originalValue="Teilblütenstände" pageId="null" pageNumber="303">Teilbluetenstaende</normalizedToken>
<normalizedToken id="E2AF503993F426521D7EB0EFFF74F033" originalValue="pyramidenförmig" pageId="null" pageNumber="303">pyramidenfoermig</normalizedToken>
(zugespitzt). 
<normalizedToken id="E5659B6AD3D059BEC38FD9FEFA219651" originalValue="Blütenstiele" pageId="null" pageNumber="303">Bluetenstiele</normalizedToken>
2-4 mm lang, nach der 
<normalizedToken id="D5C8AD0430592A166D2978A2E8EF2854" originalValue="Blüte" pageId="null" pageNumber="303">Bluete</normalizedToken>
meist nicht sparrig abstehend (miteinander 
<normalizedToken id="2BD16A6F104298199F31D35A43A3E98C" originalValue="±" pageId="null" pageNumber="303">+/-</normalizedToken>
spitze Winkel bildend). Krone 3-6 mm im Durchmesser, die Zipfel mit 0,3-0,5 mm langer, grannenartiger Spitze, 
<normalizedToken id="888034868E48D6AAF0DD014B783DB48D" originalValue="gelblichweiß" pageId="null" pageNumber="303">gelblichweiss</normalizedToken>
. Staubbeutel 0,3-0,4 mm lang. - 
<normalizedToken id="5E9F0FED00273B0C8C41B3AEF376BFBD" originalValue="Blüte" pageId="null" pageNumber="303">Bluete</normalizedToken>
: 
<normalizedToken id="9A32C0374EBD33320B7FDDF1C2954488" originalValue="Früher" pageId="null" pageNumber="303">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="D45FE34DDE09934230EB7E227EFBFB7C" pageId="null" pageNumber="303">
<emphasis id="EC93A4AA2111BFCFB7B1B55D250797E2" italics="true" pageId="null" pageNumber="303">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5334325ABAD1B66BE1B9D63F511C6DAB" italics="true" pageId="null" pageNumber="303">44:</emphasis>
Material von vielen Stellen aus 
<normalizedToken id="ED25B7D53AC6BA9176E50DA31EF334C0" originalValue="Österreich" pageId="null" pageNumber="303">Oesterreich</normalizedToken>
, Jugoslawien, Italien und der Schweiz (Krendl 1967).
</paragraph>
<paragraph id="3AE3451A18BC7911A0E3D029908B6D09" pageId="null" pageNumber="303">
<emphasis id="5918B2B790E2C8706E254549F34F3EB6" italics="true" pageId="null" pageNumber="303">Standort.</emphasis>
Kollin und montan. Ziemlich trockene und steinige 
<normalizedToken id="83CC4589665FC8F4CDCE7EF73355D2A1" originalValue="Böden" pageId="null" pageNumber="303">Boeden</normalizedToken>
auf Kalk, Dolomit und Serpentin in warmen Lagen. Lichte 
<normalizedToken id="00A58F6C5FDC0B48858F6B156DC506E5" originalValue="Wälder" pageId="null" pageNumber="303">Waelder</normalizedToken>
, felsige 
<normalizedToken id="B7DCCC3486C290E8F9CA12395CCB13E6" originalValue="Hänge" pageId="null" pageNumber="303">Haenge</normalizedToken>
, Trockenwiesen.
</paragraph>
<paragraph id="4ED4C493CF23EDD69F86E58368A52E6C" pageId="null" pageNumber="303">
<emphasis id="4A7512C4D38C8F3296F3939542B673A3" italics="true" pageId="null" pageNumber="303">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="9AC17F2FBD342EBF3C961AD5F0A6740B" originalValue="Nordwärts" pageId="null" pageNumber="303">Nordwaerts</normalizedToken>
bis Dijon, 
<normalizedToken id="F4430D5B4647C7737657959516F082AA" originalValue="nördlicher" pageId="null" pageNumber="303">noerdlicher</normalizedToken>
Jura, Nordalpen, Bukowina; 
<normalizedToken id="874A3BD60146F394210D8AD22384861B" originalValue="südwärts" pageId="null" pageNumber="303">suedwaerts</normalizedToken>
bis Nordwestafrika, Sizilien, mittlere Balkanhalbinsel. - Im Gebiet: Zentral- und 
<normalizedToken id="F80FEBEAB5B3790C4A436492B23E6943" originalValue="südalpine" pageId="null" pageNumber="303">suedalpine</normalizedToken>
<normalizedToken id="F63B6056AF8AECE1D1480B23266971C0" originalValue="Täler" pageId="null" pageNumber="303">Taeler</normalizedToken>
, nordalpine 
<normalizedToken id="7578C4565435C312A1CE8ABFFD8BB267" originalValue="Föhntäler" pageId="null" pageNumber="303">Foehntaeler</normalizedToken>
, Savoyen, 
<normalizedToken id="53E6B6AF2D01D43BF9AE1752D12F8860" originalValue="südlicher" pageId="null" pageNumber="303">suedlicher</normalizedToken>
Jura, Engen im Hegau.
</paragraph>
</subSubSection>
