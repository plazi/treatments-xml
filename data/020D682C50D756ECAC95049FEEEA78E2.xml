<subSubSection id="D52CE1A94E7B97F30864509D321F847E" pageId="null" pageNumber="841" type="description">
<paragraph id="734BE999CB4DBB800A6DB43C2B39D7AE" pageId="null" pageNumber="841">
1 
<normalizedToken id="A6346C768B0AE44942ACE5761B7E0A19" originalValue="jährig" pageId="null" pageNumber="841">jaehrig</normalizedToken>
, 0,3-1 m hoch. Unterste 
<normalizedToken id="8AF71C62E60960CAC83A3D5432C7A07E" originalValue="Blätter" pageId="null" pageNumber="841">Blaetter</normalizedToken>
1fach gefiedert oder 3 
<normalizedToken id="7305326854B4987B543758450D9BB327" originalValue="zählig" pageId="null" pageNumber="841">zaehlig</normalizedToken>
und oft mit gefiederten 
<normalizedToken id="52BF1EEC7A8111D82D418F92C94C941E" originalValue="Teilblättern" pageId="null" pageNumber="841">Teilblaettern</normalizedToken>
, obere 
<normalizedToken id="95426AEACE2A5AB683AA3CA7F416765C" originalValue="Blätter" pageId="null" pageNumber="841">Blaetter</normalizedToken>
2-3fach gefiedert, mit schmalen, 
<normalizedToken id="784EE39C5503AA5565FB97F4F4EDB28A" originalValue="gezähnten" pageId="null" pageNumber="841">gezaehnten</normalizedToken>
<normalizedToken id="C67AFC70ECC6D0DE1C93BB5F9FB58623" originalValue="Teilblättern" pageId="null" pageNumber="841">Teilblaettern</normalizedToken>
letzter Ordnung. Dolden 1. Ordnung mit 15-30 Dolden 2. Ordnung. 
<emphasis id="A11A2D6B0C320C510A618E94AC203207" italics="true" pageId="null" pageNumber="841">
Abschnitte der 
<normalizedToken id="0E83F65FB84EA6F2280B29A9AE702DD2" originalValue="Hochblätter" pageId="null" pageNumber="841">Hochblaetter</normalizedToken>
1.Ordnung meist weniger als 1 mm breit, einzelne gelegentlich so lang wie die Stiele der Dolden 2. Ordnung
</emphasis>
. Frucht 2-2,5 mm lang und 1,2-1,5 mm dick. - 
<normalizedToken id="2C991997A939D7CFCE0988E402C9BD91" originalValue="Blüte" pageId="null" pageNumber="841">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="3AC892D53ECC39F4C984429DD4DD9797" pageId="null" pageNumber="841">
<emphasis id="29E4C9C9F284534BA6F24E850F257093" italics="true" pageId="null" pageNumber="841">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0386815E6971105BB4D3D3C585DE3431" italics="true" pageId="null" pageNumber="841">22:</emphasis>
Zahlreiche 
<normalizedToken id="45D90F8E261ACE4F800061D0238A68DB" originalValue="übereinstimmende" pageId="null" pageNumber="841">uebereinstimmende</normalizedToken>
<normalizedToken id="44067B811F9C89037268EDCE35AEBD6A" originalValue="Zählungen" pageId="null" pageNumber="841">Zaehlungen</normalizedToken>
aus dem weiten Verbreitungsgebiet in 
<normalizedToken id="B6A23A41307E0700CC376CFA39FE07DA" originalValue="Löve" pageId="null" pageNumber="841">Loeve</normalizedToken>
und 
<normalizedToken id="EAC5643B64E5699E66BEEA61B5420C55" originalValue="Löve" pageId="null" pageNumber="841">Loeve</normalizedToken>
(1961).
</paragraph>
<paragraph id="69C16853AD335BBA8F9D84DBAE9D3C24" pageId="null" pageNumber="841">
<emphasis id="869173575F4435B5D1FBD82062FC3C54" italics="true" pageId="null" pageNumber="841">
<pageBreakToken id="F97FFCF83DC3D1ADB2DAF261A5DB6C33" pageId="null" pageNumber="841">Standort</pageBreakToken>
</emphasis>
. Kollin. Sandige bis lehmige 
<normalizedToken id="95982DB1724F77213CC91DC42DAED3DA" originalValue="Böden" pageId="null" pageNumber="841">Boeden</normalizedToken>
. Unkrautgesellschaften, 
<normalizedToken id="2EDF1B36046B3977B687739EBB8DDB72" originalValue="Luzerneäcker" pageId="null" pageNumber="841">Luzerneaecker</normalizedToken>
.
</paragraph>
<paragraph id="FB722B54DC80610C075D6562A6F8EBF7" pageId="null" pageNumber="841">
<emphasis id="14F8475D4F4DFACC1B342582D7D5A288" italics="true" pageId="null" pageNumber="841">Verbreitung</emphasis>
. 
<normalizedToken id="4317EC8783A076790FBA20D4A1F78FA7" originalValue="Ursprünglich" pageId="null" pageNumber="841">Urspruenglich</normalizedToken>
<emphasis id="E2CA8FDFC13E501D131D872F46D693E8" italics="true" pageId="null" pageNumber="841">mediterrane Pflanze;</emphasis>
heute in den 
<normalizedToken id="91CD3EB3DD361D4EA41F38451B45CBE8" originalValue="gemäßigten" pageId="null" pageNumber="841">gemaessigten</normalizedToken>
Zonen weit verschleppt. - Im Gebiet zerstreut und selten.
</paragraph>
</subSubSection>
