<taxonomicName id="19860A6F207027ABA85C1443F6BD5661" authority="(L.) R. Br." class="Liliopsida" family="Orchidaceae" genus="Herminium" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="614" phylum="Tracheophyta" rank="species" species="monorchis">
Herminium 
<normalizedToken id="3013D670C5FDD80733EA4744CD33859E" originalValue="Monórchis" pageId="null" pageNumber="614">Monorchis</normalizedToken>
(
<authorityName id="14637D24A7673F5199CCE4380228D69D" pageId="null" pageNumber="614">L.</authorityName>
) R. Br.
</taxonomicName>
</paragraph>
