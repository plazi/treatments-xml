<subSubSection id="8A8D268E5A34522CD0199A2D5AA339AD" pageId="null" pageNumber="216" type="description">
<paragraph id="DBFC7C006447981C2C18B68E6DD0B810" pageId="null" pageNumber="216">
Ausdauernd oder 1 
<normalizedToken id="FBB42DC617A5DE7D5DF0804BF1A71D1E" originalValue="jährig" pageId="null" pageNumber="216">jaehrig</normalizedToken>
. 
<normalizedToken id="BDDF6545E9FE12C1C55F5EED3BBB0B68" originalValue="Blüten" pageId="null" pageNumber="216">Blueten</normalizedToken>
zwitterig, 
<normalizedToken id="742CC67632D4702710FBB6CE404559CC" originalValue="quirlständig" pageId="null" pageNumber="216">quirlstaendig</normalizedToken>
. 
<normalizedToken id="192D73217A592DD0E066DA562B46C2BC" originalValue="Äußere" pageId="null" pageNumber="216">Aeussere</normalizedToken>
<normalizedToken id="DB6AB43B38DBB50CB7EEF6094C256F18" originalValue="Perigonblätter" pageId="null" pageNumber="216">Perigonblaetter</normalizedToken>
3, 
<normalizedToken id="3958F440D4E24A8B1F532E688B98005D" originalValue="grün" pageId="null" pageNumber="216">gruen</normalizedToken>
, oval, 
<normalizedToken id="1A966FC27B95F97074CC44D70504A63E" originalValue="kürzer" pageId="null" pageNumber="216">kuerzer</normalizedToken>
als die innern 
<normalizedToken id="B62AC376A405BB64548CBF20A59D7BF9" originalValue="Perigonblätter" pageId="null" pageNumber="216">Perigonblaetter</normalizedToken>
; innere 
<normalizedToken id="A0934976AB694D367454BB48E4E7E200" originalValue="Perigonblätter" pageId="null" pageNumber="216">Perigonblaetter</normalizedToken>
3, kronblattartig. 
<normalizedToken id="0FEA0985FD82DB9E79DF4FB8C37CC8C0" originalValue="Staubblätter" pageId="null" pageNumber="216">Staubblaetter</normalizedToken>
6, zu je 2 vor einem 
<normalizedToken id="3F7BDA93A99AB826A22995FD3E1BE996" originalValue="äußern" pageId="null" pageNumber="216">aeussern</normalizedToken>
Perigonblatt. 
<emphasis id="DF7235C119E8926F06E544AE4C6CBB54" italics="true" pageId="null" pageNumber="216">
<normalizedToken id="A89925A5E0384630EEA70B1E541187D7" originalValue="Früchtchen" pageId="null" pageNumber="216">Fruechtchen</normalizedToken>
6-10, auf dem 
<normalizedToken id="7F41AE9D30322AB2DB8DB7F8B1D16880" originalValue="Blütenboden" pageId="null" pageNumber="216">Bluetenboden</normalizedToken>
<normalizedToken id="0BCC075EAC9DF4BBFB7191FA9C0B17B4" originalValue="sternförmig" pageId="null" pageNumber="216">sternfoermig</normalizedToken>
angeordnet, am Grunde verwachsen
</emphasis>
, 1- bis vielsamig.
</paragraph>
<paragraph id="5279FB19A26CA80D33EA304C2AB775A5" pageId="null" pageNumber="216">
Die Gattung 
<normalizedToken id="9F62D8DDA983C9F643B28E46C29C56F0" originalValue="umfaßt" pageId="null" pageNumber="216">umfasst</normalizedToken>
<emphasis id="0ED46617E87302A55A290C967A98B3FE" italics="true" pageId="null" pageNumber="216">4 Arten</emphasis>
, die in den Tropen und Subtropen verbreitet sind. Keine zytologischen Untersuchungen.
</paragraph>
</subSubSection>
