<paragraph id="8BD236DDED233847FF4DFAC1FC7AFA8D" blockId="626.[136,1452,1295,1356]" pageId="626" pageNumber="627">
<emphasis id="B919EACFED233847FF4DFAC1FEF7FAE8" bold="true" box="[136,306,1295,1321]" pageId="626" pageNumber="627">FIGURE 424.</emphasis>
