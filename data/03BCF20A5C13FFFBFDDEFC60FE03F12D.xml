<paragraph id="8BAA431C5C13FFFEFD24FBAAFCC1F644" blockId="3.[373,1214,978,1075]" box="[715,873,1048,1075]" pageId="3" pageNumber="4">
<figureCitation id="132E5F995C13FFFEFD24FBAAFCBEF644" box="[715,790,1048,1075]" captionStart="Fig" captionStartId="4.[191,234,1892,1918]" captionTargetBox="[189,1398,684,1854]" captionTargetId="figure-152@4.[189,1398,684,1854]" captionTargetPageId="4" captionText="Fig. 2. Megatachycines pentus gen. et sp. nov. A–F. Holotype, ♂ (HBU). A–C. Head and pronotum. A. Frontal view. B. Lateral view. C. Dorsal view. D–F. Apex of abdomen. D. Lateral view. E. Dorsal view. F. Ventral view. G–H. Paratype, ♀ (HBU). G. Subgenital plate in ventral view. H. Ovipositor in lateral view." figureDoi="http://doi.org/10.5281/zenodo.6517879" httpUri="https://zenodo.org/record/6517879/files/figure.png" pageId="3" pageNumber="4">Figs 2</figureCitation>
, 
<figureCitation id="132E5F995C13FFFEFCCDFBAAFCC1F644" box="[802,873,1048,1075]" captionStart="Fig" captionStartId="7.[189,233,1929,1955]" captionTargetBox="[189,1398,695,1890]" captionTargetId="figure-91@7.[189,1398,691,1890]" captionTargetPageId="7" captionText="Fig. 5. Male genitalia. A, C, E. Dorsal view. B, D, F. Ventral view. A–B. Megatachycines pentus gen. et sp. nov., paratype, ♂ (HBU). C–D. Megatachycines elongatus (Qin, Liu &amp; Li, 2017) comb. nov. E–F. Megatachycines trispinosus (Qin &amp; Li, 2020) comb. nov." figureDoi="http://doi.org/10.5281/zenodo.6517910" httpUri="https://zenodo.org/record/6517910/files/figure.png" pageId="3" pageNumber="4">5A–B</figureCitation>
