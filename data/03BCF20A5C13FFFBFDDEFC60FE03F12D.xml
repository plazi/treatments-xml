<taxonomicName id="4C15389F5C15FFF8FEFFF83AFCE3F5D5" authority="(Qin, Liu &amp; Li, 2017)" authorityName="Zhu &amp; Shi &amp; Zhou" authorityYear="2022" baseAuthorityName="Qin, Liu &amp; Li" baseAuthorityYear="2017" box="[272,843,1928,1954]" class="Insecta" family="Rhaphidophoridae" genus="Megatachycines" kingdom="Animalia" order="Orthoptera" pageId="5" pageNumber="6" phylum="Arthropoda" rank="species" species="elongatus" status="comb. nov.">
