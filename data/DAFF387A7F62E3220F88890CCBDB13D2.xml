<normalizedToken id="011D642A0D601C7EE438F650B1300314" originalValue="Blütenstiel" pageId="null" pageNumber="527">Bluetenstiel</normalizedToken>
ein 
<normalizedToken id="6C1FA3E712A45FB6626E6B332A570154" originalValue="becherförmiges" pageId="null" pageNumber="527">becherfoermiges</normalizedToken>
, oft undeutlich 3teiliges Vorblatt vorhanden
</td>
