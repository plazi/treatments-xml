<caption id="EDEC698A2A16F332F7F9F4196776F361" ID-DOI="http://doi.org/10.5281/zenodo.5727229" ID-Zenodo-Dep="5727229" httpUri="https://zenodo.org/record/5727229/files/figure.png" inLine="true" pageId="5" pageNumber="528" targetBox="[1446,2025,2775,3182]" targetPageId="5">
<paragraph id="B92C39022A16F332F7F9F4196776F361" blockId="5.[2058,2645,2768,3186]" lastBlockId="5.[1443,2645,3200,3461]" pageId="5" pageNumber="528">
<emphasis id="8BE7E5102A16F332F7F9F41969EFF410" box="[2058,2233,2966,2995]" pageId="5" pageNumber="528">Distribution.</emphasis>
NE 
<collectingCountry id="C18479922A16F332F70CF41C681AF413" box="[2303,2380,2963,2992]" name="Brazil" pageId="5" pageNumber="528">Brazil</collectingCountry>
in remnant forest patches in the N of the states of 
<collectingRegion id="7B57F7E02A16F332F5F0F43C6905F45F" country="Brazil" name="Maranhao" pageId="5" pageNumber="528">Maranhao</collectingRegion>
, 
<collectingRegion id="7B57F7E02A16F332F796F46C69FBF45F" box="[2149,2221,3043,3068]" country="Brazil" name="Piaui" pageId="5" pageNumber="528">Piaui</collectingRegion>
