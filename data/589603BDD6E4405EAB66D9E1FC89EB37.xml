<subSubSection id="9FA29FC169B8506510D1406FF09E5F89" pageId="null" pageNumber="38" type="description">
<paragraph id="5B6C549375E8AB71B01834BA355DB0CA" pageId="null" pageNumber="38">
Unterscheidet sich von der Gattung 
<taxonomicName id="87BA4209AD9C92CDD2D4EFEA06DB7878" class="Magnoliopsida" family="Gentianaceae" genus="Gentiana" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="38" phylum="Tracheophyta" rank="genus">
<emphasis id="B248AB50F574AF39AACEB07EAC518D07" italics="true" pageId="null" pageNumber="38">Gentiana</emphasis>
</taxonomicName>
(S. 20) durch folgende Merkmale: Stets 1 
<normalizedToken id="C56FBA4B7E2F4029D554E39CA7A27FD7" originalValue="jährig" pageId="null" pageNumber="38">jaehrig</normalizedToken>
; 
<normalizedToken id="0156EFADD3D86A510569B618452AD3BB" originalValue="Blüten" pageId="null" pageNumber="38">Blueten</normalizedToken>
immer einzeln am Ende der Zweige; Kelch und Krone stets mit 4 Zipfeln; 
<emphasis id="684D8679F4E728DF142BC36B65C8A256" italics="true" pageId="null" pageNumber="38">
Griffel 
<normalizedToken id="884B9F8386426BC3D6061F5EADC82FE3" originalValue="fadenförmig" pageId="null" pageNumber="38">fadenfoermig</normalizedToken>
, deutlich vom Fruchtknoten abgesetzt;
</emphasis>
Frucht 
<normalizedToken id="1EA03BDA1E5C09C29A6F0D5A3C738D2C" originalValue="eiförmig" pageId="null" pageNumber="38">eifoermig</normalizedToken>
, ungestielt.
</paragraph>
<paragraph id="CE5D4735EEEF91446B3756A8F181CFDB" pageId="null" pageNumber="38">
Die Gattung 
<taxonomicName id="050A35D0CA03AF0FF7CA572F0E9B995A" class="Magnoliopsida" family="Gentianaceae" genus="Cicendia" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="38" phylum="Tracheophyta" rank="genus">
<emphasis id="34A503489C4AD65897D0865AB4B29CEB" italics="true" pageId="null" pageNumber="38">Cicendia</emphasis>
</taxonomicName>
<normalizedToken id="BD04B278FBFA11F0F808783955E695BC" originalValue="umfaßt" pageId="null" pageNumber="38">umfasst</normalizedToken>
in der vorliegenden Umgrenzung 
<emphasis id="3A09C85158AB6A6DD36C111EB625A610" italics="true" pageId="null" pageNumber="38">4 Arten in Europa und Amerika.</emphasis>
</paragraph>
<paragraph id="6F5C9E34ADEF198391D1EC327DDB68D1" pageId="null" pageNumber="38">
<table id="B587D252579DD70BC4A8C3C1B348170F" frame="void" pageId="null" pageNumber="38" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="9FA18F10CC0EE85E419A004FA85F0353" pageId="null" pageNumber="38">
<tr id="8BFFDC758DBE3EF90A0C71A90C3B54C6" pageId="null" pageNumber="38">
<td id="F581B11A9B12DFA245D39B72D8905C89" align="left" pageId="null" pageNumber="38" valign="top">
1. Kelch bis auf etwa ⅔ der 
<normalizedToken id="A67202300037FF7256ADECFFC4AF17C9" originalValue="Länge" pageId="null" pageNumber="38">Laenge</normalizedToken>
4teilig, mit breit 3eckigen Zipfeln; Narbe 
<normalizedToken id="6123A48AF45FC08B7138B277C0EF7167" originalValue="köpfförmig" pageId="null" pageNumber="38">koepffoermig</normalizedToken>
, nur wenig ausgerandet
</td>
<td id="2DA96AC418C13C5537808B73BEA19E3D" align="left" pageId="null" pageNumber="38" valign="bottom">
<taxonomicName id="3F6C8EE5053595858865B9B4B1DE7F65" class="Magnoliopsida" family="Gentianaceae" genus="Cicendia" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="38" phylum="Tracheophyta" rank="species" species="filiformis">
<italic id="5062202F4B40205C1665A8A14BD84DF6" pageId="null" pageNumber="38">C. filiformis</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="633FDFEF7DF44BC65F97A4916571F429" pageId="null" pageNumber="38">
<td id="18E0B27299F4DA5C4FDFD727734C5FDE" align="left" pageId="null" pageNumber="38" valign="top">1*. Kelch bis fast auf den Grund 4teilig, mit schmal lanzettlichen Zipfeln; Narbe deutlich 2teilig.</td>
<td id="28B08B8C5E7A266A2DA34446A59ACAE9" align="left" pageId="null" pageNumber="38" valign="bottom">
<taxonomicName id="16F88843C53DA07E708AB15187536D9F" class="Magnoliopsida" family="Gentianaceae" genus="Cicendia" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="38" phylum="Tracheophyta" rank="species" species="pusilla">
<italic id="F725B988CC8B7418C91D16C6099F5097" pageId="null" pageNumber="38">C. pusilla</italic>
</taxonomicName>
(Nr. 2)
</td>
</tr>
</tbody>
</table>
</paragraph>
