<taxonomicName id="3CF784BEFFA5FF82FB68FC76FAB09B34" authority="Tian &amp; Xing, 2022" authorityName="Tian &amp; Xing" authorityYear="2022" box="[1181,1376,1030,1052]" class="Insecta" family="Diaspididae" genus="Unachionaspis" kingdom="Animalia" order="Hemiptera" pageId="11" pageNumber="531" phylum="Arthropoda" rank="species" species="multiglandularis" status="sp. n.">
<emphasis id="C983232FFFA5FF82FB68FC76FAB09B34" bold="true" box="[1181,1376,1030,1052]" italics="true" pageId="11" pageNumber="531">U. multiglandularis</emphasis>
</taxonomicName>
<taxonomicNameLabel id="D2B09E54FFA5FF82FA93FC77FA4C9B33" box="[1382,1436,1030,1051]" pageId="11" pageNumber="531" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
</keyLead>
</paragraph>
