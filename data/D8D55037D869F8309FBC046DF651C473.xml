<subSubSection id="FB4DC818C47C9E659E9283A774B6F7C7" pageId="null" pageNumber="494" type="description">
<paragraph id="B57C1B5B5727EAB870197D75E8FC821A" pageId="null" pageNumber="494">
Bis 1 m hoch. 
<normalizedToken id="850D531589F03630730441721DD8FF52" originalValue="Blütenstand" pageId="null" pageNumber="494">Bluetenstand</normalizedToken>
die 
<normalizedToken id="E67C8052AF9BF9030B794FCB87D86FDE" originalValue="Blätter" pageId="null" pageNumber="494">Blaetter</normalizedToken>
<normalizedToken id="93606272C6CA9613C05E2DD3ADC7C5BA" originalValue="überragend" pageId="null" pageNumber="494">ueberragend</normalizedToken>
. Hochblatt (
<taxonomicName id="6CB47343469249C64C0F4D4BF65BBEBA" class="Bivalvia" family="Iridinidae" genus="Spatha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Unionida" pageId="null" pageNumber="494" phylum="Mollusca" rank="genus">Spatha</taxonomicName>
) bis 35 cm lang, purpurn bis violett. Oberer, 
<normalizedToken id="4B18DC2A15759F1E24FBECAABC8AE5A6" originalValue="blütenloser" pageId="null" pageNumber="494">bluetenloser</normalizedToken>
Teil der Kolbenachse 20-40 cm lang, wie die 
<taxonomicName id="EABBE9C8517B8457247239EAC2D0F48C" class="Bivalvia" family="Iridinidae" genus="Spatha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Unionida" pageId="null" pageNumber="494" phylum="Mollusca" rank="genus">Spatha</taxonomicName>
<normalizedToken id="73D21DBEED724C6DB131EF940F080ACB" originalValue="gefärbt" pageId="null" pageNumber="494">gefaerbt</normalizedToken>
. - 
<normalizedToken id="93CA9068EC7867433A751A1911B129B5" originalValue="Blüte" pageId="null" pageNumber="494">Bluete</normalizedToken>
: 
<normalizedToken id="B6A2EEBC325F5E5DDFA1B1B0BCB932CB" originalValue="Früher" pageId="null" pageNumber="494">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="B30702AC7494B061D7B83B3CD72632FA" pageId="null" pageNumber="494">
<emphasis id="27395EA5D49079C68B43B1086C351E54" italics="true" pageId="null" pageNumber="494">Zytologische Angaben. 2n = 64:</emphasis>
(Delay aus Darlington und Wylie 1955).
</paragraph>
<paragraph id="D7C0771D120575725A648A45ADD54029" pageId="null" pageNumber="494">
<emphasis id="9C7C2F3C1042C431B820D6A203898B88" italics="true" pageId="null" pageNumber="494">Standort.</emphasis>
Kollin. 
<normalizedToken id="CB9EA01F9F8C16379B290973480EA87C" originalValue="Gebüsch" pageId="null" pageNumber="494">Gebuesch</normalizedToken>
in warmen Gegenden.
</paragraph>
<paragraph id="9D8EAC36185F461D43C13E2E696E12A0" pageId="null" pageNumber="494">
<emphasis id="B7CCC2B95BDC3117FD62763BB840DDC6" italics="true" pageId="null" pageNumber="494">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="E851114D39D29C3FD2588E60344BBDDF" originalValue="Nordwärts" pageId="null" pageNumber="494">Nordwaerts</normalizedToken>
bis Mittelfrankreich (verwildert), 
<normalizedToken id="1E0B4437122143431E7770490DCCBF5F" originalValue="Alpensüdfuß" pageId="null" pageNumber="494">Alpensuedfuss</normalizedToken>
, Balkanhalbinsel; westliches Kleinasien; Nordwestafrika. - Im Gebiet wahrscheinlich nur verwildert: Tesserete, Brione, Breganzona, Valsesia (Varallo).
</paragraph>
</subSubSection>
