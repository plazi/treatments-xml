<subSubSection id="94AC04D3A4742B7A8002B90EAD093062" pageId="null" pageNumber="266" type="description">
<paragraph id="716F4AB38C41FC1750EAC7FE05B7450F" pageId="null" pageNumber="266">
15-30 cm hoch. 
<emphasis id="E519B93B6A98D45C14019F5948F86298" italics="true" pageId="null" pageNumber="266">
<normalizedToken id="D83AA5D62FE2DE3A13DF2FB9F1C05624" originalValue="Blätter" pageId="null" pageNumber="266">Blaetter</normalizedToken>
bis 2 mm breit
</emphasis>
(getrocknet), oberseits deutlich 
<normalizedToken id="EC8096008970B44CFE1C261558DD2707" originalValue="gewölbt" pageId="null" pageNumber="266">gewoelbt</normalizedToken>
. 
<emphasis id="8990E28C470B28EED43E4E28C8D7A6C5" italics="true" pageId="null" pageNumber="266">
<normalizedToken id="762D5ADDE857B58300F492B94BD987C8" originalValue="Kelchblätter" pageId="null" pageNumber="266">Kelchblaetter</normalizedToken>
mit wenig ausgezogener Spitze.
</emphasis>
<normalizedToken id="9F6F797B44B0071663DCA14357E85124" originalValue="Kronblätter" pageId="null" pageNumber="266">Kronblaetter</normalizedToken>
zitronengelb. 
<emphasis id="7AE7C5A61D8AD1C8656DA4C4EF113DFC" italics="true" pageId="null" pageNumber="266">
<normalizedToken id="63D80FBCB07E10BD0BC481B62262975C" originalValue="Staubfäden" pageId="null" pageNumber="266">Staubfaeden</normalizedToken>
am Grunde zerstreut bewimpert.
</emphasis>
</paragraph>
<paragraph id="6EFF50AF0B911C8098627B6527C45F8A" pageId="null" pageNumber="266">
<emphasis id="737B16CCFB618E076E26313D5C193638" italics="true" pageId="null" pageNumber="266">Zytologische Angaben.</emphasis>
Siehe unter Artengruppe.
</paragraph>
<paragraph id="72D69493E838B8CBDE0C70BF9C303519" pageId="null" pageNumber="266">
<emphasis id="1D51986BDC36A2AE00786F1E587324AF" italics="true" pageId="null" pageNumber="266">Standort.</emphasis>
Kollin und montan. Trockene, kalkarme, oft saure, meist sandige 
<normalizedToken id="EAD1EE623A21C499F01E9BDCA855D15F" originalValue="Böden" pageId="null" pageNumber="266">Boeden</normalizedToken>
. Trockenwiesen, lichte 
<normalizedToken id="2430EF59617B8B0092CC63C86BF5792D" originalValue="Wälder" pageId="null" pageNumber="266">Waelder</normalizedToken>
, 
<normalizedToken id="43C44B3299E881D09B99EA3E3B7E429F" originalValue="Schuttplätze" pageId="null" pageNumber="266">Schuttplaetze</normalizedToken>
, 
<normalizedToken id="47516DF92520535F995BF4987D1C6D9F" originalValue="Straßenränder" pageId="null" pageNumber="266">Strassenraender</normalizedToken>
, Mauern, Felsspalten.
</paragraph>
<paragraph id="E8D43A1343D9466CB34B02157BAF777C" pageId="null" pageNumber="266">
<emphasis id="36C633DC4F6DB3472D45D0C2C188BB3F" italics="true" pageId="null" pageNumber="266">
Verbreitung. 
<normalizedToken id="AFCAA568C73CFCA7EC0C5E184BD43008" originalValue="Europäische" pageId="null" pageNumber="266">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="D8EAB32655F1F4D6F97FC85D6484C727" originalValue="Nordwärts" pageId="null" pageNumber="266">Nordwaerts</normalizedToken>
bis Irland, Schottland, Skandinavien (bis 64° NB), 
<normalizedToken id="40D6D4A960383C2577A7540411D69418" originalValue="ostwärts" pageId="null" pageNumber="266">ostwaerts</normalizedToken>
bis Krakau, 
<normalizedToken id="05C1A6E1A39111DE88FF3E9113D958A9" originalValue="Südrußland" pageId="null" pageNumber="266">Suedrussland</normalizedToken>
, Kaukasus (?); im 
<normalizedToken id="3ED2977BC9434524737BF6BE597947DD" originalValue="Süden" pageId="null" pageNumber="266">Sueden</normalizedToken>
wahrscheinlich im ganzen Mediterrangebiet. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet zerstreut, oft verwildert, nicht 
<normalizedToken id="1D4F7B2F96A26F72AB10C7ECAFFDD268" originalValue="häufig" pageId="null" pageNumber="266">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="34EABB3C912B66AE7FD20519310D17C2" pageId="null" pageNumber="266">
<emphasis id="1DDE6860821FE0FDE2E745DD9C8D2739" italics="true" pageId="null" pageNumber="266">Bemerkungen.</emphasis>
Nach Janchen (1963) ist der Name 
<taxonomicName id="8EC32BED42B398D114E656405CFD9487" authority="L." authorityName="L." class="Magnoliopsida" family="Crassulaceae" genus="Sedum" kingdom="Plantae" order="Saxifragales" pageId="null" pageNumber="266" phylum="Tracheophyta" rank="species" species="reflexum">
<emphasis id="1F40C1F09EEBDBDC175F104C6E2203C1" italics="true" pageId="null" pageNumber="266">S. reflexum</emphasis>
<authorityName id="20116177EAC153DD6A9E74C3BF2838AE" pageId="null" pageNumber="266">L.</authorityName>
</taxonomicName>
<normalizedToken id="57FB3A631A2C047CF7F3FE5BF27BE5E2" originalValue="gültig" pageId="null" pageNumber="266">gueltig</normalizedToken>
. Bevor die komplizierte Artengruppe zytogenetisch untersucht ist, sollten keine Namen 
<normalizedToken id="00A5FA65CA23EDA10800594D8F13F01E" originalValue="geändert" pageId="null" pageNumber="266">geaendert</normalizedToken>
werden.
</paragraph>
</subSubSection>
