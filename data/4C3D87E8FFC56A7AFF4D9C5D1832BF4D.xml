<paragraph id="C42B36FEFFC56A7AFCEF9D171A85B0D4" blockId="62.[785,1380,2697,3125]" pageId="62" pageNumber="820">
Previously included in 
<taxonomicName id="03944D7DFFC56A7AFBAF9D171AE2B05D" baseAuthorityName="A. Smith" baseAuthorityYear="1829" box="[1107,1250,2894,2927]" class="Mammalia" family="Vespertilionidae" genus="Neoromicia" kingdom="Animalia" order="Chiroptera" pageId="62" pageNumber="820" phylum="Chordata" rank="species" species="capensis">N. capensis</taxonomicName>
