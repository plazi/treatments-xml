<caption id="90EB6676FFC56A7AFCEE9DAD1FFBB7B4" ID-DOI="http://doi.org/10.5281/zenodo.6398029" ID-Zenodo-Dep="6398029" httpUri="https://zenodo.org/record/6398029/files/figure.png" inLine="true" pageId="62" pageNumber="820" targetBox="[170,762,2711,3124]" targetPageId="62">
<paragraph id="C42B36FEFFC56A7AFCEE9DAD1FFBB7B4" blockId="62.[785,1380,2697,3125]" lastBlockId="62.[174,1378,3140,3480]" pageId="62" pageNumber="820">
<emphasis id="F6E0EAECFFC56A7AFCEE9DAD1DC2B73F" bold="true" box="[786,962,3060,3085]" pageId="62" pageNumber="820">Distribution.</emphasis>
<collectingCountry id="BC83766EFFC56A7AFC2D9DAD1A56B73F" box="[977,1110,3060,3085]" name="Botswana" pageId="62" pageNumber="820">Botswana</collectingCountry>
, in Okavango Delta along Gomoti River, 
<collectingCountry id="BC83766EFFC56A7AFB929A451AD6B707" box="[1134,1238,3100,3125]" name="Zambia" pageId="62" pageNumber="820">Zambia</collectingCountry>
