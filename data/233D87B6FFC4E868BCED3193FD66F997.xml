<taxonomicName id="6C944D23FFC4E868BCED31CFFE0AFD5A" authority="Mik, 1878: 6" authorityName="Mik" authorityPageNumber="6" authorityYear="1878" box="[151,441,720,745]" class="Insecta" family="Dolichopodidae" genus="Micromorphus" kingdom="Animalia" order="Diptera" pageId="1" pageNumber="438" phylum="Arthropoda" rank="genus">
<emphasis id="99E0EAB2FFC4E868BCED31CFFE9EFD5A" box="[151,301,720,744]" italics="true" pageId="1" pageNumber="438">Micromorphus</emphasis>
<bibRefCitation id="CF054B51FFC4E868BD4931CFFE0AFD5A" author="Mik, J." box="[307,441,720,745]" pageId="1" pageNumber="438" pagination="1 - 24" refId="ref5589" refString="Mik, J. (1878) Dipterologische Untersuchungen. Jahresberichte des Kaiserlich-koniglichen Akademische Gymnasium, Wein, 1877 / 1878, 1 - 24." type="journal article" year="1878">Mik, 1878: 6</bibRefCitation>
