<taxonomicName id="6C944D23FFC4E868BE2831CFFC6FFD5B" authority="Zetterstedt, 1843" authorityName="Zetterstedt" authorityYear="1843" box="[594,988,720,745]" class="Insecta" family="Dolichopodidae" genus="Hydrophorus" kingdom="Animalia" order="Diptera" pageId="1" pageNumber="438" phylum="Arthropoda" rank="species" species="albipes">
