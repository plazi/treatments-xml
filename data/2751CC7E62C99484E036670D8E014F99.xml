<subSubSection id="4C4BB3DB94FC91104CE73CC6BC96372A" pageId="null" pageNumber="395" type="description">
<paragraph id="19F6C8CCABAF341712687B43F258E3A3" pageId="null" pageNumber="395">
<normalizedToken id="ADA6E575F216AA91E65A52832084D7F6" originalValue="Grundständige" pageId="null" pageNumber="395">Grundstaendige</normalizedToken>
<normalizedToken id="CB41E574D2C71A488D51895D685084C7" originalValue="Blätter" pageId="null" pageNumber="395">Blaetter</normalizedToken>
mit 2-10 cm langen, abstehend oder anliegend behaarten Stielen; 
<emphasis id="430934E7A0F5634E808A1EB6AAE6CB3A" italics="true" pageId="null" pageNumber="395">
Behaarung wie bei 
<taxonomicName id="DFC981801E1EEC9D21B023685D359799" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="395" phylum="Tracheophyta" rank="species" species="recta">P. recta</taxonomicName>
</emphasis>
(Nr. 14), 
<emphasis id="E4C14E9E351472542E247F71AE2EBD88" italics="true" pageId="null" pageNumber="395">
die langen Haare jedoch nur etwa halb so dick wie bei 
<taxonomicName id="8AB51887C0D7C38A2DDEAEAA8386B0E2" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="395" phylum="Tracheophyta" rank="species" species="recta">P. recta</taxonomicName>
. 
<normalizedToken id="AEC45518CAF469E4511D07867A564684" originalValue="Blätter" pageId="null" pageNumber="395">Blaetter</normalizedToken>
1fach gefiedert
</emphasis>
, mit 2-7 Fiederpaaren und 
<normalizedToken id="D1034AA5AA6C89638F872CA2AA3A00A4" originalValue="endständigem" pageId="null" pageNumber="395">endstaendigem</normalizedToken>
Teilblatt; 
<normalizedToken id="93EB67DAD15CE313E272E02062B78A83" originalValue="Teilblätter" pageId="null" pageNumber="395">Teilblaetter</normalizedToken>
oval, 1-3 cm lang, etwa 2mal so lang wie breit, mit der 
<normalizedToken id="292181C0E4D7C99F23658E157C1EEF80" originalValue="größten" pageId="null" pageNumber="395">groessten</normalizedToken>
Breite in oder 
<normalizedToken id="7B271F54EFB902E66F2089851E2AC9F6" originalValue="über" pageId="null" pageNumber="395">ueber</normalizedToken>
der Mitte, beiderseits 
<normalizedToken id="6EF8C43E1E5D0616ECAE25BE10041E5B" originalValue="grün" pageId="null" pageNumber="395">gruen</normalizedToken>
, gemischte Behaarung wie an den Stielen, am Rande jederseits mit 4-8 groben und stumpfen 
<normalizedToken id="4BA5FEA37687C1F27F4E8BFBBE86D78F" originalValue="Zähnen" pageId="null" pageNumber="395">Zaehnen</normalizedToken>
oder fiederteilig und mit ebenso vielen 
<normalizedToken id="316CD6186BE11B40393C6BAA26CAE14E" originalValue="zahnähnlichen" pageId="null" pageNumber="395">zahnaehnlichen</normalizedToken>
Abschnitten. Stengel wie bei 
<emphasis id="8CE71C3606D89F825CA969CBBC71AE35" italics="true" pageId="null" pageNumber="395">
<taxonomicName id="9E4D095390D17C815762822A34308ED5" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="395" phylum="Tracheophyta" rank="species" species="recta">P. recta</taxonomicName>
.
</emphasis>
Durchmesser der 
<normalizedToken id="7FD3825B5DE4A9436CF96376D47F9FB3" originalValue="Blüten" pageId="null" pageNumber="395">Blueten</normalizedToken>
1,5-1,8 cm. 
<normalizedToken id="91C05EDC59A75175B27A2D7A8F873C43" originalValue="Äußere" pageId="null" pageNumber="395">Aeussere</normalizedToken>
<normalizedToken id="D5B108AE71B6006D95E8DEFBB2A8D52F" originalValue="Kelchblätter" pageId="null" pageNumber="395">Kelchblaetter</normalizedToken>
schmal lanzettlich, stumpf, so lang wie die innern, breit lanzettlichen, stumpfen 
<normalizedToken id="8E1CD8CED5FBBD3B6B262EFA692FC07E" originalValue="Kelchblätter" pageId="null" pageNumber="395">Kelchblaetter</normalizedToken>
. 
<normalizedToken id="6A23A7694BEA457A5EF88354A9171A68" originalValue="Kronblätter" pageId="null" pageNumber="395">Kronblaetter</normalizedToken>
gelb, oval, gestutzt oder wenig ausgerandet, den Kelch nicht oder wenig 
<normalizedToken id="A1351F117F2ED8CFC042351B61F115F5" originalValue="überragend" pageId="null" pageNumber="395">ueberragend</normalizedToken>
. 
<normalizedToken id="A50F85A24F7F9356C6B65907EF482CAD" originalValue="Früchtchen" pageId="null" pageNumber="395">Fruechtchen</normalizedToken>
wie bei 
<emphasis id="7C23D76698A0295ADD90D0E6E12374E9" italics="true" pageId="null" pageNumber="395">
<taxonomicName id="6978435ED6B9F31D001A80E7267706A9" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="395" phylum="Tracheophyta" rank="species" species="recta">P. recta</taxonomicName>
.
</emphasis>
- 
<normalizedToken id="427851D456879B95E50F222A86A7BEEB" originalValue="Blüte" pageId="null" pageNumber="395">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="B6564096562171588D1D51F1206BE1E3" pageId="null" pageNumber="395">
<emphasis id="D5EC6A79984C4D2448112B5055BA14A5" italics="true" pageId="null" pageNumber="395">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5E53E215718F3DBA6B84EF51258EE70A" italics="true" pageId="null" pageNumber="395">28:</emphasis>
Material aus botanischen 
<normalizedToken id="A37BC1BE4389ACF9C4FCFDCF759CAEEB" originalValue="Gärten" pageId="null" pageNumber="395">Gaerten</normalizedToken>
; Art sexuell (Christoff und Papasowa 1943).
</paragraph>
<paragraph id="7B8E1544B04A7E6D48E0A78C375EC604" pageId="null" pageNumber="395">
<emphasis id="36F8ABF28C90BBC19EC13046A5055408" italics="true" pageId="null" pageNumber="395">Standort.</emphasis>
Montan. Trockene, steinige 
<normalizedToken id="843F93D4BD43BFD4F2BCADC80C2EAEC3" originalValue="Böden" pageId="null" pageNumber="395">Boeden</normalizedToken>
. Wiesen, 
<normalizedToken id="1A177945B98D7549E30C4F3BBD750253" originalValue="Wegränder" pageId="null" pageNumber="395">Wegraender</normalizedToken>
, Trockenbusch (mit 
<emphasis id="255FA849605B29DF7809FE3FC13E63D5" italics="true" pageId="null" pageNumber="395">
<taxonomicName id="C3E7F72B2D39ABF0D424397FE353A908" class="Pinopsida" family="Cupressaceae" genus="Juniperus" kingdom="Plantae" order="Pinales" pageId="null" pageNumber="395" phylum="Tracheophyta" rank="genus">Juniperus</taxonomicName>
<taxonomicName id="483974719DC2E3D7B0B27ED480275FC6" authority="Quercus" authorityName="Quercus" class="Insecta" family="Hesperiidae" genus="Sabina" kingdom="Animalia" order="Lepidoptera" pageId="null" pageNumber="395" phylum="Arthropoda" rank="genus">Sabina, Quercus</taxonomicName>
<taxonomicName id="9DBE4C1EC623DF1ECB7B992F3FE30864" class="Magnoliopsida" family="Rosaceae" genus="Alchemilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="395" phylum="Tracheophyta" rank="species" species="pubescens">pubescens</taxonomicName>
</emphasis>
).
</paragraph>
<paragraph id="E7F6FABDA8684FBA2070ACC89495463B" pageId="null" pageNumber="395">
<emphasis id="62A28ECCDF8CD5B629FBEA62620E1207" italics="true" pageId="null" pageNumber="395">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
<normalizedToken id="9C196B759486060D69C86898AF6019D3" originalValue="Süd-" pageId="null" pageNumber="395">Sued-</normalizedToken>
und Ostspanien, Umgebung von Paris, 
<normalizedToken id="5E1DB99F80D305952B00C078A2FF6298" originalValue="Südwestalpen" pageId="null" pageNumber="395">Suedwestalpen</normalizedToken>
, Karelien, Ural, Sibirien; von Westkanada durch die Gebirge 
<normalizedToken id="FCF276DDF731BB3FC646B0FC53EEEFD1" originalValue="südwärts" pageId="null" pageNumber="395">suedwaerts</normalizedToken>
bis Neumexiko. - Im Gebiet: Aostatal (bei Epinel im Valle di Cogne, Valgrisanche), Valsesia (Valle Mastallone).
</paragraph>
<paragraph id="4F89DBB2887F1110AF083B082B92ADAB" pageId="null" pageNumber="395">
<emphasis id="4701A537E010778A38E15E0CACF21A85" italics="true" pageId="null" pageNumber="395">Bemerkungen.</emphasis>
<normalizedToken id="F6CFA822DFD2E379531BDB78779D34F3" originalValue="Häufig" pageId="null" pageNumber="395">Haeufig</normalizedToken>
wird die in den Westalpen vorkommende Pflanze mit 
<taxonomicName id="E250F5A8DA18CA556F9F2D894574037A" authority="F. O. Wolf" authorityName="F. O. Wolf" pageId="null" pageNumber="395" rank="variety" variety="sanguisorbifolia">
var. 
<emphasis id="8F99C4CB03F535A669DC2C397405A3AC" italics="true" pageId="null" pageNumber="395">sanguisorbifolia</emphasis>
F. O. Wolf
</taxonomicName>
bezeichnet. Nach Untersuchungen von Ball (Flora Europaea Bd. 2, 1968) hat 
<taxonomicName id="B2C14505E064E2238965B146633E2E68" authority="in Eurosibirien" authorityName="in Eurosibirien" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="395" phylum="Tracheophyta" rank="species" species="pennsylvanica">
<emphasis id="BFFE796471BB837BAB5FEAA294ADE755" italics="true" pageId="null" pageNumber="395">P. pennsylvanica</emphasis>
in Eurosibirien
</taxonomicName>
eine 
<normalizedToken id="56503D83741FB1FB34FDF0BBFF891DED" originalValue="natürliche" pageId="null" pageNumber="395">natuerliche</normalizedToken>
Verbreitung und die Pflanzen aus Spanien, den Alpen und Sibirien stimmen in den 
<normalizedToken id="BF979FFEC0F3BB7DB09FA4737F36DEA6" originalValue="äußern" pageId="null" pageNumber="395">aeussern</normalizedToken>
Merkmalen 
<normalizedToken id="B646D04640818D5EDE50CEB79B0E1307" originalValue="überein" pageId="null" pageNumber="395">ueberein</normalizedToken>
und sind mit den amerikanischen identisch. Bisher glaubte man, 
<taxonomicName id="BC14F7EC7C4F31618FBBF9FF2794F7CC" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="395" phylum="Tracheophyta" rank="species" species="pennsylvanica">
<emphasis id="906379DBF9E1E3BADED7843A6A61E051" italics="true" pageId="null" pageNumber="395">P. pennsylvanica</emphasis>
</taxonomicName>
komme 
<normalizedToken id="C03A3C0902E09CA82DDAF5ED7B7516ED" originalValue="außerhalb" pageId="null" pageNumber="395">ausserhalb</normalizedToken>
Amerikas nur in den Westalpen und um Paris vor und sei dorthin verschleppt worden. 
<normalizedToken id="DCFFD29564DC0464E639C17097A84A05" originalValue="Über" pageId="null" pageNumber="395">Ueber</normalizedToken>
den Standort im Valle di Cogne s. Peyronel (1962).
</paragraph>
</subSubSection>
