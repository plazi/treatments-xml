<subSubSection id="24CBACB4A9AE523E40F8C621B4230338" pageId="null" pageNumber="597" type="description">
<paragraph id="2F68209DD601096950AC0E68077EB483" pageId="null" pageNumber="597">
Die Gattung 
<normalizedToken id="E878207B1C677B83DD6304F95E0EC0BF" originalValue="umfaßt" pageId="null" pageNumber="597">umfasst</normalizedToken>
<emphasis id="EA2F07EDFFB6C1DBE6E24BAE77CDE080" italics="true" pageId="null" pageNumber="597">nur 1 saprophytische Art</emphasis>
und besitzt in den Tropen Asiens und Afrikas eine nahe verwandte Gattung. Die Gattungsmerkmale sind in der Artdiagnose enthalten.
</paragraph>
<paragraph id="ABE9663185C83FD007C223BFCB710567" pageId="null" pageNumber="597">
Die Gattung 
<taxonomicName id="03AE90676646203AECE4CE69FB788B54" class="Liliopsida" family="Orchidaceae" genus="Epipogium" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="597" phylum="Tracheophyta" rank="genus">
<emphasis id="20F482879C5C9B0AC491FEBACAD908E3" italics="true" pageId="null" pageNumber="597">Epipogium</emphasis>
</taxonomicName>
ist unter unsern Gattungen mit 
<taxonomicName id="575CB1808B24714C7C9E8301C2BA9E73" class="Liliopsida" family="Orchidaceae" genus="Neottia" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="597" phylum="Tracheophyta" rank="genus">
<emphasis id="7B369B1661A6E2018611DAB9CBB77B57" italics="true" pageId="null" pageNumber="597">Neottia</emphasis>
</taxonomicName>
und 
<taxonomicName id="2516126A50C376825C0E83D4F6A5F108" class="Liliopsida" family="Orchidaceae" genus="Listera" higherTaxonomySource="GBIF" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="597" phylum="Tracheophyta" rank="genus">
<emphasis id="ECCC8247727169553B2C68C191DCD454" italics="true" pageId="null" pageNumber="597">Listera</emphasis>
</taxonomicName>
am 
<normalizedToken id="8F71A098F70C16B94D5AFE9B716B1CF9" originalValue="nächsten" pageId="null" pageNumber="597">naechsten</normalizedToken>
verwandt (Vermeulen 1965).
</paragraph>
</subSubSection>
