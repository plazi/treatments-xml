vs. 
<quantity id="1614328FFFAEFF9BFBB0FCC46349D429" box="[1043,1135,833,857]" metricMagnitude="-4" metricUnit="m" metricValue="3.4" pageId="4" pageNumber="4" unit="mm" value="0.34">0.34 mm</quantity>
in 
<taxonomicName id="16ECE4E9FFAEFF9BFB2FFCC763C4D429" authorityName="ERNST &amp; KONIGSHOF" authorityYear="2010" box="[1164,1250,834,857]" class="Stenolaemata" family="Fistuliporidae" genus="Fistuliphragma" kingdom="Animalia" order="Cystoporida" pageId="4" pageNumber="4" phylum="Bryozoa" rank="species" species="parva">
