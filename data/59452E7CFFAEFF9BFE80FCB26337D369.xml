is similar to 
<taxonomicName id="16ECE4E9FFAEFF9BFA2AFD07639CD5C9" authority="ERNST &amp; KONIGSHOF, 2010" authorityName="ERNST &amp; KONIGSHOF" authorityYear="2010" class="Stenolaemata" family="Fistuliporidae" genus="Fistuliphragma" kingdom="Animalia" order="Cystoporida" pageId="4" pageNumber="4" phylum="Bryozoa" rank="species" species="parva">
