</subSubSection>
</title>
<subSubSection id="1390760A430D1733F7748C840D505C77" pageId="null" pageNumber="578" type="description">
<paragraph id="C736E8745B34063CF1497690F0DAEB19" pageId="null" pageNumber="578">
<emphasis id="6A9EF11079C44E75880C9EDA481516C8" italics="true" pageId="null" pageNumber="578">Pflanze 1geschlechtig. Unterirdischer Stengel knollig verdickt. Stengel windend.</emphasis>
<normalizedToken id="67D037EDCA99769EEF6D2FDBD5F89F71" originalValue="Blätter" pageId="null" pageNumber="578">Blaetter</normalizedToken>
<normalizedToken id="901F90EB83DFE609382C3CFB0A6A9634" originalValue="wechselständig" pageId="null" pageNumber="578">wechselstaendig</normalizedToken>
, 
<emphasis id="FCA67F0283DFE3827CC26725BC2D46A6" italics="true" pageId="null" pageNumber="578">
<normalizedToken id="D96D262A23DDC73E600319A07867507E" originalValue="herzförmig" pageId="null" pageNumber="578">herzfoermig</normalizedToken>
</emphasis>
, ganzrandig oder wenig tief 3teilig. 
<emphasis id="F1AC32EE557820A970CFF69D1AED8FB9" italics="true" pageId="null" pageNumber="578">
♂ 
<normalizedToken id="76D641209550FD579D0DF0DBEBA6618D" originalValue="Blüten" pageId="null" pageNumber="578">Blueten</normalizedToken>
in 
<normalizedToken id="4752554A1AEE32801D8FFE32EE998CBE" originalValue="vielblütigen" pageId="null" pageNumber="578">vielbluetigen</normalizedToken>
, 
<normalizedToken id="ED0E0EB6F31786BC2B90450A6D909420" originalValue="blattachselständigen" pageId="null" pageNumber="578">blattachselstaendigen</normalizedToken>
Rispen, mit 6 fertilen, freien 
<normalizedToken id="A75752395F15DDF25FE924F40357825E" originalValue="Staubblättern" pageId="null" pageNumber="578">Staubblaettern</normalizedToken>
.
</emphasis>
♀ 
<emphasis id="169B5023E8B015ADD34780F199FD4E55" italics="true" pageId="null" pageNumber="578">
<normalizedToken id="8C0AF1EA17BF1442F5D54025DEB7CF96" originalValue="Blüten" pageId="null" pageNumber="578">Blueten</normalizedToken>
einzeln oder in 
<normalizedToken id="9231EE859BA1A9839C490FF5A725DAE4" originalValue="wenigblütigen" pageId="null" pageNumber="578">wenigbluetigen</normalizedToken>
, 
<normalizedToken id="FF04FE87080D43E6EF3810E1A53586BA" originalValue="blattachselständigen" pageId="null" pageNumber="578">blattachselstaendigen</normalizedToken>
Trauben. Frucht eine kugelige, fleischige Beere.
</emphasis>
</paragraph>
<paragraph id="C301EB65F9EF2964C11A3D7D8FE6C82C" pageId="null" pageNumber="578">
Die Gattung 
<taxonomicName id="B44D7F899657D7664E750974988890BE" class="Liliopsida" family="Dioscoreaceae" genus="Tamus" higherTaxonomySource="GBIF" kingdom="Plantae" order="Dioscoreales" pageId="null" pageNumber="578" phylum="Tracheophyta" rank="genus">
<emphasis id="C802AF13DAAC698E92FCEC729D6255F7" italics="true" pageId="null" pageNumber="578">Tamus</emphasis>
</taxonomicName>
<normalizedToken id="8705AB68229F6B3F2DB44B4F0BC373C6" originalValue="umfaßt" pageId="null" pageNumber="578">umfasst</normalizedToken>
<emphasis id="0F2AF5F39D9A4415456477EECCEB2B10" italics="true" pageId="null" pageNumber="578">4 Arten, die im Mittelmeergebiet verbreitet</emphasis>
sind, in 
<normalizedToken id="9C6FF0BA2AA083CBFDD64EA0EA5415F1" originalValue="nordwärts" pageId="null" pageNumber="578">nordwaerts</normalizedToken>
angrenzenden Gebieten nur 
<taxonomicName id="6998DDA736E1AE31D5B64E01CF48CB8D" authority="L." authorityName="L." class="Liliopsida" family="Commelinaceae" genus="Commelina" kingdom="Plantae" order="Commelinales" pageId="null" pageNumber="578" phylum="Tracheophyta" rank="species" species="communis">
<emphasis id="B27BB7ABC86DCC2FB423E4952ECC1572" italics="true" pageId="null" pageNumber="578">T. communis</emphasis>
<authorityName id="C5B9D31AD3D7F309842515A89E4988EF" pageId="null" pageNumber="578">L.</authorityName>
</taxonomicName>
</paragraph>
