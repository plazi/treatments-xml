<subSubSection id="2039308D0C8014EF67D316B2E33AB015" pageId="0" pageNumber="139" type="notes">
<paragraph id="7C7EFD437918899A7FBEF2384D0E5691" pageId="0" pageNumber="139">Notes.</paragraph>
<paragraph id="3C5A64908E26F530D3DB356DDCECCF32" pageId="0" pageNumber="139">
<taxonomicName id="30B328DBC568679BD7426402F5FB8517" authority="B.Huang &amp; Y.Nie, 2020" authorityName="B. Huang &amp; Y. Nie" authorityYear="2022" class="Entomophthoromycetes" family="Ancylistaceae" genus="Capillidium" higherTaxonomySource="GBIF" kingdom="Fungi" lsidName="Capillidium macrocapilliconidium" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="macrocapilliconidium">
<emphasis id="F36DDD54BD2718023CDDB3BC739FE747" italics="true" pageId="0" pageNumber="139">Capillidium macrocapilliconidium</emphasis>
</taxonomicName>
is characterised by having larger capilliconidia compared to other 
<taxonomicName id="588FC5EEF85E5F772B890EB6AE79B9D2" authority="B.Huang &amp; Y.Nie, 2020" authorityName="B.Huang &amp; Y.Nie" authorityYear="2020" class="Entomophthoromycetes" family="Ancylistaceae" genus="Capillidium" higherTaxonomySource="GBIF" kingdom="Fungi" lsidName="Capillidium" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="genus">
<emphasis id="071883F568C70350C632159B0266E9EF" italics="true" pageId="0" pageNumber="139">Capillidium</emphasis>
</taxonomicName>
species. It produces yellowish and wrinkled zygospores like 
<taxonomicName id="D4ED6F074FF69B2665E4A30DD6A411C7" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. rhysosporum" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="rhysosporum">
<emphasis id="33353CB100564E171556450A435EC5C4" italics="true" pageId="0" pageNumber="139">Ca. rhysosporum</emphasis>
</taxonomicName>
(
<bibRefCitation id="14DAB00C49CCB9545CABD0F2F1B71F7A" DOI="https://doi.org/10.1002/j.1537-2197.1954.tb14380.x" author="Drechsler, C" journalOrPublisher="American Journal of Botany" pageId="0" pageNumber="139" pagination="567 - 575" refId="B8" refString="Drechsler, C, 1954. Two species of Conidiobolus with minutely ridged zygospores. American Journal of Botany 41 (7): 567 - 575, DOI: https://doi.org/10.1002/j.1537-2197.1954.tb14380.x" title="Two species of Conidiobolus with minutely ridged zygospores." url="https://doi.org/10.1002/j.1537-2197.1954.tb14380.x" volume="41" year="1954">Drechsler 1954</bibRefCitation>
). However, 
<taxonomicName id="E426ACE4747BEE99452AF4B42B2D2C82" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. macrocapilliconidium" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="macrocapilliconidium">
<emphasis id="394FB2BAB572F559D6CD3286AF08A1EA" italics="true" pageId="0" pageNumber="139">Ca. macrocapilliconidium</emphasis>
</taxonomicName>
has larger capilliconidia than 
<taxonomicName id="63CD415AAC8AD53551B94782CAA41E90" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. rhysosporum" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="rhysosporum">
<emphasis id="C0E7E89F57D41670BD11D1DC7CFEEFF8" italics="true" pageId="0" pageNumber="139">Ca. rhysosporum</emphasis>
</taxonomicName>
(25-37 
<normalizedToken id="A3103B0D3B284B25D2333F4713273CC8" originalValue="×">x</normalizedToken>
14-17 
<normalizedToken id="F40B8833A8A6F4398E7A764430AFD16A" originalValue="μm">μm</normalizedToken>
in 
<taxonomicName id="4596F2CEE401EAE2AEAEA712E221C2FE" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. macrocapilliconidium" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="macrocapilliconidium">
<emphasis id="9E53B8712B94F07904F5D1AF7CD6368F" italics="true" pageId="0" pageNumber="139">Ca. macrocapilliconidium</emphasis>
</taxonomicName>
vs. 12-32 
<normalizedToken id="8B22762EC6F0F7306A3A172602157970" originalValue="×">x</normalizedToken>
6.5-16 
<normalizedToken id="50C4F59C12F9CB64A6B5488C11602348" originalValue="μm">μm</normalizedToken>
in 
<taxonomicName id="8CCD178A45E7A4AA1CDF4DEF877FD332" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. rhysosporum" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="rhysosporum">
<emphasis id="60DB8DDE3E0CD6E712AECDDB06E02CC5" italics="true" pageId="0" pageNumber="139">Ca. rhysosporum</emphasis>
</taxonomicName>
). 
<taxonomicName id="D02D734C4E8D8D5121C42F2C31315667" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. macrocapilliconidium" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="macrocapilliconidium">
<emphasis id="EC22FB514177E765433432D99992E2A1" italics="true" pageId="0" pageNumber="139">Ca. macrocapilliconidium</emphasis>
</taxonomicName>
is phylogenetically distant from 
<taxonomicName id="96D236575ED2447201879C05FBA1386D" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. rhysosporum" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="rhysosporum">
<emphasis id="30D849BD41F4E7B93E14C02D9CA76296" italics="true" pageId="0" pageNumber="139">Ca. rhysosporum</emphasis>
</taxonomicName>
(Fig. 
<figureCitation id="266AB56503891898984387D15D4397FE" captionStart="Figure 1" captionStartId="F1" captionText="Figure 1. The phylogenetic tree of Capillidium constructed using Maximum Likelihood analyses on nucLSU, EFL and mtSSU sequences. Conidiobolus s. l. species were used as outgroups. New taxa are indicated by bold text. Maximum Parsimony bootstrap values (≥ 50 %) / Maximum Likelihood bootstrap values (≥ 50 %) / Bayesian posterior probabilities (≥ 0.50) of clades are provided alongside the branches. The scale bar at the lower left indicates substitutions per site." figureDoi="10.3897/mycokeys.89.79537.figure1" httpUri="https://binary.pensoft.net/fig/678749" pageId="0" pageNumber="139">1</figureCitation>
) and most closely related to 
<taxonomicName id="DA9C6EDA73DA500A03F5778863335220" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. pumilum" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="pumilum">
<emphasis id="162C4979186412962A15068F478EC560" italics="true" pageId="0" pageNumber="139">Ca. pumilum</emphasis>
</taxonomicName>
. It is distinguished from 
<taxonomicName id="28F9F569591DD8F8AD0B33868CBED6C9" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. pumilum" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="pumilum">
<emphasis id="D0F067160303924F8F30616131798A61" italics="true" pageId="0" pageNumber="139">Ca. pumilum</emphasis>
</taxonomicName>
by larger primary conidia (25-34 
<normalizedToken id="609C5B80D139B6755DBA430AD38D8F47" originalValue="×">x</normalizedToken>
20-28 
<normalizedToken id="52A0EBFD740006DBEAA3C28B51F5AC5F" originalValue="μm">μm</normalizedToken>
in 
<taxonomicName id="E2EE69E0F1794E057B5C6917A2CC7BD0" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. macrocapilliconidium" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="macrocapilliconidium">
<emphasis id="97098133FABFEE5277819C3D61F91B52" italics="true" pageId="0" pageNumber="139">Ca. macrocapilliconidium</emphasis>
</taxonomicName>
vs. 9-18 
<normalizedToken id="42E384AC80B73C50C99F060C472FB029" originalValue="×">x</normalizedToken>
7.3-14 
<normalizedToken id="4F4B52D60B9EEC5DA59684957CEE0440" originalValue="μm">μm</normalizedToken>
in 
<taxonomicName id="234FA386BBDCEAD6E96BA9E0E8EA79E1" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. pumilum" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="pumilum">
<emphasis id="668EF47DE74034923AACBDB8B72A3D91" italics="true" pageId="0" pageNumber="139">Ca. pumilum</emphasis>
</taxonomicName>
) and capilliconidia (25-37 
<normalizedToken id="36A7011B8FADE2A6453EB19C8AD7A81B" originalValue="×">x</normalizedToken>
14-17 
<normalizedToken id="00DCEF491EBE95D7C8358641706093E9" originalValue="μm">μm</normalizedToken>
in 
<taxonomicName id="3BAFC362A9811AB3EE320A37E00B1597" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. macrocapilliconidium" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="macrocapilliconidium">
<emphasis id="ADAE08553C023E57706019EA4705F7AE" italics="true" pageId="0" pageNumber="139">Ca. macrocapilliconidium</emphasis>
</taxonomicName>
vs. 8.8-12 
<normalizedToken id="1C06D67FA4238B442D2407FDE624FE2E" originalValue="×">x</normalizedToken>
5-7.5 
<normalizedToken id="26DDB2D23A3BAC946A50B0C5AD49230A" originalValue="μm">μm</normalizedToken>
in 
<taxonomicName id="839358820D743EE64D78000E6C20316E" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. pumilum" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="pumilum">
<emphasis id="6DA93BDDC19CAD5D106926103AC90628" italics="true" pageId="0" pageNumber="139">Ca. pumilum</emphasis>
</taxonomicName>
) (
<bibRefCitation id="BEBADFFC27FF7DE803C3693D03593527" DOI="https://doi.org/10.1002/j.1537-2197.1955.tb11144.x" author="Drechsler, C" journalOrPublisher="American Journal of Botany" pageId="0" pageNumber="139" pagination="437 - 443" refId="B10" refString="Drechsler, C, 1955b. Three new species of Conidiobolus isolated from decaying plant detritus. American Journal of Botany 42 (5): 437 - 443, DOI: https://doi.org/10.1002/j.1537-2197.1955.tb11144.x" title="Three new species of Conidiobolus isolated from decaying plant detritus." url="https://doi.org/10.1002/j.1537-2197.1955.tb11144.x" volume="42" year="1955 b">Drechsler 1955b</bibRefCitation>
).
