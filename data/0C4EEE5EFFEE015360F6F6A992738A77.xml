<subSubSection id="CCFD0CC3FFEF015363A5F0BE92738A77" pageId="13" pageNumber="36" type="discussion">
<paragraph id="84585F48FFEF015363A5F0BE92738A77" blockId="13.[151,760,190,341]" pageId="13" pageNumber="36">
<emphasis id="B693835AFFEF015363A5F0BE92688BF7" bold="true" box="[151,281,190,213]" pageId="13" pageNumber="36">Comments.</emphasis>
Due to the new synonymy of 
<taxonomicName id="43E724CBFFEF0153616EF0BE91B08BF7" baseAuthorityName="KIMOTO" baseAuthorityYear="2003" box="[604,705,190,213]" class="Insecta" family="Chrysomelidae" genus="Acroxena" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFEF0153616EF0BE91B08BF7" box="[604,705,190,213]" italics="true" pageId="13" pageNumber="36">Acroxena</emphasis>
</taxonomicName>
with 
<taxonomicName id="43E724CBFFEF015363A5F0DE927F8BD7" authorityName="Thunberg" authorityYear="1814" box="[151,270,222,245]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFEF015363A5F0DE927F8BD7" box="[151,270,222,245]" italics="true" pageId="13" pageNumber="36">Taumacera</emphasis>
</taxonomicName>
, 
<taxonomicName id="43E724CBFFEF01536229F0DE912D8BD7" authority="Jacoby, 1896" authorityName="Jacoby" authorityYear="1896" box="[283,604,222,245]" class="Insecta" family="Chrysomelidae" genus="Acroxena" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="indica">
<emphasis id="B693835AFFEF01536229F0DE92BB8BD7" box="[283,458,222,245]" italics="true" pageId="13" pageNumber="36">Acroxena indica</emphasis>
<bibRefCitation id="E07622B9FFEF015362E3F0DE912D8BD7" author="JACOBY M." box="[465,604,222,245]" firstAuthor="Jacoby" journalOrPublisher="Annali del Museo Civico di Storia Naturale di Genova" pageId="13" pageNumber="36" pagination="377 - 501" part="36" refId="ref31521" refString="JACOBY M. 1896 a: Descriptions of the new genera and species of phytophagous Coleoptera obtained by Dr. Modigliani in Sumatra. Annali del Museo Civico di Storia Naturale di Genova 36: 377 - 501." title="Descriptions of the new genera and species of phytophagous Coleoptera obtained by Dr. Modigliani in Sumatra" type="journal article" year="1896">Jacoby, 1896</bibRefCitation>
</taxonomicName>
becomes a junior secondary homonym of 
<taxonomicName id="43E724CBFFEF015362F9F0FE91BA8A37" authority="(Jacoby, 1889)" baseAuthorityName="Jacoby" baseAuthorityYear="1889" box="[459,715,254,277]" class="Insecta" family="Chrysomelidae" genus="Acroxena" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="indica">
<emphasis id="B693835AFFEF015362F9F0FE91598A37" box="[459,552,254,277]" italics="true" pageId="13" pageNumber="36">T. indica</emphasis>
(
<bibRefCitation id="E07622B9FFEF01536107F0FE91B28A37" author="JACOBY M." box="[565,707,254,277]" firstAuthor="Jacoby" journalOrPublisher="Annali del Museo Civico di Storia Naturale di Genova" pageId="13" pageNumber="36" pagination="147 - 237" part="27" refId="ref31279" refString="JACOBY M. 1889: Viaggio di Leonardo Fea in Birmania e regioni vicine. - List of the phytophagous Coleoptera obtained by Signor L. Fea at Burmah and Tenasserim, with descriptions of the new species. Annali del Museo Civico di Storia Naturale di Genova 27: 147 - 237." title="Viaggio di Leonardo Fea in Birmania e regioni vicine. - List of the phytophagous Coleoptera obtained by Signor L. Fea at Burmah and Tenasserim, with descriptions of the new species" type="journal article" year="1889">Jacoby, 1889</bibRefCitation>
)
</taxonomicName>
and is here replaced with the new substitute name 
<taxonomicName id="43E724CBFFEF015361B4F11E91868A17" authorityName="Bezděk" authorityYear="2019" box="[646,759,286,309]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="indicola" status="nom. nov.">
<emphasis id="B693835AFFEF015361B4F11E91868A17" box="[646,759,286,309]" italics="true" pageId="13" pageNumber="36">T. indicola</emphasis>
</taxonomicName>
<taxonomicNameLabel id="ADA03E21FFEF015363A5F13E92738A77" box="[151,258,318,341]" pageId="13" pageNumber="36">nom. nov.</taxonomicNameLabel>
</paragraph>
