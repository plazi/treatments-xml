<taxonomicName authorityName="Tullberg" authorityYear="1871" box="[642,821,583,609]" class="Collembola" family="Neanuridae" genus="Pseudachorutes" kingdom="Animalia" order="Poduromorpha" pageId="6" pageNumber="449" phylum="Arthropoda" rank="genus">
