<bibRefCitation author="Shayanmehr, M. &amp; Yoosefi Lafooraki, E. &amp; Kahrarian, M." box="[1145,1425,583,609]" pageId="6" pageNumber="449" pagination="403 - 445" refId="ref5598" refString="Shayanmehr, M., Yoosefi Lafooraki, E. &amp; Kahrarian, M. (2020) A new updated checklist of Iranian Collembola (Arthropoda: Hexapoda). Journal of Entomological Society of Iran, 39 (4), 403 - 445. https: // doi. org / 10.22117 / jesi. 2019.124366.1285" type="journal article" year="2020">
