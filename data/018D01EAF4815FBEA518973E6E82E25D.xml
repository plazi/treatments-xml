<bibRefCitation id="7AB2599B85035C902E094B8709C33F7E" author="Gjonov, I." journalOrPublisher="Annals of the Upper Silesian Museum in Bytom. Entomology" pageId="0" pageNumber="83231" refId="B7727581" refString="Gjonov, I., 2022. new_fulgoromorpha_records_bulgaria_2022. In: Biodiversity Data Journal. Occurrence dataset." title="new _ fulgoromorpha _ records _ bulgaria _ 2022" volumeTitle="Biodiversity Data Journal. Occurrence dataset." year="2022">Gjonov (2022)</bibRefCitation>
