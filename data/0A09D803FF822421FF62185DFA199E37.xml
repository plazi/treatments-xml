<taxonomicName id="45A01296FF822421FF18185DFDF89CE6" authority="Handschin, 1925" authorityName="Handschin" authorityYear="1925" box="[237,630,367,394]" class="Collembola" family="Entomobryidae" genus="Acanthocyrtus" kingdom="Animalia" order="Entomobryomorpha" pageId="2" pageNumber="343" phylum="Arthropoda" rank="genus">
<emphasis id="B0D4B507FF822421FF18185DFE139CE5" bold="true" box="[237,413,367,394]" italics="true" pageId="2" pageNumber="343">Acanthocyrtus</emphasis>
<bibRefCitation id="E63114E4FF822421FE50185DFDF89CE6" author="Handschin, E." box="[421,630,367,393]" pageId="2" pageNumber="343" pagination="225 - 270" refId="ref9487" refString="Handschin, E. (1925) Beitrage zur Collembolenfauna der Sundainseln. Treubia, 6, 225 - 270. https: // doi. org / 10.1002 / mmnd. 192519250305" type="journal article" year="1925">Handschin, 1925</bibRefCitation>
