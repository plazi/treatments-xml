<taxonomicName id="03944D7DFF2D6A92F70792B517C2BE3F" authorityName="Kuhl" authorityYear="1817" box="[2299,2498,1260,1293]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="214" pageNumber="975" phylum="Chordata" rank="species" species="daubentonii">M. daubentonii</taxonomicName>
and 
<taxonomicName id="03944D7DFF2D6A92F5F592B516A4BE07" authorityName="Ognev" authorityYear="1927" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="214" pageNumber="976" phylum="Chordata" rank="species" species="longicaudatus">M. longicaudatus</taxonomicName>
. Monotypic.
</paragraph>
</subSubSection>
