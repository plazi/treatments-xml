<subSubSection id="8C8E6575FF2D6A92F7EA922F1750BE07" pageId="214" pageNumber="976" type="discussion">
<paragraph id="C42B36FEFF2D6A92F7EA922F1750BE07" blockId="214.[2069,2664,910,1333]" pageId="214" pageNumber="976">
Subgenus 
<taxonomicName id="03944D7DFF2D6A92F739922F171ABFA5" authority="Kaup, 1829" box="[2245,2330,1142,1175]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="214" pageNumber="976" phylum="Chordata" rank="genus">Myotis</taxonomicName>
; 
<taxonomicName id="03944D7DFF2D6A92F6B4922F17E0BFA5" authorityName="Kuhl" authorityYear="1817" box="[2376,2528,1142,1175]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="214" pageNumber="976" phylum="Chordata" rank="species" species="daubentonii">daubentonii</taxonomicName>
