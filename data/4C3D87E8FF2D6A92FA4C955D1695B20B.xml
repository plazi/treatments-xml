<quantity id="036C9B1BFF2D6A92F73C91ED1729BCE7" box="[2240,2345,1972,2005]" metricMagnitude="3" metricUnit="m" metricValue="2.1" pageId="214" pageNumber="976" unit="m" value="2100.0">2100 m</quantity>
(holotype) but apparently recorded up to 
<quantity id="036C9B1BFF2D6A92F92191841946BCCC" box="[1757,1862,2013,2046]" metricMagnitude="3" metricUnit="m" metricValue="2.6" pageId="214" pageNumber="976" unit="m" value="2600.0">2600 m</quantity>
.
</paragraph>
</subSubSection>
