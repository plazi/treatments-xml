<paragraph id="8B94921EB745FFFBFAC1F654F840FC56" blockId="2.[1383,2590,2100,3276]" box="[1386,1931,2543,2568]" pageId="2" pageNumber="109">
<taxonomicName id="4C2BE99DB745FFFBFAC1F654F97EFC56" authority="Roberts, 1938" authorityName="Roberts" authorityYear="1938" box="[1386,1717,2543,2568]" class="Mammalia" family="Leporidae" genus="Pronolagus" kingdom="Animalia" order="Lagomorpha" pageId="2" pageNumber="109" phylum="Chordata" rank="subSpecies" species="randensis" subSpecies="whitei">P.r. whitei Roberts, 1938</taxonomicName>
