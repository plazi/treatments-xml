(
<taxonomicName id="4C2BE99DB745FFFBFF63F2EAFE03FB34" baseAuthorityName="Thomas" baseAuthorityYear="1903" box="[200,456,3409,3434]" class="Mammalia" family="Leporidae" genus="Bunolagus" kingdom="Animalia" order="Lagomorpha" pageId="2" pageNumber="109" phylum="Chordata" rank="species" species="monticularis">Bunolagus monticularis</taxonomicName>
); 8. Pygmy Rabbit (
