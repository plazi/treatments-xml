</paragraph>
<paragraph id="8B94921EB745FFFBFAC1F605F62BFF81" blockId="2.[1383,2590,2100,3276]" box="[1386,2528,2494,2527]" pageId="2" pageNumber="109">
<taxonomicName id="4C2BE99DB745FFFBFAC1F605F92AFF81" authority="Thomas, 1929" authorityName="Thomas" authorityYear="1929" box="[1386,1761,2494,2527]" class="Mammalia" family="Leporidae" genus="Pronolagus" kingdom="Animalia" order="Lagomorpha" pageId="2" pageNumber="109" phylum="Chordata" rank="subSpecies" species="randensis" subSpecies="caucinus">P.r.caucinusThomas,1929—C&amp;NWNamibia,andperhapsextremeSWAngola.</taxonomicName>
