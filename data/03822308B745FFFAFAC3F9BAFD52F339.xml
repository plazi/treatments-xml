); 9. Sumatran Striped Rabbit (
<taxonomicName id="4C2BE99DB745FFFBFB41F2EAFEF2FBCC" authority="Jose Brush Rabbit" authorityName="Jose Brush Rabbit" class="Mammalia" family="Leporidae" genus="Nesolagus" kingdom="Animalia" order="Lagomorpha" pageId="2" pageNumber="109" phylum="Chordata" rank="genus">Nesolagus Jose Brush Rabbit</taxonomicName>
(
<taxonomicName id="4C2BE99DB745FFFBFEE2F2C2FDFEFBCC" authorityName="Nelson" authorityYear="1907" box="[329,565,3449,3474]" class="Mammalia" family="Leporidae" genus="Sylvilagus" kingdom="Animalia" order="Lagomorpha" pageId="2" pageNumber="109" phylum="Chordata" rank="species" species="mansuetus">Sylvilagus mansuetus</taxonomicName>
); 13. Desert Cottontail (
<taxonomicName id="4C2BE99DB745FFFBFC97F2C2FBD1FBCC" baseAuthorityName="Baird" baseAuthorityYear="1858" box="[828,1050,3449,3474]" class="Mammalia" family="Leporidae" genus="Sylvilagus" kingdom="Animalia" order="Lagomorpha" pageId="2" pageNumber="109" phylum="Chordata" rank="species" species="audubonii">Sylvilagus audubonii</taxonomicName>
