<caption id="DF54C296B745FFFBFAC2F6F2F840FC56" ID-DOI="http://doi.org/10.5281/zenodo.6625547" ID-Zenodo-Dep="6625547" httpUri="https://zenodo.org/record/6625547/files/figure.png" inLine="true" pageId="2" pageNumber="109" targetBox="[1381,1971,1677,2090]" targetPageId="2">
<paragraph id="8B94921EB745FFFBFAC2F6F2F932FF34" blockId="2.[1383,2590,2100,3276]" box="[1385,1785,2377,2410]" pageId="2" pageNumber="109">
<emphasis id="B95F4E0CB745FFFBFAC2F6F2F932FF34" bold="true" box="[1385,1785,2377,2410]" pageId="2" pageNumber="109">Subspecies and Distribution.</emphasis>
