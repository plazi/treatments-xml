<location id="2B0000DFFFC1FF96057CFE6111528DC4" LSID="urn:lsid:plazi:treatment:A676E712FFC4FF9606C1FCA4166F8DC4:2B0000DFFFC1FF96057CFE6111528DC4" box="[611,879,406,431]" country="Thailand" name="Mae Hongson Province" pageId="28" pageNumber="1565">Mae Hongson Province</location>
