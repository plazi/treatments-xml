</emphasis>
. 
<taxonomicName id="4C6D4D5EED78381CFE07F925FF0CF8E9" authority="(Ooishi, 1972)" authorityName="Kim &amp; Boxshall" authorityYear="2020" baseAuthorityName="Ooishi" baseAuthorityYear="1972" class="Maxillopoda" family="Notodelphyidae" genus="Ademoixys" kingdom="Animalia" order="Cyclopoida" pageId="553" pageNumber="554" phylum="Arthropoda" rank="species" species="fusiforma" status="comb. nov.">
<emphasis id="B919EACFED78381CFE07F925FD6FF8C7" box="[450,682,1771,1798]" italics="true" pageId="553" pageNumber="554">Ademoixysfusiforma</emphasis>
(
<bibRefCitation id="EFFC4B2CED78381CFD72F925FF04F8E9" author="Ooishi, S." journalOrPublisher="Publications of the Seto Marine Biological Laboratory" pageId="553" pageNumber="554" pagination="303 - 325" part="19" refId="ref330320" refString="Ooishi, S. (1972) Notodelphyid copepods associated with compound ascidians in Akkeshi Bay, Japan. Publications of the Seto Marine Biological Laboratory, 19 (5), 303 - 325. https: // doi. org / 10.5134 / 175727" title="Notodelphyid copepods associated with compound ascidians in Akkeshi Bay, Japan" type="journal article" year="1972">Ooishi, 1972</bibRefCitation>
)
</taxonomicName>
<taxonomicNameLabel id="A22A57B4ED78381CFF14F8C0FE96F8E9" box="[209,339,1806,1832]" pageId="553" pageNumber="554" rank="species">
