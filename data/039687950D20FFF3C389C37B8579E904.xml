<subSubSection id="C32565080D20FFF0C389C35383AAE293" pageId="1" pageNumber="208" type="diagnosis">
<paragraph id="8B8036830D20FFF0C389C35383AAE293" blockId="1.[136,1453,892,1022]" pageId="1" pageNumber="208">
<taxonomicName id="4C3F4D000D20FFF0C389C3538046E2B4" box="[136,302,892,913]" class="Magnoliopsida" family="Vochysiaceae" genus="Vochysia" kingdom="Plantae" order="Myrtales" pageId="1" pageNumber="208" phylum="Tracheophyta" rank="species" species="sobralii">
<emphasis id="B94BEA910D20FFF0C389C3538046E2B4" box="[136,302,892,913]" italics="true" pageId="1" pageNumber="208">Vochysia sobralii</emphasis>
</taxonomicName>
is characterized by presenting opposite leaves or in 3-merous whorls, petioles longer than 
<quantity id="4CC79B660D20FFF0C797C35385A0E2B4" box="[1174,1224,892,913]" metricMagnitude="-2" metricUnit="m" metricValue="1.0" pageId="1" pageNumber="208" unit="cm" value="1.0">1 cm</quantity>
, leaf blades longer than 
<quantity id="4CC79B660D20FFF0C3BCC38F8193E290" box="[189,251,928,949]" metricMagnitude="-1" metricUnit="m" metricValue="1.3" pageId="1" pageNumber="208" unit="cm" value="13.0">13 cm</quantity>
, elliptic, with cuspidate apex and cuneate base.
</paragraph>
</subSubSection>
