<subSubSection id="189CBD9BBFA941D6B52AE617FDA7345E" pageId="null" pageNumber="278" type="description">
<paragraph id="889F1B9F6F4EF849A06023C64C8EC23F" pageId="null" pageNumber="278">
<emphasis id="29806C41E9829A19D41C92256BD6D15C" italics="true" pageId="null" pageNumber="278">Ausdauernd;</emphasis>
10-30 cm hoch. 
<emphasis id="2F1630C8694D248652CE7F9EB674C514" italics="true" pageId="null" pageNumber="278">Stengel verzweigt, am Grunde niederliegend und verholzt</emphasis>
, sehr kurz behaart (Haare 0,1-0,3 mm lang). 
<emphasis id="E710AE259353029F4B50DF390EFD6CDB" italics="true" pageId="null" pageNumber="278">
<normalizedToken id="CC24E3DA200C4315B4700753D7FC87F2" originalValue="Blätter" pageId="null" pageNumber="278">Blaetter</normalizedToken>
am Stengel 
<normalizedToken id="37B02D53E0018E54AC0E5CFB47BDC632" originalValue="gegenständig" pageId="null" pageNumber="278">gegenstaendig</normalizedToken>
, meist am Ende der 
<normalizedToken id="01EF6BA19F3BB29A82AB85EA766084CE" originalValue="letztjährigen" pageId="null" pageNumber="278">letztjaehrigen</normalizedToken>
Triebe 
<normalizedToken id="7C3CAFAF1A5CE00AEB613978C64FCE1D" originalValue="büschelig" pageId="null" pageNumber="278">bueschelig</normalizedToken>
<normalizedToken id="73F77F624D2F3AD8FF98CEE8707B33AE" originalValue="gehäuft" pageId="null" pageNumber="278">gehaeuft</normalizedToken>
</emphasis>
, grasartig, 
<emphasis id="580CFA36DF933E13A50235EC0EEAF249" italics="true" pageId="null" pageNumber="278">3kantig</emphasis>
, gelegentlich mit sehr kurzen 
<normalizedToken id="2E34543F5B0685B06BA31C54F97D6FAC" originalValue="Zähnen" pageId="null" pageNumber="278">Zaehnen</normalizedToken>
, zerstreut und sehr kurz behaart. 
<normalizedToken id="C06A58B5204BFAD928F2A22D2A038A0D" originalValue="Blütenähren" pageId="null" pageNumber="278">Bluetenaehren</normalizedToken>
<normalizedToken id="4E2BE76CC9E1099A6C6223D425F061BD" originalValue="eiförmig" pageId="null" pageNumber="278">eifoermig</normalizedToken>
, 1-1,5 cm lang, auf 4-8 cm langen Stielen. 
<emphasis id="1880AAD1C5417B7E68CE4FBE1D5B3D7A" italics="true" pageId="null" pageNumber="278">
Untere 
<normalizedToken id="52ED965A7230CEAA15A3F3F30812EA3D" originalValue="Tragblätter" pageId="null" pageNumber="278">Tragblaetter</normalizedToken>
mit kurzer Granne
</emphasis>
und 
<normalizedToken id="5EB417810480658419CCAD870AE67FA5" originalValue="länger" pageId="null" pageNumber="278">laenger</normalizedToken>
als die 
<normalizedToken id="B91645B8BA19B71189A3EA88D886C23A" originalValue="Blüten" pageId="null" pageNumber="278">Blueten</normalizedToken>
, wenig behaart. 
<emphasis id="B07EC7E7B42EBC6FA07B7D2D12827537" italics="true" pageId="null" pageNumber="278">
Alle 
<normalizedToken id="C7B89864E7E6342E65885542E855CD8A" originalValue="Kelchblätter" pageId="null" pageNumber="278">Kelchblaetter</normalizedToken>
bis fast zum Grunde frei.
</emphasis>
Krone etwa 5 mm lang, kahl, mit 
<normalizedToken id="A9AE4A8827EAF8739B2ED3125386E043" originalValue="weißlichen" pageId="null" pageNumber="278">weisslichen</normalizedToken>
Kronzipfeln. 
<normalizedToken id="B33DF7353D9591146F038D595947569F" originalValue="Staubblätter" pageId="null" pageNumber="278">Staubblaetter</normalizedToken>
gelblich. Frucht 2samig. Samen 2-2,5 cm lang. - 
<normalizedToken id="64287FF765C45F24201651F4AB21EA5F" originalValue="Blüte" pageId="null" pageNumber="278">Bluete</normalizedToken>
; Sommer.
</paragraph>
<paragraph id="7B3B6AAF4A753B9F382B9F60D98C2D24" pageId="null" pageNumber="278">
<emphasis id="1D1431CFBFC02728041ED3370C8FE5FD" italics="true" pageId="null" pageNumber="278">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="283D879F1FD4B50BAE8CD041DFBAE059" italics="true" pageId="null" pageNumber="278">12:</emphasis>
Material aus botanischem Garten (Ekstrand 1918, McCullagh 1934, Fujiwara 1956, Rahn in 
<normalizedToken id="C47CB5241EF72FF2BF70ECCC90226010" originalValue="Löve" pageId="null" pageNumber="278">Loeve</normalizedToken>
1966a), aus Frankreich (Rahn in 
<normalizedToken id="4E84EF8E55CB130ACA67905524238E38" originalValue="Löve" pageId="null" pageNumber="278">Loeve</normalizedToken>
1966a).
</paragraph>
<paragraph id="FC6E394B8D425678C4B105BF961F1AEF" pageId="null" pageNumber="278">
<emphasis id="FAB326260D103A64D32EADA45478005A" italics="true" pageId="null" pageNumber="278">Standort.</emphasis>
Kollin und montan. Trockene, steinige, kalkreiche 
<normalizedToken id="4C7AA410CA7FAFF85FF1EA6D9A70CB7B" originalValue="Böden" pageId="null" pageNumber="278">Boeden</normalizedToken>
in warmen Lagen. Trockenwiesen, unbebaute 
<normalizedToken id="6D79BC755AEC3C18EE26D64E3EC70FA1" originalValue="Plätze" pageId="null" pageNumber="278">Plaetze</normalizedToken>
.
</paragraph>
<paragraph id="8EBF1C46FA6A33B7725311549627B18F" pageId="null" pageNumber="278">
<emphasis id="4B28130ECC377E01EC4DBC0EF0C787A9" italics="true" pageId="null" pageNumber="278">
Verbreitung. 
<normalizedToken id="DB52A3C3B80A9CCD9F5E01930BD664B1" originalValue="Südwesteuropäische" pageId="null" pageNumber="278">Suedwesteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Iberische Halbinsel, 
<normalizedToken id="2442341EEC7098038C6869E8887F02F8" originalValue="Südfrankreich" pageId="null" pageNumber="278">Suedfrankreich</normalizedToken>
, Apenninenhalbinsel, Wiener Becken (kaum 
<normalizedToken id="772D61BC1BAD8CEEC1138C041BBE6E01" originalValue="ursprünglich" pageId="null" pageNumber="278">urspruenglich</normalizedToken>
). - Im Gebiet: 
<normalizedToken id="7BFC8650FDE60EB0A64B9CF8B33878F6" originalValue="Elsaß" pageId="null" pageNumber="278">Elsass</normalizedToken>
(Kaliminen), 
<normalizedToken id="8B897E8980803939B7A3C7FE3CD18879" originalValue="Dép" pageId="null" pageNumber="278">Dep</normalizedToken>
. Ain, 
<normalizedToken id="B1B159A94FF85485F452316917CA76A9" originalValue="Dép" pageId="null" pageNumber="278">Dep</normalizedToken>
. Jura, Savoyen, Comerseegebiet, 
<normalizedToken id="AAACB1C516B22A0CE9EC04C07783A065" originalValue="südliche" pageId="null" pageNumber="278">suedliche</normalizedToken>
Bergamasker Alpen, ziemlich selten und meist nur verschleppt; sonst selten adventiv (z. B. bei Genf).
</paragraph>
<paragraph id="724E8F3AE064BA967010F488293C3B2E" pageId="null" pageNumber="278">
<emphasis id="672BE3DA8F35D6DF0B9C20743F74EB23" italics="true" pageId="null" pageNumber="278">Bemerkungen.</emphasis>
<normalizedToken id="96ADDCBF34AE39CC77326D071EB43103" originalValue="Über" pageId="null" pageNumber="278">Ueber</normalizedToken>
die Nomenklatur von 
<taxonomicName id="82A583EE6E0A2718FE11F5E348EEB02C" class="Magnoliopsida" family="Plantaginaceae" genus="Plantago" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="278" phylum="Tracheophyta" rank="species" species="sempervirens">
<emphasis id="93E76D1898993DA42D956A550DC07D07" italics="true" pageId="null" pageNumber="278">P. sempervirens</emphasis>
</taxonomicName>
vgl. Man sfeld (1939).
</paragraph>
</subSubSection>
