<taxonomicName id="03944D7DFF786AC7F73D977A170DBA55" authority="Brooks &amp; Bickham, 2014" authorityName="Brooks &amp; Bickham" authorityYear="2014" class="Mammalia" family="Vespertilionidae" genus="Scotophilus" kingdom="Animalia" order="Chiroptera" pageId="131" pageNumber="890" phylum="Chordata" rank="species" species="livingstonii">Scotophilus livingstonii Brooks &amp; Bickham, 2014</taxonomicName>
