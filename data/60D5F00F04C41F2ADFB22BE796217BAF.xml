<subSubSection id="CABCEC967A528F53358F284E3D366FCF" pageId="null" pageNumber="243" type="description">
<paragraph id="99D279330BE0CBA3AF076FA8B4CE079A" pageId="null" pageNumber="243">
Die Gattung 
<taxonomicName id="EF1E619C8E8AB72A75AC903EA2ACC653" class="Liliopsida" family="Poaceae" genus="Echinochloa" kingdom="Plantae" order="Poales" pageId="null" pageNumber="243" phylum="Tracheophyta" rank="genus">
<emphasis id="8E462AFCA657F0898F97B1B9A4125AB8" italics="true" pageId="null" pageNumber="243">Echinochloa</emphasis>
</taxonomicName>
unterscheidet sich von der Gattung 
<taxonomicName id="2217AD7EE02B87F19B6033AC59DB6684" class="Liliopsida" family="Poaceae" genus="Panicum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="243" phylum="Tracheophyta" rank="genus">
<emphasis id="C59F471C05F221EECC836A01BCCC0614" italics="true" pageId="null" pageNumber="243">Panicum</emphasis>
</taxonomicName>
(S. 241) durch folgende Merkmale: Kein 
<normalizedToken id="6187B5A0EA549D20B011981684BB5C35" originalValue="Blatthäutchen" pageId="null" pageNumber="243">Blatthaeutchen</normalizedToken>
und meist auch kein Haarkranz vorhanden. 
<normalizedToken id="D999167822D77F5E4A2DB1644F1CFBA8" originalValue="Blütenstand" pageId="null" pageNumber="243">Bluetenstand</normalizedToken>
eine Rispe oder Traube, 
<emphasis id="D995FD414CAACAF0E433BC956AD5E82A" italics="true" pageId="null" pageNumber="243">
die 
<normalizedToken id="0BBE0C2A05A580D0527E946650699121" originalValue="Ährchen" pageId="null" pageNumber="243">Aehrchen</normalizedToken>
jedoch 
<normalizedToken id="A6D6FB8CB81E012B902927C9D6E0982C" originalValue="knäuelig" pageId="null" pageNumber="243">knaeuelig</normalizedToken>
angeordnet
</emphasis>
(nicht 
<normalizedToken id="8C608865B5A6AF914E47490826FE6E38" originalValue="regelmäßig" pageId="null" pageNumber="243">regelmaessig</normalizedToken>
verteilt) 
<emphasis id="A362538AE1D1BC7E7B6391F247A6D1E5" italics="true" pageId="null" pageNumber="243">
und nur auf 2 Seiten der 3kantigen 
<normalizedToken id="B70955BC5B98BA3DD755E150DF81024C" originalValue="Rispenäste" pageId="null" pageNumber="243">Rispenaeste</normalizedToken>
</emphasis>
(
<normalizedToken id="E3DA2EFD2900AF4B5EA97C247146097D" originalValue="Ährchen" pageId="null" pageNumber="243">Aehrchen</normalizedToken>
deshalb einseitswendig). 
<emphasis id="895D41C8E607ACB1B838EB74E93ADA43" italics="true" pageId="null" pageNumber="243">
<normalizedToken id="C9683D15DD0F8B06D6A045A6CBC61D00" originalValue="Hüllspelzen" pageId="null" pageNumber="243">Huellspelzen</normalizedToken>
<normalizedToken id="D9757237BC40550BAEC3B0A7B6336FB3" originalValue="außerseits" pageId="null" pageNumber="243">ausserseits</normalizedToken>
auf den Nerven mit starren Borstenhaaren, mit auffallender Spitze oder
</emphasis>
<normalizedToken id="CDB11614509F13123B7E906E2BFA8D81" originalValue="±" pageId="null" pageNumber="243">+/-</normalizedToken>
<emphasis id="10A7573B4CCF1EA70637038ADC264A45" italics="true" pageId="null" pageNumber="243">langer Granne.</emphasis>
</paragraph>
<paragraph id="6DB704CF26BCE22212F605CBA3BF8F07" pageId="null" pageNumber="243">
Die Gattung 
<taxonomicName id="6FC45C60849FEC225E2CCF4393418C63" class="Liliopsida" family="Poaceae" genus="Echinochloa" kingdom="Plantae" order="Poales" pageId="null" pageNumber="243" phylum="Tracheophyta" rank="genus">
<emphasis id="D8B7771587238B1B1157CC2626882839" italics="true" pageId="null" pageNumber="243">Echinochloa</emphasis>
</taxonomicName>
<normalizedToken id="21D1B8C87B9DB9653327D83AAFC3442C" originalValue="umfaßt" pageId="null" pageNumber="243">umfasst</normalizedToken>
<emphasis id="47F095FB2691FE87DEDB3EF6AF46DAD3" italics="true" pageId="null" pageNumber="243">etwa 20 Arten, die in den Tropen und Subtropen verbreitet sind. Chromosomengrundzahl n = 6.</emphasis>
Biosystematische Untersuchungen an zahlreichen Arten in Ostasien von Yabuno (1966).
</paragraph>
</subSubSection>
