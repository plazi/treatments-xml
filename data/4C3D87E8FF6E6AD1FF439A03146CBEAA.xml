<taxonomicName id="03944D7DFF6E6AD1FF429B0A1F23B646" baseAuthorityName="Thomas" baseAuthorityYear="1891" box="[190,291,3411,3444]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="149" pageNumber="916" phylum="Chordata" rank="species" species="feae">M. feae</taxonomicName>
