<taxonomicName id="03944D7DFF6E6AD1FF019B751FAAB67F" baseAuthorityName="Scully" baseAuthorityYear="1881" box="[253,426,3372,3405]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="149" pageNumber="910" phylum="Chordata" rank="species" species="tubinaris">M. tubinaris</taxonomicName>
