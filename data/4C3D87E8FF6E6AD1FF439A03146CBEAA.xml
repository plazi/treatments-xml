<taxonomicName id="03944D7DFF6E6AD1FB759B751B30B67F" authorityName="Ruedi, Biswas &amp; Csorba" authorityYear="2012" box="[1161,1328,3372,3405]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="149" pageNumber="910" phylum="Chordata" rank="species" species="pluvialis">M. pluvialis</taxonomicName>
