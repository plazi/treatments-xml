<emphasis id="B9691559FFE85F58E7F3DB2DFB6DFEA3" box="[1184,1245,302,328]" italics="true" pageId="14" pageNumber="15">et al.</emphasis>
2002
</bibRefCitation>
). 
<taxonomicName id="4C1DB2C8FFE85F58E66DDB2CFE8EFE87" class="Agaricomycetes" family="Entolomataceae" genus="Entoloma" kingdom="Fungi" order="Agaricales" pageId="14" pageNumber="15" phylum="Basidiomycota" rank="species" species="cyanomelaenum">
<emphasis id="B9691559FFE85F58E66DDB2CFE8EFE87" italics="true" pageId="14" pageNumber="15">Entoloma cyanomelaenum</emphasis>
</taxonomicName>
