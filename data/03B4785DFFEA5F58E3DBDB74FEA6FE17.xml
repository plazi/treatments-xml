<bibRefCitation id="EF8CB4BAFFE85F58E7EADB75FF79FE5E" author="Morgan-Jones, G." pageId="14" pageNumber="15" pagination="1052" refId="ref14733" refString="Morgan-Jones, G. (1971) New names in Entoloma. Canadian Journal of Botany 49: 1052. https: // doi. org / 10.1139 / b 71 - 148" type="journal article" year="1971">Morgan-Jones (1971: 1052)</bibRefCitation>
</taxonomicName>
(= 
<taxonomicName id="4C1DB2C8FFE85F58E3B9DB99FCAFFE5F" authority="(Murrill 1943: 429) Hesler (1967: 13)" authorityName="Hesler" authorityPageNumber="13" authorityYear="1967" baseAuthorityName="Murrill" baseAuthorityPageNumber="429" baseAuthorityYear="1943" box="[234,799,410,436]" class="Agaricomycetes" family="Entolomataceae" genus="Entoloma" kingdom="Fungi" order="Agaricales" pageId="14" pageNumber="15" phylum="Basidiomycota" rank="species" species="cyaneum">
<emphasis id="B9691559FFE85F58E3B9DB99FEDEFE5F" box="[234,366,411,436]" italics="true" pageId="14" pageNumber="15">E. cyaneum</emphasis>
(
<bibRefCitation id="EF8CB4BAFFE85F58E22FDB98FDF9FE5F" author="Murrill, W. A." box="[380,585,410,436]" pageId="14" pageNumber="15" pagination="422 - 433" refId="ref15003" refString="Murrill, W. A. 1943. Some Southern Novelties. Mycologia 35: 422 - 433. https: // doi. org / 10.1080 / 00275514.1943.12017497" type="journal article" year="1943">Murrill 1943: 429</bibRefCitation>
