[non 
<taxonomicName id="4C1DB2C8FFE85F58E032DB99FA2CFE5E" authority="(Peck 1873: 49) Saccardo (1887: 688)" authorityName="Saccardo" authorityPageNumber="688" authorityYear="1887" baseAuthorityName="Peck" baseAuthorityPageNumber="49" baseAuthorityYear="1873" box="[865,1436,410,437]" class="Agaricomycetes" family="Entolomataceae" genus="Entoloma" kingdom="Fungi" order="Agaricales" pageId="14" pageNumber="15" phylum="Basidiomycota" rank="species" species="cyaneum">
<emphasis id="B9691559FFE85F58E032DB99FC54FE5F" box="[865,996,411,436]" italics="true" pageId="14" pageNumber="15">E. cyaneum</emphasis>
