<paragraph blockId="45.[136,1452,1782,2090]" pageId="45" pageNumber="46">
<materialsCitation collectionCode="AM" collectorName="Plants &amp; da Neblina" country="Venezuela" county="Despite" location="Pico da Neblina" municipality="Brazilian" pageId="45" pageNumber="46" specimenCount="1" stateProvince="Amazonas">
<collectorName box="[189,257,1782,1808]" pageId="45" pageNumber="46">Plants</collectorName>
from 
<location LSID="urn:lsid:plazi:treatment:071C2D0BCF40044FA5E7FCFAFE92F7A0:8A6ACAC6CF41044FA422F946FDDBF89A" box="[333,518,1782,1808]" country="Venezuela" county="Despite" municipality="Brazilian" name="Pico da Neblina" pageId="45" pageNumber="46" stateProvince="Amazonas">
Pico 
<collectorName box="[392,518,1782,1808]" pageId="45" pageNumber="46">da Neblina</collectorName>
</location>
(
<collectionCode box="[536,584,1782,1808]" country="Australia" name="Australian Museum" pageId="45" pageNumber="46" type="Museum">AM</collectionCode>
) are relatively small in comparison to the very robust plants that occur on 
<location LSID="urn:lsid:plazi:treatment:071C2D0BCF40044FA5E7FCFAFE92F7A0:8A6ACAC6CF41044FA5E7F8A9FE96F8B9" box="[136,331,1817,1843]" country="Venezuela" county="Despite" municipality="Brazilian" name="Cerro Marahuaca" pageId="45" pageNumber="46" stateProvince="Amazonas">Cerro Marahuaca</location>
and 
<location LSID="urn:lsid:plazi:treatment:071C2D0BCF40044FA5E7FCFAFE92F7A0:8A6ACAC6CF41044FA4EEF8A9FDD1F8B9" box="[385,524,1817,1843]" country="Venezuela" county="Despite" municipality="Brazilian" name="Cerro Duida" pageId="45" pageNumber="46" stateProvince="Amazonas">Cerro Duida</location>
(
<collectingRegion box="[539,662,1817,1843]" country="Venezuela" name="Amazonas" pageId="45" pageNumber="46">Amazonas</collectingRegion>
, 
<collectingCountry box="[672,792,1817,1843]" name="Venezuela" pageId="45" pageNumber="46">Venezuela</collectingCountry>
), whereas plants growing on 
<location LSID="urn:lsid:plazi:treatment:071C2D0BCF40044FA5E7FCFAFE92F7A0:8A6ACAC6CF41044FA131F8A9FACDF8B9" box="[1118,1296,1817,1843]" country="Venezuela" county="Despite" municipality="Brazilian" name="Mount Roraima" pageId="45" pageNumber="46" stateProvince="Amazonas">Mount Roraima</location>
and 
<location LSID="urn:lsid:plazi:treatment:071C2D0BCF40044FA5E7FCFAFE92F7A0:8A6ACAC6CF41044FA029F8A9FA76F8B9" box="[1350,1451,1817,1843]" country="Venezuela" county="Despite" municipality="Brazilian" name="Kukenan" pageId="45" pageNumber="46" stateProvince="Amazonas">Kukenán</location>
tepui (the former comprising a small part of 
<collectingMunicipality box="[642,745,1852,1878]" pageId="45" pageNumber="46">Brazilian</collectingMunicipality>
territory, RR) are intermediate in size. 
<collectingCounty box="[1191,1277,1852,1878]" pageId="45" pageNumber="46">Despite</collectingCounty>
this significant variation in size, the defining characters of this species are constant and there appear to be no morphological characters distinguishing the different geographical populations of 
<taxonomicName authorityName="R. Duno &amp; Culham" authorityYear="1995" box="[765,907,1922,1948]" class="Magnoliopsida" family="Droseraceae" genus="Drosera" kingdom="Plantae" order="Caryophyllales" pageId="45" pageNumber="46" phylum="Tracheophyta" rank="species" species="hirticalyx">
<emphasis box="[765,907,1922,1948]" italics="true" pageId="45" pageNumber="46">D. hirticalyx</emphasis>
</taxonomicName>
</materialsCitation>
.
</paragraph>
