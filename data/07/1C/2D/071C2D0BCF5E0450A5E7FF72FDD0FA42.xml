. 
<collectingRegion box="[716,872,1418,1444]" country="Brazil" name="Minas Gerais" pageId="50" pageNumber="51">Minas Gerais</collectingRegion>
: 
<collectingMunicipality box="[885,1086,1418,1445]" pageId="50" pageNumber="51">Conselheiro Pena</collectingMunicipality>
, 
<location LSID="urn:lsid:plazi:treatment:071C2D0BCF5E0450A5E7FF72FDD0FA42:8A6ACAC6CF5E0450A123FA3AFA97FA2D" box="[1100,1354,1418,1447]" country="Brazil" municipality="Conselheiro Pena" name="Pico do Padre Angelo" pageId="50" pageNumber="51" stateProvince="Minas Gerais">Pico do Padre Ângelo</location>
