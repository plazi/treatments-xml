<subSubSection id="C339652BFF9EF815FF13FD11DED794FC" pageId="27" pageNumber="178" type="duscussion">
<paragraph id="8B9C36A0FF9EF815FF13FD11DED794FC" blockId="27.[151,1436,691,933]" pageId="27" pageNumber="178">
This taxon is listed in 
<tableCitation id="C6A1031BFF9EF815FE0DFD11DE829594" box="[393,474,691,717]" captionStart="TABLE 4" captionStartId="19.[163,251,163,187]" captionTargetPageId="19" captionText="TABLE 4. Diversity of Cetoniinae from Ivory Coast, Ghana, and Benin." httpUri="http://table.plazi.org/id/DF5C6628FF96F81DFF27FF01DCF297E2" pageId="27" pageNumber="178" tableUuid="DF5C6628FF96F81DFF27FF01DCF297E2">Table 4</tableCitation>
but is not listed in 
<bibRefCitation id="EFB24B51FF9EF815FD2DFD11DC159594" author="Krajcik, M." box="[681,845,691,717]" pageId="27" pageNumber="178" refId="ref17199" refString="Krajcik, M. (1998) Cetoniidae of the world catalogue. Part 1. Typos Studio, Most, 96 + xxxvi pp." type="book" year="1998">Krajčík (1998)</bibRefCitation>
or 
<bibRefCitation id="EFB24B51FF9EF815FCF4FD11DB2C9594" author="Schoolmeesters, P." box="[880,1140,691,717]" pageId="27" pageNumber="178" refId="ref18501" refString="Schoolmeesters, P. (2021) SCARABS: World Scarabaeidae Database. In: Banki, O., Roskov, Y., Vandepitte, L., DeWalt, R. E., Remsen, D., Schalk, P., Orrell, T., Keping, M., Miller, J., Aalbu, R., Adlard, R., Adriaenssens, E., Aedo, C., Aescht, E., Akkari, N., Alonso-Zarazaga, M. A., Alvarez, B., Alvarez, F., Anderson, G. et al, Catalogue of Life Checklis. Version 2021 - 09 - 01. Catalogue of Life. Leiden. https: // doi. org / 10.48580 / d 4 sl- 38 g" type="book" year="2021">Schoolmeesters (2021)</bibRefCitation>
. However, both 
<taxonomicName id="4C234D23FF9EF815FAA3FD11DAC49595" baseAuthorityName="Gory &amp; Percheron" baseAuthorityYear="1833" box="[1319,1436,691,717]" class="Insecta" family="Cetoniidae" genus="Gnathocera" kingdom="Animalia" order="Coleoptera" pageId="27" pageNumber="178" phylum="Arthropoda" rank="species" species="varians">
<emphasis id="B957EAB2FF9EF815FAA3FD11DAC49595" box="[1319,1436,691,717]" italics="true" pageId="27" pageNumber="178">G. varians</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C234D23FF9EF815FF42FD75DEAA95A8" authority="Bates, 1884" authorityName="Bates" authorityYear="1884" box="[198,498,727,753]" class="Insecta" family="Cetoniidae" genus="Gnathocera" kingdom="Animalia" order="Coleoptera" pageId="27" pageNumber="178" phylum="Arthropoda" rank="species" species="sericinitens">
<emphasis id="B957EAB2FF9EF815FF42FD75DE3095A9" box="[198,360,727,753]" italics="true" pageId="27" pageNumber="178">G. sericinitens</emphasis>
<bibRefCitation id="EFB24B51FF9EF815FEEAFD75DEAA95A8" author="Bates, H. W." box="[366,498,727,753]" pageId="27" pageNumber="178" pagination="404 - 406" refId="ref16185" refString="Bates, H. W. (1884) List of Coleoptera of the Families Carabidae and Scarabaeidae collected by the late W. A. Forbes on the Lower Niger. Proceedings of the Zoological Society of London, 1884, 404 - 406. https: // doi. org / 10.1111 / j. 1096 - 3642.1884. tb 02845. x" type="journal article" year="1884">Bates, 1884</bibRefCitation>
</taxonomicName>
are listed as accepted names (
<bibRefCitation id="EFB24B51FF9EF815FCBAFD75DB6A95A8" author="Schoolmeesters, P." box="[830,1074,727,753]" pageId="27" pageNumber="178" refId="ref18501" refString="Schoolmeesters, P. (2021) SCARABS: World Scarabaeidae Database. In: Banki, O., Roskov, Y., Vandepitte, L., DeWalt, R. E., Remsen, D., Schalk, P., Orrell, T., Keping, M., Miller, J., Aalbu, R., Adlard, R., Adriaenssens, E., Aedo, C., Aescht, E., Akkari, N., Alonso-Zarazaga, M. A., Alvarez, B., Alvarez, F., Anderson, G. et al, Catalogue of Life Checklis. Version 2021 - 09 - 01. Catalogue of Life. Leiden. https: // doi. org / 10.48580 / d 4 sl- 38 g" type="book" year="2021">Schoolmeesters 2021</bibRefCitation>
). The former includes only three subspecies: 
<taxonomicName id="4C234D23FF9EF815FE9BFD59DC11944C" authority="Beinhundner, 2006" authorityName="Beinhundner" authorityYear="2006" box="[287,841,763,789]" class="Insecta" family="Cetoniidae" genus="Gnathocera" kingdom="Animalia" order="Coleoptera" pageId="27" pageNumber="178" phylum="Arthropoda" rank="subSpecies" species="varians" subSpecies="antoinei">
<emphasis id="B957EAB2FF9EF815FE9BFD59DD3E944D" box="[287,614,763,789]" italics="true" pageId="27" pageNumber="178">Gnathocera varians antoinei</emphasis>
Beinhundner, 2006
</taxonomicName>
, 
<taxonomicName id="4C234D23FF9EF815FCD1FD59DA33944C" authority="De Lisle, 1947" authorityName="De Lisle" authorityYear="1947" box="[853,1387,763,789]" class="Insecta" family="Cetoniidae" genus="Gnathocera" kingdom="Animalia" order="Coleoptera" pageId="27" pageNumber="178" phylum="Arthropoda" rank="subSpecies" species="varians" subSpecies="histrionica">
<emphasis id="B957EAB2FF9EF815FCD1FD59DBE1944C" box="[853,1209,763,789]" italics="true" pageId="27" pageNumber="178">Gnathocera varians histrionica</emphasis>
De Lisle, 1947
</taxonomicName>
and 
<taxonomicName id="4C234D23FF9EF815FF13FCBDDDD69460" authority="Schurhoff, 1939" authorityName="Schurhoff" authorityYear="1939" box="[151,654,799,825]" class="Insecta" family="Cetoniidae" genus="Gnathocera" kingdom="Animalia" order="Coleoptera" pageId="27" pageNumber="178" phylum="Arthropoda" rank="subSpecies" species="varians" subSpecies="roseni">
<emphasis id="B957EAB2FF9EF815FF13FCBDDE919461" box="[151,457,799,825]" italics="true" pageId="27" pageNumber="178">Gnathocera varians roseni</emphasis>
Schürhoff, 1939
</taxonomicName>
. 
<bibRefCitation id="EFB24B51FF9EF815FD1DFCBDDC279460" author="Beinhundner, G." box="[665,895,799,825]" pageId="27" pageNumber="178" refId="ref16250" refString="Beinhundner, G. (2017) The Cetoniinae of Africa. Privately published, Euerbach, 1174 + XXIV pp." type="book" year="2017">Beinhundner (2017)</bibRefCitation>
lists 
<taxonomicName id="4C234D23FF9EF815FC3BFCBDDA769461" authorityName="Gory &amp; Percheron" authorityYear="1833" box="[959,1326,799,825]" class="Insecta" family="Cetoniidae" genus="Gnathocera" kingdom="Animalia" order="Coleoptera" pageId="27" pageNumber="178" phylum="Arthropoda" rank="subSpecies" species="varians" subSpecies="sericinitens">
<emphasis id="B957EAB2FF9EF815FC3BFCBDDA769461" box="[959,1326,799,825]" italics="true" pageId="27" pageNumber="178">Gnathocera varians sericinitens</emphasis>
</taxonomicName>
under 
<taxonomicName id="4C234D23FF9EF815FA05FCBDDEFF9404" authority="Bates, 1884" authorityName="Bates" authorityYear="1884" class="Insecta" family="Cetoniidae" genus="Gnathocera" kingdom="Animalia" order="Coleoptera" pageId="27" pageNumber="178" phylum="Arthropoda" rank="species" species="sericinitens">
<emphasis id="B957EAB2FF9EF815FA05FCBDDE409405" italics="true" pageId="27" pageNumber="178">G. sericinitens</emphasis>
<bibRefCitation id="EFB24B51FF9EF815FEA5FCE1DEFF9404" author="Bates, H. W." box="[289,423,835,861]" pageId="27" pageNumber="178" pagination="404 - 406" refId="ref16185" refString="Bates, H. W. (1884) List of Coleoptera of the Families Carabidae and Scarabaeidae collected by the late W. A. Forbes on the Lower Niger. Proceedings of the Zoological Society of London, 1884, 404 - 406. https: // doi. org / 10.1111 / j. 1096 - 3642.1884. tb 02845. x" type="journal article" year="1884">Bates, 1884</bibRefCitation>
</taxonomicName>
with reference to 
<bibRefCitation id="EFB24B51FF9EF815FDFCFCE1DC4B9404" author="Allard, V." box="[632,787,835,861]" pageId="27" pageNumber="178" refId="ref13107" refString="Allard, V. (1991) Goliathini 4. The Beetles of the World. Vol. 11. Les Coleopteres du Monde. Sciences Nat, Venette, 142 pp." type="book" year="1991">Allard (1991)</bibRefCitation>
where this name combination is listed and where it may have been first used. 
<bibRefCitation id="EFB24B51FF9EF815FE06FCC5DD4394D8" author="Allard, V." box="[386,539,871,897]" pageId="27" pageNumber="178" refId="ref13107" refString="Allard, V. (1991) Goliathini 4. The Beetles of the World. Vol. 11. Les Coleopteres du Monde. Sciences Nat, Venette, 142 pp." type="book" year="1991">Allard (1991)</bibRefCitation>
lists this taxon from from 
<collectingCountry id="F3347630FF9EF815FCC1FCC5DCC494D8" box="[837,924,871,897]" name="Nigeria" pageId="27" pageNumber="178">Nigeria</collectingCountry>
, 
<collectingCountry id="F3347630FF9EF815FC22FCC5DCBE94D8" box="[934,998,871,897]" name="Niger" pageId="27" pageNumber="178">Niger</collectingCountry>
and 
<collectingCountry id="F3347630FF9EF815FB98FCC5DBED94D8" box="[1052,1205,871,897]" name="Burkina Faso" pageId="27" pageNumber="178">Burkina Faso</collectingCountry>
, and 
<bibRefCitation id="EFB24B51FF9EF815FB6BFCC5DAC094D8" author="Le Gall, P." box="[1263,1432,870,897]" pageId="27" pageNumber="178" pagination="25 - 53" refId="ref17355" refString="Le Gall, P. (2015) La faune entomologique du Benin: Les Cetoniinae (Coleoptera, Cetoniidae: Cetoniinae). Cetoniimania NS, 8, 25 - 53." type="journal article" year="2015">Le Gall (2015)</bibRefCitation>
, records it from 
<collectingCountry id="F3347630FF9EF815FEC1FC29DED494FC" box="[325,396,907,933]" name="Benin" pageId="27" pageNumber="178">Benin</collectingCountry>
.
</paragraph>
</subSubSection>
