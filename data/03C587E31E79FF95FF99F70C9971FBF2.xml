<emphasis id="B918EAE71E79FF95FA84FD739759FD6B" bold="true" box="[1387,1622,713,746]" pageId="2" pageNumber="329">Activity patterns.</emphasis>
Nothing known.
</paragraph>
</subSubSection>
<subSubSection id="C376657E1E79FF95FA82FD4A981AFC90" box="[1389,2325,752,785]" pageId="2" pageNumber="329" type="biology_ecology">
<paragraph id="8BD336F51E79FF95FA82FD4A981AFC90" blockId="2.[1387,2590,280,1142]" box="[1389,2325,752,785]" pageId="2" pageNumber="329">
<emphasis id="B918EAE71E79FF95FA82FD4A9928FC90" bold="true" box="[1389,2087,752,785]" pageId="2" pageNumber="329">Movements, Home range and Social organization.</emphasis>
