<taxonomicName id="4C084D15C613FFD80C62DE19FD82F8A8" authority="KITS &amp; MARSHALL, 2013" authorityName="KITS &amp; MARSHALL" authorityYear="2013" box="[294,514,1796,1818]" class="Insecta" family="Sphaeroceridae" genus="Photoantrops" higherTaxonomySource="GBIF" kingdom="Animalia" order="Diptera" pageId="91" pageNumber="92" phylum="Arthropoda" rank="species" species="echinus" status="sp. nov.">
