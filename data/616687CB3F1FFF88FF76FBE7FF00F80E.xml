<taxonomicName id="2ECF4D5E3F1FFF88FC3AF95CFBAAF912" authorityName="Benthic" baseAuthorityName="Heckel" baseAuthorityYear="1837" box="[987,1098,1754,1779]" class="Actinopterygii" family="Gobiidae" genus="Pomatoschistus" kingdom="Animalia" order="Perciformes" pageId="42" pageNumber="43" phylum="Chordata" rank="species" species="quagga">
