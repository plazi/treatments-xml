<taxonomicName id="9BBB0581FFFFFF9DFE5DFE93FD474445" box="[467,750,302,328]" class="Dothideomycetes" family="Saccotheciaceae" genus="Aureobasidium" kingdom="Fungi" order="Dothideales" pageId="3" pageNumber="188" phylum="Ascomycota" rank="species" species="namibiae">
<emphasis id="6ECFA210FFFFFF9DFE5DFE93FD474445" box="[467,750,302,328]" italics="true" pageId="3" pageNumber="188">Aureobasidium namibiae</emphasis>
</taxonomicName>
from dolomitic marble in Namib Desert; and 
<taxonomicName id="9BBB0581FFFFFF9DFA8FFE93FF1D4461" class="Dothideomycetes" family="Saccotheciaceae" genus="Aureobasidium" kingdom="Fungi" order="Dothideales" pageId="3" pageNumber="188" phylum="Ascomycota" rank="species" species="pini">
<emphasis id="6ECFA210FFFFFF9DFA8FFE93FF1D4461" italics="true" pageId="3" pageNumber="188">Aureobasidium pini</emphasis>
</taxonomicName>
