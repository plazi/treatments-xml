<subSubSection id="C31343D2FFC4FFA16180FE45C49CFE70" pageId="8" pageNumber="309" type="discussion">
<paragraph id="8BB61059FFC4FFA16180FE45C49CFE70" blockId="8.[151,1437,151,501]" pageId="8" pageNumber="309">
<emphasis id="B97DCC4BFFC4FFA16180FE45C460FE28" bold="true" box="[199,315,403,429]" pageId="8" pageNumber="309">Remarks.</emphasis>
<bibRefCitation id="EF986DA8FFC4FFA16002FE45C4A6FE2B" author="Bartsch, I." box="[325,509,403,430]" pageId="8" pageNumber="309" pagination="173 - 201" refId="ref9358" refString="Bartsch, I. (2009 b) Psammobiont halacarid mites (Acari: Halacaridae) from St John's Island, Singapore and remarks on the halacarid fauna of the Malay Peninsula. Raffles Bulletin of Zoology, Supplement 22, 173 - 201." type="journal article" year="2009">Bartsch (2009b)</bibRefCitation>
classified 
<taxonomicName id="4C096BDAFFC4FFA1633CFE45C138FE28" authority="Otto, 2000" authorityName="Otto" authorityYear="2000" box="[635,1123,403,429]" class="Arachnida" family="Halacaridae" genus="Arhodeoporus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trombidiformes" pageId="8" pageNumber="309" phylum="Arthropoda" rank="species" species="ventromaculatus">
<emphasis id="B97DCC4BFFC4FFA1633CFE45C684FE28" box="[635,991,403,429]" italics="true" pageId="8" pageNumber="309">Arhodeoporus ventromaculatus</emphasis>
<bibRefCitation id="EF986DA8FFC4FFA162AFFE45C138FE28" author="Otto, J. C." box="[1000,1123,403,429]" pageId="8" pageNumber="309" pagination="1 - 16" refId="ref12808" refString="Otto, J. C. (2000) Seven new species of Arhodeoporus (Acarina: Halacaridae) from the Great Barrier Reef and Coral Sea. Hydrobiologia, 436, 1 - 16. https: // doi. org / 10.1023 / A: 1026551716599" type="journal article" year="2000">Otto, 2000</bibRefCitation>
</taxonomicName>
as a junior synonym of 
<taxonomicName id="4C096BDAFFC4FFA164C3FE45C442FE54" authorityName="Viets" authorityYear="1936" class="Arachnida" family="Halacaridae" genus="Copidognathus" kingdom="Animalia" order="Trombidiformes" pageId="8" pageNumber="309" phylum="Arthropoda" rank="species" species="bonairensis">
<emphasis id="B97DCC4BFFC4FFA164C3FE45C442FE54" italics="true" pageId="8" pageNumber="309">A. bonairensis</emphasis>
</taxonomicName>
. 
<bibRefCitation id="EF986DA8FFC4FFA1606DFE61C48EFE57" author="Bartsch, I." box="[298,469,439,466]" pageId="8" pageNumber="309" pagination="553 - 571" refId="ref9669" refString="Bartsch, I. (2016) Arhodeoporus, Camactognathus, Plegadognathus, and Winlundia (Acari: Halacaridae), re-evaluation and geographical distribution. Acarologia, 56 (4), 553 - 571. https: // doi. org / 10.1051 / acarologia / 20164141" type="journal article" year="2016">Bartsch (2016)</bibRefCitation>
also commented that 
<taxonomicName id="4C096BDAFFC4FFA1639FFE61C182FE54" authority="(Andre, 1959)" baseAuthorityName="Andre" baseAuthorityYear="1959" box="[728,1241,438,465]" class="Arachnida" family="Halacaridae" genus="Plegadognathus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trombidiformes" pageId="8" pageNumber="309" phylum="Arthropoda" rank="species" species="thyreophorus">
<emphasis id="B97DCC4BFFC4FFA1639FFE61C177FE54" box="[728,1068,439,465]" italics="true" pageId="8" pageNumber="309">Plegadognathus thyreophorus</emphasis>
(André, 1959)
</taxonomicName>
may be a junior synonym of 
<taxonomicName id="4C096BDAFFC4FFA16064FE0DC49AFE70" authorityName="Viets" authorityYear="1936" box="[291,449,475,501]" class="Arachnida" family="Halacaridae" genus="Copidognathus" kingdom="Animalia" order="Trombidiformes" pageId="8" pageNumber="309" phylum="Arthropoda" rank="species" species="bonairensis">
<emphasis id="B97DCC4BFFC4FFA16064FE0DC49AFE70" box="[291,449,475,501]" italics="true" pageId="8" pageNumber="309">P. bonairensis</emphasis>
</taxonomicName>
.
</paragraph>
