<paragraph id="DF16F869755174F535F3F40425695389" pageId="0" pageNumber="105">
<emphasis id="BB47A2FC1E44CDA52F7392999ED709AF" bold="true" pageId="0" pageNumber="105">(by monotypy).</emphasis>
