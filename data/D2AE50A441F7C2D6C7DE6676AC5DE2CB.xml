<subSubSection id="365F38C0F38BCEFA28F3403EB4605B1E" pageId="null" pageNumber="590" type="description">
<paragraph id="71E38A53DAA487CD2DBC3EA43957E567" pageId="null" pageNumber="590">
Unterscheidet sich von 
<taxonomicName id="C5F330F24341122761584B22D9A3E77F" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="genus">
<emphasis id="9E42990A4532822D6D1D7DF324BC18B8" italics="true" pageId="null" pageNumber="590">Hieracium</emphasis>
</taxonomicName>
(S. 657) durch folgende Merkmale: 
<emphasis id="E02D48EE66899A1FC1F3998990D0CCDB" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="B1D4E492F79F18EF4DDDDEA45CD5CEAE" originalValue="Blütenboden" pageId="null" pageNumber="590">Bluetenboden</normalizedToken>
auf den wabenartigen Leisten stets dicht behaart; 
<taxonomicName id="ABFDBA628626DBDCA3C480D5D761C18A" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
<normalizedToken id="6F7D758108EDCB392ED37C06CD82135E" originalValue="frühzeitig" pageId="null" pageNumber="590">fruehzeitig</normalizedToken>
abfallend.
</emphasis>
</paragraph>
<paragraph id="4205FC2123639EE829DF59BC364CA0A0" pageId="null" pageNumber="590">
Die Gattung 
<taxonomicName id="297CF2D004F9E320DABACB1768DF0C0E" class="Magnoliopsida" family="Asteraceae" genus="Andryala" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="genus">
<emphasis id="F861D7DBF5FB4A86005EDACE4C137446" italics="true" pageId="null" pageNumber="590">Andryala</emphasis>
</taxonomicName>
<normalizedToken id="E0C62C2D988246BC7A5DE0B9F816A18B" originalValue="umfaßt" pageId="null" pageNumber="590">umfasst</normalizedToken>
etwa 
<emphasis id="6EE3A946418814E2EEFF4E91339FFE4F" italics="true" pageId="null" pageNumber="590">20 Arten</emphasis>
, die vor allem im 
<emphasis id="3F601632934CE7B79CF0E4040F8BAD44" italics="true" pageId="null" pageNumber="590">Mittelmeergebiet</emphasis>
verbreitet sind.
</paragraph>
