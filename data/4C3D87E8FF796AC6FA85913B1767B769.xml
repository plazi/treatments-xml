<subSubSection id="8C8E6575FF796AC6F8219F7A16C2B28E" pageId="130" pageNumber="889" type="distribution">
<caption id="90EB6676FF796AC6F8219F7A16C2B28E" ID-DOI="http://doi.org/10.5281/zenodo.6398412" ID-Zenodo-Dep="6398412" httpUri="https://zenodo.org/record/6398412/files/figure.png" inLine="true" pageId="130" pageNumber="889" targetBox="[1397,1989,2111,2526]" targetPageId="130">
<paragraph id="C42B36FEFF796AC6F8219F7A16C2B28E" blockId="130.[2012,2607,2110,2531]" pageId="130" pageNumber="889">
<emphasis id="F6E0EAECFF796AC6F8219F7A168DB276" bold="true" box="[2013,2189,2339,2372]" pageId="130" pageNumber="889">
<emphasis id="F6E0EAECFF796AC6F8219F7A1689B276" box="[2013,2185,2339,2372]" pageId="130" pageNumber="889">Distribution</emphasis>
.
</emphasis>
Known only from SE 
<collectingCountry id="BC83766EFF796AC6F6149F7A162CB25E" name="Ivory Coast" pageId="130" pageNumber="889">Ivory Coast</collectingCountry>
