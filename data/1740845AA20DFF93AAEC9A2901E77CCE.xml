<subSubSection id="D7F366C7A20DFF93A88E9A81079B735D" pageId="2" pageNumber="67" type="reference_group">
<paragraph id="9F56354CA20DFF93A88E9A81079B735D" blockId="2.[739,1331,687,1115]" pageId="2" pageNumber="67">
<emphasis id="AD9DE95EA20DFF93A88E9A81007372CA" bold="true" box="[739,895,687,720]" pageId="2" pageNumber="67">Taxonomy.</emphasis>
<taxonomicName id="58E94ECFA20DFF93A9FB9A81002472E2" authority="Linnaeus, 1758" authorityName="Linnaeus" authorityYear="1758" class="Mammalia" family="Dasypodidae" genus="Dasypus" kingdom="Animalia" order="Cingulata" pageId="2" pageNumber="67" phylum="Chordata" rank="species" species="sexcinctus">Dasypus sexcinctus Linnaeus, 1758</taxonomicName>
, 
<materialsCitation id="2F813F11A20DFF93A9539AF507BD72E2" ID-GBIF-Occurrence="3804301303" box="[830,1201,731,760]" pageId="2" pageNumber="67">“in America Meridionali.”</materialsCitation>
