<taxonomicName id="4C644D095A7F980BFF85FCA3ECDCFC8C" authority="G. M. Allen &amp; Loveridge, 1927" authorityName="G. M. Allen &amp; Loveridge" authorityYear="1927" box="[114,729,768,801]" class="Mammalia" family="Chrysochloridae" genus="Chrysochloris" kingdom="Animalia" order="Afrosoricida" pageId="8" pageNumber="201" phylum="Chordata" rank="subSpecies" species="stuhlmanni" subSpecies="tropicalis">C.s.tropicalisG.M.Allen&amp;Loveridge,1927—UluguruMtsandRungwedistrict,Tanzania.</taxonomicName>
