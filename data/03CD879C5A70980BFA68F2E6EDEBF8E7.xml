<emphasis id="B910EA985A7F980BFD23FDB0EA61FD99" bold="true" box="[724,1124,531,564]" pageId="8" pageNumber="201">Subspecies and Distribution.</emphasis>
<taxonomicName id="4C644D095A7F980BFD20FDE0EA7AFDF1" authority="Matschie, 1894" authorityName="Matschie" authorityYear="1894" box="[727,1151,579,604]" class="Mammalia" family="Chrysochloridae" genus="Chrysochloris" kingdom="Animalia" order="Afrosoricida" pageId="8" pageNumber="201" phylum="Chordata" rank="subSpecies" species="stuhlmanni" subSpecies="stuhlmannii">C.s.stuhlmanniiMatschie,1894—RwenzoriMts,NEDRCongoandSWUganda.</taxonomicName>
