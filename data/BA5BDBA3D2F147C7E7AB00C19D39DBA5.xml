<normalizedToken id="F324238BBEF41416B86BC2DE793DBBAA" originalValue="nútans" pageId="null" pageNumber="780">nutans</normalizedToken>
<authorityName id="FBFCFE85298AC6A2DE6CF168CDD2FB37" pageId="null" pageNumber="780">L.</authorityName>
