<taxonomicName id="169981D11B1DFFD1FF2AF077FEF8F3FF" authorityName="Waterhouse" authorityYear="1848" box="[190,360,3078,3107]" class="Mammalia" family="Ctenomyidae" genus="Ctenomys" kingdom="Animalia" order="Rodentia" pageId="3" pageNumber="514" phylum="Chordata" rank="species" species="boliviensis">C. boliviensis</taxonomicName>
