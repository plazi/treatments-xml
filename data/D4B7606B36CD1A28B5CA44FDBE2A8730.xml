<subSubSection id="7D66A32D9CF85FD0A6BF5F2A1910B1CF" pageId="null" pageNumber="194" type="description">
<paragraph id="9BC1CD3C42AA9E4AE5990FE9F345AF6B" pageId="null" pageNumber="194">
Unterscheidet sich von der Gattung 
<taxonomicName id="E95F430BB90E636D5802927A72BB08AD" class="Magnoliopsida" family="Brassicaceae" genus="Brassica" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="194" phylum="Tracheophyta" rank="genus">
<emphasis id="CDBA9B0455E4B0DEAED588BEEE3FE98B" italics="true" pageId="null" pageNumber="194">Brassica</emphasis>
</taxonomicName>
(S. 184) durch folgende Merkmale: 
<emphasis id="98F203F8F1B76DD26CC32CAD6550AC1F" italics="true" pageId="null" pageNumber="194">
<normalizedToken id="47EDC56496CB4ED2F82348A407DB0856" originalValue="Früchte" pageId="null" pageNumber="194">Fruechte</normalizedToken>
im Querschnitt bikonvex bis quadratisch; Samen in jedem Fach 2reihig; Fruchtschnabel deutlich abgeflacht.
</emphasis>
</paragraph>
<paragraph id="EB6221570F2A8692445A2CF6BA1D7F0A" pageId="null" pageNumber="194">
Die Gattung 
<taxonomicName id="18F140CF463558AB82A7B7B1528AB274" class="Magnoliopsida" family="Brassicaceae" genus="Eruca" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="194" phylum="Tracheophyta" rank="genus">
<emphasis id="C8BB4DA0FF094B1FB94F61F170D405EB" italics="true" pageId="null" pageNumber="194">Eruca</emphasis>
</taxonomicName>
<normalizedToken id="25215F6656999FD33782AC2FD6674F5A" originalValue="umfaßt" pageId="null" pageNumber="194">umfasst</normalizedToken>
<emphasis id="1D8D6B04E555F37D9B7D314C19F39CF2" italics="true" pageId="null" pageNumber="194">5 Arten</emphasis>
, die 
<emphasis id="0079F6A819B05BAE87AC1E7768E811E7" italics="true" pageId="null" pageNumber="194">im Mittelmeergebiet verbreitet sind.</emphasis>
</paragraph>
</subSubSection>
