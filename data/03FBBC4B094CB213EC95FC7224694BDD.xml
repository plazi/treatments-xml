<taxonomicName id="4C5276DE094DB213EDA5FF6722454AFD" box="[423,590,187,213]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="25" pageNumber="476" phylum="Chordata" rank="species" species="smartae">
