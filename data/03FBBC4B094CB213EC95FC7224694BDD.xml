<subSubSection id="C3485ED6094CB212EC95FBC6210F4F19" pageId="24" pageNumber="475" type="etymology">
<paragraph id="8BED0D5D094CB212EC95FBC622394E55" blockId="24.[151,1437,1050,1329]" pageId="24" pageNumber="475">
<emphasis id="B926D14F094CB212EC95FBC621294E1D" bold="true" box="[151,290,1050,1076]" pageId="24" pageNumber="475">Etymology:</emphasis>
<taxonomicName id="4C5276DE094CB212ED2BFBC721644E1C" box="[297,367,1051,1077]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="24" pageNumber="475" phylum="Chordata" rank="genus">
<emphasis id="B926D14F094CB212ED2BFBC721644E1C" box="[297,367,1051,1077]" italics="true" pageId="24" pageNumber="475">Garra</emphasis>
</taxonomicName>
: named based on a vernacular Indian name, a fish living in mud; 
<emphasis id="B926D14F094CB212E856FBC724BC4E1D" box="[1108,1207,1051,1076]" italics="true" pageId="24" pageNumber="475">
<taxonomicName id="4C5276DE094CB212E856FBC724BA4E1D" authorityName="Krupp &amp; Budd" authorityYear="2009" box="[1108,1201,1051,1076]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="24" pageNumber="475" phylum="Chordata" rank="species" species="smartae">smartae</taxonomicName>
:
</emphasis>
named in honour of Ms. Emma Smart, 
<collectingRegion id="4996C3BF094CB212ED6AFBE221A44E71" box="[360,431,1086,1112]" country="United Arab Emirates" name="Dubayy" pageId="24" pageNumber="475">Dubai</collectingRegion>
, in recognition of her studies of Arabian wadi fishes and her contributions to the conservation of freshwater habitats in Arabia.
</paragraph>
<paragraph id="8BED0D5D094CB212ECC5FB5A22544E89" blockId="24.[151,1437,1050,1329]" box="[199,607,1158,1184]" pageId="24" pageNumber="475">
<emphasis id="B926D14F094CB212ECC5FB5A218C4E89" bold="true" box="[199,391,1158,1184]" pageId="24" pageNumber="475">Common name:</emphasis>
Wadi Hasik 
<taxonomicName id="4C5276DE094CB212EE1AFB5A22504E89" box="[536,603,1158,1184]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="24" pageNumber="475" phylum="Chordata" rank="genus">Garra</taxonomicName>
.
</paragraph>
<paragraph id="8BED0D5D094CB212ECC5FB76210F4F19" blockId="24.[151,1437,1050,1329]" pageId="24" pageNumber="475">
<emphasis id="B926D14F094CB212ECC5FB7621454EED" bold="true" box="[199,334,1194,1220]" pageId="24" pageNumber="475">Taxonomy:</emphasis>
<taxonomicName id="4C5276DE094CB212ED54FB7721E64EED" authorityName="Krupp &amp; Budd" authorityYear="2009" box="[342,493,1195,1221]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="24" pageNumber="475" phylum="Chordata" rank="species" species="smarti">
<emphasis id="B926D14F094CB212ED54FB7721E64EED" box="[342,493,1195,1221]" italics="true" pageId="24" pageNumber="475">Garra smarti</emphasis>
</taxonomicName>
<materialsCitation id="3B3A0700094CB212EDF4FB77210B4F19" ID-GBIF-Occurrence="3766721344" country="Oman" location="Wadi Hasik" longitude="55.22781" pageId="24" pageNumber="475" specimenCount="1" stateProvince="Zufar">
was originally described by Krupp [F.] &amp; Budd [K.] 2009:117, figs.1-4 [aqua, International Journal of Ichthyology v. 15 (no. 2)] 
<location id="8E8D5B86094CB212EECCFB12235C4EC1" LSID="urn:lsid:plazi:treatment:03FBBC4B094CB213EC95FC7224694BDD:8E8D5B86094CB212EECCFB12235C4EC1" box="[718,855,1230,1256]" country="Oman" longitude="55.22781" name="Wadi Hasik" pageId="24" pageNumber="475" stateProvince="Zufar">Wadi Hasik</location>
, 
<geoCoordinate id="EE666B9A094CB212EF64FB12241E4EC0" box="[870,1045,1230,1257]" degrees="17" direction="east" minutes="26.5" orientation="longitude" pageId="24" pageNumber="475" precision="1" seconds="40.11" value="55.22781">17°26.5’77”’N,</geoCoordinate>
<geoCoordinate id="EE666B9A094CB212E81DFB1224C24EC0" box="[1055,1225,1230,1257]" degrees="17" direction="east" minutes="26.5" orientation="longitude" pageId="24" pageNumber="475" precision="1" seconds="40.11" value="55.22781">55°13’40.11”E</geoCoordinate>
, 
<collectingRegion id="4996C3BF094CB212E8DAFB1225934EC1" box="[1240,1432,1230,1256]" country="Oman" name="Zufar" pageId="24" pageNumber="475">Dhofar Province</collectingRegion>
, 
<collectingCountry id="F3454DCD094CB212EC95FB2E20D44F25" box="[151,223,1266,1292]" name="Oman" pageId="24" pageNumber="475">Oman</collectingCountry>
. The species name was dedicated to a woman, so there is a mandatory change to 
<taxonomicName id="4C5276DE094CB212E87CFB2F210B4F19" authority="(Fricke et al. 2022)" baseAuthorityName="Fricke" baseAuthorityYear="2022" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="24" pageNumber="475" phylum="Chordata" rank="species" species="smartae">
<emphasis id="B926D14F094CB212E87CFB2F252D4F25" box="[1150,1318,1267,1293]" italics="true" pageId="24" pageNumber="475">Garra smartae</emphasis>
(
<bibRefCitation id="EFC370AC094CB212E934FB2E20F34F19" author="Fricke, R. &amp; Eschmeyer, W. N. &amp; Van der Laan, R." pageId="24" pageNumber="475" refId="ref23694" refString="Fricke, R., Eschmeyer, W. N. &amp; Van der Laan, R. (2022) Eschmeyer's Catalog of Fishes: Genera, Species, References. Available from: http: // researcharchive. calacademy. org / research / ichthyology / catalog / fishcatmain. asp (accessed 20 March 2022)" type="url" year="2022">
Fricke 
<emphasis id="B926D14F094CB212E98AFB2F20A64F19" italics="true" pageId="24" pageNumber="475">et al</emphasis>
. 2022
</bibRefCitation>
)
</taxonomicName>
</materialsCitation>
.
</paragraph>
</subSubSection>
