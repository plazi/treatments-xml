and 
<taxonomicName id="4C6C6AE4FFCBFFFFF61553A3507FF45F" authorityName="Thomas" authorityYear="1916" box="[2473,2590,2986,3019]" class="Mammalia" family="Echimyidae" genus="Diplomys" kingdom="Animalia" order="Rodentia" pageId="38" pageNumber="590" phylum="Chordata" rank="genus">Diplomys</taxonomicName>
