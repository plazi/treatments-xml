<taxonomicName id="4C6C6AE4FFCBFFFFF9AB53525D9DF4E8" authority="J. A. Allen, 1899" authorityName="J. A. Allen" authorityYear="1899" box="[1559,2044,2907,2940]" class="Mammalia" family="Echimyidae" genus="Isothrix" kingdom="Animalia" order="Rodentia" pageId="38" pageNumber="590" phylum="Chordata" rank="species" species="rufodorsalis">Isothrix rufodorsalis J. A. Allen, 1899</taxonomicName>
