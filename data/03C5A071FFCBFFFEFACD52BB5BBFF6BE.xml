<taxonomicName id="4C6C6AE4FFCBFFFFF6FE5533506CF2C6" authorityName="Zimmermann" authorityYear="1780" box="[2370,2573,3385,3411]" class="Mammalia" family="Echimyidae" genus="Echimys" kingdom="Animalia" order="Rodentia" pageId="38" pageNumber="590" phylum="Chordata" rank="species" species="chrysurus">Echimys chrysurus</taxonomicName>
), 83. Vieira's Tree-rat (
