<taxonomicName id="4C6C6AE4FFCBFFFFFBEC55365F7EF2C3" baseAuthorityName="Thomas" baseAuthorityYear="1928" box="[1104,1311,3390,3416]" class="Mammalia" family="Echimyidae" genus="Toromys" higherTaxonomySource="GBIF" kingdom="Animalia" order="Rodentia" pageId="38" pageNumber="592" phylum="Chordata" rank="species" species="rhipidurus">Toromys rhipidurus</taxonomicName>
