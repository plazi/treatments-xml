</paragraph>
<paragraph id="8BD31167FFCBFFFFFACE53A35C6CF460" blockId="38.[1390,2597,2907,3262]" pageId="38" pageNumber="590">
<taxonomicName id="4C6C6AE4FFCBFFFFFACE53A35CB6F45F" baseAuthorityName="J.A.Allen" baseAuthorityYear="1899" box="[1394,1751,2986,3019]" class="Mammalia" family="Echimyidae" genus="Santamartamys" higherTaxonomySource="GBIF" kingdom="Animalia" order="Rodentia" pageId="38" pageNumber="590" phylum="Chordata" rank="species" species="rufodorsalis">Santamartamys rufodorsalis</taxonomicName>
