<keyLead id="805895B50D1FB61DFF4BF96EFA2DFADC" box="[136,1451,1288,1310]" pageId="5" pageNumber="146">1. Fruit dehiscent into 5 segments ..........................................................................................................................................................2</keyLead>
</paragraph>
<paragraph id="3B1636800D1FB61DFF4BF943FA2DFAFB" blockId="5.[136,1451,1288,2088]" box="[136,1451,1317,1339]" pageId="5" pageNumber="146">
<keyLead id="805895B50D1FB61DFF4BF943FA2DFAFB" box="[136,1451,1317,1339]" pageId="5" pageNumber="146">- Fruit dehiscent into 10 segments ........................................................................................................................................................8</keyLead>
</paragraph>
</keyStep>
<keyStep id="805D2E250D1FB61DFF4BF924FA2DFAB5" pageId="5" pageNumber="146">
<paragraph id="3B1636800D1FB61DFF4BF924FA2DFA96" blockId="5.[136,1451,1288,2088]" box="[136,1451,1346,1368]" pageId="5" pageNumber="146">
<keyLead id="805895B50D1FB61DFF4BF924FA2DFA96" box="[136,1451,1346,1368]" pageId="5" pageNumber="146">2. Corolla yellow ....................................................................................................................................................................................3</keyLead>
</paragraph>
<paragraph id="3B1636800D1FB61DFF4BF939FA2DFAB5" blockId="5.[136,1451,1288,2088]" box="[136,1451,1374,1397]" pageId="5" pageNumber="146">
<keyLead id="805895B50D1FB61DFF4BF939FA2DFAB5" box="[136,1451,1374,1397]" pageId="5" pageNumber="146">- Corolla yellow-orange to salmon with a red to wine-red base...........................................................................................................5</keyLead>
</paragraph>
</keyStep>
<keyStep id="805D2E250D1FB61DFF4BF91AFA2DFA6C" pageId="5" pageNumber="146">
<paragraph id="3B1636800D1FB61DFF4BF91AFA2DFA50" blockId="5.[136,1451,1288,2088]" box="[136,1451,1403,1425]" pageId="5" pageNumber="146">
<keyLead id="805895B50D1FB61DFF4BF91AFA2DFA50" box="[136,1451,1403,1425]" pageId="5" pageNumber="146">3. Root thin; stem puberulent at the base; fruit ovoid ............................................................................................................................4</keyLead>
</paragraph>
<paragraph id="3B1636800D1FB61DFF4BF9FFFA2DFA6C" blockId="5.[136,1451,1288,2088]" box="[136,1451,1432,1454]" pageId="5" pageNumber="146">
<keyLead id="805895B50D1FB61DFF4BF9FFFA2DFA6C" box="[136,1451,1432,1454]" pageId="5" pageNumber="146">
-. Root thick; stem glabrous; fruit ellipsoid ........................................................................................................................ 
<taxonomicName id="FCA94D030D1FB61DFAF2F9FFFA2DFA6C" authorityName="Engelmann" authorityYear="1848" box="[1329,1451,1432,1454]" class="Magnoliopsida" family="Linaceae" genus="Linum" kingdom="Plantae" order="Malpighiales" pageId="5" pageNumber="146" phylum="Tracheophyta" rank="species" species="aristatum">
