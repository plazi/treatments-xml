<paragraph id="2E0FD11A0AD72B12618C59CABACF7CDE" pageId="0" pageNumber="75">
<taxonomicName id="6A3DAE7A3B55B8BBFAA3DF1D02BF9C53" authorityName="Rasplus, Boehmova &amp; Jansta" authorityYear="2022" family="Megastigmidae" genus="Striastigmus" kingdom="Animalia" lsidName="Striastigmus bicoloratus" order="Hymenoptera" pageId="0" pageNumber="75" rank="species" species="bicoloratus">
<emphasis id="0B3F01922BC88D5AC5CB5011AEABBA74" italics="true" pageId="0" pageNumber="75">Striastigmus bicoloratus</emphasis>
</taxonomicName>
Rasplus, 
<normalizedToken id="C1D93D800E48A202677079F6D0329D3C" originalValue="Böhmová">Boehmova</normalizedToken>
&amp; 
<normalizedToken id="2C60E825AC5EFD7376EE5964100CE2A4" originalValue="Janšta">Jansta</normalizedToken>
