<taxonomicName id="3B51640702A8BBB8F2CFE0223CB3A0C6" authority="Soyer-Will" class="Magnoliopsida" family="Rosaceae" genus="Sorbus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="476" phylum="Tracheophyta" rank="species" species="mougeotii">
