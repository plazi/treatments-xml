<taxonomicName id="3D9D18FC188238C53D6F7B555F145FDA" authority="L." class="Magnoliopsida" family="Fabaceae" genus="Anthyllis" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="548" phylum="Tracheophyta" rank="species" species="vulneraria">
