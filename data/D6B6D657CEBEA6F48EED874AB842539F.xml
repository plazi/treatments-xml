<subSubSection id="979CBE96AB0F7976EE5AA78BA557F6B5" pageId="null" pageNumber="503" type="description">
<paragraph id="01A1DECE4BD9242B80AD23CCCFCB2E81" pageId="null" pageNumber="503">
Ausdauernd; 30-70 cm hoch, horstbildend. 
<normalizedToken id="8ED24CF1400C1DD25D1214119E6F467C" originalValue="Blütentragende" pageId="null" pageNumber="503">Bluetentragende</normalizedToken>
Stengel ohne 
<normalizedToken id="50BF0AC26B94D59D19E40DD9CBE0DF60" originalValue="Blätter" pageId="null" pageNumber="503">Blaetter</normalizedToken>
, am Grunde nur 
<emphasis id="1C18489836A52EEBC8EF8705C2D27F64" italics="true" pageId="null" pageNumber="503">
schwarzbraune, 
<normalizedToken id="D739AD5EBF4A17766583FF17922EDD22" originalValue="glänzende" pageId="null" pageNumber="503">glaenzende</normalizedToken>
Blattscheiden
</emphasis>
vorhanden, ca. 2 mm dick, mit 
<emphasis id="0B6EEC3566B282E214463EF91E111170" italics="true" pageId="null" pageNumber="503">
12-16 feinen 
<normalizedToken id="B8BD3F253AE7B6CE44FF1AD92024DC70" originalValue="Längsrippen" pageId="null" pageNumber="503">Laengsrippen</normalizedToken>
; Mark des Stengels unterbrochen.
</emphasis>
<normalizedToken id="F70428715AF846E9C5FF4FD9BAC5A275" originalValue="Blütenstand" pageId="null" pageNumber="503">Bluetenstand</normalizedToken>
<normalizedToken id="A2AAAE8478CBDCB87FCBCD937BF40585" originalValue="vielblütig" pageId="null" pageNumber="503">vielbluetig</normalizedToken>
, locker, scheinbar 
<normalizedToken id="2E3C20840903EAFEDF3BF9BCAE17088C" originalValue="seitenständig" pageId="null" pageNumber="503">seitenstaendig</normalizedToken>
, oberhalb der Mitte der Pflanze (ein aufgerichtetes Hochblatt bildet die Fortsetzung des Stengels). 
<normalizedToken id="B5AD53FB86D2B8EFEB37425ABDE3799D" originalValue="Perigonblätter" pageId="null" pageNumber="503">Perigonblaetter</normalizedToken>
im untern Teil von 2 
<normalizedToken id="9B1C36316E8EC5BAA2ACA15E4E1CF8BD" originalValue="häutigen" pageId="null" pageNumber="503">haeutigen</normalizedToken>
<normalizedToken id="484A7E23376560FB86838A954AEB5126" originalValue="Vorblättern" pageId="null" pageNumber="503">Vorblaettern</normalizedToken>
umgeben, 2,5-3,5 mm lang, alle gleich lang oder die 
<normalizedToken id="2B314624A188791D229E1B40EFFE02F6" originalValue="äußern" pageId="null" pageNumber="503">aeussern</normalizedToken>
deutlich 
<normalizedToken id="A75D56A523A70CDE002848CC3DB2CBB8" originalValue="länger" pageId="null" pageNumber="503">laenger</normalizedToken>
als die innern, 
<normalizedToken id="80F3F5B01FA26157AABE3A6BCAFDB443" originalValue="allmählich" pageId="null" pageNumber="503">allmaehlich</normalizedToken>
und fein zugespitzt, gelblich. Reife Frucht 
<normalizedToken id="39962105CBB11A49594CEF9B3AD5AAD0" originalValue="ungefähr" pageId="null" pageNumber="503">ungefaehr</normalizedToken>
so lang wie die 
<normalizedToken id="F28C32F46A7C96A15A88D3D2DD47F84E" originalValue="Perigonblätter" pageId="null" pageNumber="503">Perigonblaetter</normalizedToken>
, rotbraun. - 
<normalizedToken id="AAD8145D81E37F519C77E5CE2D87F04E" originalValue="Blüte" pageId="null" pageNumber="503">Bluete</normalizedToken>
: 
<normalizedToken id="1B21486A3D5E4B138571A760EF9D1318" originalValue="Früher" pageId="null" pageNumber="503">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="04A150FA0E4C95A3DC722096A98379B5" pageId="null" pageNumber="503">
<emphasis id="838524CCE9888D80ADC6DFA414D2CC05" italics="true" pageId="null" pageNumber="503">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D854B2D63722674BF05C04F1EF543136" italics="true" pageId="null" pageNumber="503">40:</emphasis>
Material aus Schleswig-Holstein (Wulff 1937b), aus Skandinavien (
<normalizedToken id="2768B86AA616BA542F3A1924421BA322" originalValue="Löve" pageId="null" pageNumber="503">Loeve</normalizedToken>
und 
<normalizedToken id="E08082009B52E5ECA1F7A126CFEFCD78" originalValue="Löve" pageId="null" pageNumber="503">Loeve</normalizedToken>
1948), aus Schweden (Snogerup 1963).
</paragraph>
<paragraph id="DBF388DDE079237BEE292253DD3529B0" pageId="null" pageNumber="503">
<emphasis id="BE1A41DF8C20B58E43268F74ECA25928" italics="true" pageId="null" pageNumber="503">Standort.</emphasis>
Kollin und montan, seltener subalpin. Staunasse, 
<normalizedToken id="DCE0DC23DA81B845A094E52A5D5CD6F7" originalValue="verschlämmte" pageId="null" pageNumber="503">verschlaemmte</normalizedToken>
, lehmige, oft kalkarme, 
<normalizedToken id="B6AC2060D2DC73E0DF9D12DC1058FB49" originalValue="nährstoffreiche" pageId="null" pageNumber="503">naehrstoffreiche</normalizedToken>
(oft 
<normalizedToken id="04FC1C1822FEB65185CA2B675C19F257" originalValue="gedüngte" pageId="null" pageNumber="503">geduengte</normalizedToken>
) 
<normalizedToken id="9871C6048FAEA50B7FCC3F0F9F2BB94C" originalValue="Böden" pageId="null" pageNumber="503">Boeden</normalizedToken>
. Weiden, 
<normalizedToken id="77245359B5F3AC81A1CA2E70B2E36BA6" originalValue="Wegränder" pageId="null" pageNumber="503">Wegraender</normalizedToken>
, 
<normalizedToken id="297287D29E73AF0231F23C8259572BEC" originalValue="Kahlschläge" pageId="null" pageNumber="503">Kahlschlaege</normalizedToken>
, Flachmoore.
</paragraph>
<paragraph id="BCB7E48BD15F58EBD15723D68292BAC7" pageId="null" pageNumber="503">
<emphasis id="C6883C302EAE8C57CE73F9AAEE705FCB" italics="true" pageId="null" pageNumber="503">
<pageBreakToken id="9E76DCFFCB982ACF4BC1378241AB1F8F" pageId="null" pageNumber="503">Verbreitung</pageBreakToken>
. Eurasiatische Pflanze:
</emphasis>
<normalizedToken id="175E339D7B901F94AC54DA551DFE5AD5" originalValue="Nordwärts" pageId="null" pageNumber="503">Nordwaerts</normalizedToken>
bis Schottland, 
<normalizedToken id="3CDC83C6783A7194675EA4832E79DAE6" originalValue="Südskandinavien" pageId="null" pageNumber="503">Suedskandinavien</normalizedToken>
, Gebiet von Moskau; durch Turkestan 
<normalizedToken id="FC601651D10E501ABAF8362A625AFF65" originalValue="ostwärts" pageId="null" pageNumber="503">ostwaerts</normalizedToken>
bis in die Mongolei; 
<normalizedToken id="2CED061BE8AD81CAB5C0DD7EC2023A32" originalValue="südwärts" pageId="null" pageNumber="503">suedwaerts</normalizedToken>
bis Nordwestafrika, Syrien, Iran. Nach Nordamerika, 
<normalizedToken id="1BA1A7BE4B145982B603B74D62F04632" originalValue="Südafrika" pageId="null" pageNumber="503">Suedafrika</normalizedToken>
, 
<normalizedToken id="9E6E623C953A5928CC93F5C600C88E03" originalValue="Südindien" pageId="null" pageNumber="503">Suedindien</normalizedToken>
, Indonesien und Neuseeland verschleppt. Verbreitungskarte von Meusel (1964). - Im Gebiet verbreitet und 
<normalizedToken id="B1B4B0F9FBC0F683687DEA2AAACC07FD" originalValue="häufig" pageId="null" pageNumber="503">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
