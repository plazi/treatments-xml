<bibRefCitation id="FD6DDAC0E13699F37853AE0F7657AC04" author="Lapeva-Gjonova, A." journalOrPublisher="Biodiversity Data Journal" pageId="0" pageNumber="83658" refId="B7741022" refString="Lapeva-Gjonova, A., Borowiec, L., 2022. New and little-known ant species (Hymenoptera, Formicidae) from Bulgaria. In: Biodiversity Data Journal. Occurrence dataset." title="New and little-known ant species (Hymenoptera, Formicidae) from Bulgaria" volumeTitle="Biodiversity Data Journal. Occurrence dataset." year="2022">Lapeva-Gjonova and Borowiec (2022)</bibRefCitation>
