<figureCitation id="14C467386D29441B88DC6BDDF16AA18D" captionStart="Figure 7" captionStartId="F7727181" captionText="Figure 7. Cataglyphis viaticoides, worker lateral: specimen from Svirachi vill.; scale bar 1 mm." figureDoi="10.3897/BDJ.10.e83658.figure7" httpUri="https://binary.pensoft.net/fig/653858" pageId="0" pageNumber="83658">7</figureCitation>
