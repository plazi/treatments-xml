<subSubSection id="794CAD45DA726E8D7399F112BEFE97B5" type="description">
<paragraph id="78A4C6888E053E46EC270EFE061A9CD7">
Meist 
<normalizedToken id="2A5748E030878381496AC8C76ED52B93" originalValue="Bäume">Baeume</normalizedToken>
oder 
<normalizedToken id="EAC2D791676D4BAFD709AF46B208AC16" originalValue="Sträucher">Straeucher</normalizedToken>
; 
<emphasis id="575AA650947AE488642A914F83B5CEA1" italics="true">mit Sternhaaren.</emphasis>
Kelch 
<normalizedToken id="6479499E101B0455542E87F09957F367" originalValue="glockenförmig">glockenfoermig</normalizedToken>
, 
<emphasis id="728EB13FA1C15FFAB88D870EF538E216" italics="true">4teilig.</emphasis>
Krone 
<normalizedToken id="2616BCF480A000AFC3E982AAAEF51032" originalValue="röhrenförmig">roehrenfoermig</normalizedToken>
, mit 
<emphasis id="08F7FDCD3CA337A11D993F569A75C576" italics="true">4teiligem</emphasis>
, ausgebreitetem Rand. 
<normalizedToken id="673B60CD6C7DE1E37C3B7293400845E8" originalValue="Staubblätter">Staubblaetter</normalizedToken>
4, mit kurzen 
<normalizedToken id="6C48B1A5E31BCB707510EE1E916FC95A" originalValue="Staubfäden">Staubfaeden</normalizedToken>
. Narbe ungeteilt. Frucht eine Kapsel.
</paragraph>
<paragraph id="410A1EC57BEF641F9D342F6FA8F17086">
Die Gattung 
<taxonomicName id="CEAE2A0442CFA5C5F0FDD2E7A8E097F4" class="Magnoliopsida" family="Scrophulariaceae" genus="Buddleja" kingdom="Plantae" order="Lamiales" phylum="Tracheophyta" rank="genus">
<emphasis id="D4DABBABD959FEF9F4FD18778315E162" italics="true">Buddleja</emphasis>
</taxonomicName>
<normalizedToken id="359A5F95812452252B86DDBA09510C5C" originalValue="umfaßt">umfasst</normalizedToken>
etwa 
<emphasis id="B4530EB51F349CD448A32FCC28893F34" italics="true">120 tropische und subtropische</emphasis>
Arten. Verbreitungskarte von Janaki - Ammal (1954). 
<emphasis id="E87B493BE25BA78305E7DD569A8CB19A" italics="true">Chromosomengrundzahl:</emphasis>
n = 19 (2n = 38, 76, 104, 228). Experimentelle Bastarde in der Gattung sind auch zwischen Arten mit verschiedenen Chromosomenzahlen 
<normalizedToken id="CFFDB01BF3A1324596883F98AA88C269" originalValue="möglich">moeglich</normalizedToken>
(Moore 1960).
</paragraph>
