<bibRefCitation id="45744B7FEB448B024CC14232FEC2FDEA" author="Tics, A." box="[237,361,522,544]" pageId="3" pageNumber="297" refId="ref5823" refString="Tics, A. (2000) Ziemelu citrons Cido. Jauna auglu kultura. [author's edition], [Pure], 257 pp." type="book" year="2000">Tīcs 2000: 6</bibRefCitation>
