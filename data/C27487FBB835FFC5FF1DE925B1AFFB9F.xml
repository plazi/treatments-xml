<taxonomicName id="8DDD4D6EB835FFC5FA8AEA18B1AFFDD3" box="[1311,1451,587,608]" class="Agaricomycetes" family="Hymenogastraceae" genus="Psilocybe" kingdom="Fungi" order="Agaricales" pageId="7" pageNumber="182" phylum="Basidiomycota" rank="species" species="taiwanensis">
