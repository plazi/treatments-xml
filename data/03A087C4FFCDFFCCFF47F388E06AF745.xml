, and more recently into 
<collectingCountry id="F31E7642FFCDFFCCF894FD7BE1E0FD1C" box="[1887,2013,716,741]" name="Australia" pageId="8" pageNumber="415">Australia</collectingCountry>
, and 
<collectingCountry id="F31E7642FFCDFFCCF7E7FD7BEEE0FD1C" box="[2092,2269,716,741]" name="South Africa" pageId="8" pageNumber="415">South Africa</collectingCountry>
