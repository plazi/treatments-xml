<taxonomicName id="E3530B947B48F2F6DBE4B2B5E3870018" authority="(L.) Scop." class="Magnoliopsida" family="Asteraceae" genus="Cirsium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="421" phylum="Tracheophyta" rank="species" species="oleraceum">
