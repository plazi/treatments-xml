<subSubSection id="EF5F8E8C40B0B10E37DB0E12749B8629" pageId="null" pageNumber="152" type="description">
<paragraph id="D9209B9D03C61D93929D33C322DB5370" pageId="null" pageNumber="152">
Sporentragende und nicht sporentragende Triebe 
<emphasis id="BA7C1CF5565F1190B2F2314C40D48070" italics="true" pageId="null" pageNumber="152">gleich</emphasis>
, 20-70 cm hoch, 0,3-0,8 cm dick, 
<emphasis id="DA094B81DA1D6BB4925611CC9D8B5AC5" italics="true" pageId="null" pageNumber="152">
<normalizedToken id="9C8C088CF9E6B04BD17A1EA7FD969307" originalValue="grün" pageId="null" pageNumber="152">gruen</normalizedToken>
</emphasis>
, im 
<normalizedToken id="CCABF0E5568A43B421175E105A4BAF44" originalValue="Frühjahr" pageId="null" pageNumber="152">Fruehjahr</normalizedToken>
treibend und im Herbst absterbend, im untern Teil mit langen Seitentrieben. 
<emphasis id="D639E5EDCC4D9E3AB3A8C74E78797A49" italics="true" pageId="null" pageNumber="152">Haupttrieb mit 8-20 Rillen</emphasis>
, hohl (
<emphasis id="07781FC2C2ECA62D46FF1009E5B339BF" italics="true" pageId="null" pageNumber="152">Durchmesser des Hohlraumes</emphasis>
<normalizedToken id="0DFD5DEA6EB2497D6C185C11749BE57C" originalValue="½" pageId="null" pageNumber="152">1/2</normalizedToken>
-⅔ 
<emphasis id="302E561206B5A44472A4076E41BBD293" italics="true" pageId="null" pageNumber="152">des gesamten Durchmessers</emphasis>
)
<emphasis id="377212C7B9687DEAC51E38BA23C844ED" italics="true" pageId="null" pageNumber="152">;</emphasis>
Blattscheiden bis 1 cm lang, mit 8-20 
<normalizedToken id="9A858E5C55F6AAE2916BE7F92B6F228E" originalValue="Zähnen" pageId="null" pageNumber="152">Zaehnen</normalizedToken>
; 
<normalizedToken id="3AA07845362EED25515B8C877FFB93CB" originalValue="Zähne" pageId="null" pageNumber="152">Zaehne</normalizedToken>
<normalizedToken id="F150BD9CF1F541E7258CB2CD7778B408" originalValue="kürzer" pageId="null" pageNumber="152">kuerzer</normalizedToken>
als die Blattscheide, rotbraun mit 
<normalizedToken id="40371FA8CA6D2735FC7B50C3422B96CE" originalValue="weißlichem" pageId="null" pageNumber="152">weisslichem</normalizedToken>
Rand und 
<normalizedToken id="AF14DD8F886048682ED2CE89E274CD4C" originalValue="haarförmiger" pageId="null" pageNumber="152">haarfoermiger</normalizedToken>
, oft abbrechender Spitze. 
<emphasis id="C7C3388EBE952CA891305E8A73794899" italics="true" pageId="null" pageNumber="152">Unterstes Internodium der Seitentriebe etwa</emphasis>
⅓ 
<emphasis id="2B196462FE13F6ECFB096EF9F230ED3E" italics="true" pageId="null" pageNumber="152">
so lang wie die Blattscheiden des 
<normalizedToken id="ECCF47B78F8E032DE956B4A8D5A86CE8" originalValue="zugehörigen" pageId="null" pageNumber="152">zugehoerigen</normalizedToken>
Haupttriebes.
</emphasis>
<normalizedToken id="3FE04ACDB26D30B333258D6BC4A4034A" originalValue="Sporangienähren" pageId="null" pageNumber="152">Sporangienaehren</normalizedToken>
1-3 cm lang, 
<emphasis id="800154AA3733F5C0BD583EA49FE98380" italics="true" pageId="null" pageNumber="152">spitz.</emphasis>
- Sporenreife: 
<normalizedToken id="D02101858839ECFBBA17E2A6E9D0BB93" originalValue="Frühsommer" pageId="null" pageNumber="152">Fruehsommer</normalizedToken>
.
</paragraph>
<paragraph id="D9230F40D8F0695247BEADEF4D0293DB" pageId="null" pageNumber="152">
<emphasis id="AF28F71E4136C14C32599390A5697867" italics="true" pageId="null" pageNumber="152">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="8729AE13FF656EF331F2362D77C38AA5" italics="true" pageId="null" pageNumber="152">216:</emphasis>
Material aus Italien; Meiose normal (Manton 1960), von Darjeeling (Osthimalaja) und Musoorie (Westhimalaja) (Mehra und Bir 1959).
</paragraph>
<paragraph id="B1B98F4BF923D5C93F348168355AD1F9" pageId="null" pageNumber="152">
<emphasis id="432486D3D8267C877F413DAE02D121F5" italics="true" pageId="null" pageNumber="152">Standort.</emphasis>
Kollin und montan. Sandige, trockene, kalkhaltige, meist offene 
<normalizedToken id="EC58AC81CD6ACC82D6AE6EB1FA14B55F" originalValue="Böden" pageId="null" pageNumber="152">Boeden</normalizedToken>
an 
<normalizedToken id="CB2CA17B1A8FF4FC6B02530708C58D48" originalValue="Flußufern" pageId="null" pageNumber="152">Flussufern</normalizedToken>
in warmen Lagen. Anfangsstadien von Trockenwiesengesellschaften, 
<taxonomicName id="64122D04FE5C64CB393569BB9DC07BCC" class="Magnoliopsida" family="Tamaricaceae" genus="Myricaria" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="152" phylum="Tracheophyta" rank="genus">
<emphasis id="8A3BC76D86A669026EFDF8C9519D6249" italics="true" pageId="null" pageNumber="152">Myricaria</emphasis>
</taxonomicName>
-Gesellschaft.
</paragraph>
<paragraph id="B6B2FC4F1702E39A63FA2DCF9732931E" pageId="null" pageNumber="152">
<emphasis id="3202CF6F2918B947E6FE18674A867753" italics="true" pageId="null" pageNumber="152">Verbreitung. Pflanze mit weltweiter Verbreitung</emphasis>
(von 35° SB bis 55° NB): Mittel-, 
<normalizedToken id="7F6B99E9E87B89E513056C03A5C0909F" originalValue="Süd-" pageId="null" pageNumber="152">Sued-</normalizedToken>
und Osteuropa, isolierte Fundstellen in England, Holland und Norddeutschland, 
<normalizedToken id="ABAD2791D146833C06A32D35BCF5B0BE" originalValue="westwärts" pageId="null" pageNumber="152">westwaerts</normalizedToken>
auf die Kanarischen Inseln; Asien (zwischen 23 und 50° NB); Afrika (zerstreut) und Madagaskar; im westlichen Amerika von Britisch-Kolumbien 
<normalizedToken id="7CFA369A65FDA205A7F52CB222E6C714" originalValue="südwärts" pageId="null" pageNumber="152">suedwaerts</normalizedToken>
bis Chile. Verbreitungskarte von Hauke (1963). Auf der Karte von Meusel (1964) keine Angaben aus Amerika. - Im Gebiet zerstreut und selten (besonders Oberrheinische Tiefebene, zentral- und 
<normalizedToken id="049ADDF46666815B16577893C216F5EF" originalValue="südalpine" pageId="null" pageNumber="152">suedalpine</normalizedToken>
<normalizedToken id="BE39C900AE59ED1F8A79BA9046BDB90F" originalValue="Täler" pageId="null" pageNumber="152">Taeler</normalizedToken>
).
</paragraph>
</subSubSection>
