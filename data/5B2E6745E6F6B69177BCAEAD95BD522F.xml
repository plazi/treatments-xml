<subSubSection id="98AA1659E8F2080391C092E1ACCC7339" pageId="null" pageNumber="713" type="description">
<paragraph id="9D73D640A87EE5EA0CA7FB1A81E89F75" pageId="null" pageNumber="713">
Reich verzweigter, bis 1 m hoher Strauch. Zweige 
<normalizedToken id="BF083AF014DAD3ADC73152EC6EAAB93A" originalValue="aufwärts" pageId="null" pageNumber="713">aufwaerts</normalizedToken>
gerichtet. 
<emphasis id="6E397334B40A25DCE8C8A2CB10C0D7F5" italics="true" pageId="null" pageNumber="713">
<normalizedToken id="4D8738A32607788A10C26896DF25DCC8" originalValue="Blätter" pageId="null" pageNumber="713">Blaetter</normalizedToken>
<normalizedToken id="E6E07A83E94F95EEDE02896F1DAF7357" originalValue="immergrün" pageId="null" pageNumber="713">immergruen</normalizedToken>
</emphasis>
, lanzettlich, bis 2 cm lang, 4-8mal so lang wie breit, mit feiner, oft aufgesetzter Spitze, 1nervig. Pflanzen ♂ oder ♀ oder mit zwittrigen 
<normalizedToken id="5A0E3A13274CFF7474BFB271542AFF03" originalValue="Blüten" pageId="null" pageNumber="713">Blueten</normalizedToken>
. Unter jeder 
<normalizedToken id="D87FE0A666629D5E37AF54C10868C9E7" originalValue="Blüte" pageId="null" pageNumber="713">Bluete</normalizedToken>
3 
<normalizedToken id="EE63423C3C83AD678931B7B84BD76337" originalValue="kelchähnliche" pageId="null" pageNumber="713">kelchaehnliche</normalizedToken>
<normalizedToken id="EC257164C29FE524B028722F667B7ABB" originalValue="Hochblätter" pageId="null" pageNumber="713">Hochblaetter</normalizedToken>
vorhanden. 
<emphasis id="3ED8839A9650E10DEBAEFA2C8A68AF90" italics="true" pageId="null" pageNumber="713">
<normalizedToken id="29196782AC92655F57CCE06C040CB870" originalValue="Blüten" pageId="null" pageNumber="713">Blueten</normalizedToken>
3 
<normalizedToken id="1965F89E1571AA5184D8BB99CCF50416" originalValue="zählig" pageId="null" pageNumber="713">zaehlig</normalizedToken>
</emphasis>
, Perigon gelblich. Frucht kugelig, rot, wenig saftig. - 
<normalizedToken id="CE108E5A15F2E9468A38BD22BFDA70A0" originalValue="Blüte" pageId="null" pageNumber="713">Bluete</normalizedToken>
: 
<normalizedToken id="92355E9FAAA9A4F1EC9267FAEE0B00E5" originalValue="Frühling" pageId="null" pageNumber="713">Fruehling</normalizedToken>
und 
<normalizedToken id="225A2E499AB9B29EE6BAE7C9BFA38727" originalValue="früher" pageId="null" pageNumber="713">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="32ABF41AC03BDF1283E51542991114AF" pageId="null" pageNumber="713">
<emphasis id="23F74516104225B280ED4AAAB9D49E1C" italics="true" pageId="null" pageNumber="713">Zytologische Angaben. 2n wahrscheinlich 40:</emphasis>
Material aus dem Gebiet von Montpellier, 
<normalizedToken id="2FD89B6639F7D4E219A4C9CFE988AC82" originalValue="blütenmorphologische" pageId="null" pageNumber="713">bluetenmorphologische</normalizedToken>
und embryologische Untersuchungen (Schaeppi und Steindl 1937).
</paragraph>
<paragraph id="37B1CB266989A6D3BE969AF5519223A2" pageId="null" pageNumber="713">
<emphasis id="6D6A42BDD8E4CA312EB17A7493191DD1" italics="true" pageId="null" pageNumber="713">Standort.</emphasis>
Kollin. Trockene, sandige 
<normalizedToken id="401C06A55D76125997A8A10DC2109E69" originalValue="Böden" pageId="null" pageNumber="713">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="5207B2BB0F710B1B2F0EF1386F7C63BD" originalValue="Gebüsche" pageId="null" pageNumber="713">Gebuesche</normalizedToken>
, 
<normalizedToken id="C0912D8D7C4178272D8859EE56447203" originalValue="Wälder" pageId="null" pageNumber="713">Waelder</normalizedToken>
.
</paragraph>
<paragraph id="B222242F9344DCAA348A0DAA8F3008A9" pageId="null" pageNumber="713">
<emphasis id="F11BD78FA0E303B6EE7A82B569E593F7" italics="true" pageId="null" pageNumber="713">Verbreitung. Mediterrane Pflanze:</emphasis>
Ganzes Mittelmeergebiet. - Im Gebiet: 
<normalizedToken id="56423E5B399B268428360FE12A06D50D" originalValue="Dép" pageId="null" pageNumber="713">Dep</normalizedToken>
. Ain, Savoyen (vom 
<normalizedToken id="E85900E3EBA639A2BA4D5F56F0C4EA90" originalValue="Salève" pageId="null" pageNumber="713">Saleve</normalizedToken>
<normalizedToken id="E1BF5E96EB3E1E9C577EDF1C0C851C8F" originalValue="südwärts" pageId="null" pageNumber="713">suedwaerts</normalizedToken>
), Comerseegebiet.
</paragraph>
</subSubSection>
