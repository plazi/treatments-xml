<emphasis id="B9286A1799EFFF5401CBFDFEFC9AFD18" bold="true" box="[733,887,636,665]" pageId="164" pageNumber="777">Taxonomy.</emphasis>
<taxonomicName id="4C5CCD8699EFFF540085FDFEFC69FD41" authority="Zimmermann, 1783" authorityName="Zimmermann" authorityYear="1783" class="Mammalia" family="Bovidae" genus="Antilope" kingdom="Animalia" order="Artiodactyla" pageId="164" pageNumber="777" phylum="Chordata" rank="species" species="oreotragus">Antilope oreotragus Zimmermann, 1783</taxonomicName>
