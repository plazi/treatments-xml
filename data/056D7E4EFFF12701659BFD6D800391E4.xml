<subSubSection id="C5DE9CD3FFF12700659BFCD482D097F0" pageId="38" pageNumber="339" type="reference_group">
<paragraph id="8D7BCF58FFF12700659BFCD4828D93EB" blockId="38.[151,1437,837,1834]" pageId="38" pageNumber="339">
<taxonomicName id="4AC4B4DBFFF12700659BFCD483029373" authority="Pfeffer, 1893" authorityName="Pfeffer" authorityYear="1893" box="[151,538,837,863]" class="Amphibia" family="Hyperoliidae" genus="Rappia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="vermiculata">
<emphasis id="BFB0134AFFF12700659BFCD480609373" box="[151,376,837,863]" italics="true" pageId="38" pageNumber="339">Rappia vermiculata</emphasis>
<materialsCitation id="3DACC505FFF12700648EFCD783029373" ID-GBIF-Occurrence="3766067305" accessionNumber="ZMB 10988" box="[386,538,837,863]" collectionCode="ZMB" country="Zanzibar, Tanzania" location="Zanzibar, Tanzania" pageId="38" pageNumber="339" specimenCount="2" typeStatus="syntype">Pfeffer, 1893</materialsCitation>
</taxonomicName>
. 
<typeStatus id="527F71FAFFF127006724FCD7839C9373" box="[552,644,837,863]" pageId="38" pageNumber="339">Syntype</typeStatus>
<accessionNumber id="929752BBFFF127006781FCD782029373" box="[653,794,837,863]" httpUri="http://www.ncbi.nlm.nih.gov/protein/ZMB10988" pageId="38" pageNumber="339">ZMB 10988</accessionNumber>
(other ZMB 
<typeStatus id="527F71FAFFF1270066BBFCD785019373" box="[951,1049,837,863]" pageId="38" pageNumber="339">syntypes</typeStatus>
destroyed) “Sansibar (= 
<collectingCountry id="F5D38FC8FFF12700603CFCD7803693AF" isEnumeration="true" pageId="38" pageNumber="339">Zanzibar, Tanzania</collectingCountry>
) The name is preoccupied by 
<taxonomicName id="4AC4B4DBFFF127006773FCFA853F93AE" authority="Peters, 1882" authorityName="Peters" authorityYear="1882" box="[639,1063,872,898]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="vermiculatus">
<emphasis id="BFB0134AFFF127006773FCFA828B93AE" box="[639,915,872,898]" italics="true" pageId="38" pageNumber="339">Hyperolius vermiculatus</emphasis>
Peters, 1882
</taxonomicName>
, and so is not available, although it appears to be the oldest name for this taxon. Above brown with many small yellow flecks. A dark band runs from eye to snout tip. Eyelid very dark with thin yellow margin.
</paragraph>
<paragraph id="8D7BCF58FFF12700659BFC428216947E" blockId="38.[151,1437,837,1834]" pageId="38" pageNumber="339">
<taxonomicName id="4AC4B4DBFFF12700659BFC4283B293C6" authority="Barbour &amp; Loveridge, 1928" authorityName="Barbour &amp; Loveridge" authorityYear="1928" box="[151,682,976,1002]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="mariae">
<emphasis id="BFB0134AFFF12700659BFC42807093C5" box="[151,360,976,1002]" italics="true" pageId="38" pageNumber="339">Hyperolius mariae</emphasis>
Barbour &amp; Loveridge, 1928
</taxonomicName>
. 
<accessionNumber id="929752BBFFF1270067B8FC42825993C5" box="[692,833,975,1002]" httpUri="http://www.ncbi.nlm.nih.gov/protein/MCZ13267" pageId="38" pageNumber="339">MCZ 13267</accessionNumber>
, “near the mill dam at Derema, Usambara Mtns., 
<collectingCountry id="F5D38FC8FFF127006065FC4280949420" name="Tanzania" pageId="38" pageNumber="339">Tanganyika Territory</collectingCountry>
” 
<collectingCountry id="F5D38FC8FFF127006497FC60831B9420" box="[411,515,1010,1036]" name="Tanzania" pageId="38" pageNumber="339">Tanzania</collectingCountry>
. Colour in life: Above uniform greyish-white, with a black speck on snout, nostrils ringed with black, edge of upper eyelid black. A broad cream-coloured stripe laterally with a broad black one below it. Lower lip with red marks, belly blood-red.
</paragraph>
<paragraph id="8D7BCF58FFF12700659BFBC8850494BB" blockId="38.[151,1437,837,1834]" pageId="38" pageNumber="339">
<taxonomicName id="4AC4B4DBFFF12700659BFBC880B49458" authorityName="Ahl" authorityYear="1931" box="[151,428,1114,1140]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="callichromus">
<emphasis id="BFB0134AFFF12700659BFBC880B49458" box="[151,428,1114,1140]" italics="true" pageId="38" pageNumber="339">Hyperolius callichromus</emphasis>
</taxonomicName>
<materialsCitation id="3DACC505FFF1270064B9FBC982159458" ID-GBIF-Occurrence="3766067304" box="[437,781,1114,1141]" location="Dar es Salaam" pageId="38" pageNumber="339" specimenCount="1" stateProvince="Dar es Salaam" typeStatus="paratype">
<typeStatus id="527F71FAFFF1270064B9FBC983389459" box="[437,544,1115,1141]" pageId="38" pageNumber="339">paratypes</typeStatus>
from 
<collectingRegion id="4F0001BAFFF127006764FBC982159458" box="[616,781,1114,1141]" country="Tanzania" name="Dar es Salaam" pageId="38" pageNumber="339">Dar es Salaam</collectingRegion>
</materialsCitation>
<materialsCitation id="3DACC505FFF12700661AFBC9850094BB" ID-GBIF-Occurrence="3766067302" collectionCode="ZMB" location="Dar es Salaam" pageId="38" pageNumber="339" specimenCode="ZMB 85869-85872" specimenCount="1" stateProvince="Dar es Salaam" typeStatus="paratype">
<specimenCode id="DD626723FFF12700661AFBC982ED9459" box="[790,1013,1114,1141]" collectionCode="ZMB" country="Germany" httpUri="http://grbio.org/cool/8syf-d21i" name="Museum für Naturkunde Berlin (Zoological Collections)" pageId="38" pageNumber="339" type="Museum">ZMB 85869–85872</specimenCode>
(
<bibRefCitation id="E955B2A9FFF127006109FBC885C49458" author="Tillack" box="[1029,1244,1114,1141]" etAl="et al." firstAuthor="Tillack" pageId="38" pageNumber="339" pagination="407 - 450" refId="ref34684" refString="Tillack, F., De Ruiter, R. &amp; Rodel, M. - O. (2021) A type catalogue of the reed frogs (Amphibia, Anura, Hyperoliidae) in the collection of the Museum fur Naturkunde Berlin (ZMB) with comments on historical collectors and expeditions. Zoosystematics and Evolution, 97, 407 - 450. https: // doi. org / 10.3897 / zse. 97.68000" type="journal article" year="2021">
Tillack 
<emphasis id="BFB0134AFFF127006152FBC985899458" box="[1118,1169,1114,1140]" italics="true" pageId="38" pageNumber="339">et al</emphasis>
. 2021
</bibRefCitation>
), are assigned as synonyms of 
<taxonomicName id="4AC4B4DBFFF127006452FBEC80D794BB" authorityName="Barbour &amp; Loveridge" authorityYear="1928" box="[350,463,1150,1175]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="mariae">
<emphasis id="BFB0134AFFF127006452FBEC80D794BB" box="[350,463,1150,1175]" italics="true" pageId="38" pageNumber="339">H. mariae</emphasis>
</taxonomicName>
as this is the only clade known from 
<collectingRegion id="4F0001BAFFF12700667FFBEF850094BB" box="[883,1048,1149,1175]" country="Tanzania" name="Dar es Salaam" pageId="38" pageNumber="339">Dar es Salaam</collectingRegion>
</materialsCitation>
.
</paragraph>
<paragraph id="8D7BCF58FFF12700659BFB328548950E" blockId="38.[151,1437,837,1834]" pageId="38" pageNumber="339">
<taxonomicName id="4AC4B4DBFFF12700659BFB32833B9496" authority="Ahl, 1931" authorityName="Ahl" authorityYear="1931" box="[151,547,1184,1210]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="vermicularis">
<emphasis id="BFB0134AFFF12700659BFB3280B19496" box="[151,425,1184,1210]" italics="true" pageId="38" pageNumber="339">Hyperolius vermicularis</emphasis>
<bibRefCitation id="E955B2A9FFF1270064A3FB32833B9496" author="Ahl" box="[431,547,1184,1210]" firstAuthor="Ahl" pageId="38" pageNumber="339" pagination="1 - 132" refId="ref28575" refString="Ahl, E. (1931) Zur Systematik der afrikanischen Arten der Baumfroschgattung Hyperolius (Amph. Anur.). Mitteilungen aus dem Zoologischen Museum in Berlin, 17, 1 - 132." type="journal article" year="1931">Ahl, 1931</bibRefCitation>
</taxonomicName>
. 
<accessionNumber id="929752BBFFF127006723FB3283A49496" box="[559,700,1184,1210]" httpUri="http://www.ncbi.nlm.nih.gov/protein/ZMB10988" pageId="38" pageNumber="339">ZMB 10988</accessionNumber>
, 
<collectingCountry id="F5D38FC8FFF1270067C4FB3282359496" box="[712,813,1184,1210]" name="Tanzania" pageId="38" pageNumber="339">Zanzibar</collectingCountry>
, 
<collectingCountry id="F5D38FC8FFF127006635FB3282B99496" box="[825,929,1184,1210]" name="Tanzania" pageId="38" pageNumber="339">Tanzania</collectingCountry>
. (Replacement name for 
<taxonomicName id="4AC4B4DBFFF1270061B2FB32804594F0" authority="Pfeffer, 1893" authorityName="Pfeffer" authorityYear="1893" class="Amphibia" family="Hyperoliidae" genus="Rappia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="vermiculata">
<emphasis id="BFB0134AFFF1270061B2FB3284849496" box="[1214,1436,1184,1210]" italics="true" pageId="38" pageNumber="339">Rappia vermiculata</emphasis>
Pfeffer, 1893
</taxonomicName>
). Only the 
<taxonomicName id="4AC4B4DBFFF1270064D5FB51835294F0" authorityName="Barbour &amp; Loveridge" authorityYear="1928" box="[473,586,1219,1244]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="mariae">
<emphasis id="BFB0134AFFF1270064D5FB51835294F0" box="[473,586,1219,1244]" italics="true" pageId="38" pageNumber="339">H. mariae</emphasis>
</taxonomicName>
clade is known from 
<collectingCountry id="F5D38FC8FFF127006632FB5082BC94F0" box="[830,932,1218,1244]" name="Tanzania" pageId="38" pageNumber="339">Zanzibar</collectingCountry>
. Sequences from the adjacent mainland form part of the clade. Above brown with very many small yellow flecks, forming vermiculation. A dark band from snout tip to eye, eyelid with a thin yellow margin, tibia with small dark speckles.
</paragraph>
<paragraph id="8D7BCF58FFF12700659BFAB882EA95A6" blockId="38.[151,1437,837,1834]" pageId="38" pageNumber="339">
<taxonomicName id="4AC4B4DBFFF12700659BFAB883549568" authority="Ahl, 1931" authorityName="Ahl" authorityYear="1931" box="[151,588,1322,1348]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="melanopthalmus">
<emphasis id="BFB0134AFFF12700659BFAB880CB9568" box="[151,467,1322,1348]" italics="true" pageId="38" pageNumber="339">Hyperolius melanopthalmus</emphasis>
<bibRefCitation id="E955B2A9FFF1270064D5FAB883549568" author="Ahl" box="[473,588,1322,1348]" firstAuthor="Ahl" pageId="38" pageNumber="339" pagination="1 - 132" refId="ref28575" refString="Ahl, E. (1931) Zur Systematik der afrikanischen Arten der Baumfroschgattung Hyperolius (Amph. Anur.). Mitteilungen aus dem Zoologischen Museum in Berlin, 17, 1 - 132." type="journal article" year="1931">Ahl, 1931</bibRefCitation>
</taxonomicName>
. 
<accessionNumber id="929752BBFFF127006754FAB983FB9569" box="[600,739,1322,1349]" httpUri="http://www.ncbi.nlm.nih.gov/protein/ZMB85670" pageId="38" pageNumber="339">ZMB 85670</accessionNumber>
–85672, “ 
<collectingCountry id="F5D38FC8FFF127006642FAB882AE9568" box="[846,950,1322,1348]" name="Tanzania" pageId="38" pageNumber="339">Sansibar</collectingCountry>
”, (
<collectingCountry id="F5D38FC8FFF1270066DFFAB885229568" box="[979,1082,1322,1348]" name="Tanzania" pageId="38" pageNumber="339">Zanzibar</collectingCountry>
, 
<collectingCountry id="F5D38FC8FFF127006149FAB885B79569" box="[1093,1199,1322,1349]" name="Tanzania" pageId="38" pageNumber="339">Tanzania</collectingCountry>
). Synonymy by 
<bibRefCitation id="E955B2A9FFF12700606AFAB9807B9544" author="Loveridge" firstAuthor="Loveridge" pageId="38" pageNumber="339" pagination="369 - 430" refId="ref32561" refString="Loveridge, A. (1936) Scientific results of an expedition to rain forest regions in eastern Africa. VII. Amphibians. Bulletin of the Museum of Comparative Zoology, 79, 369 - 430." type="journal article" year="1936">Loveridge (1936)</bibRefCitation>
. Colour in alcohol: Above pale grey, nostrils ringed with black, upper eyelid with dark fleck. A broad lateral dark or violet band between the limbs, sometimes marbled.
</paragraph>
<paragraph id="8D7BCF58FFF12700659BFA0082B895E3" blockId="38.[151,1437,837,1834]" pageId="38" pageNumber="339">
<taxonomicName id="4AC4B4DBFFF12700659BFA0080E99580" authority="Ahl, 1931" authorityName="Ahl" authorityYear="1931" box="[151,497,1426,1452]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="rubripes">
<emphasis id="BFB0134AFFF12700659BFA0080619580" box="[151,377,1426,1452]" italics="true" pageId="38" pageNumber="339">Hyperolius rubripes</emphasis>
<bibRefCitation id="E955B2A9FFF127006472FA0080E99580" author="Ahl" box="[382,497,1426,1452]" firstAuthor="Ahl" pageId="38" pageNumber="339" pagination="1 - 132" refId="ref28575" refString="Ahl, E. (1931) Zur Systematik der afrikanischen Arten der Baumfroschgattung Hyperolius (Amph. Anur.). Mitteilungen aus dem Zoologischen Museum in Berlin, 17, 1 - 132." type="journal article" year="1931">Ahl, 1931</bibRefCitation>
</taxonomicName>
. 
<accessionNumber id="929752BBFFF1270064F1FA01839D9580" box="[509,645,1426,1453]" httpUri="http://www.ncbi.nlm.nih.gov/protein/ZMB36110" pageId="38" pageNumber="339">ZMB 36110</accessionNumber>
and 57530, “Kililana”, 
<collectingCountry id="F5D38FC8FFF12700669EFA0182C79581" box="[914,991,1427,1453]" name="Kenya" pageId="38" pageNumber="339">Kenya</collectingCountry>
. Synonymy by 
<bibRefCitation id="E955B2A9FFF127006180FA0084819580" author="Wieczorek" box="[1164,1433,1426,1453]" etAl="et al." firstAuthor="Wieczorek" pageId="38" pageNumber="339" pagination="155 - 166" refId="ref35260" refString="Wieczorek, A., Drewes, R. C. &amp; Channing, A. (2000) Phylogenetic relationships within the Hyperolius viridiflavus complex (Anura: Hyperoliidae), and comments on taxonomic status. Amphibia-Reptilia, 22, 155 - 166. https: // doi. org / 10.1163 / 15685380152030382" type="journal article" year="2000">
Wieczorek 
<emphasis id="BFB0134AFFF127006007FA0184259580" box="[1291,1341,1426,1452]" italics="true" pageId="38" pageNumber="339">et al</emphasis>
. (2000)
</bibRefCitation>
. Colour in alcohol: Above uniform pale yellow, pink or brownish.
</paragraph>
<paragraph id="8D7BCF58FFF12700659BFA4A82F79638" blockId="38.[151,1437,837,1834]" pageId="38" pageNumber="339">
<taxonomicName id="4AC4B4DBFFF12700659BFA4A80F395DE" authority="Ahl, 1931" authorityName="Ahl" authorityYear="1931" box="[151,491,1496,1522]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="renschi">
<emphasis id="BFB0134AFFF12700659BFA4A807595DE" box="[151,365,1496,1522]" italics="true" pageId="38" pageNumber="339">Hyperolius renschi</emphasis>
<bibRefCitation id="E955B2A9FFF127006479FA4A80F395DE" author="Ahl" box="[373,491,1496,1522]" firstAuthor="Ahl" pageId="38" pageNumber="339" pagination="1 - 132" refId="ref28575" refString="Ahl, E. (1931) Zur Systematik der afrikanischen Arten der Baumfroschgattung Hyperolius (Amph. Anur.). Mitteilungen aus dem Zoologischen Museum in Berlin, 17, 1 - 132." type="journal article" year="1931">Ahl, 1931</bibRefCitation>
</taxonomicName>
. ZMB 
<typeStatus id="527F71FAFFF127006732FA4A837695DE" box="[574,622,1496,1522]" pageId="38" pageNumber="339">type</typeStatus>
lost (
<bibRefCitation id="E955B2A9FFF1270067BDFA4A829095DE" author="Tillack" box="[689,904,1496,1522]" etAl="et al." firstAuthor="Tillack" pageId="38" pageNumber="339" pagination="407 - 450" refId="ref34684" refString="Tillack, F., De Ruiter, R. &amp; Rodel, M. - O. (2021) A type catalogue of the reed frogs (Amphibia, Anura, Hyperoliidae) in the collection of the Museum fur Naturkunde Berlin (ZMB) with comments on historical collectors and expeditions. Zoosystematics and Evolution, 97, 407 - 450. https: // doi. org / 10.3897 / zse. 97.68000" type="journal article" year="2021">
Tillack 
<emphasis id="BFB0134AFFF127006607FA4A822795DE" box="[779,831,1496,1522]" italics="true" pageId="38" pageNumber="339">et al</emphasis>
. 2021
</bibRefCitation>
) 
<collectingCountry id="F5D38FC8FFF127006696FA4A82E795DE" box="[922,1023,1496,1522]" name="Tanzania" pageId="38" pageNumber="339">Zanzibar</collectingCountry>
, 
<collectingCountry id="F5D38FC8FFF127006100FA4A856C95DE" box="[1036,1140,1496,1522]" name="Tanzania" pageId="38" pageNumber="339">Tanzania</collectingCountry>
. Synonymy by 
<bibRefCitation id="E955B2A9FFF127006025FA4A800D9639" author="Loveridge" firstAuthor="Loveridge" pageId="38" pageNumber="339" pagination="369 - 430" refId="ref32561" refString="Loveridge, A. (1936) Scientific results of an expedition to rain forest regions in eastern Africa. VII. Amphibians. Bulletin of the Museum of Comparative Zoology, 79, 369 - 430." type="journal article" year="1936">Loveridge (1936)</bibRefCitation>
. Colour in alcohol: Above pale yellow, with a lateral violet band.
</paragraph>
<paragraph id="8D7BCF58FFF12700659BF98F831C96C8" blockId="38.[151,1437,837,1834]" pageId="38" pageNumber="339">
<taxonomicName id="4AC4B4DBFFF12700659BF98F83A1961B" authority="Laurent, 1961" authorityName="Laurent" authorityYear="1961" box="[151,697,1565,1591]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="subSpecies" species="marmoratus" subSpecies="mafianus">
<emphasis id="BFB0134AFFF12700659BF98F8309961B" box="[151,529,1565,1591]" italics="true" pageId="38" pageNumber="339">Hyperolius marmoratus mafianus</emphasis>
<bibRefCitation id="E955B2A9FFF127006714F98F83A1961B" author="Laurent" box="[536,697,1565,1591]" firstAuthor="Laurent" pageId="38" pageNumber="339" pagination="65 - 96" refId="ref32027" refString="Laurent, R. F. (1961) Note sur les Hyperolius et quelques Afrixalus (Salientia) du Musee de Berlin. Revue de Zoologie et de Botanique Africaines, 64, 65 - 96." type="journal article" year="1961">Laurent, 1961</bibRefCitation>
</taxonomicName>
. BMNH 1937.7.1.42–44, This is a new name for specimens of 
<taxonomicName id="4AC4B4DBFFF12700608DF98C80BC9676" authority="Ahl, 1931" authorityName="Ahl" authorityYear="1931" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="albifrons">
<emphasis id="BFB0134AFFF12700608DF98C80339676" italics="true" pageId="38" pageNumber="339">H. albifrons</emphasis>
<bibRefCitation id="E955B2A9FFF12700643DF9D280BC9676" author="Ahl" box="[305,420,1600,1626]" firstAuthor="Ahl" pageId="38" pageNumber="339" pagination="1 - 132" refId="ref28575" refString="Ahl, E. (1931) Zur Systematik der afrikanischen Arten der Baumfroschgattung Hyperolius (Amph. Anur.). Mitteilungen aus dem Zoologischen Museum in Berlin, 17, 1 - 132." type="journal article" year="1931">Ahl, 1931</bibRefCitation>
</taxonomicName>
, from Mafia Island, reported on by 
<bibRefCitation id="E955B2A9FFF12700663BF9D282CC9676" author="Parker" box="[823,980,1600,1626]" firstAuthor="Parker" pageId="38" pageNumber="339" pagination="629 - 632" refId="ref33059" refString="Parker, H. W. (1937) Reptiles and amphibians from the Mafia Archipelago. Annals and Magazine of Natural History, Series 10, 20, 629 - 632. https: // doi. org / 10.1080 / 00222933708655396" type="journal article" year="1937">Parker (1937)</bibRefCitation>
. Only one clade is known from northern coastal 
<collectingCountry id="F5D38FC8FFF127006411F9F0809D9650" box="[285,389,1634,1660]" name="Tanzania" pageId="38" pageNumber="339">Tanzania</collectingCountry>
. Back and sides yellowish-brown. Upper surface of snout silvery-white or yellowish-green, extending back to the eyes, continuing as lateral stripes to the level of the shoulder. The lateral stripes may branch to form a dorsal marbling, or may unite over the coccyx.A dark subdermal lateral band is present. Limbs the same colour as the back.
</paragraph>
<paragraph id="8D7BCF58FFF12700659BF97F82849706" blockId="38.[151,1437,837,1834]" pageId="38" pageNumber="339">
<taxonomicName id="4AC4B4DBFFF12700659BF97F830C972B" authority="Ahl, 1931" authorityName="Ahl" authorityYear="1931" box="[151,532,1773,1799]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="udjidjiensis">
<emphasis id="BFB0134AFFF12700659BF97F8084972B" box="[151,412,1773,1799]" italics="true" pageId="38" pageNumber="339">Hyperolius udjidjiensis</emphasis>
<bibRefCitation id="E955B2A9FFF1270064AFF97F830C972B" author="Ahl" box="[419,532,1773,1799]" firstAuthor="Ahl" pageId="38" pageNumber="339" pagination="1 - 132" refId="ref28575" refString="Ahl, E. (1931) Zur Systematik der afrikanischen Arten der Baumfroschgattung Hyperolius (Amph. Anur.). Mitteilungen aus dem Zoologischen Museum in Berlin, 17, 1 - 132." type="journal article" year="1931">Ahl, 1931</bibRefCitation>
</taxonomicName>
was removed from the synonymy of 
<taxonomicName id="4AC4B4DBFFF1270066CDF97C852C972B" authorityName="Barbour &amp; Loveridge" authorityYear="1928" box="[961,1076,1774,1799]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="mariae">
<emphasis id="BFB0134AFFF1270066CDF97C852C972B" box="[961,1076,1774,1799]" italics="true" pageId="38" pageNumber="339">H. mariae</emphasis>
</taxonomicName>
and placed in the synonymy of 
<taxonomicName id="4AC4B4DBFFF1270065CBF882837B9706" authority="Gunther, 1858" authorityName="Gunther" authorityYear="1858" box="[199,611,1807,1834]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="parallelus">
<emphasis id="BFB0134AFFF1270065CBF88280A49706" box="[199,444,1808,1834]" italics="true" pageId="38" pageNumber="339">Hyperolius parallelus</emphasis>
Günther, 1858
</taxonomicName>
by 
<bibRefCitation id="E955B2A9FFF127006780F88282809706" author="Wieczorek" box="[652,920,1808,1834]" etAl="et al." firstAuthor="Wieczorek" pageId="38" pageNumber="339" pagination="155 - 166" refId="ref35260" refString="Wieczorek, A., Drewes, R. C. &amp; Channing, A. (2000) Phylogenetic relationships within the Hyperolius viridiflavus complex (Anura: Hyperoliidae), and comments on taxonomic status. Amphibia-Reptilia, 22, 155 - 166. https: // doi. org / 10.1163 / 15685380152030382" type="journal article" year="2000">
Wieczorek 
<emphasis id="BFB0134AFFF127006607F88282259706" box="[779,829,1808,1834]" italics="true" pageId="38" pageNumber="339">et al</emphasis>
. (2000)
</bibRefCitation>
.
</paragraph>
<paragraph id="8D7BCF58FFF12700659BF8C482D097F0" blockId="38.[151,1436,1878,2013]" pageId="38" pageNumber="339">
Sequences were available from Mafia Island (as 
<taxonomicName id="4AC4B4DBFFF1270067B0F8C58236975C" authorityName="Barbour &amp; Loveridge" authorityYear="1928" box="[700,814,1879,1904]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="mariae">
<emphasis id="BFB0134AFFF1270067B0F8C58236975C" box="[700,814,1879,1904]" italics="true" pageId="38" pageNumber="339">H. mariae</emphasis>
</taxonomicName>
and 
<taxonomicName id="4AC4B4DBFFF127006669F8C58546975C" authorityName="Barbour and Loveridge" authorityYear="1928" box="[869,1118,1878,1904]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="subSpecies" species="viridiflavus" subSpecies="mariae">
<emphasis id="BFB0134AFFF127006669F8C58546975C" box="[869,1118,1878,1904]" italics="true" pageId="38" pageNumber="339">H. viridiflavus mariae</emphasis>
</taxonomicName>
) and Mtai Forest, 
<collectingCountry id="F5D38FC8FFF12700603CF8C48480975C" box="[1328,1432,1878,1904]" name="Tanzania" pageId="38" pageNumber="339">Tanzania</collectingCountry>
; Arabuko Sokoke, 
<collectingCountry id="F5D38FC8FFF12700646DF8E980B297B9" box="[353,426,1915,1941]" name="Kenya" pageId="38" pageNumber="339">Kenya</collectingCountry>
(as 
<taxonomicName id="4AC4B4DBFFF1270064DBF8E983D697B8" authorityName="Barbour and Loveridge" authorityYear="1928" box="[471,718,1914,1940]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="subSpecies" species="viridiflavus" subSpecies="mariae">
<emphasis id="BFB0134AFFF1270064DBF8E983D697B8" box="[471,718,1914,1940]" italics="true" pageId="38" pageNumber="339">H. viridiflavus mariae</emphasis>
</taxonomicName>
and 
<taxonomicName id="4AC4B4DBFFF12700660FF8E9828497B8" authorityName="Ahl" authorityYear="1931" box="[771,924,1914,1940]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="variety" species="viridiflavus" variety="rubripes">
<emphasis id="BFB0134AFFF12700660FF8E9828497B8" box="[771,924,1914,1940]" italics="true" pageId="38" pageNumber="339">H. v. rubripes</emphasis>
</taxonomicName>
). The minimum uncorrected 
<emphasis id="BFB0134AFFF1270061EDF8E985E097B8" box="[1249,1272,1915,1940]" italics="true" pageId="38" pageNumber="339">p-</emphasis>
distances from other clades were 4.0–6.5% (
<tableCitation id="C046FAE3FFF1270064D5F80C83299794" box="[473,561,1950,1976]" captionStart="TABLE 2" captionStartId="20.[151,239,762,788]" captionTargetPageId="20" captionText="TABLE 2. Uncorrected minimum p-distances as percentages between the clades. GOE—Hyperolius goetzei, NOB—H. noblei, MAR—H. mariae, VIR—H. viridiflavus, GLA— H. glandicolor, MAG—H. marginatus, TUB—H. tuberculosa, BAN—H. bangwae, DIN—H. dintelmanni, MOR—H. marmoratus, NIT—H. nitidulus, SPA—H. spatzi, PAR—H. parallelus." httpUri="http://table.plazi.org/id/D9BB9FD0FFC32732659BFD6880129370" pageId="38" pageNumber="339" tableUuid="D9BB9FD0FFC32732659BFD6880129370">Table 2</tableCitation>
). The sample occurs in coastal 
<collectingCountry id="F5D38FC8FFF127006687F80C82E89794" box="[907,1008,1950,1976]" name="Tanzania" pageId="38" pageNumber="339">Tanzania</collectingCountry>
and 
<collectingCountry id="F5D38FC8FFF127006129F80D85769795" box="[1061,1134,1951,1977]" name="Kenya" pageId="38" pageNumber="339">Kenya</collectingCountry>
(
<figureCitation id="15FFD3DDFFF127006171F80C85CC9794" box="[1149,1236,1950,1976]" captionStart="FIGURE 9" captionStartId="38.[151,250,638,662]" captionTargetBox="[151,1436,181,615]" captionTargetId="figure-33@38.[151,1436,181,615]" captionTargetPageId="38" captionText="FIGURE 9. Localities of sequences (black circles), type localities (stars) and location of junior synonyms of Hyperolius bangwae (A), H. tuberculatus (B), and H. glandicolor (C). Locality codes are explained in Table 3." figureDoi="http://doi.org/10.5281/zenodo.6538298" httpUri="https://zenodo.org/record/6538298/files/figure.png" pageId="38" pageNumber="339">Fig. 9C</figureCitation>
). The localities of taxa now regarded as junior synonyms of 
<taxonomicName id="4AC4B4DBFFF127006760F85183C597F0" authorityName="Barbour &amp; Loveridge" authorityYear="1928" box="[620,733,1987,2012]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="38" pageNumber="339" phylum="Chordata" rank="species" species="mariae">
<emphasis id="BFB0134AFFF127006760F85183C597F0" box="[620,733,1987,2012]" italics="true" pageId="38" pageNumber="339">H. mariae</emphasis>
</taxonomicName>
are listed in 
<tableCitation id="C046FAE3FFF127006662F85082DB97F0" box="[878,963,1986,2012]" captionStart="TABLE 3" captionStartId="43.[151,239,151,175]" captionTargetPageId="43" captionText="TABLE 3. Codes, localities and co-ordinates for the types and taxa now regarded as junior synonyms of the Hyperolius species, used in figs. 4–10." httpUri="http://table.plazi.org/id/D9BB9FD0FFFC270D659BFF0580AE90FF" pageId="38" pageNumber="339" tableUuid="D9BB9FD0FFFC270D659BFF0580AE90FF">Table 3</tableCitation>
.
</paragraph>
</subSubSection>
<subSubSection id="C5DE9CD3FFF0270165CBFF05800391E4" pageId="39" pageNumber="340" type="description">
<paragraph id="8D7BCF58FFF0270165CBFF0583A890DB" blockId="39.[151,1437,151,456]" pageId="39" pageNumber="340">
The most common pattern elements in the descriptions of the 
<typeStatus id="527F71FAFFF02701667AFF0582A9909D" box="[886,945,151,177]" pageId="39" pageNumber="340">types</typeStatus>
included in 
<taxonomicName id="4AC4B4DBFFF027016137FF0585B4909C" authorityName="Barbour &amp; Loveridge" authorityYear="1928" box="[1083,1196,151,176]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="39" pageNumber="340" phylum="Chordata" rank="species" species="mariae">
<emphasis id="BFB0134AFFF027016137FF0585B4909C" box="[1083,1196,151,176]" italics="true" pageId="39" pageNumber="340">H. mariae</emphasis>
</taxonomicName>
are various markings on the head such as black-ringed nostrils (50%), followed by a dark lateral band (33%). The percentages are not additive, as the pattern elements may be shared.
</paragraph>
<paragraph id="8D7BCF58FFF0270165CBFE92800391E4" blockId="39.[151,1437,151,456]" pageId="39" pageNumber="340">
Advertisement calls from Mikumi, 
<collectingCountry id="F5D38FC8FFF027016755FE9283A69136" box="[601,702,256,282]" name="Tanzania" pageId="39" pageNumber="340">Tanzania</collectingCountry>
(no vouchers), show a series of brief notes, with an emphasised frequency of about 3200 Hz, and a note rate of 5 
<superScript id="7AB16210FFF0270167B1FEB183CD911C" attach="left" box="[701,725,290,317]" fontSize="6" pageId="39" pageNumber="340">s-1</superScript>
(
<bibRefCitation id="E955B2A9FFF0270167E8FEB182649111" author="Schiotz" box="[740,892,290,317]" firstAuthor="Schiotz" pageId="39" pageNumber="340" refId="ref34189" refString="Schiotz, A. (1975) The treefrogs of Eastern Africa. Steenstrupia, Copenhagen, 232 pp." type="book" year="1975">Schiøtz 1975</bibRefCitation>
, 
<bibRefCitation id="E955B2A9FFF02701668BFEB182A79111" author="Schiotz" box="[903,959,291,317]" firstAuthor="Schiotz" pageId="39" pageNumber="340" refId="ref34233" refString="Schiotz, A. (1999) Treefrogs of Africa. Edition Chimaira, Frankfurt am Main, 350 pp." type="book" year="1999">1999</bibRefCitation>
as 
<taxonomicName id="4AC4B4DBFFF0270166E8FEB185759110" authorityName="Barbour and Loveridge" authorityYear="1928" box="[996,1133,291,316]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="39" pageNumber="340" phylum="Chordata" rank="variety" species="viridiflavus" variety="mariae">
<emphasis id="BFB0134AFFF0270166E8FEB185759110" box="[996,1133,291,316]" italics="true" pageId="39" pageNumber="340">H. v. mariae</emphasis>
</taxonomicName>
). This is similar to another call (no voucher) from the same locality (
<bibRefCitation id="E955B2A9FFF027016777FED782229173" author="Pickersgill" box="[635,826,325,351]" firstAuthor="Pickersgill" pageId="39" pageNumber="340" refId="ref33175" refString="Pickersgill, M. (2007) Frog Search. Edition Chimaira, Frankfurt am Main, 574 pp." type="book" year="2007">Pickersgill 2007</bibRefCitation>
, as 
<taxonomicName id="4AC4B4DBFFF027016665FED482C59173" authorityName="Barbour &amp; Loveridge" authorityYear="1928" box="[873,989,326,351]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="39" pageNumber="340" phylum="Chordata" rank="species" species="mariae">
<emphasis id="BFB0134AFFF027016665FED482C59173" box="[873,989,326,351]" italics="true" pageId="39" pageNumber="340">H. mariae</emphasis>
</taxonomicName>
). A call from Kingupira, 
<collectingCountry id="F5D38FC8FFF027016004FED784759173" box="[1288,1389,325,351]" name="Tanzania" pageId="39" pageNumber="340">Tanzania</collectingCountry>
(no voucher) has an emphasised frequency of 2750 Hz (
<bibRefCitation id="E955B2A9FFF0270167D4FEFA827791AF" author="Schiotz" box="[728,879,360,387]" firstAuthor="Schiotz" pageId="39" pageNumber="340" refId="ref34189" refString="Schiotz, A. (1975) The treefrogs of Eastern Africa. Steenstrupia, Copenhagen, 232 pp." type="book" year="1975">Schiøtz 1975</bibRefCitation>
, as 
<taxonomicName id="4AC4B4DBFFF02701669BFEFB852091AE" authorityName="Peters" authorityYear="1854" box="[919,1080,361,386]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="39" pageNumber="340" phylum="Chordata" rank="species" species="marginatus">
<emphasis id="BFB0134AFFF02701669BFEFB852091AE" box="[919,1080,361,386]" italics="true" pageId="39" pageNumber="340">H. marginatus</emphasis>
</taxonomicName>
), similar to calls from 
<collectingRegion id="4F0001BAFFF027016039FEFB848091AF" box="[1333,1432,361,387]" country="Malawi" name="Karonga" pageId="39" pageNumber="340">Karonga</collectingRegion>
, 
<collectingCountry id="F5D38FC8FFF02701659BFE1981F59189" box="[151,237,395,421]" name="Malawi" pageId="39" pageNumber="340">Malawi</collectingCountry>
(no vouchers) (
<bibRefCitation id="E955B2A9FFF027016491FE1983789189" author="Pickersgill" box="[413,608,395,421]" firstAuthor="Pickersgill" pageId="39" pageNumber="340" refId="ref33175" refString="Pickersgill, M. (2007) Frog Search. Edition Chimaira, Frankfurt am Main, 574 pp." type="book" year="2007">Pickersgill, 2007</bibRefCitation>
, as 
<taxonomicName id="4AC4B4DBFFF027016785FE19821C9188" authorityName="Ahl" authorityYear="1931" box="[649,772,395,420]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="39" pageNumber="340" phylum="Chordata" rank="species" species="nyassae">
<emphasis id="BFB0134AFFF027016785FE19821C9188" box="[649,772,395,420]" italics="true" pageId="39" pageNumber="340">H. nyassae</emphasis>
</taxonomicName>
) and Bububu, 
<collectingCountry id="F5D38FC8FFF0270166A6FE1985169189" box="[938,1038,395,421]" name="Tanzania" pageId="39" pageNumber="340">Zanzibar</collectingCountry>
(no vouchers) (
<bibRefCitation id="E955B2A9FFF0270161B2FE1984629189" author="Pickersgill" box="[1214,1402,395,421]" firstAuthor="Pickersgill" pageId="39" pageNumber="340" refId="ref33175" refString="Pickersgill, M. (2007) Frog Search. Edition Chimaira, Frankfurt am Main, 574 pp." type="book" year="2007">Pickersgill 2007</bibRefCitation>
, as 
<taxonomicName id="4AC4B4DBFFF02701659BFE3C801291EB" authorityName="Ahl" authorityYear="1931" box="[151,266,429,455]" class="Amphibia" family="Hyperoliidae" genus="Hyperolius" kingdom="Animalia" order="Anura" pageId="39" pageNumber="340" phylum="Chordata" rank="species" species="renschi">
<emphasis id="BFB0134AFFF02701659BFE3C801291EB" box="[151,266,429,455]" italics="true" pageId="39" pageNumber="340">H. renschi</emphasis>
</taxonomicName>
).
</paragraph>
</subSubSection>
