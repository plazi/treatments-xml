(
<figureCitation id="13332A77215BFFF6FF2A1C9CFE8CF857" box="[159,274,1945,1971]" captionStart="FIGURE 1" captionStartId="3.[151,250,1866,1890]" captionTargetBox="[171,1412,191,1824]" captionTargetId="figure-20@3.[171,1416,181,1841]" captionTargetPageId="3" captionText="FIGURE 1. Grammedessa. A–B: G. hamata comb.n. A: Dorsal view. B: Ventral view. C–D: G. nigricava sp.n. C: Dorsal view. D: Ventral view. E–F: G. longispina sp.n. E: Dorsal view. F: Ventral view. G–H: G. fundicava sp.n. G: Dorsal view. H: Ventral view. I–J: G. graciligramma sp.n. I: Dorsal view. J: Ventral view. K–L: G. stichtocephala sp.n. K: Dorsal view. L: Ventral view. M–N: G. acalyptoprocta sp.n. M: Dorsal view. N: Ventral view. Scale = 10 mm." figureDoi="http://doi.org/10.5281/zenodo.6500667" httpUri="https://zenodo.org/record/6500667/files/figure.png" pageId="9" pageNumber="220">Figs. 1I–J</figureCitation>
; 
<figureCitation id="13332A77215BFFF6FEAB1C9CFEFDF850" box="[286,355,1945,1972]" captionStart="FIGURE 6" captionStartId="10.[151,250,1674,1698]" captionTargetBox="[162,1436,432,1639]" captionTargetId="figure-132@10.[151,1437,417,1650]" captionTargetPageId="10" captionText="FIGURE 6. Genitalia of G. graciligramma sp.n. A–C: Male genitalia. A: Pygophore in dorsal view. B: Pygophore in ventral view. C: Pygophore in posterior view. D: Female genital plates in ventral view. Scale = 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6500685" httpUri="https://zenodo.org/record/6500685/files/figure.png" pageId="9" pageNumber="220">6A–D</figureCitation>
