<subSubSection id="A8CB9B89354C43498B77AE1008AB6108" pageId="null" pageNumber="370" type="description">
<paragraph id="20972466E825B2CC1EE672CEDE1EE73A" pageId="null" pageNumber="370">
1 
<normalizedToken id="40E6831F2BF8493D160B7B4716E1D0A3" originalValue="jährig" pageId="null" pageNumber="370">jaehrig</normalizedToken>
. 
<emphasis id="4CFF74BB40098B65331C30B9B9BDC1D5" italics="true" pageId="null" pageNumber="370">
<normalizedToken id="4C3F298CD884A4CDB9895B0AD0607F71" originalValue="Blütenstand" pageId="null" pageNumber="370">Bluetenstand</normalizedToken>
aus 2 oder mehreren, traubig oder 
<normalizedToken id="78BE2DEEA85EAB24201271202AABC3AB" originalValue="strahlenförmig" pageId="null" pageNumber="370">strahlenfoermig</normalizedToken>
angeordneten, einseitswendigen 
<normalizedToken id="9679B377C2AC77BFD6507E96D6A57774" originalValue="Ähren" pageId="null" pageNumber="370">Aehren</normalizedToken>
.
</emphasis>
<normalizedToken id="2AB069E40C2A5A66A609223B177753A0" originalValue="Ährchen" pageId="null" pageNumber="370">Aehrchen</normalizedToken>
<normalizedToken id="166DE17E92F65CDB37CA5729D70966A4" originalValue="mehrblütig" pageId="null" pageNumber="370">mehrbluetig</normalizedToken>
, auf der Seite flach (wie 
<taxonomicName id="CA4942C5A7A78AD9E999706FA7203BA9" class="Liliopsida" family="Poaceae" genus="Eragrostis" kingdom="Plantae" order="Poales" pageId="null" pageNumber="370" phylum="Tracheophyta" rank="genus">
<emphasis id="24ED018B004EB66B75CEED986806681D" italics="true" pageId="null" pageNumber="370">Eragrostis</emphasis>
</taxonomicName>
). 
<normalizedToken id="10F013E703097CE2DF4D948C942B1501" originalValue="Hüllspelzen" pageId="null" pageNumber="370">Huellspelzen</normalizedToken>
2, scharf gekielt, die untere 
<normalizedToken id="21F61F8F9331E4C6B7BE8B89014CB191" originalValue="kürzer" pageId="null" pageNumber="370">kuerzer</normalizedToken>
als die obere, obere jedoch die Spitze der untersten Deckspelzen nicht erreichend. Deckspelzen und Vorspelzen 
<normalizedToken id="C44C02976150C9881B7A0440A0FE5D18" originalValue="häutig" pageId="null" pageNumber="370">haeutig</normalizedToken>
, scharf gekielt.
</paragraph>
<paragraph id="0D56169CCB696DD9AE4C67516BB2BDF8" pageId="null" pageNumber="370">
Die Gattung 
<taxonomicName id="DE868FCAD035F9E07B3FD5A62A9AEC4A" class="Liliopsida" family="Poaceae" genus="Eleusine" kingdom="Plantae" order="Poales" pageId="null" pageNumber="370" phylum="Tracheophyta" rank="genus">
<emphasis id="D7C6636775685EBBD902437845F4CE8F" italics="true" pageId="null" pageNumber="370">Eleusine</emphasis>
</taxonomicName>
<normalizedToken id="897A33AD462615005BC466F816A8C75D" originalValue="umfaßt" pageId="null" pageNumber="370">umfasst</normalizedToken>
etwa 
<emphasis id="717FD92F3C2970396C7032DC7B49DB0D" italics="true" pageId="null" pageNumber="370">8 Arten, die in den Tropen und Subtropen verbreitet sind</emphasis>
.
</paragraph>
</subSubSection>
