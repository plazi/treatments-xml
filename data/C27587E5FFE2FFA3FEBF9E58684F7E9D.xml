Zone
</taxonomicName>
and 
<taxonomicName id="8DDC4D70FFE2FFA3FDC49F80683B7E9D" authority="Zone" authorityName="Zone" class="Globothalamea" family="Truncorotaloididae" genus="Morozovella" kingdom="Chromista" order="Rotaliida" pageId="15" pageNumber="29" phylum="Foraminifera" rank="species" species="uncinata">
