<subSubSection id="7309A8FCBAEB2894F73C779845299072" pageId="null" pageNumber="192" type="nomenclature">
<paragraph id="B074615F3072B2BAC0A8C3447E6678AA" pageId="null" pageNumber="192">
<pageBreakToken id="73711D40AADC8F614711947E1F4701DA" pageId="null" pageNumber="192">Artengruppe</pageBreakToken>
der 
<taxonomicName id="2578A6551635F99E7541863F85446225" class="Magnoliopsida" family="Plantaginaceae" genus="Veronica" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="192" phylum="Tracheophyta" rank="genus">Veronica</taxonomicName>
<normalizedToken id="C2005AC6757FE5B52C79CC5F70F9DEFC" originalValue="fruticolósa" pageId="null" pageNumber="192">fruticolosa</normalizedToken>
<authorityName id="C9EB0708954FFCA93466BAF03F8B0C94" pageId="null" pageNumber="192">L.</authorityName>
</paragraph>
</subSubSection>
<subSubSection id="20E7C35CCB4B8E582173BC063E7BAA3F" pageId="null" pageNumber="192" type="vernacular_names">
<paragraph id="4545EE0F02041D0BFE67FD34970EBBE3" pageId="null" pageNumber="192">Halbstrauchiger Ehrenpreis</paragraph>
</subSubSection>
</title>
<subSubSection id="35DD9DEE05DBD1B75DB044331794B0C2" pageId="null" pageNumber="192" type="description">
<paragraph id="64F8327F24F51C59F5D50889D2396034" pageId="null" pageNumber="192">
Ausdauernd. 
<emphasis id="4A60F9E7B97B002613E1261D222E6526" italics="true" pageId="null" pageNumber="192">Stengel am Grunde holzig</emphasis>
, verzweigt, aufrecht oder aufsteigend, sehr kurz und kraus behaart. 
<normalizedToken id="820A3EA422910F75FDCC3B082940E968" originalValue="Blätter" pageId="null" pageNumber="192">Blaetter</normalizedToken>
kurz gestielt, oval bis lanzettlich, am Grunde 
<normalizedToken id="E7F1717605CDE7A7D632091F414C421F" originalValue="verschmälert" pageId="null" pageNumber="192">verschmaelert</normalizedToken>
, meist stumpf, fein 
<normalizedToken id="CD2C8E1970211170B1E101FB2E10D6F4" originalValue="gezähnt" pageId="null" pageNumber="192">gezaehnt</normalizedToken>
oder ganzrandig, 
<normalizedToken id="35404BBB9278863456FE7A7F1548ADC3" originalValue="±" pageId="null" pageNumber="192">+/-</normalizedToken>
kahl. 
<normalizedToken id="06402445636DBF788CDAE11D64209CF0" originalValue="Blüten" pageId="null" pageNumber="192">Blueten</normalizedToken>
in einzelnen ungestielten, 1-20 
<normalizedToken id="394BBFD964F92187FAB5B861D26896A1" originalValue="blütigen" pageId="null" pageNumber="192">bluetigen</normalizedToken>
Trauben am Ende der Zweige. 
<emphasis id="6457DC3B29EAC6C85304057DA50FB778" italics="true" pageId="null" pageNumber="192">Kelch 5teilig. Krone im Durchmesser 10</emphasis>
- 
<emphasis id="697A59E3FC7E2D74EFF658DD2ACEC3A0" italics="true" pageId="null" pageNumber="192">15 mm.</emphasis>
Frucht breit oval, abgeflacht, bei der Griffelansatzstelle nicht oder nur wenig ausgerandet, behaart. 
<emphasis id="B31AB30134860D9B154F95022F1B853F" italics="true" pageId="null" pageNumber="192">Griffel so lang oder fast so lang wie die Frucht.</emphasis>
Samen 
<normalizedToken id="27A1C2B760D6A9B7C2DD1E2FC8B40F98" originalValue="scheibenförmig" pageId="null" pageNumber="192">scheibenfoermig</normalizedToken>
(im 
<normalizedToken id="EAB46D3964FF402462122B977A6B4277" originalValue="Umriß" pageId="null" pageNumber="192">Umriss</normalizedToken>
oval), etwa 1,5 mm lang.
</paragraph>
<paragraph id="15026BB8117BE053A088891F15FF09B7" pageId="null" pageNumber="192">
Die Artengruppe der 
<emphasis id="C726392B89DACA88788836F53228BCF0" italics="true" pageId="null" pageNumber="192">
<taxonomicName id="5F3BDF6D01A5AD6DBFC8FA754E25B3A7" class="Magnoliopsida" family="Plantaginaceae" genus="Veronica" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="192" phylum="Tracheophyta" rank="species" species="fruticulosa">V. fruticulosa</taxonomicName>
besteht aus 3 Arten
</emphasis>
, von denen die im Gebiet auftretenden 2 Arten miteinander fertil bastardieren (Beatus 1936). Oft treten in Gebieten, wo beide Arten Vorkommen, Genintrogressionen auf.
</paragraph>
<paragraph id="24122E3AF5E188DF9401221DEE6F9A86" pageId="null" pageNumber="192">
<table id="6C2FB8060E81B9ADA41274A61768567B" frame="void" pageId="null" pageNumber="192" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="21FDCAB7403BB637A3C881668C1A4AC8" pageId="null" pageNumber="192">
<tr id="89DD7CBF9C6C50252F964E982069A759" pageId="null" pageNumber="192">
<td id="59FFD11A7A1BE39D04B7B03A3F51FCEE" align="left" pageId="null" pageNumber="192" valign="top">
1. Krone 
<normalizedToken id="872CE72F4848B8BAB998688F7F03B4F1" originalValue="blaßrosa" pageId="null" pageNumber="192">blassrosa</normalizedToken>
, mit dunkleren Adern; Kelch und 
<normalizedToken id="A4EB259F66FE002611879177BE003308" originalValue="Blütenstiele" pageId="null" pageNumber="192">Bluetenstiele</normalizedToken>
<normalizedToken id="5AAF5175D9ED40139DF4B43BCD8A56B1" originalValue="drüsig" pageId="null" pageNumber="192">druesig</normalizedToken>
behaart
</td>
<td id="3AEE8D49847FBB019ED0636C1F0ECB7D" align="left" pageId="null" pageNumber="192" valign="bottom">
<taxonomicName id="3C5B4E4BE4A05607FAD420F1434F16C0" class="Magnoliopsida" family="Plantaginaceae" genus="Veronica" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="192" phylum="Tracheophyta" rank="species" species="fruticulosa">
<italic id="309A6F43EEBEC889B7B9D8814B7B99C0" pageId="null" pageNumber="192">V. fruticulosa</italic>
</taxonomicName>
(Nr. 10a)
</td>
</tr>
<tr id="D72CABFEC2A86B9691A63CFE4582CFBD" pageId="null" pageNumber="192">
<td id="9669F9B06E5DD35C3068E5851E42E758" align="left" pageId="null" pageNumber="192" valign="top">
1*. Krone blau; Kelch und 
<normalizedToken id="77C66349D8F1796200381D262D687741" originalValue="Blütenstiele" pageId="null" pageNumber="192">Bluetenstiele</normalizedToken>
ohne 
<normalizedToken id="BFB94ACE3D10227AE318F694901B7620" originalValue="Drüsen" pageId="null" pageNumber="192">Druesen</normalizedToken>
, aber behaart
</td>
<td id="5D0533154FCB57A9C7125B4140D9CE27" align="left" pageId="null" pageNumber="192" valign="bottom">
<taxonomicName id="76337F924DBF3D60ACEA7BB28C07DCCE" class="Magnoliopsida" family="Plantaginaceae" genus="Veronica" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="192" phylum="Tracheophyta" rank="species" species="fruticans">
<italic id="8F83EA17ADB350CED1FE3D051A25EF93" pageId="null" pageNumber="192">V. fruticans</italic>
</taxonomicName>
(Nr. 10b)
</td>
</tr>
</tbody>
</table>
</paragraph>
