<taxonomicName id="4C4C4D4AFFEEFFC431D00CB4FDEAF95E" baseAuthorityName="Sonnini &amp; Latreille" baseAuthorityYear="1802" box="[437,580,1676,1697]" class="Reptilia" family="Agamidae" genus="Agama" kingdom="Animalia" order="Squamata" pageId="17" pageNumber="212" phylum="Chordata" rank="subSpecies" species="stellio" subSpecies="vulgaris">
<emphasis id="B938EADBFFEEFFC431D00CB4FDEAF95E" box="[437,580,1676,1697]" italics="true" pageId="17" pageNumber="212">L. s. vulgaris</emphasis>
</taxonomicName>
and 
<emphasis id="B938EADBFFEEFFC432190CB4FD5FF95E" box="[636,753,1676,1697]" italics="true" pageId="17" pageNumber="212">L. s. salehi</emphasis>
is ambiguous and requires further investigation.
