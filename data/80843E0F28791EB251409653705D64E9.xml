<subSubSection id="38769470755C7DBFAF2DC468FBCB7BF2" pageId="null" pageNumber="694" type="description">
<paragraph id="B667E915277E039CD34702C41603AD84" pageId="null" pageNumber="694">
<normalizedToken id="22FC256825F5DD684027F899A6CA2A44" originalValue="Sträucher" pageId="null" pageNumber="694">Straeucher</normalizedToken>
oder 
<normalizedToken id="E1F6BC1534563D2BDBA2DB54DA5D56E6" originalValue="Bäume" pageId="null" pageNumber="694">Baeume</normalizedToken>
, 
<normalizedToken id="07F4EF6BD1E5E03C07955407488CD1E6" originalValue="sommergrün" pageId="null" pageNumber="694">sommergruen</normalizedToken>
; 
<normalizedToken id="7524D51626D8B405AEA784BFC6F2C9FB" originalValue="Blätter" pageId="null" pageNumber="694">Blaetter</normalizedToken>
<normalizedToken id="A46E2F22665C528248C9B8E74C8CB5C0" originalValue="wechselständig" pageId="null" pageNumber="694">wechselstaendig</normalizedToken>
, 
<emphasis id="7D6FB97CF2E6EF696289F01651D16288" italics="true" pageId="null" pageNumber="694">fast 2zeilig</emphasis>
angeordnet, ganzrandig oder 
<normalizedToken id="1B068D47078BBB33C96858BFA1A440CE" originalValue="gezähnt" pageId="null" pageNumber="694">gezaehnt</normalizedToken>
, oval oder 
<normalizedToken id="434845B4864C7566BEDB3E8200B38CBB" originalValue="herzförmig" pageId="null" pageNumber="694">herzfoermig</normalizedToken>
; 
<emphasis id="4114A432D0A0E3F27AA8E6226A20719D" italics="true" pageId="null" pageNumber="694">
Dornen anstelle der 
<normalizedToken id="EAA68C1E3CA9296DD4BE4F6CE1968F69" originalValue="Nebenblätter" pageId="null" pageNumber="694">Nebenblaetter</normalizedToken>
.
</emphasis>
<normalizedToken id="E3DA5056CED7808025BDDB7E04165986" originalValue="Blüten" pageId="null" pageNumber="694">Blueten</normalizedToken>
⚥, 5 
<normalizedToken id="960777515CECB6E84CCC644692239E8D" originalValue="zählig" pageId="null" pageNumber="694">zaehlig</normalizedToken>
, mit Kelch und Krone. Fruchtknoten zum 
<normalizedToken id="EA9D4C9A24A3DEB750796821271D28B3" originalValue="großen" pageId="null" pageNumber="694">grossen</normalizedToken>
Teil mit dem Achsenbecher verwachsen, 2-3 
<normalizedToken id="90E9D0CF2D6610D93FB48AFB32EBCF0D" originalValue="fächerig" pageId="null" pageNumber="694">faecherig</normalizedToken>
; Griffel 2-3teilig. Frucht lederig, sich nicht 
<normalizedToken id="7AB9DB9681E4C802CF29D45314507FE5" originalValue="öffnend" pageId="null" pageNumber="694">oeffnend</normalizedToken>
, mit 2-3 
<normalizedToken id="46B38D0D6B684F76AE8CBFFFE379C4C4" originalValue="fächerigem" pageId="null" pageNumber="694">faecherigem</normalizedToken>
Kern, der die Samen 
<normalizedToken id="82A57EB85E39FD65B8976D9D15AF00FD" originalValue="enthält" pageId="null" pageNumber="694">enthaelt</normalizedToken>
, im untern Teil vom Achsenbecher umgeben, 
<normalizedToken id="0B187DF0337F74CCEFD0F904A43733CB" originalValue="darüber" pageId="null" pageNumber="694">darueber</normalizedToken>
<emphasis id="50EFFC4DA25CF701B14F4C2FC9C7574F" italics="true" pageId="null" pageNumber="694">
mit breitem, senkrecht zur Griffelachse stehendem, 
<normalizedToken id="F8E5CCA1A73FE16CA623895ABB238E0E" originalValue="ringförmigem" pageId="null" pageNumber="694">ringfoermigem</normalizedToken>
, 
<normalizedToken id="1C233568AD9ED019C30E826EF8B930AF" originalValue="radiärnervigem" pageId="null" pageNumber="694">radiaernervigem</normalizedToken>
<normalizedToken id="6C4DDBCEDDA3820F15B190E3F861761D" originalValue="Flügel" pageId="null" pageNumber="694">Fluegel</normalizedToken>
</emphasis>
(
<emphasis id="A0B68CB2E46E88A7356787A5EF8FE04B" italics="true" pageId="null" pageNumber="694">
<normalizedToken id="DDA37346EB00FF4DED5966C07799D046" originalValue="Flügel" pageId="null" pageNumber="694">Fluegel</normalizedToken>
entsteht aus der Griffelbasis
</emphasis>
).
</paragraph>
<paragraph id="39D0DF2234F405671CA1EED49EE8A446" pageId="null" pageNumber="694">
Die Gattung 
<taxonomicName id="218956040D8D784AD879308FBB2D8AF2" class="Polychaeta" family="Rhamnaceae" genus="Paliurus" kingdom="Animalia" order="Rosales" pageId="null" pageNumber="694" phylum="Annelida" rank="genus">
<emphasis id="1A1F4F8B3EC9777193C5BAB0F9F7C712" italics="true" pageId="null" pageNumber="694">Paliurus</emphasis>
</taxonomicName>
<normalizedToken id="5391A3944B8091726E7F175A3E417745" originalValue="umfaßt" pageId="null" pageNumber="694">umfasst</normalizedToken>
<emphasis id="899066200AB91450D6DBDFB652D31599" italics="true" pageId="null" pageNumber="694">
etwa 8 Arten, die in 
<normalizedToken id="F059A5E00FBCE032551BCB21DA96CB03" originalValue="Südeuropa" pageId="null" pageNumber="694">Suedeuropa</normalizedToken>
, Westasien und Ostasien
</emphasis>
(
<emphasis id="4CFF44CD7F9A47A0B268C573B122631F" italics="true" pageId="null" pageNumber="694">China, Japan, Korea</emphasis>
)
</paragraph>
</subSubSection>
