<taxonomicName id="39ED62717C2B9301F646A72CF7ADED56" authorityName="Ze H. Wang &amp; H. Peng" authorityYear="2022" class="Magnoliopsida" family="Primulaceae" genus="Primula" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Primula longipilosa" order="Ericales" pageId="0" pageNumber="15" phylum="Tracheophyta" rank="species" species="longipilosa">
<emphasis id="D592BCD055E62699B841D302E14D95E5" italics="true" pageId="0" pageNumber="15">Primula longipilosa</emphasis>
</taxonomicName>
and 
