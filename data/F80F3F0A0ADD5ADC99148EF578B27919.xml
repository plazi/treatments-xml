<tr id="A2CAA13C627FB3883F9AC76574524095" pageId="0" pageNumber="15">
<td id="D898D7CDD8B2EA75A1AE5750AA21BFF8" colspan="1" pageId="0" pageNumber="15" rowspan="1">Leave blade</td>
<td id="4A1ECA3EDBF62DEEBD85B1D54B4803D8" colspan="1" pageId="0" pageNumber="15" rowspan="1">margin undulate</td>
<td id="E6B2709BC507E057E171F6AD64A9B5F0" colspan="1" pageId="0" pageNumber="15" rowspan="1">margin sinuate-lobulate and denticulate-crenulate</td>
</tr>
<tr id="F3C8FAE2469F6EEB6767816BF5245000" pageId="0" pageNumber="15">
<td id="9FC636272DBEC7F2E2E7353CDD5305C3" colspan="1" pageId="0" pageNumber="15" rowspan="1">Inflorescence</td>
<td id="6FDFD8E8393A52D009BEF535309D992E" colspan="1" pageId="0" pageNumber="15" rowspan="1">racemose, shorter than or almost equal to the leaves</td>
<td id="CD3C12A69BB934AA5E0B0CEA59C8A44C" colspan="1" pageId="0" pageNumber="15" rowspan="1">umbellate, umbels 3-10, superimposed, significantly longer than leaves</td>
</tr>
<tr id="7BE7641A4B5E97804A294A4BD9854340" pageId="0" pageNumber="15">
<td id="D44756A89ABABCE5115FEEFF019F1037" colspan="1" pageId="0" pageNumber="15" rowspan="1">Pedicel</td>
<td id="2E2D22E1B6DDE0CAB2746CB9F3C7124D" colspan="1" pageId="0" pageNumber="15" rowspan="1">covered with dense hairs</td>
<td id="0AADB7378E8853FA9B8F153A573097BC" colspan="1" pageId="0" pageNumber="15" rowspan="1">covered with sparse hairs</td>
</tr>
