<subSubSection id="90CEF5366E9C1AD417A985A9488B27B4" pageId="null" pageNumber="736" type="description">
<paragraph id="A6681980D4113C7B039A855A114A0CDB" pageId="null" pageNumber="736">
Unterscheidet sich von 
<taxonomicName id="F76B3FF73E005A00DCF6703C3960BFCC" class="Insecta" family="Hesperiidae" genus="Viola" kingdom="Animalia" order="Lepidoptera" pageId="null" pageNumber="736" phylum="Arthropoda" rank="species" species="cenisia">
<emphasis id="D8CE033588EDE4E30BE2AEF26EDFB47F" italics="true" pageId="null" pageNumber="736">V. cenisia</emphasis>
</taxonomicName>
(Nr. 5) durch folgende Merkmale: 
<emphasis id="117F157B279C45E23BA2E54B0149AA90" italics="true" pageId="null" pageNumber="736">
<normalizedToken id="AD77354783328E7177FD2EDFC41FEC46" originalValue="Kelchblätter" pageId="null" pageNumber="736">Kelchblaetter</normalizedToken>
besonders am Rand der 
<normalizedToken id="BBA2C47AB3DCE0FC0278FABDE6463286" originalValue="Anhängsel" pageId="null" pageNumber="736">Anhaengsel</normalizedToken>
behaart;
</emphasis>
<normalizedToken id="34789A951B037E55D1FDC6DF9CE95151" originalValue="Kronblätter" pageId="null" pageNumber="736">Kronblaetter</normalizedToken>
purpurn oder hellgelb; unterstes Kronblatt 
<normalizedToken id="5A785D08CD350315B6AD926BF9B4F09D" originalValue="1½" pageId="null" pageNumber="736">11/2</normalizedToken>
-2mal so lang wie die 
<normalizedToken id="20F8629F874D43D1CAE7FC0DA5727D93" originalValue="Kelchblätter" pageId="null" pageNumber="736">Kelchblaetter</normalizedToken>
, 
<emphasis id="88DDE97A1F88635A31DCA7DA817A3091" italics="true" pageId="null" pageNumber="736">
mit dem Sporn 12-20 mm lang; Sporn 
<normalizedToken id="6E3E31370089327E2321B68F637A7C77" originalValue="höchstens" pageId="null" pageNumber="736">hoechstens</normalizedToken>
</emphasis>
<normalizedToken id="F50DDD214187A4FBEA2BCE23387E7C16" originalValue="½" pageId="null" pageNumber="736">1/2</normalizedToken>
<emphasis id="9E31DC965C132B8BCF9871EFDD4FFAD1" italics="true" pageId="null" pageNumber="736">so lang wie der Rest des Kronblattes, 1</emphasis>
<normalizedToken id="11C0F9F8553E0F53D9AF2EF9E37A85C6" originalValue="½" pageId="null" pageNumber="736">1/2</normalizedToken>
<emphasis id="D6461AD76D147F06F0946F124BA88B0A" italics="true" pageId="null" pageNumber="736">
-2mal so lang wie die 
<normalizedToken id="80322E2D0CA3DA9139F89BD7F717ECD4" originalValue="Kelchblattanhängsel" pageId="null" pageNumber="736">Kelchblattanhaengsel</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="5FEDBFD1B808EE256F4D98D6334F969A" originalValue="Blüte" pageId="null" pageNumber="736">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="58292A8C3F4539E588DB824D4C6D9284" pageId="null" pageNumber="736">
<emphasis id="516A6C5A45CC179B57220C5783A3D5BB" italics="true" pageId="null" pageNumber="736">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="B2E5B2D97E068C348B6ED47820C37A64" pageId="null" pageNumber="736">
<emphasis id="6424CFEBA347D6E83F9475D496ED6668" italics="true" pageId="null" pageNumber="736">Standort.</emphasis>
Alpin. Ruhender, kalkarmer Feinschutt, seltener Dolomitschutt.
</paragraph>
<paragraph id="1E12E90251EE5C4B44323696DDBA6E48" pageId="null" pageNumber="736">
<emphasis id="3D69DDAA5AA85FB05BEAB3383189DB9E" italics="true" pageId="null" pageNumber="736">Verbreitung. Bergamasker Pflanze:</emphasis>
Grigna settentrionale (Seitter 1969 
<normalizedToken id="DB9A143C13131998117702C666B6DF13" originalValue="mündlich" pageId="null" pageNumber="736">muendlich</normalizedToken>
), Cima di Menna (Wilczek und Chenevard 1912), 
<normalizedToken id="AEA495D773351E17058F6D47DCE2DDE2" originalValue="nördliche" pageId="null" pageNumber="736">noerdliche</normalizedToken>
Bergamasker Alpen (zwischen Pizzo del Diavolo und Monte Venerocolo). Verbreitungskarte von Pitschmann und Reisigl (1959).
</paragraph>
</subSubSection>
