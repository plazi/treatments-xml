<taxonomicName id="A2EA84A9FFFBFFC4FF71F9ACFDECF936" authority="(Okano, 1964)" baseAuthorityName="Okano" baseAuthorityYear="1964" box="[151,529,1662,1689]" class="Insecta" family="Noctuidae" genus="Eudocima" kingdom="Animalia" order="Lepidoptera" pageId="19" pageNumber="20" phylum="Arthropoda" rank="species" species="okurai">
<emphasis id="579E2338FFFBFFC4FF71F9ACFDECF936" bold="true" box="[151,529,1662,1689]" pageId="19" pageNumber="20">
<emphasis id="579E2338FFFBFFC4FF71F9ACFE9DF937" bold="true" box="[151,352,1662,1689]" italics="true" pageId="19" pageNumber="20">Eudocima okurai</emphasis>
(
<bibRefCitation id="017B82DBFFFBFFC4FE89F9ACFDF4F936" author="Okano, M." box="[367,521,1662,1688]" pageId="19" pageNumber="20" pagination="41 - 44" refId="ref39395" refString="Okano, M. (1964) New or little known moths from Formosa (5). Tohoku Konchu, Morioka, 1, 41 - 44." type="journal article" year="1964">Okano, 1964</bibRefCitation>
