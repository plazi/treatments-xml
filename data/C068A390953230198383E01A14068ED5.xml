<subSubSection id="523CEC02295015BE98C7AA011F12866A" pageId="null" pageNumber="709" type="description">
<paragraph id="D7986571196B8BF1713C46332581562F" pageId="null" pageNumber="709">
Zweige gabelig (dichotom) verzweigt. 
<emphasis id="C88930F9EA049271D8D747F9BFBF8C76" italics="true" pageId="null" pageNumber="709">
<normalizedToken id="403A122717EAC83E8779C80D00E36B10" originalValue="Blätter" pageId="null" pageNumber="709">Blaetter</normalizedToken>
dick, lederig, 
<normalizedToken id="7C4639891FB58FEE5E288E019890AFA9" originalValue="immergrün" pageId="null" pageNumber="709">immergruen</normalizedToken>
</emphasis>
, selten 
<normalizedToken id="288302BB6F89FBF19BB85FE6C68A5691" originalValue="schuppenförmig" pageId="null" pageNumber="709">schuppenfoermig</normalizedToken>
oder nicht vorhanden. 
<normalizedToken id="AF7765F9BAFD1751A8A019864E474BB8" originalValue="Blütenstände" pageId="null" pageNumber="709">Bluetenstaende</normalizedToken>
1-5 
<normalizedToken id="3050DCC3D5187867FF9062DA94131C5C" originalValue="blütig" pageId="null" pageNumber="709">bluetig</normalizedToken>
. 
<emphasis id="2EA80B8BF9B087221F8853C5E699BC55" italics="true" pageId="null" pageNumber="709">
<normalizedToken id="AB5B1C749C88A4F28389515FB8F639FC" originalValue="Blüten" pageId="null" pageNumber="709">Blueten</normalizedToken>
klein, 1geschlechtig.
</emphasis>
Pflanzen 1geschlechtig oder 2geschlechtig. 
<normalizedToken id="1937599C6A0E70675317F7403AABCC0A" originalValue="Blüten" pageId="null" pageNumber="709">Blueten</normalizedToken>
4-, seltener 3- oder 5 
<normalizedToken id="8B5E3F8A2286B311DE25EDA64C07FCFE" originalValue="zählig" pageId="null" pageNumber="709">zaehlig</normalizedToken>
. Fruchtknoten mit kurzem Griffel oder ohne Griffel, mit dicker Narbe. Beerenartige Frucht rot, gelb oder 
<normalizedToken id="8E8CF29A5E082442FE32235A46E7D7DB" originalValue="weiß" pageId="null" pageNumber="709">weiss</normalizedToken>
.
</paragraph>
<paragraph id="59AABC9814AA0FAB259900B274DCE253" pageId="null" pageNumber="709">
Die Gattung 
<taxonomicName id="6551F9E3FB9C1B0A3D68CF1C552260AE" class="Magnoliopsida" family="Viscaceae" genus="Viscum" kingdom="Plantae" order="Santalales" pageId="null" pageNumber="709" phylum="Tracheophyta" rank="genus">
<emphasis id="0535A7B7653BDA4E7143BF0505F4D7FC" italics="true" pageId="null" pageNumber="709">Viscum</emphasis>
</taxonomicName>
<normalizedToken id="5192978B573F9DF1B01AAC133E170373" originalValue="umfaßt" pageId="null" pageNumber="709">umfasst</normalizedToken>
etwa 
<emphasis id="8A14259AF78BEB73F7C9FDF744C379F4" italics="true" pageId="null" pageNumber="709">65 Arten; die meisten sind in den Tropen und Subtropen von Afrika, Asien und Nordaustralien;</emphasis>
keine Arten in Amerika. Neben 
<taxonomicName id="1ED8330045615C2778D7CA5C3F341118" class="Liliopsida" family="Melanthiaceae" genus="Veratrum" kingdom="Plantae" order="Liliales" pageId="null" pageNumber="709" phylum="Tracheophyta" rank="species" species="album">
<emphasis id="B7750E0A51DD32C73EF4AAB0FC89A35F" italics="true" pageId="null" pageNumber="709">V. album</emphasis>
</taxonomicName>
in 
<taxonomicName id="E338E598D005D48351F08ECE21C03F36" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="709" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
nur 
<taxonomicName id="99005EC0E1E67675323D33C738FCED06" authority="Sieber" authorityName="Sieber" class="Magnoliopsida" family="Viscaceae" genus="Viscum" kingdom="Plantae" order="Santalales" pageId="null" pageNumber="709" phylum="Tracheophyta" rank="species" species="cruciatum">
<emphasis id="5054E5FD7D66BCB42B41CC4CB0502A89" italics="true" pageId="null" pageNumber="709">V. cruciatum</emphasis>
Sieber
</taxonomicName>
im Mediterrangebiet auf Schwarzpappel, Kastanie, Mandel- und 
<normalizedToken id="48B75FA8A0E3BC76350AD68345CCF205" originalValue="Ölbaum" pageId="null" pageNumber="709">Oelbaum</normalizedToken>
. Monographie 
<normalizedToken id="874CED82D4B9CEEE06251137B78FA42D" originalValue="über" pageId="null" pageNumber="709">ueber</normalizedToken>
<taxonomicName id="2E4299872442E6E285A600C1CFF973D0" authority="von Tubeuf (1923)" authorityName="von Tubeuf" authorityYear="1923" class="Liliopsida" family="Melanthiaceae" genus="Veratrum" kingdom="Plantae" order="Liliales" pageId="null" pageNumber="709" phylum="Tracheophyta" rank="species" species="album">
<emphasis id="14ADD85ACDFCA72204AC7A080F650299" italics="true" pageId="null" pageNumber="709">V. album</emphasis>
von Tubeuf (1923)
</taxonomicName>
, mit vielen experimentellen Untersuchungen 
<normalizedToken id="F0B6000067D74C4F85E8387F45F7B671" originalValue="über" pageId="null" pageNumber="709">ueber</normalizedToken>
Sippen und biologische Rassen, mit 
<normalizedToken id="F94C01B219DE98B8E0F69A096960EF65" originalValue="ausführlichen" pageId="null" pageNumber="709">ausfuehrlichen</normalizedToken>
Verbreitungsangaben und Bedeutung als Medizinalpflanze.
</paragraph>
</subSubSection>
