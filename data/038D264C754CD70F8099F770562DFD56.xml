<taxonomicName id="4C24ECD9754CD70886C1F26F56E7F228" authorityName="E. Geoffroy" authorityYear="1818" box="[987,1177,3456,3477]" class="Mammalia" family="Nycteridae" genus="Nycteris" kingdom="Animalia" order="Chiroptera" pageId="3" pageNumber="386" phylum="Chordata" rank="species" species="thebaica">Nycteris thebaica</taxonomicName>
