<subSubSection id="4CD140A68BF30C43CDAB9DC6A4999513" pageId="null" pageNumber="504" type="description">
<paragraph id="5161C913B16AA935B82B8CE292709CDB" pageId="null" pageNumber="504">
<emphasis id="C5EF9D8B977291E149E27A00F0D3D5DE" italics="true" pageId="null" pageNumber="504">
1 
<normalizedToken id="00FD921ECDBF14817D31F2603C4CC244" originalValue="jährig" pageId="null" pageNumber="504">jaehrig</normalizedToken>
;
</emphasis>
2-30 cm hoch, 
<normalizedToken id="BF7A37AD46E84F42C1332594EE18578F" originalValue="büschelig" pageId="null" pageNumber="504">bueschelig</normalizedToken>
. Stengel 
<normalizedToken id="0CB3D083BBA1B9665CE531BB95CFD2B9" originalValue="beblättert" pageId="null" pageNumber="504">beblaettert</normalizedToken>
, weniger als 1 mm dick. 
<emphasis id="5B821ED1D414033543DAD8721AAA4D86" italics="true" pageId="null" pageNumber="504">
<normalizedToken id="E92AAE393ED0B79C518AEDAB09AAFD28" originalValue="Blätter" pageId="null" pageNumber="504">Blaetter</normalizedToken>
zuoberst an der Scheide mit 
<normalizedToken id="658A7BBD920DB6C2B781F7FC9ED9327A" originalValue="häutigen" pageId="null" pageNumber="504">haeutigen</normalizedToken>
<normalizedToken id="E78E29BEF13A94F5EA012824E9532C71" originalValue="Öhrchen" pageId="null" pageNumber="504">Oehrchen</normalizedToken>
.
</emphasis>
<normalizedToken id="680A3FE2F61125A97DCF03C302E48D86" originalValue="Blütenstand" pageId="null" pageNumber="504">Bluetenstand</normalizedToken>
<normalizedToken id="586C511149B0FE7C3950DD8CD565CD39" originalValue="endständig" pageId="null" pageNumber="504">endstaendig</normalizedToken>
, locker, reich verzweigt, mit 
<emphasis id="6DE843DEAF668A6812237B7451204EF7" italics="true" pageId="null" pageNumber="504">
0,5-2 cm voneinander entfernt stehenden, einzelnen 
<normalizedToken id="650B6407003859A1EFDA199648DFDFF7" originalValue="Blüten" pageId="null" pageNumber="504">Blueten</normalizedToken>
</emphasis>
. 
<normalizedToken id="54E755E9BB52B6C5D38A4EE161813DDF" originalValue="Perigonblätter" pageId="null" pageNumber="504">Perigonblaetter</normalizedToken>
im untern Teil von 2 
<normalizedToken id="242F7F0C5CE42E5E734936BCA42CF048" originalValue="häutigen" pageId="null" pageNumber="504">haeutigen</normalizedToken>
<pageBreakToken id="D606F926A21FA1DA6FDFA9344B6F2F6B" pageId="null" pageNumber="504">
<normalizedToken id="AF55AF3F3E4DB36E0A2F39675505CA8C" originalValue="Vorblättern" pageId="null" pageNumber="504">Vorblaettern</normalizedToken>
</pageBreakToken>
umgeben, 2-2,5 mm lang, alle gleich lang, spitz, mit 
<normalizedToken id="A8DAD6D04A41D4A7A52C28403AF000FC" originalValue="häutigem" pageId="null" pageNumber="504">haeutigem</normalizedToken>
Rand, gelblich. Reife Frucht so lang oder wenig 
<normalizedToken id="3D6390FDE498057B705C77B0F82908BC" originalValue="länger" pageId="null" pageNumber="504">laenger</normalizedToken>
als die 
<normalizedToken id="66D022590E825E2C4E35D0FA26268E0B" originalValue="Perigonblätter" pageId="null" pageNumber="504">Perigonblaetter</normalizedToken>
. - 
<normalizedToken id="87CDD9C6CE12D25868E5FECB91E0CF90" originalValue="Blüte" pageId="null" pageNumber="504">Bluete</normalizedToken>
: 
<normalizedToken id="13717160044A37FBEF3C521920251AC5" originalValue="Früher" pageId="null" pageNumber="504">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="FF296E8C3260813D22E0671A3A5E54E1" pageId="null" pageNumber="504">
<emphasis id="6E92C8919EF7445A37F465CE4617EC74" italics="true" pageId="null" pageNumber="504">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="943CE760E942210385D607D8DAEE0854" pageId="null" pageNumber="504">
<emphasis id="7573DE671D4D4EE72FAF63B183B708AC" italics="true" pageId="null" pageNumber="504">Standort.</emphasis>
Kollin. Feuchter, nackter, kalkarmer, meist toniger Boden. 
<normalizedToken id="1A7AA18FC9EBA56DBAE5BB73D8FA7742" originalValue="Tümpelufer" pageId="null" pageNumber="504">Tuempelufer</normalizedToken>
, auf dem Grund periodisch austrocknender Teiche, Ackerfurchen, Wagengeleise in Feldwegen. Zwergbinsengesellschaften.
</paragraph>
<paragraph id="B7E3D4D66DF8B8B600B953C0AC215437" pageId="null" pageNumber="504">
<emphasis id="88F7C113CFF03C6C879AA584CBE744ED" italics="true" pageId="null" pageNumber="504">
Verbreitung. 
<normalizedToken id="6645EAD5781EB90397F01394A3F58AC7" originalValue="Westeuropäisch-mediterrane" pageId="null" pageNumber="504">Westeuropaeisch-mediterrane</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="9ED3C27592C3C46B4F7CAB719AB8CFF2" originalValue="Nordwärts" pageId="null" pageNumber="504">Nordwaerts</normalizedToken>
bis Holland, Norddeutschland, Polen, Ukraine, 
<normalizedToken id="3D93E6CAF50F5B598D815EAC99CDC86E" originalValue="ostwärts" pageId="null" pageNumber="504">ostwaerts</normalizedToken>
bis in den Kaukasus, 
<normalizedToken id="B00D7E0DDCC9AC9FD14F90AB9E9B5E03" originalValue="südwärts" pageId="null" pageNumber="504">suedwaerts</normalizedToken>
bis Nordwestafrika. - Im Gebiet: Oberrheinische Tiefebene und 
<normalizedToken id="B6573AE247FCA4470BEDCADF8A069DDA" originalValue="Seitentäler" pageId="null" pageNumber="504">Seitentaeler</normalizedToken>
, Gebiet von Delle und Territoire de Belfort, Savoyen (Mont Corsuet, 
<normalizedToken id="9FDDBDA46F03C85BF504E795A735E6E4" originalValue="Salève" pageId="null" pageNumber="504">Saleve</normalizedToken>
), 
<normalizedToken id="1B8F244500CF8596AA2F09FB8AE4E84F" originalValue="Dép" pageId="null" pageNumber="504">Dep</normalizedToken>
. Jura (Bresse), 
<normalizedToken id="4D6EC5823E47DE673F65480FFDCDD7A7" originalValue="Dép" pageId="null" pageNumber="504">Dep</normalizedToken>
. Doubs (
<normalizedToken id="6E8F4630F70C8AFF6E22017B9E00E66E" originalValue="Montbéliard" pageId="null" pageNumber="504">Montbeliard</normalizedToken>
); mehrere Fundstellen im Tessin; bei Ivrea am Ausgang des Aostatals; selten und 
<normalizedToken id="F81A71D8B712FD5AC0707CA4C44B6739" originalValue="unbeständig" pageId="null" pageNumber="504">unbestaendig</normalizedToken>
.
</paragraph>
</subSubSection>
