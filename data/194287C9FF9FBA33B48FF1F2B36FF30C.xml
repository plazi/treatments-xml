<subSubSection id="D9F16554FF9FBA33B6EDF0BBB153F784" pageId="35" pageNumber="654" type="distribution">
<caption id="C5946657FF9FBA33B6EDF0BBB153F784" ID-DOI="http://doi.org/10.5281/zenodo.6567864" ID-Zenodo-Dep="6567864" httpUri="https://zenodo.org/record/6567864/files/figure.png" inLine="true" pageId="35" pageNumber="654" targetBox="[151,744,1864,2279]" targetPageId="35">
<paragraph id="915436DFFF9FBA33B6EDF0BBB153F784" blockId="35.[766,1361,1853,2280]" pageId="35" pageNumber="654">
<emphasis id="A39FEACDFF9FBA33B6EDF0BBB189F832" bold="true" box="[767,943,2011,2044]" pageId="35" pageNumber="654">Distribution.</emphasis>
