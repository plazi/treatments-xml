<subSubSection id="589E18850A80D6B66D4F2FA6F1614624" pageId="null" pageNumber="457" type="vernacular_names">
<paragraph id="EF9FF85B6A28C5C27A00D29777D41D8A" pageId="null" pageNumber="457">Chavins Rose</paragraph>
</subSubSection>
</title>
<subSubSection id="5841961E39E3D462AFD51F0883FA41C8" pageId="null" pageNumber="457" type="description">
<paragraph id="7119A87E3F941C5CFDE77EE87834AAEC" pageId="null" pageNumber="457">
<emphasis id="B1A4BFAB548FFD04EC13CD5AE0ED0FC7" italics="true" pageId="null" pageNumber="457">
<normalizedToken id="C54AAE2CDE50887275D2F5D8C7C5BF78" originalValue="Blätter" pageId="null" pageNumber="457">Blaetter</normalizedToken>
beiderseits kahl
</emphasis>
, meist doppelt 
<normalizedToken id="C54705D5C0D0821A73161E030EBA0491" originalValue="gezähnt" pageId="null" pageNumber="457">gezaehnt</normalizedToken>
; Blattstiele nicht behaart, oft mit 
<normalizedToken id="B375D57B5785914225A16EDDF5EB2961" originalValue="Stieldrüsen" pageId="null" pageNumber="457">Stieldruesen</normalizedToken>
und 
<normalizedToken id="6B0B0654E74765F808B6A872E7D3D537" originalValue="sichelförmigen" pageId="null" pageNumber="457">sichelfoermigen</normalizedToken>
Stacheln. 
<emphasis id="F7D9F21E487EF385301749308908E2B4" italics="true" pageId="null" pageNumber="457">
<normalizedToken id="27850D6B3E6E8F8B5AB03879D1E9FF72" originalValue="Blütenstiele" pageId="null" pageNumber="457">Bluetenstiele</normalizedToken>
mit 
<normalizedToken id="33DDCBBC0D8EB9455C68921DA9CB5DA3" originalValue="Stieldrüsen" pageId="null" pageNumber="457">Stieldruesen</normalizedToken>
und oft auch mit 
<normalizedToken id="9842354B681E8893A9EF66D51480806C" originalValue="Drüsenborsten" pageId="null" pageNumber="457">Druesenborsten</normalizedToken>
.
</emphasis>
<normalizedToken id="7FB000A1B58848C8A08203F68456B413" originalValue="Kelchblätter" pageId="null" pageNumber="457">Kelchblaetter</normalizedToken>
nach der 
<normalizedToken id="BC02645E0E338F719B099AD44BE21353" originalValue="Blüte" pageId="null" pageNumber="457">Bluete</normalizedToken>
<emphasis id="E25A3FD702CD337704FEEEB17C381369" italics="true" pageId="null" pageNumber="457">
<normalizedToken id="FBE2AB6A6B44E56A62F5061FB56270A7" originalValue="zurückgebogen" pageId="null" pageNumber="457">zurueckgebogen</normalizedToken>
</emphasis>
, vor der Fruchtreife abfallend.
</paragraph>
<paragraph id="35427BA506E7CDC5B7D3BB279038FDA2" pageId="null" pageNumber="457">
<emphasis id="1A81C4AAAC698279C4EE6BB051EF4751" italics="true" pageId="null" pageNumber="457">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="3830F56E25C1D92362B2F9F08AF738A8" pageId="null" pageNumber="457">
<emphasis id="6E15B4B8991D979E968CC2DE1C04E882" italics="true" pageId="null" pageNumber="457">Standort.</emphasis>
Kollin und montan. Trockene, steinige, kalkhaltige und kalkfreie 
<normalizedToken id="DAB543F88D6DC8F11A1E2EF0DD6484F2" originalValue="Böden" pageId="null" pageNumber="457">Boeden</normalizedToken>
. An felsigen 
<normalizedToken id="0A71CE6A2E2D88B4BF18079FCDE4DF4A" originalValue="Hängen" pageId="null" pageNumber="457">Haengen</normalizedToken>
und auf 
<normalizedToken id="0012B5146F7F6B787A2FCA7D40057462" originalValue="Geröllhalden" pageId="null" pageNumber="457">Geroellhalden</normalizedToken>
. 
<normalizedToken id="C0049A8C18BD46CBE708C8D9F52CED02" originalValue="Gebüsch" pageId="null" pageNumber="457">Gebuesch</normalizedToken>
.
</paragraph>
<paragraph id="428FABAA8900FFE2C615012F7814FA6C" pageId="null" pageNumber="457">
<emphasis id="14CD647C3E6434054CBB45EC50BA236E" italics="true" pageId="null" pageNumber="457">Verbreitung. Westalpen-Pflanze:</emphasis>
Von den Seealpen 
<normalizedToken id="7B44DB2DC5EE023E1F42734EDD718E7C" originalValue="ostwärts" pageId="null" pageNumber="457">ostwaerts</normalizedToken>
bis ins Veltlin. - Im Gebiet: Savoyen, 
<normalizedToken id="9C3D6CB1BF5CF9F9735D2C4FB5EC15AA" originalValue="Salève" pageId="null" pageNumber="457">Saleve</normalizedToken>
bei Genf, in den Nordalpen vereinzelt in den Kantonen Waadt, Freiburg und Uri, Wallis (von den 
<normalizedToken id="135D816D0D5636802952D4EF7E64F9A3" originalValue="Follatères" pageId="null" pageNumber="457">Follateres</normalizedToken>
und Salvan bis Lens und bis ins Saastal; Gondoschlucht), Aostatal, 
<normalizedToken id="531102201FBCFB96A10D465BFA2858D7" originalValue="südliches" pageId="null" pageNumber="457">suedliches</normalizedToken>
Tessin, Grigna, Veltlin.
</paragraph>
<paragraph id="63C9FFD282FFBB8AAFA507A9FE38288C" pageId="null" pageNumber="457">
<emphasis id="E420038784D64B906127AC399DC4CD8E" italics="true" pageId="null" pageNumber="457">Bemerkungen.</emphasis>
Standort und Verbreitung von 
<taxonomicName id="A86374F8CBAB2F3721A456F48BA79AA7" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="457" phylum="Tracheophyta" rank="species" species="montana">
<emphasis id="FB1C899D339D50497FD147ED353B6B16" italics="true" pageId="null" pageNumber="457">R. montana</emphasis>
</taxonomicName>
(Nr. 6) und 
<taxonomicName id="4B8D37B220EA2C6CFACAC82A8C1C47AE" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="457" phylum="Tracheophyta" rank="species" species="chavinii">
<emphasis id="0A46BB23BD237E4933B3BD8FCDB88561" italics="true" pageId="null" pageNumber="457">R. Chavinii</emphasis>
</taxonomicName>
stimmen im Gebiet weitgehend 
<normalizedToken id="8F3F546C4180AC286B53AF32D8C51456" originalValue="überein" pageId="null" pageNumber="457">ueberein</normalizedToken>
; die beiden Arten scheinen morphologisch gut getrennt. Ob es sich bei 
<taxonomicName id="281C0BDF862BD22C6AE3089FC9F5C6C7" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="457" phylum="Tracheophyta" rank="species" species="chavinii">
<emphasis id="D88C6DF58B6512A2D6A5F8C3AA802F56" italics="true" pageId="null" pageNumber="457">R. Chavinii</emphasis>
</taxonomicName>
(wie oft vermutet) um fixierte oder immer wieder neu entstehende Bastarde zwischen 
<taxonomicName id="E9EE677496D0F321700A5F86F46C568B" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="457" phylum="Tracheophyta" rank="species" species="montana">
<emphasis id="2298A2AFCC50F15CFC6FDB579194EFAB" italics="true" pageId="null" pageNumber="457">R. montana</emphasis>
</taxonomicName>
und 
<taxonomicName id="607A0920DF3D26E65CBC2E2FC3E2E521" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="457" phylum="Tracheophyta" rank="species" species="canina">
<emphasis id="5E02571B95E0C74CE175DFBD16430D1F" italics="true" pageId="null" pageNumber="457">R. canina</emphasis>
</taxonomicName>
oder 
<taxonomicName id="9B6601635E7B80490DFD38D40F3C9739" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="457" phylum="Tracheophyta" rank="species" species="vosagiaca">
<emphasis id="C1C606D4224E47F6CD19724CDF304C17" italics="true" pageId="null" pageNumber="457">R. vosagiaca</emphasis>
</taxonomicName>
handelt, 
<normalizedToken id="58C3AA82D855F12F900337DEADB5088C" originalValue="muß" pageId="null" pageNumber="457">muss</normalizedToken>
zytogenetisch 
<normalizedToken id="528D7CE316BEF29CF08E6DBE7A96F5A2" originalValue="abgeklärt" pageId="null" pageNumber="457">abgeklaert</normalizedToken>
werden.
</paragraph>
</subSubSection>
