, 
<figureCitation id="13252A54FFC07630FBC2D7EA4EB1F6D1" box="[1129,1157,946,971]" captionStart="Figure 8" captionStartId="14.[146,225,1007,1029]" captionTargetBox="[147,1428,197,966]" captionTargetId="figure-341@14.[145,1428,195,967]" captionTargetPageId="14" captionText="Figure 8. Male chelicerae, stridulatory striae on lateral side. A, Oedothorax gibbosus (Blackwall, 1841). B, Oe. trilobatus (Banks, 1896). C, Oe. gibbifer (Kulczyński, 1882). D, Oe. apicatus (Blackwall, 1850). E, Oe. retusus (Westring, 1851). F, Oe. paludigena Simon, 1926. G, Oe. meridionalis Tanasevitch, 1987. H, Oe. agrestis (Blackwall, 1853). I, Oe. fuscus (Blackwall, 1834). J, Oe. tingitanus (Simon, 1884). Scale bars 0.05 mm." pageId="29" pageNumber="446">8F</figureCitation>
, 
<figureCitation id="13252A54FFC07630FB39D7EA4E85F6D1" box="[1170,1201,946,971]" captionStart="Figure 9" captionStartId="15.[163,241,931,953]" captionTargetBox="[164,1444,196,890]" captionTargetId="figure-419@15.[163,1446,195,892]" captionTargetPageId="15" captionText="Figure 9. Male opisthosoma, dorsal view. A, Oedothorax gibbosus (Blackwall, 1841). B, Oe. trilobatus (Banks, 1896). C, Oe. gibbifer (Kulczyński, 1882). D, Oe. apicatus (Blackwall, 1850). E, Oe. retusus (Westring, 1851). F, Oe. paludigena Simon, 1926. G, Oe. meridionalis Tanasevitch, 1987. H, Oe. agrestis (Blackwall, 1853). I, Oe. fuscus (Blackwall, 1834). J, Oe. tingitanus (Simon, 1884). Scale bars 0.1 mm." pageId="29" pageNumber="446">9F</figureCitation>
, 
<figureCitation id="13252A54FFC07630FB15D7EA4EEEF6D1" box="[1214,1242,946,971]" captionStart="Figure 13" captionStartId="22.[145,225,1708,1730]" captionTargetBox="[151,1427,198,1665]" captionTargetId="figure-24@22.[145,1431,195,1668]" captionTargetPageId="22" captionText="Figure 13. Oedothorax paludigena Simon, 1926. A–E, male left palp. A, retrolateral view. B, prolateral view. C, dorsal view. D, ventral view. E, apical view. F, G, epigyne. F, ventral view. G, external morphology. H, male spinnerets. I, female left spinnerets. Scale bar 0.1 mm." pageId="29" pageNumber="446">13</figureCitation>
