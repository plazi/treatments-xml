<quantity id="8A3467A1FF3CB3B34627F903CAC10DCE" box="[609,711,1738,1762]" metricMagnitude="1" metricUnit="m" metricValue="4.85" metricValueMax="6.8" metricValueMin="2.9" pageId="160" pageNumber="161" unit="m" value="48.5" valueMax="68.0" valueMin="29.0">29–68 m</quantity>
.
</paragraph>
