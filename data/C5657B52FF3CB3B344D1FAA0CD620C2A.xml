<collectingRegion id="8F0804A6FF3CB3B34522F96EC9880D92" box="[356,398,1703,1726]" country="Maldives" name="Uthuru" pageId="160" pageNumber="161">Not</collectingRegion>
reported.
</paragraph>
<paragraph id="4D73CA44FF3CB3B34481F903CACD0DCE" blockId="160.[151,1437,1558,1799]" box="[199,715,1738,1763]" pageId="160" pageNumber="161">
<emphasis id="7FB81656FF3CB3B34481F903C9AF0DCF" bold="true" box="[199,425,1738,1763]" inLineHeading="true" pageId="160" pageNumber="161" reason="1">Habitat and depth.</emphasis>
