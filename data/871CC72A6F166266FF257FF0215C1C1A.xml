<number id="B97D641B6F166266FF65782D25B01D16" box="[215,245,1056,1080]" pageId="23" pageNumber="554" value="15.13">15</number>
</figureCitation>
, 
<figureCitation id="978E6AB96F166266FEB3782D24591D16" box="[257,284,1056,1080]" captionStart="FIGURE 13" captionStartId="20.[151,250,1733,1756]" captionTargetBox="[223,1370,201,1690]" captionTargetId="figure@20.[210,1376,193,1712]" captionTargetPageId="20" captionText="FIGURE 13. Legs (trochanter setae not drawn). A. Aleurodamaeus woasi sp. nov. leg I, left, paraxial view, with cerotegumental granules; B. Aleurodamaeus prominens sp. nov. leg I, left, paraxial view, with cerotegumental granules; C. Aleurodamaeus deswardti (Hugo), tarsus of leg I, left, antiaxial view. Scale bars: 50 μ m." httpUri="https://zenodo.org/record/217590/files/figure.png" pageId="23" pageNumber="554">13</figureCitation>
C)
</paragraph>
