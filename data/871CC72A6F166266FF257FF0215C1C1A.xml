(
<figureCitation id="978E6AB96F166266FF2D782D25B01D16" box="[159,245,1056,1080]" captionStart="FIGURE 15" captionStartId="23.[151,250,2007,2030]" captionTargetBox="[254,1353,1405,1965]" captionTargetId="figure@23.[228,1358,1388,1984]" captionTargetPageId="23" captionText="FIGURE 15. Aleurodamaeus deswardti (Hugo) lateral view with some cerotegument. Scale bar 100 μ m." httpUri="https://zenodo.org/record/217592/files/figure.png" pageId="23" pageNumber="554">
