<subSubSection id="713B86EDE4360E8A4BB22781B3CD4D4C" pageId="null" pageNumber="657" type="vernacular_names">
<paragraph id="85A10952D68226061B3912F20F66BC34" pageId="null" pageNumber="657">Zwerg-Wolfsmilch</paragraph>
</subSubSection>
</title>
<subSubSection id="BDC9E42A9D820F51064FFCD8FE25C950" pageId="null" pageNumber="657" type="description">
<paragraph id="8E65739DDD871FB79B2681875491BBF8" pageId="null" pageNumber="657">
Pflanze lang, kraus und abstehend behaart, seltener ganz kahl. 
<emphasis id="DBAE32977AA0ECD327CB3A09D9EDD076" italics="true" pageId="null" pageNumber="657">
<normalizedToken id="06B015F8EA79B9886003975D5B4FD111" originalValue="Blätter" pageId="null" pageNumber="657">Blaetter</normalizedToken>
rundlich, Durchmesser 0,4-0,8 cm
</emphasis>
. 
<normalizedToken id="17026B6679612FD166BB2FDC58362C30" originalValue="Hüllbecher" pageId="null" pageNumber="657">Huellbecher</normalizedToken>
und Frucht 
<normalizedToken id="D2D9D85FBF78F9F3016603961B3B8F1C" originalValue="überall" pageId="null" pageNumber="657">ueberall</normalizedToken>
behaart bis kahl. Samen 1,2-1,4 mm lang, 0,7-0,9 mm dick, scharfkantig, 
<emphasis id="2A9648756836E9B1433952960AB0AD41" italics="true" pageId="null" pageNumber="657">
mit 
<normalizedToken id="1849D3CDBBCFC0782D3C3E55DE5343FD" originalValue="unregelmäßig" pageId="null" pageNumber="657">unregelmaessig</normalizedToken>
grubiger und wulstiger 
<normalizedToken id="F6C2E94C0F2757BD977895E530689B40" originalValue="Oberfläche" pageId="null" pageNumber="657">Oberflaeche</normalizedToken>
</emphasis>
, 
<normalizedToken id="5F27520C5C55DCF736DCDA8C91CABBAD" originalValue="weiß" pageId="null" pageNumber="657">weiss</normalizedToken>
bis graubraun.
</paragraph>
<paragraph id="CF30F600CAE810E5BA8EC0D9E1E952E7" pageId="null" pageNumber="657">
<emphasis id="B577A3E9DC6CFE1CCAC830722CABC744" italics="true" pageId="null" pageNumber="657">Zytologische Angaben</emphasis>
. Keine Untersuchungen.
</paragraph>
<paragraph id="048E80F946F267052A750B15B9AA4C1B" pageId="null" pageNumber="657">
<emphasis id="18AC2ECE44833FC15C2AD1A24953E04A" italics="true" pageId="null" pageNumber="657">Standort</emphasis>
. Kollin, Sommertrockene, steinige 
<normalizedToken id="8F41289F43C1E4ABF23A9416B5CE00C7" originalValue="Böden" pageId="null" pageNumber="657">Boeden</normalizedToken>
. Bahnareale, Ruderalstellen, 
<normalizedToken id="AAB152C0733C625B20F977D44EBE814B" originalValue="Wegränder" pageId="null" pageNumber="657">Wegraender</normalizedToken>
, Weinberge.
</paragraph>
<paragraph id="000539E69619106A416685A4503D6D6C" pageId="null" pageNumber="657">
<emphasis id="776209BEEE20F468B1E15F41C6A80CB0" italics="true" pageId="null" pageNumber="657">Verbreitung. Mediterran-westasiatische Pflanze:</emphasis>
Ganzes Mediterrangebiet und Westasien. - Im Gebiet: Tessin (Maroggia), Comersee (Mandello [Becherer 1962], Gebiet der Grigna [Rossi 1926]), 
<normalizedToken id="1B81D4C6CC62DEA7E997F2660A11247C" originalValue="südliche" pageId="null" pageNumber="657">suedliche</normalizedToken>
Bergamasker Alpen.
</paragraph>
</subSubSection>
