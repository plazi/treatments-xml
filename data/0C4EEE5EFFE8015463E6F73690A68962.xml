<paragraph id="84585F48FFE80154600EF18990A68962" blockId="10.[828,1436,393,576]" pageId="10" pageNumber="33">
<emphasis id="B693835AFFE80154600EF18990CE8A82" bold="true" box="[828,959,393,416]" pageId="10" pageNumber="33">Comments.</emphasis>
To date 
<taxonomicName id="43E724CBFFE801546714F18997A88A82" authorityName="Baly" authorityYear="1886" box="[1062,1241,393,416]" class="Insecta" family="Chrysomelidae" genus="Aenidea" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="10" pageNumber="33" phylum="Arthropoda" rank="species" species="facialis">
<emphasis id="B693835AFFE801546714F18997A88A82" box="[1062,1241,393,416]" italics="true" pageId="10" pageNumber="33">Aenidea facialis</emphasis>
</taxonomicName>
was classified in 
<taxonomicName id="43E724CBFFE80154600EF1A990DF8AE2" authorityName="Baly" authorityYear="1861" box="[828,942,425,448]" class="Insecta" family="Chrysomelidae" genus="Palpoxena" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="10" pageNumber="33" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFE80154600EF1A990DF8AE2" box="[828,942,425,448]" italics="true" pageId="10" pageNumber="33">Palpoxena</emphasis>
</taxonomicName>
(
<bibRefCitation id="E07622B9FFE80154608FF1A997218AE2" author="MAULIK S." bookContentInfo="xiv + 648 pp. + 1 pl." box="[957,1104,425,448]" editor="SEWELL R. B. S." firstAuthor="MAULIK" journalOrPublisher="Taylor and Francis, London" pageId="10" pageNumber="33" refId="ref32093" refString="MAULIK S. 1936: Coleoptera, Chrysomelidae (Galerucinae). In: SEWELL R. B. S. (ed.): The fauna of British India including Ceylon and Burma. Taylor and Francis, London, xiv + 648 pp. + 1 pl." title="Coleoptera, Chrysomelidae (Galerucinae)" type="book chapter" volumeTitle="The fauna of British India including Ceylon and Burma" year="1936">MAULIK 1936</bibRefCitation>
, 
<bibRefCitation id="E07622B9FFE80154676EF1A9979C8AE2" author="WILCOX J. A." box="[1116,1261,425,448]" editor="WILCOX J. A." firstAuthor="WILCOX" journalOrPublisher="Editio seconda. W. Junk, ' s-Gravenhage" pageId="10" pageNumber="33" pagination="433 - 664" refId="ref33616" refString="WILCOX J. A. 1973: Chrysomelidae: Galerucinae: Luperini: Luperina. In: WILCOX J. A. (ed.): Coleopterorum Catalogus Supplementa. Pars 78 (3). Editio seconda. W. Junk, ' s-Gravenhage, pp. 433 - 664." title="Chrysomelidae: Galerucinae: Luperini: Luperina" type="book chapter" volumeTitle="Coleopterorum Catalogus Supplementa. Pars 78 (3)." year="1973">WILCOX 1973</bibRefCitation>
) or in 
<taxonomicName id="43E724CBFFE801546605F1A990AC8AC2" authority="(KIMOTO 2003)" baseAuthorityName="KIMOTO" baseAuthorityYear="2003" class="Insecta" family="Chrysomelidae" genus="Acroxena" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="10" pageNumber="33" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFE801546605F1A996ED8AE2" box="[1335,1436,425,448]" italics="true" pageId="10" pageNumber="33">Acroxena</emphasis>
(
<bibRefCitation id="E07622B9FFE801546071F1C990A78AC2" author="KIMOTO S." box="[835,982,457,480]" firstAuthor="KIMOTO" journalOrPublisher="Bulletin of the Kitakyushu Museum of Natural History and Human History" pageId="10" pageNumber="33" pagination="23 - 43" part="1" refId="ref31779" refString="KIMOTO S. 2003: The Chrysomelidae (Insecta: Coleoptera) collected by Dr. Akio Otake, on the occasion of his entomological survey in Sri Lanka from 1973 to 1975. Bulletin of the Kitakyushu Museum of Natural History and Human History, Series A 1: 23 - 43." title="The Chrysomelidae (Insecta: Coleoptera) collected by Dr. Akio Otake, on the occasion of his entomological survey in Sri Lanka from 1973 to 1975" type="journal article" year="2003">KIMOTO 2003</bibRefCitation>
)
</taxonomicName>
. Based on the presence of the metasternal process and strongly modified head in males I hereby transfer it to 
<taxonomicName id="43E724CBFFE8015460E3F20997388902" authorityName="Thunberg" authorityYear="1814" box="[977,1097,521,544]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="10" pageNumber="33" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFE8015460E3F20997388902" box="[977,1097,521,544]" italics="true" pageId="10" pageNumber="33">Taumacera</emphasis>
</taxonomicName>
and assign it to the 
<taxonomicName id="43E724CBFFE801546604F20996ED8902" authorityName="Baly" authorityYear="1879" box="[1334,1436,521,544]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="10" pageNumber="33" phylum="Arthropoda" rank="species" species="nasuta">
<emphasis id="B693835AFFE801546604F20996ED8902" box="[1334,1436,521,544]" italics="true" pageId="10" pageNumber="33">T. nasuta</emphasis>
</taxonomicName>
species-group.
</paragraph>
