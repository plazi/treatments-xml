<taxonomicName id="A1814D19DD175A3EFECAF802CF9FC98D" authority="Borson, 1820" authorityName="Borson" authorityYear="1820" box="[339,953,1965,1991]" class="Gastropoda" family="Conidae" genus="Conus" isUncertain="true" kingdom="Animalia" order="Neogastropoda" pageId="21" pageNumber="22" phylum="Mollusca" rank="species" species="baldichieri" subGenus="Lautoconus">
<emphasis id="54F5EA88DD175A3EFECAF802CDB8C98D" box="[339,414,1965,1991]" italics="true" pageId="21" pageNumber="22">Conus</emphasis>
(
<emphasis id="54F5EA88DD175A3EFE2FF801CE19C98D" box="[438,575,1966,1991]" italics="true" pageId="21" pageNumber="22">Lautoconus</emphasis>
) cf. 
<emphasis id="54F5EA88DD175A3EFD1DF802CF23C98D" box="[644,773,1965,1991]" italics="true" pageId="21" pageNumber="22">baldichieri</emphasis>
<bibRefCitation id="02104B6BDD175A3EFC8AF802CF9FC98D" author="Borson S." box="[787,953,1965,1991]" pageId="21" pageNumber="22" pagination="180 - 229" refId="ref28722" refString="Borson S. 1820. Saggio di Orittografia Piemontese. Memorie della Reale Accademia delle Scienze di Torino: 180 - 229." type="book chapter" year="1820">Borson, 1820</bibRefCitation>
</taxonomicName>
from the Tortonian of Crete (Greece) on apertural, abapertural and apical views, under natural (A1–A2, A5) and UV light. Specimen MNHN.F. 
<accessionNumber id="79D2AB79DD175A3EFEC3F85CCD9DC647" box="[346,443,2035,2061]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/A83013" pageId="21" pageNumber="22">A83013</accessionNumber>
. Scale bar = 
<quantity id="A1799B7FDD175A3EFDCBF85CCEA9C644" box="[594,655,2035,2062]" metricMagnitude="-2" metricUnit="m" metricValue="1.0" pageId="21" pageNumber="22" unit="cm" value="1.0">1 cm</quantity>
.
</paragraph>
</caption>
