Comment: 
<taxonomicName id="52E14D47EF46FFFBFEBCFDB8FDE4FDB8" baseAuthorityName="SHARP" baseAuthorityYear="1874" box="[359,542,589,611]" class="Insecta" family="Staphylinidae" genus="Rugilus" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="458" phylum="Arthropoda" rank="species" species="rufescens">
