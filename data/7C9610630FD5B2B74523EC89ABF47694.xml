<subSubSection id="1F3C7F70448500535AD7CB13065EDD8D" pageId="null" pageNumber="333" type="description">
<paragraph id="F59F6137842EDC9525096537AB0D2627" pageId="null" pageNumber="333">
<normalizedToken id="B2AB9439C3A0D207F77F6E58F993F649" originalValue="Ähnlich" pageId="null" pageNumber="333">Aehnlich</normalizedToken>
<taxonomicName id="279C480AC49ACAE186D363914F958689" class="Magnoliopsida" family="Rosaceae" genus="Alchemilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="333" phylum="Tracheophyta" rank="species" species="incisa">
<emphasis id="87AB6E9C27124746EDDC7B73BAB42E16" italics="true" pageId="null" pageNumber="333">A. incisa</emphasis>
</taxonomicName>
(Nr. 6d). 
<normalizedToken id="C68CDA6FDA15CEF04AFC0D5DA6E1B43A" originalValue="Blätter" pageId="null" pageNumber="333">Blaetter</normalizedToken>
, mit Ausnahme des Randes, ganz kahl oder auf den Nerven unterseits zerstreut anliegend behaart. Form der 
<normalizedToken id="A875858F286D3BB2C275751C021ECAB8" originalValue="grundständigen" pageId="null" pageNumber="333">grundstaendigen</normalizedToken>
<normalizedToken id="946CD5C4DABFCCD91708EB37F1163241" originalValue="Blätter" pageId="null" pageNumber="333">Blaetter</normalizedToken>
wie bei 
<emphasis id="E4BD1C98A6180805296598C3811C22AC" italics="true" pageId="null" pageNumber="333">
<taxonomicName id="44BA04154334C80D763F83AEFD6870AF" authority="Blaetter" authorityName="Blaetter" class="Magnoliopsida" family="Rosaceae" genus="Alchemilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="333" phylum="Tracheophyta" rank="species" species="incisa">
A. incisa, 
<normalizedToken id="A63F135017E47EF71A04CECEAEB89339" originalValue="Blätter" pageId="null" pageNumber="333">Blaetter</normalizedToken>
</taxonomicName>
jedoch meist tiefer, bis auf
</emphasis>
⅓ 
<emphasis id="7C98F83851599C25F88F2F32D5A91AB3" italics="true" pageId="null" pageNumber="333">7</emphasis>
- 
<emphasis id="35B7CE3EAB4A3C33664C6678A15864C7" italics="true" pageId="null" pageNumber="333">9teilig.</emphasis>
Abschnitte stets nach dem Grunde 
<normalizedToken id="5DE42BB6E535C43517AD0829BD3B5773" originalValue="keilförmig" pageId="null" pageNumber="333">keilfoermig</normalizedToken>
<normalizedToken id="75515A20142BCE472AE9CE5BD235B67F" originalValue="verschmälert" pageId="null" pageNumber="333">verschmaelert</normalizedToken>
, die 
<normalizedToken id="423DBFA994E8D99FD75C4824004D36AE" originalValue="Ränder" pageId="null" pageNumber="333">Raender</normalizedToken>
in der untern 
<normalizedToken id="558C2A955F31849BAD04BA95E7A2CA2B" originalValue="Hälfte" pageId="null" pageNumber="333">Haelfte</normalizedToken>
ohne 
<normalizedToken id="8B036171E0ADB36F55F4A341506BC21D" originalValue="Zähne" pageId="null" pageNumber="333">Zaehne</normalizedToken>
, sich oft nicht 
<normalizedToken id="8991152652BCEA717ABE699CE32B4958" originalValue="berührend" pageId="null" pageNumber="333">beruehrend</normalizedToken>
; 
<normalizedToken id="AB48145AB3F84F36C21972A6AB686C98" originalValue="Zähne" pageId="null" pageNumber="333">Zaehne</normalizedToken>
1,5-2,5 mm lang, 
<normalizedToken id="400069BA2B6837E0E361F8AD50845CC0" originalValue="1½" pageId="null" pageNumber="333">11/2</normalizedToken>
-2mal so lang wie breit. Blattstiele wie bei 
<emphasis id="D0B6E117A09DEC6E6AA1BF260997D803" italics="true" pageId="null" pageNumber="333">
<taxonomicName id="E52E496BC12241DA1C45F8DF5251AEF9" class="Magnoliopsida" family="Rosaceae" genus="Alchemilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="333" phylum="Tracheophyta" rank="species" species="incisa">A. incisa</taxonomicName>
. Stengel an normal entwickelten Pflanzen 4
</emphasis>
- 
<emphasis id="D065AC328118035EDDB67D0A505B2AFC" italics="true" pageId="null" pageNumber="333">6</emphasis>
(bei den andern Arten der Gruppe 1-3), 
<emphasis id="33D79CBC61D6B231A767B5E5A9B9B35F" italics="true" pageId="null" pageNumber="333">niederliegend, an der Spitze bogig aufsteigend</emphasis>
, gelegentlich kahl. 
<emphasis id="3CADB44E6EE300844C2789FF460B6F4B" italics="true" pageId="null" pageNumber="333">
<normalizedToken id="194A4A3CEEAF90A6D0B5DF6315D8CA52" originalValue="Blütenstand" pageId="null" pageNumber="333">Bluetenstand</normalizedToken>
die 
<normalizedToken id="C8E3795E39D9ED83A5EE3E208424B21D" originalValue="Blätter" pageId="null" pageNumber="333">Blaetter</normalizedToken>
nicht 
<normalizedToken id="31FE8E8008E765F7571185F7A7FE1BA7" originalValue="überragend" pageId="null" pageNumber="333">ueberragend</normalizedToken>
, dicht.
</emphasis>
</paragraph>
<paragraph id="60110DB2CDBB709524ECA131A4D9DEFA" pageId="null" pageNumber="333">
<emphasis id="E3A5968F5B3581F196009CDCE9C44065" italics="true" pageId="null" pageNumber="333">
<pageBreakToken id="93A111F232C0CB7E3AD594F328EE8E89" pageId="null" pageNumber="333">Zytologische</pageBreakToken>
Angaben.
</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="59B1BDA44CC52D8CC51A7134F1F514CC" pageId="null" pageNumber="333">
<emphasis id="46F4DCF71639C308175385A1D2EF420C" italics="true" pageId="null" pageNumber="333">Standort.</emphasis>
Subalpin. Weiden.
</paragraph>
<paragraph id="E9470F63AAC7D1FF221FC7F7C5484B91" pageId="null" pageNumber="333">
<emphasis id="BCF9908D084A98013B5E719074B3C4AB" italics="true" pageId="null" pageNumber="333">Verbreitung.</emphasis>
Bisher nur aus dem Wallis bekannt; Angaben aus dem Tessin (Monte Generoso) sind 
<normalizedToken id="A1ADEF6015955DEA1ACA93849FF69B6E" originalValue="nachzuprüfen" pageId="null" pageNumber="333">nachzupruefen</normalizedToken>
. (Von Rothmaler 1962 nur die Angaben 
<normalizedToken id="6CB11C0FDBBD7ABACEC358F46C39AB7F" originalValue="Südschweiz" pageId="null" pageNumber="333">Suedschweiz</normalizedToken>
.)
</paragraph>
</subSubSection>
