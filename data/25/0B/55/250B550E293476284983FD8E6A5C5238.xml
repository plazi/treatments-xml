<subSubSection pageId="1" pageNumber="94" type="diagnosis">
<paragraph blockId="1.[136,1452,572,738]" pageId="1" pageNumber="94">
<taxonomicName authorityName="Demir, Sefali &amp; Yapar" authorityYear="2022" box="[136,320,572,593]" class="Magnoliopsida" family="Apiaceae" genus="Pastinaca" kingdom="Plantae" order="Apiales" pageId="1" pageNumber="94" phylum="Tracheophyta" rank="species" species="vanensis">
<emphasis box="[136,320,572,593]" italics="true" pageId="1" pageNumber="94">Pastinaca vanensis</emphasis>
</taxonomicName>
is related to 
<taxonomicName authorityName="Fenzl" authorityYear="1860" box="[441,569,572,593]" class="Magnoliopsida" family="Apiaceae" genus="Pastinaca" kingdom="Plantae" order="Apiales" pageId="1" pageNumber="94" phylum="Tracheophyta" rank="species" species="zozimoides">
<emphasis box="[441,569,572,593]" italics="true" pageId="1" pageNumber="94">P. zozimoides</emphasis>
</taxonomicName>
(
<figureCitation box="[582,639,572,594]" captionStart="FIGURE 3" captionStartId="3.[136,229,1047,1069]" captionTargetBox="[168,1423,370,1011]" captionTargetId="figure-97@3.[151,1436,353,1022]" captionTargetPageId="3" captionText="FIGURE 3. Pastinaca zozimoides; A. general habit, B. flowers, C. mericarps. (photos by Ahmet Savran)" figureDoi="http://doi.org/10.5281/zenodo.6809857" httpUri="https://zenodo.org/record/6809857/files/figure.png" pageId="1" pageNumber="94">Fig. 3</figureCitation>
). It differs from 
<taxonomicName authorityName="Fenzl" authorityYear="1860" box="[796,924,572,593]" class="Magnoliopsida" family="Apiaceae" genus="Pastinaca" kingdom="Plantae" order="Apiales" pageId="1" pageNumber="94" phylum="Tracheophyta" rank="species" species="zozimoides">
<emphasis box="[796,924,572,593]" italics="true" pageId="1" pageNumber="94">P. zozimoides</emphasis>
</taxonomicName>
in that the stem is 
<quantity box="[1101,1196,572,594]" metricMagnitude="-1" metricUnit="m" metricValue="3.35" metricValueMax="4.2" metricValueMin="2.5" pageId="1" pageNumber="94" unit="cm" value="33.5" valueMax="42.0" valueMin="25.0">25–42 cm</quantity>
long and glandular-villose (versus 
<quantity box="[267,365,608,630]" metricMagnitude="-1" metricUnit="m" metricValue="1.75" metricValueMax="2.5" metricValueMin="1.0" pageId="1" pageNumber="94" unit="cm" value="17.5" valueMax="25.0" valueMin="10.0">10–25 cm</quantity>
long and eglandular-villose), the petals are white-dirty to white (versus pinkish), and the mericarp is oblongobovate, 4–5 × 
<quantity box="[339,421,644,665]" metricMagnitude="-3" metricUnit="m" metricValue="3.5" metricValueMax="4.0" metricValueMin="3.0" pageId="1" pageNumber="94" unit="mm" value="3.5" valueMax="4.0" valueMin="3.0">3–4 mm</quantity>
, glandular-hairy (versus cordate-obovate, 3.5–4.5 × 
<quantity box="[923,1005,644,665]" metricMagnitude="-3" metricUnit="m" metricValue="3.5" metricValueMax="4.0" metricValueMin="3.0" pageId="1" pageNumber="94" unit="mm" value="3.5" valueMax="4.0" valueMin="3.0">3–4 mm</quantity>
, eglandular-hirsute).
</paragraph>
</subSubSection>
