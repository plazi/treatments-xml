<taxonomicName authorityName="Kollman" authorityYear="1910" class="Mammalia" family="Cheirogaleidae" genus="Microcebus" kingdom="Animalia" order="Primates" pageId="2" pageNumber="10" phylum="Chordata" rank="species" species="minor">Microcebus minor griseorufus Kollman, 1910</taxonomicName>
