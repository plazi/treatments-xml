<taxonomicName authorityName="Valenciennes" authorityYear="1840" class="Actinopterygii" family="Labridae" genus="Cheilinus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Cheilinus arenatus" order="Perciformes" pageId="0" pageNumber="135" phylum="Chordata" rank="species" species="arenatus">
<emphasis italics="true" pageId="0" pageNumber="135">Cheilinus arenatus</emphasis>
