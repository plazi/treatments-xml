<subSubSection id="79DA65243624FC06C482DE2CFE68B193" pageId="29" pageNumber="394" type="description">
<paragraph id="317F36AF3624FC06C482DE2CFE68B193" blockId="29.[178,1087,623,926]" pageId="29" pageNumber="394">
Comment: 
<taxonomicName id="F6C04D2C3624FC06C555DE2CFD30B124" authority="PACE 1988" authorityName="PACE" authorityYear="1988" box="[357,671,787,809]" class="Insecta" family="Staphylinidae" genus="Oxypoda" kingdom="Animalia" order="Coleoptera" pageId="29" pageNumber="394" phylum="Arthropoda" rank="species" species="insidiosa">
<emphasis id="03B4EABD3624FC06C555DE2CFD8BB124" box="[357,548,787,809]" italics="true" pageId="29" pageNumber="394">Oxypoda insidiosa</emphasis>
PACE 1988
</taxonomicName>
was synonymised with 
<taxonomicName id="F6C04D2C3624FC06C7ACDE2CFBB4B124" authorityName="KRAATZ" authorityYear="1857" box="[924,1051,787,809]" class="Insecta" family="Staphylinidae" genus="Oxypoda" kingdom="Animalia" order="Coleoptera" pageId="29" pageNumber="394" phylum="Arthropoda" rank="species" species="islandica">
<emphasis id="03B4EABD3624FC06C7ACDE2CFBB4B124" box="[924,1051,787,809]" italics="true" pageId="29" pageNumber="394">O. islandica</emphasis>
</taxonomicName>
by 
<bibRefCitation id="55514B5E3624FC06C482DE0FFEFEB14B" author="ASSING V" box="[178,337,816,838]" pageId="29" pageNumber="394" pagination="1301 - 1325" refId="ref19990" refString="ASSING V. (2008): Nine new species and additional records of Staphylinidae from southern Spain, with new synonymies (Insecta: Coleoptera). - Linzer biologische Beitrage 40 (2): 1301 - 1325." type="journal article" year="2008">ASSING (2008)</bibRefCitation>
. Since 
<taxonomicName id="F6C04D2C3624FC06C597DE0EFD87B14B" authorityName="PACE" authorityYear="1988" box="[423,552,816,838]" class="Insecta" family="Staphylinidae" genus="Oxypoda" kingdom="Animalia" order="Coleoptera" pageId="29" pageNumber="394" phylum="Arthropoda" rank="species" species="insidiosa">
<emphasis id="03B4EABD3624FC06C597DE0EFD87B14B" box="[423,552,816,838]" italics="true" pageId="29" pageNumber="394">O. insidiosa</emphasis>
</taxonomicName>
had already been synonymised with 
<taxonomicName id="F6C04D2C3624FC06C7F7DE0EFE9EB16E" authority="FAGEL 1960" authorityName="FAGEL" authorityYear="1960" class="Insecta" family="Staphylinidae" genus="Oxypoda" kingdom="Animalia" order="Coleoptera" pageId="29" pageNumber="394" phylum="Arthropoda" rank="species" species="dubiosa">
<emphasis id="03B4EABD3624FC06C7F7DE0EFB92B14B" box="[967,1085,816,838]" italics="true" pageId="29" pageNumber="394">O. dubiosa</emphasis>
<bibRefCitation id="55514B5E3624FC06C482DE71FE9EB16E" author="FAGEL G" box="[178,305,845,867]" pageId="29" pageNumber="394" pagination="222 - 233" refId="ref20379" refString="FAGEL G. (1960): Contribution a la connaissance des Staphylinidae. LXVIII. Notes sur quelques especes mediterraneennes. - Bulletin et Annales de la Societe Royale d'Entomologie de Belgique 96: 222 - 233." type="journal article" year="1960">FAGEL 1960</bibRefCitation>
</taxonomicName>
by 
<bibRefCitation id="55514B5E3624FC06C56CDE71FDB5B16E" author="TRONQUET M" box="[348,538,845,867]" pageId="29" pageNumber="394" pagination="167 - 181" refId="ref21161" refString="TRONQUET M. (1999): Sur quelques Oxypoda des collections A. Fauvel et G. Fagel; Derocala lucida n. sp. (Coleoptera, Staphylinidae). - Bulletin de la Societe Entomologique de France 104: 167 - 181." type="journal article" year="1999">TRONQUET (1999)</bibRefCitation>
, it follows that 
<taxonomicName id="F6C04D2C3624FC06C6F1DE71FC9CB16E" authorityName="FAGEL" authorityYear="1960" box="[705,819,845,867]" class="Insecta" family="Staphylinidae" genus="Oxypoda" kingdom="Animalia" order="Coleoptera" pageId="29" pageNumber="394" phylum="Arthropoda" rank="species" species="dubiosa">
<emphasis id="03B4EABD3624FC06C6F1DE71FC9CB16E" box="[705,819,845,867]" italics="true" pageId="29" pageNumber="394">O. dubiosa</emphasis>
</taxonomicName>
, too, is a synonym of 
<taxonomicName id="F6C04D2C3624FC06C014DE71FEA0B18D" authorityName="KRAATZ" authorityYear="1857" class="Insecta" family="Staphylinidae" genus="Oxypoda" kingdom="Animalia" order="Coleoptera" pageId="29" pageNumber="394" phylum="Arthropoda" rank="species" species="islandica">
<emphasis id="03B4EABD3624FC06C014DE71FEA0B18D" italics="true" pageId="29" pageNumber="394">O. islandica</emphasis>
</taxonomicName>
. For a distribution map, illustrations of the genitalia, and a compilation of records see 
<bibRefCitation id="55514B5E3624FC06C519DEB7FE6DB193" author="ASSING V" box="[297,450,904,926]" pageId="29" pageNumber="394" pagination="1301 - 1325" refId="ref19990" refString="ASSING V. (2008): Nine new species and additional records of Staphylinidae from southern Spain, with new synonymies (Insecta: Coleoptera). - Linzer biologische Beitrage 40 (2): 1301 - 1325." type="journal article" year="2008">ASSING (2008)</bibRefCitation>
.
</paragraph>
