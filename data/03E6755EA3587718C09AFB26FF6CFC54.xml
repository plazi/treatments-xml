) (
<bibRefCitation id="EFDEB9B9A35A7718C23EFC45FF61FC54" author="BENDERITTER E." pageId="10" pageNumber="307" pagination="101 - 109" refId="ref20782" refString="BENDERITTER E. 1929: Contribution a l'etude des Rutelides du Tonkin. Annales de la Societe Entomologique de France 98: 101 - 109." type="journal article" year="1929">BENDERITTER 1929</bibRefCitation>
