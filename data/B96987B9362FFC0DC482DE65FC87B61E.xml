<bibRefCitation id="55514B5E362FFC0DC5CADEFCFD37B1D5" author="ZERCHE L" box="[506,664,962,984]" pageId="22" pageNumber="387" pagination="307 - 336" refId="ref21311" refString="ZERCHE L. (1995): Revision der Oxypoda - Untergattung Cyrtonychochaeta SCHEERPELTZ, 1947, stat. n., und alpiner Arten der Untergattung Podoxya MULSANT &amp; REY, 1875 (Coleoptera, Staphylinidae, Aleocharinae). - Beitrage zur Entomologie, Berlin 45 (2): 307 - 336." type="journal article" year="1995">ZERCHE (1995)</bibRefCitation>
and 
<bibRefCitation id="55514B5E362FFC0DC6E2DEFDFC2AB1D5" author="SMETANA A" box="[722,901,962,984]" pageId="22" pageNumber="387" pagination="353 - 494" refId="ref21053" refString="SMETANA A. (2004): Staphylinidae, subfamily Aleocharinae, pp. 353 - 494. - In: LOBL I. &amp; A. SMETANA (eds), Catalogue of Palaearctic Coleoptera. II. Hydrophiloidea-Histeroidea- Staphylinoidea. Stenstrup: Apollo Books, 942 pp." type="book chapter" year="2004">SMETANA (2004)</bibRefCitation>
, this species was previously known only from southern 
<collectingCountry id="49D7763F362FFC0DC608DEDFFD39B1FB" box="[568,662,992,1014]" name="Germany" pageId="22" pageNumber="387">Germany</collectingCountry>
(
<collectingRegion id="F304F84D362FFC0DC694DEDFFD5FB1FB" box="[676,752,992,1014]" country="Germany" name="Bayern" pageId="22" pageNumber="387">Bayern</collectingRegion>
) and 
<collectingCountry id="49D7763F362FFC0DC719DEDFFCDCB1FB" box="[809,883,992,1014]" name="Austria" pageId="22" pageNumber="387">Austria</collectingCountry>
(Osttirol, 
<collectingRegion id="F304F84D362FFC0DC7EDDEDEFB9CB1FB" box="[989,1075,993,1014]" country="Austria" name="Karnten" pageId="22" pageNumber="387">Kärnten</collectingRegion>
). The above specimens represent the first record from 
<collectingCountry id="49D7763F362FFC0DC6F8DEC2FC8BB61E" box="[712,804,1021,1043]" name="Slovenia" pageId="22" pageNumber="387">Slovenia</collectingCountry>
