<subSubSection id="BBC5367C6E667C4E8DD898D52147E312" pageId="null" pageNumber="757" type="description">
<paragraph id="B34EE056E2EB519E5CCBE9504A18B337" pageId="null" pageNumber="757">
1 
<normalizedToken id="273D0AEEC9985585C590CDD36E84201D" originalValue="jährig" pageId="null" pageNumber="757">jaehrig</normalizedToken>
, bis 50 cm hoch, 
<normalizedToken id="9C975AAFAF50C2AA44C9F3B0F8C04548" originalValue="±" pageId="null" pageNumber="757">+/-</normalizedToken>
verzweigt, 
<emphasis id="51C4EB13482F1C7CA92A146D8CF6C073" italics="true" pageId="null" pageNumber="757">
ganze Pflanze dicht mit 
<normalizedToken id="7400FF8FAA90524E1ED621DD4B569A5B" originalValue="Drüsenhaaren" pageId="null" pageNumber="757">Druesenhaaren</normalizedToken>
besetzt, aromatisch riechend, klebrig
</emphasis>
(nur bei dieser Art so!), wenig verzweigt. 
<normalizedToken id="70DCCF4895E26B76F7D4CD77AE508AAD" originalValue="Blätter" pageId="null" pageNumber="757">Blaetter</normalizedToken>
im 
<normalizedToken id="89ADCC2A7642B2E18C31F3BE8B7A42CF" originalValue="Umriß" pageId="null" pageNumber="757">Umriss</normalizedToken>
oval oder lanzettlich, 
<emphasis id="E228783B3B10F4D593890AB737148B34" italics="true" pageId="null" pageNumber="757">
fiederteilig, mit ganzrandigen oder 
<normalizedToken id="7E869668E40245C6090FD0B32B33E75E" originalValue="unregelmäβig" pageId="null" pageNumber="757">unregelmaeβig</normalizedToken>
und grob 
<normalizedToken id="08DA4607DD5FF57902511EE2DCF724E6" originalValue="gezähnten" pageId="null" pageNumber="757">gezaehnten</normalizedToken>
Abschnitten
</emphasis>
, bis 7 cm lang und 
<normalizedToken id="C08A62D6E174C5EBE04EF18A9B5FB204" originalValue="1½" pageId="null" pageNumber="757">11/2</normalizedToken>
-3mal so lang wie breit, 
<emphasis id="AA1755391A65399EE9A36DC16C9BD885" italics="true" pageId="null" pageNumber="757">
<normalizedToken id="F08C58F6ACDFD150ABD5EB13DFF5022D" originalValue="gelbgrün" pageId="null" pageNumber="757">gelbgruen</normalizedToken>
.
</emphasis>
<normalizedToken id="6D5622B5A96C5D437908CD77B3A3FBE0" originalValue="Gesamtblütenstand" pageId="null" pageNumber="757">Gesamtbluetenstand</normalizedToken>
<normalizedToken id="7662B6FE9F521A8DF6AE4A5FFF25C524" originalValue="reichblütig" pageId="null" pageNumber="757">reichbluetig</normalizedToken>
. 
<normalizedToken id="65A73784B1483118F8ED09F04C0ED9C9" originalValue="Perigonblätter" pageId="null" pageNumber="757">Perigonblaetter</normalizedToken>
5, ganzrandig, 
<normalizedToken id="C89265F1196D4B5CD5D5F395A83D0BCC" originalValue="Staubblätter" pageId="null" pageNumber="757">Staubblaetter</normalizedToken>
5. Frucht quer zur 
<normalizedToken id="C8F79D817F426CE3F2A75B7245F7F3CB" originalValue="Längsrichtung" pageId="null" pageNumber="757">Laengsrichtung</normalizedToken>
etwas abgeflacht; Same dunkelbraun, 
<normalizedToken id="2C6C0F225FABE12B8CB5347EAF6EB693" originalValue="glänzend" pageId="null" pageNumber="757">glaenzend</normalizedToken>
, glatt. - 
<normalizedToken id="3A471DEC0C131879A6AFE14AEC965EA4" originalValue="Blüte" pageId="null" pageNumber="757">Bluete</normalizedToken>
: 
<normalizedToken id="F397D41A73538CAD925DBBA43B5F50B2" originalValue="Später" pageId="null" pageNumber="757">Spaeter</normalizedToken>
<normalizedToken id="4BD28AE3FBF75430C61271AE23A87282" originalValue="Frühling" pageId="null" pageNumber="757">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="7C1509DC34EDDD778C69E51FC19773AB" pageId="null" pageNumber="757">
<emphasis id="1E2C94B906D269D8A40E4FB21A1A480B" italics="true" pageId="null" pageNumber="757">Zytologische Angaben. 2n = 16:</emphasis>
(Kawatani und Ohno aus 
<normalizedToken id="77BE98995D564292149E0E032EBB4C11" originalValue="Löve" pageId="null" pageNumber="757">Loeve</normalizedToken>
und 
<normalizedToken id="4155EC3AF56E4F3D54EE98684F17BB1D" originalValue="Löve" pageId="null" pageNumber="757">Loeve</normalizedToken>
1961). 
<emphasis id="4026E0BC1A60A9245E3BDF71D79B188F" italics="true" pageId="null" pageNumber="757">2n = 36:</emphasis>
Material aus Indien (Mehra und Malik 1963).
</paragraph>
<paragraph id="3CBBB2CCA0C403236F12782A265CEC5C" pageId="null" pageNumber="757">
<emphasis id="3BFE46635C0F420F0FFBC24F101CBC32" italics="true" pageId="null" pageNumber="757">Standort.</emphasis>
Kollin und montan. Sandige bis steinige, 
<normalizedToken id="63357975A05D6DCE632C78FC88EB7A81" originalValue="nährstoffreiche" pageId="null" pageNumber="757">naehrstoffreiche</normalizedToken>
<normalizedToken id="9AEBC4331F613798E7D1EC9E84E9BCFE" originalValue="Böden" pageId="null" pageNumber="757">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="D7EF4FC594CEAE0DA0B57B1A4F0EEC6B" originalValue="Heiße" pageId="null" pageNumber="757">Heisse</normalizedToken>
, felsige 
<normalizedToken id="ECC8269A43AB5C16FD51B97EB50B47BF" originalValue="Hänge" pageId="null" pageNumber="757">Haenge</normalizedToken>
, Rebberge, 
<normalizedToken id="E950A3AC3B3DFBC5FB9128AB70AB04F5" originalValue="Schuttplätze" pageId="null" pageNumber="757">Schuttplaetze</normalizedToken>
, Ruderalstellen.
</paragraph>
<paragraph id="5964D06CB7961A9EB7D23CCC283F1223" pageId="null" pageNumber="757">
<emphasis id="26C8F322B6FE890407EBF58E38F2F994" italics="true" pageId="null" pageNumber="757">Verbreitung. Eurasiatische Pflanze:</emphasis>
Ganzes Mittelmeergebiet, durch West- und Zentralasien 
<normalizedToken id="7DB129ED0A9E32B8CD4243673F303417" originalValue="ostwärts" pageId="null" pageNumber="757">ostwaerts</normalizedToken>
bis China; in 
<taxonomicName id="D69F90C9BE480A976142FC5BFA59C4B2" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="757" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
<normalizedToken id="33691B36B0320816DEAE311FBA805168" originalValue="nordwärts" pageId="null" pageNumber="757">nordwaerts</normalizedToken>
bis in die zentralalpinen 
<normalizedToken id="B0B1FC6196FAD12111AC4978FFF00CD2" originalValue="Täler" pageId="null" pageNumber="757">Taeler</normalizedToken>
; 
<normalizedToken id="C821330081628F53877E6D3E55A5ACA5" originalValue="nördlich" pageId="null" pageNumber="757">noerdlich</normalizedToken>
der Alpen und der Balkanhalbinsel nur verschleppt; eingeschleppt ebenfalls in weiten Gebieten von Nordamerika und Australien. - Im Gebiet vom 
<normalizedToken id="031D902910759BBD8E4C655DB90A5975" originalValue="Süden" pageId="null" pageNumber="757">Sueden</normalizedToken>
her bis in die zentralalpinen 
<normalizedToken id="68D75ADE4A2420ABF4684EBD1297FC49" originalValue="Täler" pageId="null" pageNumber="757">Taeler</normalizedToken>
(Savoyen, Wallis, 
<normalizedToken id="A5ED8423E7868D1AFDFC2EF45C328EC9" originalValue="Graubünden" pageId="null" pageNumber="757">Graubuenden</normalizedToken>
), sonst nur selten und 
<normalizedToken id="C6F439C76F2EB9C8570EB91913571B2A" originalValue="unbeständig" pageId="null" pageNumber="757">unbestaendig</normalizedToken>
.
</paragraph>
</subSubSection>
