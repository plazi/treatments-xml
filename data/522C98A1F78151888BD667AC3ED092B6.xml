<geoCoordinate id="0D5E11ACCEEC171FF0D9AA31A0549F8D" degrees="8" direction="south" minutes="45" orientation="latitude" precision="925" value="-8.75">8°45'S</geoCoordinate>
, 
<geoCoordinate id="8904AED258BD7742578128521EA3BB4C" degrees="147" direction="east" minutes="30" orientation="longitude" precision="925" value="147.5">147°30'E</geoCoordinate>
, Papua New Guinea), 9 November 1896 (QM S111920).
