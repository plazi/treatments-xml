<subSubSection id="A281D4469718C201AC43D25FA41E9E0C" pageId="null" pageNumber="171" type="description">
<paragraph id="92DC10AD3C6FF97BA0BF3103FF06ED06" pageId="null" pageNumber="171">
Unterscheidet sich von der Gattung 
<taxonomicName id="ACEFE13913A6FF65CDE25E85B38DA4CF" class="Magnoliopsida" family="Brassicaceae" genus="Alyssum" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="171" phylum="Tracheophyta" rank="genus">
<emphasis id="3A406D623919C10B2A9F0FFB5C2033AD" italics="true" pageId="null" pageNumber="171">Alyssum</emphasis>
</taxonomicName>
(S. 168) durch folgende Merkmale: 
<normalizedToken id="55ECB693CCFACE1685A6A28754C5B2F7" originalValue="Kelchblätter" pageId="null" pageNumber="171">Kelchblaetter</normalizedToken>
aufrecht (nicht abstehend), die innern am Grunde etwas ausgebuchtet; 
<emphasis id="1AAA1815EB058C4CFE9482AD5125C6BE" italics="true" pageId="null" pageNumber="171">
<normalizedToken id="EB5B3E4C108FE4D4A2C2936E992F5127" originalValue="Kronblätter" pageId="null" pageNumber="171">Kronblaetter</normalizedToken>
lang gestielt
</emphasis>
, gelb oder rot; 
<emphasis id="4C1605CD71D3F171D8322DF942FE3512" italics="true" pageId="null" pageNumber="171">Fruchtstiele etwa</emphasis>
1/10 
<emphasis id="D4D3653E24B6CC624875E8E239CA83D3" italics="true" pageId="null" pageNumber="171">
so lang wie die 
<normalizedToken id="02223F19D49489DEAC7D742E43075A1F" originalValue="Früchte" pageId="null" pageNumber="171">Fruechte</normalizedToken>
; 
<normalizedToken id="0B98BAC2E7AC8E5F31C07DAF7C11606A" originalValue="Früchte" pageId="null" pageNumber="171">Fruechte</normalizedToken>
<normalizedToken id="72DC8E7B9C4AE925301BBF79FBF75B60" originalValue="groß" pageId="null" pageNumber="171">gross</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="B17C7635A8CB16AC8F5210675E3C793A" pageId="null" pageNumber="171">
Die Gattung 
<taxonomicName id="46FBED40570593088A358CFDFCB11102" class="Magnoliopsida" family="Brassicaceae" genus="Fibigia" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="171" phylum="Tracheophyta" rank="genus">
<emphasis id="6BB8235DE8CBF04E74A4B52787C55926" italics="true" pageId="null" pageNumber="171">Fibigia</emphasis>
</taxonomicName>
<normalizedToken id="D89B0FB75086B986C913A98C7DD232D5" originalValue="umfaßt" pageId="null" pageNumber="171">umfasst</normalizedToken>
etwa 
<emphasis id="66BC76B7EE1746D9094A8989BB568813" italics="true" pageId="null" pageNumber="171">12 ostmediterrane Arten</emphasis>
und ist sehr nahe verwandt mit 
<emphasis id="C55EB1D10D88CBE2ED675106FF24E27D" italics="true" pageId="null" pageNumber="171">
<taxonomicName id="27F10AA45A3A555FF37F7BAFC6F5D121" class="Magnoliopsida" family="Brassicaceae" genus="Alyssum" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="171" phylum="Tracheophyta" rank="genus">Alyssum</taxonomicName>
.
</emphasis>
</paragraph>
