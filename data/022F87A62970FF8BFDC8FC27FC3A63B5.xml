</taxonomicName>
, 
<taxonomicName id="4D864D332970FF8AFE45F93AFB96669C" authority="Chew Kea Foo, Porion &amp; Audibert, 2010" authorityName="Chew Kea Foo, Porion &amp; Audibert" authorityYear="2010" box="[511,1137,1735,1762]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="2" pageNumber="125" phylum="Arthropoda" rank="species" species="jasmini">
<emphasis id="B8F2EAA22970FF8AFE45F93AFD92669C" box="[511,629,1736,1761]" italics="true" pageId="2" pageNumber="125">P. jasmini</emphasis>
Chew Kea Foo, Porion &amp; Audibert, 2010
</taxonomicName>
, 
<taxonomicName id="4D864D332970FF8AFBC4F93AFE3F6775" authority="Wang, Xu &amp; Qin, 2018" authorityName="Wang, Xu &amp; Qin" authorityYear="2018" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="2" pageNumber="125" phylum="Arthropoda" rank="species" species="jiangfenglingensis">
<emphasis id="B8F2EAA22970FF8AFBC4F93AFA91669C" box="[1150,1398,1735,1761]" italics="true" pageId="2" pageNumber="125">P. jiangfenglingensis</emphasis>
<bibRefCitation id="EE174B412970FF8AFF07F91CFE3F6775" author="Wang W. Q. &amp; Xu S. - L. &amp; Qin D. - Z." box="[189,472,1774,1800]" pageId="2" pageNumber="125" pagination="296 - 309" refId="ref11557" refString="Wang W. Q., Xu S. - L. &amp; Qin D. - Z. 2018. The lanternfly genus Pyrops Spinola (Hemiptera: Fulgoridae) from China with description of a new species. Entomotaxonomia 40 (4): 296 - 309. https: // doi. org / 10.11680 / entomotax. 2018031" type="journal article" year="2018">Wang, Xu &amp; Qin, 2018</bibRefCitation>
</taxonomicName>
, 
<taxonomicName id="4D864D332970FF8AFE5CF91DFC6A6775" authority="Porion &amp; Audibert, 2020" authorityName="Porion &amp; Audibert" authorityYear="2020" box="[486,909,1774,1800]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="2" pageNumber="125" phylum="Arthropoda" rank="species" species="kozlovi">
<emphasis id="B8F2EAA22970FF8AFE5CF91DFDB06775" box="[486,599,1774,1800]" italics="true" pageId="2" pageNumber="125">P. kozlovi</emphasis>
Porion &amp; Audibert, 2020
</taxonomicName>
, 
<taxonomicName id="4D864D332970FF8AFC20F91DFF1C6752" authority="Nagai, Porion &amp; Audibert, 2017" authorityName="Nagai, Porion &amp; Audibert" authorityYear="2017" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="2" pageNumber="125" phylum="Arthropoda" rank="species" species="nishiguroi">
<emphasis id="B8F2EAA22970FF8AFC20F91DFBD66775" box="[922,1073,1774,1800]" italics="true" pageId="2" pageNumber="125">P. nishiguroi</emphasis>
Nagai, Porion &amp; Audibert, 2017
</taxonomicName>
, 
<taxonomicName id="4D864D332970FF8AFEBDF8E4FD576752" authority="Nagai &amp; Porion, 2002" authorityName="Nagai &amp; Porion" authorityYear="2002" box="[263,688,1813,1839]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="2" pageNumber="125" phylum="Arthropoda" rank="species" species="nishiyamai">
<emphasis id="B8F2EAA22970FF8AFEBDF8E4FE426752" box="[263,421,1813,1839]" italics="true" pageId="2" pageNumber="125">P. nishiyamai</emphasis>
Nagai &amp; Porion, 2002
</taxonomicName>
and 
<taxonomicName id="4D864D332970FF8AFD50F8E4FB106752" authority="Nagai, Porion &amp; Audibert, 2016" authorityName="Nagai, Porion &amp; Audibert" authorityYear="2016" box="[746,1271,1813,1839]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="2" pageNumber="125" phylum="Arthropoda" rank="species" species="priscillae">
<emphasis id="B8F2EAA22970FF8AFD50F8E4FC916752" box="[746,886,1813,1839]" italics="true" pageId="2" pageNumber="125">P. priscillae</emphasis>
Nagai, Porion &amp; Audibert, 2016
</taxonomicName>
(
<bibRefCitation id="EE174B412970FF8AFABCF8E7FF1B672B" author="Bourgoin T." pageId="2" pageNumber="125" refId="ref9833" refString="Bourgoin T. 2021. FLOW (Fulgoromorpha Lists on The Web): a world knowledge base dedicated to Fulgoromorpha. Version 8, [3 Feb. 2022]. Available from http: // hemiptera-databases. org / flow / [accessed 8 Mar. 2022]." type="url" year="2021">Bourgoin 2021</bibRefCitation>
). Finally, 
<taxonomicName id="4D864D332970FF8AFECBF8CEFD3E672B" authority="(Kirby, 1818)" baseAuthorityName="Kirby" baseAuthorityYear="1818" box="[369,729,1851,1878]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="2" pageNumber="125" phylum="Arthropoda" rank="species" species="lathburii">
<emphasis id="B8F2EAA22970FF8AFECBF8CEFDD66728" box="[369,561,1851,1877]" italics="true" pageId="2" pageNumber="125">Pyrops lathburii</emphasis>
(
<bibRefCitation id="EE174B412970FF8AFDFBF8C9FD36672B" author="Kirby W. F." box="[577,721,1851,1878]" pageId="2" pageNumber="125" pagination="375 - 453" refId="ref10857" refString="Kirby W. F. 1818. A century of insects, including several new genera described from his cabinet. The Transactions of the Linnean Society of London. Second series. Zoology 12 (2): 375 - 453. https: // doi. org / 10.1111 / j. 1095 - 8339.1817. tb 00239. x" type="journal article" year="1818">Kirby, 1818</bibRefCitation>
)
</taxonomicName>
is here transferred to the 
<taxonomicName id="4D864D332970FF8AFBBDF8C9FB616728" baseAuthorityName="Linnaeus" baseAuthorityYear="1758" box="[1031,1158,1851,1877]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="2" pageNumber="125" phylum="Arthropoda" rank="species" species="candelaria">
<emphasis id="B8F2EAA22970FF8AFBBDF8C9FB616728" box="[1031,1158,1851,1877]" italics="true" pageId="2" pageNumber="125">candelaria</emphasis>
</taxonomicName>
species group, from the 
<emphasis id="B8F2EAA22970FF8AFF52F890FE746701" box="[232,403,1890,1916]" italics="true" pageId="2" pageNumber="125">pyrorrhynchus</emphasis>
species group.
</paragraph>
<paragraph id="8A3936B02970FF8AFF07F85AFAF06795" blockId="2.[189,1398,1959,2025]" pageId="2" pageNumber="125">
It is widely distributed in the Oriental Region: from 
<collectingCountry id="F29176202970FF8AFC93F855FC7B67BC" box="[809,924,1959,1985]" name="Sri Lanka" pageId="2" pageNumber="125">Sri Lanka</collectingCountry>
it extends over northern 
<collectingCountry id="F29176202970FF8AFB7CF855FAE267BC" box="[1222,1285,1959,1985]" name="India" pageId="2" pageNumber="125">India</collectingCountry>
, southern 
<collectingCountry id="F29176202970FF8AFF07F83CFEE16795" box="[189,262,1998,2024]" name="China" pageId="2" pageNumber="125">China</collectingCountry>
, 
<collectingCountry id="F29176202970FF8AFEABF83CFE8D6795" box="[273,362,1998,2024]" name="Taiwan" pageId="2" pageNumber="125">Taiwan</collectingCountry>
, all Indochina, the 
<collectingCountry id="F29176202970FF8AFDF0F83CFD366795" box="[586,721,1998,2024]" name="Philippines" pageId="2" pageNumber="125">Philippines</collectingCountry>
, 
<collectingCountry id="F29176202970FF8AFD66F83CFCAF6795" box="[732,840,1998,2024]" name="Malaysia" pageId="2" pageNumber="125">Malaysia</collectingCountry>
and 
<collectingCountry id="F29176202970FF8AFC3BF83CFC146795" box="[897,1011,1998,2024]" name="Indonesia" pageId="2" pageNumber="125">Indonesia</collectingCountry>
southwards to 
<collectingRegion id="4842F8522970FF8AFB1FF83CFAF46795" box="[1189,1299,1998,2024]" country="Indonesia" name="Sulawesi Utara" pageId="2" pageNumber="125">Sulawesi</collectingRegion>
.
</paragraph>
<paragraph id="8A3936B02971FF8BFF07FEFBFDAB615E" blockId="3.[189,588,264,291]" box="[189,588,264,291]" pageId="3" pageNumber="126">
<heading id="D17181DC2971FF8BFF07FEFBFDAB615E" bold="true" box="[189,588,264,291]" fontSize="11" level="3" pageId="3" pageNumber="126" reason="3">
<emphasis id="B8F2EAA22971FF8BFF07FEFBFDAB615E" bold="true" box="[189,588,264,291]" pageId="3" pageNumber="126">
The 
<taxonomicName id="4D864D332971FF8BFF4FFEFAFE7A615E" baseAuthorityName="Donovan" baseAuthorityYear="1800" box="[245,413,264,291]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="pyrorhynchus">
<emphasis id="B8F2EAA22971FF8BFF4FFEFAFE7A615E" bold="true" box="[245,413,264,291]" italics="true" pageId="3" pageNumber="126">pyrorhynchus</emphasis>
</taxonomicName>
species group
</emphasis>
</heading>
</paragraph>
<paragraph id="8A3936B02971FF8BFF07FEC5FDC36109" blockId="3.[189,1399,311,550]" pageId="3" pageNumber="126">
The 
<taxonomicName id="4D864D332971FF8BFF48FEC5FE75612C" baseAuthorityName="Donovan" baseAuthorityYear="1800" box="[242,402,311,337]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="pyrorhynchus">
<emphasis id="B8F2EAA22971FF8BFF48FEC5FE75612C" box="[242,402,311,337]" italics="true" pageId="3" pageNumber="126">pyrorhynchus</emphasis>
</taxonomicName>
species group, as defined by 
<bibRefCitation id="EE174B412971FF8BFD50FEC5FC23612C" author="Baker C. F." box="[746,964,311,338]" pageId="3" pageNumber="126" pagination="343 - 364" refId="ref9803" refString="Baker C. F. 1925. Remarks on certain Indo-Malayan Fulgora, with special reference to Philippines species. Philippines Journal of Science 28: 343 - 364." type="journal article" year="1925">Baker (1925: 347)</bibRefCitation>
, contains species characterized by: (1) large, stout, elongate body;
</paragraph>
<paragraph id="8A3936B02971FF8BFF07FE8CFCE0627F" blockId="3.[189,1399,311,550]" pageId="3" pageNumber="126">(2) long stout cephalic process, not tapering apically, with width in dorsal view about equal along distal ⅘ and height in lateral view about equal along distal ⅘; upper margin in lateral view abruptly bent beyond mid-length (apical part often slightly higher in lateral view); apically brightly coloured, yellow to red; (3) anteocular carina slightly extending on vertex;</paragraph>
<paragraph id="8A3936B02971FF8BFF07FDF9FB466258" blockId="3.[189,1399,311,550]" box="[189,1185,522,550]" pageId="3" pageNumber="126">(4) hind wings bright blue on basal ⅓, with apex and posterior margin broadly black.</paragraph>
<paragraph id="8A3936B02971FF8BFF07FDBFFC3A63B5" blockId="3.[189,1399,589,969]" pageId="3" pageNumber="126">
According to 
<bibRefCitation id="EE174B412971FF8BFEE4FDBFFE1A6215" author="Baker C. F." box="[350,509,589,616]" pageId="3" pageNumber="126" pagination="343 - 364" refId="ref9803" refString="Baker C. F. 1925. Remarks on certain Indo-Malayan Fulgora, with special reference to Philippines species. Philippines Journal of Science 28: 343 - 364." type="journal article" year="1925">Baker (1925)</bibRefCitation>
, the group contained 
<taxonomicName id="4D864D332971FF8BFD43FDBCFBCE621A" authority="Schmidt, 1923" authorityName="Schmidt" authorityYear="1923" box="[761,1065,589,615]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="incertus">
<emphasis id="B8F2EAA22971FF8BFD43FDBCFC93621A" box="[761,884,590,615]" italics="true" pageId="3" pageNumber="126">P. incertus</emphasis>
Schmidt, 1923
</taxonomicName>
, 
<taxonomicName id="4D864D332971FF8BFB8CFDBCFEE662F7" authority="(Donovan, 1800)" baseAuthorityName="Donovan" baseAuthorityYear="1800" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="pyrorhynchus">
<emphasis id="B8F2EAA22971FF8BFB8CFDBCFB14621A" box="[1078,1267,589,615]" italics="true" pageId="3" pageNumber="126">P. pyrorhynchus</emphasis>
(Donovan, 1800)
</taxonomicName>
and 
<taxonomicName id="4D864D332971FF8BFE8CFD83FD8962F7" authority="(Distant, 1891)" baseAuthorityName="Distant" baseAuthorityYear="1891" box="[310,622,624,650]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="pythicus">
<emphasis id="B8F2EAA22971FF8BFE8CFD83FE5462F7" box="[310,435,624,650]" italics="true" pageId="3" pageNumber="126">P. pythicus</emphasis>
(Distant, 1891)
</taxonomicName>
. 
<bibRefCitation id="EE174B412971FF8BFDC2FD82FCAD62F6" author="Lallemand V." box="[632,842,624,651]" pageId="3" pageNumber="126" pagination="1 - 99" refId="ref10944" refString="Lallemand V. 1963. Revision des Fulgoridae (Homoptera). Deuxieme partie. Faunes asiatique et australienne. Memoires de l'Institut royal des Sciences naturelles de Belgique (2 e serie) 75: 1 - 99." type="journal article" year="1963">Lallemand (1963)</bibRefCitation>
added seven species to the group by broadening its interpretation without providing any justification, and 
<bibRefCitation id="EE174B412971FF8BFCD7FD61FB6362D3" author="Nagai S. &amp; Porion T." box="[877,1156,659,686]" pageId="3" pageNumber="126" refId="ref11134" refString="Nagai S. &amp; Porion T. 1996. Fulgoridae 2: Catalogue illustre des Faunes asiatique et australienne. Sciences Nat, Compiegne." type="book" year="1996">Nagai &amp; Porion (1996)</bibRefCitation>
followed his views. More recently, 
<bibRefCitation id="EE174B412971FF8BFEC9FD45FD4862AC" author="Constant J. &amp; Mohan A. V." box="[371,687,695,721]" pageId="3" pageNumber="126" pagination="1 - 24" refId="ref10257" refString="Constant J. &amp; Mohan A. V. 2017. The lanternflies from Andaman and Nicobar: one new Pyrops species, new records and illustrated key to the species (Hemiptera: Fulgoromorpha: Fulgoridae). Belgian Journal of Entomology 49: 1 - 24." type="journal article" year="2017">Constant &amp; Mohan (2017)</bibRefCitation>
transferred one of these species, 
<taxonomicName id="4D864D332971FF8BFBFAFD4AFA9562AF" authority="(Distant, 1906)" authorityName="" baseAuthorityName="Distant" baseAuthorityYear="1906" box="[1088,1394,695,722]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="rogersi">
<emphasis id="B8F2EAA22971FF8BFBFAFD4AFB5562AC" box="[1088,1202,696,721]" italics="true" pageId="3" pageNumber="126">P. rogersi</emphasis>
(
<bibRefCitation id="EE174B412971FF8BFB79FD45FA8E62AF" author="Distant W. L." box="[1219,1385,695,722]" pageId="3" pageNumber="126" refId="ref10413" refString="Distant W. L. 1906. Rhynchota Vol. 3. Heteroptera-Homoptera. In: C. T. Bingham (ed.) The Fauna of British India, including Ceylon and Burma. Taylor and Francis, London. https: // doi. org / 10.5962 / bhl. title. 48423" type="book" year="1906">Distant, 1906</bibRefCitation>
)
</taxonomicName>
, from the 
<taxonomicName id="4D864D332971FF8BFE93FD28FE2E6289" baseAuthorityName="Donovan" baseAuthorityYear="1800" box="[297,457,730,756]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="pyrorhynchus">
<emphasis id="B8F2EAA22971FF8BFE93FD28FE2E6289" box="[297,457,730,756]" italics="true" pageId="3" pageNumber="126">pyrorhynchus</emphasis>
</taxonomicName>
to the 
<taxonomicName id="4D864D332971FF8BFDA0FD28FD7E6289" baseAuthorityName="Linnaeus" baseAuthorityYear="1758" box="[538,665,730,756]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="candelaria">
<emphasis id="B8F2EAA22971FF8BFDA0FD28FD7E6289" box="[538,665,730,756]" italics="true" pageId="3" pageNumber="126">candelaria</emphasis>
</taxonomicName>
group, and two additional ones, 
<taxonomicName id="4D864D332971FF8BFBA0FD29FAA36289" authority="(Kirby, 1818)" baseAuthorityName="Kirby" baseAuthorityYear="1818" box="[1050,1348,730,756]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="lathburii">
<emphasis id="B8F2EAA22971FF8BFBA0FD29FB796289" box="[1050,1182,730,756]" italics="true" pageId="3" pageNumber="126">P. lathburii</emphasis>
(
<bibRefCitation id="EE174B412971FF8BFB17FD28FADB6289" author="Kirby W. F." box="[1197,1340,730,756]" pageId="3" pageNumber="126" pagination="375 - 453" refId="ref10857" refString="Kirby W. F. 1818. A century of insects, including several new genera described from his cabinet. The Transactions of the Linnean Society of London. Second series. Zoology 12 (2): 375 - 453. https: // doi. org / 10.1111 / j. 1095 - 8339.1817. tb 00239. x" type="journal article" year="1818">Kirby, 1818</bibRefCitation>
)
</taxonomicName>
and 
<taxonomicName id="4D864D332971FF8BFF07FD0CFE006365" authority="(Distant, 1914)" baseAuthorityName="Distant" baseAuthorityYear="1914" box="[189,487,765,792]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="astarte">
<emphasis id="B8F2EAA22971FF8BFF07FD0CFECC636A" box="[189,299,766,791]" italics="true" pageId="3" pageNumber="126">P. astarte</emphasis>
(
<bibRefCitation id="EE174B412971FF8BFE81FD0FFE396365" author="Distant W. L." box="[315,478,765,792]" pageId="3" pageNumber="126" pagination="409 - 424" refId="ref10469" refString="Distant W. L. 1914. Some additions to the genera and species in the Homopterous family Fulgoridae. Annals and Magazine of Natural History. London. (Ser. 8) 13: 409 - 424. https: // doi. org / 10.1080 / 00222931408693503" type="journal article" year="1914">Distant, 1914</bibRefCitation>
)
</taxonomicName>
, are synonymized and moved to the 
<taxonomicName id="4D864D332971FF8BFC2FFD0FFBF3636A" baseAuthorityName="Linnaeus" baseAuthorityYear="1758" box="[917,1044,765,791]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="candelaria">
<emphasis id="B8F2EAA22971FF8BFC2FFD0FFBF3636A" box="[917,1044,765,791]" italics="true" pageId="3" pageNumber="126">candelaria</emphasis>
</taxonomicName>
group in the present work. As a result, the 
<taxonomicName id="4D864D332971FF8BFEF7FCD3FE0A6346" baseAuthorityName="Donovan" baseAuthorityYear="1800" box="[333,493,801,827]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="pyrorhynchus">
<emphasis id="B8F2EAA22971FF8BFEF7FCD3FE0A6346" box="[333,493,801,827]" italics="true" pageId="3" pageNumber="126">pyrorhynchus</emphasis>
</taxonomicName>
group currently contains the following taxa: 
<taxonomicName id="4D864D332971FF8BFBBBFCD0FB0E6346" authority="pythicus" box="[1025,1257,801,827]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="subSpecies" species="pythicus" subSpecies="pythicus">
<emphasis id="B8F2EAA22971FF8BFBBBFCD0FB0E6346" box="[1025,1257,801,827]" italics="true" pageId="3" pageNumber="126">P. pythicus pythicus</emphasis>
</taxonomicName>
, 
<taxonomicName id="4D864D332971FF8BFB42FCD0FE386323" authority="(Schmidt, 1923)" baseAuthorityName="Schmidt" baseAuthorityYear="1923" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="subSpecies" species="pythicus" subSpecies="incertus">
<emphasis id="B8F2EAA22971FF8BFB42FCD0FEFC6323" italics="true" pageId="3" pageNumber="126">P. pythicus incertus</emphasis>
(Schmidt, 1923)
</taxonomicName>
, 
<taxonomicName id="4D864D332971FF8BFE53FCB7FCEA6322" authority="(Schmidt, 1926)" baseAuthorityName="Schmidt" baseAuthorityYear="1926" box="[489,781,836,863]" class="Insecta" family="Fulgoridae" genus="Pyrops" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="126" phylum="Arthropoda" rank="species" species="ruehli">
<emphasis id="B8F2EAA22971FF8BFE53FCB7FDAE6323" box="[489,585,836,862]" italics="true" pageId="3" pageNumber="126">P. ruehli</emphasis>
(Schmidt, 1926)
</taxonomicName>
, 
