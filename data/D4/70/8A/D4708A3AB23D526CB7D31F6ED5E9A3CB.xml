<bibRefCitation DOI="https://doi.org/10.11646/zootaxa.4018.4.2" author="Manuel, M" journalOrPublisher="Zootaxa" pageId="0" pageNumber="301" pagination="506 - 534" refId="B56" refString="Manuel, M, 2015. The genus Notomicrus in Guadeloupe, with description of three new species (Coleoptera: Noteridae). Zootaxa 4018 (4): 506 - 534, DOI: https://doi.org/10.11646/zootaxa.4018.4.2" title="The genus Notomicrus in Guadeloupe, with description of three new species (Coleoptera: Noteridae)." url="https://doi.org/10.11646/zootaxa.4018.4.2" volume="4018" year="2015">Manuel 2015</bibRefCitation>
