<figureCitation id="A7831FACFF8B864FD985C2D9FEFE7C3E" box="[144,281,241,267]" captionStart-0="FIGURE 62" captionStart-1="FIGURE 63" captionStartId-0="94.[136,235,1977,2001]" captionStartId-1="95.[136,235,1229,1253]" captionTargetBox-0="[151,1436,1381,1961]" captionTargetBox-1="[151,1436,158,1188]" captionTargetId-0="figure-557@94.[151,1436,1381,1961]" captionTargetId-1="figure-320@95.[151,1436,158,1188]" captionTargetPageId-0="94" captionTargetPageId-1="95" captionText-0="FIGURE 62. Holotype of Coelorinchus lanceolatus sp. nov. NSMT-P 95590, 79.2 mm HL, 255+ mm TL, off Ogasawara Islands, Shichito-Iojima Ridge, Pacific, 521–536 m depth. (A) Lateral view; (B) dorsal and (C) ventral views of the head and trunk. Preserved condition. [Photos: N. Nakayama]" captionText-1="FIGURE 63. Scanning electron micrographs showing scales of Coelorinchus lanceolatus sp. nov. NSMT-P 95590, holotype, 79.2 mm HL. (A–B) Scales from the dorsum below the interdorsal space; (C–D) from the top of the head between the parietal ridges. (A, C) Views from above; (B, D) oblique views. [Photos: N. Nakayama]" figureDoi-0="http://doi.org/10.5281/zenodo.6422922" figureDoi-1="http://doi.org/10.5281/zenodo.6422926" httpUri-0="https://zenodo.org/record/6422922/files/figure.png" httpUri-1="https://zenodo.org/record/6422926/files/figure.png" pageId="93" pageNumber="94">Figs. 62–63</figureCitation>
; 
<tableCitation id="723A3692FF8B864FD831C2D9FE9F7C3E" box="[292,376,241,267]" captionStart="TABLE 1" captionStartId="30.[136,224,161,185]" captionTargetPageId="30" captionText="TABLE 1. Morphometric measurements and meristic counts* for Coelorinchus anatirostris and C. lanceolatus sp. nov." httpUri="http://table.plazi.org/id/6BC753A1FFC8860CD99DC289FA607D8C" pageId="93" pageNumber="94" tableUuid="6BC753A1FFC8860CD99DC289FA607D8C">Table 1</tableCitation>
