<emphasis id="F5E1EA88FFB6FFC8C48F025995D4FBA0" box="[151,255,1067,1090]" italics="true" pageId="1" pageNumber="390">Zeuxippus</emphasis>
Thorell, 1891: 109
</taxonomicName>
(
<typeStatus id="182E8838FFB6FFC8C5C00259972EFBA1" box="[472,517,1067,1091]" pageId="1" pageNumber="390">type</typeStatus>
species: 
<taxonomicName id="00954D19FFB6FFC8C67E02599684FBA1" authority="Thorell, 1891" authorityName="Thorell" authorityYear="1891" box="[614,943,1067,1091]" class="Arachnida" family="Salticidae" genus="Zeuxippus" kingdom="Animalia" order="Araneae" pageId="1" pageNumber="390" phylum="Arthropoda" rank="species" species="histrio">
<emphasis id="F5E1EA88FFB6FFC8C67E02599632FBA1" box="[614,793,1067,1091]" italics="true" pageId="1" pageNumber="390">Zeuxippus histrio</emphasis>
Thorell, 1891
</taxonomicName>
