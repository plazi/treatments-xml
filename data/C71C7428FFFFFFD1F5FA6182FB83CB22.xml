<paragraph id="4F0AC53EFFFFFFD1F5246346FD9CCC98" blockId="27.[111,648,494,1101]" pageId="27" pageNumber="262">
DISTRIBUTION. — This species is restricted to SW corner of 
<collectingCountry id="37A285AEFFFFFFD1F5DF637FFF36CCC8" box="[138,253,875,899]" name="Madagascar" pageId="27" pageNumber="262">Madagascar</collectingCountry>
(
<collectorName id="E240A0E8FFFFFFD1F45F637FFE48CCC8" box="[266,387,875,899]" pageId="27" pageNumber="262">Andohahela</collectorName>
, 
<collectorName id="E240A0E8FFFFFFD1F4DB637FFD9BCCC8" box="[398,592,875,899]" pageId="27" pageNumber="262">Col du Maningotry</collectorName>
, 
<collectorName id="E240A0E8FFFFFFD1F70F637FFF6FCCD5" pageId="27" pageNumber="262">Ifarantsa</collectorName>
) between 
<quantity id="884D68DBFFFFFFD1F4536392FEBFCCD6" box="[262,372,902,926]" metricMagnitude="2" metricUnit="m" metricValue="4.5" metricValueMax="6.0" metricValueMin="3.0" pageId="27" pageNumber="262" unit="m" value="450.0" valueMax="600.0" valueMin="300.0">
<elevation id="C498220DFFFFFFD1F4536392FEBFCCD6" box="[262,372,902,926]" metricMagnitude="2" metricUnit="m" metricValue="4.5" metricValueMax="6.0" metricValueMin="3.0" pageId="27" pageNumber="262" unit="m" value="450.0" valueMax="600.0" valueMin="300.0">300-600 m</elevation>
