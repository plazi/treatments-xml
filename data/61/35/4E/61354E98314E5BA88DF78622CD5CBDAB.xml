<caption doi="10.3897/zookeys.1108.85655.figure7" httpUri="https://binary.pensoft.net/fig/705988" pageId="0" pageNumber="189" start="Figure 7" startId="F7">
<paragraph pageId="0" pageNumber="189">
<emphasis bold="true" pageId="0" pageNumber="189">Figure 7.</emphasis>
