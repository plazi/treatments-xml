, 
<figureCitation box="[293,322,721,747]" captionStart="FIGURE 30" captionStartId="10.[151,250,1975,1999]" captionTargetBox="[298,1290,982,1951]" captionTargetId="figure-292@10.[298,1290,982,1951]" captionTargetPageId="10" captionText="FIGURE 30. Distribution records of five species of Paravelia in South America." figureDoi="http://doi.org/10.5281/zenodo.6810204" httpUri="https://zenodo.org/record/6810204/files/figure.png" pageId="1" pageNumber="278">30</figureCitation>
