<taxonomicName id="4C6A4D06FFC4FFD2FF67F903BD5AC80E" authority="F. Kern, Mycologia" authorityName="F. Kern, Mycologia" box="[198,623,1774,1801]" class="Pucciniomycetes" family="Pucciniaceae" genus="Puccinia" kingdom="Fungi" order="Pucciniales" pageId="23" pageNumber="244" phylum="Basidiomycota" rank="species" species="urticata">
