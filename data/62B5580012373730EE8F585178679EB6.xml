<subSubSection id="BD787357DBD9CB410A10BA2DFEA822E1" pageId="null" pageNumber="592" type="description">
<paragraph id="B7110E59F651A43597C086DF6F28712C" pageId="null" pageNumber="592">
<normalizedToken id="0BADDCFE7D2BCB854287970BE0C5C61F" originalValue="Teilblätter" pageId="null" pageNumber="592">Teilblaetter</normalizedToken>
der obern 
<normalizedToken id="E0CFC07AD0698C5D74D133E70A49BDAF" originalValue="Blätter" pageId="null" pageNumber="592">Blaetter</normalizedToken>
am Grunde meist abgerundet, 6-12mal so lang wie breit. 
<emphasis id="49C130DBA22409560EF5E0DD0CCF7DBF" italics="true" pageId="null" pageNumber="592">Kelch 7-10 mm lang</emphasis>
, 
<normalizedToken id="A6D3786C933473F5E2EF16C96A183AE4" originalValue="½" pageId="null" pageNumber="592">1/2</normalizedToken>
-⅔ 
<emphasis id="4C635D79D081837EA02FC46D850C6EDB" italics="true" pageId="null" pageNumber="592">so lang wie die Fahne, behaart;</emphasis>
<normalizedToken id="DA0BEB97A86625FF7475F54F619138D4" originalValue="Kelchzähne" pageId="null" pageNumber="592">Kelchzaehne</normalizedToken>
<normalizedToken id="8DA84FDCC4E412C07E18268921FE8FCC" originalValue="kürzer" pageId="null" pageNumber="592">kuerzer</normalizedToken>
als die 
<normalizedToken id="E922059FD4AAD999AB3A7F5371DCE7A3" originalValue="Kelchröhre" pageId="null" pageNumber="592">Kelchroehre</normalizedToken>
. Krone 1,3-1,7 cm lang, fast einfarbig. Fahne senkrecht nach oben gebogen, rotviolett, 
<emphasis id="3518E3A2F21B46D7C8A95940A6BAA9AD" italics="true" pageId="null" pageNumber="592">
<normalizedToken id="C5E4F3D704DB779D52914272E13669D6" originalValue="außen" pageId="null" pageNumber="592">aussen</normalizedToken>
gleichfarbig
</emphasis>
, fast gleichfarbig wie die 
<normalizedToken id="6BA06208AF8CC701102CEA4EE19B11AE" originalValue="Flügel" pageId="null" pageNumber="592">Fluegel</normalizedToken>
, Schiffchen 
<normalizedToken id="210C381F18CED048A307376794A452E8" originalValue="grünlich" pageId="null" pageNumber="592">gruenlich</normalizedToken>
bis 
<normalizedToken id="E08810D903A11F03F9B01BAA96439327" originalValue="rötlich" pageId="null" pageNumber="592">roetlich</normalizedToken>
. Frucht 3-5 cm lang und 0,35 bis 0,5 cm breit, ohne 
<normalizedToken id="818D641B38B3C9E904C59A0909842B1E" originalValue="Einschnürungen" pageId="null" pageNumber="592">Einschnuerungen</normalizedToken>
, nicht abgeflacht, schwarz, fast kahl; Haare der Frucht 0,1 bis 0,2 mm lang. Samen 9-12 je Frucht, 2-3 mm lang. - 
<normalizedToken id="A44A9238375721BB24B3D72F2DEF436B" originalValue="Blüte" pageId="null" pageNumber="592">Bluete</normalizedToken>
: 
<normalizedToken id="FC4F5DD98209D18C85BCFCEC0BECD19F" originalValue="Später" pageId="null" pageNumber="592">Spaeter</normalizedToken>
<normalizedToken id="BE71165A9FDC4A2F06F82E776B263867" originalValue="Frühling" pageId="null" pageNumber="592">Fruehling</normalizedToken>
und 
<normalizedToken id="915B4ED3192516B25871C9A906E1D5CF" originalValue="früher" pageId="null" pageNumber="592">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="235DA0174B3FC423B394B7D09DB95AFD" pageId="null" pageNumber="592">
<emphasis id="73839E5BEC4C5B06F0899EC60B5B20F2" italics="true" pageId="null" pageNumber="592">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="EF01DD657D360534C237595A140ECE27" italics="true" pageId="null" pageNumber="592">12:</emphasis>
Ohne Herkunftsangabe des Materials (Sveshnikova 1927, Mettin und Hanelt 1964), Material aus Kanada (Mulligan 1961), aus der Slowakei (
<normalizedToken id="BF749862B5685F1992053C46EB288910" originalValue="Činčura" pageId="null" pageNumber="592">Cincura</normalizedToken>
1963), aus dem Kaukasus (Chuxanova 1967).
</paragraph>
<paragraph id="099454BE28FA1F74CB9C5342C6CFA3E0" pageId="null" pageNumber="592">
<emphasis id="6746A1B3074735206832EFDA0498261C" italics="true" pageId="null" pageNumber="592">Standort.</emphasis>
Kollin und montan. Trockene lehmige 
<normalizedToken id="9B39E85BD530368930349A2D7BE2D8CC" originalValue="Böden" pageId="null" pageNumber="592">Boeden</normalizedToken>
in warmen Lagen. Trockenwiesen, Felsenheiden.
</paragraph>
<paragraph id="57771A7D737502BD794BB1B79C058264" pageId="null" pageNumber="592">
<emphasis id="F394F05F96F2C05B1E09D2BCDDB5CFA9" italics="true" pageId="null" pageNumber="592">Verbreitung. Mediterrane Pflanze:</emphasis>
Genaue Verbreitung nicht bekannt, da oft mit 
<taxonomicName id="1A63505415A8FAC00BD56310E029FF3C" class="Magnoliopsida" family="Fabaceae" genus="Vicia" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="592" phylum="Tracheophyta" rank="species" species="segetalis">
<emphasis id="CA5C6CE110DD7A330ACC7F3943E6C57E" italics="true" pageId="null" pageNumber="592">V. segetalis</emphasis>
</taxonomicName>
verwechselt. - Im Gebiet: Savoyen, 
<normalizedToken id="7F26208D11BD97F552ACDF35F64D06F9" originalValue="südlicher" pageId="null" pageNumber="592">suedlicher</normalizedToken>
Jura, Genf, zentral- und 
<normalizedToken id="FDD910DCA3403B70171B30642A36F794" originalValue="südalpine" pageId="null" pageNumber="592">suedalpine</normalizedToken>
<normalizedToken id="08FC2BF9D14F61F674BDD053AB49E525" originalValue="Täler" pageId="null" pageNumber="592">Taeler</normalizedToken>
, Oberrheinische Tiefebene, Schaffhauser Becken; ziemlich selten.
</paragraph>
</subSubSection>
