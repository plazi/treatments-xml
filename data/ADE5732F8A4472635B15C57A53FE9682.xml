<subSubSection id="62B7FE93F5032D244207AD12066A783D" pageId="null" pageNumber="699" type="description">
<paragraph id="01868014F80562A80656A0003A747851" pageId="null" pageNumber="699">
Kletternde 
<normalizedToken id="E1A56D8552C63596988C5A8ABA39BB9C" originalValue="Sträucher" pageId="null" pageNumber="699">Straeucher</normalizedToken>
. 
<emphasis id="1B9BF36ED91555B5E8D19BAFD4BA1D82" italics="true" pageId="null" pageNumber="699">
Rinde sich in langen 
<normalizedToken id="A64BADE37D21FDC86232BD714071D483" originalValue="Bändern" pageId="null" pageNumber="699">Baendern</normalizedToken>
<normalizedToken id="4906636878CD6849BD5F64E60AC53383" originalValue="ablösend" pageId="null" pageNumber="699">abloesend</normalizedToken>
.
</emphasis>
Ranken vorhanden, ohne Haftscheiben, den 
<normalizedToken id="2EEFE36256CADDB731404BDB3F274864" originalValue="Blättern" pageId="null" pageNumber="699">Blaettern</normalizedToken>
<normalizedToken id="B07FABCA1371CDFBBAE61FEEC3542E7A" originalValue="gegenüber" pageId="null" pageNumber="699">gegenueber</normalizedToken>
. 
<emphasis id="DB770BFFD28C62861DA068FC3FA96BB2" italics="true" pageId="null" pageNumber="699">
<normalizedToken id="5C8294D254963B24CB4BE7482B97F77F" originalValue="Blütenstand" pageId="null" pageNumber="699">Bluetenstand</normalizedToken>
eine 
<normalizedToken id="B154C8386B2093B41C0CDFBF3F9D9ADA" originalValue="längliche" pageId="null" pageNumber="699">laengliche</normalizedToken>
, oft zusammengesetzte Rispe
</emphasis>
, ⚥ und ♂ 
<normalizedToken id="F517253E295CE5351C215B349F5330E3" originalValue="Blüten" pageId="null" pageNumber="699">Blueten</normalizedToken>
auf derselben Pflanze oder Pflanzen 
<normalizedToken id="2C60DF24730B30D9BD7273820772F00A" originalValue="diözisch" pageId="null" pageNumber="699">dioezisch</normalizedToken>
. Kelch mit 5 undeutlichen 
<normalizedToken id="B109C8BCD93C88166A0467E22CE14BB0" originalValue="Zähnen" pageId="null" pageNumber="699">Zaehnen</normalizedToken>
. 
<emphasis id="41AB3F7669A010DECB8A57F5432B2EB6" italics="true" pageId="null" pageNumber="699">
<normalizedToken id="438E2BB6326DB97F1BA6334051FD4771" originalValue="Kronblätter" pageId="null" pageNumber="699">Kronblaetter</normalizedToken>
5, an der Spitze verwachsen und gemeinsam als Haube abfallend.
</emphasis>
<normalizedToken id="F9487E5AC2060BC4779FA1219A76DDE2" originalValue="Staubblätter" pageId="null" pageNumber="699">Staubblaetter</normalizedToken>
5. Griffel kurz. Samen im 
<normalizedToken id="CB6BED8CD6DE136481976376CE6F3542" originalValue="Umriß" pageId="null" pageNumber="699">Umriss</normalizedToken>
<emphasis id="43FD1545C96017E4108EFC8C451ACA32" italics="true" pageId="null" pageNumber="699">
<normalizedToken id="08858A2AF6BEFE56CFBB2EFBA97ED71F" originalValue="birnenförmig" pageId="null" pageNumber="699">birnenfoermig</normalizedToken>
</emphasis>
, mit 
<normalizedToken id="F1FADF9698FE83BE74FC448BD8BE68B9" originalValue="Längsfurche" pageId="null" pageNumber="699">Laengsfurche</normalizedToken>
und 2 Gruben.
</paragraph>
<paragraph id="5CE61C05059E24F2A579E755C740F478" pageId="null" pageNumber="699">
Die Gattung 
<taxonomicName id="EF71992D41AA7543B6B4BEAA4CFFD396" class="Magnoliopsida" family="Vitaceae" genus="Vitis" kingdom="Plantae" order="Vitales" pageId="null" pageNumber="699" phylum="Tracheophyta" rank="genus">
<emphasis id="5E3CD77F3725D94E3997EF7BAABD3D08" italics="true" pageId="null" pageNumber="699">Vitis</emphasis>
</taxonomicName>
<normalizedToken id="2C345EDB9D0717AAA44A164872D65947" originalValue="umfaßt" pageId="null" pageNumber="699">umfasst</normalizedToken>
etwa 
<emphasis id="FCC960A9D056F56F7ED54EDA41DED2F7" italics="true" pageId="null" pageNumber="699">50 Arten, die vor allem in Nordamerika und Ostasien verbreitet sind.</emphasis>
Zahlreiche Arten, darunter auch Kultursorten von 
<taxonomicName id="D33771B671FD20BF2DE464485C5CD7CD" class="Magnoliopsida" family="Vitaceae" genus="Vitis" kingdom="Plantae" order="Vitales" pageId="null" pageNumber="699" phylum="Tracheophyta" rank="species" species="vinifera">
<emphasis id="84C05C6D9A6FFFC0D62C5203D83CD534" italics="true" pageId="null" pageNumber="699">V. vinifera</emphasis>
</taxonomicName>
und 
<taxonomicName id="B711BE5BD94596C4DA3ED4F571DB5C8E" class="Magnoliopsida" family="Vitaceae" genus="Vitis" kingdom="Plantae" order="Vitales" pageId="null" pageNumber="699" phylum="Tracheophyta" rank="species" species="labrusca">
<emphasis id="FF25DE1B04569C8B23D4E9F28DB9831F" italics="true" pageId="null" pageNumber="699">V. Labrusca</emphasis>
</taxonomicName>
besitzen die 
<emphasis id="186EE9080F00FFCCC0E0BCF93136C1F8" italics="true" pageId="null" pageNumber="699">Chromosomenzahl</emphasis>
2n = 38; bei 
<taxonomicName id="B711925BBF9D957E5BEDBB08EDF1D26E" class="Magnoliopsida" family="Vitaceae" genus="Vitis" kingdom="Plantae" order="Vitales" pageId="null" pageNumber="699" phylum="Tracheophyta" rank="species" species="vinifera">
<emphasis id="2B72DF9E1E636398BE8A2E89D4A043F0" italics="true" pageId="null" pageNumber="699">V. vinifera</emphasis>
</taxonomicName>
sind auch 
<emphasis id="E874C882E61B0028DBE70C9A85809059" italics="true" pageId="null" pageNumber="699">Polyploide</emphasis>
bekannt (2n = 57, 76); Zusammenstellung der Literatur von 
<normalizedToken id="0114328F147EC905D8CE5FA95DB043FD" originalValue="Löve" pageId="null" pageNumber="699">Loeve</normalizedToken>
und 
<normalizedToken id="DD4BBB47F5184C86259B0A31921B6711" originalValue="Löve" pageId="null" pageNumber="699">Loeve</normalizedToken>
(1961), Husfeld (1962).
</paragraph>
