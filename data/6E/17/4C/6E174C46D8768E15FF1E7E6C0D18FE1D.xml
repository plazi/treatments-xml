<emphasis box="[279,505,439,465]" italics="true" pageId="5" pageNumber="72">Bracon rosamondae</emphasis>
</taxonomicName>
<emphasis bold="true" box="[511,599,439,465]" pageId="5" pageNumber="72">
<taxonomicNameLabel box="[511,599,439,465]" pageId="5" pageNumber="72" rank="species">sp. nov.</taxonomicNameLabel>
