Flaumiger Seidelbast, 
<normalizedToken id="5913B4CBBC91435D3C7101BFFA9D39B1" originalValue="Fluhröschen" pageId="null" pageNumber="754">Fluhroeschen</normalizedToken>
</paragraph>
