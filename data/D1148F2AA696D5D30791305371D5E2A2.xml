<subSubSection id="26F2305E9A919219CD1D1751154DDFA9" pageId="null" pageNumber="754" type="description">
<paragraph id="784824CAC591FEF417E9B852DFD3BD66" pageId="null" pageNumber="754">
Unterscheidet sich von 
<taxonomicName id="6EC5969DEDC0B5F68FA5FE0CC3DFA6BD" class="Magnoliopsida" family="Thymelaeaceae" genus="Daphne" kingdom="Plantae" order="Malvales" pageId="null" pageNumber="754" phylum="Tracheophyta" rank="species" species="striata">
<emphasis id="C1C8B44CBC2C81E1B0628E57E2083AF7" italics="true" pageId="null" pageNumber="754">D. striata</emphasis>
</taxonomicName>
(Nr. 4) durch folgende Merkmale: 10-30 cm hoch; 
<emphasis id="ED3706DD70A04D10B411E99C65852D36" italics="true" pageId="null" pageNumber="754">Zweige anliegend behaart</emphasis>
(Haare 0,1-0,2 mm lang); 
<normalizedToken id="1ECC86B7231B157AA7034670F33A95FD" originalValue="Blätter" pageId="null" pageNumber="754">Blaetter</normalizedToken>
<normalizedToken id="AE7F75043EA53006899A3F4B2B747B51" originalValue="2½" pageId="null" pageNumber="754">21/2</normalizedToken>
-5mal so lang wie breit; 
<normalizedToken id="19F8C44B087B4BACCBA8E51706EA54E0" originalValue="Kelchröhre" pageId="null" pageNumber="754">Kelchroehre</normalizedToken>
0,6 bis 1,2 cm lang, 
<emphasis id="CE32CD1DABC48104B5509FA390ECB21C" italics="true" pageId="null" pageNumber="754">dicht anliegend behaart</emphasis>
(Haare 0,3-0,4 mm lang); 
<emphasis id="85BF05FB4F52DF474071A33521C3504B" italics="true" pageId="null" pageNumber="754">Kelchzipfel</emphasis>
<normalizedToken id="A54677D0302353ED7CE0A8BBC5B1DEEB" originalValue="½-¾" pageId="null" pageNumber="754">1/2-3/4</normalizedToken>
<emphasis id="CB41B2B298A07E4ED9020468EE1E68E8" italics="true" pageId="null" pageNumber="754">
so lang wie die 
<normalizedToken id="BB0518B1D1D3FD128F8B2CAFE3D2D996" originalValue="Kelchröhre" pageId="null" pageNumber="754">Kelchroehre</normalizedToken>
</emphasis>
, leuchtend rosa; 
<emphasis id="E69A6EF7D90A07470A7341EBB2545C58" italics="true" pageId="null" pageNumber="754">Frucht behaart.</emphasis>
- 
<normalizedToken id="1DF9C777B9A5AF63425A2D346DCA6674" originalValue="Blüte" pageId="null" pageNumber="754">Bluete</normalizedToken>
: 
<normalizedToken id="55A5FFF4E810029701007B1AC5EB1277" originalValue="Später" pageId="null" pageNumber="754">Spaeter</normalizedToken>
<normalizedToken id="09C74518E00D532B747D2D57D1F31521" originalValue="Frühling" pageId="null" pageNumber="754">Fruehling</normalizedToken>
und 
<normalizedToken id="7E3242E695E360DAB05E5CA7E291FBDC" originalValue="früher" pageId="null" pageNumber="754">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="FF01EDC7FF1BBE4D90DFAA5CF04D9503" pageId="null" pageNumber="754">
<emphasis id="50B219ED14C6C745F3D02F64EDE85AA8" italics="true" pageId="null" pageNumber="754">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B1EC68DA368EB70561F5CCC2DF987892" italics="true" pageId="null" pageNumber="754">18:</emphasis>
Material aus 
<normalizedToken id="2C586F3FC305F30A12E87FC319358E8F" originalValue="Österreich" pageId="null" pageNumber="754">Oesterreich</normalizedToken>
(Fuchs 1938), aus Ungarn (Baksay 1956).
</paragraph>
<paragraph id="7539578B0EEF6A2FACBCA26C6EC1A06C" pageId="null" pageNumber="754">
<emphasis id="49ABAFC5A282FCBC4003CEE873CDBD27" italics="true" pageId="null" pageNumber="754">Standort.</emphasis>
Kollin und montan, seltener subalpin. Trockene, steinige, magere 
<normalizedToken id="05B283ABC8CE3E0DC7E772EC1FAAC723" originalValue="Böden" pageId="null" pageNumber="754">Boeden</normalizedToken>
in 
<normalizedToken id="308B5E160AD684BFE572FE694D6D6F80" originalValue="wärmeren" pageId="null" pageNumber="754">waermeren</normalizedToken>
, halbschattigen Lagen. Lichte 
<normalizedToken id="DBDC4F2A25052A9BA448FEF2983BE6D6" originalValue="Föhrenwälder" pageId="null" pageNumber="754">Foehrenwaelder</normalizedToken>
, 
<normalizedToken id="FEB39ED5630211B4D65B67B30552FDF9" originalValue="Waldränder" pageId="null" pageNumber="754">Waldraender</normalizedToken>
, steinige 
<normalizedToken id="688A658F131A005AFB6BBBE3C6D17189" originalValue="Hänge" pageId="null" pageNumber="754">Haenge</normalizedToken>
.
</paragraph>
<paragraph id="83A0DF7CEFB929EDB850D00C2333E361" pageId="null" pageNumber="754">
<emphasis id="E16AF04CF2AF46A899655C9036FA9547" italics="true" pageId="null" pageNumber="754">
Verbreitung. Mittel- und 
<normalizedToken id="76F9F881033AF0E93A94AA42D7075053" originalValue="südeuropäische" pageId="null" pageNumber="754">suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Nord- und 
<normalizedToken id="8280CEFA550A9A9DF6D2380F538B0502" originalValue="ostwärts" pageId="null" pageNumber="754">ostwaerts</normalizedToken>
bis Lothringen, 
<normalizedToken id="4E686BE51BC251C9F01756F23CA497DF" originalValue="Schwäbischer" pageId="null" pageNumber="754">Schwaebischer</normalizedToken>
Jura, 
<normalizedToken id="6997947A6BABB76098115FC09303FF3B" originalValue="Mähren" pageId="null" pageNumber="754">Maehren</normalizedToken>
, 
<normalizedToken id="77DFA124BD8FFFD4E12B5482002E4E6C" originalValue="Südpolen" pageId="null" pageNumber="754">Suedpolen</normalizedToken>
, 
<normalizedToken id="70A949F490FF9114E6A8756ECB488B6C" originalValue="Siebenbürgen" pageId="null" pageNumber="754">Siebenbuergen</normalizedToken>
; west- und 
<normalizedToken id="FD5F3F891577D5F829E28FB1405E33EE" originalValue="südwärts" pageId="null" pageNumber="754">suedwaerts</normalizedToken>
bis Nordspanien, 
<normalizedToken id="AC3338C1981D2B3379EA929729B62737" originalValue="Pyrenäen" pageId="null" pageNumber="754">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="D72607EAB1145E553A2C45D3CB98424E" originalValue="nördlicher" pageId="null" pageNumber="754">noerdlicher</normalizedToken>
Apennin, Mazedonien, Bulgarien. Karte der zirkumalpinen Verbreitung von Bresinsky (1965). - Im Gebiet: Jura (Mont Tendre bis Hauenstein, auch im 
<normalizedToken id="72893C37D09D137F03C3D1DB8C825C55" originalValue="Dép" pageId="null" pageNumber="754">Dep</normalizedToken>
. Jura und 
<normalizedToken id="7156CEC2D9848AC58C9F29B114D97921" originalValue="Dép" pageId="null" pageNumber="754">Dep</normalizedToken>
. Doubs, 
<normalizedToken id="11115C55EB85AA6A56BF4B863A6FF854" originalValue="Schwäbisch-Badischer" pageId="null" pageNumber="754">Schwaebisch-Badischer</normalizedToken>
Jura), Eglisau, Baar, 
<normalizedToken id="2A1577B65DBDE76CE8FBBC077D793FA5" originalValue="nördlicher" pageId="null" pageNumber="754">noerdlicher</normalizedToken>
Hegau, 
<normalizedToken id="947FB2572E43A20C3A48964C35D9DF0B" originalValue="Alpensüdseite" pageId="null" pageNumber="754">Alpensuedseite</normalizedToken>
(Valsesia [Monte Toro], 
<normalizedToken id="CD181375D977D04E875A08B1D0BF75F7" originalValue="südliches" pageId="null" pageNumber="754">suedliches</normalizedToken>
Tessin, Comerseegebiet, Bergamasker Alpen).
</paragraph>
<paragraph id="48F7D82EA0BF5C9702111D1BA818B0DA" pageId="null" pageNumber="754">
<emphasis id="51A98105C5A272E5A91D396A0E498E98" italics="true" pageId="null" pageNumber="754">Bemerkungen.</emphasis>
Aymonin (1959) beschreibt die morphologische und 
<normalizedToken id="D72F63DC2384134F1DBADB18222CBDAF" originalValue="ökologische" pageId="null" pageNumber="754">oekologische</normalizedToken>
<normalizedToken id="601A336EDF7BA4BC7C84AF47E04A492F" originalValue="Variabilität" pageId="null" pageNumber="754">Variabilitaet</normalizedToken>
der Art in Frankreich.
</paragraph>
</subSubSection>
