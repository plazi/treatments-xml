<taxonomicName id="4C494D5669787A2FDE80290C06B6FDC8" baseAuthorityName="ROUGEMONT" baseAuthorityYear="1987" box="[907,1022,599,620]" class="Insecta" family="Staphylinidae" genus="Rugilus" kingdom="Animalia" order="Coleoptera" pageId="12" pageNumber="183" phylum="Arthropoda" rank="species" species="morvani">
