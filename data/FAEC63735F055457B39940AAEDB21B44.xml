</tr>
<tr id="522E668066FEC051AE9D166D4CFF80BC" pageId="0" pageNumber="139">
<td id="C329519FE190B27FD08C9E1957661754" colspan="1" pageId="0" pageNumber="139" rowspan="1">
<taxonomicName id="729FC2EB959BDC817C947DADB1AABD6C" authorityName="Lowry, Springthorpe &amp; Myers" authorityYear="2020" class="Liliopsida" family="Arecaceae" genus="Carpentaria" kingdom="Plantae" lsidName="Carpentaria" order="Arecales" pageId="0" pageNumber="139" phylum="Tracheophyta" rank="genus">
<emphasis id="57BC45BC76141C9ED74CA947C6BE2876" italics="true" pageId="0" pageNumber="139">Carpentaria</emphasis>
</taxonomicName>
</td>
<td id="881E144ABEF98448BF683455A2E9A110" colspan="1" pageId="0" pageNumber="139" rowspan="1">well developed</td>
<td id="951E1F386DFBBA1E7D60C7DDB74DF5D1" colspan="1" pageId="0" pageNumber="139" rowspan="1">4-dentate</td>
<td id="F664A01FE428A14A525F612F5342E212" colspan="1" pageId="0" pageNumber="139" rowspan="1">absent, palm obtuse</td>
<td id="1ED08B841BE2EB3C5AEB8FD0E7D8DBB1" colspan="1" pageId="0" pageNumber="139" rowspan="1">subequal</td>
