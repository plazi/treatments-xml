<th id="864F1C3F66924CF86D1322E189C4416C" colspan="1" pageId="0" pageNumber="139" rowspan="1">MP palp article 2 distomedial lobe</th>
<th id="35EFF0164C8925CA9F6EF202D82E605F" colspan="1" pageId="0" pageNumber="139" rowspan="1">LMD lacinia mobilis</th>
<th id="187F9DE9FC1A6A329948C3BE81F14ABC" colspan="1" pageId="0" pageNumber="139" rowspan="1">G1 sexual dimorphism</th>
<th id="1939253ED83027A780B44ED854587581" colspan="1" pageId="0" pageNumber="139" rowspan="1">Carpi of P4:P3</th>
<th id="2FFF56D304C32CD7F53D6F351DEAA482" colspan="1" pageId="0" pageNumber="139" rowspan="1">P6-7 sexual dimorphism</th>
<th id="4DD7346B9FA724DE65D66E70AED66230" colspan="1" pageId="0" pageNumber="139" rowspan="1">P7 postero- distal lobe</th>
