<subSubSection id="993CB7B3A85DA1660E257805E0BDCD15" pageId="null" pageNumber="495" type="description">
<paragraph id="EBBF22B9A1B9ACFA5588FE3285058F5F" pageId="null" pageNumber="495">
Ausdauernd, mit dickem Rhizom; 40-150 cm hoch. Stengel aufrecht, 
<emphasis id="DC33061F6B4927F4595F7BBC04AFEE1A" italics="true" pageId="null" pageNumber="495">kahl</emphasis>
, im obern Teil verzweigt, 
<normalizedToken id="9190C2D04092B672A18B92D63978FAC8" originalValue="beblättert" pageId="null" pageNumber="495">beblaettert</normalizedToken>
. 
<emphasis id="090C843CD4FA959D48BC766B58BCAD8A" italics="true" pageId="null" pageNumber="495">
<normalizedToken id="084196C1FAB4F53309FA39015D1D8E5B" originalValue="Blätter" pageId="null" pageNumber="495">Blaetter</normalizedToken>
kahl, 
<normalizedToken id="8005A127B32FDE33C07F23784BA68ECE" originalValue="blaugrün" pageId="null" pageNumber="495">blaugruen</normalizedToken>
</emphasis>
, lederig, oval bis lanzettlich, wenig tief und buchtig 
<normalizedToken id="B12C0C2F9742317953CDEA82AC455822" originalValue="gezähnt" pageId="null" pageNumber="495">gezaehnt</normalizedToken>
, seltener fast ganzrandig, die untersten in den kurzen, 
<normalizedToken id="9F8F9D3F52912D3BB8FBB844EEA839C4" originalValue="geflügelten" pageId="null" pageNumber="495">gefluegelten</normalizedToken>
Stiel 
<normalizedToken id="C3090B9C22E71482097EA575BDEC9492" originalValue="verschmälert" pageId="null" pageNumber="495">verschmaelert</normalizedToken>
(ohne Stiel 2-5mal so lang wie breit), die folgenden mit 
<normalizedToken id="715921D3E9760830AF086BDD76A61763" originalValue="verschmälertem" pageId="null" pageNumber="495">verschmaelertem</normalizedToken>
Grunde sitzend und 
<emphasis id="2F0ACF296144DD304B35D2280C2D61BA" italics="true" pageId="null" pageNumber="495">am Stengel wenig herablaufend; die obern kaum</emphasis>
⅓ 
<emphasis id="F0D0673D7B35BFC451228F51AB34A9A7" italics="true" pageId="null" pageNumber="495">
so breit wie die 
<normalizedToken id="5A01303FB570C0313E252A265115D22F" originalValue="grundständigen" pageId="null" pageNumber="495">grundstaendigen</normalizedToken>
. 
<normalizedToken id="30154A558117F926FE44A7AD606BF7C6" originalValue="Köpfe" pageId="null" pageNumber="495">Koepfe</normalizedToken>
zahlreich
</emphasis>
, in einer dichten, doldenartigen Traube, meist kurz und 
<normalizedToken id="8E61ED1A6E8FDCA65021B160F4C3D8BE" originalValue="dünn" pageId="null" pageNumber="495">duenn</normalizedToken>
gestielt, 
<emphasis id="E05FF250E5D25852EB753A95589AA7A1" italics="true" pageId="null" pageNumber="495">im Durchmesser 1,5</emphasis>
- 
<emphasis id="4C49A735A57CEE53C45E927D89E2C5E6" italics="true" pageId="null" pageNumber="495">2,5 cm</emphasis>
. 
<normalizedToken id="02DBE804209F945A05053E8D2AC59D7C" originalValue="Hülle" pageId="null" pageNumber="495">Huelle</normalizedToken>
zylindrisch bis 
<normalizedToken id="DC739BA21884264F3E70EF50956F500D" originalValue="glockenförmig" pageId="null" pageNumber="495">glockenfoermig</normalizedToken>
, 6-9 mm lang, 
<normalizedToken id="C6F7BF877CE37EC1E0845FD90AFA3AFE" originalValue="außen" pageId="null" pageNumber="495">aussen</normalizedToken>
von einzelnen, 2-3 mm langen, schmal lanzettlichen 
<normalizedToken id="CB22563FB23ED337407CF66D1EDE5F86" originalValue="Blättern" pageId="null" pageNumber="495">Blaettern</normalizedToken>
umgeben. Innere 
<normalizedToken id="DB2CB53EDB69C6CF546B8B0A9179966E" originalValue="Hüllblätter" pageId="null" pageNumber="495">Huellblaetter</normalizedToken>
12-15, kahl. Kronen gelb; die 5-10 
<normalizedToken id="2FF9E0CEA869C1EFD190CEEAC588174B" originalValue="zungenförmigen" pageId="null" pageNumber="495">zungenfoermigen</normalizedToken>
Kronen 10-15 mm lang und 1-2 mm breit. 
<normalizedToken id="B52CDF487A3281EA8A766E2CDDB1433B" originalValue="Früchte" pageId="null" pageNumber="495">Fruechte</normalizedToken>
3-4 mm lang, etwa 12rippig, kahl oder zwischen einzelnen Rippen kurz behaart. 
<taxonomicName id="E7D32EF95FEE7FD6C1452B3A5873D38A" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="495" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
6-8 mm lang, gelblich. - 
<normalizedToken id="9696D44E8FDBC1FAA1B6E198B21384C0" originalValue="Blüte" pageId="null" pageNumber="495">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="2587C83282E6E7913D8294342D6E16EF" originalValue="früher" pageId="null" pageNumber="495">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="5310E8B8C790C2CB3553696865B40456" pageId="null" pageNumber="495">
<emphasis id="FE9CF07BF5C2A149AF7BBD3AB47F9FAD" italics="true" pageId="null" pageNumber="495">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="1CDE6349EA9E77745D074095C8C763A0" italics="true" pageId="null" pageNumber="495">40:</emphasis>
Material aus botanischen 
<normalizedToken id="D8FCD110987C7F7814E7728504A41D59" originalValue="Gärten" pageId="null" pageNumber="495">Gaerten</normalizedToken>
(Afzelius 1924), aus dem Atlas (
<normalizedToken id="DCE54A17448D80C1FC4A9EB158E94422" originalValue="Quézel" pageId="null" pageNumber="495">Quezel</normalizedToken>
1957).
</paragraph>
<paragraph id="DE9561F900E4E1384A63F2965EEF4079" pageId="null" pageNumber="495">
<emphasis id="DB2AA8F28ED8D5A87532294C62439D19" italics="true" pageId="null" pageNumber="495">Standort</emphasis>
. Kollin und montan. Nasse, humose 
<normalizedToken id="DBEB15799AFE830FFC0DC3CAE4EB1CE2" originalValue="Böden" pageId="null" pageNumber="495">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="BCBE72257133A6B51404C1F9EA807897" originalValue="Auenwälder" pageId="null" pageNumber="495">Auenwaelder</normalizedToken>
, nasse Wiesen, Ufer, 
<normalizedToken id="2EA38668DC71674D31525710FF5E17D9" originalValue="Gräben" pageId="null" pageNumber="495">Graeben</normalizedToken>
.
</paragraph>
<paragraph id="1C275A9EE3664589C88221F8829270E6" pageId="null" pageNumber="495">
<emphasis id="A901AA6D780FBEDDA8F308C7325BDAF0" italics="true" pageId="null" pageNumber="495">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="41305281FDC0195101E3F4835C528726" originalValue="Südeuropa" pageId="null" pageNumber="495">Suedeuropa</normalizedToken>
(
<normalizedToken id="8F58491EBE6FFBA87A3650BD5BA804B0" originalValue="nordwärts" pageId="null" pageNumber="495">nordwaerts</normalizedToken>
bis Mittelfrankreich, 
<normalizedToken id="BD397B130518E944C28760C240F02C41" originalValue="Alpensüdfuß" pageId="null" pageNumber="495">Alpensuedfuss</normalizedToken>
, 
<normalizedToken id="1472B90198997575B0563257987A9005" originalValue="Mähren" pageId="null" pageNumber="495">Maehren</normalizedToken>
, 
<normalizedToken id="F0F7BB11BF63062E405634604536950A" originalValue="Mittelrußland" pageId="null" pageNumber="495">Mittelrussland</normalizedToken>
); Kaukasus; Marokko. - Im Gebiet: 
<normalizedToken id="F9E62376C9CA4A4FD51E3DD14F862B66" originalValue="Dép" pageId="null" pageNumber="495">Dep</normalizedToken>
. Ain (
<normalizedToken id="C0A2526A5DE71BF0A6DD1FC558A4B2B9" originalValue="Serrières" pageId="null" pageNumber="495">Serrieres</normalizedToken>
), Savoyen (Lac du Bourget), alte Angaben aus dem Valle 
<normalizedToken id="3965D07E6549636B9FBDB3B21C5EF8D1" originalValue="d’Ossola" pageId="null" pageNumber="495">d'Ossola</normalizedToken>
.
</paragraph>
</subSubSection>
