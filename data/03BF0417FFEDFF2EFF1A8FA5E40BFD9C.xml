Holotype, ♀, except 
<emphasis id="B9626913FFECFF2CFC108870E4FBF8FB" bold="true" box="[925,945,1858,1882]" pageId="61" pageNumber="62">P,</emphasis>
paratype A. 
<emphasis id="B9626913FFECFF2CFBBC8870E31AF8FB" bold="true" box="[1073,1104,1858,1882]" pageId="61" pageNumber="62">clv</emphasis>
, head lateral view; 
<emphasis id="B9626913FFECFF2CFA988870E20EF8FB" bold="true" box="[1301,1348,1858,1882]" pageId="61" pageNumber="62">mx1</emphasis>
, maxilla 1; 
<emphasis id="B9626913FFECFF2CFF3E8854E7A9F8DF" bold="true" box="[179,227,1894,1918]" pageId="61" pageNumber="62">mxp</emphasis>
, maxilliped; 
<emphasis id="B9626913FFECFF2CFEE18854E63CF8DF" bold="true" box="[364,374,1894,1918]" pageId="61" pageNumber="62">s</emphasis>
, plumose seta of ventral margin of article 1 of antennula; 
<emphasis id="B9626913FFECFF2CFC5D8854E358F8DF" bold="true" box="[976,1042,1894,1918]" pageId="61" pageNumber="62">up3 ir</emphasis>
, uropod 3 tip of inner ramus; 
<emphasis id="B9626913FFECFF2CFAC18854E22EF8DF" bold="true" box="[1356,1380,1894,1918]" pageId="61" pageNumber="62">us</emphasis>
, urosome.
</paragraph>
