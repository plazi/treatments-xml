<emphasis id="B9626913FFEFFF2FFF1A8873E655F8F8" bold="true" box="[151,287,1857,1881]" pageId="62" pageNumber="63">FIGURE 36.</emphasis>
<taxonomicName id="4C16CE82FFEFFF2FFEA88873E56BF8F8" authority="Just, 2022" authorityName="Just" authorityYear="2022" box="[293,545,1857,1881]" class="Malacostraca" family="Synopiidae" genus="Glandulotiron" kingdom="Animalia" order="Amphipoda" pageId="62" pageNumber="63" phylum="Arthropoda" rank="species" species="postremus" status="gen. et sp. nov.">
<emphasis id="B9626913FFEFFF2FFEA88873E56BF8F8" box="[293,545,1857,1881]" italics="true" pageId="62" pageNumber="63">Glandulotiron postremus</emphasis>
</taxonomicName>
<emphasis id="B9626913FFEFFF2FFDAA8873E588F8F8" bold="true" box="[551,706,1857,1881]" pageId="62" pageNumber="63">
<taxonomicNameLabel id="A251D468FFEFFF2FFDAA8873E588F8F8" box="[551,706,1857,1881]" pageId="62" pageNumber="63" rank="species">gen. et sp. nov.</taxonomicNameLabel>
</emphasis>
Holotype, ♀. 
<emphasis id="B9626913FFEFFF2FFCDC8873E4C9F8F8" bold="true" box="[849,899,1857,1881]" pageId="62" pageNumber="63">cox3</emphasis>
, coxal plate 3; 
<emphasis id="B9626913FFEFFF2FFB968873E33DF8F8" bold="true" box="[1051,1143,1857,1881]" pageId="62" pageNumber="63">gp1–gp2</emphasis>
, gnathopods 1 and 2; 
<emphasis id="B9626913FFEFFF2FFADE8873E2DCF8F8" bold="true" box="[1363,1430,1857,1881]" pageId="62" pageNumber="63">p4–p7</emphasis>
; pereopods 4 to 7; 
<emphasis id="B9626913FFEFFF2FFEC08857E622F8DC" bold="true" box="[333,360,1893,1917]" pageId="62" pageNumber="63">tel</emphasis>
, telson with glands in left lobe indicated.
</paragraph>
