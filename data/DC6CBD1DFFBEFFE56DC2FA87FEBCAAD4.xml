<subSubSection id="1CDF5F80FFBFFFE56DC2FE3FFEBCAAD4" pageId="27" pageNumber="1540" type="etymology">
<paragraph id="547A0C0BFFBFFFE56DC2FE3FFEBCAAD4" blockId="27.[178,1085,418,470]" pageId="27" pageNumber="1540">
Etymology: The trivial name 
<emphasis id="66B1D019FFBFFFE56F58FE3FFD17AAB5" box="[552,642,418,439]" italics="true" pageId="27" pageNumber="1540">fasciatus</emphasis>
