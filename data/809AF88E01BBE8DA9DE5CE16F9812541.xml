<subSubSection id="27CDE2A13815D988E5D1717511A38006" pageId="null" pageNumber="552" type="description">
<paragraph id="40E3F486A64E5334B93754CCCA021C14" pageId="null" pageNumber="552">
Unterscheidet sich von 
<taxonomicName id="8E1441AF62C4261AA6D2355E1C80DC6D" class="Magnoliopsida" family="Asteraceae" genus="Anthemis" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="552" phylum="Tracheophyta" rank="genus">
<emphasis id="D9A2DE7149B7EB1D674EC5E0461BB167" italics="true" pageId="null" pageNumber="552">Anthemis</emphasis>
</taxonomicName>
(S. 547) durch folgende Merkmale: Ausdauernd und 
<emphasis id="CF70BB1385D70D8AE2D27D1C065EA13D" italics="true" pageId="null" pageNumber="552">
am Grunde verholzt; 
<normalizedToken id="943201CA49A6CB7BD26B4833ABCE69B1" originalValue="Spreublätter" pageId="null" pageNumber="552">Spreublaetter</normalizedToken>
stumpf; alle 
<normalizedToken id="3CCC9E045AA57345C2C6D43AAF782793" originalValue="Blüten" pageId="null" pageNumber="552">Blueten</normalizedToken>
<normalizedToken id="EE06E2C12B6D8BAA591EA13FF6989AFD" originalValue="röhrenförmig" pageId="null" pageNumber="552">roehrenfoermig</normalizedToken>
</emphasis>
, ⚥, 
<emphasis id="88076037EF3CD8BE4A4F8F00125FE747" italics="true" pageId="null" pageNumber="552">
am Grunde mit einseitigem 
<normalizedToken id="04411B0E26AFBBABAB6F99BCFF36BE1C" originalValue="Anhängsel" pageId="null" pageNumber="552">Anhaengsel</normalizedToken>
; Frucht 3
</emphasis>
- 
<emphasis id="17AF81E9A29B3FCC22620C01F623BD2E" italics="true" pageId="null" pageNumber="552">4kantig.</emphasis>
</paragraph>
<paragraph id="3E99B00DDF4843DA0442805DDC176666" pageId="null" pageNumber="552">
Die Gattung 
<taxonomicName id="123FC650E78492029EA1AC45BC5082A0" class="Magnoliopsida" family="Asteraceae" genus="Santolina" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="552" phylum="Tracheophyta" rank="genus">
<emphasis id="AC2265BAA4466634BFEB13AF8421EF41" italics="true" pageId="null" pageNumber="552">Santolina</emphasis>
</taxonomicName>
<normalizedToken id="E5C5A1659AE0D60D1272731CE7BCCF3F" originalValue="umfaßt" pageId="null" pageNumber="552">umfasst</normalizedToken>
etwa 8 
<emphasis id="771A0F96A0F6CA0F04FBE41FF0D3D86B" italics="true" pageId="null" pageNumber="552">Arten</emphasis>
, die vor allem im 
<emphasis id="5105FC1EFAB5BC1DCABF7E973932FE06" italics="true" pageId="null" pageNumber="552">
<normalizedToken id="149C206FAD063B67743F7F243CAA0A09" originalValue="südwestlichen" pageId="null" pageNumber="552">suedwestlichen</normalizedToken>
Europa
</emphasis>
verbreitet sind. 
<emphasis id="330BB0078AB34A46416DC99D7EE3CE95" italics="true" pageId="null" pageNumber="552">Chromosomengrundzahl:</emphasis>
n = 9.
</paragraph>
