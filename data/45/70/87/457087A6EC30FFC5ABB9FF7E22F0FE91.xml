<taxonomicName authorityName="Huang &amp; Lin &amp; Li &amp; Qiu" authorityYear="2022" box="[284,530,345,371]" class="Agaricomycetes" family="Russulaceae" genus="Lactarius" kingdom="Fungi" order="Russulales" pageId="5" pageNumber="250" phylum="Basidiomycota" rank="species" species="baiyunensis">
<emphasis box="[284,530,345,371]" italics="true" pageId="5" pageNumber="250">Lactarius baiyunensis</emphasis>
</taxonomicName>
differs from the other orange-white species within 
<taxonomicName baseAuthorityName="Bloch &amp; Schneider" baseAuthorityYear="1801" box="[1107,1396,345,371]" class="Agaricomycetes" family="Russulaceae" genus="Lactarius" kingdom="Fungi" order="Russulales" pageId="5" pageNumber="250" phylum="Basidiomycota" rank="subGenus" subGenus="Lactarius">
