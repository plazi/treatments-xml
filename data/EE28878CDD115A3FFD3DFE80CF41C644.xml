<paragraph id="663E369ADD165A3FFF7AF85BCF41C644" blockId="20.[227,871,2036,2062]" box="[227,871,2036,2062]" pageId="20" pageNumber="21">
Tortonian of 
<collectingCountry id="1E96760ADD165A3FFEE5F85BCDE9C644" box="[380,463,2036,2062]" name="Greece" pageId="20" pageNumber="21">Greece</collectingCountry>
(Voleones, Apostoli Basin, 
<collectingRegion id="A445F878DD165A3FFC8FF85BCF7DC644" box="[790,859,2036,2062]" country="Greece" name="Kriti" pageId="20" pageNumber="21">Crete</collectingRegion>
