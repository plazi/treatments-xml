<subSubSection id="09AB84DA4203895BFF755DA9FBC2C735" pageId="4" pageNumber="14" type="diagnosis">
<paragraph id="410ED7514203895BFF755DA9FE98C74C" blockId="4.[227,348,1766,1792]" box="[227,348,1766,1792]" pageId="4" pageNumber="14">
<heading id="1A46603D4203895BFF755DA9FE98C74C" bold="true" box="[227,348,1766,1792]" fontSize="11" level="3" pageId="4" pageNumber="14" reason="3">
