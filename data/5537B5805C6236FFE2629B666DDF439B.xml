<subSubSection id="E940266A345B73CB019A07B10A1E2D98" pageId="null" pageNumber="39" type="description">
<paragraph id="7694DF7098A8465196B072387C8E17CB" pageId="null" pageNumber="39">
10-50 cm hoch. 
<emphasis id="79FFAD0A764F752322DB5FA3229EA0F1" italics="true" pageId="null" pageNumber="39">
<normalizedToken id="C9F7FC8C6008F1CCDAF08C389726930B" originalValue="Stengelblätter" pageId="null" pageNumber="39">Stengelblaetter</normalizedToken>
an der Basis kaum 
<normalizedToken id="F749B60601C4B20B988134373972AC2E" originalValue="verschmälert" pageId="null" pageNumber="39">verschmaelert</normalizedToken>
; verwachsene Basis fast so lang wie die 
<normalizedToken id="4A02A17C84C28B5610041D88DC4F665A" originalValue="größte" pageId="null" pageNumber="39">groesste</normalizedToken>
Breite des Blattes.
</emphasis>
<normalizedToken id="3CA83CA59BE16CD277AA6AAD80DE621F" originalValue="Blütenstiele" pageId="null" pageNumber="39">Bluetenstiele</normalizedToken>
0,5-3 cm (meist etwa 1 cm) lang, 
<emphasis id="124ED64983A5B69757F0FC506662F039" italics="true" pageId="null" pageNumber="39">
die meisten 
<normalizedToken id="871486B576B69988962DCCDC014CE65D" originalValue="Blütenstiele" pageId="null" pageNumber="39">Bluetenstiele</normalizedToken>
einer Pflanze 
<normalizedToken id="260866D4B4CADF27C8B1DFEE9D2963DF" originalValue="kürzer" pageId="null" pageNumber="39">kuerzer</normalizedToken>
als die 
<normalizedToken id="829639D13F2C35188B3D159B864E6AF3" originalValue="größten" pageId="null" pageNumber="39">groessten</normalizedToken>
<normalizedToken id="6EE89772DB731C4CD9D76FCD995A3BA3" originalValue="Stengelblätter" pageId="null" pageNumber="39">Stengelblaetter</normalizedToken>
.
</emphasis>
<normalizedToken id="4BE38781C203E7F46F4C1E42FFE42DCB" originalValue="Kelchblätter" pageId="null" pageNumber="39">Kelchblaetter</normalizedToken>
von der Frucht bogig abstehend, nach oben konkav (
<normalizedToken id="BAAE68E39B71CCC7C3E5F3DCB2F65FAB" originalValue="kahnförmig" pageId="null" pageNumber="39">kahnfoermig</normalizedToken>
), 
<emphasis id="4AE9F14D14EADD3A901DBE5C1527EEE3" italics="true" pageId="null" pageNumber="39">kaum je breiter als 1 mm.</emphasis>
- 
<normalizedToken id="3C030CAB6128F39FA65B57B1977699E7" originalValue="Blüte" pageId="null" pageNumber="39">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="0B5065A670A8F7668E082E75E53B9844" pageId="null" pageNumber="39">
<emphasis id="53D56ADB891F9EEB8976714684C83042" italics="true" pageId="null" pageNumber="39">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="77EDB6BE295CCB809777FF0D339910B9" italics="true" pageId="null" pageNumber="39">40:</emphasis>
Material aus Nordafrika und aus verschiedenen Gegenden Spaniens und Frankreichs, Italiens, Griechenlands und der Schweiz (Zeltner 1961 1962 1966 1970), aus 
<normalizedToken id="A82BDA2FD42BE1AD90A2BC648625BE24" originalValue="Südfrankreich" pageId="null" pageNumber="39">Suedfrankreich</normalizedToken>
(Van Loon et al. 1971); 
<normalizedToken id="1E31AC3A71CD0BD3B792F4B17CB27250" originalValue="Maüde" pageId="null" pageNumber="39">Mauede</normalizedToken>
(1939) 
<normalizedToken id="CD606B98752929A4F2A9FBA8CFBEA62F" originalValue="zählte" pageId="null" pageNumber="39">zaehlte</normalizedToken>
an Material aus England 2n = 44, ebenso Delay (1969b) an Material aus Nordfrankreich. Zeltner (1966 1970) fand an morphologisch verschiedenen Pflanzen (
<taxonomicName id="5E8130D2D6CD4B256D235A38AFDF1D9F" pageId="null" pageNumber="39" rank="subSpecies" subSpecies="intermedia">
ssp. 
<emphasis id="06E36A2F454FFA298C8670359632B547" italics="true" pageId="null" pageNumber="39">intermedia</emphasis>
</taxonomicName>
[Ten.] Zeltner) aus Griechenland, Italien, Spanien, Portugal und Marokko die Zahl 2n = 20.
</paragraph>
<paragraph id="AE895CCC9FBA4178FEAC9A228BA962C5" pageId="null" pageNumber="39">
<emphasis id="E45CF07EEC0F551224009904FEE5CFD6" italics="true" pageId="null" pageNumber="39">Standort.</emphasis>
Kollin, selten montan. Feuchte oder wechselfeuchte, meist kalkhaltige, tonige oder lehmige 
<normalizedToken id="52835E628106FB4840B0301BD962B938" originalValue="Böden" pageId="null" pageNumber="39">Boeden</normalizedToken>
in 
<normalizedToken id="C050B43B07905A91AEE3AADC0620C25F" originalValue="wärmeren" pageId="null" pageNumber="39">waermeren</normalizedToken>
Lagen. Riedwiesen, seltener lichte 
<normalizedToken id="326D81074DD89C54C33443A50515BF55" originalValue="Wälder" pageId="null" pageNumber="39">Waelder</normalizedToken>
, 
<normalizedToken id="652F695EA2B6E91C340331E9780C8E48" originalValue="Rutschhänge" pageId="null" pageNumber="39">Rutschhaenge</normalizedToken>
, unbebaute Orte (z. B. Kiesgruben).
</paragraph>
<paragraph id="B03AD49295C99EE29B6C7CE3CEC97AAD" pageId="null" pageNumber="39">
<emphasis id="5DE25D9F85C7465D1ADF8DFE5982CBF2" italics="true" pageId="null" pageNumber="39">
Verbreitung. 
<normalizedToken id="A3F035525BA4B8943EAAE48A12199223" originalValue="Westeuropäisch-mediterrane" pageId="null" pageNumber="39">Westeuropaeisch-mediterrane</normalizedToken>
Pflanze:
</emphasis>
Nord- und 
<normalizedToken id="B6BE2D562E9C1A1CFF083A725DA4FB10" originalValue="ostwärts" pageId="null" pageNumber="39">ostwaerts</normalizedToken>
bis Irland, England, Holland, Oberrheinische Tiefebene, Bodensee, Alpen, 
<normalizedToken id="E2C0B5F8524DCDB32370DFF4E11C7AC0" originalValue="Niederösterreich" pageId="null" pageNumber="39">Niederoesterreich</normalizedToken>
, Kroatien, Thrazien, Krim; Kaukasus; Nordwestafrika. - Im Gebiet zerstreut (fehlt den innern 
<normalizedToken id="33FDB2C47D6944355C3312AB4559DA48" originalValue="Alpentälern" pageId="null" pageNumber="39">Alpentaelern</normalizedToken>
), nicht 
<normalizedToken id="F60DAC754CAC9C091DC19A596FA6D056" originalValue="häufig" pageId="null" pageNumber="39">haeufig</normalizedToken>
und oft 
<normalizedToken id="429890B763195690A801044645931F0B" originalValue="unbeständig" pageId="null" pageNumber="39">unbestaendig</normalizedToken>
.
</paragraph>
</subSubSection>
