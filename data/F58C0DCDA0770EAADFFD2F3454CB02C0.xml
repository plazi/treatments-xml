<subSubSection id="F94A74B0CE8C7CFE7488767F50152D0F" pageId="null" pageNumber="370" type="vernacular_names">
<paragraph id="BD5F8F7A39D28030BBA9ECF893DACC1D" pageId="null" pageNumber="370">Niedrige Rapunzel</paragraph>
</subSubSection>
</title>
<subSubSection id="22A00D1F31646DD263B6A5FE2000FE9B" pageId="null" pageNumber="370" type="description">
<paragraph id="7E5C9168FBB96AF0D2368DCBAA83D648" pageId="null" pageNumber="370">
<normalizedToken id="9E673238B0253F7EE263D5940AB5B215" originalValue="Blätter" pageId="null" pageNumber="370">Blaetter</normalizedToken>
in der Mitte 2-3 mm breit, ganzrandig oder mit entfernt stehenden kleinen, aber scharfen 
<normalizedToken id="BF1538CBC4167E4F909EC03A1F897C99" originalValue="Zähnen" pageId="null" pageNumber="370">Zaehnen</normalizedToken>
; obere 
<normalizedToken id="C55CD364593714B3ED2359F239306E54" originalValue="Stengelblätter" pageId="null" pageNumber="370">Stengelblaetter</normalizedToken>
fast immer mit 
<normalizedToken id="C7162BF0817D6C2BD47CF7885081735D" originalValue="Zähnen" pageId="null" pageNumber="370">Zaehnen</normalizedToken>
. 
<emphasis id="7E818A9B934B64E2738A7062501EF449" italics="true" pageId="null" pageNumber="370">
<normalizedToken id="016A6564F536D3E4CC21A466945D2A58" originalValue="Hüllblätter" pageId="null" pageNumber="370">Huellblaetter</normalizedToken>
aus 3
</emphasis>
- 
<emphasis id="F7B080207E12DC3D4687056090645747" italics="true" pageId="null" pageNumber="370">6 mm breitem Grunde lang zugespitzt, 4</emphasis>
- 
<emphasis id="98088A86A35A6E79DB65898C37F9314A" italics="true" pageId="null" pageNumber="370">
7mal so lang wie breit, so lang oder 
<normalizedToken id="E522FC27350B763388EAA36666FA940D" originalValue="länger" pageId="null" pageNumber="370">laenger</normalizedToken>
als der Kopf
</emphasis>
, am Grunde mit scharfen 
<normalizedToken id="00B3487C5392C1A9952E98E900810FC0" originalValue="Zähnen" pageId="null" pageNumber="370">Zaehnen</normalizedToken>
. Kelchzipfel 5-6 mm lang, kurz behaart; Haare 0,1 mm lang. Frucht kahl oder behaart. - 
<normalizedToken id="ECE6E75CA1667B7C9725DACEE91C3F92" originalValue="Blüte" pageId="null" pageNumber="370">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="C04D188D6F5F23215EA4CA8250ABE91E" pageId="null" pageNumber="370">
<emphasis id="2350BB4AC7F94C9F9B3FB3E1F9C8C69C" italics="true" pageId="null" pageNumber="370">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E9A00CDBCAFC14A2911F9DEC4DC285FA" italics="true" pageId="null" pageNumber="370">28:</emphasis>
Material vom Gornergrat (Contandriopoulos 1962), bei einer Pflanze wurde auch 2n = 22 
<normalizedToken id="BD57A3AFC04A21FF41F8FC05159AF713" originalValue="gezählt" pageId="null" pageNumber="370">gezaehlt</normalizedToken>
.
</paragraph>
<paragraph id="1C968688A5CD42322FCA3770A1879BB1" pageId="null" pageNumber="370">
<emphasis id="5DEFD1ACC1AE2A6F46237F1501F2CC1B" italics="true" pageId="null" pageNumber="370">Standort.</emphasis>
Wie 
<taxonomicName id="0AE9F636EF6DAB5185F249D3B5E76B45" class="Magnoliopsida" family="Campanulaceae" genus="Phyteuma" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="370" phylum="Tracheophyta" rank="species" species="hedraianthifolium">
<emphasis id="A35141DFF378B145C7377DD6DC77B5F8" italics="true" pageId="null" pageNumber="370">Ph. hedraianthifolium</emphasis>
</taxonomicName>
(Nr. 1c).
</paragraph>
<paragraph id="C74907F71E47C02F43133DBD8784107D" pageId="null" pageNumber="370">
<emphasis id="D935765AED4034F5A00FF29047E9D6A9" italics="true" pageId="null" pageNumber="370">Verbreitung. Penninische Pflanze:</emphasis>
Penninische Alpen (Gegend des Monte Rosa: Nicolaital, Saastal, Valtornenche, Val de Gressoney, oberes Valsesia, Macugnaga); angeblich auch im Val Formazza und Val Vigezzo (Rossi 1883); selten.
</paragraph>
</subSubSection>
