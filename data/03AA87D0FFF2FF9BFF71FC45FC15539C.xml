<emphasis id="B977EAD4FFF2FF9BFB4CFB32FA9553D1" box="[1277,1368,1179,1204]" italics="true" pageId="7" pageNumber="6">Euagrus</emphasis>
</taxonomicName>
? 
<taxonomicName id="4C034D45FFF2FF9BFAD9FB32FECB53B3" class="Insecta" family="Pompilidae" genus="Pepsis" kingdom="Animalia" order="Hymenoptera" pageId="7" pageNumber="6" phylum="Arthropoda" rank="species" species="mexicanus">
<emphasis id="B977EAD4FFF2FF9BFAD9FB32FECB53B3" italics="true" pageId="7" pageNumber="6">mexicanus</emphasis>
