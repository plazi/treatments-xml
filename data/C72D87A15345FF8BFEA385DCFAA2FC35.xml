<subSubSection id="079E653C5345FF8BFEF38762FAA2FC35" pageId="27" pageNumber="28" type="discussion">
<paragraph id="4F3B36B75345FF8BFEF38762FAA2FC35" blockId="27.[151,1437,428,923]" pageId="27" pageNumber="28">
<emphasis id="7DF0EAA55345FF8BFEF38762FE9CFDD5" bold="true" box="[199,308,609,635]" pageId="27" pageNumber="28">Remarks</emphasis>
. The SPA specimens have been identified here as the northern hemisphere 
<taxonomicName id="88844D345345FF8BFABE8762FB58FDD4" baseAuthorityName="Lyman" baseAuthorityYear="1883" box="[1162,1264,608,635]" class="Ophiuroidea" family="Ophiacanthidae" genus="Ophiolimna" kingdom="Animalia" order="Ophiacanthida" pageId="27" pageNumber="28" phylum="Echinodermata" rank="species" species="bairdi">
