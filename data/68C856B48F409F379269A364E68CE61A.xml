<subSubSection id="3433A0AA011FC77969513CE170C3D710" pageId="null" pageNumber="380" type="description">
<paragraph id="876AB5033B3361545B5A0C6B8EACBA4D" pageId="null" pageNumber="380">
Unterscheidet sich von der Gattung 
<taxonomicName id="03D98203F88DAEDC1F2458761D9B3C64" class="Magnoliopsida" family="Campanulaceae" genus="Campanula" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="380" phylum="Tracheophyta" rank="genus">
<emphasis id="AAA3C1E64262A7463E595AB7C0DDD8DC" italics="true" pageId="null" pageNumber="380">Campanula</emphasis>
</taxonomicName>
(S. 380) einzig durch folgende Merkmale: 
<emphasis id="71130E469F80D92F7E6B5745E92CE8B9" italics="true" pageId="null" pageNumber="380">
Griffel am Grunde von einem 
<normalizedToken id="D862A6B9D1C97755B1DDD61562883F53" originalValue="Drüsenring" pageId="null" pageNumber="380">Druesenring</normalizedToken>
umgeben, viel 
<normalizedToken id="0A35052A6FA4B2C98A5429B2215EBDD9" originalValue="länger" pageId="null" pageNumber="380">laenger</normalizedToken>
als die Krone
</emphasis>
.
</paragraph>
<paragraph id="05C00E80E06577038BFE19EE0B998708" pageId="null" pageNumber="380">
Die Gattung 
<taxonomicName id="3CC4207B67DEF88F0A19DF95B37B5CE9" class="Insecta" family="Phoridae" genus="Adenophora" kingdom="Animalia" order="Diptera" pageId="null" pageNumber="380" phylum="Arthropoda" rank="genus">
<emphasis id="FAC1B7EF7A9F2B45839E7C611B4E5AAD" italics="true" pageId="null" pageNumber="380">Adenophora</emphasis>
</taxonomicName>
<normalizedToken id="1412ECAD8993213ECE67E0ABA24CACFA" originalValue="umfaßt" pageId="null" pageNumber="380">umfasst</normalizedToken>
<emphasis id="A5D58AD0D0FC87F33E493EA72C5F232A" italics="true" pageId="null" pageNumber="380">50 Arten</emphasis>
und hat ihre Hauptverbreitung in 
<emphasis id="22D523497C07F5405CFA61256F82746C" italics="true" pageId="null" pageNumber="380">Zentral- und Ostasien</emphasis>
.
</paragraph>
