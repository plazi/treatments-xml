<subSubSection id="3777F46B672E5BA751DB3E67A0B4D8BF" pageId="null" pageNumber="766" type="description">
<paragraph id="9DDBB00E507C9D7EB688ADC00B6447D0" pageId="null" pageNumber="766">
Unterscheidet sich von 
<taxonomicName id="E1B2C5D1F021CEDBA26B7FF85893B92F" class="Magnoliopsida" family="Amaranthaceae" genus="Amaranthus" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="766" phylum="Tracheophyta" rank="species" species="deflexus">
<emphasis id="C887F340B35218497801989A5AB4CA7C" italics="true" pageId="null" pageNumber="766">A. deflexus</emphasis>
</taxonomicName>
(Nr. 5) durch folgende Merkmale: 1 
<normalizedToken id="EF52E79D79C39271D194290C9BB3E8B5" originalValue="jährig" pageId="null" pageNumber="766">jaehrig</normalizedToken>
, bogig aufsteigend, 
<emphasis id="8BB5112B5411F43C2A7389778ECA42C3" italics="true" pageId="null" pageNumber="766">
kahl; alle 
<normalizedToken id="EC641FF5E455DDC7C76DC835B9046C8D" originalValue="Blütenknäuel" pageId="null" pageNumber="766">Bluetenknaeuel</normalizedToken>
in Blattachseln;
</emphasis>
<normalizedToken id="6EC689D8BC25B3B48D5FD7E66534EF76" originalValue="Perigonblätter" pageId="null" pageNumber="766">Perigonblaetter</normalizedToken>
3, 
<normalizedToken id="7B5E35FD806C02EFC3EF824D79840D45" originalValue="kürzer" pageId="null" pageNumber="766">kuerzer</normalizedToken>
als die reife Frucht; 
<emphasis id="1D7D582D70E3B0F6B9A70C96EDF2CADA" italics="true" pageId="null" pageNumber="766">
Frucht 
<normalizedToken id="F6506E8E2E1DD136DE0AC7AF345AF031" originalValue="öffnet" pageId="null" pageNumber="766">oeffnet</normalizedToken>
sich durch 
<normalizedToken id="9E4C46BA3E5ED4172D669DC29BDA0B9A" originalValue="Querriβ" pageId="null" pageNumber="766">Querriβ</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="038BE952DEBFE8B2B9710C155AC2AE1E" originalValue="Blüte" pageId="null" pageNumber="766">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="F6974D622350D66AB0F5DEC1734B077E" pageId="null" pageNumber="766">
<emphasis id="E2BEBF48463C47CD881D721A18CEC048" italics="true" pageId="null" pageNumber="766">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A1E8F8F44B197C75CA2533B8943B70E4" italics="true" pageId="null" pageNumber="766">32:</emphasis>
Material aus 
<normalizedToken id="778403A8C8F89BDEAC7E9B63E7FB5C9C" originalValue="europäischen" pageId="null" pageNumber="766">europaeischen</normalizedToken>
und amerikanischen botanischen 
<normalizedToken id="81181D9DC2CF6F60B2ABDA769C932802" originalValue="Gärten" pageId="null" pageNumber="766">Gaerten</normalizedToken>
(Grant 1959a).
</paragraph>
<paragraph id="56690829F3521DBD91640E63309A1A34" pageId="null" pageNumber="766">
<emphasis id="266D5549D6669EF706C5D96D9FE718E4" italics="true" pageId="null" pageNumber="766">Standort.</emphasis>
Kollin. Wie 
<emphasis id="595E85B407AD03618C9DE2CF570CF71E" italics="true" pageId="null" pageNumber="766">
A. 
<normalizedToken id="A3AB0ADC42E8551EA112E5D4B176DF36" originalValue="retroβexus" pageId="null" pageNumber="766">retroβexus</normalizedToken>
</emphasis>
(Nr. 1).
</paragraph>
<paragraph id="80A78A70701BCF7BE145A5ACD1D39861" pageId="null" pageNumber="766">
<emphasis id="3F1C1358AAC463DA589851EB3D8B28CE" italics="true" pageId="null" pageNumber="766">
Verbreitung. 
<normalizedToken id="253B4E38208C082036C8A6092578DD51" originalValue="Ursprünglich" pageId="null" pageNumber="766">Urspruenglich</normalizedToken>
vielleicht mediterrane Pflanze;
</emphasis>
heute 
<normalizedToken id="B48415E6F93016D59604545FAF260FF8" originalValue="über" pageId="null" pageNumber="766">ueber</normalizedToken>
die warmen Zonen der ganzen Erde verbreitet. - Im Gebiet: 
<normalizedToken id="C1954E7736A31D6C199E1B55E3421F16" originalValue="Alpensüdseite" pageId="null" pageNumber="766">Alpensuedseite</normalizedToken>
, zentralalpine 
<normalizedToken id="E71243BDA19ED164F51C39DD1F05E68E" originalValue="Täler" pageId="null" pageNumber="766">Taeler</normalizedToken>
, Oberrheinische Tiefebene (
<normalizedToken id="D5FD52616411892F5AB3D65F07C4B589" originalValue="eingebürgert" pageId="null" pageNumber="766">eingebuergert</normalizedToken>
); 
<normalizedToken id="294020F4E8448219676A51BB08F42AC8" originalValue="nördlich" pageId="null" pageNumber="766">noerdlich</normalizedToken>
der Alpen sonst gelegentlich adventiv.
</paragraph>
</subSubSection>
