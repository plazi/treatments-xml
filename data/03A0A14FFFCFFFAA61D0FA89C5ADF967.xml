<subSubSection id="C31343D2FFCFFFAA6180F98AC5ADF967" pageId="3" pageNumber="304" type="discussion">
<paragraph id="8BB61059FFCFFFAA6180F98AC5ADF967" blockId="3.[151,1437,1447,1762]" pageId="3" pageNumber="304">
<emphasis id="B97DCC4BFFCFFFAA6180F98AC460F9F3" bold="true" box="[199,315,1628,1654]" pageId="3" pageNumber="304">Remarks.</emphasis>
<bibRefCitation id="EF986DA8FFCFFFAA600EF98AC756F9F3" author="Lohmann, H." box="[329,525,1628,1654]" pageId="3" pageNumber="304" pagination="149 - 154" refId="ref12631" refString="Lohmann, H. (1909) Marine Hydrachnidae und Halacaridae. In: Michaelsen, W. &amp; Hartmeyer, R. (Eds.), Die Fauna Sudwest- Australiens. Ergebnisse der Hamburger Sudwest-Australischen Forschungsreise 1905. G. Fischer, Jena, pp. 149 - 154." type="book chapter" year="1909">Lohmann (1909)</bibRefCitation>
discovered 
<taxonomicName id="4C096BDAFFCFFFAA63E4F98AC1EDF9F3" authority="(Lohmann 1909)" baseAuthorityName="Lohmann" baseAuthorityYear="1909" box="[675,1206,1628,1654]" class="Arachnida" family="Halacaridae" genus="Copidognathus" kingdom="Animalia" order="Trombidiformes" pageId="3" pageNumber="304" phylum="Arthropoda" rank="species" species="australensis">
<emphasis id="B97DCC4BFFCFFFAA63E4F98AC6B8F9F3" box="[675,995,1628,1654]" italics="true" pageId="3" pageNumber="304">Copidognathus australensis</emphasis>
(
<bibRefCitation id="EF986DA8FFCFFFAA62BEF98AC1F6F9F3" author="Lohmann, H." box="[1017,1197,1628,1654]" pageId="3" pageNumber="304" pagination="149 - 154" refId="ref12631" refString="Lohmann, H. (1909) Marine Hydrachnidae und Halacaridae. In: Michaelsen, W. &amp; Hartmeyer, R. (Eds.), Die Fauna Sudwest- Australiens. Ergebnisse der Hamburger Sudwest-Australischen Forschungsreise 1905. G. Fischer, Jena, pp. 149 - 154." type="book chapter" year="1909">Lohmann 1909</bibRefCitation>
)
</taxonomicName>
from southwestern 
<collectingCountry id="F31E50C9FFCFFFAA61D0F956C5A5F91F" box="[151,254,1664,1690]" name="Australia" pageId="3" pageNumber="304">Australia</collectingCountry>
with a very short description. 
<bibRefCitation id="EF986DA8FFCFFFAA6324F956C641F91F" author="Bartsch I." box="[611,794,1664,1690]" pageId="3" pageNumber="304" pagination="315 - 331" refId="ref8776" refString="Bartsch I. (1999 a) Halacaridae (Acari) from Western Australia. Four species of Copidognathus. In: Walker, D. I. &amp; Wells, F. E. (Eds.), The Seagrass Flora and Fauna of Rottnest Island, Western Australia. Western Australian Museum, Perth, pp. 315 - 331." type="book chapter" year="1999">Bartsch (1999a)</bibRefCitation>
redescribed this species collected from Rottnest Island, southwestern 
<collectingCountry id="F31E50C9FFCFFFAA6075F972C4C7F93B" box="[306,412,1700,1726]" name="Australia" pageId="3" pageNumber="304">Australia</collectingCountry>
. The Indian specimens from Andaman Islands match well with the description of 
<bibRefCitation id="EF986DA8FFCFFFAA6400F972C5AAF967" author="Bartsch I." pageId="3" pageNumber="304" pagination="315 - 331" refId="ref8776" refString="Bartsch I. (1999 a) Halacaridae (Acari) from Western Australia. Four species of Copidognathus. In: Walker, D. I. &amp; Wells, F. E. (Eds.), The Seagrass Flora and Fauna of Rottnest Island, Western Australia. Western Australian Museum, Perth, pp. 315 - 331." type="book chapter" year="1999">Bartsch (1999a)</bibRefCitation>
.
</paragraph>
