Anteon autumnale Olmi 1991: 170; Xu et al. 
<quantity id="C731ABA48E04FF8A4A525432FD04FCC4" box="[610,673,798,820]" metricMagnitude="0" metricUnit="kg" metricValue="2.011" pageId="74" pageNumber="75" unit="g" value="2011.0">2011g</quantity>
