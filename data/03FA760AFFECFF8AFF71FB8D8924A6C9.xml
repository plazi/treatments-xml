<subSubSection id="C3499497FFE8FF8BFF44F88A89E9A939" pageId="6" pageNumber="277" type="biology_ecology">
<paragraph id="8BECC71CFFE8FF8BFF44F88A89E9A939" blockId="6.[136,1452,1911,2082]" pageId="6" pageNumber="277">
<emphasis id="B9271B0EFFE8FF8BFF44F88A899BA68A" bold="true" box="[189,485,1911,1937]" pageId="6" pageNumber="277">Habitat and Ecology:—</emphasis>
Bamboo forest, riparian forest, ca. 
<quantity id="4CAB6AF9FFE8FF8BFC75F88A8C7DA68A" box="[908,1027,1911,1938]" metricMagnitude="1" metricUnit="m" metricValue="7.5" metricValueMax="10.0" metricValueMin="5.0" pageId="6" pageNumber="277" unit="m" value="75.0" valueMax="100.0" valueMin="50.0">50–100 m</quantity>
a.s.l. The 
<taxonomicName id="4C53BC9FFFE8FF8BFB73F8858D58A68A" box="[1162,1318,1911,1937]" class="Magnoliopsida" family="Ebenaceae" genus="Diospyros" kingdom="Plantae" order="Ericales" pageId="6" pageNumber="277" phylum="Tracheophyta" rank="species" species="bambuseti">
