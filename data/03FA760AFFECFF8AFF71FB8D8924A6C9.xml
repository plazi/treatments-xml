Symington (1938: 347)
</taxonomicName>
, 
<taxonomicName id="4C53BC9FFFE8FF8BFF71F8198C58A6E6" authority="(Blume 1827: 1097) Payens (1967: 231)" authorityName="Payens" authorityPageNumber="231" authorityYear="1967" baseAuthorityName="Blume" baseAuthorityPageNumber="1097" baseAuthorityYear="1827" box="[136,1062,2019,2045]" class="Magnoliopsida" family="Lecythidaceae" genus="Barringtonia" kingdom="Plantae" order="Ericales" pageId="6" pageNumber="277" phylum="Tracheophyta" rank="subSpecies" species="acutangula" subSpecies="spicata">
