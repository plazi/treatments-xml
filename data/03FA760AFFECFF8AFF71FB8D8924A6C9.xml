</taxonomicName>
(L. 1753: 95) L. (1763: 243), 
<taxonomicName id="4C53BC9FFFE8FF8BFEE4F8428A05A6C2" authority="Hook." authorityName="Hook." box="[285,635,1983,2009]" class="Magnoliopsida" family="Achariaceae" genus="Hydnocarpus" kingdom="Plantae" order="Malpighiales" pageId="6" pageNumber="277" phylum="Tracheophyta" rank="species" species="castaneus">
<emphasis id="B9271B0EFFE8FF8BFEE4F8428A54A6C2" box="[285,554,1983,2009]" italics="true" pageId="6" pageNumber="277">Hydnocarpus castaneus</emphasis>
