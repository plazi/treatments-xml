<taxonomicName id="4C53BC9FFFE8FF8BFE6CF8CE8A6BA653" box="[405,533,1843,1864]" class="Magnoliopsida" family="Ebenaceae" genus="Diospyros" kingdom="Plantae" order="Ericales" pageId="6" pageNumber="277" phylum="Tracheophyta" rank="species" species="bambuseti">
<emphasis id="B9271B0EFFE8FF8BFE6CF8CE8A6BA653" box="[405,533,1843,1864]" italics="true" pageId="6" pageNumber="277">D. bambuseti</emphasis>
