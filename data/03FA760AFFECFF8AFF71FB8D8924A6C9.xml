<taxonomicName id="4C53BC9FFFE8FF8BFC4FF83D8DD9A6C2" authority="Symington (1938: 347)" authorityName="Symington" authorityPageNumber="347" authorityYear="1938" box="[950,1447,1983,2009]" class="Magnoliopsida" family="Dipterocarpaceae" genus="Vatica" kingdom="Plantae" order="Malvales" pageId="6" pageNumber="277" phylum="Tracheophyta" rank="species" species="diospyroides">
