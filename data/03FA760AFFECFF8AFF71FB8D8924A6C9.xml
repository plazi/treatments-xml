<taxonomicName id="4C53BC9FFFE8FF8BFAE9F8F28D0CA63F" box="[1296,1394,1807,1828]" class="Magnoliopsida" family="Ebenaceae" genus="Diospyros" kingdom="Plantae" order="Ericales" pageId="6" pageNumber="277" phylum="Tracheophyta" rank="genus">
