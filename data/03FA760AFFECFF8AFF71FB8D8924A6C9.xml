<taxonomicName id="4C53BC9FFFE8FF8BFBF6F8668C9CA6AE" box="[1039,1250,1947,1973]" class="Magnoliopsida" family="Rubiaceae" genus="Nauclea" kingdom="Plantae" order="Gentianales" pageId="6" pageNumber="277" phylum="Tracheophyta" rank="species" species="orientalis">
