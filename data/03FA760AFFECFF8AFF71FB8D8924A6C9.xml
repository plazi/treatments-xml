subsp. 
<emphasis id="B9271B0EFFE8FF8BFE02F8198A32A6E6" box="[507,588,2020,2045]" italics="true" pageId="6" pageNumber="277">spicata</emphasis>
(
<bibRefCitation id="EFC2BAEDFFE8FF8BFDA4F81E8B4AA6E6" author="Blume, C. L." box="[605,820,2019,2045]" pageId="6" pageNumber="277" pagination="1096 - 1197" refId="ref5283" refString="Blume, C. L. (1827) Barringtonia. Bijdragen tot de Flora van Nederlandsch Indie. Ter Lands Drukkerij, Batavia, pp. 1096 - 1197." type="book chapter" year="1827">Blume 1827: 1097</bibRefCitation>
