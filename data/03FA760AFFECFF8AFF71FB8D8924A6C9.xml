<taxonomicName id="4C53BC9FFFE8FF8BFE24F93A8A41A7C7" box="[477,575,1735,1756]" class="Magnoliopsida" family="Ebenaceae" genus="Diospyros" kingdom="Plantae" order="Ericales" pageId="6" pageNumber="277" phylum="Tracheophyta" rank="genus">
