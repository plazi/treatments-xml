<taxonomicName id="4C53BC9FFFE8FF8BFE60F9168A63A61B" box="[409,541,1771,1792]" class="Magnoliopsida" family="Ebenaceae" genus="Diospyros" kingdom="Plantae" order="Ericales" pageId="6" pageNumber="277" phylum="Tracheophyta" rank="species" species="bambuseti">
