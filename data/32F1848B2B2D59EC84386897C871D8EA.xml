<taxonomicName id="55601D2377A5A3E2E7C37E81CB12B62E" authority="" authorityName="Moore" authorityYear="1867" class="Insecta" family="Drepanidae" genus="Drepanodes" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Drepanodes quinaria" order="Lepidoptera" pageId="0" pageNumber="57" phylum="Arthropoda" rank="species" species="quinaria">Drepanodes quinaria</taxonomicName>
