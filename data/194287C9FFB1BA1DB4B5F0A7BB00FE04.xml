, 
<collectingCountry id="E9FC764FFFB1BA1DB719FED1B181F600" box="[779,935,2481,2510]" name="Costa Rica" pageId="13" pageNumber="632">Costa Rica</collectingCountry>
, E 
<collectingCountry id="E9FC764FFFB1BA1DB7F4FED1B671F600" box="[998,1111,2481,2510]" name="Panama" pageId="13" pageNumber="632">Panama</collectingCountry>
, 
<collectingCountry id="E9FC764FFFB1BA1DB07DFED1B724F600" box="[1135,1282,2481,2510]" name="Venezuela" pageId="13" pageNumber="632">Venezuela</collectingCountry>
