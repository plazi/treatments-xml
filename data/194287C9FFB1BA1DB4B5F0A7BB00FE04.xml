, 
<collectingCountry id="E9FC764FFFB1BA1DB4B7FD61B2D1F5D0" box="[165,247,2561,2590]" name="Brazil" pageId="13" pageNumber="632">Brazil</collectingCountry>
, and N 
<collectingCountry id="E9FC764FFFB1BA1DB575FD61B3E1F5D0" box="[359,455,2561,2590]" name="Bolivia" pageId="13" pageNumber="632">Bolivia</collectingCountry>
