<paragraph id="BE12B0980182E54F46E3D584ABDC44E1" pageId="null" pageNumber="602">
<taxonomicName id="10EA8C8D0CA1DB4DD32233266D92BB99" authority="L." class="Magnoliopsida" family="Fabaceae" genus="Lathyrus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="602" phylum="Tracheophyta" rank="species" species="pratensis">
Lathyrus 
<normalizedToken id="B30C1A563DAA4F5789E7D6E2431B791D" originalValue="praténsis" pageId="null" pageNumber="602">pratensis</normalizedToken>
<authorityName id="B8ABC25B128C5DE569F179A79BADF540" pageId="null" pageNumber="602">L.</authorityName>
</taxonomicName>
</paragraph>
