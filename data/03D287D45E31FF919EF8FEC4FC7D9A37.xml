Subfamily 
<taxonomicName id="4C7B4D415E31FF919F74FEC4FE1C9953" authorityName="Navas" authorityYear="1910" box="[298,494,347,373]" pageId="8" pageNumber="109" rank="subFamily" subFamily="Nothochrysinae">Nothochrysinae</taxonomicName>
