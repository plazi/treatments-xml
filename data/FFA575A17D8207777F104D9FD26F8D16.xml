<subSubSection id="AB4132CB6AE207CDA874127E62679D4D" pageId="null" pageNumber="167" type="description">
<paragraph id="A8100007909E4916ECA57C346B9BBABA" pageId="null" pageNumber="167">
1- oder 2 
<normalizedToken id="EB15AE1D5FD7D29118C0DDA12174A9DC" originalValue="jährige" pageId="null" pageNumber="167">jaehrige</normalizedToken>
<normalizedToken id="D5088223561037FE500C29BF7C837399" originalValue="Kräuter" pageId="null" pageNumber="167">Kraeuter</normalizedToken>
. 
<normalizedToken id="60CB7072DE2F783E0A8BDE0843FD4B97" originalValue="Blätter" pageId="null" pageNumber="167">Blaetter</normalizedToken>
ungeteilt bis fiederteilig. Kelch 
<normalizedToken id="56DC26FF0CCFDC12F6D6B6729D99472F" originalValue="röhren-" pageId="null" pageNumber="167">roehren-</normalizedToken>
bis 
<normalizedToken id="55DDF773495B2AE7E226D1B12A8A0C8B" originalValue="glockenförmig" pageId="null" pageNumber="167">glockenfoermig</normalizedToken>
, 5 
<normalizedToken id="F613A1A7B4F0CC1220F76E855834C58A" originalValue="zähnig" pageId="null" pageNumber="167">zaehnig</normalizedToken>
, zur Fruchtzeit 
<normalizedToken id="6103B16B853A0733FA19011C0474C249" originalValue="vergrößert" pageId="null" pageNumber="167">vergroessert</normalizedToken>
und die Frucht 
<normalizedToken id="F1A1DCAB56CE7ABD45407DBEF6951F45" originalValue="einschließend" pageId="null" pageNumber="167">einschliessend</normalizedToken>
. Krone 
<normalizedToken id="D4AC9168AFB20BB8C5555C4EF74B738D" originalValue="trichterförmig" pageId="null" pageNumber="167">trichterfoermig</normalizedToken>
, mit 5teiligem, wenig ausgebreitetem Rand. 
<normalizedToken id="2C33AD1488130653C60D066483550373" originalValue="Staubblätter" pageId="null" pageNumber="167">Staubblaetter</normalizedToken>
5 (davon 3 
<normalizedToken id="EC5E293FB461E2DC2BA417F42D9234A8" originalValue="länger" pageId="null" pageNumber="167">laenger</normalizedToken>
). Fruchtknoten 2 
<normalizedToken id="82EC63B6794C271B72A918D7C6B108C9" originalValue="fächerig" pageId="null" pageNumber="167">faecherig</normalizedToken>
. 
<emphasis id="5E128A6E675C284115441BAA49CE33AE" italics="true" pageId="null" pageNumber="167">Frucht eine mit einem Deckel aufspringende Kapsel</emphasis>
. Samen mit wabenartiger 
<normalizedToken id="929B9DEAD91805E36A66FCC75E9BFB13" originalValue="Oberfläche" pageId="null" pageNumber="167">Oberflaeche</normalizedToken>
.
</paragraph>
<paragraph id="34826EED140512A65ABBD267FAE86D69" pageId="null" pageNumber="167">
Die Gattung 
<taxonomicName id="705FF6AE19E4039536697D144EABA5E3" class="Magnoliopsida" family="Solanaceae" genus="Hyoscyamus" kingdom="Plantae" order="Solanales" pageId="null" pageNumber="167" phylum="Tracheophyta" rank="genus">
<emphasis id="17666ADAACF8AB5B8DDB2E0FAEE2C410" italics="true" pageId="null" pageNumber="167">Hyoscyamus</emphasis>
</taxonomicName>
<normalizedToken id="1AC67920E743BAC02F2D274EA4E0F58F" originalValue="umfaßt" pageId="null" pageNumber="167">umfasst</normalizedToken>
<emphasis id="66AF280C0A03FC3050FEEF26A0E970C1" italics="true" pageId="null" pageNumber="167">15 Arten und hat ihre Hauptverbreitung im Mittelmeergebiet</emphasis>
.
</paragraph>
