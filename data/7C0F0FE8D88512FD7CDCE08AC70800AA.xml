<subSubSection id="C3BFFD1590FAEBB22296B9C645929FE8" pageId="null" pageNumber="590" type="description">
<paragraph id="1FFE0A011ED6262FB974FC30E0A8E7D1" pageId="null" pageNumber="590">
2-10 cm hoch. 
<emphasis id="4184654AFC18313AD26A3B4F714334E1" italics="true" pageId="null" pageNumber="590">Blattrosetten zu mehreren beisammen</emphasis>
(bei den andern Arten im Gebiet meist einzeln), 
<emphasis id="5FEAF8A39347519CA529BE7B9DA97151" italics="true" pageId="null" pageNumber="590">
so 
<normalizedToken id="5255DB25D21832729AF958AFA5E141F1" originalValue="daß" pageId="null" pageNumber="590">dass</normalizedToken>
die Pflanze kleine Polster bildet.
</emphasis>
Am Grunde der Blattrosette 
<normalizedToken id="8410F3125D3128276FA35927E0B12A15" originalValue="weißflockig" pageId="null" pageNumber="590">weissflockig</normalizedToken>
behaart und 
<emphasis id="76149B7705345DA72A97BD9E5E77CB28" italics="true" pageId="null" pageNumber="590">mit zahlreichen schwarzen, alten Blattresten.</emphasis>
<normalizedToken id="ABEE3CB6DA9754BC0B5C25722D0905FF" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
meist bis fast zum Mittelnerv geteilt, mit schmalen, 
<normalizedToken id="85ACC97AB2F88EC61B91EB2140E5B433" originalValue="1½" pageId="null" pageNumber="590">11/2</normalizedToken>
-3mal so langen wie breiten, grob 
<normalizedToken id="53B81B9CCFF8E742580C37F279576822" originalValue="gezähnten" pageId="null" pageNumber="590">gezaehnten</normalizedToken>
Abschnitten (auch zwischen den Abschnitten 
<normalizedToken id="E4CB3EE69CBE25D049E3DBBF8E6A2258" originalValue="gezähnt" pageId="null" pageNumber="590">gezaehnt</normalizedToken>
). 
<normalizedToken id="E969D1DC24BA91AB775F3131F8B83383" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
zur 
<normalizedToken id="CB87C6E2FB43DCCA4C2D5CD90C849237" originalValue="Blütezeit" pageId="null" pageNumber="590">Bluetezeit</normalizedToken>
0,9-1,3 cm lang, 
<normalizedToken id="0448FA62C926910EF759C40192A4C418" originalValue="hellgrün" pageId="null" pageNumber="590">hellgruen</normalizedToken>
. 
<normalizedToken id="8CFF44E49A4A463F44CEAE2623241A47" originalValue="Äußere" pageId="null" pageNumber="590">Aeussere</normalizedToken>
<normalizedToken id="C3DAEA1C52F44BC1A778A26366B1690B" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
breit lanzettlich, ⅕-⅓ so lang und 
<normalizedToken id="FFE6887069561D35804038522D319323" originalValue="½" pageId="null" pageNumber="590">1/2</normalizedToken>
-⅔ so breit wie die innern, 
<emphasis id="1B51F6861D72ED792D7EC21DF91C3942" italics="true" pageId="null" pageNumber="590">mit deutlichem, 0,3</emphasis>
- 
<emphasis id="6E12CEB9EE7BCFB4959D6BC638689E8F" italics="true" pageId="null" pageNumber="590">
0,5 mm breitem, 
<normalizedToken id="0E6CC2A6FA3C8A6EAEFD29EDE5365B31" originalValue="häutigem" pageId="null" pageNumber="590">haeutigem</normalizedToken>
, hellem Rand
</emphasis>
, zur 
<normalizedToken id="AFEC3327483AECCBFE64188BB186C64B" originalValue="Blütezeit" pageId="null" pageNumber="590">Bluetezeit</normalizedToken>
anliegend; innere 
<normalizedToken id="24C9F361BF8592822487B868329718E5" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
an der Spitze oft mit kleinen 
<normalizedToken id="58E28FC7AB7D5F175A66D058B9CD2BA3" originalValue="Höckern" pageId="null" pageNumber="590">Hoeckern</normalizedToken>
. 
<normalizedToken id="98AAEC3940FA9D6E2B9F9571AA2D5959" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
hellgelb. 
<normalizedToken id="19C78E968A9D9CD3D4EC23C422DA80C6" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
(ohne Schnabel) 3-3,5 mm lang, hellbraun; Fruchtspitze ⅛-⅕ so lang wie der Rest der Frucht; Schnabel 
<normalizedToken id="0636756E8035D8F06C5C3F61C81C5813" originalValue="1½" pageId="null" pageNumber="590">11/2</normalizedToken>
-2mal so lang wie die Frucht. - 
<normalizedToken id="BE2CECB3D28236676017CB984DD344E0" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="A0216C8321C3A1FDE7B464CB2775B3FA" pageId="null" pageNumber="590">
<emphasis id="69A1307AEAD16C83BB670F466AE27BFA" italics="true" pageId="null" pageNumber="590">
<pageBreakToken id="2ED7E02673C011FDC391FBE584BB2E7C" pageId="null" pageNumber="590">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="F9FC537E6638B6B07A84F989D6075B9D" italics="true" pageId="null" pageNumber="590">24:</emphasis>
Material aus der Mongolei (Malecka 1967).
</paragraph>
<paragraph id="5F0E3881930C890469804899B443B3F2" pageId="null" pageNumber="590">
<emphasis id="B38321658FC26377812F2C208E43A535" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Alpin (bis 
<normalizedToken id="24D34CE67C067E100D2DC23329658644" originalValue="über" pageId="null" pageNumber="590">ueber</normalizedToken>
3000 m). Trockene, lockere, neutrale 
<normalizedToken id="9C154CAE4246BAFBA96F63B70411A73F" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
. Rasen.
</paragraph>
<paragraph id="380987E613EB1E4FEF7F09BAEB7EA2DB" pageId="null" pageNumber="590">
<emphasis id="2A427A59B6EE4D2388EEFCEBBC331E38" italics="true" pageId="null" pageNumber="590">Verbreitung. Eurasiatische Gebirgspflanze:</emphasis>
Sierra Nevada, 
<normalizedToken id="EF5B7ACC77C08467F37461EA15CABCCF" originalValue="Pyrenäen" pageId="null" pageNumber="590">Pyrenaeen</normalizedToken>
, Alpen, Kaukasus, Gebirge Zentralasiens, Altai. - Im Gebiet: Mont Cenis, Aostatal, 
<normalizedToken id="2D59C56E37C554408A900B7983D86E4B" originalValue="südliche" pageId="null" pageNumber="590">suedliche</normalizedToken>
Walliser Alpen zwischen Zermatt und Simplon.
</paragraph>
</subSubSection>
