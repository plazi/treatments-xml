<subSubSection id="A7CC2DBDFFECFFC7FF6BFD74FE90FC99" pageId="54" pageNumber="329" type="discussion">
<paragraph id="EF697E36FFECFFC7FF6BFD74FE90FC99" blockId="54.[151,1127,658,841]" pageId="54" pageNumber="329">
<emphasis id="DDA2A224FFECFFC7FF6BFD74FEB8FD19" bold="true" box="[151,262,658,681]" pageId="54" pageNumber="329">Remarks.</emphasis>
<bibRefCitation id="8B4703C7FFECFFC7FEF3FD74FE17FD19" author="SPAETH" box="[271,425,658,681]" firstAuthor="SPAETH" pageId="54" pageNumber="329" pagination="165 - 181" refId="ref51142" refString="SPAETH F. 1923: Neue Cassidinen (Coleoptera) des tropischen Amerika. Norsk Entomologisk Tidsskrift 1 (1922): 165 - 181. [Published on 24. vi. 1923]." type="journal article" year="1923">SPAETH (1923)</bibRefCitation>
synonymized 
<taxonomicName id="28D605B5FFECFFC7FDB7FD74FC89FD19" authorityName="Wagener" authorityYear="1877" box="[587,823,658,681]" class="Insecta" family="Chrysomelidae" genus="Physonota" kingdom="Animalia" order="Coleoptera" pageId="54" pageNumber="329" phylum="Arthropoda" rank="species" species="bipunctata">
<emphasis id="DDA2A224FFECFFC7FDB7FD74FC89FD19" box="[587,823,658,681]" italics="true" pageId="54" pageNumber="329">Physonota bipunctata</emphasis>
</taxonomicName>
with 
<taxonomicName id="28D605B5FFECFFC7FC86FD74FE81FD79" authority="Boheman, 1857" authorityName="Boheman" authorityYear="1857" class="Insecta" family="Chrysomelidae" genus="Chelymorpha" kingdom="Animalia" order="Coleoptera" pageId="54" pageNumber="329" phylum="Arthropoda" rank="species" species="longula">
<emphasis id="DDA2A224FFECFFC7FC86FD74FBD8FD19" box="[890,1126,658,681]" italics="true" pageId="54" pageNumber="329">Chelymorpha longula</emphasis>
<bibRefCitation id="8B4703C7FFECFFC7FF6BFD54FE81FD79" author="Boheman" box="[151,319,690,713]" firstAuthor="Boheman" pageId="54" pageNumber="329" refId="ref47980" refString="BOHEMAN C. H. 1857: Catalogue of Coleopterous Insects in the collection of the British Museum. Part IX. Cassidae. Printed by Order of the trustees [of the British Museum], London, 225 pp." type="book" year="1857">Boheman, 1857</bibRefCitation>
</taxonomicName>
and transferred it to the genus 
<taxonomicName id="28D605B5FFECFFC7FD7DFD54FCCCFD79" authority="Spaeth, 1909" authorityName="Spaeth" authorityYear="1909" box="[641,882,690,713]" class="Insecta" family="Chrysomelidae" genus="Eutheria" kingdom="Animalia" order="Coleoptera" pageId="54" pageNumber="329" phylum="Arthropoda" rank="genus">
<emphasis id="DDA2A224FFECFFC7FD7DFD54FD60FD79" box="[641,734,690,713]" italics="true" pageId="54" pageNumber="329">Eutheria</emphasis>
<bibRefCitation id="8B4703C7FFECFFC7FD18FD54FCCCFD79" author="Spaeth" box="[740,882,690,713]" firstAuthor="Spaeth" journalOrPublisher="Deutsche Entomologische Zeitschrift" pageId="54" pageNumber="329" pagination="715 - 732" part="1909" refId="ref50857" refString="SPAETH F. 1909 a: Kritische Studien uber Chelymorpha Boh. und die verwandten Gattungen (Col.). Deutsche Entomologische Zeitschrift 1909: 715 - 732." title="Kritische Studien uber Chelymorpha Boh. und die verwandten Gattungen (Col.)" type="journal article" year="1909">Spaeth, 1909</bibRefCitation>
</taxonomicName>
. I have studied the 
<typeStatus id="306DC094FFECFFC7FBC5FD54FBD9FD79" box="[1081,1127,690,713]" pageId="54" pageNumber="329">type</typeStatus>
of the latter taxon and found that it is conspecific with 
<taxonomicName id="28D605B5FFECFFC7FD33FD34FCC2FD59" authorityName="Boheman" authorityYear="1854" box="[719,892,722,745]" class="Insecta" family="Chrysomelidae" genus="Chelymorpha" kingdom="Animalia" order="Coleoptera" pageId="54" pageNumber="329" phylum="Arthropoda" rank="species" species="commutabilis">
<emphasis id="DDA2A224FFECFFC7FD33FD34FCC2FD59" box="[719,892,722,745]" italics="true" pageId="54" pageNumber="329">C. commutabilis</emphasis>
</taxonomicName>
, for more information see remarks under that species. Due of the new synonymy I hereby restore species status of 
<taxonomicName id="28D605B5FFECFFC7FF6BFCF4FE99FC99" authorityName="Wagener" authorityYear="1877" box="[151,295,786,809]" class="Insecta" family="Chrysomelidae" genus="Physonota" kingdom="Animalia" order="Coleoptera" pageId="54" pageNumber="329" phylum="Arthropoda" rank="species" species="bipunctata">
<emphasis id="DDA2A224FFECFFC7FF6BFCF4FE99FC99" box="[151,295,786,809]" italics="true" pageId="54" pageNumber="329">E. bipunctata</emphasis>
</taxonomicName>
.
</paragraph>
</subSubSection>
