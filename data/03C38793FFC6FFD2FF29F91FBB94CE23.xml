<collectingCountry id="F37D7615FFC5FFD3FD2EF815BDDEC714" box="[655,747,2040,2066]" name="China" pageId="22" pageNumber="243">CHINA</collectingCountry>
(
<figureCitation id="13512A00FFC5FFD3FD5BF815BC0AC714" box="[762,831,2040,2066]" captionStart="FIGURE 1" captionStartId="2.[136,229,1599,1621]" captionTargetBox="[151,1436,350,1570]" captionTargetId="figure-95@2.[151,1436,350,1571]" captionTargetPageId="2" captionText="FIGURE 1. Collection areas in northeastern China. A. Changchun area in Jilin Province. B. Jilin area in Jilin Province. C. Mountanious area in southern Heilongjiang Province. D. Area around Changbai Mountains in Jilin Province. E. Baicheng area in western Jilin Province. F. Yanbian area in eastern Jilin Province. G. Tonghua area in southeastern Jilin Province." figureDoi="http://doi.org/10.5281/zenodo.6416743" httpUri="https://zenodo.org/record/6416743/files/figure.png" pageId="22" pageNumber="243">Fig. 1</figureCitation>
):
</emphasis>
—Telia on 
<taxonomicName id="4C6A4D06FFC5FFD3FC6EF815BBA4C714" box="[975,1169,2040,2066]" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="22" pageNumber="243" phylum="Tracheophyta" rank="species" species="pediformis">
