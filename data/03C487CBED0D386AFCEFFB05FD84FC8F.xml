<td id="768C5DE3ED0EC5CAFE6DFF3FFDFDFECA" box="[424,568,241,267]" gridcol="2" gridrow="2" pageId="607" pageNumber="608">1-0; 11</td>
<td id="768C5DE3ED0EC5CAFDADFF3FFD08FECA" box="[616,717,241,267]" gridcol="3" gridrow="2" pageId="607" pageNumber="608">10 or 11</td>
</tr>
<tr id="355D349FED0EC5CAFF4DFEDDFD08FEEF" box="[136,717,275,302]" gridrow="3" pageId="607" pageNumber="608">
