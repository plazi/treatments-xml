<td id="768C5DE3ED0EC5CAFE6DFF01FDFDFF28" box="[424,568,207,233]" gridcol="2" gridrow="1" pageId="607" pageNumber="608">1-0; 8</td>
<td id="768C5DE3ED0EC5CAFDADFF01FD08FF28" box="[616,717,207,233]" gridcol="3" gridrow="1" pageId="607" pageNumber="608">7 or 8</td>
