<subSubSection id="C4FA16AA326527243529B572265E53D6" pageId="null" pageNumber="729" type="description">
<paragraph id="4BCE70008568922013195C5AA5ACA3F1" pageId="null" pageNumber="729">
Kleine, nur im untern Teil verholzte 
<normalizedToken id="3F8B9DAC465DFA3000C748556D763655" originalValue="Sträucher" pageId="null" pageNumber="729">Straeucher</normalizedToken>
. 
<emphasis id="FFAB4E8A889DAD646735EAD314755067" italics="true" pageId="null" pageNumber="729">
<normalizedToken id="744D00338B48231C52E55956E905917F" originalValue="Blätter" pageId="null" pageNumber="729">Blaetter</normalizedToken>
<normalizedToken id="50681AAF0B7BB4AA63B10D5E8CB92735" originalValue="wechselständig" pageId="null" pageNumber="729">wechselstaendig</normalizedToken>
</emphasis>
(unsere Arten), seltener 
<normalizedToken id="2C4E34822EDDE5683DB6D9EF6669DE12" originalValue="gegenständig" pageId="null" pageNumber="729">gegenstaendig</normalizedToken>
, ohne deutlichen Stiel, 1nervig, mit oder ohne 
<normalizedToken id="69E985192F191226D9611CECE0DD33B3" originalValue="Nebenblätter" pageId="null" pageNumber="729">Nebenblaetter</normalizedToken>
. 
<normalizedToken id="D7486E16C3E9AC3907E3F8D3555D5FB7" originalValue="Kelchblätter" pageId="null" pageNumber="729">Kelchblaetter</normalizedToken>
5, ungleich 
<normalizedToken id="2F7DEE0586BAB883209FB18B52D6E0F9" originalValue="groß" pageId="null" pageNumber="729">gross</normalizedToken>
, die 2 
<normalizedToken id="ECF0C16F3020273F13551D5DAB5A7CFD" originalValue="äußern" pageId="null" pageNumber="729">aeussern</normalizedToken>
bedeutend kleiner als die 3 innern. 
<normalizedToken id="5B80F15E9C8CBD6E0A137943531EC794" originalValue="Kronblätter" pageId="null" pageNumber="729">Kronblaetter</normalizedToken>
<normalizedToken id="7C3A90BFFB0CB5265D3ED621A553390A" originalValue="kürzer" pageId="null" pageNumber="729">kuerzer</normalizedToken>
als 1,5 cm, gelb. 
<emphasis id="1775743E6600EE29DB35C29C146E917D" italics="true" pageId="null" pageNumber="729">
<normalizedToken id="4D8BC27F6B0984854C56CB9EA4BCC817" originalValue="Äußere" pageId="null" pageNumber="729">Aeussere</normalizedToken>
<normalizedToken id="119954D5B4AAE71CAB81EBBFD1590D59" originalValue="Staubblätter" pageId="null" pageNumber="729">Staubblaetter</normalizedToken>
ohne Staubbeutel.
</emphasis>
Fruchtknoten aus 3 
<normalizedToken id="3CE502E21D531456C2460818A4E977AF" originalValue="Fruchtblättern" pageId="null" pageNumber="729">Fruchtblaettern</normalizedToken>
, 3 
<normalizedToken id="54E61DAFF0C7776BB7632744E0AEC9F7" originalValue="fächerig" pageId="null" pageNumber="729">faecherig</normalizedToken>
. Narbe 3teilig, auf einem Griffel. Frucht nach unten gebogen.
</paragraph>
<paragraph id="B10291350631FCEEA54B259105C363B2" pageId="null" pageNumber="729">
Die Gattung 
<emphasis id="68865D64AA4359977DCC479FF5BAD314" italics="true" pageId="null" pageNumber="729">
<taxonomicName id="54665A1A062E2A7A570D32EFA8CDB11A" class="Magnoliopsida" family="Cistaceae" genus="Fumana" kingdom="Plantae" order="Malvales" pageId="null" pageNumber="729" phylum="Tracheophyta" rank="genus">Fumana</taxonomicName>
<normalizedToken id="7BC483A6CD648A18BD878230295A6866" originalValue="umfaßt" pageId="null" pageNumber="729">umfasst</normalizedToken>
10 Arten und hat fast 
<normalizedToken id="75645FAF8163F202CDA961379D7D4787" originalValue="ausschließlich" pageId="null" pageNumber="729">ausschliesslich</normalizedToken>
mediterrane Verbreitung. Chromosomengrundzahl
</emphasis>
n = 16.
</paragraph>
<paragraph id="A36864BA87FEC502A7405AFBA8D8C7E6" pageId="null" pageNumber="729">
<table id="B219B091A5DEA9EF43EFC9FFD9F0428C" frame="void" pageId="null" pageNumber="729" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="6D8AC44D2C3FF3B0D9352A0427AD6464" pageId="null" pageNumber="729">
<tr id="D5586EC94E12AF13B5D5DFF3BCE893C5" pageId="null" pageNumber="729">
<td id="50DC88B59E10936BF9A7EB4871082157" align="left" pageId="null" pageNumber="729" valign="top">
1. 
<normalizedToken id="098CA79CAC68FF359E1D5A8656268EA8" originalValue="Blütenstiele" pageId="null" pageNumber="729">Bluetenstiele</normalizedToken>
so lang oder 
<normalizedToken id="BC63778E180B5E1C04FD4A64B6326CFA" originalValue="kürzer" pageId="null" pageNumber="729">kuerzer</normalizedToken>
als die 
<normalizedToken id="C68BFD3D2CD5D229AA2FADCAB2125726" originalValue="nächststehenden" pageId="null" pageNumber="729">naechststehenden</normalizedToken>
<normalizedToken id="CCA59CC254FCBDFEA4901AD776BE51A4" originalValue="Blätter" pageId="null" pageNumber="729">Blaetter</normalizedToken>
; oberer Teil der Zweige, 
<normalizedToken id="1F6263623993DA5D59275F66A5BC6C03" originalValue="Blätter" pageId="null" pageNumber="729">Blaetter</normalizedToken>
, 
<normalizedToken id="EB52BCF26B05D558233CADEF1F99D76D" originalValue="Blütenstiele" pageId="null" pageNumber="729">Bluetenstiele</normalizedToken>
und 
<normalizedToken id="55136FC4CFE115F9BB1AC9AED82FC5FE" originalValue="Kelchblätter" pageId="null" pageNumber="729">Kelchblaetter</normalizedToken>
mit nach 
<normalizedToken id="DE54743FE5482336D496B757BDE04F10" originalValue="rückwärts" pageId="null" pageNumber="729">rueckwaerts</normalizedToken>
gerichteten, 
<normalizedToken id="D343FF7A11E0597BC5881DE9061444B6" originalValue="weißen" pageId="null" pageNumber="729">weissen</normalizedToken>
, 0,3-0,4 mm langen, mehrzelligen Haaren (10fache 
<normalizedToken id="0B61E283E92B0E2A03E0B14862975F14" originalValue="Vergrößerung" pageId="null" pageNumber="729">Vergroesserung</normalizedToken>
!); 
<normalizedToken id="FBE0323C4282FCD6F209B6B4BCB36251" originalValue="Kelchblätter" pageId="null" pageNumber="729">Kelchblaetter</normalizedToken>
nur mit vereinrelten 0,4-0,8 mm langen Borstenhaaren
</td>
<td id="F4F405DD7435DE10BFADF15C1427EC3B" align="left" pageId="null" pageNumber="729" valign="bottom">
<taxonomicName id="66BEFC8ED887541B1C2A0B86093D66F1" class="Magnoliopsida" family="Cistaceae" genus="Fumana" kingdom="Plantae" order="Malvales" pageId="null" pageNumber="729" phylum="Tracheophyta" rank="species" species="procumbens">
<italic id="35C624B1FF75EDD41737DF106ABD362B" pageId="null" pageNumber="729">F. procumbens</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="7A20D1C69597DCA0D383D65FD97094E1" pageId="null" pageNumber="729">
<td id="7FB2E80115821E3D9E6DFCDB3473C16E" align="left" pageId="null" pageNumber="729" valign="top">
1*. 
<normalizedToken id="813C26FFCE6C47B096F83C9B0A8F068D" originalValue="Blütenstiele" pageId="null" pageNumber="729">Bluetenstiele</normalizedToken>
<normalizedToken id="63120732A811D2C14DB3B4F1BE52E7A1" originalValue="länger" pageId="null" pageNumber="729">laenger</normalizedToken>
als die 
<normalizedToken id="A5AECFEB510CCBBAAE360BDF63AB3740" originalValue="nächststehenden" pageId="null" pageNumber="729">naechststehenden</normalizedToken>
<normalizedToken id="E38BA62A321C015412581AAE9F2926F4" originalValue="Blätter" pageId="null" pageNumber="729">Blaetter</normalizedToken>
; ganze Pflanze ohne mehrzellige Haare; 
<normalizedToken id="70E47687961E650996615C37F8426F9D" originalValue="Kelchblätter" pageId="null" pageNumber="729">Kelchblaetter</normalizedToken>
auf den Nerven und am Rande mit zahlreichen 0,4-0,8 mm langen einzelligen Borstenhaaren
</td>
<td id="1F55C6E2F39D1E40A4BB1198212F89EC" align="left" pageId="null" pageNumber="729" valign="bottom">
<taxonomicName id="BA78AEBB2A4FEEFB36F82851B0368EE5" class="Magnoliopsida" family="Cistaceae" genus="Fumana" kingdom="Plantae" order="Malvales" pageId="null" pageNumber="729" phylum="Tracheophyta" rank="species" species="ericoides">
<italic id="8DEF6F4DD3DEED03792A8B17A78AC064" pageId="null" pageNumber="729">F. ericoides</italic>
</taxonomicName>
(Nr. 2)
</td>
</tr>
</tbody>
</table>
</paragraph>
