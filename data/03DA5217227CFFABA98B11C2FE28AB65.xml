(figs 19–20) and 
<taxonomicName id="4C739882227CFFA9AB4F1686FD7DAD3E" baseAuthorityName="Meigen" baseAuthorityYear="1822" box="[618,743,1789,1810]" class="Insecta" family="Syrphidae" genus="Epistrophe" kingdom="Animalia" order="Diptera" pageId="5" pageNumber="246" phylum="Arthropoda" rank="species" species="nitidicollis">
