<taxonomicName box="[1351,1451,1191,1213]" class="Agaricomycetes" family="Hydnodontaceae" genus="Scytinopogon" kingdom="Fungi" order="Trechisporales" pageId="8" pageNumber="81" phylum="Basidiomycota" rank="species" species="foetidus">
