<taxonomicName box="[1345,1451,1134,1155]" class="Agaricomycetes" family="Hydnodontaceae" genus="Scytinopogon" kingdom="Fungi" order="Trechisporales" pageId="8" pageNumber="81" phylum="Basidiomycota" rank="species" species="robustus">
