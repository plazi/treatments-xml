<taxonomicName LSID="7DC48987-37F5-5925-BBAE-E18188748640" authority="Rambur, 1838" authorityName="Deranja &amp; Kasalo &amp; Adžić &amp; Franjević &amp; Skejo" authorityYear="2022" class="Insecta" family="Tetrigidae" genus="Valalyllum" higherTaxonomySource="treatment-meta" kingdom="Animalia" lsidName="" order="Orthoptera" pageId="0" pageNumber="1" rank="family">Tetrigidae Rambur, 1838</taxonomicName>
