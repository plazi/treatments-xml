<paragraph blockId="6.[278,630,1172,1231]" box="[399,508,1204,1231]" pageId="6" pageNumber="203">
(
<figureCitation box="[408,471,1204,1230]" captionStart="FIG" captionStartId="7.[132,143,1986,2003]" captionTargetBox="[131,1454,215,1878]" captionTargetId="figure-15@7.[131,1454,215,1878]" captionTargetPageId="7" captionText="FIG. 3. — Asperula fidanii Eroğlu, sp. nov.: A, habit; B, inflorescence and flowers; C, fruit and ovaries; D, basal leaves; E, middle and upper leaves; F, 4- and 5-lobed flowers on same plant." figureDoi="http://doi.org/10.5281/zenodo.6817836" httpUri="https://zenodo.org/record/6817836/files/figure.png" pageId="6" pageNumber="203">Figs 3</figureCitation>
; 
<figureCitation box="[485,499,1204,1230]" captionStart="FIG" captionStartId="8.[132,143,1493,1510]" captionTargetBox="[132,1455,215,1452]" captionTargetId="figure-254@8.[132,1455,215,1452]" captionTargetPageId="8" captionText="FIG. 4. — Flowers of Asperula fidanii Eroğlu,sp.nov.; A, B, general wiew;A, 5-lobed flower;B, 4-lobed flower;C, D, dissected flowers;E, ovarium.Scale bars:1 mm." figureDoi="http://doi.org/10.5281/zenodo.6817838" httpUri="https://zenodo.org/record/6817838/files/figure.png" pageId="6" pageNumber="203">4</figureCitation>
