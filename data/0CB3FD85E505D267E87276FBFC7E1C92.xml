<taxonomicName id="FE63A3A84D8170AC90DAB9D8ED1CC9A1" class="Magnoliopsida" family="Resedaceae" genus="Reseda" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="249" phylum="Tracheophyta" rank="genus">Reseda</taxonomicName>
