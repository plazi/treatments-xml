<subSubSection id="2950409F179110478A38F033CB98DB46" pageId="null" pageNumber="669" type="vernacular_names">
<paragraph id="7CDA5614E8A774BFAEFD7AFD1A22FDF2" pageId="null" pageNumber="669">Sichel-Wolfsmilch</paragraph>
</subSubSection>
</title>
<subSubSection id="DC7B95383BB3ACC1EF4215E92F76BC91" pageId="null" pageNumber="669" type="description">
<paragraph id="0EEFB70BEF7FB5FFC831DF3F0941DBC5" pageId="null" pageNumber="669">
1 
<normalizedToken id="AB3C3BA4B5659324950D3DD0DF5EC919" originalValue="jährig" pageId="null" pageNumber="669">jaehrig</normalizedToken>
, mit einfacher Pfahlwurzel, kahl. Habitus wie 
<taxonomicName id="2C717E42628F4FEEC8F500C3505F2A6B" class="Magnoliopsida" family="Euphorbiaceae" genus="Euphorbia" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="669" phylum="Tracheophyta" rank="species" species="exigua">
<emphasis id="0A2D4AB95897A76F58A1D0F51CE60A53" italics="true" pageId="null" pageNumber="669">E. exigua</emphasis>
</taxonomicName>
(Nr. 18). 
<normalizedToken id="9226CE1AD6AF7E2A68E949D7DCB2FC5A" originalValue="Stengelblätter" pageId="null" pageNumber="669">Stengelblaetter</normalizedToken>
<normalizedToken id="DA1156BA31EF260C66160E15D9625C17" originalValue="wechselständig" pageId="null" pageNumber="669">wechselstaendig</normalizedToken>
, stets vorzeitig abfallend, meist 
<normalizedToken id="E494F9FA88576E605F58B28BE4685A80" originalValue="spatelförmig" pageId="null" pageNumber="669">spatelfoermig</normalizedToken>
(selten die obersten lanzettlich), 0,5-2 cm lang, 2-4mal so lang wie breit, an der Spitze oft ausgerandet, ganzrandig, 
<emphasis id="FF39E0787FA5D63FE0D868448EA9E4FE" italics="true" pageId="null" pageNumber="669">sitzend;</emphasis>
<normalizedToken id="7279AB800625D4278E3DE488A1B79225" originalValue="Nebenblätter" pageId="null" pageNumber="669">Nebenblaetter</normalizedToken>
keine. 
<normalizedToken id="D85A20E4D8F209A76EA7243E1BB5A808" originalValue="Tragblätter" pageId="null" pageNumber="669">Tragblaetter</normalizedToken>
bei den 
<normalizedToken id="D13F0CA5C878665F32744E1638450096" originalValue="Einzelblütenständen" pageId="null" pageNumber="669">Einzelbluetenstaenden</normalizedToken>
nicht verwachsen, im 
<normalizedToken id="59D911FD5112B1BABA46255742140883" originalValue="Umriß" pageId="null" pageNumber="669">Umriss</normalizedToken>
fast 3eckig, etwa so lang wie breit, am Grunde breit abgerundet, steil in die durch den Mittelnerv gebildete, 0,5-1 mm 
<pageBreakToken id="B863F7C0231DAF14CE2A353901E4558D" pageId="null" pageNumber="669">lang</pageBreakToken>
ausgezogene Spitze 
<normalizedToken id="D28CD627A2DF144C42DD1B15A12A593A" originalValue="verschmälert" pageId="null" pageNumber="669">verschmaelert</normalizedToken>
. 
<normalizedToken id="C0C96E6D3E12D6E0C2781BFEBF9D855C" originalValue="Drüsen" pageId="null" pageNumber="669">Druesen</normalizedToken>
am 
<normalizedToken id="9EE8DEE3B1FBE8140D1780654C4CCFE5" originalValue="Hüllbecher" pageId="null" pageNumber="669">Huellbecher</normalizedToken>
gelb, mit 2 
<normalizedToken id="ED11D856025854D5CD3706E86C18E3E9" originalValue="weißen" pageId="null" pageNumber="669">weissen</normalizedToken>
, 
<normalizedToken id="4FAE73EDEE90E2390AE71D7C58AD75DB" originalValue="fadenförmigen" pageId="null" pageNumber="669">fadenfoermigen</normalizedToken>
<normalizedToken id="1FD0CAE427E3ABEDE003767CAC4F2158" originalValue="Anhängseln" pageId="null" pageNumber="669">Anhaengseln</normalizedToken>
. Frucht 2-2,5 mm lang, glatt. Samen 1,5-1,8 mm lang, 0,8-1,1 mm dick, 
<emphasis id="09057BBD68A3FDDF4F0FFD58001CEF0D" italics="true" pageId="null" pageNumber="669">
4kantig, auf allen 4 
<normalizedToken id="E4CB5AD2D1919EF9057A24F51B982192" originalValue="Flächen" pageId="null" pageNumber="669">Flaechen</normalizedToken>
mit 4-7 Querfurchen
</emphasis>
, grau oder rotbraun. - 
<normalizedToken id="1F06A6699FFE06BF614F07E8359D3044" originalValue="Blüte" pageId="null" pageNumber="669">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="322038A36442841B49A7D923F00AE77A" pageId="null" pageNumber="669">
<emphasis id="34C45BF35DAB2FBA4853B1D1C8CE7D9C" italics="true" pageId="null" pageNumber="669">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="065E18FD85FAA0B7DAA6DF5CB4270CF4" italics="true" pageId="null" pageNumber="669">16:</emphasis>
Material aus Ungarn (
<normalizedToken id="62C00EF42402BE781E4972E475274A4F" originalValue="Pólya" pageId="null" pageNumber="669">Polya</normalizedToken>
1958). 
<emphasis id="089F29EB721AB6FCD67AF9A812EB80AE" italics="true" pageId="null" pageNumber="669">2n</emphasis>
= 
<emphasis id="29D5D4AB025015064535F4287A09D2B9" italics="true" pageId="null" pageNumber="669">36:</emphasis>
Material aus Italien, normal sexuell (
<normalizedToken id="8F8595FC0FB22DDA7B15D7FAF32182A3" originalValue="D’Amato" pageId="null" pageNumber="669">D'Amato</normalizedToken>
1939).
</paragraph>
<paragraph id="37996375D90AA2788FF5269798A189A8" pageId="null" pageNumber="669">
<emphasis id="B438564B76DF7C90AD9B69A25F151870" italics="true" pageId="null" pageNumber="669">Standort.</emphasis>
Kollin. Kalkhaltige, 
<normalizedToken id="412DD8A55BA08395F4FAB37194A5B1E9" originalValue="nährstoffreiche" pageId="null" pageNumber="669">naehrstoffreiche</normalizedToken>
, lehmige 
<normalizedToken id="5653D46ED245C2B20DD098D0F5957266" originalValue="Böden" pageId="null" pageNumber="669">Boeden</normalizedToken>
. Unkrautgesellschaften in 
<normalizedToken id="7989E6BF5CD5DC7E9FB1774194DFBD1F" originalValue="Äckern" pageId="null" pageNumber="669">Aeckern</normalizedToken>
und auf 
<normalizedToken id="35C41D3FC991B5B70AC0414BE14AFA5D" originalValue="Schuttplätzen" pageId="null" pageNumber="669">Schuttplaetzen</normalizedToken>
.
</paragraph>
<paragraph id="68334D1E32B8346075A8F87C008D48DC" pageId="null" pageNumber="669">
<emphasis id="87A0A593E2214D0AAD9A734293600551" italics="true" pageId="null" pageNumber="669">Verbreitung.</emphasis>
<normalizedToken id="256FB9F43F2A5C27645E0AC3B695D2FC" originalValue="Ursprünglich" pageId="null" pageNumber="669">Urspruenglich</normalizedToken>
<emphasis id="AAF0E1D182ADD5A30FBC5344BE8860C1" italics="true" pageId="null" pageNumber="669">mediterran-westasiatische Pflanze;</emphasis>
heute weithin verschleppt. - Im Gebiet im Nordosten nicht vorhanden, sonst ziemlich verbreitet; selten.
</paragraph>
</subSubSection>
