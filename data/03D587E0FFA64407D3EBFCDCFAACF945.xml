<heading id="D08B819AFFA64407D3EBFCDCFCCBFCCC" bold="true" box="[151,791,813,840]" fontSize="11" level="1" pageId="4" pageNumber="83" reason="1">
<emphasis id="B908EAE4FFA64407D3EBFCDCFCCBFCCC" bold="true" box="[151,791,813,840]" pageId="4" pageNumber="83">
<taxonomicName id="4C7C4D75FFA64407D3EBFCDCFE83FCCC" authorityName="Breuning" authorityYear="1970" box="[151,351,813,840]" class="Insecta" family="Cerambycidae" genus="Mimonephelotes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="83" phylum="Arthropoda" rank="genus">
<emphasis id="B908EAE4FFA64407D3EBFCDCFE83FCCC" bold="true" box="[151,351,813,840]" italics="true" pageId="4" pageNumber="83">Mimonephelotes</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C7C4D75FFA64407D2E2FCDCFD82FCCC" baseAuthorityName="Breuning" baseAuthorityYear="1971" box="[414,606,813,840]" class="Insecta" family="Cerambycidae" genus="Mimanhammus" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="83" phylum="Arthropoda" rank="genus">
<emphasis id="B908EAE4FFA64407D2E2FCDCFD82FCCC" bold="true" box="[414,606,813,840]" italics="true" pageId="4" pageNumber="83">Mimanhammus</emphasis>
</taxonomicName>
vs. 
<taxonomicName id="4C7C4D75FFA64407D1F2FCDCFCCBFCCC" authorityName=", Pascoe" authorityYear="1866" box="[654,791,813,840]" class="Insecta" family="Cerambycidae" genus="Nephelotus" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="83" phylum="Arthropoda" rank="genus">
<emphasis id="B908EAE4FFA64407D1F2FCDCFCCBFCCC" bold="true" box="[654,791,813,840]" italics="true" pageId="4" pageNumber="83">Nephelotus</emphasis>
</taxonomicName>
</emphasis>
</heading>
</paragraph>
