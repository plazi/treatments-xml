<typeStatus box="[151,201,1036,1057]" pageId="4" pageNumber="305">Type</typeStatus>
species: 
<taxonomicName authority="Liu, 2004" authorityName="Liu" authorityYear="2004" box="[294,741,1035,1057]" class="Insecta" family="Tettigoniidae" genus="Xizicus" kingdom="Animalia" order="Orthoptera" pageId="4" pageNumber="305" phylum="Arthropoda" rank="species" species="anisocercus" subGenus="Paraxizicus">
