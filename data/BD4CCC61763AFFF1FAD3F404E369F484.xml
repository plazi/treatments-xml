<taxonomicName id="F2E506F4763AFFF2FBD5F28EE33EF265" baseAuthorityName="G. Cuvier" baseAuthorityYear="1829" box="[1151,1334,3440,3465]" class="Dothideomycetes" family="Mycosphaerellaceae" genus="Stenella" kingdom="Fungi" order="Capnodiales" pageId="21" pageNumber="520" phylum="Ascomycota" rank="species" species="frontalis">Stenella frontalis</taxonomicName>
