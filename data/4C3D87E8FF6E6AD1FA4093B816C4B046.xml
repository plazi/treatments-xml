<quantity id="036C9B1BFF6E6AD1F6769C4E1434B10A" box="[2442,2612,2583,2616]" metricMagnitude="2" metricUnit="m" metricValue="9.9" metricValueMax="12.0" metricValueMin="7.8" pageId="149" pageNumber="910" unit="m" value="990.0" valueMax="1200.0" valueMin="780.0">780-1200 m</quantity>
.
</paragraph>
</subSubSection>
