<subSubSection box="[179,1283,2143,2176]" pageId="106" pageNumber="734" type="activity">
<paragraph blockId="106.[179,1389,1356,2768]" box="[179,1283,2143,2176]" pageId="106" pageNumber="734">
<emphasis bold="true" box="[179,414,2143,2176]" pageId="106" pageNumber="734">Activity patterns.</emphasis>
