<taxonomicName box="[1056,1170,449,482]" class="Mammalia" family="Cercopithecidae" genus="Colobus" kingdom="Animalia" order="Primates" pageId="82" pageNumber="710" phylum="Chordata" rank="genus">Colobus</taxonomicName>
