<taxonomicName authorityName="Colyn" authorityYear="1991" box="[383,655,3414,3435]" class="Mammalia" family="Cercopithecidae" genus="Piliocolobus" kingdom="Animalia" order="Primates" pageId="77" pageNumber="709" phylum="Chordata" rank="species" species="semlikiensis">Piliocolobus semlikiensis</taxonomicName>
); 98. Foa’'s Red 
