<paragraph id="915436DFFFA1BA0DB488F345B1EDFB88" blockId="29.[150,1361,272,1453]" box="[154,971,1061,1094]" pageId="29" pageNumber="648">
<emphasis id="A39FEACDFFA1BA0DB488F345B3A3FB88" bold="true" box="[154,389,1061,1094]" pageId="29" pageNumber="648">Activity patterns.</emphasis>
<collectingCountry id="E9FC764FFFA1BA0DB580F345B03AFB88" box="[402,540,1061,1094]" name="Sao Tome and Principe" pageId="29" pageNumber="648">Sao Tome</collectingCountry>
