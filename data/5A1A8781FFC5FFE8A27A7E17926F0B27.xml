CRANCHIOIDEA 
<bibRefCitation id="B6224B66FFC5FFE9A5C37E17950A0F17" author="Prosch V" box="[1226,1386,1357,1382]" pageId="12" pageNumber="1224" pagination="53 - 72" refId="ref16412" refString="Prosch V. 1847. Nogle nye cephalopoder, beskrevne og anatomisk undersogte. Kongelige Danske Videnskabernes Selskabs Skrifter, Naturvidenskabelig og Mathematisk 1: 53 - 72." type="journal article" year="1847">PROSCH, 1847</bibRefCitation>
