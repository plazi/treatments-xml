<subSubSection id="AD22FE3D8646B2D05D6823A960451E81" pageId="null" pageNumber="87" type="description">
<paragraph id="3596472A39817B891C337147C9F27548" pageId="null" pageNumber="87">
<emphasis id="7467AA8BC6153BFB540259207732F746" italics="true" pageId="null" pageNumber="87">Ausdauernd; bis 5 cm hoch</emphasis>
. Rhizom kurz. 
<normalizedToken id="DDA9F97725E0524BF415677140EC201A" originalValue="Grundständige" pageId="null" pageNumber="87">Grundstaendige</normalizedToken>
<normalizedToken id="A543BC2C86ADC88FAB647794B2A93F99" originalValue="Blätter" pageId="null" pageNumber="87">Blaetter</normalizedToken>
kahl, bis auf ⅓ 3teilig; seitliche Abschnitte 
<normalizedToken id="10A61D8BBABEBF48B16CDC067ECC60E1" originalValue="höchstens" pageId="null" pageNumber="87">hoechstens</normalizedToken>
bis auf 
<normalizedToken id="09ED1B2DC9744DC06781C99C8957677F" originalValue="½" pageId="null" pageNumber="87">1/2</normalizedToken>
2-3teilig; Abschnitte meist ganzrandig. 
<emphasis id="6652B6BF7D2A8ABF3917AA9DFBBF8A40" italics="true" pageId="null" pageNumber="87">
Stengel 1, aufrecht oder bogig aufsteigend, 1 
<normalizedToken id="E52B1787B0638C4BA8E514D6CDB8F374" originalValue="blütig" pageId="null" pageNumber="87">bluetig</normalizedToken>
, kurz behaart
</emphasis>
. 
<normalizedToken id="A7D3C52A69D49158A7DDBBCF100DB6C6" originalValue="Stengelblätter" pageId="null" pageNumber="87">Stengelblaetter</normalizedToken>
1-2, sitzend, bis zum Grunde 3-5teilig; Abschnitte schmal lanzettlich, ganzrandig. 
<normalizedToken id="C61F67238C0234B52A48DEC60FDE7CEB" originalValue="Blüte" pageId="null" pageNumber="87">Bluete</normalizedToken>
hellgelb, im Durchmesser 0,5-1 cm. Kelch- und 
<normalizedToken id="AE63BE7BFA6B7C836E87600A19E33DBC" originalValue="Kronblätter" pageId="null" pageNumber="87">Kronblaetter</normalizedToken>
<normalizedToken id="330EE1BA9B73D60E905AE9DD3E89219C" originalValue="ungefähr" pageId="null" pageNumber="87">ungefaehr</normalizedToken>
gleich lang. 
<emphasis id="836C1D248B9991DBD29A4305F8FF2B29" italics="true" pageId="null" pageNumber="87">
Reife 
<normalizedToken id="D0183B9E2B98403380C33B9D049A9A93" originalValue="Früchtchen" pageId="null" pageNumber="87">Fruechtchen</normalizedToken>
einen zylindrischen oder 
<normalizedToken id="071E66FA708E628E68D668DEFD21142C" originalValue="eiförmigen" pageId="null" pageNumber="87">eifoermigen</normalizedToken>
Kopf bildend
</emphasis>
(
<emphasis id="E6E840630243429BB5533CEA9FD47401" italics="true" pageId="null" pageNumber="87">
bis 50 
<normalizedToken id="A2704C30412163CC5E60E5D5A45DE08C" originalValue="Früchtchen" pageId="null" pageNumber="87">Fruechtchen</normalizedToken>
je Kopf
</emphasis>
). 
<normalizedToken id="74504E6D4287F0A48067C5742DF01ED4" originalValue="Früchtchen" pageId="null" pageNumber="87">Fruechtchen</normalizedToken>
rundlich bis undeutlich 
<normalizedToken id="C9A4BFB92F80B92FA5A441AEC63C628E" originalValue="nierenförmig" pageId="null" pageNumber="87">nierenfoermig</normalizedToken>
, 1,2-1,4 mm lang und 0,8-1 mm breit, unberandet, kahl; Schnabel gerade oder an der Spitze hakig gebogen, 0,2-0,4 mm lang. 
<normalizedToken id="20E61469370DD46077882352AD0DD50F" originalValue="Blütenboden" pageId="null" pageNumber="87">Bluetenboden</normalizedToken>
zerstreut behaart. - 
<normalizedToken id="542F2A09727CBA375BE4B7BA08AED619" originalValue="Blüte" pageId="null" pageNumber="87">Bluete</normalizedToken>
: Nach der Schneeschmelze.
</paragraph>
<paragraph id="C985D19DAF8FB8F339346FB42C6D89EB" pageId="null" pageNumber="87">
<emphasis id="EF2117451163FBBAFC89C47DBBD5A00D" italics="true" pageId="null" pageNumber="87">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="7CD39A28DE57F56482E6C1C2EA835EB9" italics="true" pageId="null" pageNumber="87">16:</emphasis>
Material aus Spitzbergen (Langlet 1932, Flovik 1936), aus Tirol (Mattick in Tischler 1950), aus Island (
<normalizedToken id="2EFA01C89E6FE6653717B1FE799FE6F1" originalValue="Löve" pageId="null" pageNumber="87">Loeve</normalizedToken>
und 
<normalizedToken id="12AA601DE2DD61010C46109D5D61558A" originalValue="Löve" pageId="null" pageNumber="87">Loeve</normalizedToken>
1956b), aus 
<normalizedToken id="05F61A1CACCA233B7CE213BC263BDDD4" originalValue="Grönland" pageId="null" pageNumber="87">Groenland</normalizedToken>
(
<normalizedToken id="C283C28B6E725A3CDC98D58062713A95" originalValue="Böcher" pageId="null" pageNumber="87">Boecher</normalizedToken>
1938b, 
<normalizedToken id="A3CC2D490F2A67149B71633F2E5ADA80" originalValue="Jörgensen" pageId="null" pageNumber="87">Joergensen</normalizedToken>
et al. 1958), aus Norwegen (Knaben und 
<normalizedToken id="5DCBE361300289130F59BF0A127FFD6B" originalValue="Engelskjön" pageId="null" pageNumber="87">Engelskjoen</normalizedToken>
1967), aus Polen (Skalinska et al. 1969), von der Halbinsel Kola (Sokolovskaya und Strelkova 1960), aus Kanada (64° NB) (Hedberg 1967), aus Alaska (Johnson und Packer 1968).
</paragraph>
<paragraph id="03E10A922BF6662AF8982E53204B8FE3" pageId="null" pageNumber="87">
<emphasis id="1336C536F3ED45FB3D1106ABF721F2E5" italics="true" pageId="null" pageNumber="87">Standort</emphasis>
. Alpin. In den Alpen nur auf kalkfreiem, 
<normalizedToken id="AEF1098FF409F8A2454187E9FCE505CD" originalValue="ständig" pageId="null" pageNumber="87">staendig</normalizedToken>
durchfeuchtetem, humusreichem Boden, in flachen oder schwach geneigten Mulden, 
<normalizedToken id="DFFBF200A4EDCE49FD5939319E6CB8DE" originalValue="höchstens" pageId="null" pageNumber="87">hoechstens</normalizedToken>
2 Monate schneefrei (
<normalizedToken id="752991B14909B91BBBEEAC99DD4A26DF" originalValue="Schneetälchen" pageId="null" pageNumber="87">Schneetaelchen</normalizedToken>
). 
<emphasis id="140B6B9F9B17AF2837168380C9FFB4AD" italics="true" pageId="null" pageNumber="87">Polytrichetum sexangularis</emphasis>
Br.-Bl. 1926.
</paragraph>
<paragraph id="25B5C423E049A6453FEF0BC3CA7AFDCE" pageId="null" pageNumber="87">
<emphasis id="8E3B275AE5E7100C33E7D466B6636560" italics="true" pageId="null" pageNumber="87">Verbreitung. Arktisch-alpine Pflanze:</emphasis>
Arktisches Europa, Island; zahlreiche Fundstellen in den Ostalpen (zwischen Unterengadin und Hohen Tauern und Lienz) und Karpaten; arktisches Sibirien, Himalaja; in Amerika 
<normalizedToken id="88C6A918EF499073F2462660E3BDFAE2" originalValue="südwärts" pageId="null" pageNumber="87">suedwaerts</normalizedToken>
bis Wyoming und 
<normalizedToken id="956395387E70C5ABABC7649B37BA02C4" originalValue="nördliche" pageId="null" pageNumber="87">noerdliche</normalizedToken>
Hudsonbay; 
<normalizedToken id="210881762EC35C3A1149F46930DFDAB9" originalValue="Grönland" pageId="null" pageNumber="87">Groenland</normalizedToken>
. - Im Gebiet: Westlichste Fundstellen in den Alpen: 
<normalizedToken id="7369F43B8E8C567F3DE575DEA8CA2229" originalValue="Graubünden" pageId="null" pageNumber="87">Graubuenden</normalizedToken>
(2 benachbarte Fundorte an den Macunseen und unterhalb des Lai 
<normalizedToken id="798E1DE50151631437EEC1EFBD420752" originalValue="d’Arpiglias" pageId="null" pageNumber="87">d'Arpiglias</normalizedToken>
im Val Zeznina, Unterengadin), Spronsertal und Pfossental nordwestlich Meran; 
<normalizedToken id="374F748B3A2D59C20BAB5A3AE95659EA" originalValue="nächst" pageId="null" pageNumber="87">naechst</normalizedToken>
des Gebiets im 
<normalizedToken id="052E5C47CAA57AFA51D0B4CFD8C18C55" originalValue="Ötztal" pageId="null" pageNumber="87">Oetztal</normalizedToken>
(Gurglgletscher).
</paragraph>
</subSubSection>
