<subSubSection id="6FEA27AD01C79358E9B1CD37AF3F9A92" pageId="null" pageNumber="163" type="description">
<paragraph id="3B4127FC3DCE04A571C518330B29F3BF" pageId="null" pageNumber="163">
3-10 cm hoch. 
<emphasis id="866C642445675C4470F0EF9EAB185D70" italics="true" pageId="null" pageNumber="163">Stengel mit sehr zahlreichen, vielstrahligen Sternhaaren.</emphasis>
<normalizedToken id="8ECA38725BDEDE91CFEF0BF35AAFF42E" originalValue="Grundständige" pageId="null" pageNumber="163">Grundstaendige</normalizedToken>
<normalizedToken id="D871406FF45CD6BB84145A9E68880D78" originalValue="Blätter" pageId="null" pageNumber="163">Blaetter</normalizedToken>
oval, 
<normalizedToken id="709D63DE0612FFCE54FB31B107688E2C" originalValue="1½" pageId="null" pageNumber="163">11/2</normalizedToken>
-3mal so lang wie breit, mit zahlreichen Sternhaaren und nur einzelnen 1fachen Haaren am Rande. 
<normalizedToken id="992CFAE5547B0D6D74EE39C8706AF54A" originalValue="Stengelblätter" pageId="null" pageNumber="163">Stengelblaetter</normalizedToken>
fast gleich 
<normalizedToken id="9C1F8EFF1DA877A36F710BE01D9DC3A8" originalValue="groß" pageId="null" pageNumber="163">gross</normalizedToken>
wie die 
<normalizedToken id="B945109A25D5E98D18BDB7280E0AA966" originalValue="grundständigen" pageId="null" pageNumber="163">grundstaendigen</normalizedToken>
, gelegentlich mit 1-5 
<normalizedToken id="7B76B38904BA36BDF84C210685256A32" originalValue="Zähnen" pageId="null" pageNumber="163">Zaehnen</normalizedToken>
. 
<normalizedToken id="461006A3EE5B87991FA377E12114B9B8" originalValue="Kelchblätter" pageId="null" pageNumber="163">Kelchblaetter</normalizedToken>
2-2,5 mm lang, mit einzelnen 1fachen oder 
<normalizedToken id="969D453BEE4881177DF3BF58745F69C4" originalValue="sternförmigen" pageId="null" pageNumber="163">sternfoermigen</normalizedToken>
Haaren. 
<normalizedToken id="49C05344B192889F885FD30488DB23ED" originalValue="Kronblätter" pageId="null" pageNumber="163">Kronblaetter</normalizedToken>
3,5-5,5 mm lang. 
<normalizedToken id="2DEF4F5A88DDE8E47DE41AF7D2FF90DD" originalValue="Früchte" pageId="null" pageNumber="163">Fruechte</normalizedToken>
auf 3-10 mm langen, mit Sternhaaren besetzten Stielen, die 
<normalizedToken id="518227F94160890FA533937A25E93F87" originalValue="länger" pageId="null" pageNumber="163">laenger</normalizedToken>
sind als der Abstand zum 
<normalizedToken id="C51D2B96D0BC1B81A213B7D529B0D6D6" originalValue="nächst" pageId="null" pageNumber="163">naechst</normalizedToken>
<normalizedToken id="FE931D7194E7260A66F95619AEEF1CB9" originalValue="höheren" pageId="null" pageNumber="163">hoeheren</normalizedToken>
Fruchtstiel, 6-10 mm lang, 2-3 
<normalizedToken id="A3A3F34C16AD096457015037FB852581" originalValue="½" pageId="null" pageNumber="163">1/2</normalizedToken>
mal so lang wie breit, 
<emphasis id="474F025FD2773A38E376D4DCD6038F05" italics="true" pageId="null" pageNumber="163">an den Enden gerundet, mit einzelnen kurzen, 1fachen Haaren.</emphasis>
Samen 1-1,6 mm lang, 10-16 je Fach. - 
<normalizedToken id="8FA50C31885732194F84A8E1A6460304" originalValue="Blüte" pageId="null" pageNumber="163">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="4D284E38F9953B234BDBB0417B305CA0" pageId="null" pageNumber="163">
<emphasis id="484B715DC7301D3ACB4203E62689B507" italics="true" pageId="null" pageNumber="163">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="EC9AF8D05A15E012C87A87C6E9624B97" italics="true" pageId="null" pageNumber="163">16:</emphasis>
Material von verschiedenen Stellen in den Alpen (Mattick in Tischler 1950, 
<normalizedToken id="848B99BE5B004971B4E123165CA7B613" originalValue="Merxmüller" pageId="null" pageNumber="163">Merxmueller</normalizedToken>
und Buttler 1964, Favarger 1965, Buttler 1967).
</paragraph>
<paragraph id="6C11B7DF45467B6CEEB472905A9C05B8" pageId="null" pageNumber="163">
<emphasis id="7B691CEC0CFB1A79ECED0B18AF7D9645" italics="true" pageId="null" pageNumber="163">Standort.</emphasis>
Alpin (bis weit 
<normalizedToken id="EEC1E369A636AF9FC611293240860C46" originalValue="über" pageId="null" pageNumber="163">ueber</normalizedToken>
3000 m). Ritzen und Spalten von Kalk- und Dolomitfelsen, seltener in feinem Kalkschutt. 
<emphasis id="3AA8776478698F27566FF8212A07A03B" italics="true" pageId="null" pageNumber="163">Androsacetum helveticae</emphasis>
Br.-Bl. 1918.
</paragraph>
<paragraph id="907282056E056887919B71970E573465" pageId="null" pageNumber="163">
<emphasis id="50F38F1F5DEAC8767A3A355370CCDB4B" italics="true" pageId="null" pageNumber="163">
Verbreitung. Mittel- und 
<normalizedToken id="4F453E0F0153425DD25A9E1681036555" originalValue="südeuropäische" pageId="null" pageNumber="163">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="9079D99E8647AA95D5EBC7C22C2043FA" italics="true" pageId="null" pageNumber="163">
<normalizedToken id="286744BC13BAC727381930A2A2CE916C" originalValue="östlich" pageId="null" pageNumber="163">oestlich</normalizedToken>
</emphasis>
): Alpen (
<normalizedToken id="EEFC444341DD20FC2B9E1E14C43653B9" originalValue="westwärts" pageId="null" pageNumber="163">westwaerts</normalizedToken>
bis Alpes 
<normalizedToken id="0CBA500E9E602BB1754BF325072322D1" originalValue="d’Annecy" pageId="null" pageNumber="163">d'Annecy</normalizedToken>
), Abruzzen, Nordkarpaten, Rilagebirge. Verbreitungskarte in den Alpen von Greuter in Hegi IV/1 (1963) und Buttler (1967). - Im Gebiet: Alpen (in den 
<normalizedToken id="C8514022D192CE82675535D18C0C30E5" originalValue="Südalpen" pageId="null" pageNumber="163">Suedalpen</normalizedToken>
nur selten im Puschlav, die Angabe vom Monte Generoso bezieht sich nach Buttler 1967 auf 
<taxonomicName id="92735CB0DEA075012B3315FBFBCC5506" class="Magnoliopsida" family="Brassicaceae" genus="Draba" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="163" phylum="Tracheophyta" rank="species" species="dubia">
<emphasis id="085C922B466E327DEF15E74EB827200D" italics="true" pageId="null" pageNumber="163">D. dubia</emphasis>
</taxonomicName>
); ziemlich verbreitet, nicht 
<normalizedToken id="88ACCCB989C12F5C633A2593AC793425" originalValue="häufig" pageId="null" pageNumber="163">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
