<subSubSection id="C30165293300FFC3249188D8FE9EFE57" lastPageId="4" lastPageNumber="446" pageId="3" pageNumber="445" type="diagnosis">
<paragraph id="8BA436A23300FFC3249188D8FE9EFE57" blockId="3.[151,1437,1513,2008]" lastBlockId="4.[151,1437,151,1689]" lastPageId="4" lastPageNumber="446" pageId="3" pageNumber="445">
<emphasis id="B96FEAB03300FFC4249188D8FED0F985" bold="true" box="[151,274,1513,1539]" pageId="3" pageNumber="445">Diagnosis.</emphasis>
Species of the new genus (
<figureCitation id="13202A273300FFC4264E88D8FD6FF985" box="[584,685,1513,1539]" captionStart="FIGURES 1–8" captionStartId="7.[151,264,1944,1968]" captionTargetBox="[198,1393,183,1891]" captionTargetId="figure-26@7.[151,1435,181,1920]" captionTargetPageId="7" captionText="FIGURES 1–8. Marcinistra gen. n. and Baimistra gen. n. spp.: adults. Depositories of the specimens: 1 and 2 in HNHM; 3–6 in AFM; 7 and 8 in ZSM." figureDoi="http://doi.org/10.5281/zenodo.6593182" httpUri="https://zenodo.org/record/6593182/files/figure.png" pageId="3" pageNumber="445">Figs 1–4</figureCitation>
) are reminiscent of 
<taxonomicName id="4C1B4D213300FFC4279488DBFC36F982" authorityName="Hubner" authorityYear="1821" box="[914,1012,1514,1540]" class="Insecta" family="Noctuidae" genus="Conistra" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus">
<emphasis id="B96FEAB03300FFC4279488DBFC36F982" box="[914,1012,1514,1540]" italics="true" pageId="3" pageNumber="445">Conistra</emphasis>
</taxonomicName>
(
<figureCitation id="13202A273300FFC4200588D8FBB4F982" box="[1027,1142,1513,1540]" captionStart="FIGURES 9–16" captionStartId="8.[151,264,1944,1968]" captionTargetBox="[207,1414,182,1905]" captionTargetId="figure-18@8.[151,1435,181,1920]" captionTargetPageId="8" captionText="FIGURES 9–16. Type species of subgenera of Conistra: adults. Depositories of the specimens: 9, 10 and 16 in HNHM; 11, 12 and 15 in BBT; 13 and 14 in GGF." figureDoi="http://doi.org/10.5281/zenodo.6593186" httpUri="https://zenodo.org/record/6593186/files/figure.png" pageId="3" pageNumber="445">Figs 9–16</figureCitation>
) but separated by the less robust body with a cylindrical abdomen (it is dorso-ventrally flattened in 
<taxonomicName id="4C1B4D213300FFC427E68B3FFB80F9AE" authorityName="Hubner" authorityYear="1821" box="[992,1090,1550,1576]" class="Insecta" family="Noctuidae" genus="Conistra" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus">
<emphasis id="B96FEAB03300FFC427E68B3FFB80F9AE" box="[992,1090,1550,1576]" italics="true" pageId="3" pageNumber="445">Conistra</emphasis>
</taxonomicName>
) and the shiny, metallic green suffusion on the forewing. The male genital capsule of 
<taxonomicName id="4C1B4D213300FFC426FA8B03FC43F9CD" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[764,897,1586,1611]" class="Insecta" family="Noctuidae" genus="Marcinistra" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03300FFC426FA8B03FC43F9CD" box="[764,897,1586,1611]" italics="true" pageId="3" pageNumber="445">Marcinistra</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03300FFC427818B00FC14F9CD" bold="true" box="[903,982,1585,1611]" pageId="3" pageNumber="445">
<taxonomicNameLabel id="A25C57CB3300FFC427818B00FC14F9CD" box="[903,982,1585,1611]" pageId="3" pageNumber="445" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13202A273300FFC427E58B00FBA0F9CD" box="[995,1122,1585,1611]" captionStart="FIGURES 21–23" captionStartId="11.[151,264,1944,1968]" captionTargetBox="[168,1432,185,1903]" captionTargetId="figure-26@11.[151,1435,181,1920]" captionTargetPageId="11" captionText="FIGURES 21–23. Marcinistra gen. n. and Baimistra gen. n. spp.: male genitalia. Depositories of the specimens dissected: 21 in HNHM; 22 and 23 in AFM." figureDoi="http://doi.org/10.5281/zenodo.6593190" httpUri="https://zenodo.org/record/6593190/files/figure.png" pageId="3" pageNumber="445">Figs 21, 22</figureCitation>
) is similar to 
<taxonomicName id="4C1B4D213300FFC420FC8B03FA9EF9CA" authorityName="Hubner" authorityYear="1821" box="[1274,1372,1586,1612]" class="Insecta" family="Noctuidae" genus="Conistra" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus">
<emphasis id="B96FEAB03300FFC420FC8B03FA9EF9CA" box="[1274,1372,1586,1612]" italics="true" pageId="3" pageNumber="445">Conistra</emphasis>
</taxonomicName>
(
<figureCitation id="13202A273300FFC4216C8B00FF23F9E9" captionStart-0="FIGURES 24–26" captionStart-1="FIGURES 27–29" captionStartId-0="12.[151,264,1944,1968]" captionStartId-1="13.[151,264,1944,1968]" captionTargetBox-0="[151,1435,187,1901]" captionTargetBox-1="[155,1389,216,1902]" captionTargetId-0="figure-18@12.[151,1435,181,1920]" captionTargetId-1="figure-26@13.[151,1435,181,1920]" captionTargetPageId-0="12" captionTargetPageId-1="13" captionText-0="FIGURES 24–26. Type species of subgenera of Conistra: male genitalia. Depositories of the specimens dissected: 24 and 26 in HNHM; 25 in BBT." captionText-1="FIGURES 27–29. Type species of Conistra (Dasycampa), Suginistra and Vargalorta gen. n.: male genitalia. Depositories of the specimens dissected: 27 in BBT; 28 and 29 in HNHM." figureDoi-0="http://doi.org/10.5281/zenodo.6593192" figureDoi-1="http://doi.org/10.5281/zenodo.6593194" httpUri-0="https://zenodo.org/record/6593192/files/figure.png" httpUri-1="https://zenodo.org/record/6593194/files/figure.png" pageId="3" pageNumber="445">Figs 24–27</figureCitation>
), 
<taxonomicName id="4C1B4D213300FFC424F08B67FEA6F9E9" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[246,356,1622,1647]" class="Insecta" family="Noctuidae" genus="Baimistra" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03300FFC424F08B67FEA6F9E9" box="[246,356,1622,1647]" italics="true" pageId="3" pageNumber="445">Baimistra</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03300FFC425688B64FE7DF9E9" bold="true" box="[366,447,1621,1647]" pageId="3" pageNumber="445">
<taxonomicNameLabel id="A25C57CB3300FFC425688B64FE7DF9E9" box="[366,447,1621,1647]" pageId="3" pageNumber="445" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13202A273300FFC425C98B64FDE7F9E9" box="[463,549,1621,1647]" captionStart="FIGURES 21–23" captionStartId="11.[151,264,1944,1968]" captionTargetBox="[168,1432,185,1903]" captionTargetId="figure-26@11.[151,1435,181,1920]" captionTargetPageId="11" captionText="FIGURES 21–23. Marcinistra gen. n. and Baimistra gen. n. spp.: male genitalia. Depositories of the specimens dissected: 21 in HNHM; 22 and 23 in AFM." figureDoi="http://doi.org/10.5281/zenodo.6593190" httpUri="https://zenodo.org/record/6593190/files/figure.png" pageId="3" pageNumber="445">Fig. 23</figureCitation>
), 
<emphasis id="B96FEAB03300FFC4263D8B67FD6CF9F6" box="[571,686,1622,1648]" italics="true" pageId="3" pageNumber="445">Suginistra</emphasis>
(
<figureCitation id="13202A273300FFC426B98B64FCD0F9E9" box="[703,786,1621,1647]" captionStart="FIGURES 27–29" captionStartId="13.[151,264,1944,1968]" captionTargetBox="[155,1389,216,1902]" captionTargetId="figure-26@13.[151,1435,181,1920]" captionTargetPageId="13" captionText="FIGURES 27–29. Type species of Conistra (Dasycampa), Suginistra and Vargalorta gen. n.: male genitalia. Depositories of the specimens dissected: 27 in BBT; 28 and 29 in HNHM." figureDoi="http://doi.org/10.5281/zenodo.6593194" httpUri="https://zenodo.org/record/6593194/files/figure.png" pageId="3" pageNumber="445">Fig. 28</figureCitation>
) and 
<taxonomicName id="4C1B4D213300FFC427538B64FC0FF9E9" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[853,973,1621,1647]" class="Insecta" family="Noctuidae" genus="Vargalorta" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03300FFC427538B64FC0FF9E9" box="[853,973,1621,1647]" italics="true" pageId="3" pageNumber="445">Vargalorta</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03300FFC427D08B64FBE5F9E9" bold="true" box="[982,1063,1621,1647]" pageId="3" pageNumber="445">
<taxonomicNameLabel id="A25C57CB3300FFC427D08B64FBE5F9E9" box="[982,1063,1621,1647]" pageId="3" pageNumber="445" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13202A273300FFC4203E8B64FB49F9E9" box="[1080,1163,1621,1647]" captionStart="FIGURES 27–29" captionStartId="13.[151,264,1944,1968]" captionTargetBox="[155,1389,216,1902]" captionTargetId="figure-26@13.[151,1435,181,1920]" captionTargetPageId="13" captionText="FIGURES 27–29. Type species of Conistra (Dasycampa), Suginistra and Vargalorta gen. n.: male genitalia. Depositories of the specimens dissected: 27 in BBT; 28 and 29 in HNHM." figureDoi="http://doi.org/10.5281/zenodo.6593194" httpUri="https://zenodo.org/record/6593194/files/figure.png" pageId="3" pageNumber="445">Fig. 29</figureCitation>
) but differs in the juxta structure: in 
<taxonomicName id="4C1B4D213300FFC425218B4BFE6EF915" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[295,428,1658,1683]" class="Insecta" family="Noctuidae" genus="Marcinistra" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03300FFC425218B4BFE6EF915" box="[295,428,1658,1683]" italics="true" pageId="3" pageNumber="445">Marcinistra</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03300FFC425B58B48FDC1F915" bold="true" box="[435,515,1657,1683]" pageId="3" pageNumber="445">
<taxonomicNameLabel id="A25C57CB3300FFC425B58B48FDC1F915" box="[435,515,1657,1683]" pageId="3" pageNumber="445" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
, it bears a swollen, heavily sclerotised, short ventral protrusion while the juxta is flattened in the related genera. The posterior section of the juxta is only slightly narrower than the anterior one and has a broad medial depression whereas in the related genera, the posterior section of the juxta is conspicuously narrower than the anterior one and has a narrow medial incision. Additionally, the sacculus of 
<taxonomicName id="4C1B4D213300FFC420C78BD7FA84F979" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[1217,1350,1766,1791]" class="Insecta" family="Noctuidae" genus="Marcinistra" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03300FFC420C78BD7FA84F979" box="[1217,1350,1766,1791]" italics="true" pageId="3" pageNumber="445">Marcinistra</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03300FFC4214B8BD4FA5FF979" bold="true" box="[1357,1437,1765,1791]" pageId="3" pageNumber="445">
<taxonomicNameLabel id="A25C57CB3300FFC4214B8BD4FA5FF979" box="[1357,1437,1765,1791]" pageId="3" pageNumber="445" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
bears a serrulate clavus and a tiny, tubercle-like distal process which are absent in the related genera. The latter one is present in certain species of the genera 
<taxonomicName id="4C1B4D213300FFC4266C8A1CFD05F8C1" box="[618,711,1837,1863]" class="Insecta" family="Noctuidae" genus="Eupsilia" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus">
<emphasis id="B96FEAB03300FFC4266C8A1CFD05F8C1" box="[618,711,1837,1863]" italics="true" pageId="3" pageNumber="445">Eupsilia</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C1B4D213300FFC426F88A1CFBD3F8C1" authority="Hubner. The" authorityName="Hubner. The" box="[766,1041,1837,1863]" class="Insecta" family="Noctuidae" genus="Lithophane" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus">
<emphasis id="B96FEAB03300FFC426F88A1CFCBCF8C1" box="[766,894,1837,1863]" italics="true" pageId="3" pageNumber="445">Lithophane</emphasis>
Hübner. The
</taxonomicName>
phallus of the new genus is shorter than in the related genera (in proportion to the genital capsule), with carina bearing a robust, long, thorn-like lateral process directed anteriorly (a feature unique for the genus). The vesica of the new genus lacks cornuti and spinules which are present in 
<taxonomicName id="4C1B4D213300FFC425878AABFDA7F832" authority=", Suginistra" authorityName="Suginistra" box="[385,613,1946,1972]" class="Insecta" family="Noctuidae" genus="Conistra" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus">
<emphasis id="B96FEAB03300FFC425878AABFE21F832" box="[385,483,1946,1972]" italics="true" pageId="3" pageNumber="445">Conistra</emphasis>
, 
<emphasis id="B96FEAB03300FFC425F48AABFDA7F832" box="[498,613,1946,1972]" italics="true" pageId="3" pageNumber="445">Suginistra</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C1B4D213300FFC4269A8AA8FCD6F835" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[668,788,1945,1971]" class="Insecta" family="Noctuidae" genus="Vargalorta" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03300FFC4269A8AA8FCD6F835" box="[668,788,1945,1971]" italics="true" pageId="3" pageNumber="445">Vargalorta</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03300FFC4271D8AA8FCA9F835" bold="true" box="[795,875,1945,1971]" pageId="3" pageNumber="445">
<taxonomicNameLabel id="A25C57CB3300FFC4271D8AA8FCA9F835" box="[795,875,1945,1971]" pageId="3" pageNumber="445" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
but has a long but narrow, weakly sclerotised and rugose bar which is an extension of the carina (a feature unique within the 
<taxonomicName id="4C1B4D213300FFC427D48A8FFBF6F85E" box="[978,1076,1982,2008]" class="Insecta" family="Noctuidae" genus="Conistra" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="445" phylum="Arthropoda" rank="genus">
<emphasis id="B96FEAB03300FFC427D48A8FFBF6F85E" box="[978,1076,1982,2008]" italics="true" pageId="3" pageNumber="445">Conistra</emphasis>
</taxonomicName>
generic complex). In the female genitalia of 
<taxonomicName id="4C1B4D213307FFC325268DA6FE67FF36" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[288,421,151,176]" class="Insecta" family="Noctuidae" genus="Marcinistra" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="446" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03307FFC325268DA6FE67FF36" box="[288,421,151,176]" italics="true" pageId="4" pageNumber="446">Marcinistra</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03307FFC325AB8DA6FE3FFF37" bold="true" box="[429,509,151,177]" pageId="4" pageNumber="446">
<taxonomicNameLabel id="A25C57CB3307FFC325AB8DA6FE3FFF37" box="[429,509,151,177]" pageId="4" pageNumber="446" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13202A273307FFC3260B8DA6FD52FF37" box="[525,656,151,177]" captionStart="FIGURES 30–35" captionStartId="14.[151,264,1944,1968]" captionTargetBox="[166,1415,182,1902]" captionTargetId="figure-18@14.[151,1435,181,1920]" captionTargetPageId="14" captionText="FIGURES 30–35. Marcinistra gen. n., Baimistra gen. n. and Conistra spp.: female genitalia. Depositories of the specimens dissected: 30 and 34 in HNHM; 31 in AFM; 32 and 33 in ZSM; 35 in BBT." figureDoi="http://doi.org/10.5281/zenodo.6593198" httpUri="https://zenodo.org/record/6593198/files/figure.png" pageId="4" pageNumber="446">Figs 30, 31</figureCitation>
), the antrum is short, gelatinous, with two swollen, serrulate, sclerotised postero-lateral subostial ventral lobes, whereas in 
<taxonomicName id="4C1B4D213307FFC327018D8AFCABFF53" box="[775,873,187,213]" class="Insecta" family="Noctuidae" genus="Conistra" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="446" phylum="Arthropoda" rank="genus">
<emphasis id="B96FEAB03307FFC327018D8AFCABFF53" box="[775,873,187,213]" italics="true" pageId="4" pageNumber="446">Conistra</emphasis>
</taxonomicName>
(
<figureCitation id="13202A273307FFC3277E8D8AFC3EFF53" box="[888,1020,187,213]" captionStart-0="FIGURES 30–35" captionStart-1="FIGURES 36–39" captionStartId-0="14.[151,264,1944,1968]" captionStartId-1="15.[151,264,1944,1968]" captionTargetBox-0="[166,1415,182,1902]" captionTargetBox-1="[265,1323,186,1902]" captionTargetId-0="figure-18@14.[151,1435,181,1920]" captionTargetId-1="figure-26@15.[151,1435,181,1920]" captionTargetPageId-0="14" captionTargetPageId-1="15" captionText-0="FIGURES 30–35. Marcinistra gen. n., Baimistra gen. n. and Conistra spp.: female genitalia. Depositories of the specimens dissected: 30 and 34 in HNHM; 31 in AFM; 32 and 33 in ZSM; 35 in BBT." captionText-1="FIGURES 36–39. Conistra, Suginistra and Vargalorta gen. n. spp.: female genitalia. Depositories of the specimens dissected: 36 and 39 in HNHM; 37 in BBT; 38 after Ronkay et al. (2017)." figureDoi-0="http://doi.org/10.5281/zenodo.6593198" figureDoi-1="http://doi.org/10.5281/zenodo.6593200" httpUri-0="https://zenodo.org/record/6593198/files/figure.png" httpUri-1="https://zenodo.org/record/6593200/files/figure.png" pageId="4" pageNumber="446">Figs 34–37</figureCitation>
), 
<emphasis id="B96FEAB03307FFC320098D8AFB40FF53" box="[1039,1154,187,213]" italics="true" pageId="4" pageNumber="446">Suginistra</emphasis>
(
<figureCitation id="13202A273307FFC320948D8AFB26FF53" box="[1170,1252,187,213]" captionStart="FIGURES 36–39" captionStartId="15.[151,264,1944,1968]" captionTargetBox="[265,1323,186,1902]" captionTargetId="figure-26@15.[151,1435,181,1920]" captionTargetPageId="15" captionText="FIGURES 36–39. Conistra, Suginistra and Vargalorta gen. n. spp.: female genitalia. Depositories of the specimens dissected: 36 and 39 in HNHM; 37 in BBT; 38 after Ronkay et al. (2017)." figureDoi="http://doi.org/10.5281/zenodo.6593200" httpUri="https://zenodo.org/record/6593200/files/figure.png" pageId="4" pageNumber="446">Fig. 38</figureCitation>
) and 
<taxonomicName id="4C1B4D213307FFC321228D8AFA5EFF53" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[1316,1436,187,213]" class="Insecta" family="Noctuidae" genus="Vargalorta" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="446" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03307FFC321228D8AFA5EFF53" box="[1316,1436,187,213]" italics="true" pageId="4" pageNumber="446">Vargalorta</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03307FFC324918DEEFF25FF7F" bold="true" box="[151,231,223,249]" pageId="4" pageNumber="446">
<taxonomicNameLabel id="A25C57CB3307FFC324918DEEFF25FF7F" box="[151,231,223,249]" pageId="4" pageNumber="446" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13202A273307FFC324F08DEEFE89FF7F" box="[246,331,223,249]" captionStart="FIGURES 36–39" captionStartId="15.[151,264,1944,1968]" captionTargetBox="[265,1323,186,1902]" captionTargetId="figure-26@15.[151,1435,181,1920]" captionTargetPageId="15" captionText="FIGURES 36–39. Conistra, Suginistra and Vargalorta gen. n. spp.: female genitalia. Depositories of the specimens dissected: 36 and 39 in HNHM; 37 in BBT; 38 after Ronkay et al. (2017)." figureDoi="http://doi.org/10.5281/zenodo.6593200" httpUri="https://zenodo.org/record/6593200/files/figure.png" pageId="4" pageNumber="446">Fig. 39</figureCitation>
), the antrum is long, dorso-ventrally flattened and well-sclerotised, and in 
<taxonomicName id="4C1B4D213307FFC320908DEEFAC6FF7E" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[1174,1284,223,248]" class="Insecta" family="Noctuidae" genus="Baimistra" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="446" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03307FFC320908DEEFAC6FF7E" box="[1174,1284,223,248]" italics="true" pageId="4" pageNumber="446">Baimistra</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03307FFC3210A8DEEFA99FF7F" bold="true" box="[1292,1371,223,249]" pageId="4" pageNumber="446">
<taxonomicNameLabel id="A25C57CB3307FFC3210A8DEEFA99FF7F" box="[1292,1371,223,249]" pageId="4" pageNumber="446" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13202A273307FFC3216C8DEEFF23FE9B" captionStart="FIGURES 30–35" captionStartId="14.[151,264,1944,1968]" captionTargetBox="[166,1415,182,1902]" captionTargetId="figure-18@14.[151,1435,181,1920]" captionTargetPageId="14" captionText="FIGURES 30–35. Marcinistra gen. n., Baimistra gen. n. and Conistra spp.: female genitalia. Depositories of the specimens dissected: 30 and 34 in HNHM; 31 in AFM; 32 and 33 in ZSM; 35 in BBT." figureDoi="http://doi.org/10.5281/zenodo.6593198" httpUri="https://zenodo.org/record/6593198/files/figure.png" pageId="4" pageNumber="446">Figs 32, 33</figureCitation>
), the antrum is narrower, weakly sclerotised, and bears smaller postero-lateral subostial lobes. The anterior section of the ductus bursae of 
<taxonomicName id="4C1B4D213307FFC325F68C16FDB7FEC6" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[496,629,295,320]" class="Insecta" family="Noctuidae" genus="Marcinistra" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="446" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03307FFC325F68C16FDB7FEC6" box="[496,629,295,320]" italics="true" pageId="4" pageNumber="446">Marcinistra</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03307FFC3267D8C16FD0BFEC7" bold="true" box="[635,713,295,321]" pageId="4" pageNumber="446">
<taxonomicNameLabel id="A25C57CB3307FFC3267D8C16FD0BFEC7" box="[635,713,295,321]" pageId="4" pageNumber="446" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
is membranous with granulation and a lateral heavily sclerotised lateral plate, whereas in the related genera, the anterior section of the ductus bursae is sclerotised and dorso-ventrally flattened. Additionally, the appendix bursae is membranous in the new genus whereas it has sclerotised areas in 
<taxonomicName id="4C1B4D213307FFC324B38CA2FE5BFE2B" authority=", Suginistra" authorityName="Suginistra" box="[181,409,403,429]" class="Insecta" family="Noctuidae" genus="Conistra" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="446" phylum="Arthropoda" rank="genus">
<emphasis id="B96FEAB03307FFC324B38CA2FED5FE2B" box="[181,279,403,429]" italics="true" pageId="4" pageNumber="446">Conistra</emphasis>
, 
<emphasis id="B96FEAB03307FFC325208CA2FE5BFE2B" box="[294,409,403,429]" italics="true" pageId="4" pageNumber="446">Suginistra</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C1B4D213307FFC325D48CA2FD88FE2B" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[466,586,403,429]" class="Insecta" family="Noctuidae" genus="Vargalorta" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="446" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03307FFC325D48CA2FD88FE2B" box="[466,586,403,429]" italics="true" pageId="4" pageNumber="446">Vargalorta</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03307FFC326558CA2FD61FE2B" bold="true" box="[595,675,403,429]" pageId="4" pageNumber="446">
<taxonomicNameLabel id="A25C57CB3307FFC326558CA2FD61FE2B" box="[595,675,403,429]" pageId="4" pageNumber="446" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
, and a latero-basal protrusion of the ductus bursae sclerotisation in 
<taxonomicName id="4C1B4D213307FFC324918C86FEC7FE56" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[151,261,439,464]" class="Insecta" family="Noctuidae" genus="Baimistra" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="446" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03307FFC324918C86FEC7FE56" box="[151,261,439,464]" italics="true" pageId="4" pageNumber="446">Baimistra</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03307FFC3250B8C86FE9EFE57" bold="true" box="[269,348,439,465]" pageId="4" pageNumber="446">
<taxonomicNameLabel id="A25C57CB3307FFC3250B8C86FE9EFE57" box="[269,348,439,465]" pageId="4" pageNumber="446" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
</paragraph>
</subSubSection>
<subSubSection id="C30165293307FFC324C18CEBFCC6FA1B" pageId="4" pageNumber="446" type="description">
<paragraph id="8BA436A23307FFC324C18CEBFCC6FA1B" blockId="4.[151,1437,151,1689]" pageId="4" pageNumber="446">
<emphasis id="B96FEAB03307FFC324C18CEBFE93FE72" bold="true" box="[199,337,474,500]" pageId="4" pageNumber="446">Description</emphasis>
. 
<emphasis id="B96FEAB03307FFC325598CEAFD0EFE73" bold="true" box="[351,716,474,501]" pageId="4" pageNumber="446">External morphology of adults</emphasis>
(
<figureCitation id="13202A273307FFC326DD8CEAFC83FE73" box="[731,833,475,501]" captionStart="FIGURES 1–8" captionStartId="7.[151,264,1944,1968]" captionTargetBox="[198,1393,183,1891]" captionTargetId="figure-26@7.[151,1435,181,1920]" captionTargetPageId="7" captionText="FIGURES 1–8. Marcinistra gen. n. and Baimistra gen. n. spp.: adults. Depositories of the specimens: 1 and 2 in HNHM; 3–6 in AFM; 7 and 8 in ZSM." figureDoi="http://doi.org/10.5281/zenodo.6593182" httpUri="https://zenodo.org/record/6593182/files/figure.png" pageId="4" pageNumber="446">Figs 1–4</figureCitation>
). Forewing length 
<quantity id="4CE39B473307FFC320158CEAFB48FE73" box="[1043,1162,475,501]" metricMagnitude="-2" metricUnit="m" metricValue="1.25" metricValueMax="1.4" metricValueMin="1.1" pageId="4" pageNumber="446" unit="mm" value="12.5" valueMax="14.0" valueMin="11.0">11–14 mm</quantity>
in males and 
<quantity id="4CE39B473307FFC321228CEBFA5FFE73" box="[1316,1437,474,501]" metricMagnitude="-2" metricUnit="m" metricValue="1.35" metricValueMax="1.5" metricValueMin="1.2" pageId="4" pageNumber="446" unit="mm" value="13.5" valueMax="15.0" valueMin="12.0">12–15 mm</quantity>
in females. Antenna filiform in both sexes. Head dark brown. Thorax dark brown with admixture of pale brown scales; abdomen dark brown with whitish transverse stripes ventrally. Forewing elongate, relatively narrow, with convex anal and outer margins. Forewing ground colour pale brown with intense dark brown suffusion in medial area and shiny metallic green suffusion forming spots along costa and within transverse lines. Subbasal, ante- and postmedial lines sinuous, double. Subterminal line thin, zigzagged, diffuse. Terminal line interrupted into small spots between veins. Orbicular and reniform stigmata pale brown, encircled with black scales. Medial area with intense black or dark brown suffusion outward from reniform stigma. Hindwing monotonous brown. 
<emphasis id="B96FEAB03307FFC321008FE6FF77FC92" bold="true" pageId="4" pageNumber="446">Male genitalia</emphasis>
(
<figureCitation id="13202A273307FFC324C28FCAFE84FC93" box="[196,326,763,789]" captionStart="FIGURES 21–23" captionStartId="11.[151,264,1944,1968]" captionTargetBox="[168,1432,185,1903]" captionTargetId="figure-26@11.[151,1435,181,1920]" captionTargetPageId="11" captionText="FIGURES 21–23. Marcinistra gen. n. and Baimistra gen. n. spp.: male genitalia. Depositories of the specimens dissected: 21 in HNHM; 22 and 23 in AFM." figureDoi="http://doi.org/10.5281/zenodo.6593190" httpUri="https://zenodo.org/record/6593190/files/figure.png" pageId="4" pageNumber="446">Figs 21, 22</figureCitation>
). Uncus slender, subbasally down curved, laterally flattened, gradually tapered distally and pointed apically. Tegumen short, with short subuncal lobe and relatively short and apically rounded peniculus. Vinculum more or less equal in length to tegumen, V-shaped. Valva narrowed distally with slightly down curved distal section, apically tapered, ventral margin with short subapical protrusion. Clasper straight, parallel to ventral margin of valva; harpe long, narrow but heavily sclerotised, medially curved outwards, dilated distally. Sacculus with short and serrulate clavus and tiny tubercle-like process distally. Juxta shield-like, with shallow medial posterior depression and short but heavily sclerotised, swollen ventral protrusion medially. Anellus granulose. Phallus cylindrical, somewhat dilated and down curved distally, with short and apically rounded coecum. Carina with robust, long, thorn-like lateral process directed anteriorly, long and thin rugose distal bar deeply protruding in vesica, and dorsal dentate plate in certain species. Vesica tubular, equal in length to phallus or somewhat shorter than it, curved dorsally, granulose, with short semiglobular distal diverticulum, lacking cornuti. 
<emphasis id="B96FEAB03307FFC327318952FC39FBFA" bold="true" box="[823,1019,1122,1149]" pageId="4" pageNumber="446">Female genitalia</emphasis>
(
<figureCitation id="13202A273307FFC3200F8952FB4AFBFB" box="[1033,1160,1123,1149]" captionStart="FIGURES 30–35" captionStartId="14.[151,264,1944,1968]" captionTargetBox="[166,1415,182,1902]" captionTargetId="figure-18@14.[151,1435,181,1920]" captionTargetPageId="14" captionText="FIGURES 30–35. Marcinistra gen. n., Baimistra gen. n. and Conistra spp.: female genitalia. Depositories of the specimens dissected: 30 and 34 in HNHM; 31 in AFM; 32 and 33 in ZSM; 35 in BBT." figureDoi="http://doi.org/10.5281/zenodo.6593198" httpUri="https://zenodo.org/record/6593198/files/figure.png" pageId="4" pageNumber="446">Figs 30, 31</figureCitation>
). Papilla analis short and narrow, triangular and apically rounded, setose. Ovipositor strongly elongate and narrow. Apophyses thin, slightly dilated and flattened distally and rectangular apically. Apophysis posterioris ca. 3–3.5 times longer than apophysis anterioris. Ostium bursae broad. Antrum short, gelatinous, caliciform with sclerotised postero-lateral subostial lobes ventrally. Posterior section of corpus bursae very short, tubular, membranous. Anterior section of ductus bursae short, tubular, somewhat narrower than antrum, membranous with heavily sclerotised curved plate laterally. Corpus bursae elongate pear-shaped with weakly rugose anterior section bearing one or four small elliptical serrulate signa with medial groove. Appendix bursae more or less elliptical, membranous with weakly gelatinous lateral area, originating from posterior section of corpus bursae laterally.
</paragraph>
</subSubSection>
<subSubSection id="C30165293307FFC324C18897FBB4FA47" box="[199,1142,1446,1473]" pageId="4" pageNumber="446" type="distribution">
<paragraph id="8BA436A23307FFC324C18897FBB4FA47" blockId="4.[151,1437,151,1689]" box="[199,1142,1446,1473]" pageId="4" pageNumber="446">
<emphasis id="B96FEAB03307FFC324C18897FE9BFA46" bold="true" box="[199,345,1446,1472]" pageId="4" pageNumber="446">Distribution</emphasis>
. Species of the genus are known from 
<collectingCountry id="F30C76323307FFC327088896FC93FA47" box="[782,849,1447,1473]" name="Nepal" pageId="4" pageNumber="446">Nepal</collectingCountry>
and south-western 
<collectingCountry id="F30C76323307FFC3202D8896FBB0FA47" box="[1067,1138,1447,1473]" name="China" pageId="4" pageNumber="446">China</collectingCountry>
.
</paragraph>
</subSubSection>
<subSubSection id="C30165293307FFC324C188FAFC07F9D7" pageId="4" pageNumber="446" type="etymology">
<paragraph id="8BA436A23307FFC324C188FAFDEDF9AB" blockId="4.[151,1437,151,1689]" pageId="4" pageNumber="446">
<emphasis id="B96FEAB03307FFC324C188FAFE8AFA63" bold="true" box="[199,328,1483,1509]" pageId="4" pageNumber="446">Etymology</emphasis>
. The genus name is an aggregation of the diminutive name Marci and the genus group name 
<taxonomicName id="4C1B4D213307FFC3215488FAFF7AF98E" class="Insecta" family="Noctuidae" genus="Conistra" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="446" phylum="Arthropoda" rank="genus">
<emphasis id="B96FEAB03307FFC3215488FAFF7AF98E" italics="true" pageId="4" pageNumber="446">Conistra</emphasis>
</taxonomicName>
. The new genus is dedicated to the memory of the late Márton Hreblay, one of authors of the 
<typeStatus id="54A088003307FFC320E588DEFAD1F98F" box="[1251,1299,1519,1545]" pageId="4" pageNumber="446">type</typeStatus>
species and an early mentor of the senior author.
</paragraph>
<paragraph id="8BA436A23307FFC324C18B06FC07F9D7" blockId="4.[151,1437,151,1689]" box="[199,965,1590,1617]" pageId="4" pageNumber="446">
<emphasis id="B96FEAB03307FFC324C18B06FE41F9D7" bold="true" box="[199,387,1590,1617]" pageId="4" pageNumber="446">Number of taxa</emphasis>
. The genus comprises two species reviewed below.
</paragraph>
</subSubSection>
<subSubSection id="C30165293307FFC324C18B6AFB46F91F" pageId="4" pageNumber="446" type="discussion">
<paragraph id="8BA436A23307FFC324C18B6AFB46F91F" blockId="4.[151,1437,151,1689]" pageId="4" pageNumber="446">
<emphasis id="B96FEAB03307FFC324C18B6AFEEBF9F3" bold="true" box="[199,297,1627,1653]" pageId="4" pageNumber="446">Remark</emphasis>
. No overwintered specimens of the genus are known (
<bibRefCitation id="EF8A4B533307FFC327798B6AFB56F9F3" author="Hreblay, M. &amp; Ronkay, L." box="[895,1172,1627,1653]" pageId="4" pageNumber="446" pagination="1 - 314" refId="ref7508" refString="Hreblay, M. &amp; Ronkay, L. (1998) Noctuidae from Nepal. Moths of Nepal. Vol. 5. Tinea, 15 (Supplement 1), 1 - 314." type="book chapter" year="1998">Hreblay &amp; Ronkay 1998</bibRefCitation>
; present study) whereas members of the closely related 
<taxonomicName id="4C1B4D213307FFC325F08B4EFDA6F91E" authority="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth, 2022" authorityName="Benedek &amp; Volynkin &amp; Saldaitis &amp; Tóth" authorityYear="2022" box="[502,612,1663,1688]" class="Insecta" family="Noctuidae" genus="Baimistra" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="446" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="B96FEAB03307FFC325F08B4EFDA6F91E" box="[502,612,1663,1688]" italics="true" pageId="4" pageNumber="446">Baimistra</emphasis>
</taxonomicName>
<emphasis id="B96FEAB03307FFC3266D8B4EFD78F91F" bold="true" box="[619,698,1663,1689]" pageId="4" pageNumber="446">
<taxonomicNameLabel id="A25C57CB3307FFC3266D8B4EFD78F91F" box="[619,698,1663,1689]" pageId="4" pageNumber="446" rank="genus">gen. n.</taxonomicNameLabel>
</emphasis>
and 
<taxonomicName id="4C1B4D213307FFC326F68B4EFC90F91F" box="[752,850,1663,1689]" class="Insecta" family="Noctuidae" genus="Conistra" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="446" phylum="Arthropoda" rank="genus">
<emphasis id="B96FEAB03307FFC326F68B4EFC90F91F" box="[752,850,1663,1689]" italics="true" pageId="4" pageNumber="446">Conistra</emphasis>
</taxonomicName>
have overwintering adults.
</paragraph>
</subSubSection>
