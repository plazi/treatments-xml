<taxonomicName id="20D2632F906E7A67BF6FF60F85CEEF4F" authority="L." class="Magnoliopsida" family="Oleaceae" genus="Syringa" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="12" phylum="Tracheophyta" rank="species" species="vulgaris">
<pageBreakToken id="1A9E3A7AC71F9DF5C661A708839E7C38" pageId="null" pageNumber="12">Syringa</pageBreakToken>
vulgaris 
<authorityName id="D8759665463D00B2BA1797890B3F1E3E" pageId="null" pageNumber="12">L.</authorityName>
</taxonomicName>
</paragraph>
