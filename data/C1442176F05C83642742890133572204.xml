<subSubSection id="DCA200CA000E52564A1EB7A533992D8E" pageId="null" pageNumber="196" type="description">
<paragraph id="02D36AF9CAB167454E05FB2334817353" pageId="null" pageNumber="196">
Unterscheidet sich von der Gattung 
<taxonomicName id="0CC6682BB9C61130E527FC772606A1CB" class="Magnoliopsida" family="Brassicaceae" genus="Cardamine" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="196" phylum="Tracheophyta" rank="genus">
<emphasis id="69A63F81427C277B2475273B95AA1C49" italics="true" pageId="null" pageNumber="196">Cardamine</emphasis>
</taxonomicName>
(S. 196) durch folgende Merkmale: 
<normalizedToken id="519CFC979F514959DBFD4FED317FD39D" originalValue="Kelchblätter" pageId="null" pageNumber="196">Kelchblaetter</normalizedToken>
am Grunde nicht ausgebuchtet; 
<normalizedToken id="42FBEEB0CAA7F2C7C030B3AE3A9BEFAE" originalValue="Kronblätter" pageId="null" pageNumber="196">Kronblaetter</normalizedToken>
<normalizedToken id="E15E0FE102D98B4FD2447A29FA7C47B8" originalValue="weiß" pageId="null" pageNumber="196">weiss</normalizedToken>
; 
<emphasis id="76D76211CD08F452E07383A00A3697F9" italics="true" pageId="null" pageNumber="196">
Blutenstand 
<normalizedToken id="72AF6A05191060BD8637CB627B8BABE1" originalValue="beblättert" pageId="null" pageNumber="196">beblaettert</normalizedToken>
;
</emphasis>
Fruchtstiele 1/10- 
<normalizedToken id="844712C13E76CC6B4BB9AD2E1D3DC419" originalValue="¼" pageId="null" pageNumber="196">1/4</normalizedToken>
so lang wie die 
<normalizedToken id="5C1A6DF407283D92630AEA37253A57EE" originalValue="Früchte" pageId="null" pageNumber="196">Fruechte</normalizedToken>
; 
<emphasis id="AFFDF849E26E170308E260EB8481F1F7" italics="true" pageId="null" pageNumber="196">
<normalizedToken id="DB0C42BFA764261DBE07089609CE5009" originalValue="Früchte" pageId="null" pageNumber="196">Fruechte</normalizedToken>
behaart;
</emphasis>
Samen in unreifem Zustand 2reihig, 
<normalizedToken id="54E8246303CFC3AC6585E882416E1EBF" originalValue="später" pageId="null" pageNumber="196">spaeter</normalizedToken>
1reihig.
</paragraph>
<paragraph id="473DE228D13C532BD361704FB1D9A13B" pageId="null" pageNumber="196">
Die Gattung 
<taxonomicName id="BBAF0C950FA5A8147E7CCD76ADE155E5" class="Magnoliopsida" family="Brassicaceae" genus="Kibera" higherTaxonomySource="GBIF" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="196" phylum="Tracheophyta" rank="genus">
<emphasis id="37942D9932165D2DD7B79850769D3137" italics="true" pageId="null" pageNumber="196">Kibera</emphasis>
</taxonomicName>
, die meistens mit 
<taxonomicName id="1E35C2BDBF0EF6123FA3790ED05B57F8" class="Magnoliopsida" family="Brassicaceae" genus="Sisymbrium" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="196" phylum="Tracheophyta" rank="genus">
<emphasis id="DD736A7B0392B75EB34A33777F455A69" italics="true" pageId="null" pageNumber="196">Sisymbrium</emphasis>
</taxonomicName>
vereinigt wird, 
<normalizedToken id="BBFD9D7CBD2E7E2D0FCADE5C5980D237" originalValue="umfaßt" pageId="null" pageNumber="196">umfasst</normalizedToken>
neben unserer Art wahrscheinlich nur noch 1 Art in den Anden von Peru und Bolivien. Die beiden Arten unterscheiden sich in einer Reihe von Merkmalen (auch 
<normalizedToken id="1B84C6F62C6583EE3BECEA15BDF1ED4F" originalValue="ökologischen" pageId="null" pageNumber="196">oekologischen</normalizedToken>
) von den meisten andern Arten der Gattung 
<emphasis id="24931182F639E7A89DDAFF7647F1DFDF" italics="true" pageId="null" pageNumber="196">
<taxonomicName id="1CF4C80D98D40A3402A1AF118999700E" class="Magnoliopsida" family="Brassicaceae" genus="Sisymbrium" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="196" phylum="Tracheophyta" rank="genus">Sisymbrium</taxonomicName>
.
</emphasis>
</paragraph>
</subSubSection>
