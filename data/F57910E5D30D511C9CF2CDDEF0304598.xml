<bibRefCitation id="5B500C200AF46CF94E839BE714AC7FB3" DOI="https://doi.org/10.1653/024.098.0227" author="Li, Y" journalOrPublisher="Florida Entomological Society" pageId="0" pageNumber="57" pagination="567 - 569" refId="B15" refString="Li, Y, Xin, DY, Wang, M, 2015. A New Species of the Genus Ditrigona Moore, 1888 (Lepidoptera: Drepanidae) in China. Florida Entomological Society 98 (2): 567 - 569, DOI: https://doi.org/10.1653/024.098.0227" title="A New Species of the Genus Ditrigona Moore, 1888 (Lepidoptera: Drepanidae) in China." url="https://doi.org/10.1653/024.098.0227" volume="98" year="2015">Li et al. (2015)</bibRefCitation>
