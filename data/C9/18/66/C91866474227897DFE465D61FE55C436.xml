<quantity box="[1028,1112,1084,1111]" metricMagnitude="-2" metricUnit="m" metricValue="1.27" pageId="34" pageNumber="44" unit="in" value="0.5">0.50 in</quantity>
<taxonomicName baseAuthorityName="Sandberger &amp; Sandberger" baseAuthorityYear="1851" box="[1122,1269,1084,1110]" class="Cephalopoda" family="Acanthoclymeniidae" genus="Acanthoclymenia" kingdom="Animalia" order="Ammonoidea" pageId="34" pageNumber="44" phylum="Mollusca" rank="species" species="planorbis">
<emphasis box="[1122,1269,1084,1110]" italics="true" pageId="34" pageNumber="44">A. planorbis</emphasis>
</taxonomicName>
but ~ 
<quantity box="[1352,1436,1084,1110]" metricMagnitude="-3" metricUnit="m" metricValue="7.62" pageId="34" pageNumber="44" unit="in" value="0.3">0.30 in</quantity>
<taxonomicName baseAuthorityName="Sandberger &amp; Sandberger" baseAuthorityYear="1851" box="[227,383,1119,1146]" class="Cephalopoda" family="Acanthoclymeniidae" genus="Acanthoclymenia" kingdom="Animalia" order="Ammonoidea" pageId="34" pageNumber="44" phylum="Mollusca" rank="species" species="forcipifera">
<emphasis box="[227,383,1119,1146]" italics="true" pageId="34" pageNumber="44">A. forcipifera</emphasis>
</taxonomicName>
).
