<subSubSection pageId="19" pageNumber="29" type="discussion">
<paragraph blockId="19.[227,341,1606,1632]" box="[227,341,1606,1632]" pageId="19" pageNumber="29">
<heading bold="true" box="[227,341,1606,1632]" fontSize="11" level="3" pageId="19" pageNumber="29" reason="3">
<emphasis bold="true" box="[227,341,1606,1632]" pageId="19" pageNumber="29">Remarks</emphasis>
</heading>
</paragraph>
<paragraph blockId="19.[227,1437,1655,1759]" pageId="19" pageNumber="29">
<taxonomicName authorityName="Bockwinkel, Becker &amp; Ebbighausen" authorityYear="2009" box="[227,380,1655,1681]" class="Cephalopoda" family="Taouzitidae" genus="Darkaoceras" kingdom="Animalia" order="Ammonoidea" pageId="19" pageNumber="29" phylum="Mollusca" rank="genus">
<emphasis box="[227,380,1655,1681]" italics="true" pageId="19" pageNumber="29">Darkaoceras</emphasis>
</taxonomicName>
(with subacute venter and four umbilical lobes) is morphologically intermediate between 
<taxonomicName authorityName="Becker &amp; House" authorityYear="1994" box="[227,366,1693,1719]" class="Cephalopoda" family="Taouzitidae" genus="Mzerrebites" kingdom="Animalia" order="Ammonoidea" pageId="19" pageNumber="29" phylum="Mollusca" rank="genus">
<emphasis box="[227,366,1693,1719]" italics="true" pageId="19" pageNumber="29">Mzerrebites</emphasis>
</taxonomicName>
(with narrowly rounded venter and three umbilical lobes) and 
<taxonomicName authorityName="Korn" authorityYear="2001" box="[1105,1215,1694,1719]" class="Cephalopoda" family="Taouzitidae" genus="Taouzites" kingdom="Animalia" order="Ammonoidea" pageId="19" pageNumber="29" phylum="Mollusca" rank="genus">
<emphasis box="[1105,1215,1694,1719]" italics="true" pageId="19" pageNumber="29">Taouzites</emphasis>
</taxonomicName>
(with sharp venter and up to eight umbilical lobes).
</paragraph>
