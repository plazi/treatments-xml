<typeStatus id="5496E5A4F77EB13FB06FFABB33624616" box="[298,347,1348,1364]" pageId="11" pageNumber="532">TYPE</typeStatus>
LOCALITY: 
<location id="8EF20DDDF77EB13FB096FAC3304B4614" LSID="urn:lsid:plazi:treatment:0384EA10F77EB138B1D2FCBB36F24203:8EF20DDDF77EB13FB096FAC3304B4614" box="[467,626,1340,1366]" country="Namibia" name="Swakop River" pageId="11" pageNumber="532">Swakop River</location>
and 
<collectingCountry id="F33A1B96F77EB13FB3ECFAC331124615" box="[681,811,1340,1367]" name="Namibia" pageId="11" pageNumber="532">Walvis Bay</collectingCountry>
, 
<collectingCountry id="F33A1B96F77EB13FB273FAC331A34614" box="[822,922,1340,1366]" name="Namibia" pageId="11" pageNumber="532">Namibia</collectingCountry>
