<geoCoordinate id="A9A616DDA5286A02BAFFFB2DFD38FA96" box="[640,723,1265,1287]" degrees="77" direction="east" minutes="29" orientation="longitude" pageId="7" pageNumber="1094" precision="925" value="77.48333">77°29'E</geoCoordinate>
] in 
<collectingRegion id="0E56BEF8A5286A02BA82FB2EFC90FA99" box="[765,891,1266,1288]" country="India" name="Tamil Nadu" pageId="7" pageNumber="1094">Tamil Nadu</collectingRegion>
, South 
<collectingCountry id="B485308AA5286A02BBB5FB2EFC15FA99" box="[970,1022,1266,1288]" name="India" pageId="7" pageNumber="1094">India</collectingCountry>
(
<figureCitation id="54A96C9FA5286A02BC72FB2EFF56FAB4" captionStart="Map 1" captionStartId="1.[178,223,1240,1261]" captionTargetBox="[178,1085,558,1214]" captionTargetId="figure-142@1.[178,1085,558,1214]" captionTargetPageId="1" captionText="Map 1: Distribution of Echiaster species in Asia. Echiaster discrepans (white circles); E. bivirgatus (white diamonds); E. maior (white triangles); E. paulexcisus (black diamond); E. unicolor (black circles)." figureDoi="http://doi.org/10.5281/zenodo.5361369" httpUri="https://zenodo.org/record/5361369/files/figure.png" pageId="7" pageNumber="1094">Map 1</figureCitation>
), at altitudes of 
<quantity id="0B6ADDFFA5286A02B91BFAD3FE05FAB5" box="[356,494,1295,1316]" metricMagnitude="3" metricUnit="m" metricValue="2.15" metricValueMax="2.2" metricValueMin="2.1" pageId="7" pageNumber="1094" unit="m" value="2150.0" valueMax="2200.0" valueMin="2100.0">2100-2200 m</quantity>
