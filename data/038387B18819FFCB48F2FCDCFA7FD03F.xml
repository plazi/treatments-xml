<heading id="D0DD81CB8819FFCB48F2FCDCFDA2D66C" bold="true" centered="true" fontSize="11" level="1" pageId="7" pageNumber="134" reason="1">
<emphasis id="B95EEAB58819FFCB48F2FCDCFDA2D66C" bold="true" pageId="7" pageNumber="134">
Identification key to 
<taxonomicName id="4C2A4D248819FFCB4905FCDCFA8CD631" authority="Nees von Esenbeck (1832: 75)" authorityName="Nees von Esenbeck" authorityPageNumber="75" authorityYear="1832" box="[383,1368,770,797]" class="Magnoliopsida" family="Acanthaceae" genus="Petalidium" kingdom="Plantae" order="Lamiales" pageId="7" pageNumber="134" phylum="Tracheophyta" rank="genus">
<emphasis id="B95EEAB58819FFCB4905FCDCFD78D630" bold="true" box="[383,684,770,797]" italics="true" pageId="7" pageNumber="134">Petalidium sesfonteinense</emphasis>
, 
<emphasis id="B95EEAB58819FFCB4AC0FCDDFC9AD631" bold="true" box="[698,846,770,797]" italics="true" pageId="7" pageNumber="134">P. kaokoense</emphasis>
, 
<emphasis id="B95EEAB58819FFCB4B26FCDDFC08D631" bold="true" box="[860,988,770,797]" italics="true" pageId="7" pageNumber="134">P. variabile</emphasis>
, and other species of 
<emphasis id="B95EEAB58819FFCB4CA0FCDCFA8CD631" bold="true" box="[1242,1368,770,797]" italics="true" pageId="7" pageNumber="134">Petalidium</emphasis>
</taxonomicName>
within the distribution range of 
<taxonomicName id="4C2A4D248819FFCB49C9FCF9FDA2D66C" authorityName="Swanepoel &amp; E. Tripp" authorityYear="2022" box="[435,630,806,833]" class="Magnoliopsida" family="Acanthaceae" genus="Petalidium" kingdom="Plantae" order="Lamiales" pageId="7" pageNumber="134" phylum="Tracheophyta" rank="species" species="sesfonteinense">
<emphasis id="B95EEAB58819FFCB49C9FCF9FDA2D66C" bold="true" box="[435,630,806,833]" italics="true" pageId="7" pageNumber="134">P. sesfonteinense</emphasis>
</taxonomicName>
</emphasis>
