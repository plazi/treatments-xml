<emphasis id="F860A200844E90C0C00EE484DC04DB5B" italics="true" pageId="0" pageNumber="95">Meconopsis integrifolia</emphasis>
</taxonomicName>
(Maxim.) Franch. (
<taxonomicName id="9CB4CD50A23E573241144E43726070BF" authorityName="L.G.A.Viguier" authorityYear="1814" class="Magnoliopsida" family="Papaveraceae" genus="Meconopsis" kingdom="Plantae" lsidName="" order="Ranunculales" pageId="0" pageNumber="95" phylum="Tracheophyta" rank="family">Papaveraceae</taxonomicName>
