<taxonomicName id="ADD817BD48B881CF0CB3F68930EA314B" class="Magnoliopsida" family="Plantaginaceae" genus="Veronica" kingdom="Plantae" lsidName="Veronica szechuanica subsp. sikkimensis" order="Lamiales" pageId="0" pageNumber="95" phylum="Tracheophyta" rank="subSpecies" species="szechuanica" subSpecies="sikkimensis">Veronica szechuanica subsp. sikkimensis</taxonomicName>
