<emphasis id="FD86EDEE33ACAE59431C747CC25F4BB2" italics="true" pageId="0" pageNumber="95">Draba amplexicaulis</emphasis>
</taxonomicName>
Franch. (brassicaceaee), 
<taxonomicName id="D8C999D2A56CA0EDF4D7D41E827929DA" class="Magnoliopsida" family="Scrophulariaceae" genus="Scrophularia" kingdom="Plantae" lsidName="Scrophularia delavayi" order="Lamiales" pageId="0" pageNumber="95" phylum="Tracheophyta" rank="species" species="delavayi">
<emphasis id="E5E07D6FE4708E75136B0BA6F97ED5A1" italics="true" pageId="0" pageNumber="95">Scrophularia delavayi</emphasis>
</taxonomicName>
Franch.(
<taxonomicName id="E2A94435A399C04A8AA405C262081336" class="Magnoliopsida" family="Scrophulariaceae" genus="Scrophularia" kingdom="Plantae" lsidName="" order="Lamiales" pageId="0" pageNumber="95" phylum="Tracheophyta" rank="family">Scrophulariaceae</taxonomicName>
