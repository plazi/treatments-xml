<td id="8E83B62CED400491BA9B0BCFDFB6B673" align="left" pageId="null" pageNumber="576" valign="top">
1. Krone gelblich, 
<normalizedToken id="D11C1787FBB41C26C7AD29C475683237" originalValue="rötlich" pageId="null" pageNumber="576">roetlich</normalizedToken>
gestreift; alle 
<normalizedToken id="C4E306F1077657278432FB2E29C10A24" originalValue="Blätter" pageId="null" pageNumber="576">Blaetter</normalizedToken>
in 
<normalizedToken id="F8CBB823A21527D018E92758F77A39FA" originalValue="grundständiger" pageId="null" pageNumber="576">grundstaendiger</normalizedToken>
Rosette; Frucht ohne deutliche 
<normalizedToken id="2899812BB58A8EA1E442BCCE5128FDA5" originalValue="Zähne" pageId="null" pageNumber="576">Zaehne</normalizedToken>
. Aostatal
</td>
<td id="DC085B7F4008BF3FE7FE96006248B030" align="left" pageId="null" pageNumber="576" valign="bottom">
