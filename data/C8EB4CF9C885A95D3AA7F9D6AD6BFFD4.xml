<italic id="C527EAA6224498FDB2050F4063A76E7C" pageId="null" pageNumber="576">O. saxatilis</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="8AC6BA9D13DB5FEC76689DEF0248FD1C" pageId="null" pageNumber="576">
<td id="D770C21461552A29C71CAACF06134B0F" align="left" pageId="null" pageNumber="576" valign="top">
1*. Krone 
<normalizedToken id="61123A03C51958A848071D7EEF358BAC" originalValue="rötlich" pageId="null" pageNumber="576">roetlich</normalizedToken>
, dunkler gestreift; Stengel 
<normalizedToken id="B086FC9A1E19FDBF18EDC031E365AF18" originalValue="beblättert" pageId="null" pageNumber="576">beblaettert</normalizedToken>
; Frucht mit 
<normalizedToken id="086FF136B876F4F51188EEE90C802265" originalValue="Zähnen" pageId="null" pageNumber="576">Zaehnen</normalizedToken>
</td>
<td id="72476F971DD3B5E904F48BFB9C4BF37F" align="left" pageId="null" pageNumber="576" valign="bottom">
<italic id="79C9502EEAA04FEAAD4C2C0D4C47AFDC" pageId="null" pageNumber="576">
Artengruppe der 
<taxonomicName id="3A1779A7D2D840526F6EE9B671A49CE1" class="Magnoliopsida" family="Fabaceae" genus="Onobrychis" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="576" phylum="Tracheophyta" rank="species" species="viciifolia">O. viciifolia</taxonomicName>
</italic>
