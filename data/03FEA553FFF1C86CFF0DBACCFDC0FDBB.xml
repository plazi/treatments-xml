<paragraph id="8BE81445FFEFC86CFF0DBACDFD7DFF0F" blockId="17.[151,1437,150,609]" pageId="17" pageNumber="372">
<emphasis id="B923C857FFEFC86CFF0DBACDFEC3FF6A" bold="true" box="[151,274,150,176]" pageId="17" pageNumber="372">Diagnosis.</emphasis>
