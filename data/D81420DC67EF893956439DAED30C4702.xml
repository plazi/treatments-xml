<subSubSection id="1AA2F5C30902431A6BBDAEF571456005" pageId="null" pageNumber="58" type="description">
<paragraph id="3A34E3A302A6BC161B222238A9194051" pageId="null" pageNumber="58">
Unterscheidet sich durch folgende Merkmale von 
<taxonomicName id="80DBBA52773EFB1BAA3B21A5C682CF3B" class="Magnoliopsida" family="Boraginaceae" genus="Echium" kingdom="Plantae" order="Boraginales" pageId="null" pageNumber="58" phylum="Tracheophyta" rank="species" species="vulgare">
<emphasis id="1D72BEED0F10DC0B0A1DC3B09C01C3D2" italics="true" pageId="null" pageNumber="58">E. vulgare</emphasis>
</taxonomicName>
(Nr. 1): 
<emphasis id="610439BD45E73C157C6473B4DC66E955" italics="true" pageId="null" pageNumber="58">
Am Kelch die langen Borstenhaare sehr dicht stehend und die kurzen Haare fast verdeckend; Krone meist 
<normalizedToken id="7C53AAF153CAD8A597F5A745AECAE61A" originalValue="weiß" pageId="null" pageNumber="58">weiss</normalizedToken>
bis rosa, 8
</emphasis>
- 
<emphasis id="601EDFDAD483BB3E8AB3073B7FC9851C" italics="true" pageId="null" pageNumber="58">12 mm lang.</emphasis>
- 
<normalizedToken id="4A50789C7D2209D85AE67869D8D8E30E" originalValue="Blüte" pageId="null" pageNumber="58">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="E587C86D1C0B97C9BA632E5987D267FF" pageId="null" pageNumber="58">
<emphasis id="63905CBE75385F5B74C13879CA11C6E7" italics="true" pageId="null" pageNumber="58">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A6D1E20549B1208DA122C88A7FB454A4" italics="true" pageId="null" pageNumber="58">16:</emphasis>
Material aus Frankreich (Antibes) (
<normalizedToken id="61CA8EF1FE75BDAB875AC74CA4E3E846" originalValue="Litardière" pageId="null" pageNumber="58">Litardiere</normalizedToken>
1943), aus Afghanistan (Podlech und Dieterle 1969) aus Albanien (Strid 1971). 
<emphasis id="0F04B93AE44392B097812AA6703A1EB7" italics="true" pageId="null" pageNumber="58">2n</emphasis>
= 
<emphasis id="C733B96C1712F0A1EA34E6DE7E9B4C08" italics="true" pageId="null" pageNumber="58">16, 32:</emphasis>
Material aus 
<normalizedToken id="465DCD4A491A1A597F15428266279D08" originalValue="Rumänien" pageId="null" pageNumber="58">Rumaenien</normalizedToken>
und Ungarn (
<normalizedToken id="E4473AB292BA9C7AD655CB2AE30DEBE2" originalValue="Litardière" pageId="null" pageNumber="58">Litardiere</normalizedToken>
1943). 
<emphasis id="DF7A8F1F8DAA9E6291482738926D92E4" italics="true" pageId="null" pageNumber="58">2n</emphasis>
= 
<emphasis id="1D9C7A2D973AD6747D598721D89318BE" italics="true" pageId="null" pageNumber="58">32:</emphasis>
Material aus Spanien (Gadella et al. 1966).
</paragraph>
<paragraph id="6F016BBC1296200DCBE3870E2131E9BA" pageId="null" pageNumber="58">
<emphasis id="769AD0A5E9444DE540B5E7C1216471E0" italics="true" pageId="null" pageNumber="58">Standort.</emphasis>
Kollin. Trockene, 
<normalizedToken id="92B583065563B7C6D04EA40A24AED3F8" originalValue="durchlässige" pageId="null" pageNumber="58">durchlaessige</normalizedToken>
<normalizedToken id="862EC5A3364E2ED67E278E5AB73629CD" originalValue="Böden" pageId="null" pageNumber="58">Boeden</normalizedToken>
. 
<normalizedToken id="2D03EBF4CDBD77DB4A79D01C30E2B23D" originalValue="Äcker" pageId="null" pageNumber="58">Aecker</normalizedToken>
, Weinberge, Ruderalstellen.
</paragraph>
<paragraph id="3A6FA2B3C87C272AA6685AF1BE3A91F1" pageId="null" pageNumber="58">
<emphasis id="D9FDA72AE34DBE45348599FB8512D3BD" italics="true" pageId="null" pageNumber="58">Verbreitung.</emphasis>
<normalizedToken id="10369D8751A1373E930577C96C6E2612" originalValue="Ursprünglich" pageId="null" pageNumber="58">Urspruenglich</normalizedToken>
<emphasis id="E2D4A0EC4925BE6E8C1E1B9BE0276AF8" italics="true" pageId="null" pageNumber="58">mediterran-westasiatische Pflanze</emphasis>
(
<normalizedToken id="A3AF1A09BA5B37175073970BA23B9081" originalValue="ostwärts" pageId="null" pageNumber="58">ostwaerts</normalizedToken>
bis Zentralasien); heute 
<normalizedToken id="34BB637E4BC04BFC4E811B4D5CD64FAA" originalValue="über" pageId="null" pageNumber="58">ueber</normalizedToken>
weite Gebiete verschleppt. - Im Gebiet: 
<normalizedToken id="BED7C5452234390CD158339B31706011" originalValue="Ursprünglich" pageId="null" pageNumber="58">Urspruenglich</normalizedToken>
wahrscheinlich in der Gegend von Bergamo und im untern Veltlin; sonst gelegentlich adventiv.
</paragraph>
</subSubSection>
