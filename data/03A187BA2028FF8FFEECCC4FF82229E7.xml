</caption>
<caption id="DF7766242028FF8FFB00CA6CF7972945" ID-DOI="http://doi.org/10.5281/zenodo.6595817" ID-Zenodo-Dep="6595817" box="[1256,2132,1085,1114]" httpUri="https://zenodo.org/record/6595817/files/figure.png" inLine="true" pageId="0" pageNumber="186" targetBox="[248,1192,697,1320]" targetPageId="0">
