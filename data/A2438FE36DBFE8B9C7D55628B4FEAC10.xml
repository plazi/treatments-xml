<taxonomicName id="D44C53198FDBA67541C0C3E548645221" authority="L." class="Magnoliopsida" family="Plantaginaceae" genus="Veronica" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="194" phylum="Tracheophyta" rank="species" species="serpyllifolia">
Veronica 
<normalizedToken id="724B5C39D1888C148F52EE9C6FC2615F" originalValue="serpyllifólia" pageId="null" pageNumber="194">serpyllifolia</normalizedToken>
