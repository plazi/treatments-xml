<subSubSection id="D3C0C44ECBBC106AAC9DE82DBD492A27" pageId="null" pageNumber="194" type="vernacular_names">
<paragraph id="988D7DA78FDAE762ED0188D4F27CBABE" pageId="null" pageNumber="194">
<normalizedToken id="262F9F8567FB4636BC8CB10EA80D69C6" originalValue="Quendelblättriger" pageId="null" pageNumber="194">Quendelblaettriger</normalizedToken>
Ehrenpreis
</paragraph>
</subSubSection>
</title>
<subSubSection id="29944371CE1B8ABB4DD8EEAD18B6505C" pageId="null" pageNumber="194" type="description">
<paragraph id="3B83C99777F692EC5914034512F1C7CB" pageId="null" pageNumber="194">
5-25 cm hoch. Stengel aufrecht oder aufsteigend. 
<normalizedToken id="E35DE9B419FA1C410339E972963180E9" originalValue="Blätter" pageId="null" pageNumber="194">Blaetter</normalizedToken>
bis 2,5 cm lang, 
<normalizedToken id="1DBB8BC8ABDEB5D35CBA7089C5C58B98" originalValue="1½-2½" pageId="null" pageNumber="194">11/2-21/2</normalizedToken>
mal so lang wie breit. 
<normalizedToken id="FC0BA7660119E411F58879BEAD23E645" originalValue="Blüten" pageId="null" pageNumber="194">Blueten</normalizedToken>
bis 35 je Stengel. 
<emphasis id="AD9CA2D9D4B278E733707FEE32C39568" italics="true" pageId="null" pageNumber="194">
Kelch und 
<normalizedToken id="25BDED631D1CCF9AEF1939AD5FE87372" originalValue="Blütenstiele" pageId="null" pageNumber="194">Bluetenstiele</normalizedToken>
sehr kurz und 
<normalizedToken id="9DDEDA589A278FB65B2BD336D4DFE196" originalValue="drüsenlos" pageId="null" pageNumber="194">druesenlos</normalizedToken>
behaart
</emphasis>
(
<emphasis id="65D814D41432D6DD60787460DAA14264" italics="true" pageId="null" pageNumber="194">
Haare 
<normalizedToken id="CFCD5E54B11F2D44691D84C603EAAF2A" originalValue="kürzer" pageId="null" pageNumber="194">kuerzer</normalizedToken>
als der Durchmesser des 
<normalizedToken id="8840AC7218BD75360BEC66A6B91DA988" originalValue="Blütenstiels" pageId="null" pageNumber="194">Bluetenstiels</normalizedToken>
</emphasis>
)
<emphasis id="565B2479DFB119F128B62F445B90A2AA" italics="true" pageId="null" pageNumber="194">. Krone im Durchmesser 5</emphasis>
- 
<emphasis id="1382E5B3D5011EA2CD2539C6E620121D" italics="true" pageId="null" pageNumber="194">
6 mm, 
<normalizedToken id="A4A60D885BCF5266A94D4FD212207E2F" originalValue="weiß" pageId="null" pageNumber="194">weiss</normalizedToken>
, blau geadert.
</emphasis>
- 
<normalizedToken id="E2F9E2DAEFF3DA8EF225897110FB4848" originalValue="Blüte" pageId="null" pageNumber="194">Bluete</normalizedToken>
: 
<normalizedToken id="ACF6A03D517378864F81F3F2DC2F47BB" originalValue="Später" pageId="null" pageNumber="194">Spaeter</normalizedToken>
<normalizedToken id="CBE1E6E998136D2ADA5785D6F6703DEE" originalValue="Frühling" pageId="null" pageNumber="194">Fruehling</normalizedToken>
bis Herbst.
</paragraph>
<paragraph id="F52B7E929D6E9F5F3F4CE4083A0DF6DB" pageId="null" pageNumber="194">
<emphasis id="F262A878C162B83DD0E202D8F9F87954" italics="true" pageId="null" pageNumber="194">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E59EF66709BC3B23B3CBBB8A4C0B0281" italics="true" pageId="null" pageNumber="194">14:</emphasis>
Material aus botanischen 
<normalizedToken id="B38B486F03643C7E5728056DCC54A880" originalValue="Gärten" pageId="null" pageNumber="194">Gaerten</normalizedToken>
und aus Mitteldeutschland (Hofelich 1935), aus Tirol (Mattick in Tischler 1950, Fischer 1969), aus Island (
<normalizedToken id="D77E4E91987C3E2119BF9FCA8A9C682C" originalValue="Löve" pageId="null" pageNumber="194">Loeve</normalizedToken>
und 
<normalizedToken id="4946ADA8443BE472547DA01D1C6F1261" originalValue="Löve" pageId="null" pageNumber="194">Loeve</normalizedToken>
1956b), aus den Niederlanden (Gadella und Kliphuis 1966), aus Ostsibirien (Sokolovskaya 1968), aus der 
<normalizedToken id="A795B14AAA6CABCA01B78669FF440551" originalValue="Türkei" pageId="null" pageNumber="194">Tuerkei</normalizedToken>
(Fischer 1969), aus der Tatra (Skalinska et al. 1968). 
<emphasis id="8D3B466F9DD781D0E0112FA38FA1DEB9" italics="true" pageId="null" pageNumber="194">2n</emphasis>
= 
<emphasis id="D28CD5070E072AAF3EF93C6EDB5A5C08" italics="true" pageId="null" pageNumber="194">28:</emphasis>
Material aus dem Wienerwald (Fischer 1969).
</paragraph>
<paragraph id="7FAC70EA2A33A6639A1148BB7E376DCC" pageId="null" pageNumber="194">
<emphasis id="5F9CC4AF442E5E8CC8169EFE89A71BF8" italics="true" pageId="null" pageNumber="194">Standort.</emphasis>
Kollin, montan und subalpin. 
<normalizedToken id="773E0B66A3B1C176C8F5E808315938D0" originalValue="Nährstoffreiche" pageId="null" pageNumber="194">Naehrstoffreiche</normalizedToken>
, eher feuchte, tonige 
<normalizedToken id="1EB5683B876713502E3AB6BC97CD0891" originalValue="Böden" pageId="null" pageNumber="194">Boeden</normalizedToken>
. Fettwiesen, Weiden, Wegund 
<normalizedToken id="1EC1ED83067EAABEB008B52A9F41F428" originalValue="Ackerränder" pageId="null" pageNumber="194">Ackerraender</normalizedToken>
.
</paragraph>
<paragraph id="FF1BAEB562B38233C02DA6CB148A1584" pageId="null" pageNumber="194">
<emphasis id="A5DD4B4AA01403D2D42569ECE2C2EC5C" italics="true" pageId="null" pageNumber="194">Verbreitung.</emphasis>
<normalizedToken id="83757A9DE4F439C1AE03A0733FCED27A" originalValue="Ursprünglich" pageId="null" pageNumber="194">Urspruenglich</normalizedToken>
wahrscheinlich 
<emphasis id="C9C2432239C9191B23A1AEA0EB2ED6D6" italics="true" pageId="null" pageNumber="194">eurosibirische Pflanze;</emphasis>
heute 
<normalizedToken id="984EB1B2BDEA71FAC2884C6BA9A17F1C" originalValue="über" pageId="null" pageNumber="194">ueber</normalizedToken>
einen 
<normalizedToken id="9AC217AB4B762B4E3670FC9B21818F69" originalValue="großen" pageId="null" pageNumber="194">grossen</normalizedToken>
Teil der Erde verschleppt. - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="52101122D1C4D56687595AC71CE46053" originalValue="häufig" pageId="null" pageNumber="194">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
