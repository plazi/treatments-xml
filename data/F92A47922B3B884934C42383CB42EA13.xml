<paragraph id="3628A3A6C283B0C32F0288E56205DE23" pageId="null" pageNumber="215">Igelschlauch</paragraph>
</subSubSection>
</title>
<subSubSection id="8A75D8F8A92703B3DF649BA180E56AFF" pageId="null" pageNumber="215" type="description">
<paragraph id="6C058D2B9CAA6CDB6DF676173FCF979E" pageId="null" pageNumber="215">
1 
<normalizedToken id="BC249B0E6304C29F75DD5D50FC990B8A" originalValue="jährige" pageId="null" pageNumber="215">jaehrige</normalizedToken>
oder ausdauernde Sumpf- und Wasserpflanzen. Keine 
<normalizedToken id="B030D36CBC6219FDF16C0180555DF293" originalValue="Ausläufer" pageId="null" pageNumber="215">Auslaeufer</normalizedToken>
. Habitus wie bei 
<taxonomicName id="9D7E020EA284DFC04458E26D51874D3A" class="Colpodea" family="Sagittariidae" genus="Sagittaria" kingdom="Chromista" order="Cyrtolophosidida" pageId="null" pageNumber="215" phylum="Ciliophora" rank="genus">
<emphasis id="D08CD283DBB6EE58975715301BD5B8E2" italics="true" pageId="null" pageNumber="215">Sagittaria</emphasis>
</taxonomicName>
(S. 211). 
<emphasis id="2F918765BC5578AD19B4A6139DDB5D5C" italics="true" pageId="null" pageNumber="215">
<normalizedToken id="BB6A68F0972F7EAE04A1A78706F20D92" originalValue="Blüten" pageId="null" pageNumber="215">Blueten</normalizedToken>
zwitterig;
</emphasis>
<normalizedToken id="7D70CA106A23A4882B535D81E99AD178" originalValue="Perigonblätter" pageId="null" pageNumber="215">Perigonblaetter</normalizedToken>
6, die innern kronblattartig; 
<normalizedToken id="13CD854AC9C0B1BD7A31DABD23BDFF84" originalValue="Staubblätter" pageId="null" pageNumber="215">Staubblaetter</normalizedToken>
6-20; 
<emphasis id="D946DD21EBEEB186069DD396375DC446" italics="true" pageId="null" pageNumber="215">
<normalizedToken id="989CBDD4F6BFAA343827609B129176F3" originalValue="Früchtchen" pageId="null" pageNumber="215">Fruechtchen</normalizedToken>
zahlreich, in einem kugeligen Kopf
</emphasis>
(wie bei 
<taxonomicName id="D6EF78A265F525892330E8F886E661EE" class="Colpodea" family="Sagittariidae" genus="Sagittaria" kingdom="Chromista" order="Cyrtolophosidida" pageId="null" pageNumber="215" phylum="Ciliophora" rank="genus">
<emphasis id="03D232ED6EF8502964477354D980B6AE" italics="true" pageId="null" pageNumber="215">Sagittaria</emphasis>
</taxonomicName>
), frei, 1samig.
</paragraph>
<paragraph id="48F46DDFC82A4AB3AACC29DDE68F3C84" pageId="null" pageNumber="215">
Die Gattung 
<normalizedToken id="46923D751DD76310A8A0F47C4C02EA1D" originalValue="umfaßt" pageId="null" pageNumber="215">umfasst</normalizedToken>
etwa 
<emphasis id="C5070012CC4951074BEFAA7EF07F01D1" italics="true" pageId="null" pageNumber="215">25 Arten</emphasis>
, die vor allem im 
<emphasis id="4740AA012B9E3D3AFF5D832E05007908" italics="true" pageId="null" pageNumber="215">tropischen</emphasis>
und 
<emphasis id="74EA0277D7794E012C221B2450BF6B58" italics="true" pageId="null" pageNumber="215">subtropischen Amerika</emphasis>
verbreitet sind. In 
<taxonomicName id="8685820AE1B2B1D660D59A4B302A1A1E" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="215" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
nur die aus 3 Arten bestehende Gruppe des 
<taxonomicName id="38D3DCBACC84A3414F0144DF311F81A7" authority="(L.) Engelm. Im Gebiet" authorityName="Engelm. Im Gebiet" baseAuthorityName="L." class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="215" phylum="Arthropoda" rank="species" species="ranunculoides">
<emphasis id="5042A3E77DFFAE7948C207E59FA9DD48" italics="true" pageId="null" pageNumber="215">E. ranunculoides</emphasis>
(
<authorityName id="603CD6DA1BA3952E06F35FE1A7EE8BE3" pageId="null" pageNumber="215">L.</authorityName>
) Engelm. Im Gebiet
</taxonomicName>
einzig 
<emphasis id="5D88AAC6E26F892447BD4ECAEB1FA6BA" italics="true" pageId="null" pageNumber="215">
<taxonomicName id="7E2C4D5F9CDC1AA24493F47D8685449E" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="215" phylum="Arthropoda" rank="species" species="ranunculoides">E. ranunculoides</taxonomicName>
.
</emphasis>
Nur von 
<taxonomicName id="0C6FE76E4D7023D315DAC3359502D3C7" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="215" phylum="Arthropoda" rank="species" species="ranunculoides">
<emphasis id="1DF0AEFC01FA2E9CD9D337C724AB2CF0" italics="true" pageId="null" pageNumber="215">E. ranunculoides</emphasis>
</taxonomicName>
liegen Chromosomenuntersuchungen vor: 
<emphasis id="92F16AFC88964E8FDB8A73A17344027F" italics="true" pageId="null" pageNumber="215">aneuploide Reihe</emphasis>
wie in der Gattung 
<emphasis id="5D4D6496ED102CF105D314DB05C816D4" italics="true" pageId="null" pageNumber="215">
<taxonomicName id="D1B464743A471104A5A72EC3D851350C" class="Liliopsida" family="Alismataceae" genus="Alisma" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="215" phylum="Tracheophyta" rank="genus">Alisma</taxonomicName>
.
</emphasis>
</paragraph>
</subSubSection>
