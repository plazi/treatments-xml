3.8. 
<taxonomicName id="9AC477E8FF81EF42FF4EF887FEC5F8F4" authority="Fianco &amp; Szinwelski &amp; Faria, 2022" authorityName="Fianco &amp; Szinwelski &amp; Faria" authorityYear="2022" box="[203,368,1842,1868]" class="Insecta" family="Tettigoniidae" kingdom="Animalia" order="Orthoptera" pageId="41" pageNumber="66" phylum="Arthropoda" rank="tribe" status="trib. n." tribe="Pycnopalpini">Pycnopalpini</taxonomicName>
