<taxonomicName id="4C2901BE049715C4FE034BBCFDEBFA5B" box="[288,512,1429,1455]" class="Gastropoda" family="Triphoridae" genus="Triphoris" higherTaxonomySource="GBIF" kingdom="Animalia" order="Ptenoglossa" pageId="158" pageNumber="159" phylum="Mollusca" rank="species" species="conspersa">
<emphasis id="B95DA62F049715C4FE034BBCFDEBFA5B" box="[288,512,1429,1455]" italics="true" pageId="158" pageNumber="159">Triphoris conspersa</emphasis>
</taxonomicName>
E.A. 
<bibRefCitation id="EFB807CC049715C4FD1C4BBCFD22FA44" author="Smith, E. A." box="[575,713,1429,1456]" pageId="158" pageNumber="159" pagination="103 - 115" refId="ref169308" refString="Smith, E. A. (1875) A list of the Gasteropoda collected in Japanese Seas by Commander H. C. St. John, R. N. Annals and Magazine of Natural History, Series 4, 16, 103 - 115. https: // doi. org / 10.1080 / 00222937508681135" type="journal article" year="1875">
<collectingRegion id="49EDB4DF049715C4FD1C4BBCFD6EFA5B" box="[575,645,1429,1455]" country="Bermuda" name="Smith's" pageId="158" pageNumber="159">Smith</collectingRegion>
, 1875
</bibRefCitation>
. However, the name 
<taxonomicName id="4C2901BE049715C4FC8C4BBCFB7AFA5B" authorityName="Oyama" authorityYear="1954" box="[943,1169,1429,1455]" class="Gastropoda" family="Triphoridae" genus="Triphora" higherTaxonomySource="CoL" kingdom="Animalia" order="Asparagales" pageId="158" pageNumber="159" phylum="Mollusca" rank="species" species="sematensis">
