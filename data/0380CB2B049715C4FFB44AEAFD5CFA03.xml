Kuroda 
<emphasis id="B95DA62F049715C4FD884B5BFD08FA7F" box="[683,739,1393,1419]" italics="true" pageId="158" pageNumber="159">et al.</emphasis>
(1971)
</bibRefCitation>
considered 
<taxonomicName id="4C2901BE049715C4FC9F4B58FAB9FA78" authority="Oyama, 1954 a" authorityName="Oyama" authorityYear="1954" box="[956,1362,1393,1420]" class="Gastropoda" family="Triphoridae" genus="Triphora" higherTaxonomySource="CoL" kingdom="Animalia" order="Asparagales" pageId="158" pageNumber="159" phylum="Mollusca" rank="species" species="sematensis">
