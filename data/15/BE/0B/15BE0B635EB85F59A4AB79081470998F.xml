<subSubSection pageId="0" pageNumber="59" type="description">
<paragraph pageId="0" pageNumber="59">Description.</paragraph>
<paragraph pageId="0" pageNumber="59">Annuals; inflorescences aphyllous or bracteate, rarely leafy in the lower and middle parts; glomerules loosely or densely arranged.</paragraph>
</subSubSection>
