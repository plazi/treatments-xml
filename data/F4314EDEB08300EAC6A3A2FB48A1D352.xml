<taxonomicName id="845EE177652A8B2D0122409B7452FF25" authority="L." class="Magnoliopsida" family="Boraginaceae" genus="Borago" kingdom="Plantae" order="Boraginales" pageId="null" pageNumber="58" phylum="Tracheophyta" rank="species" species="officinalis">
Borago 
<normalizedToken id="DB26B6118721F069187AD04993A90559" originalValue="officinális" pageId="null" pageNumber="58">officinalis</normalizedToken>
<authorityName id="C071E97F738691F3D226AD8546BD3EE1" pageId="null" pageNumber="58">L.</authorityName>
