<subSubSection id="3F3FA9D9457EF49B153982668EB5103F" pageId="null" pageNumber="590" type="description">
<paragraph id="1D5AFD6E7934CD5A9E33DA2EBB8A4B06" pageId="null" pageNumber="590">
Unterscheidet sich von 
<taxonomicName id="10298BE9CDB32497B52037E4D78079C9" class="Magnoliopsida" family="Asteraceae" genus="Scorzonera" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="genus">
<emphasis id="F7C277BA03801B60A797D0B3E8E22B89" italics="true" pageId="null" pageNumber="590">Scorzonera</emphasis>
</taxonomicName>
(S. 600) durch folgende Merkmale: 
<emphasis id="DDFE758C9C59BE01BBA531B21946FEA5" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="1137BEB03E357A072FFD93DEC3F432FB" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
bis auf den Mittelnerv fiederteilig; 
<normalizedToken id="8B97F7DEF1BDDE64F3A599717CFC93AF" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
am Grunde mit einem heller 
<normalizedToken id="1E95BBD0F4F268D91D6877FA5B4F3CFD" originalValue="gefärbten" pageId="null" pageNumber="590">gefaerbten</normalizedToken>
, hohlen Stiel, der dicker ist als die Frucht
</emphasis>
(
<emphasis id="6598433E7808981D2A93C11801813A89" italics="true" pageId="null" pageNumber="590">die eigentliche Frucht deshalb wie ein Fruchtschnabel aussehend</emphasis>
).
</paragraph>
<paragraph id="35E1762E9F9D3680B3C6B1C7FA013B19" pageId="null" pageNumber="590">
Die Gattung 
<taxonomicName id="1D2A8CAC94D8D4DC95E72E82FCE59EC7" class="Magnoliopsida" family="Asteraceae" genus="Podospermum" higherTaxonomySource="GBIF" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="genus">
<emphasis id="83A2475B4122BA2F848558C79EABF4EA" italics="true" pageId="null" pageNumber="590">Podospermum</emphasis>
</taxonomicName>
<normalizedToken id="3132B279906C202C9A2BF8AEB87E9764" originalValue="umfaßt" pageId="null" pageNumber="590">umfasst</normalizedToken>
<emphasis id="49305831BA4D718AC26ECBA793E27110" italics="true" pageId="null" pageNumber="590">12 Arten</emphasis>
und hat vor allem 
<emphasis id="4AF5C16C1F616300C8D0279784DA2572" italics="true" pageId="null" pageNumber="590">westasiatisch-mediterrane Verbreitung. Chromosomengrundzahl:</emphasis>
n = 7.
</paragraph>
<paragraph id="48F1267DBDB02C156EA647D026E7BFEB" pageId="null" pageNumber="590">
