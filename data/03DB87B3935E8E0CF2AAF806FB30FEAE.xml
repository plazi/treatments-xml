<materialsCitation id="3B1A3CF8935E8E0CF2AAF84FFEEBFF1E" ID-GBIF-Occurrence="3798147311" collectorName="G. E. Ball &amp; J. Serrano" country="Russia" determinerName="George E. Ball" lastPageId="8" lastPageNumber="492" location="Moscou" pageId="7" pageNumber="491" specimenCount="2" stateProvince="Moscow" typeStatus="lectotype">
The specimen here designated as 
<typeStatus id="54C98807935E8E03F037F84FFDA0F83C" box="[522,625,2013,2039]" pageId="7" pageNumber="491">lectotype</typeStatus>
is a male bearing labels: “ 
<collectingRegion id="49B6F847935E8E03F1ACF84FFC22F83C" box="[913,1011,2013,2039]" country="Russia" name="Moscow" pageId="7" pageNumber="491">Moscou</collectingRegion>
”, “zabroides m. in 
<collectingCountry id="F3657635935E8E03F6F9F84FFAC5F83C" box="[1220,1300,2013,2039]" name="Russia" pageId="7" pageNumber="491">Russia</collectingCountry>
”, “ 
<collectorName id="26875373935E8E03F70EF84FFA4CF83C" box="[1331,1437,2013,2039]" pageId="7" pageNumber="491">G.E. Ball</collectorName>
H 18”, “ 
<taxonomicName id="4C724D2693518E0CF2CAFF05FDDCFF7A" authority="Dej." authorityName="Dejean" authorityYear="1829" box="[247,525,151,177]" class="Insecta" family="Carabidae" genus="Harpalus" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="492" phylum="Arthropoda" rank="species" species="zabroides">
<emphasis id="B906EAB793518E0CF2CAFF05FE04FF7A" box="[247,469,151,177]" italics="true" pageId="8" pageNumber="492">Harpalus zabroides</emphasis>
Dej.
</taxonomicName>
det. 
<determinerName id="7E11DA6193518E0CF078FF05FD21FF7A" box="[581,752,151,177]" pageId="8" pageNumber="492">George E. Ball</determinerName>
” and “ 
<typeStatus id="54C9880793518E0CF101FF05FC7EFF7A" box="[828,943,151,177]" pageId="8" pageNumber="492">Lectotype</typeStatus>
of 
<taxonomicName id="4C724D2693518E0CF1EBFF05FA83FF7A" authority="Dejean, 1829" authorityName="Dejean" authorityYear="1829" box="[982,1362,151,177]" class="Insecta" family="Carabidae" genus="Harpalus" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="492" phylum="Arthropoda" rank="species" species="zabroides">
<emphasis id="B906EAB793518E0CF1EBFF05FB65FF7A" box="[982,1204,151,177]" italics="true" pageId="8" pageNumber="492">Harpalus zabroides</emphasis>
<bibRefCitation id="EFE34B5493518E0CF681FF05FA83FF7A" author="Dejean, P. F. M. A." box="[1212,1362,151,177]" pageId="8" pageNumber="492" refId="ref10732" refString="Dejean, P. F. M. A. (1829) Species general des coleopteres de la collection de M. le Comte Dejean. Tome quatrieme. Mequignon- Marvis, Paris, vii + 520 pp." type="book" year="1829">Dejean, 1829</bibRefCitation>
</taxonomicName>
desig. by 
<collectorName id="2687537393518E0CF287FF29FEE1FF1E" box="[186,304,187,213]" pageId="8" pageNumber="492">J. Serrano</collectorName>
”
</materialsCitation>
.
</paragraph>
