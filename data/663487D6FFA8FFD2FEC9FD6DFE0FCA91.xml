<paragraph id="EE2236C0FFA8FFD2FF54FC0DFD4CCA31" blockId="3.[129,772,1008,1639]" pageId="3" pageNumber="60">
<emphasis id="DCE9EAD2FFA8FFD2FF54FC0DFF1EC851" bold="true" box="[129,247,1008,1031]" pageId="3" pageNumber="60">Diagnosis.</emphasis>
<taxonomicName id="299D4D43FFA8FFD2FF29FC0DFE57C851" authorityName="Cope" authorityYear="1894" box="[252,446,1008,1031]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="flexilis">
<emphasis id="DCE9EAD2FFA8FFD2FF29FC0DFE57C851" box="[252,446,1008,1031]" italics="true" pageId="3" pageNumber="60">Otocinclus flexilis</emphasis>
</taxonomicName>
is distinguished from all other 
<taxonomicName id="299D4D43FFA8FFD2FF54FBEDFF1FC871" authorityName="Schaefer" authorityYear="1997" box="[129,246,1040,1063]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="genus">
<emphasis id="DCE9EAD2FFA8FFD2FF54FBEDFF1FC871" box="[129,246,1040,1063]" italics="true" pageId="3" pageNumber="60">Otocinclus</emphasis>
</taxonomicName>
(except for 
<taxonomicName id="299D4D43FFA8FFD2FEA2FBEDFE1EC871" authorityName="Schaefer" authorityYear="1997" box="[375,503,1040,1063]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="xakriaba">
<emphasis id="DCE9EAD2FFA8FFD2FEA2FBEDFE63C871" box="[375,394,1040,1063]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FE42FBEDFE1EC871" box="[407,503,1040,1063]" italics="true" pageId="3" pageNumber="60">xakriaba</emphasis>
</taxonomicName>
, 
<taxonomicName id="299D4D43FFA8FFD2FDD1FBEDFD81C871" authorityName="Steindachner" authorityYear="1877" box="[516,616,1040,1063]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="affinis">
<emphasis id="DCE9EAD2FFA8FFD2FDD1FBEDFDFEC871" box="[516,535,1040,1063]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FDF1FBEDFD81C871" box="[548,616,1040,1063]" italics="true" pageId="3" pageNumber="60">affinis</emphasis>
</taxonomicName>
, 
<taxonomicName id="299D4D43FFA8FFD2FDA0FBEDFD15C871" authorityName="Steindachner" authorityYear="1915" box="[629,764,1040,1063]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="hasemani">
<emphasis id="DCE9EAD2FFA8FFD2FDA0FBEDFD61C871" box="[629,648,1040,1063]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FD40FBEDFD15C871" box="[661,764,1040,1063]" italics="true" pageId="3" pageNumber="60">hasemani</emphasis>
</taxonomicName>
, 
<taxonomicName id="299D4D43FFA8FFD2FF54FBCDFF06C811" authorityName="Regan" authorityYear="1909" box="[129,239,1072,1095]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="arnoldi">
<emphasis id="DCE9EAD2FFA8FFD2FF54FBCDFF7DC811" box="[129,148,1072,1095]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FF75FBCDFF06C811" box="[160,239,1072,1095]" italics="true" pageId="3" pageNumber="60">arnoldi</emphasis>
</taxonomicName>
, and 
<taxonomicName id="299D4D43FFA8FFD2FEFDFBCDFE4BC811" authorityName="Axenrot &amp; Kullander" authorityYear="2003" box="[296,418,1072,1095]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="mimulus">
<emphasis id="DCE9EAD2FFA8FFD2FEFDFBCDFED2C811" box="[296,315,1072,1095]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FE92FBCDFE4BC811" box="[327,418,1072,1095]" italics="true" pageId="3" pageNumber="60">mimulus</emphasis>
</taxonomicName>
) by possessing an iris operculum and (except for 
<taxonomicName id="299D4D43FFA8FFD2FEFDFBADFE41C831" authorityName="Schaefer" authorityYear="1997" box="[296,424,1104,1127]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="xakriaba">
<emphasis id="DCE9EAD2FFA8FFD2FEFDFBADFED2C831" box="[296,315,1104,1127]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FE9DFBADFE41C831" box="[328,424,1104,1127]" italics="true" pageId="3" pageNumber="60">xakriaba</emphasis>
</taxonomicName>
, 
<taxonomicName id="299D4D43FFA8FFD2FE60FBADFDCDC831" authorityName="Regan" authorityYear="1909" box="[437,548,1104,1127]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="arnoldi">
<emphasis id="DCE9EAD2FFA8FFD2FE60FBADFE21C831" box="[437,456,1104,1127]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FE00FBADFDCDC831" box="[469,548,1104,1127]" italics="true" pageId="3" pageNumber="60">arnoldi</emphasis>
</taxonomicName>
, and 
<taxonomicName id="299D4D43FFA8FFD2FD8BFBADFD30C831" authorityName="Axenrot &amp; Kullander" authorityYear="2003" box="[606,729,1104,1127]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="mimulus">
<emphasis id="DCE9EAD2FFA8FFD2FD8BFBADFD98C831" box="[606,625,1104,1127]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FDABFBADFD30C831" box="[638,729,1104,1127]" italics="true" pageId="3" pageNumber="60">mimulus</emphasis>
</taxonomicName>
) by having a lateral trunk coloration consisting of a series of 3-6 diffuse pigment blotches (
<figureCitation id="76A62A45FFA8FFD2FE4DFB6DFE33C8F1" box="[408,474,1168,1191]" captionStart="Fig" captionStartId="4.[136,174,1757,1780]" captionTargetBox="[174,1421,174,1742]" captionTargetId="figure-112@4.[174,1421,174,1742]" captionTargetPageId="4" captionText="Fig. 2. Color variation of Otocinclus flexilis. (a) and (b): MCP 17414, SL = 37.6 and 44.6 mm respectively.(c) and (d): MCP 18307, SL = 37.2 and 36.8 mm respectively." pageId="3" pageNumber="60">Fig. 2</figureCitation>
). An inconspicuous and not elevated patch of 0-10 (mode = 0, mean = 3.0) enlarged odontodes on the postero-dorsal parieto-supraoccipital tip, the pectoral skeleton with closed 
<emphasis id="DCE9EAD2FFA8FFD2FE2CFB0DFD49C951" box="[505,672,1264,1287]" italics="true" pageId="3" pageNumber="60">arrector fossae</emphasis>
, and the presence of a triangular pigment mark at the dorsal-fin base distinguishes 
<taxonomicName id="299D4D43FFA8FFD2FEC0FACDFE96C911" authorityName="Cope" authorityYear="1894" box="[277,383,1328,1351]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="flexilis">
<emphasis id="DCE9EAD2FFA8FFD2FEC0FACDFEC1C911" box="[277,296,1328,1351]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FEE2FACDFE96C911" box="[311,383,1328,1351]" italics="true" pageId="3" pageNumber="60">flexilis</emphasis>
</taxonomicName>
from 
<taxonomicName id="299D4D43FFA8FFD2FE17FACDFDADC911" authorityName="Schaefer" authorityYear="1997" box="[450,580,1328,1351]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="xakriaba">
<emphasis id="DCE9EAD2FFA8FFD2FE17FACDFE3CC911" box="[450,469,1328,1351]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FE31FACDFDADC911" box="[484,580,1328,1351]" italics="true" pageId="3" pageNumber="60">xakriaba</emphasis>
</taxonomicName>
, which possesses an elevated patch of enlarged odontodes on the parietosupraoccipital, has an open 
<emphasis id="DCE9EAD2FFA8FFD2FE6DFA8DFDB6C9D1" box="[440,607,1392,1415]" italics="true" pageId="3" pageNumber="60">arrector fossae</emphasis>
, and lacks the dorsal-fin mark. From 
<taxonomicName id="299D4D43FFA8FFD2FEA6FA6DFE0BC9F1" authorityName="Regan" authorityYear="1909" box="[371,482,1424,1447]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="arnoldi">
<emphasis id="DCE9EAD2FFA8FFD2FEA6FA6DFE6FC9F1" box="[371,390,1424,1447]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FE46FA6DFE0BC9F1" box="[403,482,1424,1447]" italics="true" pageId="3" pageNumber="60">arnoldi</emphasis>
</taxonomicName>
and 
<taxonomicName id="299D4D43FFA8FFD2FDC3FA6DFD78C9F1" authorityName="Axenrot &amp; Kullander" authorityYear="2003" box="[534,657,1424,1447]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="mimulus">
<emphasis id="DCE9EAD2FFA8FFD2FDC3FA6DFDC0C9F1" box="[534,553,1424,1447]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FDE3FA6DFD78C9F1" box="[566,657,1424,1447]" italics="true" pageId="3" pageNumber="60">mimulus</emphasis>
</taxonomicName>
it is easily distinguished by having six branched pectoral-fin rays (
<emphasis id="DCE9EAD2FFA8FFD2FD33FA4DFD15C991" box="[742,764,1456,1479]" italics="true" pageId="3" pageNumber="60">vs</emphasis>
. five branched rays) and few (0-10, mode = 0, mean = 3.0) not elevated enlarged odontodes on the parieto-supraoccipital tip (
<emphasis id="DCE9EAD2FFA8FFD2FF7BF9EDFF2DCA71" box="[174,196,1552,1575]" italics="true" pageId="3" pageNumber="60">vs</emphasis>
. 2-23, mode = 7, mean = 8.3) not elevated enlarged odontodes in 
<taxonomicName id="299D4D43FFA8FFD2FECDF9CDFE62CA11" authorityName="Regan" authorityYear="1909" box="[280,395,1584,1607]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="arnoldi">
<emphasis id="DCE9EAD2FFA8FFD2FECDF9CDFEC2CA11" box="[280,299,1584,1607]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FEE9F9CDFE62CA11" box="[316,395,1584,1607]" italics="true" pageId="3" pageNumber="60">arnoldi</emphasis>
</taxonomicName>
and 5-14, mode = 7, mean = 8.4 conspicuously elevated odontodes in 
<taxonomicName id="299D4D43FFA8FFD2FDCDF9ADFD7DCA31" authorityName="Axenrot &amp; Kullander" authorityYear="2003" box="[536,660,1616,1639]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="mimulus">
<emphasis id="DCE9EAD2FFA8FFD2FDCDF9ADFDC2CA31" box="[536,555,1616,1639]" italics="true" pageId="3" pageNumber="60">O</emphasis>
. 
<emphasis id="DCE9EAD2FFA8FFD2FDECF9ADFD7DCA31" box="[569,660,1616,1639]" italics="true" pageId="3" pageNumber="60">mimulus</emphasis>
</taxonomicName>
).
</paragraph>
</subSubSection>
<subSubSection id="A687654BFFA8FFD2FF54F96DFE0FCA91" pageId="3" pageNumber="60" type="distribution">
<paragraph id="EE2236C0FFA8FFD2FF54F96DFE0FCA91" blockId="3.[129,771,1680,1735]" pageId="3" pageNumber="60">
<emphasis id="DCE9EAD2FFA8FFD2FF54F96DFEFCCAF1" bold="true" box="[129,277,1680,1703]" pageId="3" pageNumber="60">Distribution.</emphasis>
<taxonomicName id="299D4D43FFA8FFD2FEC8F96DFE0ACAF1" authorityName="Cope" authorityYear="1894" box="[285,483,1680,1703]" class="Actinopterygii" family="Loricariidae" genus="Otocinclus" kingdom="Animalia" order="Siluriformes" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="flexilis">
<emphasis id="DCE9EAD2FFA8FFD2FEC8F96DFE0ACAF1" box="[285,483,1680,1703]" italics="true" pageId="3" pageNumber="60">Otocinclus flexilis</emphasis>
</taxonomicName>
is restricted to the laguna dos Patos drainage basin (
<figureCitation id="76A62A45FFA8FFD2FE42F94DFE31CA91" box="[407,472,1712,1735]" captionStart="Fig" captionStartId="8.[136,174,752,775]" captionTargetBox="[156,753,185,739]" captionTargetId="figure-1800@8.[144,771,174,745]" captionTargetPageId="8" captionText="Fig. 5. Geographic distribution of Otocinclus flexilis (triangles) and O. arnoldi (dots). Open dot represents paratypes of O. mimulus. One symbol may cover more than one lot or locality." pageId="3" pageNumber="60">Fig. 5</figureCitation>
).
</paragraph>
