<subSubSection id="C32E54C8161FFFF0B59EE0076A77C9A6" pageId="9" pageNumber="325" type="diagnosis">
<paragraph id="8B8B0743161FFFF0B59EE0076A4DCE46" blockId="9.[160,1156,800,930]" box="[160,276,800,826]" pageId="9" pageNumber="325">
<emphasis id="B940DB51161FFFF0B59EE0076A4DCE46" bold="true" box="[160,276,800,826]" italics="true" pageId="9" pageNumber="325">Diagnosis</emphasis>
</paragraph>
<paragraph id="8B8B0743161FFFF0B59EE0636A2CCEDE" blockId="9.[160,1156,800,930]" pageId="9" pageNumber="325">The soldier caste of this species is easily identified by the yellow blotch over the first and second gastral tergites; head, mesosoma and gaster end dark brown; minor workers are completely yellow.</paragraph>
<paragraph id="8B8B0743161FFFF0B59EE0EA6A2ECE9B" blockId="9.[160,1155,973,1103]" box="[160,375,973,999]" pageId="9" pageNumber="325">
<emphasis id="B940DB51161FFFF0B59EE0EA6A2ECE9B" bold="true" box="[160,375,973,999]" italics="true" pageId="9" pageNumber="325">Geographic range</emphasis>
</paragraph>
<paragraph id="8B8B0743161FFFF0B59EE0D5689AC933" blockId="9.[160,1155,973,1103]" pageId="9" pageNumber="325">
<taxonomicName id="4C347CC0161FFFF0B59EE0D56ADEC976" authorityName="Forel" authorityYear="1890" box="[160,391,1010,1034]" class="Insecta" family="Formicidae" genus="Camponotus" kingdom="Animalia" order="Hymenoptera" pageId="9" pageNumber="325" phylum="Arthropoda" rank="species" species="atlantis">
<emphasis id="B940DB51161FFFF0B59EE0D56ADEC976" box="[160,391,1010,1034]" italics="true" pageId="9" pageNumber="325">Camponotus atlantis</emphasis>
</taxonomicName>
was described from 
<collectingCountry id="F32347D3161FFFF0B7BFE0D56989C976" box="[641,720,1010,1034]" name="Tunisia" pageId="9" pageNumber="325">Tunisia</collectingCountry>
and has been recorded from several countries in the Arabian Peninsula including 
<collectingCountry id="F32347D3161FFFF0B7A5E733699EC950" box="[667,711,1044,1068]" name="Saudi Arabia" pageId="9" pageNumber="325">KSA</collectingCountry>
(
<bibRefCitation id="EFA57AB2161FFFF0B7EAE73368FAC950" author="Collingwood CA" box="[724,931,1044,1068]" pageId="9" pageNumber="325" pagination="230 - 302" refId="ref18149" refString="Collingwood CA. 1985. Hymenoptera: fam. Formicidae of Saudi Arabia. Fauna Saudi Arabia. 7: 230 - 302." type="journal article" year="1985">Collingwood 1985</bibRefCitation>
), 
<collectingCountry id="F32347D3161FFFF0B689E73368A2C950" box="[951,1019,1044,1068]" name="Oman" pageId="9" pageNumber="325">Oman</collectingCountry>
and 
<collectingCountry id="F32347D3161FFFF0B10BE7336FDAC950" box="[1077,1155,1044,1068]" name="Yemen" pageId="9" pageNumber="325">Yemen</collectingCountry>
(
<bibRefCitation id="EFA57AB2161FFFF0B598E7106AA3C933" author="Collingwood CA &amp; Agosti D" box="[166,506,1079,1103]" pageId="9" pageNumber="325" pagination="300 - 385" refId="ref18173" refString="Collingwood CA, Agosti D. 1996. Formicidae (Insecta: Hymenoptera) of Saudi Arabia (part 2). Fauna of Saudi Arabia. 15: 300 - 385." type="journal article" year="1996">Collingwood and Agosti 1996</bibRefCitation>
), and 
<collectingCountry id="F32347D3161FFFF0B77DE71069C1C933" box="[579,664,1079,1103]" name="Yemen" pageId="9" pageNumber="325">Socotra</collectingCountry>
(
<bibRefCitation id="EFA57AB2161FFFF0B798E71068EEC933" author="Collingwood CA &amp; Pohl H &amp; Guesten R &amp; Wranik W &amp; Van Harten A" box="[678,951,1079,1103]" pageId="9" pageNumber="325" pagination="473 - 495" refId="ref18239" refString="Collingwood CA, Pohl H, Guesten R, Wranik W, Van Harten A. 2004. The ants (Insecta: Hymenoptera: Formicidae) of the Socotra Archipelago. Fauna of Arabia. 20: 473 - 495." type="journal article" year="2004">Collingwood et al. 2004</bibRefCitation>
).
</paragraph>
<paragraph id="8B8B0743161FFFF0B59EE75D694CC9E8" blockId="9.[160,1155,1146,1242]" box="[160,533,1146,1172]" pageId="9" pageNumber="325">
<emphasis id="B940DB51161FFFF0B59EE75D694CC9E8" bold="true" box="[160,533,1146,1172]" italics="true" pageId="9" pageNumber="325">Ecological and biological notes</emphasis>
</paragraph>
<paragraph id="8B8B0743161FFFF0B59EE7B86A77C9A6" blockId="9.[160,1155,1146,1242]" pageId="9" pageNumber="325">
Colonies of 
<taxonomicName id="4C347CC0161FFFF0B412E7B8694BC9CB" authorityName="Forel" authorityYear="1890" box="[300,530,1183,1207]" class="Insecta" family="Formicidae" genus="Camponotus" kingdom="Animalia" order="Hymenoptera" pageId="9" pageNumber="325" phylum="Arthropoda" rank="species" species="atlantis">
<emphasis id="B940DB51161FFFF0B412E7B8694BC9CB" box="[300,530,1183,1207]" italics="true" pageId="9" pageNumber="325">Camponotus atlantis</emphasis>
</taxonomicName>
are commonly found under rocks next to and under 
<taxonomicName id="4C347CC0161FFFF0B59EE7E56BB1C9A6" box="[160,232,1218,1242]" class="Magnoliopsida" family="Fabaceae" genus="Acacia" kingdom="Plantae" order="Fabales" pageId="9" pageNumber="325" phylum="Tracheophyta" rank="genus">
<emphasis id="B940DB51161FFFF0B59EE7E56BB1C9A6" box="[160,232,1218,1242]" italics="true" pageId="9" pageNumber="325">Acacia</emphasis>
</taxonomicName>
trees.
</paragraph>
</subSubSection>
