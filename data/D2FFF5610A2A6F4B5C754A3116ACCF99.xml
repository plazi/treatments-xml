<subSubSection id="5B871C8FE8CCD85B2299C8B1195C464C" pageId="null" pageNumber="406" type="description">
<paragraph id="26A63BF07D663B47922FD7BECED7252E" pageId="null" pageNumber="406">
10-40 cm hoch, unterirdische 
<normalizedToken id="5A021FC5A29C230AD9B1CAD841A9877D" originalValue="Ausläufer" pageId="null" pageNumber="406">Auslaeufer</normalizedToken>
treibend. Stengel aufrecht oder bogig aufsteigend, im obern Teil stumpf 3kantig. 
<normalizedToken id="AA5E65F0EA5AEBB3CEB892D15CAC853F" originalValue="Blätter" pageId="null" pageNumber="406">Blaetter</normalizedToken>
bis 4 mm breit, 
<emphasis id="815FF259C597D9C61178801A9E94F774" italics="true" pageId="null" pageNumber="406">
vom Grunde an 
<normalizedToken id="8EAD136843B13CE151F9CFF5CD29AEE6" originalValue="allmählich" pageId="null" pageNumber="406">allmaehlich</normalizedToken>
<normalizedToken id="265F1FD7E7265ADC5B68D043CC01506A" originalValue="verschmälert" pageId="null" pageNumber="406">verschmaelert</normalizedToken>
</emphasis>
, oberseits flach oder 
<emphasis id="FE19B3EE58301B41E392C02D2CD11B89" italics="true" pageId="null" pageNumber="406">hohlrinnig</emphasis>
, unterseits gekielt, 
<emphasis id="DD87968B92FDB76013BE5A1DF8A6B0ED" italics="true" pageId="null" pageNumber="406">
fleischig, 
<normalizedToken id="022338AE6C7947615F7F41E102B18632" originalValue="dunkelgrün" pageId="null" pageNumber="406">dunkelgruen</normalizedToken>
, auffallend 
<normalizedToken id="496AB446EDEBE116854E67DFCE6D14CF" originalValue="glänzend" pageId="null" pageNumber="406">glaenzend</normalizedToken>
.
</emphasis>
<normalizedToken id="AFEE298714D0217483DCD0B6B44AFA47" originalValue="Blütenstand" pageId="null" pageNumber="406">Bluetenstand</normalizedToken>
1,5-3 cm lang, aus 5-15 
<normalizedToken id="56EE5C0EF9C765E3E68A16B9792B2FDF" originalValue="Ähren" pageId="null" pageNumber="406">Aehren</normalizedToken>
. 
<normalizedToken id="0D5B7B8A3E6CAEE60A6B6914FE54387B" originalValue="Tragblätter" pageId="null" pageNumber="406">Tragblaetter</normalizedToken>
braun, mit hellem Rand und hellem Mittelnerv. Perigonborsten 
<normalizedToken id="4C7E15B7E76F21BAE4BBC28F08ABA363" originalValue="länger" pageId="null" pageNumber="406">laenger</normalizedToken>
als die reife, ca. 2 mm lange, braune, 
<normalizedToken id="B39749E4755F62EC62C490485F528B12" originalValue="glänzende" pageId="null" pageNumber="406">glaenzende</normalizedToken>
Frucht.
</paragraph>
<paragraph id="5135785223D89014B27306CAAB0DC757" pageId="null" pageNumber="406">
<emphasis id="741DD21FB416731FA242F25490F9625E" italics="true" pageId="null" pageNumber="406">Zytologische Angaben. 2n = 54:</emphasis>
Material aus Schweden (
<normalizedToken id="50FA608D0D31A5EACE28E5577C7A8070" originalValue="Håkansson" pageId="null" pageNumber="406">Hakansson</normalizedToken>
1927).
</paragraph>
<paragraph id="853254D74961C1137E9E46586D715284" pageId="null" pageNumber="406">
<emphasis id="6294B3F07D235D33F611E4CAE926DBE2" italics="true" pageId="null" pageNumber="406">Standort.</emphasis>
Kollin, montan und subalpin. Nasse, lehmige bis humose, meist kalkhaltige 
<normalizedToken id="FACABBC7A21FA1FC683B6AA3DD614B84" originalValue="Böden" pageId="null" pageNumber="406">Boeden</normalizedToken>
. Flachmoore (besonders im 
<emphasis id="14ADB201951B5AE2FE2F369CDEB069E9" italics="true" pageId="null" pageNumber="406">Caricetum Davallianae</emphasis>
W. Koch 1926), Waldwege (Tretgesellschaften).
</paragraph>
<paragraph id="90EF263D036E0D4B1930E971ABD72487" pageId="null" pageNumber="406">
<emphasis id="46CA144C79AB586F7D88369849D1901A" italics="true" pageId="null" pageNumber="406">Verbreitung. Eurasiatische Pflanze:</emphasis>
<normalizedToken id="0C8CBCF98280FB5E2DFD573B5D00D36F" originalValue="Nordwärts" pageId="null" pageNumber="406">Nordwaerts</normalizedToken>
bis Schottland, 
<normalizedToken id="733C7E4BEA0439E1879DD4659D5A4C75" originalValue="Südskandinavien" pageId="null" pageNumber="406">Suedskandinavien</normalizedToken>
(bis 61° NB), Baltikum, 
<normalizedToken id="B7BA6E61C6F0FD239CF93BBC64B5E9AB" originalValue="südliches" pageId="null" pageNumber="406">suedliches</normalizedToken>
Dwinagebiet, 
<normalizedToken id="8F01FE39E079F957E70FB8355F8E223A" originalValue="südwärts" pageId="null" pageNumber="406">suedwaerts</normalizedToken>
bis 
<normalizedToken id="BE7B742A64C055CD2172769159DA2F50" originalValue="Südfrankreich" pageId="null" pageNumber="406">Suedfrankreich</normalizedToken>
, Sardinien, 
<normalizedToken id="E4939FC2A924D1218E78339DFACD2987" originalValue="Süditalien" pageId="null" pageNumber="406">Sueditalien</normalizedToken>
, Griechenland, Kleinasien, durch 
<normalizedToken id="70E5C35ADADA1F86EF7E507F03977575" originalValue="Südrußland" pageId="null" pageNumber="406">Suedrussland</normalizedToken>
und den Kaukasus 
<normalizedToken id="8EBB519B1B954D4D347D4F894E937AB0" originalValue="ostwärts" pageId="null" pageNumber="406">ostwaerts</normalizedToken>
zerstreut durch zentralasiatische Gebirge bis an den Baikalsee. Verbreitungskarte von Meusel (1964). - Im Gebiet verbreitet; ziemlich 
<normalizedToken id="AFCAC7B0832F4427458AAA5C5D5CF8D5" originalValue="häufig" pageId="null" pageNumber="406">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
