<paragraph id="214B93A6B285CFE90DE750EAA350021C" pageId="0" pageNumber="91">
<taxonomicName id="41708FF915598CA6AC22A970D8900B06" authorityName="Fassou &amp; Korotkova &amp; Nersesyan &amp; Koch &amp; Dimopoulos &amp; Borsch" authorityYear="2022" baseAuthorityName="Fassou &amp; Korotkova &amp; Nersesyan &amp; Koch &amp; Dimopoulos &amp; Borsch" baseAuthorityYear="2022" class="Magnoliopsida" family="Caryophyllaceae" genus="Saponaria" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Saponaria cretica" order="Caryophyllales" pageId="0" pageNumber="91" phylum="Tracheophyta" rank="species" species="cretica" status="comb. nov.">= Saponaria cretica</taxonomicName>
