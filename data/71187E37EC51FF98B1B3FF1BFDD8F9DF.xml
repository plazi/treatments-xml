, wingspan 
<quantity id="3E4962C4EC51FF9EB2C0F8D7FBC7F8A8" box="[996,1117,1883,1910]" metricMagnitude="-2" metricUnit="m" metricValue="2.55" metricValueMax="2.6" metricValueMin="2.5" pageId="2" pageNumber="69" unit="mm" value="25.5" valueMax="26.0" valueMin="25.0">25–26 mm</quantity>
in male; 
<quantity id="3E4962C4EC51FF9EB5E3F8D7FA8CF8A8" box="[1223,1302,1883,1909]" metricMagnitude="-2" metricUnit="m" metricValue="1.4" pageId="2" pageNumber="69" unit="mm" value="14.0">14 mm</quantity>
