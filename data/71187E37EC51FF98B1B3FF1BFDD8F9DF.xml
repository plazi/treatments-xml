<taxonomicName id="3EB1B4A2EC51FF9EB084FA79FD3AF9D1" box="[416,672,1525,1549]" class="Insecta" family="Limacodidae" genus="Pseudohampsonella" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="69" phylum="Arthropoda" rank="species" species="undetermined">
<emphasis id="CBC51333EC51FF9EB084FA79FDF6F9D0" box="[416,620,1525,1549]" italics="true" pageId="2" pageNumber="69">Pseudohampsonella</emphasis>
spp.
</taxonomicName>
: 
<emphasis id="CBC51333EC51FF9EB38EFA79FD27F9D0" bold="true" box="[682,701,1525,1549]" pageId="2" pageNumber="69">1.</emphasis>
<taxonomicName id="3EB1B4A2EC51FF9EB3E7FA79FCC9F9D0" authority="Wu &amp; Zhao &amp; Han, 2022" authorityName="Wu &amp; Zhao &amp; Han" authorityYear="2022" box="[707,851,1525,1549]" class="Insecta" family="Limacodidae" genus="Pseudohampsonella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="69" phylum="Arthropoda" rank="species" species="medogensis" status="sp. nov.">
<emphasis id="CBC51333EC51FF9EB3E7FA79FCC9F9D0" box="[707,851,1525,1549]" italics="true" pageId="2" pageNumber="69">P. medogensis</emphasis>
</taxonomicName>
<emphasis id="CBC51333EC51FF9EB27DFA79FC30F9D0" bold="true" box="[857,938,1525,1549]" pageId="2" pageNumber="69">
<taxonomicNameLabel id="D0F6AE48EC51FF9EB27DFA79FC30F9D0" box="[857,938,1525,1549]" pageId="2" pageNumber="69" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
, male, holotype, Xizang, China (in NEFU); 
<emphasis id="CBC51333EC51FF9EB454FA79FA19F9D0" bold="true" box="[1392,1411,1525,1549]" pageId="2" pageNumber="69">2.</emphasis>
<taxonomicName id="3EB1B4A2EC51FF9EB4AEFA79FE97F9EC" authority="Wu &amp; Zhao &amp; Han, 2022" authorityName="Wu &amp; Zhao &amp; Han" authorityYear="2022" class="Insecta" family="Limacodidae" genus="Pseudohampsonella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="69" phylum="Arthropoda" rank="species" species="medogensis" status="sp. nov.">
<emphasis id="CBC51333EC51FF9EB4AEFA79FE97F9EC" italics="true" pageId="2" pageNumber="69">P. medogensis</emphasis>
</taxonomicName>
<emphasis id="CBC51333EC51FF9EB031F995FEFDF9EC" bold="true" box="[277,359,1561,1585]" pageId="2" pageNumber="69">
<taxonomicNameLabel id="D0F6AE48EC51FF9EB031F995FEFDF9EC" box="[277,359,1561,1585]" pageId="2" pageNumber="69" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
, female, paratype, Xizang, China (in NEFU); 
<emphasis id="CBC51333EC51FF9EB263F995FCC3F9EC" bold="true" box="[839,857,1561,1585]" pageId="2" pageNumber="69">3.</emphasis>
<taxonomicName id="3EB1B4A2EC51FF9EB245F995FB00F9EC" authority="Wu &amp; Pan, 2015" authorityName="Wu &amp; Pan" authorityYear="2015" box="[865,1178,1561,1585]" class="Insecta" family="Limacodidae" genus="Pseudohampsonella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="69" phylum="Arthropoda" rank="species" species="bayizhena">
<emphasis id="CBC51333EC51FF9EB245F995FC79F9EC" box="[865,995,1561,1585]" italics="true" pageId="2" pageNumber="69">P. bayizhena</emphasis>
Wu &amp; 
<bibRefCitation id="9D20B2D0EC51FF9EB514F995FB00F9EC" author="Pan, Z. H. &amp; Wu, C. S." box="[1072,1178,1561,1585]" pageId="2" pageNumber="69" pagination="393 - 400" refId="ref4226" refString="Pan, Z. H. &amp; Wu, C. S. (2015) New and little known Limacodidae (Lepidoptera) from Xizang, China. Zootaxa, 3999 (3), 393 - 400. https: // doi. org / 10.11646 / zootaxa. 3999.3.4" type="journal article" year="2015">Pan, 2015</bibRefCitation>
</taxonomicName>
, male, Xizang, China (in NEFU); 
<emphasis id="CBC51333EC51FF9EB1CBF9B1FE98F988" bold="true" box="[239,258,1597,1621]" pageId="2" pageNumber="69">4.</emphasis>
<taxonomicName id="3EB1B4A2EC51FF9EB02CF9B1FD1EF988" authority="Solovyev &amp; Saldaitis, 2014" authorityName="Solovyev &amp; Saldaitis" authorityYear="2014" box="[264,644,1597,1621]" class="Insecta" family="Limacodidae" genus="Pseudohampsonella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="2" pageNumber="69" phylum="Arthropoda" rank="species" species="hoenei">
