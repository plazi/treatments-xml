<emphasis id="B93FEA87FF8AEE6EFBC6FAC0F5C22E2B" bold="true" box="[1040,1265,1320,1339]" italics="true" pageId="24" pageNumber="23">G. teopiscaensis</emphasis>
</taxonomicName>
