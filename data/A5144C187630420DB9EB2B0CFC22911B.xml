<paragraph id="2D02FD0E7630420DB9962B9AFC22911B" blockId="6.[166,1225,994,1149]" pageId="6" pageNumber="373">
Diagnosis. 
<taxonomicName id="EABD868D7630420DB83B2B9BF9E5969A" authorityName="Constantineanu" authorityYear="1973" box="[374,490,995,1021]" class="Insecta" family="Ichneumonidae" genus="Schizopyga" kingdom="Animalia" order="Hymenoptera" pageId="6" pageNumber="373" phylum="Arthropoda" rank="species" species="coxator">
<emphasis id="1FC9211C7630420DB83B2B9BF9E5969A" box="[374,490,995,1021]" italics="true" pageId="6" pageNumber="373">S. coxator</emphasis>
</taxonomicName>
(
<figureCitation id="B586E18B7630420DB8B52B9AFA38969B" box="[504,567,994,1021]" captionStart="Fig" captionStartId="7.[174,205,1238,1260]" captionTargetBox="[265,1142,174,1221]" captionTargetId="figure-303@7.[265,1142,174,1221]" captionTargetPageId="7" captionText="Fig. 4. Schizopyga and Sinarachna, ♀. 1–5 — Schizopyga: 1 — S. coxator, habitus (lateral view); 2 — S. circulator, face (frontal view);3 — S.coxator, face (frontal view);4 — S.coxator, pronotum (lateral view); 5 — S.circulator, pronotum (lateral view); 6–7 — Sinarachna, tergites III–IV of metasoma (dorsal view):6 — S. pallipes; 7 — S. nigricornis." figureDoi="http://doi.org/10.5281/zenodo.6449483" httpUri="https://zenodo.org/record/6449483/files/figure.png" pageId="6" pageNumber="373">FIg. 4</figureCitation>
, 
<figureCitation id="B586E18B7630420DBB092B9BFA5D969B" box="[580,594,995,1021]" captionStart="Fig" captionStartId="3.[174,207,1769,1791]" captionTargetBox="[276,1153,630,1748]" captionTargetId="figure-150@3.[276,1153,630,1748]" captionTargetPageId="3" captionText="Fig. 1. Clistopyga, ♀. 1, 3, 5, 7 — metapleuron (lateral view): 1 — C. incitator; 3 — C. rufator; 5 — C. canadensis; 7 — C. sziladyi; 2, 4, 6, 8 — ovipositor (lateral view): 1 — C. incitator; 3 — C. rufator; 5 — C. canadensis; 7 — C. sziladyi." figureDoi="http://doi.org/10.5281/zenodo.6449473" httpUri="https://zenodo.org/record/6449473/files/figure.png" pageId="6" pageNumber="373">
<emphasis id="1FC9211C7630420DBB092B9BFA5D969B" box="[580,594,995,1021]" italics="true" pageId="6" pageNumber="373">1</emphasis>
</figureCitation>
) is similar in coloration to 
<taxonomicName id="EABD868D7630420DBAD42B9BFC2A969A" baseAuthorityName="Panzer" baseAuthorityYear="1800" box="[921,1061,994,1021]" class="Insecta" family="Ichneumonidae" genus="Schizopyga" kingdom="Animalia" order="Hymenoptera" pageId="6" pageNumber="373" phylum="Arthropoda" rank="species" species="circulator">
<emphasis id="1FC9211C7630420DBAD42B9BFC2A969A" box="[921,1061,994,1021]" italics="true" pageId="6" pageNumber="373">S. circulator</emphasis>
</taxonomicName>
, but it can be distinguished by the partly yellow face (
<figureCitation id="B586E18B7630420DBB202C7AFAA6917B" box="[621,681,1026,1053]" captionStart="Fig" captionStartId="7.[174,205,1238,1260]" captionTargetBox="[265,1142,174,1221]" captionTargetId="figure-303@7.[265,1142,174,1221]" captionTargetPageId="7" captionText="Fig. 4. Schizopyga and Sinarachna, ♀. 1–5 — Schizopyga: 1 — S. coxator, habitus (lateral view); 2 — S. circulator, face (frontal view);3 — S.coxator, face (frontal view);4 — S.coxator, pronotum (lateral view); 5 — S.circulator, pronotum (lateral view); 6–7 — Sinarachna, tergites III–IV of metasoma (dorsal view):6 — S. pallipes; 7 — S. nigricornis." figureDoi="http://doi.org/10.5281/zenodo.6449483" httpUri="https://zenodo.org/record/6449483/files/figure.png" pageId="6" pageNumber="373">FIg. 4</figureCitation>
, 
<figureCitation id="B586E18B7630420DBBF92C7BFACD917B" box="[692,706,1027,1053]" captionStart="Fig" captionStartId="5.[174,207,1005,1027]" captionTargetBox="[259,1136,176,991]" captionTargetId="figure-342@5.[259,1136,175,991]" captionTargetPageId="5" captionText="Fig. 3. Polysphincta, ♀. 1–2 — metapleuron (lateral view): 1 — P. tuberosa; 2 — P. vexator; 3–5 — metasoma (dorsal view): 3 — P. tuberosa, tergites III–IV; 4 — P. rufipes, tergites II–IV; 5 — P. vexator, tergites II–IV." figureDoi="http://doi.org/10.5281/zenodo.6449479" httpUri="https://zenodo.org/record/6449479/files/figure.png" pageId="6" pageNumber="373">
<emphasis id="1FC9211C7630420DBBF92C7BFACD917B" box="[692,706,1027,1053]" italics="true" pageId="6" pageNumber="373">3</emphasis>
</figureCitation>
) (completely black in 
<taxonomicName id="EABD868D7630420DBA8F2C7BFC43917A" baseAuthorityName="Panzer" baseAuthorityYear="1800" box="[962,1100,1026,1053]" class="Insecta" family="Ichneumonidae" genus="Schizopyga" kingdom="Animalia" order="Hymenoptera" pageId="6" pageNumber="373" phylum="Arthropoda" rank="species" species="circulator">
<emphasis id="1FC9211C7630420DBA8F2C7BFC43917A" box="[962,1100,1026,1053]" italics="true" pageId="6" pageNumber="373">S. circulator</emphasis>
</taxonomicName>
(
<figureCitation id="B586E18B7630420DBD142C7AFC9A917B" box="[1113,1173,1026,1053]" captionStart="Fig" captionStartId="7.[174,205,1238,1260]" captionTargetBox="[265,1142,174,1221]" captionTargetId="figure-303@7.[265,1142,174,1221]" captionTargetPageId="7" captionText="Fig. 4. Schizopyga and Sinarachna, ♀. 1–5 — Schizopyga: 1 — S. coxator, habitus (lateral view); 2 — S. circulator, face (frontal view);3 — S.coxator, face (frontal view);4 — S.coxator, pronotum (lateral view); 5 — S.circulator, pronotum (lateral view); 6–7 — Sinarachna, tergites III–IV of metasoma (dorsal view):6 — S. pallipes; 7 — S. nigricornis." figureDoi="http://doi.org/10.5281/zenodo.6449483" httpUri="https://zenodo.org/record/6449483/files/figure.png" pageId="6" pageNumber="373">FIg. 4</figureCitation>
, 
<figureCitation id="B586E18B7630420DBDED2C7BFCA1917B" box="[1184,1198,1027,1053]" captionStart="Fig" captionStartId="4.[166,199,1022,1044]" captionTargetBox="[250,1127,175,996]" captionTargetId="figure-223@4.[250,1127,175,997]" captionTargetPageId="4" captionText="Fig. 2. Clistopyga, face (frontal view), Ơ: 1 — C. rufator; 2 — C. incitator; 3 — C. canadensis; 4 — C. sziladyi." figureDoi="http://doi.org/10.5281/zenodo.6449475" httpUri="https://zenodo.org/record/6449475/files/figure.png" pageId="6" pageNumber="373">
<emphasis id="1FC9211C7630420DBDED2C7BFCA1917B" box="[1184,1198,1027,1053]" italics="true" pageId="6" pageNumber="373">2</emphasis>
</figureCitation>
)), pale yellow fore and middle coxae (red with black marks in 
<taxonomicName id="EABD868D7630420DBA3F2C5BFBF0915A" baseAuthorityName="Panzer" baseAuthorityYear="1800" box="[882,1023,1058,1085]" class="Insecta" family="Ichneumonidae" genus="Schizopyga" kingdom="Animalia" order="Hymenoptera" pageId="6" pageNumber="373" phylum="Arthropoda" rank="species" species="circulator">
<emphasis id="1FC9211C7630420DBA3F2C5BFBF0915A" box="[882,1023,1058,1085]" italics="true" pageId="6" pageNumber="373">S. circulator</emphasis>
</taxonomicName>
), hind tibia with only apical dark band (subbasally and apically dark banded in 
<taxonomicName id="EABD868D7630420DBACB2C3BFC1D913A" baseAuthorityName="Panzer" baseAuthorityYear="1800" box="[902,1042,1090,1117]" class="Insecta" family="Ichneumonidae" genus="Schizopyga" kingdom="Animalia" order="Hymenoptera" pageId="6" pageNumber="373" phylum="Arthropoda" rank="species" species="circulator">
<emphasis id="1FC9211C7630420DBACB2C3BFC1D913A" box="[902,1042,1090,1117]" italics="true" pageId="6" pageNumber="373">S. circulator</emphasis>
</taxonomicName>
), weakly raised anterior part of pronotum (
<figureCitation id="B586E18B7630420DB8AA2C1AFA30911B" box="[487,575,1122,1149]" captionStart="Fig" captionStartId="7.[174,205,1238,1260]" captionTargetBox="[265,1142,174,1221]" captionTargetId="figure-303@7.[265,1142,174,1221]" captionTargetPageId="7" captionText="Fig. 4. Schizopyga and Sinarachna, ♀. 1–5 — Schizopyga: 1 — S. coxator, habitus (lateral view); 2 — S. circulator, face (frontal view);3 — S.coxator, face (frontal view);4 — S.coxator, pronotum (lateral view); 5 — S.circulator, pronotum (lateral view); 6–7 — Sinarachna, tergites III–IV of metasoma (dorsal view):6 — S. pallipes; 7 — S. nigricornis." figureDoi="http://doi.org/10.5281/zenodo.6449483" httpUri="https://zenodo.org/record/6449483/files/figure.png" pageId="6" pageNumber="373">
FIg. 4, 
<emphasis id="1FC9211C7630420DBB7C2C1BFA30911B" box="[561,575,1123,1149]" italics="true" pageId="6" pageNumber="373">4</emphasis>
</figureCitation>
) (sharply raised in 
<taxonomicName id="EABD868D7630420DBA6F2C1BFBA1911A" baseAuthorityName="Panzer" baseAuthorityYear="1800" box="[802,942,1122,1149]" class="Insecta" family="Ichneumonidae" genus="Schizopyga" kingdom="Animalia" order="Hymenoptera" pageId="6" pageNumber="373" phylum="Arthropoda" rank="species" species="circulator">
<emphasis id="1FC9211C7630420DBA6F2C1BFBA1911A" box="[802,942,1122,1149]" italics="true" pageId="6" pageNumber="373">S. circulator</emphasis>
