<emphasis id="B965A961647DFFE28A574D9AFD5E147F" box="[366,699,1519,1545]" italics="true" pageId="13" pageNumber="50">Heteroberdeniella jaramensis</emphasis>
(Wagner)
</taxonomicName>
, 
<emphasis id="B965A961647DFFE288004D9AFC5C147F" bold="true" box="[825,953,1519,1545]" pageId="13" pageNumber="50">
