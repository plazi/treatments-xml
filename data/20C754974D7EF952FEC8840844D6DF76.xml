<subSubSection id="0999E609C3D95B0B18DB8974DB27991A" pageId="null" pageNumber="546" type="description">
<paragraph id="B2B46D1383BF5C57D9C00590F1169F70" pageId="null" pageNumber="546">
Die sich von 
<taxonomicName id="259BABA0E56A4F3BBD381C42E8EBDDA2" class="Magnoliopsida" family="Asteraceae" genus="Aster" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="546" phylum="Tracheophyta" rank="genus">
<emphasis id="7472081A2109180287B6F56EEA505891" italics="true" pageId="null" pageNumber="546">Aster</emphasis>
</taxonomicName>
durch die blattartigen, krautigen 
<normalizedToken id="9F050A1E446202A8C13F0AAE7DCCF902" originalValue="Hüllblätter" pageId="null" pageNumber="546">Huellblaetter</normalizedToken>
und durch einen 
<emphasis id="D5297C2050FC4F7B4DF6C5CAD6A64FD9" italics="true" pageId="null" pageNumber="546">
sehr kurzen, 
<normalizedToken id="F8C4F900B0FC36F84E8474418FE40D65" originalValue="äußern" pageId="null" pageNumber="546">aeussern</normalizedToken>
, verwachsenen 
<taxonomicName id="A599816E6DE7289B870BC7E8814C388E" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="546" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
</emphasis>
unterscheidende Gattung 
<taxonomicName id="E04D8F3701BD0C8FDABE5AE652713AF3" class="Magnoliopsida" family="Asteraceae" genus="Callistephus" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="546" phylum="Tracheophyta" rank="genus">
<emphasis id="9145FEE970379C70616673855B3AA753" italics="true" pageId="null" pageNumber="546">Callistephus</emphasis>
</taxonomicName>
<normalizedToken id="1B52126593187B983B5992A3326937C4" originalValue="umfaßt" pageId="null" pageNumber="546">umfasst</normalizedToken>
nur 1 Art. Die Gattungsmerkmale sind in der Art-diagnose enthalten.
</paragraph>
</subSubSection>
