<subSubSection id="C8344BEC205C226F9E71DBC1B91FC96D" pageId="null" pageNumber="83" type="vernacular_names">
<paragraph id="83D402910B971E36E6579BBDEBF9FF96" pageId="null" pageNumber="83">Echter Steinsame</paragraph>
</subSubSection>
</title>
<subSubSection id="92F104450DAD2327684FE23B7D32E731" pageId="null" pageNumber="83" type="description">
<paragraph id="4D51D255DEE0C097DB7C2B68AC2CC2B5" pageId="null" pageNumber="83">
<emphasis id="6FD5DD60CA40BB46A85CED0EA6D97F9E" italics="true" pageId="null" pageNumber="83">Ausdauernd</emphasis>
, 0,3-1 m hoch, mehrere Stengel nebeneinander auf demselben Rhizom. Stengel reich verzweigt. 
<normalizedToken id="DCCDB2C780063F0BF5C53550A240682A" originalValue="Blätter" pageId="null" pageNumber="83">Blaetter</normalizedToken>
lanzettlich, bis 10 cm lang, 4-8mal so lang wie breit, nach dem Grunde und nach der Spitze 
<normalizedToken id="70E147089B9120B522AC5F7C9326B132" originalValue="allmählich" pageId="null" pageNumber="83">allmaehlich</normalizedToken>
<normalizedToken id="D2C718E7E85313E28B8736F4CBB710DF" originalValue="verschmälert" pageId="null" pageNumber="83">verschmaelert</normalizedToken>
, 
<emphasis id="FF31C384DE17BCBDC94A1E6DC43D934E" italics="true" pageId="null" pageNumber="83">unterseits deutlich fiedernervig.</emphasis>
Kelch zur Fruchtzeit 4-6 mm lang, 
<emphasis id="559477CAA263D1C18F54980F3E4CB281" italics="true" pageId="null" pageNumber="83">mit stumpfen Zipfeln</emphasis>
, auf 1-4 mm langem Stiel. 
<emphasis id="15B5BFCB19F01613ECCDD928C2F34F22" italics="true" pageId="null" pageNumber="83">
Krone 
<normalizedToken id="9130E0EF3A71D10AFD48EA8735D587F0" originalValue="weiß" pageId="null" pageNumber="83">weiss</normalizedToken>
oder gelblich
</emphasis>
, gelegentlich auch 
<normalizedToken id="CF512C27DA208BE103A734B1D83895E8" originalValue="grünlich" pageId="null" pageNumber="83">gruenlich</normalizedToken>
, in der 
<emphasis id="04FD8D68AFCA4ACD81953D7BA076C378" italics="true" pageId="null" pageNumber="83">4</emphasis>
- 
<emphasis id="0D7FB63213632AD61D22CACA3B564D57" italics="true" pageId="null" pageNumber="83">
5 mm langen 
<normalizedToken id="047A50EC54434A390D3A947866337BC9" originalValue="Röhre" pageId="null" pageNumber="83">Roehre</normalizedToken>
</emphasis>
mit 5 behaarten Falten. 
<emphasis id="3C59C53F279B253955182D9E920B8B65" italics="true" pageId="null" pageNumber="83">
<normalizedToken id="0FEC37D5C6D01D904DF1D3D1E8C80CB6" originalValue="Teilfrüchte" pageId="null" pageNumber="83">Teilfruechte</normalizedToken>
ca. 3 mm lang, glatt, 
<normalizedToken id="79219A1DD2C3B700DD5B6104DF6B3A41" originalValue="glänzend" pageId="null" pageNumber="83">glaenzend</normalizedToken>
, 
<normalizedToken id="E9FAD0F3F6282FA13E53B31C78E064BB" originalValue="weiß" pageId="null" pageNumber="83">weiss</normalizedToken>
.
</emphasis>
(Nicht 
<normalizedToken id="A034334C8E867EF071CD7A723EA5FD9D" originalValue="vollständig" pageId="null" pageNumber="83">vollstaendig</normalizedToken>
ausgereifte 
<normalizedToken id="8F40E451587D72C7432E86CFBD99F840" originalValue="Früchte" pageId="null" pageNumber="83">Fruechte</normalizedToken>
haben eine wulstige 
<normalizedToken id="077BD685396095B54C35588F068A3236" originalValue="Oberfläche" pageId="null" pageNumber="83">Oberflaeche</normalizedToken>
!). - 
<normalizedToken id="74D397D5C54EC6678B10F2084B6053A1" originalValue="Blüte" pageId="null" pageNumber="83">Bluete</normalizedToken>
: 
<normalizedToken id="EA4160B80E55EC0DECC2A36532FC209C" originalValue="Später" pageId="null" pageNumber="83">Spaeter</normalizedToken>
<normalizedToken id="B2BB42C79E45FFFBA502D174E7238506" originalValue="Frühling" pageId="null" pageNumber="83">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="CB92BD5E3A3FB8EA4C42863F311EBC49" pageId="null" pageNumber="83">
<emphasis id="FF60713E342E8096837FF05732CED6EB" italics="true" pageId="null" pageNumber="83">
<pageBreakToken id="53F7263B9BAC00A24D10D4276B6887F1" pageId="null" pageNumber="83">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="A0ECD86E95027FF7609558C3C025947C" italics="true" pageId="null" pageNumber="83">28:</emphasis>
Material aus botanischen 
<normalizedToken id="6FBB0C7C7A527E1A7FB388053282781B" originalValue="Gärten" pageId="null" pageNumber="83">Gaerten</normalizedToken>
(Strey 1931, Britton 1951), aus Holland (Gadella und Kliphuis 1966), aus Kanada (Mulligan 1957), aus Afghanistan (Podlech und Dieterle 1969).
</paragraph>
<paragraph id="B9A03CDC3004761538464FE6C6EFD0B1" pageId="null" pageNumber="83">
<emphasis id="B294CC3D431976FE9034D168DFFDED00" italics="true" pageId="null" pageNumber="83">Standort.</emphasis>
Kollin, selten montan. Sickerfeuchte bis trockene, sandige bis lehmige 
<normalizedToken id="941C8B70FCF24C39CE0F4F85FB746927" originalValue="Böden" pageId="null" pageNumber="83">Boeden</normalizedToken>
. Lichte 
<normalizedToken id="45C88B7295B343F7F1231EEF4FD91CA9" originalValue="Auenwälder" pageId="null" pageNumber="83">Auenwaelder</normalizedToken>
und lichte 
<normalizedToken id="D49DA679134C3E9572B08D994250BDC9" originalValue="Laubmischwälder" pageId="null" pageNumber="83">Laubmischwaelder</normalizedToken>
in warmen Lagen.
</paragraph>
<paragraph id="E5C5E53430CF95E39959D7570DE48656" pageId="null" pageNumber="83">
<emphasis id="B432A786DEAB9763FF1FE30C3E9AD631" italics="true" pageId="null" pageNumber="83">Verbreitung.</emphasis>
<normalizedToken id="B42C427489DBC11AE961B22DD3E94823" originalValue="Ursprünglich" pageId="null" pageNumber="83">Urspruenglich</normalizedToken>
<emphasis id="AADA97275D35AC85B9B5229FF760EDD6" italics="true" pageId="null" pageNumber="83">eurasiatische Pflanze:</emphasis>
Europa ohne arktische Gebiete; 
<normalizedToken id="E34F010D1D5F97B00DA3E12535B56FFA" originalValue="ostwärts" pageId="null" pageNumber="83">ostwaerts</normalizedToken>
bis Zentralasien (nahe verwandte Art in Ostasien). - Im Gebiet verbreitet und ziemlich selten.
</paragraph>
</subSubSection>
