<subSubSection id="896CB8DA0BCBF1935476AB2A4005A989" pageId="null" pageNumber="434" type="description">
<paragraph id="A87899F17BA1B19BF7EDA0456FF6B753" pageId="null" pageNumber="434">
20-80 cm hoch. 
<normalizedToken id="66A7D9B5C3E9D0290ACCCBA6D1214248" originalValue="Blätter" pageId="null" pageNumber="434">Blaetter</normalizedToken>
2-3 mm breit, 
<emphasis id="86706F5E89D8B2B56D4361E0332D364D" italics="true" pageId="null" pageNumber="434">schlaff</emphasis>
, 
<normalizedToken id="98DD63097C725F3D3566BC97937B1C52" originalValue="kürzer" pageId="null" pageNumber="434">kuerzer</normalizedToken>
als die Stengel; 
<normalizedToken id="FAB4AE2E45D50F2C32C74315B877D99C" originalValue="Blatthäutchen" pageId="null" pageNumber="434">Blatthaeutchen</normalizedToken>
so hoch wie breit. 
<emphasis id="110A53CB479D069F9D441EF651145F60" italics="true" pageId="null" pageNumber="434">
Stengel schlaff gebogen, oft fast niederliegend, 
<normalizedToken id="6CBC346DF0E035FD633C21119488FDC7" originalValue="dünn" pageId="null" pageNumber="434">duenn</normalizedToken>
</emphasis>
(
<emphasis id="3F81C48311683814424BC12F07B09DA1" italics="true" pageId="null" pageNumber="434">Durchmesser 0,5-1,2 mm</emphasis>
). 
<emphasis id="7863758A8B3D9328353731509EA47C5F" italics="true" pageId="null" pageNumber="434">
<normalizedToken id="F0EA550828A4BFAEC8C8137CEA652627" originalValue="Blütenstand" pageId="null" pageNumber="434">Bluetenstand</normalizedToken>
bis 10 cm lang
</emphasis>
, 
<normalizedToken id="4F461E652A1C5BA398987F6663B95218" originalValue="ähnlich" pageId="null" pageNumber="434">aehnlich</normalizedToken>
dem von 
<taxonomicName id="A535BF1A550B1DA88C26AB622D84F503" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="434" phylum="Tracheophyta" rank="species" species="leersii">
<emphasis id="5E8916BDE9188F636BBBBA70DA53573A" italics="true" pageId="null" pageNumber="434">C. Leersii</emphasis>
</taxonomicName>
(Nr. 20c), die untern 
<emphasis id="C5788EEAE76E52CA0BDAE75AD9D13A3A" italics="true" pageId="null" pageNumber="434">
3-6 
<normalizedToken id="3E1B010A8457BA589D5E832F3460234C" originalValue="Ähren" pageId="null" pageNumber="434">Aehren</normalizedToken>
</emphasis>
(einzelne 
<normalizedToken id="5DD1427F70FCC84DA77D03962415B06C" originalValue="Ähren" pageId="null" pageNumber="434">Aehren</normalizedToken>
, zuunterst 
<normalizedToken id="2E6799B3E82F3D7BD03AABBDEBC77501" originalValue="Ährenknäuel" pageId="null" pageNumber="434">Aehrenknaeuel</normalizedToken>
wie bei 
<taxonomicName id="402F51030E8F3C46DF2430ED05FE3C48" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="434" phylum="Tracheophyta" rank="species" species="leersii">
<emphasis id="A97B96A8436728D4554C19F066D9B770" italics="true" pageId="null" pageNumber="434">C. Leersii</emphasis>
</taxonomicName>
) je etwa 2-4 cm voneinander 
<normalizedToken id="B514DAEE751DDB918CE17EED15578DC7" originalValue="abgerückt" pageId="null" pageNumber="434">abgerueckt</normalizedToken>
; die reifen 
<normalizedToken id="CCA7E86C690FEF8C91D83D57D18B7D8A" originalValue="Fruchtschläuche" pageId="null" pageNumber="434">Fruchtschlaeuche</normalizedToken>
schief 
<emphasis id="1F4A041D2C34F246CC83AA0ED696BC20" italics="true" pageId="null" pageNumber="434">aufrecht, weniger abstehend</emphasis>
als bei den andern Arten der Gruppe. 
<normalizedToken id="9F877D718EE27F02261A49E408920CDA" originalValue="Fruchtschläuche" pageId="null" pageNumber="434">Fruchtschlaeuche</normalizedToken>
3,5-4,5 mm lang, 2,2-2,5mal so lang wie breit, am Grunde mit nur wenig schwammigem Gewebe, hellbraun, 
<normalizedToken id="378D38C7A389DBAC867D1F0A07B4158B" originalValue="glänzend" pageId="null" pageNumber="434">glaenzend</normalizedToken>
.
</paragraph>
<paragraph id="7D87E8E5B54681E069B5A833B3485083" pageId="null" pageNumber="434">
<emphasis id="C527DE5810A21AB2D30FC458A0659BC4" italics="true" pageId="null" pageNumber="434">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="26E18DDF45DBD83712C84C7AE968CD84" italics="true" pageId="null" pageNumber="434">56:</emphasis>
Material aus Frankreich (Fontan), aus der Schweiz (Ascona, Gandria, Walenstadtberg) (Studer in lit.). 
<emphasis id="F8833133418CC3F1AA9A5ACD849DE64C" italics="true" pageId="null" pageNumber="434">2n</emphasis>
= 
<emphasis id="3E002FF0B59C8DA11CC1E51C01A37143" italics="true" pageId="null" pageNumber="434">58:</emphasis>
Material aus Japan (Tanaka 1942Tanaka 1948 aus Studer in lit.), aus England (Davies 1956), aus der Schweiz (Betlis) (Studer in lit.).
</paragraph>
<paragraph id="CCB15052D1ADA22798288662266E637C" pageId="null" pageNumber="434">
<emphasis id="36620A18379AD66143E311DD65FF5357" italics="true" pageId="null" pageNumber="434">Standort.</emphasis>
Kollin. Sommertrockene 
<normalizedToken id="14E1B7CB6DA1BE42632ED019942E314B" originalValue="Böden" pageId="null" pageNumber="434">Boeden</normalizedToken>
. 
<normalizedToken id="F9EFCD1ECD49DC8CAA7E14BC8B16C39C" originalValue="Gebüschränder" pageId="null" pageNumber="434">Gebueschraender</normalizedToken>
, auch 
<normalizedToken id="1ACEAB42133433E7E57B320AB00706E8" originalValue="Wegränder" pageId="null" pageNumber="434">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="C9BB2650415A66387CD8AD72671C3D83" pageId="null" pageNumber="434">
<emphasis id="F32051317A687B818262FE958DC1E80A" italics="true" pageId="null" pageNumber="434">Verbreitung.</emphasis>
(
<normalizedToken id="1F45AF9FDA369DA5A8D0109505C819AE" originalValue="Ungenügend" pageId="null" pageNumber="434">Ungenuegend</normalizedToken>
bekannt.) 
<emphasis id="ECC58020149892D1F41133B133F49B11" italics="true" pageId="null" pageNumber="434">Mediterrane Pflanze:</emphasis>
<normalizedToken id="93246A29D0FF8476FE332B5D160016CB" originalValue="Süd-" pageId="null" pageNumber="434">Sued-</normalizedToken>
und Westeuropa (
<normalizedToken id="C0327EB94EA3AD0464208B6C3D881ADE" originalValue="nordwärts" pageId="null" pageNumber="434">nordwaerts</normalizedToken>
bis 
<normalizedToken id="0E2B2420DA31DAE44CC2A50C8E6A12B6" originalValue="Südengland" pageId="null" pageNumber="434">Suedengland</normalizedToken>
), Krim; Kaukasus, Kleinasien, Persien; Nordwestafrika, im 
<normalizedToken id="63AB37C50339534E0455DA8018817D7C" originalValue="östlichen" pageId="null" pageNumber="434">oestlichen</normalizedToken>
Nordamerika eingeschleppt. - Im Gebiet: 
<normalizedToken id="CA016B174CD0840054F14EFFC5C28CDC" originalValue="Südliches" pageId="null" pageNumber="434">Suedliches</normalizedToken>
Tessin (
<normalizedToken id="A96AA3084A2E1F049C998E15DF2C0881" originalValue="häufig" pageId="null" pageNumber="434">haeufig</normalizedToken>
) und angrenzende Gebiete Italiens, Unterwallis, Walenseegebiet.
</paragraph>
</subSubSection>
