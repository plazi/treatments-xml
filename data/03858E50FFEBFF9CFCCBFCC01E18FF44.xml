city. 
<location id="8EF3699DFFEBFF9DFD11F9F61A69F9ED" LSID="urn:lsid:plazi:treatment:03858E50FFEBFF9CFCCBFCC01E18FF44:8EF3699DFFEBFF9DFD11F9F61A69F9ED" box="[338,372,1627,1653]" country="American Samoa" county="Ibid." municipality="Xingyi" name="On" pageId="4" pageNumber="68">On</location>
