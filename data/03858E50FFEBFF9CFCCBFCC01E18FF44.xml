<specimenCode id="DB8A973DFFEBFF9DFD53FC7E1AA3FC75" box="[272,446,979,1005]" collectionCode="HKAS" country="China" httpUri="http://grbio.org/cool/di2a-40jb" name="Cryptogamic Herbarium of Kunming Institute of Botany" pageId="4" pageNumber="68">HKAS 122239</specimenCode>
