Key to the species of the 
<taxonomicName id="D2BC4D5AFFC9FFC307FEFB58FD2EFAE9" baseAuthorityName="Chen" baseAuthorityYear="1941" box="[459,702,1267,1294]" class="Insecta" family="Chrysomelidae" genus="Gonioctena" kingdom="Animalia" order="Coleoptera" pageId="1" pageNumber="112" phylum="Arthropoda" rank="species" species="kanfani">
