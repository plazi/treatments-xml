<subSubSection id="C3081DCA610AFFFFFF13F96A77AFC191" pageId="24" pageNumber="23" type="reference_group">
<paragraph id="8BAD4E41610AFFFFFF13F96A77AFC191" blockId="24.[192,1440,1702,1790]" pageId="24" pageNumber="23">
<taxonomicName id="4C1235C2610AFFFFFF13F96A7592C1D1" authorityName="Smith" authorityYear="2008" box="[240,418,1702,1726]" class="Insecta" family="Melolonthidae" genus="Plectris" kingdom="Animalia" order="Coleoptera" pageId="24" pageNumber="23" phylum="Arthropoda" rank="species" species="evansi">
<emphasis id="B9669253610AFFFFFF13F96A7592C1D1" box="[240,418,1702,1726]" italics="true" pageId="24" pageNumber="23">Plectris evansi</emphasis>
</taxonomicName>
is a replacement name for 
<taxonomicName id="4C1235C2610AFFFFFD09F96A7080C1D1" authority="Moser, 1918: 161" authorityName="Moser" authorityPageNumber="161" authorityYear="1918" baseAuthorityName="Blanchard" baseAuthorityYear="1850" box="[746,1200,1702,1726]" class="Insecta" family="Melolonthidae" genus="Plectris" kingdom="Animalia" order="Coleoptera" pageId="24" pageNumber="23" phylum="Arthropoda" rank="species" species="cinerascens">
<emphasis id="B9669253610AFFFFFD09F96A77EAC1D1" box="[746,986,1702,1726]" italics="true" pageId="24" pageNumber="23">Plectris cinerascens</emphasis>
<bibRefCitation id="EF8333B0610AFFFFFC03F96B7080C1D1" author="Moser, J." box="[992,1200,1702,1726]" pageId="24" pageNumber="23" pagination="95 - 167" refId="ref18919" refString="Moser, J. 1918. Neue amerikanische Melolonthiden (Col.). Stettiner Entomologische Zeitung 79: 95 - 167." type="journal article" year="1918">Moser, 1918: 161</bibRefCitation>
</taxonomicName>
(a junior secondary homonym of 
<taxonomicName id="4C1235C2610AFFFFFEBEF90A767DC1B1" authorityName="Moser" authorityYear="1918" baseAuthorityName="Blanchard" baseAuthorityYear="1850" box="[349,589,1734,1758]" class="Insecta" family="Melolonthidae" genus="Plectris" kingdom="Animalia" order="Coleoptera" pageId="24" pageNumber="23" phylum="Arthropoda" rank="species" species="cinerascens">
<emphasis id="B9669253610AFFFFFEBEF90A767DC1B1" box="[349,589,1734,1758]" italics="true" pageId="24" pageNumber="23">Plectris cinerascens</emphasis>
</taxonomicName>
[
<bibRefCitation id="EF8333B0610AFFFFFDB8F90A7757C1B1" author="Blanchard, C. E." box="[603,871,1734,1758]" pageId="24" pageNumber="23" pagination="1 - 128" refId="ref17533" refString="Blanchard, C. E. 1850. Ordre des Coleopteres. In: H. Milne-Edwards, E. Blanchard. and H. Lucas. (eds.). Museum d'Histoire Naturelle de Paris. Catalogue de la collection entomologique. Classe des insectes. Gide and Baudry; Paris. p. 1 - 128." type="book chapter" year="1850">Blanchard, 1850: 121</bibRefCitation>
]). This name is in honor of Art Evans, who has spearheaded the charge to catalog New World melolonthines.
</paragraph>
