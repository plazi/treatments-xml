<emphasis id="5681EADF650C047F2A866BFDFEF0DB85" bold="true" box="[151,342,1951,1975]" pageId="13" pageNumber="262">FIGURES 53–60.</emphasis>
<taxonomicName id="A3F54D4E650C047F2B4F6BC2FD95DB85" authority="Richardson, 2022" authorityName="Richardson" authorityYear="2022" box="[350,563,1952,1975]" class="Arachnida" family="Salticidae" genus="Frewena" kingdom="Animalia" order="Araneae" pageId="13" pageNumber="262" phylum="Arthropoda" rank="species" species="terraregina" status="n. sp.">
