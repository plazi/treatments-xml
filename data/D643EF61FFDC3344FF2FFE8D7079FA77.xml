<emphasis id="6C9E8265FFDD3344FC74FC01763BFC40" box="[1021,1032,963,984]" italics="true" pageId="5" pageNumber="200">3</emphasis>
— head, left (arrow indicates enlarged setae); 
<emphasis id="6C9E8265FFDD3344FE2FFC1F7382FC6A" box="[422,433,989,1010]" italics="true" pageId="5" pageNumber="200">4</emphasis>
— head, anterior view; 
<emphasis id="6C9E8265FFDD3344FD10FC1C7097FC6B" box="[665,676,990,1011]" italics="true" pageId="5" pageNumber="200">5</emphasis>
