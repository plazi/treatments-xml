<subSubSection id="028D6519FF86FFF65FA79EF529EE4C09" pageId="87" pageNumber="86" type="discussion">
<paragraph id="4A283692FF86FFF65FA79EF529EE4C09" blockId="87.[191,1440,477,886]" pageId="87" pageNumber="86">
<emphasis id="78E3EA80FF86FFF65FA79EF52B124E88" bold="true" box="[192,328,477,503]" pageId="87" pageNumber="86">Comments.</emphasis>
Crawford (1914: 91) listed under 
<taxonomicName id="8D974D11FF86FFF65DDA9EF729CB4E87" authority="Mally" authorityName="Mally. We" authorityYear="1894" box="[701,913,478,504]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="salicis">
<emphasis id="78E3EA80FF86FFF65DDA9EF729114E87" box="[701,843,478,504]" italics="true" pageId="87" pageNumber="86">Trioza salicis</emphasis>
Mally
</taxonomicName>
the following synonyms: 
<taxonomicName id="8D974D11FF86FFF65BCC9EF72AB54D65" authority="Crawford" authorityName="Crawford, T" authorityYear="1910" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="assimilis">
<emphasis id="78E3EA80FF86FFF65BCC9EF72F0E4E87" box="[1195,1364,478,504]" italics="true" pageId="87" pageNumber="86">Trioza assimilis</emphasis>
Crawford
</taxonomicName>
nec Flor and its replacement names 
<taxonomicName id="8D974D11FF86FFF65D189D2929304D65" authority="Crawford" authorityName="Crawford" authorityYear="1911" box="[639,874,512,538]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="flori">
<emphasis id="78E3EA80FF86FFF65D189D2928A34D65" box="[639,761,512,538]" italics="true" pageId="87" pageNumber="86">Trioza flori</emphasis>
Crawford
</taxonomicName>
and 
<taxonomicName id="8D974D11FF86FFF65CF99D292E9B4D65" authority="Aulmann" authorityName="Aulmann" authorityYear="1912" box="[926,1217,512,538]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="pomonae">
<emphasis id="78E3EA80FF86FFF65CF99D292E154D65" box="[926,1103,513,538]" italics="true" pageId="87" pageNumber="86">Trioza pomonae</emphasis>
Aulmann
</taxonomicName>
, 
<taxonomicName id="8D974D11FF86FFF65BAC9D292FC64D65" authority="Patch" authorityName="Patch" authorityYear="1912" box="[1227,1436,512,538]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="dubia">
<emphasis id="78E3EA80FF86FFF65BAC9D292F0C4D65" box="[1227,1366,512,538]" italics="true" pageId="87" pageNumber="86">Trioza dubia</emphasis>
Patch
</taxonomicName>
, 
<taxonomicName id="8D974D11FF86FFF65FA79D0C2BE44D42" authority="Crawford" authorityName="Crawford" box="[192,446,547,573]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="nigra">
<emphasis id="78E3EA80FF86FFF65FA79D0C2B104D42" box="[192,330,548,573]" italics="true" pageId="87" pageNumber="86">Trioza nigra</emphasis>
Crawford
</taxonomicName>
nec 
<taxonomicName id="8D974D11FF86FFF65E9E9D0C282E4D41" authorityName="Crawford" authorityYear="1911" box="[505,628,548,574]" class="Insecta" family="Triozidae" genus="Kuwayama" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="genus">Kuwayama</taxonomicName>
and its replacement names 
<taxonomicName id="8D974D11FF86FFF65CDD9D0C2E944D42" authority="Crawford" authorityName="Crawford" authorityYear="1911" box="[954,1230,547,573]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="nigrilla">
<emphasis id="78E3EA80FF86FFF65CDD9D0C2E034D42" box="[954,1113,547,573]" italics="true" pageId="87" pageNumber="86">Trioza nigrilla</emphasis>
Crawford
</taxonomicName>
and 
<taxonomicName id="8D974D11FF86FFF65A6C9D0C2B324D1F" authority="Aulmann" authorityName="Aulmann" authorityYear="1912" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="louisianae">
<emphasis id="78E3EA80FF86FFF65A6C9D0C2AAF4D1F" italics="true" pageId="87" pageNumber="86">Trioza louisianae</emphasis>
Aulmann
</taxonomicName>
, as well as 
<taxonomicName id="8D974D11FF86FFF65E839D6F28AE4D1F" authority="Crawford" authorityName="Crawford" box="[484,756,582,608]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="minuta">
<emphasis id="78E3EA80FF86FFF65E839D6F28D84D1F" box="[484,642,583,608]" italics="true" pageId="87" pageNumber="86">Trioza minuta</emphasis>
Crawford
</taxonomicName>
and 
<taxonomicName id="8D974D11FF86FFF65C499D6F2AA94DFC" authority="Crawford. Later Tuthill (1943: 555)" authorityName="Crawford. Later Tuthill" authorityPageNumber="555" authorityYear="1943" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="variety" species="minuta" variety="similis">
<emphasis id="78E3EA80FF86FFF65C499D6F29964D1F" box="[814,972,583,608]" italics="true" pageId="87" pageNumber="86">Trioza minuta</emphasis>
var. 
<emphasis id="78E3EA80FF86FFF65B649D6E2E124D1F" box="[1027,1096,582,608]" italics="true" pageId="87" pageNumber="86">similis</emphasis>
Crawford. Later Tuthill (1943: 555)
</taxonomicName>
questioned the synonymy of 
<emphasis id="78E3EA80FF86FFF65D279D4128C04DFD" box="[576,666,616,642]" italics="true" pageId="87" pageNumber="86">
T. 
<taxonomicName id="8D974D11FF86FFF65D3C9D4028C04DFD" authorityName="Patch" authorityYear="1912" box="[603,666,616,642]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="dubia">dubia</taxonomicName>
</emphasis>
and synonymized it instead with 
<taxonomicName id="8D974D11FF86FFF65B7F9D412F0B4DFD" authority="Crawford" authorityName="Crawford" authorityYear="1910" box="[1048,1361,616,642]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="longicornis">
<emphasis id="78E3EA80FF86FFF65B7F9D412E874DFD" box="[1048,1245,616,642]" italics="true" pageId="87" pageNumber="86">Trioza longicornis</emphasis>
Crawford
</taxonomicName>
, an act which was followed by Hodkinson (1988). According to the original descriptions, the forewing of 
<emphasis id="78E3EA80FF86FFF65B919DA42FD34DDA" box="[1270,1417,651,677]" italics="true" pageId="87" pageNumber="86">
T. 
<taxonomicName id="8D974D11FF86FFF65A759DA32FD34DDA" authorityName="Crawford" authorityYear="1910" box="[1298,1417,651,677]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="longicornis">longicornis</taxonomicName>
</emphasis>
is broadly rounded but that of 
<emphasis id="78E3EA80FF86FFF65E9E9D8728094DB7" box="[505,595,686,712]" italics="true" pageId="87" pageNumber="86">
T. 
<taxonomicName id="8D974D11FF86FFF65D739D8628094DB7" authorityName="Patch" authorityYear="1912" box="[532,595,686,712]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="dubia">dubia</taxonomicName>
</emphasis>
subacute suggesting they are not conspecific. On the other hand, 
<emphasis id="78E3EA80FF86FFF65A4F9D872F644DB7" box="[1320,1342,687,712]" italics="true" pageId="87" pageNumber="86">T.</emphasis>
<taxonomicName id="8D974D11FF86FFF65A239D862B714D95" authority="Crawford" authorityName="Crawford, T" authorityYear="1910" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="assimilis">
<emphasis id="78E3EA80FF86FFF65A239D862FFA4DB7" box="[1348,1440,686,712]" italics="true" pageId="87" pageNumber="86">assimilis</emphasis>
Crawford
</taxonomicName>
and 
<emphasis id="78E3EA80FF86FFF65E019DF92B9A4D95" box="[358,448,720,746]" italics="true" pageId="87" pageNumber="86">
T. 
<taxonomicName id="8D974D11FF86FFF65EE69DF82B9A4D95" authorityName="Patch" authorityYear="1912" box="[385,448,720,746]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="dubia">dubia</taxonomicName>
</emphasis>
are congeneric and share the slender falcate paramere that is curved cephalad, the relatively long cuneate female terminalia with a pointed subgenital plate and their origin from 
<collectingRegion id="8853F870FF86FFF65BCD9DDB2F454C72" box="[1194,1311,755,781]" country="United States of America" name="California" pageId="87" pageNumber="86">California</collectingRegion>
. We believe they are conspecific and synonymize them. As 
<taxonomicName id="8D974D11FF86FFF65DB49C3F29AB4C4F" authority="Crawford" authorityName="Crawford, T" authorityYear="1910" box="[723,1009,790,816]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="assimilis">
<emphasis id="78E3EA80FF86FFF65DB49C3F29244C4F" box="[723,894,790,816]" italics="true" pageId="87" pageNumber="86">Trioza assimilis</emphasis>
Crawford
</taxonomicName>
is a primary homonym of 
<taxonomicName id="8D974D11FF86FFF65A469C3F2B714C2C" authority="Flor" authorityName="Flor" authorityYear="1861" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="assimilis">
<emphasis id="78E3EA80FF86FFF65A469C3F2AAF4C2C" italics="true" pageId="87" pageNumber="86">Trioza assimilis</emphasis>
Flor
</taxonomicName>
, the name is not available and the oldest synonym, i.e. 
<taxonomicName id="8D974D11FF86FFF65CF59C112E574C2C" authorityName="Crawford" authorityYear="1911" box="[914,1037,825,851]" class="Insecta" family="Triozidae" genus="Trioza" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="flori">
<emphasis id="78E3EA80FF86FFF65CF59C112E574C2C" box="[914,1037,825,851]" italics="true" pageId="87" pageNumber="86">Trioza flori</emphasis>
</taxonomicName>
, has to be used which is transferred here to 
<taxonomicName id="8D974D11FF86FFF65E739C742BD54C0A" authorityName="Puton" authorityYear="1876" box="[276,399,860,885]" class="Insecta" family="Triozidae" genus="Bactericera" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="genus">
<emphasis id="78E3EA80FF86FFF65E739C742BD54C0A" box="[276,399,860,885]" italics="true" pageId="87" pageNumber="86">Bactericera</emphasis>
</taxonomicName>
as 
<taxonomicName id="8D974D11FF86FFF65ED49C7429704C0A" authority="(Crawford, 1911)" baseAuthorityName="Crawford" baseAuthorityYear="1911" box="[435,810,859,885]" class="Insecta" family="Triozidae" genus="Bactericera" kingdom="Animalia" order="Hemiptera" pageId="87" pageNumber="86" phylum="Arthropoda" rank="species" species="flori" status="comb. nov.">
<emphasis id="78E3EA80FF86FFF65ED49C7428384C0A" box="[435,610,859,885]" italics="true" pageId="87" pageNumber="86">Bactericera flori</emphasis>
(Crawford, 1911)
</taxonomicName>
, 
<taxonomicNameLabel id="63D057FBFF86FFF65C519C7329EE4C09" box="[822,948,859,886]" pageId="87" pageNumber="86" rank="species">
<emphasis id="78E3EA80FF86FFF65C519C7329F44C0A" bold="true" box="[822,942,859,885]" pageId="87" pageNumber="86">comb. nov</emphasis>
.
</taxonomicNameLabel>
</paragraph>
