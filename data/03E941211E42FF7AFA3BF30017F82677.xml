<taxonomicName id="4C408BB41E41FF7AFF89F82E1EFB25E3" authority="Flerov, 1927" authorityName="Flerov" authorityYear="1927" box="[122,508,1941,1970]" class="Mammalia" family="Ochotonidae" genus="Ochotona" kingdom="Animalia" order="Lagomorpha" pageId="6" pageNumber="34" phylum="Chordata" rank="subSpecies" species="hyperborea" subSpecies="uralensis">O.h.uralensisFlerov,1927—NofUralMts,WRussia.</taxonomicName>
</paragraph>
<paragraph id="8BFFF0371E41FF7AFF89F8031C6B2588" blockId="6.[115,1324,715,3466]" box="[122,876,1976,2009]" pageId="6" pageNumber="34">
<taxonomicName id="4C408BB41E41FF7AFF89F8031D0B2588" authority="Kishida, 1930" authorityName="Kishida" authorityYear="1930" box="[122,524,1976,2009]" class="Mammalia" family="Ochotonidae" genus="Ochotona" kingdom="Animalia" order="Lagomorpha" pageId="6" pageNumber="34" phylum="Chordata" rank="subSpecies" species="hyperborea" subSpecies="yesoensis">O.h.yesoensisKishida,1930—Hokkaido(NJapan).</taxonomicName>
</paragraph>
<paragraph id="8BFFF0371E41FF7AFF89F8641B892A79" blockId="6.[115,1324,715,3466]" pageId="6" pageNumber="34">
<taxonomicName id="4C408BB41E41FF7AFF89F8641D182A51" authority=": Kishida, 1932" authorityName=": Kishida" authorityYear="1932" box="[122,543,2015,2048]" class="Mammalia" family="Ochotonidae" genus="Ochotona" kingdom="Animalia" order="Lagomorpha" pageId="6" pageNumber="34" phylum="Chordata" rank="subSpecies" species="hyperborea" subSpecies="yoshikura">O. h. yoshikura: Kishida, 1932</taxonomicName>
