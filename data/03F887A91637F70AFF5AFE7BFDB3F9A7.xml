(Meigen, 1822)
</taxonomicName>
by black claws (pale at base in 
<taxonomicName id="4C514D3C1630F70AFE13FDA4FDE8F9C4" baseAuthorityName="Meigen" baseAuthorityYear="1822" box="[483,600,623,650]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="4" pageNumber="17" phylum="Arthropoda" rank="species" species="urbana">
<emphasis id="B925EAAD1630F70AFE13FDA4FDE8F9C4" box="[483,600,623,650]" italics="true" pageId="4" pageNumber="17">C. urbana</emphasis>
</taxonomicName>
, 
<figureCitation id="136A2A3A1630F70AFD94FDBBFD1CF9C7" box="[612,684,623,650]" captionStart="Figs 6–11" captionStartId="3.[174,213,1800,1822]" captionTargetBox="[228,1176,577,1757]" captionTargetId="figure-141@3.[212,1195,560,1776]" captionTargetPageId="3" captionText="Figs 6–11. Females of Cheilosia psilophthalma (figs 6–8, 10) and C. urbana (figs 9, 11): 6 — habitus, dorsal view; 7 — habitus, lateral view; 8, 9 — head, frontal view; 10, 11 — claws of fore leg." figureDoi="http://doi.org/10.5281/zenodo.6404162" httpUri="https://zenodo.org/record/6404162/files/figure.png" pageId="4" pageNumber="17">fig. 11</figureCitation>
), dust spots on frons not connected to dusting on face (connected in 
<taxonomicName id="4C514D3C1630F70AFE44FD44FD9CF9E4" baseAuthorityName="Meigen" baseAuthorityYear="1822" box="[436,556,655,682]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="4" pageNumber="17" phylum="Arthropoda" rank="species" species="urbana">
<emphasis id="B925EAAD1630F70AFE44FD44FD9CF9E4" box="[436,556,655,682]" italics="true" pageId="4" pageNumber="17">C. urbana</emphasis>
</taxonomicName>
, 
<figureCitation id="136A2A3A1630F70AFDCDFD5BFDCAF9E7" box="[573,634,655,682]" captionStart="Figs 6–11" captionStartId="3.[174,213,1800,1822]" captionTargetBox="[228,1176,577,1757]" captionTargetId="figure-141@3.[212,1195,560,1776]" captionTargetPageId="3" captionText="Figs 6–11. Females of Cheilosia psilophthalma (figs 6–8, 10) and C. urbana (figs 9, 11): 6 — habitus, dorsal view; 7 — habitus, lateral view; 8, 9 — head, frontal view; 10, 11 — claws of fore leg." figureDoi="http://doi.org/10.5281/zenodo.6404162" httpUri="https://zenodo.org/record/6404162/files/figure.png" pageId="4" pageNumber="17">fig. 9</figureCitation>
), femora apex pale for a shot distance (pale over considerable distance in 
<taxonomicName id="4C514D3C1630F70AFE3FFD64FDF7F984" baseAuthorityName="Meigen" baseAuthorityYear="1822" box="[463,583,687,714]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="4" pageNumber="17" phylum="Arthropoda" rank="species" species="urbana">
<emphasis id="B925EAAD1630F70AFE3FFD64FDF7F984" box="[463,583,687,714]" italics="true" pageId="4" pageNumber="17">C. urbana</emphasis>
</taxonomicName>
), tergite 5 mostly weakly dusted (mostly undusted in 
<taxonomicName id="4C514D3C1630F70AFF56FD04FEACF9A4" baseAuthorityName="Meigen" baseAuthorityYear="1822" box="[166,284,719,746]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="4" pageNumber="17" phylum="Arthropoda" rank="species" species="urbana">
<emphasis id="B925EAAD1630F70AFF56FD04FEACF9A4" box="[166,284,719,746]" italics="true" pageId="4" pageNumber="17">C. urbana</emphasis>
</taxonomicName>
) (
<collectingRegion id="4995F85D1630F70AFEC5FD1BFED8F9A4" box="[309,360,719,745]" country="Turkey" name="Van" pageId="4" pageNumber="17">Van</collectingRegion>
