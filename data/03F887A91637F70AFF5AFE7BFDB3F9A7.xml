<taxonomicName id="4C514D3C1630F70AFC9FFD84FB14F927" authority="(Meigen, 1822)" baseAuthorityName="Meigen" baseAuthorityYear="1822" box="[879,1188,591,618]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="4" pageNumber="17" phylum="Arthropoda" rank="species" species="urbana">
