<taxonomicName id="F2E1A8E4FF9E8D513BEEFB46FD2FFB46" authority="ARCANGELI, 1935" authorityName="Arcangeli" authorityYear="1935" box="[224,681,1233,1258]" class="Malacostraca" family="Armadillidiidae" genus="Cristarmadillidium" kingdom="Animalia" order="Isopoda" pageId="7" pageNumber="1319" phylum="Arthropoda" rank="genus">
<emphasis id="07950F75FF9E8D513BEEFB46FE5CFB44" box="[224,474,1233,1256]" italics="true" pageId="7" pageNumber="1319">CRISTARMADILLIDIUM</emphasis>
