<collectingCountry id="ECC3B8BBFFF6160E1537FE38FE48FE22" box="[359,430,403,429]" name="China" pageId="8" pageNumber="600">China</collectingCountry>
: 
<collectingRegion id="561036C9FFF6160E15E9FE38FDE8FE22" box="[441,526,403,429]" country="China" name="Jiangxi" pageId="8" pageNumber="600">Jiangxi</collectingRegion>
