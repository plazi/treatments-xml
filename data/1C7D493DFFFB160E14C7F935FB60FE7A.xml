<emphasis id="A6A02439FFF816001606F826FD50F82B" box="[598,694,1933,1956]" italics="true" pageId="6" pageNumber="598">yeziyangi</emphasis>
</taxonomicName>
<emphasis id="A6A02439FFF8160016EDF826FCE9F82A" bold="true" box="[701,783,1933,1957]" pageId="6" pageNumber="598">
<taxonomicNameLabel id="BD939942FFF8160016EDF826FCE9F82A" box="[701,783,1933,1957]" pageId="6" pageNumber="598" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
, A–H, male, I–J, female. 
<emphasis id="A6A02439FFF816001049F827FBD4F82B" bold="true" box="[1049,1074,1932,1956]" pageId="6" pageNumber="598">A.</emphasis>
Head and pronotum; 
