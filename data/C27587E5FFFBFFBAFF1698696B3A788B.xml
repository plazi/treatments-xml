<paragraph id="4A6336F3FFFBFFBAFF3D99176B3A788B" blockId="22.[151,756,1363,1515]" pageId="22" pageNumber="36">
<emphasis id="78A8EAE1FFFBFFBAFF3D991768D8780A" bold="true" box="[151,469,1363,1387]" pageId="22" pageNumber="36">Stratigraphic distribution:</emphasis>
