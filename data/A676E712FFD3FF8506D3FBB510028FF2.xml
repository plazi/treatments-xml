<figureCitation id="B6E44A81FFD3FF840537FB9410718810" box="[552,588,1122,1146]" captionStart="Figure 2" captionStartId="6.[211,278,1132,1154]" captionTargetBox="[213,1170,168,1099]" captionTargetId="figure-5@6.[213,1170,168,1099]" captionTargetPageId="6" captionText="Figure 2. Females of Jacaena spp., habitus, dorsal (A–H). Jacaena schwendingeri comb. nov., paratype (A); J. lunulata sp. nov., paratypes (B, C); J. angoonae sp. nov., holotype (D); J. punctata sp. nov., paratypes (E,F); J. mihun (G); J. peculiaris sp. nov., holotype (H)." figureDoi="http://doi.org/10.5281/zenodo.6517642" httpUri="https://zenodo.org/record/6517642/files/figure.png" pageId="14" pageNumber="1551">2G</figureCitation>
, 
<figureCitation id="B6E44A81FFD3FF840548FB9410418810" box="[599,636,1122,1146]" captionStart="Figure 3" captionStartId="7.[143,210,1174,1196]" captionTargetBox="[145,1102,169,1141]" captionTargetId="figure-5@7.[145,1102,169,1141]" captionTargetPageId="7" captionText="Figure 3. Jacaena spp. Prosoma and anterior part of opisthosoma showing epigastric scutum, ventral (A). Fovea, dorsal (B). Opisthosoma, ventral (C). Carapace, dorsal, showing ocular region (D). Carapace, frontal (E). Jacaena lunulata sp. nov., male, paratype (A–C, E); J. mihun, male, new material (D)." figureDoi="http://doi.org/10.5281/zenodo.6517646" httpUri="https://zenodo.org/record/6517646/files/figure.png" pageId="14" pageNumber="1551">3D</figureCitation>
