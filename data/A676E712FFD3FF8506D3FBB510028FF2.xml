<figureCitation id="B6E44A81FFD3FF840598FB9410F98810" box="[647,708,1122,1146]" captionStart="Figure 4" captionStartId="8.[211,278,1428,1450]" captionTargetBox="[213,1170,168,1394]" captionTargetId="figure-5@8.[213,1170,168,1394]" captionTargetPageId="8" captionText="Figure 4. Jacaena spp. Male palps, ventral (A, D, G). Ditto, prolateral (B, E, H). Ditto, retrolateral (C, F, I). Jacaena schwendingeri comb. nov., holotype (A–C); J. lunulata sp. nov., paratype (originally misidentified as Sesieutes schwendingeri) (D–F); J. mihun, holotype (G–I)." figureDoi="http://doi.org/10.5281/zenodo.6517648" httpUri="https://zenodo.org/record/6517648/files/figure.png" pageId="14" pageNumber="1551">4G–I</figureCitation>
, 
<figureCitation id="B6E44A81FFD3FF8405CFFB9410D38810" box="[720,750,1122,1146]" captionStart="Figure 6" captionStartId="12.[211,278,1142,1164]" captionTargetBox="[213,1170,171,1109]" captionTargetId="figure-5@12.[213,1170,167,1109]" captionTargetPageId="12" captionText="Figure 6. Jacaena spp. Male palps, ventral (A). Ditto, prolateral (B). Ditto, retrolateral (C). Internal copulatory organ, anterior part, dorsal (D). Ditto, showing proximal chamber and secretory ampulla (E). Internal copulatory organ (middle portion of insemination duct removed on right spermathecae, showing connection between copulatory orifice and insemination duct) (F). Jacaena lunulata sp. nov., holotype (A–C); J. peculiaris sp. nov., paratype (D); J. punctata sp. nov., paratype (E); J. mihun (F). AM, secretory ampulla. CH, semi-transparent chamber. CO, copulatory orifice. F, fertilisation duct." figureDoi="http://doi.org/10.5281/zenodo.6517660" httpUri="https://zenodo.org/record/6517660/files/figure.png" pageId="14" pageNumber="1551">6F</figureCitation>
, 
<figureCitation id="B6E44A81FFD3FF8405E6FB9511238810" box="[761,798,1123,1146]" captionStart="Figure 7" captionStartId="13.[143,210,790,812]" captionTargetBox="[145,1102,169,757]" captionTargetId="figure-5@13.[145,1102,169,758]" captionTargetPageId="13" captionText="Figure 7. Jacaena spp. Epigynal region, ventral (A–F). Jacaena schwendingeri comb. nov., paratype (A); J. punctata sp. nov., paratype (B); J. lunulata sp. nov., paratype (C); J. mihun (D); J. angoonae sp. nov., holotype (E); J. peculiaris sp. nov., holotype (F)." figureDoi="http://doi.org/10.5281/zenodo.6517662" httpUri="https://zenodo.org/record/6517662/files/figure.png" pageId="14" pageNumber="1551">7D</figureCitation>
, 
<figureCitation id="B6E44A81FFD3FF840436FB9411528810" box="[809,879,1122,1146]" captionStart="Figure 8" captionStartId="14.[211,278,950,972]" captionTargetBox="[213,1170,169,916]" captionTargetId="figure-5@14.[213,1170,169,917]" captionTargetPageId="14" captionText="Figure 8. Jacaena spp. Internal copulatory organ, dorsal (A–G). Jacaena mihun (A–D); J. angoonae sp. nov., holotype (E); J. schwendingeri comb. nov., paratype (F); J. lunulata sp. nov., paratype (G)." figureDoi="http://doi.org/10.5281/zenodo.6517664" httpUri="https://zenodo.org/record/6517664/files/figure.png" pageId="14" pageNumber="1551">8A–D</figureCitation>
, 
<figureCitation id="B6E44A81FFD3FF840465FB9411F68810" box="[890,971,1122,1146]" captionStart="Figure 10" captionStartId="18.[211,278,1446,1468]" captionTargetBox="[213,1170,167,1412]" captionTargetId="figure-5@18.[213,1170,167,1413]" captionTargetPageId="18" captionText="Figure 10. Jacaena mihun, holotype (A–C); J. thakek comb. nov., holotype (D–F). Male palp, ventral (A, D). Ditto, prolateral (B, E). Ditto, retrolateral (C, F)." figureDoi="http://doi.org/10.5281/zenodo.6517670" httpUri="https://zenodo.org/record/6517670/files/figure.png" pageId="14" pageNumber="1551">10A–C</figureCitation>
)
