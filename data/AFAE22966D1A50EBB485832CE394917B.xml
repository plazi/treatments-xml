</taxonomicName>
sp. nov., holotype, SMF PO 101.116, Fuchu machi, Toyama City, Higashibessho Formation, level H 20; 
<emphasis id="E502EF19C8EE3FAE59F38334D11B4243" bold="true" pageId="0" pageNumber="103">E</emphasis>
: 
<taxonomicName id="30E399B3EB58448179B27D1A2B84BA2C" authorityName="Johnson" authorityYear="1975" class="Actinopterygii" family="Myctophidae" genus="Bolinichthys" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Bolinichthys distofax" order="Myctophiformes" pageId="0" pageNumber="103" phylum="Chordata" rank="species" species="distofax">
<emphasis id="C1C04178A29C6299363074E1CF79F8F0" italics="true" pageId="0" pageNumber="103">Bolinichthys distofax</emphasis>
</taxonomicName>
