<emphasis id="B919EACFEEB53BD1FEEEFA12FE23FA37" box="[299,486,1500,1526]" italics="true" pageId="484" pageNumber="485">Doroixysfijiensis</emphasis>
</taxonomicName>
<emphasis id="B919EACFEEB53BD1FE29FA12FD84FA37" bold="true" box="[492,577,1500,1526]" pageId="484" pageNumber="485">
<taxonomicNameLabel id="A22A57B4EEB53BD1FE29FA12FD84FA37" box="[492,577,1500,1526]" pageId="484" pageNumber="485" rank="species">sp. nov.</taxonomicNameLabel>
