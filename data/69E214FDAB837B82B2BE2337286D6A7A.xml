<taxonomicName id="DBF986B50D78C42D4C40C2CDB93C04DB" authority="L." class="Magnoliopsida" family="Caprifoliaceae" genus="Lonicera" kingdom="Plantae" order="Dipsacales" pageId="null" pageNumber="320" phylum="Tracheophyta" rank="species" species="tatarica">
Lonicera 
<normalizedToken id="4C7AF0049A59DCA00479B34E158C74D3" originalValue="tatárica" pageId="null" pageNumber="320">tatarica</normalizedToken>
<authorityName id="BD53440CC354238BBE724EE266685F37" pageId="null" pageNumber="320">L.</authorityName>
