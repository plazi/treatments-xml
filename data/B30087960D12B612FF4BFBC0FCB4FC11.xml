<quantity id="FC519B650D10B612FE8EFE4CFE24FD85" box="[333,418,554,581]" metricMagnitude="5" metricUnit="m" metricValue="5.0" pageId="10" pageNumber="151" unit="km" value="500.0">500 km</quantity>
<superScript id="CCDC9BC80D10B612FE62FE4CFE2FFDF9" attach="left" box="[417,425,554,568]" fontSize="6" pageId="10" pageNumber="151">2</superScript>
(
<quantity id="FC519B650D10B612FE7AFE4CFD87FD85" box="[441,513,554,580]" metricMagnitude="4" metricUnit="m" metricValue="2.8" pageId="10" pageNumber="151" unit="km" value="28.0">28 km</quantity>
<superScript id="CCDC9BC80D10B612FDC2FE4CFD8FFDF9" attach="left" box="[513,521,554,568]" fontSize="6" pageId="10" pageNumber="151">2</superScript>
).
</paragraph>
