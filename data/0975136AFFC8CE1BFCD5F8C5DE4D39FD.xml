<taxonomicName id="46DCD9FFFFCBCE1BFF09F9D4DA3F3A30" box="[246,364,1540,1567]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="70" pageNumber="71" phylum="Arthropoda" rank="species" species="cornelli">
