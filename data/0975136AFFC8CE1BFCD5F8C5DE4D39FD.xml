<taxonomicName id="46DCD9FFFFCBCE1BFDA8FA0ED99C39D7" box="[599,719,1503,1529]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="70" pageNumber="71" phylum="Arthropoda" rank="species" species="hirsutus">
