<subSubSection id="8C8E6575FF3B6A84FCEB9AF61A61B6A7" pageId="192" pageNumber="954" type="discussion">
<paragraph id="C42B36FEFF3B6A84FCEB9AF61A61B6A7" blockId="192.[790,1385,3054,3477]" pageId="192" pageNumber="954">
Subgenus 
<taxonomicName id="03944D7DFF3B6A84FC469AF61A11B7E2" authority="Kaup, 1829" box="[954,1041,3247,3280]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="192" pageNumber="954" phylum="Chordata" rank="genus">Myotis</taxonomicName>
(62 species); 
<taxonomicName id="03944D7DFF3B6A84FB029AF61B69B7E2" box="[1278,1385,3247,3280]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="192" pageNumber="954" phylum="Chordata" rank="species" species="alcathoe">alcathoe</taxonomicName>
