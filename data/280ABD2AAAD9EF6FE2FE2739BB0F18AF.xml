<subSubSection id="3D120F1B306F10F1F2627D862A4EA4C9" pageId="null" pageNumber="317" type="description">
<paragraph id="F0BEA6A1CD1B6BC87114922EDD5B130A" pageId="null" pageNumber="317">
Strauch, bis 2 m hoch. 
<normalizedToken id="1A31B4EE99698F9BE293A9E1C6DBC2ED" originalValue="Blätter" pageId="null" pageNumber="317">Blaetter</normalizedToken>
<normalizedToken id="8188354350B3DAE58BC4D5D2DF42C9BB" originalValue="sommergrün" pageId="null" pageNumber="317">sommergruen</normalizedToken>
, am Grunde nie miteinander verwachsen, 
<emphasis id="E90F3DF1957FF292827A75C605CFD001" italics="true" pageId="null" pageNumber="317">
<normalizedToken id="6563EC8016955DC31ECD8EF026EEE6C5" originalValue="groß" pageId="null" pageNumber="317">gross</normalizedToken>
, zur 
<normalizedToken id="77A1E7B852C84119A4670F04546EBA38" originalValue="Blütezeit" pageId="null" pageNumber="317">Bluetezeit</normalizedToken>
die 
<normalizedToken id="45239FA09DF303688BB743AADF9058E5" originalValue="größten" pageId="null" pageNumber="317">groessten</normalizedToken>
<normalizedToken id="8B6595EB1EDC32190A67D4E1AE5CD6B9" originalValue="über" pageId="null" pageNumber="317">ueber</normalizedToken>
6 cm lang
</emphasis>
, lanzettlich, 2-3mal so lang wie breit, 
<emphasis id="5A06235DFB01CF9C598B1F0716D4EB6C" italics="true" pageId="null" pageNumber="317">
die meisten an der Spitze 
<normalizedToken id="3003611ECA7C529EBF6CDF9B83CD4C28" originalValue="plötzlich" pageId="null" pageNumber="317">ploetzlich</normalizedToken>
<normalizedToken id="D4AA1711BB85010791E4C5E108A4E87D" originalValue="verschmälert" pageId="null" pageNumber="317">verschmaelert</normalizedToken>
und in eine Spitze ausgezogen
</emphasis>
, am Grunde abgerundet oder in den Stiel 
<normalizedToken id="27D8D2938246FDD23D9F9F06D20E62EA" originalValue="verschmälert" pageId="null" pageNumber="317">verschmaelert</normalizedToken>
, oberseits 
<normalizedToken id="307B93494EF95552DDC7837213B3159D" originalValue="dunkelgrün" pageId="null" pageNumber="317">dunkelgruen</normalizedToken>
, mit gestielten 
<normalizedToken id="E37FCDDB898B8F7F16ECA14FAB5FB42E" originalValue="Drüsen" pageId="null" pageNumber="317">Druesen</normalizedToken>
auf den Nerven, sonst zerstreut behaart oder kahl, unterseits heller 
<normalizedToken id="788FDEBAFF46D447B725FE9033E62376" originalValue="grün" pageId="null" pageNumber="317">gruen</normalizedToken>
, 
<emphasis id="A54C695E842A7A1614C2D2E8AB2170BE" italics="true" pageId="null" pageNumber="317">
<normalizedToken id="C2FC8A96C70BEAFC4411E8851F89E9F1" originalValue="glänzend" pageId="null" pageNumber="317">glaenzend</normalizedToken>
</emphasis>
(im Gebiet nur bei dieser Art so!), behaart, mit vereinzelten, gestielten 
<normalizedToken id="B5B636C73C8929360401C88D135C3890" originalValue="Drüsen" pageId="null" pageNumber="317">Druesen</normalizedToken>
; Blattstiel 2-10 mm lang. 
<normalizedToken id="679E974D9282DFF9B0AF568D645E0984" originalValue="Blüten" pageId="null" pageNumber="317">Blueten</normalizedToken>
zu 2 auf gemeinsamem Stiel; gemeinsamer Stiel meist 2-3mal so lang wie die Kronen (einzelne gelegentlich nur so lang wie die Kronen). Kelch ein undeutlicher, welliger Saum. Krone 1,5-2 cm lang, 
<emphasis id="CDB8BC50129CD9BDA225E47B90923C1D" italics="true" pageId="null" pageNumber="317">am Grunde gelb, weiter oben rotbraun</emphasis>
(im Gebiet nur bei dieser Art so!). Die paarweise angeordneten 
<normalizedToken id="B75382AFB7F0E9711CD4B6F52180CACE" originalValue="Früchte" pageId="null" pageNumber="317">Fruechte</normalizedToken>
dunkelrot, verwachsen. - 
<normalizedToken id="1C291FF88108D057609D67C3E0ECA07D" originalValue="Blüte" pageId="null" pageNumber="317">Bluete</normalizedToken>
: 
<normalizedToken id="38A9606DB4B06E6B725B92E83B115572" originalValue="Später" pageId="null" pageNumber="317">Spaeter</normalizedToken>
<normalizedToken id="8B06459A65509794F35BC0BDDBB85F43" originalValue="Frühling" pageId="null" pageNumber="317">Fruehling</normalizedToken>
und 
<normalizedToken id="AF045E047BCB3C02B92A8DD224CB973A" originalValue="früher" pageId="null" pageNumber="317">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="29A9E0E5F81D2E82DF98A7A9963C1B21" pageId="null" pageNumber="317">
<emphasis id="7132530BE32CB79CBDF25374A0577475" italics="true" pageId="null" pageNumber="317">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E1043C40A29650CA7FC4DA6FA2DEA250" italics="true" pageId="null" pageNumber="317">18:</emphasis>
Siehe unter Gattung. 
<emphasis id="D4793EE3FC5F5729209D658F0C811AAA" italics="true" pageId="null" pageNumber="317">2n</emphasis>
= 
<emphasis id="D6BCB5891DD0415331B78880A79C17B7" italics="true" pageId="null" pageNumber="317">36:</emphasis>
Material aus botanischen 
<normalizedToken id="B114D4CD65EFE86A1F73FA43223B8E7A" originalValue="Gärten" pageId="null" pageNumber="317">Gaerten</normalizedToken>
(
<normalizedToken id="244B31BB8951C066A40DBFE0C8DDFBDC" originalValue="Rüdenberg" pageId="null" pageNumber="317">Ruedenberg</normalizedToken>
und Green 1966 1969).
</paragraph>
<paragraph id="45277762E24A7037B3F55C003C75CDD8" pageId="null" pageNumber="317">
<emphasis id="C708088065A0165877B76C53A5948E96" italics="true" pageId="null" pageNumber="317">Standort</emphasis>
. Montan und subalpin, selten kollin. Meist kalkhaltige, 
<normalizedToken id="FB2A446FC14AAACBD6627C2A87CE1F7A" originalValue="nährstoffreiche" pageId="null" pageNumber="317">naehrstoffreiche</normalizedToken>
, trockene bis sickernasse 
<normalizedToken id="EE2B28989FF55BB7AAC4B9A9E1B64284" originalValue="Böden" pageId="null" pageNumber="317">Boeden</normalizedToken>
. 
<normalizedToken id="D8BF1239E941760FFD01A95CB7106892" originalValue="Buchenwälder" pageId="null" pageNumber="317">Buchenwaelder</normalizedToken>
, 
<normalizedToken id="0BC076311BF467FC8158EA397C053B48" originalValue="Schluchtwälder" pageId="null" pageNumber="317">Schluchtwaelder</normalizedToken>
, 
<normalizedToken id="9B027F218CA3AEF62C0E9A471987A1CC" originalValue="Fichtenwälder" pageId="null" pageNumber="317">Fichtenwaelder</normalizedToken>
, 
<taxonomicName id="4D92A41C687E0FC4E1DDF2716C2D0F84" class="Magnoliopsida" family="Betulaceae" genus="Alnus" kingdom="Plantae" order="Fagales" pageId="null" pageNumber="317" phylum="Tracheophyta" rank="species" species="viridis">
<emphasis id="C55074ABD9454ACE2B643E44302BC48D" italics="true" pageId="null" pageNumber="317">Alnus viridis</emphasis>
</taxonomicName>
- 
<normalizedToken id="630908E98C9A9B8159646A99463C479C" originalValue="Gebüsch" pageId="null" pageNumber="317">Gebuesch</normalizedToken>
.
</paragraph>
<paragraph id="277CBEEF2E29B59EB6DB047B1E9AC978" pageId="null" pageNumber="317">
<emphasis id="B4F930E6196A9FC23D3CA7AFE0625241" italics="true" pageId="null" pageNumber="317">
Verbreitung. Mittel- und 
<normalizedToken id="A0799966A4E4BE85BE598ABD94EC9137" originalValue="südeuropäische" pageId="null" pageNumber="317">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
<normalizedToken id="74692E01EE3F9FED9EBD0C6C3810E7B5" originalValue="Pyrenäen" pageId="null" pageNumber="317">Pyrenaeen</normalizedToken>
, Auvergne, Alpen, Jura, Apennin, Gebirge der Balkanhalbinsel (
<normalizedToken id="227C5220FB949B1E0A91E4F30F53D087" originalValue="südwärts" pageId="null" pageNumber="317">suedwaerts</normalizedToken>
bis Nordgriechenland), Karpaten. In der Flora der URSS Bd. 23 1958 werden die asiatischen Sippen als eigene Arten abgetrennt. Verbreitungskarte von Hegi VI/2, 2. Auflage 1966. - Im Gebiet: Jura, Baar, Alpen und Alpenvorland (ziemlich 
<normalizedToken id="254BE6905BB624860643E36C136814E0" originalValue="häufig" pageId="null" pageNumber="317">haeufig</normalizedToken>
), wenige Fundstellen im Mittelland; kommt in den Vogesen und im Schwarzwald nicht vor.
</paragraph>
</subSubSection>
