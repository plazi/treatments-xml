Similar species. 
<taxonomicName id="2ECF4D5E3F61FFF6FE9EF93AFDBFF937" authorityName="Kovacic, Ordines &amp; Schliewen" authorityYear="2016" box="[383,607,1724,1750]" class="Actinopterygii" family="Gobiidae" genus="Speleogobius" kingdom="Animalia" order="Perciformes" pageId="84" pageNumber="85" phylum="Chordata" rank="species" species="llorisi">
