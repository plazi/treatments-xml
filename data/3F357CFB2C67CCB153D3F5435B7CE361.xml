<subSubSection id="A84C68E752EB1299B989979C8499404D" pageId="null" pageNumber="653" type="description">
<paragraph id="A3FF47382B7E0F89A7FE7BEE9CF727AA" pageId="null" pageNumber="653">
<normalizedToken id="F7DC9526C5EF6DBB2D474D28FD9503AC" originalValue="Sträucher" pageId="null" pageNumber="653">Straeucher</normalizedToken>
und 
<normalizedToken id="832648F077989E87CDA372F5F0BCB37A" originalValue="Kräuter" pageId="null" pageNumber="653">Kraeuter</normalizedToken>
(habituell oft 
<normalizedToken id="3BAC23D6C6E061B5976205A1536CFFA7" originalValue="ähnlich" pageId="null" pageNumber="653">aehnlich</normalizedToken>
<emphasis id="90E1DB95F9EFE8D2278BFF62E547368D" italics="true" pageId="null" pageNumber="653">Urtica-</emphasis>
und 
<emphasis id="3D2FB042320BD604F2ADDDF2256A58CF" italics="true" pageId="null" pageNumber="653">Amaranthu</emphasis>
sarten), ohne Milchsaft. 
<emphasis id="83352BD7C258979CC01CA5E25C73F83B" italics="true" pageId="null" pageNumber="653">
<normalizedToken id="1FD0531CCDEED5D905332770655F23B8" originalValue="Blätter" pageId="null" pageNumber="653">Blaetter</normalizedToken>
<normalizedToken id="AD1D21D1FE94248D3557DAEDA011BAF8" originalValue="wechselständig" pageId="null" pageNumber="653">wechselstaendig</normalizedToken>
</emphasis>
, gestielt, mit 
<normalizedToken id="CDE6C63A527AEE8C2ACDA8DE399A4D18" originalValue="Nebenblättern" pageId="null" pageNumber="653">Nebenblaettern</normalizedToken>
. 
<emphasis id="3C11B26094C89D2483AC78779FAA3570" italics="true" pageId="null" pageNumber="653">
Pflanzen 1 
<normalizedToken id="C01543C611F0520F2D6D6D1785AE0228" originalValue="häusig" pageId="null" pageNumber="653">haeusig</normalizedToken>
.
</emphasis>
♂ 
<normalizedToken id="2A8374587DFC268660F751D35B8F506C" originalValue="Blütenstände" pageId="null" pageNumber="653">Bluetenstaende</normalizedToken>
wie bei 
<taxonomicName id="A425C1C7D055C6710015D05D77103246" class="Magnoliopsida" family="Euphorbiaceae" genus="Mercurialis" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="653" phylum="Tracheophyta" rank="genus">
<emphasis id="0C4F3AAB0DBB6AE49CBAB6AE7A41E278" italics="true" pageId="null" pageNumber="653">Mercurialis</emphasis>
</taxonomicName>
(S. 650); ♀ 
<normalizedToken id="A84F6B13966FAB58718ABD4FB28902E1" originalValue="Blütenstände" pageId="null" pageNumber="653">Bluetenstaende</normalizedToken>
selten von den 
<emphasis id="1A25B46693BC59563A82F634452DE24A" italics="true" pageId="null" pageNumber="653">♂</emphasis>
getrennt, meist nur einzelne oder wenige ♀ 
<normalizedToken id="6FF976A78D649E852BB84A75FF774EA1" originalValue="Blüten" pageId="null" pageNumber="653">Blueten</normalizedToken>
am Grunde der ♂ 
<normalizedToken id="20DE539B04A8E1463B8D335A89B848F7" originalValue="Blütenstände" pageId="null" pageNumber="653">Bluetenstaende</normalizedToken>
, 
<emphasis id="F6EEBE592FE1885F94CC29868DEA88DD" italics="true" pageId="null" pageNumber="653">
stets von einem 
<normalizedToken id="39CAFC2D96EC92564C951B481BA41CE1" originalValue="gezähnten" pageId="null" pageNumber="653">gezaehnten</normalizedToken>
Hochblatt 
<normalizedToken id="E801B5FC5DDA197B66FE993E34919E4C" originalValue="umhüllt" pageId="null" pageNumber="653">umhuellt</normalizedToken>
.
</emphasis>
♂ 
<emphasis id="70F33B7B80A649CECCDA4EE9F5C45E6D" italics="true" pageId="null" pageNumber="653">
<normalizedToken id="2C2BA3DF1FE1022E1411CAE04376ABFE" originalValue="Blüten" pageId="null" pageNumber="653">Blueten</normalizedToken>
klein, mit 4teiligem, 
<normalizedToken id="BE5109F6439F568FE35E90A3360DCF81" originalValue="grünem" pageId="null" pageNumber="653">gruenem</normalizedToken>
Kelch;
</emphasis>
<normalizedToken id="B71A3BB1270A6D1E4989EC63C897A599" originalValue="Staubblätter" pageId="null" pageNumber="653">Staubblaetter</normalizedToken>
8-16; die beiden Staubbeutel oft 
<normalizedToken id="F6F357993462BC88974E072971EECEC0" originalValue="wurmförmig" pageId="null" pageNumber="653">wurmfoermig</normalizedToken>
an der Staubfadenspitze sitzend. ♀ 
<normalizedToken id="D633FCC9566985DD2A944834634E43DB" originalValue="Blüten" pageId="null" pageNumber="653">Blueten</normalizedToken>
klein, mit 3-5teiligem, 
<normalizedToken id="9B1EE442295E80B020AA267C2006BF8F" originalValue="grünem" pageId="null" pageNumber="653">gruenem</normalizedToken>
Kelch; keine Staminodien. 
<emphasis id="8709F4D7E322148014A32BAA038DD45C" italics="true" pageId="null" pageNumber="653">
<normalizedToken id="A65C24F27F202680E6161006142BB7D7" originalValue="Fruchtblätter" pageId="null" pageNumber="653">Fruchtblaetter</normalizedToken>
3;
</emphasis>
Teilfrucht 1samig. 
<normalizedToken id="9A4CC7F2D80C774303BF851431F0C396" originalValue="Samenoberfläche" pageId="null" pageNumber="653">Samenoberflaeche</normalizedToken>
rauh bis glatt.
</paragraph>
<paragraph id="C68436EEDEA3C7FADCE97AE64AC26C95" pageId="null" pageNumber="653">
Die Gattung 
<taxonomicName id="A8231F0D09EA832BEB886A71BDA0FA37" class="Magnoliopsida" family="Euphorbiaceae" genus="Acalypha" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="653" phylum="Tracheophyta" rank="genus">
<emphasis id="9EB121CA72AE712B4068754F80749625" italics="true" pageId="null" pageNumber="653">Acalypha</emphasis>
</taxonomicName>
<normalizedToken id="1B03DDD2C93314AD99F0F9CAED0F66AA" originalValue="umfaßt" pageId="null" pageNumber="653">umfasst</normalizedToken>
<emphasis id="FB2FE951794FA837D53C901B53294555" italics="true" pageId="null" pageNumber="653">430 Arten, die in den Tropen und Subtropen verbreitet sind;</emphasis>
Hauptzentren sind das tropische Amerika und das tropische Afrika mit Madagaskar. Polyploide Reihen 2n = 14, 28, 112, 224 (
<normalizedToken id="D5F8C0DDDE775959F8AA44318E7F4BF2" originalValue="höchste" pageId="null" pageNumber="653">hoechste</normalizedToken>
Chromosomenzahl der Familie der 
<taxonomicName id="1B6130555E614AE32E134576E965E23D" class="Magnoliopsida" family="Euphorbiaceae" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="653" phylum="Tracheophyta" rank="family">
<emphasis id="3B5845609E501B8AC245345F856A2EC0" italics="true" pageId="null" pageNumber="653">Euphorbiaceae</emphasis>
</taxonomicName>
[an Gartenformen 
<normalizedToken id="768F6D63CC2A2AAAA67FABB75CEECDD8" originalValue="gezählt" pageId="null" pageNumber="653">gezaehlt</normalizedToken>
], Perry 1943).
</paragraph>
