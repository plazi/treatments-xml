<subSubSection id="FD875BC74392B4341C306507060B1139" pageId="null" pageNumber="99" type="description">
<paragraph id="EDF96622DEB1EBFED97652801E77504C" pageId="null" pageNumber="99">
<emphasis id="F40D65BC182D7118000C125E29FF7CEB" italics="true" pageId="null" pageNumber="99">Nicht sporentragende</emphasis>
(
<normalizedToken id="8FECEB272B7BFD91ACE98CCEE39FAF57" originalValue="äußere" pageId="null" pageNumber="99">aeussere</normalizedToken>
) 
<emphasis id="A61E825A1809C8DEA0A0B85FF769772D" italics="true" pageId="null" pageNumber="99">
<normalizedToken id="F465C4B03B6236881BB2679D9A149025" originalValue="Blätter" pageId="null" pageNumber="99">Blaetter</normalizedToken>
</emphasis>
oft 
<normalizedToken id="F72BB3588AC142E4D66014021D2EA27E" originalValue="kürzer" pageId="null" pageNumber="99">kuerzer</normalizedToken>
gestielt als die sporentragenden; Stiel kahl, strohgelb bis gelbbraun; Spreite im 
<normalizedToken id="371E8983A4DDF1259C3529B44A5B1368" originalValue="Umriß" pageId="null" pageNumber="99">Umriss</normalizedToken>
3eckig bis oval (
<normalizedToken id="81F9000891DD722512E985DF813161F7" originalValue="größte" pageId="null" pageNumber="99">groesste</normalizedToken>
Breite unterhalb der Mitte), 6-10 cm lang, 5-6 cm breit, zart, 
<normalizedToken id="4488CE4D0CB6779DDB4E8F9FAC90CD84" originalValue="gelbgrün" pageId="null" pageNumber="99">gelbgruen</normalizedToken>
, meist 
<emphasis id="17680EA69E682BC48A6991C525920A71" italics="true" pageId="null" pageNumber="99">3fach gefiedert</emphasis>
, mit 5-9 Fiederpaaren 1. Ordnung; Fiedern 1. und 2. Ordnung im 
<normalizedToken id="93260E84A8D1917DEFEEC1FA836C9AC2" originalValue="Umriß" pageId="null" pageNumber="99">Umriss</normalizedToken>
oval, gestielt; Fiedern 3. Ordnung mit 
<normalizedToken id="AB9FFD15BC1FA58EBEB5AFF628CCF7FD" originalValue="keilförmiger" pageId="null" pageNumber="99">keilfoermiger</normalizedToken>
Basis, fiederteilig; Abschnitte mit stumpfer Spitze. 
<emphasis id="25DBDD3B37007591F2ECADDE18AF1C41" italics="true" pageId="null" pageNumber="99">
Sporentragende 
<normalizedToken id="36B919FA3F2E8587411421003D9D2091" originalValue="Blätter" pageId="null" pageNumber="99">Blaetter</normalizedToken>
in der Mitte des 
<normalizedToken id="FC2C1EC594EC4955700E906FD7D396AC" originalValue="Blattbüschels" pageId="null" pageNumber="99">Blattbueschels</normalizedToken>
stehend
</emphasis>
, von gleichem 
<normalizedToken id="4DDE5F3DA1872B7BBFC4B54737CBFD07" originalValue="Umriß" pageId="null" pageNumber="99">Umriss</normalizedToken>
und gleicher Fiederung wie die nicht sporentragenden 
<normalizedToken id="55734C54661296E46540C692441A2BB6" originalValue="Blätter" pageId="null" pageNumber="99">Blaetter</normalizedToken>
, 
<emphasis id="79D0CEEF9CC5BD90B429B9218AB4E158" italics="true" pageId="null" pageNumber="99">die Fiedern 3. Ordnung jedoch eingerollt, zylindrisch</emphasis>
, die Sori 
<normalizedToken id="6C0B026774D86272C50531C2C6E8A758" originalValue="enthüllend" pageId="null" pageNumber="99">enthuellend</normalizedToken>
, wenn die Sporen reif sind. (Ausnahmsweise treten an nicht sporentragenden 
<normalizedToken id="8FF51392CDADC0DE46B976ABD6BC1D18" originalValue="Blättern" pageId="null" pageNumber="99">Blaettern</normalizedToken>
, namentlich an der Spitze der 
<normalizedToken id="8D6A5B2BBBB0C83FB119C310137A59D2" originalValue="Blätter" pageId="null" pageNumber="99">Blaetter</normalizedToken>
und an den Fiedern 1. Ordnung, teilweise sporentragende Endfiedern auf.) - Sporenreife: 
<normalizedToken id="92C704C86E3A47093D96FE2EE2887D42" originalValue="Spätsommer" pageId="null" pageNumber="99">Spaetsommer</normalizedToken>
und Herbst.
</paragraph>
<paragraph id="B436D5B643544C18E247FD401CEBB773" pageId="null" pageNumber="99">
<emphasis id="DEC2F161F342F9E60AE126359D0B0839" italics="true" pageId="null" pageNumber="99">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0948CB2C4312435BF2707F0FDB8FB726" italics="true" pageId="null" pageNumber="99">80:</emphasis>
Material aus Kanada (
<taxonomicName id="A8C6CFD49AAF8E184FBCF44505720D1B" authority="C. B. Clarke" authorityName="C. B. Clarke" pageId="null" pageNumber="99" rank="variety" variety="acrostichoides">
var. 
<emphasis id="F0A5B2C8302D02787DCFE6995EA428BA" italics="true" pageId="null" pageNumber="99">acrostichoides</emphasis>
C. B. Clarke
</taxonomicName>
) (Taylor und Lange 1963) 
<emphasis id="12E7B614374965BA6901DF3115D7DF4E" italics="true" pageId="null" pageNumber="99">2n</emphasis>
= 
<emphasis id="876DB5C1A956B6FC50689EE8E74F7BFD" italics="true" pageId="null" pageNumber="99">120:</emphasis>
Material aus England (Manton 1950).
</paragraph>
<paragraph id="5CB539CFC7176C0BDAB39C200DCFD755" pageId="null" pageNumber="99">
<emphasis id="B7BC54226B34172214B068A009FAB18A" italics="true" pageId="null" pageNumber="99">Standort.</emphasis>
Subalpin und alpin, selten montan, ausnahmsweise kollin (Grono im Misox, 310 m). Lockerer, grober, durchfeuchteter oder trockener Silikatschutt (nie auf Kalk), seltener in Felsspalten. 
<emphasis id="F3F79A11A1537320AF1A6728B9CD71EA" italics="true" pageId="null" pageNumber="99">Cryptogrammetum</emphasis>
Jenny-Lips 1930.
</paragraph>
<paragraph id="477D1B73BB014FDF3863AED812FA6E6B" pageId="null" pageNumber="99">
<emphasis id="6ADDD34548F19C931E99F8989454A658" italics="true" pageId="null" pageNumber="99">
Verbreitung. 
<normalizedToken id="8738B058F43DDA7AFC9AF90E2B906B72" originalValue="Europäische" pageId="null" pageNumber="99">Europaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
Nordgrenze durch Island, Lappland; 
<normalizedToken id="989FFEA130B9963B153897E1DE04CD1D" originalValue="Südgrenze" pageId="null" pageNumber="99">Suedgrenze</normalizedToken>
durch Sierra Nevada, Korsika, Apennin, Balkanhalbinsel, Kleinasien, Afghanistan; Ostgrenze im Ural. Zentral- und ostasiatische sowie nordamerikanische Sippen werden abgetrennt (vgl. 
<normalizedToken id="85C9AC09267422A9E6050B46FC3AB960" originalValue="Hultén" pageId="null" pageNumber="99">Hulten</normalizedToken>
1940-1949 und Verbreitungskarten von 
<normalizedToken id="69999DF1FDFDB3EB6ADCFD23096FAFD1" originalValue="Hultén" pageId="null" pageNumber="99">Hulten</normalizedToken>
1958 und Meusel 1964). - Im Gebiet: Alpen, 
<normalizedToken id="EE180EB1F017262802688545C95B92C7" originalValue="südlicher" pageId="null" pageNumber="99">suedlicher</normalizedToken>
Schwarzwald, Vogesen; ziemlich 
<normalizedToken id="23D1B4CC16D62F31E33BF26317D49B4A" originalValue="häufig" pageId="null" pageNumber="99">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
