<taxonomicName id="9AC477E8FFB7EF74FF4EF95FFD62F8BC" authority="Brunner von Wattenwyl, 1878" authorityName="Brunner von Wattenwyl" authorityYear="1878" box="[203,727,1770,1797]" class="Insecta" family="Tettigoniidae" kingdom="Animalia" order="Orthoptera" pageId="31" pageNumber="32" phylum="Arthropoda" rank="tribe" tribe="Odonturini">
Odonturini 
<bibRefCitation id="3955719AFFB7EF74FEE5F95EFD62F8BC" author="Brunner von Wattenwyl, C." box="[352,727,1770,1797]" pageId="31" pageNumber="32" pagination="1 - 401" refId="ref29469" refString="Brunner von Wattenwyl, C. (1878) Monographie der Phaneropteriden. Verhandlungen der Kaiserlich-Koniglichen Zoologisch- Botanischen Gesellschaft in Wien, 28, 1 - 401." type="journal article" year="1878">Brunner von Wattenwyl, 1878</bibRefCitation>
