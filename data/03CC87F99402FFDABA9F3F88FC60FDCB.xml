(
<bibRefCitation id="EFF44B1E9402FFD8BBDF3D5BFDE6F8C6" author="Suffrian, E." box="[471,635,1873,1900]" pageId="13" pageNumber="264" pagination="1 - 483" refId="ref25218" refString="Suffrian, E. (1866) Zur Kenntnis der Sudamerikanischen Cryptocephalen. Linnaea Entomologica, 16, 1 - 483." type="journal article" year="1866">Suffrian, 1866</bibRefCitation>
)
</taxonomicName>
