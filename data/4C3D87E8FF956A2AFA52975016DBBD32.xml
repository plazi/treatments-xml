<quantity id="036C9B1BFF956A2AF7C6920D1699BF47" box="[2106,2201,1108,1141]" metricMagnitude="3" metricUnit="m" metricValue="2.25" pageId="110" pageNumber="868" unit="m" value="2250.0">2250 m</quantity>
,in central mountains of 
<collectingCountry id="BC83766EFF956A2AF607920D145EBF47" box="[2555,2654,1108,1141]" name="Taiwan" pageId="110" pageNumber="868">Taiwan</collectingCountry>
.
</paragraph>
</subSubSection>
