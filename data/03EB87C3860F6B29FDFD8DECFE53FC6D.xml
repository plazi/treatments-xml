species. 
<taxonomicName id="4C424D56860F6B29FDEF8E74FC2AFDB3" authority="Yoo, 1994" authorityName="Yoo" authorityYear="1994" box="[567,944,512,552]" class="Gastropoda" genus="Palaeoalvania" higherTaxonomySource="GBIF" kingdom="Animalia" order="Heterostropha" pageId="29" pageNumber="92" phylum="Mollusca" rank="species" species="talenti" status="n.sp.">
<emphasis id="B936EAC7860F6B29FDEF8E74FC2AFDB3" box="[567,944,512,552]" italics="true" pageId="29" pageNumber="92">Palaeoalvania talenti</emphasis>
</taxonomicName>
