; B – 
<taxonomicName id="4C78F1F8E80951357D52F7D93C15F7C7" authority="Yin &amp; Li, 2021" authorityName="Yin &amp; Li" authorityYear="2021" box="[772,852,2061,2080]" class="Insecta" family="Staphylinidae" genus="Pselaphodes" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="44" phylum="Arthropoda" rank="species" species="nongfa" status="sp. nov.">
