</taxonomicName>
<taxonomicNameLabel id="A23FEB12E80951357D0CF7D93CDCF7C7" box="[858,925,2061,2080]" pageId="9" pageNumber="44" rank="species">sp. nov.</taxonomicNameLabel>
Scale bars: 1 mm.
</paragraph>
</caption>
<paragraph id="8BC78A7BE80A51367EE3FE0A3EC7FE12" blockId="10.[151,760,190,725]" box="[181,390,478,501]" pageId="10" pageNumber="45">
