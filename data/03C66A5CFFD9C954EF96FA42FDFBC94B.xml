<subSubSection id="C37588C1FFD9C954EFEBF9B3FDFBC94B" lastPageId="5" lastPageNumber="416" pageId="4" pageNumber="415" type="reference_group">
<paragraph id="8BD0DB4AFFD9C954EFEBF9B3FDFBC94B" blockId="4.[166,1225,1559,1841]" lastBlockId="5.[174,1232,175,266]" lastPageId="5" lastPageNumber="416" pageId="4" pageNumber="415">
Genus 
<taxonomicName id="4C6FA0C9FFD9C955EE1DF9B3FDABCE73" authority="Bonaparte, 1837" authorityName="Bonaparte" authorityYear="1837" box="[301,619,1559,1585]" class="Actinopterygii" family="Cyprinidae" genus="Scardinius" kingdom="Animalia" order="Cypriniformes" pageId="4" pageNumber="415" phylum="Chordata" rank="genus">
<emphasis id="B91B0758FFD9C955EE1DF9B3FE67CE73" box="[301,423,1559,1585]" italics="true" pageId="4" pageNumber="415">Scardinius</emphasis>
Bonaparte, 1837
</taxonomicName>
consists of 10 extant taxa (FishBase, 2014; 
<bibRefCitation id="EFFEA6BBFFD9C955EB6BF9B3FEEFCE13" author="Ketmaier, V. &amp; Bianco, P. G. &amp; Cobolli, M." pageId="4" pageNumber="415" pagination="1061 - 1071" refId="ref4433" refString="Ketmaier, V., Bianco, P. G., Cobolli, M. et al. Molecular phylogeny of two lineages of Leuciscinae cyprinids (Telestes and Scardinius) from the peri-Mediterranean area based on cytochrome b data // Molecular Phylogenetics and Evolution. - 2004. - 32. - P. 1061 - 1071." type="book chapter" year="2004">Ketmaier et al., 2004</bibRefCitation>
), including one species from the territory of 
<collectingCountry id="F3789BDAFFD9C955EC64F993FC74CE13" box="[852,948,1591,1617]" name="Ukraine" pageId="4" pageNumber="415">Ukraine</collectingCountry>
(
<bibRefCitation id="EFFEA6BBFFD9C955ECF7F993FB46CE13" author="Movchan, Yu. V." box="[967,1158,1590,1617]" pageId="4" pageNumber="415" refId="ref4514" refString="Movchan, Yu. V. Fishes of Ukraine. - Kyiv, 2011. - 444 p. - Ukrainian: Мovcaн Ю. V. Рibi Ukрayнi." type="book" year="2011">Movchan, 2011</bibRefCitation>
). The Rudd remnants were firstly appeared in the fossil record in the Middle Miocene — 
<taxonomicName id="4C6FA0C9FFD9C955EF96F9D3FDBACED3" authority="Sytchevskaya, 1989" authorityName="Sytchevskaya" authorityYear="1989" box="[166,634,1655,1681]" class="Actinopterygii" family="Cyprinidae" genus="Scardinius" kingdom="Animalia" order="Cypriniformes" pageId="4" pageNumber="415" phylum="Chordata" rank="species" species="tchuensis">
<emphasis id="B91B0758FFD9C955EF96F9D3FE52CED3" box="[166,402,1655,1681]" italics="true" pageId="4" pageNumber="415">Scardinius tchuensis</emphasis>
<bibRefCitation id="EFFEA6BBFFD9C955EEA9F9D3FDBACED3" author="Sytchevskaya, Y. K." box="[409,634,1655,1681]" pageId="4" pageNumber="415" refId="ref4915" refString="Sytchevskaya, Y. K. Freshwater Neogene Ichthyofauna of Mongolia // Trudy Sovmestnoy Sovetsko-Mongolskoy Paleontologicheskoy Ekspeditsii. - Moscow: Nauka, 1989. - N 39. - 144 p. - Russian: Сыcivсkai I. K. Pрiснovodнai iktioфauнa нiogiнa Мoнgoлii." type="book" year="1989">Sytchevskaya, 1989</bibRefCitation>
</taxonomicName>
from the Tueryk locality in 
<collectingCountry id="F3789BDAFFD9C955ECF9F9D3FBD5CED3" box="[969,1045,1655,1681]" name="Russia" pageId="4" pageNumber="415">Russia</collectingCountry>
(
<bibRefCitation id="EFFEA6BBFFD9C955EB14F9D3FF22CEF3" author="Sytchevskaya, Y. K." pageId="4" pageNumber="415" refId="ref4915" refString="Sytchevskaya, Y. K. Freshwater Neogene Ichthyofauna of Mongolia // Trudy Sovmestnoy Sovetsko-Mongolskoy Paleontologicheskoy Ekspeditsii. - Moscow: Nauka, 1989. - N 39. - 144 p. - Russian: Сыcivсkai I. K. Pрiснovodнai iktioфauнa нiogiнa Мoнgoлii." type="book" year="1989">Sytchevskaya, 1989</bibRefCitation>
), 
<taxonomicName id="4C6FA0C9FFD9C955EFCDF933FE65CEF3" box="[253,421,1687,1713]" class="Actinopterygii" family="Cyprinidae" genus="Scardinius" kingdom="Animalia" order="Cypriniformes" pageId="4" pageNumber="415" phylum="Chordata" rank="species" species="undetermined">
<emphasis id="B91B0758FFD9C955EFCDF933FEB7CEF3" box="[253,375,1687,1713]" italics="true" pageId="4" pageNumber="415">Scardinius</emphasis>
sp.
</taxonomicName>
from the Baghmisheh-Marzdaran in 
<collectingCountry id="F3789BDAFFD9C955EC4FF933FC71CEF3" box="[895,945,1687,1713]" name="Iran" pageId="4" pageNumber="415">Iran</collectingCountry>
(
<bibRefCitation id="EFFEA6BBFFD9C955ECF6F933FF22CE93" author="Reichenbacher, B. &amp; Alimohammadian, H. &amp; Sabouri, J." pageId="4" pageNumber="415" pagination="1 - 18" refId="ref4710" refString="Reichenbacher, B., Alimohammadian, H., Sabouri, J. et al. Late Miocene stratigraphy, palaeoecology and palaeogeography of the Tabriz Basin (NW Iran, Eastern Paratethys) // Palaeogeography, Palaeoclimatology, Palaeoecology. - 2011. - 311. - P. 1 - 18." type="book chapter" year="2011">Reichenbacher et al., 2011</bibRefCitation>
), and also 
<taxonomicName id="4C6FA0C9FFD9C955EE6FF913FE19CE93" authorityName="Bonaparte" authorityYear="1837" box="[351,473,1719,1745]" class="Actinopterygii" family="Cyprinidae" genus="Scardinius" kingdom="Animalia" order="Cypriniformes" pageId="4" pageNumber="415" phylum="Chordata" rank="genus">
<emphasis id="B91B0758FFD9C955EE6FF913FE19CE93" box="[351,473,1719,1745]" italics="true" pageId="4" pageNumber="415">Scardinius</emphasis>
</taxonomicName>
cf. sp. from Unggeried in 
<collectingCountry id="F3789BDAFFD9C955EC20F913FCBFCE93" box="[784,895,1719,1745]" name="Germany" pageId="4" pageNumber="415">Germany</collectingCountry>
and Mataschen, 
<collectingRegion id="49AB15A8FFD9C955EB78F913FB09CE93" box="[1096,1225,1719,1745]" country="Austria" name="Steiermark" pageId="4" pageNumber="415">Steiermark</collectingRegion>
in 
<collectingCountry id="F3789BDAFFD9C955EFF8F973FEDFCEB3" box="[200,287,1751,1777]" name="Austria" pageId="4" pageNumber="415">Austria</collectingCountry>
(Böhme, 2003; 
<bibRefCitation id="EFFEA6BBFFD9C955EEEFF973FD43CEB3" author="Schultz, O." box="[479,643,1750,1777]" pageId="4" pageNumber="415" pagination="231 - 256" refId="ref4875" refString="Schultz, O. Fish remains from the Lower Pannonian (Upper Miocene) of Mataschen, Styria (Austria) // Joannea Geologie und Palaontologie. - 2004. - 5. - P. 231 - 256." type="book chapter" year="2004">Schultz, 2004</bibRefCitation>
). Besides, three extinct Rudd species (
<taxonomicName id="4C6FA0C9FFD9C955EB7EF973FE03CF53" authority="(Munster, 1842)" baseAuthorityName="Munster" baseAuthorityYear="1842" class="Actinopterygii" family="Cyprinidae" genus="Scardinius" kingdom="Animalia" order="Cypriniformes" pageId="4" pageNumber="415" phylum="Chordata" rank="species" species="haueri">
<emphasis id="B91B0758FFD9C955EB7EF973FF31CF53" italics="true" pageId="4" pageNumber="415">Scardinius haueri</emphasis>
(
<bibRefCitation id="EFFEA6BBFFD9C955EE35F953FE7ACF53" author="Munster, G." box="[261,442,1782,1809]" pageId="4" pageNumber="415" pagination="65 - 69" refId="ref4544" refString="Munster, G. Beschreibung eininger fossilen Fischzahne aus dem Tertiar-Becken von Wien // Beitrage zur Petrefaktenkunde. - 1842. - 5. - S. 65 - 69." type="book chapter" year="1842">Münster, 1842</bibRefCitation>
)
</taxonomicName>
, 
<taxonomicName id="4C6FA0C9FFD9C955EEE3F953FCB4CF53" authority="Schtylko, 1934" authorityName="Schtylko" authorityYear="1934" box="[467,884,1783,1809]" class="Actinopterygii" family="Cyprinidae" genus="Scardinius" kingdom="Animalia" order="Cypriniformes" pageId="4" pageNumber="415" phylum="Chordata" rank="species" species="prolixus">
<emphasis id="B91B0758FFD9C955EEE3F953FD75CF53" box="[467,693,1783,1809]" italics="true" pageId="4" pageNumber="415">Scardinius prolixus</emphasis>
<bibRefCitation id="EFFEA6BBFFD9C955EDF1F953FCB4CF53" author="Schtylko, B. A." box="[705,884,1783,1809]" pageId="4" pageNumber="415" refId="ref4828" refString="Schtylko, B. A. Neogene freshwater fish fauna of Western Siberia // Trudy VGRO NKTP SSSR. - 1934. - 359. - P. 1 - 93. - Russian: Stыльko B. A. Нiogiнovai фauнa pрiснovodныk рыb Zapadнoй Сibiрi." type="book" year="1934">Schtylko, 1934</bibRefCitation>
</taxonomicName>
, and 
<taxonomicName id="4C6FA0C9FFD9C955EC8BF953FE4ECF73" authority="Sytchevskaya, 1989" authorityName="Sytchevskaya" authorityYear="1989" class="Actinopterygii" family="Cyprinidae" genus="Scardinius" kingdom="Animalia" order="Cypriniformes" pageId="4" pageNumber="415" phylum="Chordata" rank="species" species="longipinnus">
<emphasis id="B91B0758FFD9C955EC8BF953FB09CF53" box="[955,1225,1783,1809]" italics="true" pageId="4" pageNumber="415">Scardinius longipinnus</emphasis>
<bibRefCitation id="EFFEA6BBFFD9C955EF96F8B3FE4ECF73" author="Sytchevskaya, Y. K." box="[166,398,1814,1841]" pageId="4" pageNumber="415" refId="ref4915" refString="Sytchevskaya, Y. K. Freshwater Neogene Ichthyofauna of Mongolia // Trudy Sovmestnoy Sovetsko-Mongolskoy Paleontologicheskoy Ekspeditsii. - Moscow: Nauka, 1989. - N 39. - 144 p. - Russian: Сыcivсkai I. K. Pрiснovodнai iktioфauнa нiogiнa Мoнgoлii." type="book" year="1989">Sytchevskaya, 1989</bibRefCitation>
</taxonomicName>
) were described from the Late Miocene strata of Europe and Asia (
<bibRefCitation id="EFFEA6BBFFD8C954EF86FF0BFEA7C88B" author="Munster, G." box="[182,359,175,201]" pageId="5" pageNumber="416" pagination="65 - 69" refId="ref4544" refString="Munster, G. Beschreibung eininger fossilen Fischzahne aus dem Tertiar-Becken von Wien // Beitrage zur Petrefaktenkunde. - 1842. - 5. - S. 65 - 69." type="book chapter" year="1842">Münster, 1842</bibRefCitation>
; 
<bibRefCitation id="EFFEA6BBFFD8C954EE44FF0BFDE3C88B" author="Schtylko, B. A." box="[372,547,175,201]" pageId="5" pageNumber="416" refId="ref4828" refString="Schtylko, B. A. Neogene freshwater fish fauna of Western Siberia // Trudy VGRO NKTP SSSR. - 1934. - 359. - P. 1 - 93. - Russian: Stыльko B. A. Нiogiнovai фauнa pрiснovodныk рыb Zapadнoй Сibiрi." type="book" year="1934">Schtylko, 1934</bibRefCitation>
; 
<bibRefCitation id="EFFEA6BBFFD8C954ED00FF0BFCD7C888" author="Sytchevskaya, Y. K." box="[560,791,175,202]" pageId="5" pageNumber="416" refId="ref4915" refString="Sytchevskaya, Y. K. Freshwater Neogene Ichthyofauna of Mongolia // Trudy Sovmestnoy Sovetsko-Mongolskoy Paleontologicheskoy Ekspeditsii. - Moscow: Nauka, 1989. - N 39. - 144 p. - Russian: Сыcivсkai I. K. Pрiснovodнai iktioфauнa нiogiнa Мoнgoлii." type="book" year="1989">Sytchevskaya, 1989</bibRefCitation>
). It should be noted, that five taxa of the 
<taxonomicName id="4C6FA0C9FFD8C954EFE9FF6BFE93C8AB" authorityName="Bonaparte" authorityYear="1837" box="[217,339,207,233]" class="Actinopterygii" family="Cyprinidae" genus="Scardinius" kingdom="Animalia" order="Cypriniformes" pageId="5" pageNumber="416" phylum="Chordata" rank="genus">
<emphasis id="B91B0758FFD8C954EFE9FF6BFE93C8AB" box="[217,339,207,233]" italics="true" pageId="5" pageNumber="416">Scardinius</emphasis>
</taxonomicName>
genus were identified in the Late Miocene of Southern 
<collectingCountry id="F3789BDAFFD8C954ECE1FF6BFBF4C8AB" box="[977,1076,207,233]" name="Ukraine" pageId="5" pageNumber="416">Ukraine</collectingCountry>
. One of them is described here as a new species.
</paragraph>
