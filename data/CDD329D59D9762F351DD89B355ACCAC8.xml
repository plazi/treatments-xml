<subSubSection id="8CEB465028CACE49B18E9CE4BB655F7A" pageId="null" pageNumber="590" type="description">
<paragraph id="D97E9A94E0D3A837F5B470293B1B19C3" pageId="null" pageNumber="590">
<emphasis id="F706DB3A19233E136557F338A1AA2026" italics="true" pageId="null" pageNumber="590">Stengel meist 4</emphasis>
- 
<emphasis id="3E3B5CD926FB5830DC2F106979C8F7D1" italics="true" pageId="null" pageNumber="590">
8 
<normalizedToken id="67E0C1FD877DF028F7BB80116FE0D517" originalValue="köpfig" pageId="null" pageNumber="590">koepfig</normalizedToken>
.
</emphasis>
<normalizedToken id="3AA998AD0C3852E1801F7C4C38770582" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
lanzettlich, oft mit einzelnen 
<normalizedToken id="7D848353FAD2285F25E4EC80685C50D1" originalValue="Zähnen" pageId="null" pageNumber="590">Zaehnen</normalizedToken>
, die 
<normalizedToken id="C8ED83663370E39EEFBD633093EF8428" originalValue="größeren" pageId="null" pageNumber="590">groesseren</normalizedToken>
5-25mal so lang wie breit, 
<emphasis id="BD3CA6796EE370DE130456E09C29B308" italics="true" pageId="null" pageNumber="590">
zwischen Spreite und Blattgrund meist bis fast auf den Mittelnerv 
<normalizedToken id="371608870AE09518F89E94FD8932D9E0" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
</emphasis>
(
<emphasis id="5667D8B8A79E5591DF510C22B3A57648" italics="true" pageId="null" pageNumber="590">1</emphasis>
- 
<emphasis id="8F91CFDA0FB6EAB6E3ECB12646E0593B" italics="true" pageId="null" pageNumber="590">3 mm breit</emphasis>
)
<emphasis id="89C15259802635B236B070C257EF6FDC" italics="true" pageId="null" pageNumber="590">
. 
<normalizedToken id="408949776BBE6C7BECD2D5CFE5F67FA4" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
9
</emphasis>
- 
<emphasis id="BA2A99FB426CB4412C214A591A2EDAFA" italics="true" pageId="null" pageNumber="590">
11 mm lang. 
<normalizedToken id="A74500AC9A24AE696614A01206D7E394" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
1
</emphasis>
- 
<emphasis id="6BCF074854599096F6D0DADBF5AAC834" italics="true" pageId="null" pageNumber="590">1,8 mm breit.</emphasis>
<normalizedToken id="6473B6C500493C69C3E80E700FB74B82" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
meist dunkelbraun. - 
<normalizedToken id="B6DAA615C78CEFE865E87E73C9B98A2F" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="9E6C06BDA7AD93BFFEF7165B0949A699" pageId="null" pageNumber="590">
<emphasis id="F28B5AE498B460DA200EBD04687CF897" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="966492CF85F092F3059CFDED56D0E032" italics="true" pageId="null" pageNumber="590">27:</emphasis>
Material aus der Steiermark (Polatschek 1966a). Fortpflanzung apomiktisch (Ostenfeld 1906).
</paragraph>
<paragraph id="9DC469C7AB70221603980052177AA260" pageId="null" pageNumber="590">
<emphasis id="3599FCF2FFE0094C304FCAC1C67BC716" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Montan und subalpin, seltener kollin (herabgeschwemmt). Trockene, steinige, kalkhaltige 
<normalizedToken id="CA0FC0A7CFD074DB3C755FCB9F054843" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
in sonnigen Lagen. Felsspalten, 
<normalizedToken id="776D2B2D949D4ECAEE4856EFB71A817E" originalValue="Geröll" pageId="null" pageNumber="590">Geroell</normalizedToken>
. 
<emphasis id="8E18A5F85E6504A3E4C932F245763885" italics="true" pageId="null" pageNumber="590">
Potentillo-Hieracietum 
<taxonomicName id="D57898DCDDDA0DA01F57DD29502146D8" authority="Br." authorityName="Br." class="Magnoliopsida" family="Asteraceae" genus="Scorzonera" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="humilis">humilis Br.</taxonomicName>
</emphasis>
-Bl. 1933, 
<emphasis id="4492ACC237DFACB8453C5B77534064FF" italics="true" pageId="null" pageNumber="590">Stipetum Calamagrostis</emphasis>
Br.-Bl. 1918.
</paragraph>
<paragraph id="1A8FB5D05225A638CFEC0D0209075855" pageId="null" pageNumber="590">
<emphasis id="9C9B0F1C354E24E10A0377E6FCD64C69" italics="true" pageId="null" pageNumber="590">
Verbreitung. Mittel- und 
<normalizedToken id="41BA9457764AD6B94C55F857FCF37137" originalValue="südeuropäische" pageId="null" pageNumber="590">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="C08ED00255E65E0201907009CF5F0FEC" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="462467266ACA8F0DC0356AD5C7BD27E0" originalValue="östlich" pageId="null" pageNumber="590">oestlich</normalizedToken>
</emphasis>
)
<emphasis id="184A4595376197CD3A080BDEFD484DF8" italics="true" pageId="null" pageNumber="590">:</emphasis>
Alpen (
<normalizedToken id="08FD902C02621A74D7257CB3E949F8AE" originalValue="Dauphiné" pageId="null" pageNumber="590">Dauphine</normalizedToken>
bis 
<normalizedToken id="6BEFECB6A5F6786F925C863F27A09B5A" originalValue="Niederösterreich" pageId="null" pageNumber="590">Niederoesterreich</normalizedToken>
), Alpenvorland, Apennin, Gebirge der 
<normalizedToken id="B24A413FCEAF0791138E717BEC2EF38F" originalValue="nördlichen" pageId="null" pageNumber="590">noerdlichen</normalizedToken>
Balkanhalbinsel (
<normalizedToken id="6C0AA71250DCAF4314204C268152B398" originalValue="südwärts" pageId="null" pageNumber="590">suedwaerts</normalizedToken>
bis Bosnien). - Im Gebiet: Alpen; ziemlich selten.
</paragraph>
</subSubSection>
