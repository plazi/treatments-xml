“L’ile de 
<collectingRegion id="0650F81CFFBE6A01FBED904B1A4FBD1D" box="[1041,1103,1554,1583]" country="Indonesia" name="Jawa Timur" pageId="69" pageNumber="827">Java</collectingRegion>
