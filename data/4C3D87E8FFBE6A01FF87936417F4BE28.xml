<emphasis id="F6E0EAECFFBE6A01FD2A93BE1D72BD3A" bold="true" box="[726,882,1511,1544]" pageId="69" pageNumber="827">Taxonomy.</emphasis>
<taxonomicName id="03944D7DFFBE6A01FC6A93BE1D85BD1D" authority="Temminck, 1840" authorityName="Temminck" authorityYear="1840" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="69" pageNumber="827" phylum="Chordata" rank="species" species="circumdatus">Vespertilio circumdatus Temminck, 1840</taxonomicName>
