<taxonomicName id="4C0E4D2FFF83E570531A82E260C5F9B5" authorityName="DVORAK" authorityYear="1996" box="[831,974,1514,1537]" class="Insecta" family="Staphylinidae" genus="Zyras" kingdom="Animalia" order="Coleoptera" pageId="66" pageNumber="183" phylum="Arthropoda" rank="species" species="trapeziceps">
