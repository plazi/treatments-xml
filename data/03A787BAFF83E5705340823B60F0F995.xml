<taxonomicName id="4C0E4D2FFF83E570554782E26070F995" authority="sensu" authorityName="SenSU" class="Insecta" family="Staphylinidae" genus="Zyras" kingdom="Animalia" order="Coleoptera" pageId="66" pageNumber="186" phylum="Arthropoda" rank="genus">
<emphasis id="B97AEABEFF83E570554782E26697F9B5" box="[1378,1436,1514,1537]" italics="true" pageId="66" pageNumber="183">Zyras</emphasis>
