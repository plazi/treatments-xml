<subSubSection id="40D8FD3DAA6941D1747022F787D20DA9" pageId="null" pageNumber="101" type="vernacular_names">
<paragraph id="D6A6D41695779F590F6F3B64112E9DE4" pageId="null" pageNumber="101">Schmuckblume</paragraph>
</subSubSection>
</title>
<subSubSection id="7447870CF12EC33736533E758C6C7E17" pageId="null" pageNumber="101" type="description">
<paragraph id="7AB3B9597C07259FEF810A64127697C9" pageId="null" pageNumber="101">
Ausdauernde 
<normalizedToken id="F8B0EF9FD73D801728909D6F9B17FEB7" originalValue="Kräuter" pageId="null" pageNumber="101">Kraeuter</normalizedToken>
, mit kurzem Rhizom. 
<emphasis id="EBB748FF8DD06F981E486204762F1BC8" italics="true" pageId="null" pageNumber="101">
<normalizedToken id="5C9D44BECA026AE8F24589D6026EF630" originalValue="Blätter" pageId="null" pageNumber="101">Blaetter</normalizedToken>
1-2fach gefiedert.
</emphasis>
<normalizedToken id="2B8ED4B293BAAF2ACE4A581269B929D7" originalValue="Blüten" pageId="null" pageNumber="101">Blueten</normalizedToken>
aktinomorph, zwitterig. 
<normalizedToken id="A1F51ECE879B50CF2C954150548B2A53" originalValue="Kelchblätter" pageId="null" pageNumber="101">Kelchblaetter</normalizedToken>
5-10, 
<normalizedToken id="4C337A7773BC7361BBAF55DA96F14A0E" originalValue="hinfällig" pageId="null" pageNumber="101">hinfaellig</normalizedToken>
. 
<emphasis id="306168702C3BC6D2DB8F8176D2F89D5E" italics="true" pageId="null" pageNumber="101">
<normalizedToken id="327A7EA0372FCD4BE11CC9D4EDAC39AF" originalValue="Kronblätter" pageId="null" pageNumber="101">Kronblaetter</normalizedToken>
meist mehr als 5
</emphasis>
(
<emphasis id="599882F7A4A5189C2441DB32FCF78105" italics="true" pageId="null" pageNumber="101">bis 20</emphasis>
), 
<emphasis id="B5393B1E84B1A2DA5C45E0F60609226D" italics="true" pageId="null" pageNumber="101">
<normalizedToken id="D4A5C8D7F2BBA1BAF503DE407D1A3838" originalValue="weiß" pageId="null" pageNumber="101">weiss</normalizedToken>
oder 
<normalizedToken id="1DEBC5309A9AB8C4D73278AEF89974F8" originalValue="rötlich" pageId="null" pageNumber="101">roetlich</normalizedToken>
, mit 
<normalizedToken id="D521AEE1F11C3A6294F36DDEF337A0B5" originalValue="Honigdrüse" pageId="null" pageNumber="101">Honigdruese</normalizedToken>
.
</emphasis>
<normalizedToken id="4FC0AA83170C3C6D0B33BA74C952BFCC" originalValue="Staubblätter" pageId="null" pageNumber="101">Staubblaetter</normalizedToken>
zahlreich. Fruchtknoten zahlreich, auf kugeligem 
<normalizedToken id="A35F057682DFA0BD4FADCF9057A61D5B" originalValue="Blütenboden" pageId="null" pageNumber="101">Bluetenboden</normalizedToken>
, 1samig, 
<emphasis id="1A2366AA1A8FD6D232931211C25F1B49" italics="true" pageId="null" pageNumber="101">
mit 
<normalizedToken id="DA921A925C5707B3B22D4514F4DA1A3D" originalValue="hängender" pageId="null" pageNumber="101">haengender</normalizedToken>
Samenanlage
</emphasis>
, zudem noch 1 
<emphasis id="7BBC7202924791797DF26F7B5BC1040B" italics="true" pageId="null" pageNumber="101">sterile Samenanlage</emphasis>
vorhanden (Hauptunterschiede zur Gattung 
<taxonomicName id="B1DBBDBFD1F634400DE94276344C037F" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="101" phylum="Tracheophyta" rank="genus">
<emphasis id="DAD70AF5B6BB1663E25C055C8CC5BC82" italics="true" pageId="null" pageNumber="101">Ranunculus</emphasis>
</taxonomicName>
). 
<normalizedToken id="F55866EE5A3BD24437219147BBB7E7F6" originalValue="Früchtchen" pageId="null" pageNumber="101">Fruechtchen</normalizedToken>
im 
<normalizedToken id="784F1AA60C321404D511F540A4498EDA" originalValue="Umriß" pageId="null" pageNumber="101">Umriss</normalizedToken>
rundlich bis oval, kurz gestielt; die Narbe bildet einen Schnabel.
</paragraph>
<paragraph id="94200131AFBDE9E3B362F1FA97B24087" pageId="null" pageNumber="101">
Die Gattung 
<taxonomicName id="A1DDD5FB71A1CE41CA049A5D04DB8819" class="Magnoliopsida" family="Ranunculaceae" genus="Callianthemum" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="101" phylum="Tracheophyta" rank="genus">
<emphasis id="E8311A5BC03D9E5ECD3B0C63708B9551" italics="true" pageId="null" pageNumber="101">Callianthemum</emphasis>
</taxonomicName>
<normalizedToken id="68ECFC0F0B2F256B8A07640A61AC858C" originalValue="umfaßt" pageId="null" pageNumber="101">umfasst</normalizedToken>
etwa 
<emphasis id="1D5B7882D5DA9F764225C05C0690F995" italics="true" pageId="null" pageNumber="101">16 Arten</emphasis>
, davon kommen 
<emphasis id="E2D2D30715509C49B5B070D2594FAD6F" italics="true" pageId="null" pageNumber="101">
13 Arten in asiatischen, 3 in 
<normalizedToken id="5C155665A752F6527FA7278D72909764" originalValue="europäischen" pageId="null" pageNumber="101">europaeischen</normalizedToken>
Gebirgen vor: 
<taxonomicName id="3787444EED6C261809F45B318B59ABE4" authority="Freyn" authorityName="Freyn" class="Magnoliopsida" family="Ranunculaceae" genus="Callianthemum" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="101" phylum="Tracheophyta" rank="species" species="kernerianum">C. Kernerianum Freyn</taxonomicName>
</emphasis>
ist endemisch in den 
<normalizedToken id="9D4CC7B93C5516E6A4A4D958E7C8C417" originalValue="südlichen" pageId="null" pageNumber="101">suedlichen</normalizedToken>
Kalkalpen (Gebiet des Gardasees); 
<taxonomicName id="03C9B92CDD22C59D3B72E8EE85C84D21" authority="(Zahlbr.) Endl." authorityName="Endl." baseAuthorityName="Zahlbr." class="Magnoliopsida" family="Ranunculaceae" genus="Callianthemum" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="101" phylum="Tracheophyta" rank="species" species="anemonoides">
<emphasis id="4C24065AD2F15EE6BBE241E8F417567E" italics="true" pageId="null" pageNumber="101">C. anemonoides</emphasis>
(Zahlbr.) Endl.
</taxonomicName>
besiedelt ein 
<normalizedToken id="D3BA98CC751B46307D738E2227474DED" originalValue="größeres" pageId="null" pageNumber="101">groesseres</normalizedToken>
Areal in den 
<normalizedToken id="1AACA95833106B31E4C41D677B8437DF" originalValue="nordöstlichen" pageId="null" pageNumber="101">nordoestlichen</normalizedToken>
Kalkalpen (Nieder- und 
<normalizedToken id="BAEF88A0847297D3099DF4DA53417B5A" originalValue="Oberösterreich" pageId="null" pageNumber="101">Oberoesterreich</normalizedToken>
, Steiermark); im Gebiet nur 
<taxonomicName id="AE8B06F21D09ECCC5F3B6853EC2468B7" authority="Rchb. Verbreitungskarte" authorityName="Rchb. Verbreitungskarte" class="Magnoliopsida" family="Ranunculaceae" genus="Callianthemum" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="101" phylum="Tracheophyta" rank="species" species="coriandrifolium">
<emphasis id="4EF3D029F9AE97483D5FFA6114CC7AC7" italics="true" pageId="null" pageNumber="101">C. coriandrifolium</emphasis>
Rchb. Verbreitungskarte
</taxonomicName>
<normalizedToken id="0A9A4274C045E659AFE655FF674AF234" originalValue="für" pageId="null" pageNumber="101">fuer</normalizedToken>
12 Arten von Meusel (1965).
</paragraph>
</subSubSection>
