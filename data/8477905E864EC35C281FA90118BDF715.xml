<taxonomicName id="CBDE5ACB864EC35C2DD9AD8A1688F715" authority="Roosmalen et al. (2002)" authorityName="Roosmalen" authorityYear="2002" box="[1444,1750,2254,2279]" class="Liliopsida" family="Arecaceae" genus="Mauritia" kingdom="Plantae" order="Arecales" pageId="4" pageNumber="461" phylum="Tracheophyta" rank="species" species="van">van Roosmalen et al. (2002)</taxonomicName>
