<normalizedToken id="86B09D45916C57F014DF4EC33023BBDD" originalValue="längere" pageId="null" pageNumber="601">laengere</normalizedToken>
<normalizedToken id="E4D29F16F13FE8FA40DD16EACE73B6BC" originalValue="Kelchzähne" pageId="null" pageNumber="601">Kelchzaehne</normalizedToken>
<normalizedToken id="DE441BBB7EAEA32E01EAA782EFD87124" originalValue="½" pageId="null" pageNumber="601">1/2</normalizedToken>
-⅔ so lang wie die 
<normalizedToken id="1BAF948A432CAB08BBE54B3871780E33" originalValue="Kelchröhre" pageId="null" pageNumber="601">Kelchroehre</normalizedToken>
</td>
