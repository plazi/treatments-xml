<normalizedToken id="7F485BD1FDD08260B3F45191224B20C5" originalValue="längere" pageId="null" pageNumber="601">laengere</normalizedToken>
<normalizedToken id="43ED89D81ACDD847BA7986B3A51089AC" originalValue="Kelchzähne" pageId="null" pageNumber="601">Kelchzaehne</normalizedToken>
