<tr id="B4C11CB6870E6D501D8D8A6D47265DCC" pageId="null" pageNumber="601">
<td id="ACABF90D975445A9F373A9F5866E0907" align="left" pageId="null" pageNumber="601" valign="top">
2. Kelch 5-5,5 mm lang; 
<normalizedToken id="275A726EDFC9CCAA674F5C37858EFB2F" originalValue="längere" pageId="null" pageNumber="601">laengere</normalizedToken>
<normalizedToken id="82A888918A1F446F6C4ED4DB330F653B" originalValue="Kelchzähne" pageId="null" pageNumber="601">Kelchzaehne</normalizedToken>
⅔-⅘ so lang wie die 
<normalizedToken id="04DBF96E5ED9DF28A2D30A166896B006" originalValue="Kelchröhre" pageId="null" pageNumber="601">Kelchroehre</normalizedToken>
; Krone 1-1,4 cm lang
</td>
<td id="8C2BD637BFD9EA483790FAE63805AC3A" align="left" pageId="null" pageNumber="601" valign="bottom">
<taxonomicName id="A10705FC1EAAFF13B450ABD8957D491F" class="Magnoliopsida" family="Fabaceae" genus="Lathyrus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="601" phylum="Tracheophyta" rank="species" species="pratensis">
