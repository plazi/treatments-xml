<emphasis id="91843240FF9DFFE13D180F704380BF4F" box="[1091,1198,1094,1120]" italics="true" pageId="19" pageNumber="246">S. gracile</emphasis>
</taxonomicName>
, both deposited in RB (
<accessionNumber id="BCA373B1FF9DFFE139CB0F5C4626BFAB" box="[144,264,1130,1156]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/RB118804" pageId="19" pageNumber="246">
<collectionCode id="C5E17697FF9DFFE139CB0F5C479BBFAB" box="[144,181,1130,1156]" country="Brazil" lsid="urn:lsid:biocol.org:col:15528" name="Jardim Botânico do Rio de Janeiro" pageId="19" pageNumber="246" type="Herbarium">RB</collectionCode>
118804
</accessionNumber>
/ 
<collectorName id="0E058B84FF9DFFE138400F5C4642BFAB" box="[283,364,1130,1156]" pageId="19" pageNumber="246">Rizzini</collectorName>
s.n. and 
<accessionNumber id="BCA373B1FF9DFFE138820F5C457CBFAB" box="[473,594,1130,1156]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/RB121073" pageId="19" pageNumber="246">RB121073</accessionNumber>
/ 
<collectorName id="0E058B84FF9DFFE13B3F0F5C45D3BFAB" box="[612,765,1130,1156]" pageId="19" pageNumber="246">E.P. Heringer</collectorName>
