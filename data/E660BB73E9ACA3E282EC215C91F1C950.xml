<subSubSection id="2F444D8704686C3DF991B6476E73F01C" pageId="null" pageNumber="145" type="description">
<paragraph id="80C0F3317A3E11478EB0E6B3AB4D9A80" pageId="null" pageNumber="145">
Oft 
<normalizedToken id="B7A888C62575C2899F17447E3BDB77FB" originalValue="gynodiözisch" pageId="null" pageNumber="145">gynodioezisch</normalizedToken>
(s. Familienbeschreibung). Kelch 
<normalizedToken id="F38BEEA5CF5D488820A1000C45E216C2" originalValue="glockenförmig" pageId="null" pageNumber="145">glockenfoermig</normalizedToken>
, 
<emphasis id="AF6B19E2AE785E148CB3009A75863BED" italics="true" pageId="null" pageNumber="145">10</emphasis>
- 
<emphasis id="5434ECCF153D03FFA78FF71DBAA17B94" italics="true" pageId="null" pageNumber="145">
13nervig, 
<normalizedToken id="0AA6470183D96A1EBC3BBAC5FA987308" originalValue="gleichmäßig" pageId="null" pageNumber="145">gleichmaessig</normalizedToken>
5 
<normalizedToken id="3CD6CAAFC223E34C55D42923357783F7" originalValue="zähnig" pageId="null" pageNumber="145">zaehnig</normalizedToken>
</emphasis>
(nicht 21ippig); 
<emphasis id="52B1EF9554499E610E4F4240DE6F379F" italics="true" pageId="null" pageNumber="145">
innere Seite der 
<normalizedToken id="782F1DB6B1DB6A4741FB3F135119814D" originalValue="Kelchröhre" pageId="null" pageNumber="145">Kelchroehre</normalizedToken>
dicht mit 0,4
</emphasis>
- 
<emphasis id="A721B4A224449FAB563FEF2E5E0DEFC6" italics="true" pageId="null" pageNumber="145">
1 mm langen, 
<normalizedToken id="C1B9162116DE66F4C96CC094E2B27D66" originalValue="weißen" pageId="null" pageNumber="145">weissen</normalizedToken>
, mehrzelligen Haaren besetzt
</emphasis>
(
<normalizedToken id="46440569F01BF57470A8730141541711" originalValue="bärtiger" pageId="null" pageNumber="145">baertiger</normalizedToken>
Schlund). Krone 
<normalizedToken id="07BAEE37408B0906203A9E2457EB223C" originalValue="außen" pageId="null" pageNumber="145">aussen</normalizedToken>
und oft auch innen behaart, mit einer 
<normalizedToken id="6209F17B319CDD8579C5E08E451842A3" originalValue="Röhre" pageId="null" pageNumber="145">Roehre</normalizedToken>
und 21ippigem Rand; Oberlippe ausgerandet, fast flach; Unterlippe 3teilig, Oberlippe und Mittelabschnitt der Unterlippe 1-2mal so breit wie die seitlichen Abschnitte (bei allen andern Gattungen im Gebiet mit 21ippiger Krone 
<normalizedToken id="944FE76CA37613DDC334C358E4486086" originalValue="außer" pageId="null" pageNumber="145">ausser</normalizedToken>
<taxonomicName id="4662E12F5646869578711CC16B037875" class="Magnoliopsida" family="Lamiaceae" genus="Majorana" higherTaxonomySource="GBIF" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="145" phylum="Tracheophyta" rank="genus">
<emphasis id="C25F166CD0CCD410C11E0246FAD30E01" italics="true" pageId="null" pageNumber="145">Majorana</emphasis>
</taxonomicName>
und 
<taxonomicName id="1616957973197AF512E428F74C4D32E8" class="Insecta" family="Eulophidae" genus="Thymus" kingdom="Animalia" order="Hymenoptera" pageId="null" pageNumber="145" phylum="Arthropoda" rank="genus">
<emphasis id="238E7EFE49C1C1701026E90ED122F486" italics="true" pageId="null" pageNumber="145">Thymus</emphasis>
</taxonomicName>
entweder die Oberlippe oder der Mittelabschnitt der Unterlippe mindestens 2mal so breit wie die seitlichen Abschnitte der Unterlippe). 
<normalizedToken id="A3061029C2F144392219F7FECC4BA99E" originalValue="Staubblätter" pageId="null" pageNumber="145">Staubblaetter</normalizedToken>
4, frei aus der 
<normalizedToken id="3C1840DD5C24F69B648C528FE8AC0ADD" originalValue="Kronröhre" pageId="null" pageNumber="145">Kronroehre</normalizedToken>
herausragend und spreizend; Staubbeutel mit gespreizten 
<normalizedToken id="26ED4588BC7F90E838F3BEB5C7CD388C" originalValue="Hälften" pageId="null" pageNumber="145">Haelften</normalizedToken>
. 
<normalizedToken id="39ACD66374F6E70B3D76C337DB75D05D" originalValue="Teilfrüchte" pageId="null" pageNumber="145">Teilfruechte</normalizedToken>
kugelig bis 
<normalizedToken id="E18DB864CCCD65317410F1549E56FE5A" originalValue="eiförmig" pageId="null" pageNumber="145">eifoermig</normalizedToken>
, im 
<emphasis id="4A34A624961CFCAE1D08E2FCE90C0444" italics="true" pageId="null" pageNumber="145">Durchmesser 0,5</emphasis>
- 
<emphasis id="E1506173035B1FA127525E53B2220B03" italics="true" pageId="null" pageNumber="145">1 mm.</emphasis>
</paragraph>
<paragraph id="778F6868DC2905FB209CA57C00DE31E0" pageId="null" pageNumber="145">
Die Gattung 
<taxonomicName id="7B6583223CD05ADF3E1817FD3C05B7BA" class="Magnoliopsida" family="Lamiaceae" genus="Origanum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="145" phylum="Tracheophyta" rank="genus">
<emphasis id="2D47218B41359D946E41F13446DDCA6E" italics="true" pageId="null" pageNumber="145">Origanum</emphasis>
</taxonomicName>
, die mit 
<taxonomicName id="38454AC8993CF56D63341D9D10190112" class="Insecta" family="Eulophidae" genus="Thymus" kingdom="Animalia" order="Hymenoptera" pageId="null" pageNumber="145" phylum="Arthropoda" rank="genus">
<emphasis id="CD32B23D09CAF4672C5ED6EF4F7AC5CE" italics="true" pageId="null" pageNumber="145">Thymus</emphasis>
</taxonomicName>
und besonders 
<taxonomicName id="39B760364AEFC868458AF5563048FC6C" class="Magnoliopsida" family="Lamiaceae" genus="Majorana" higherTaxonomySource="GBIF" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="145" phylum="Tracheophyta" rank="genus">
<emphasis id="F80E3EAD88E6A751F897AA458FF702E9" italics="true" pageId="null" pageNumber="145">Majorana</emphasis>
</taxonomicName>
nahe verwandt ist, 
<normalizedToken id="5F3FC4B80AE9D6548E6BA7A0499DC1A3" originalValue="umfaßt" pageId="null" pageNumber="145">umfasst</normalizedToken>
etwa 
<emphasis id="6F0FED942815894812DA8C4DC003E0E9" italics="true" pageId="null" pageNumber="145">8 Arten</emphasis>
und hat 
<emphasis id="AE0BA269BFD6FAE35EA1CD6079786208" italics="true" pageId="null" pageNumber="145">mediterrane Verbreitung.</emphasis>
</paragraph>
</subSubSection>
