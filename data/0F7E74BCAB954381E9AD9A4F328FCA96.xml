<subSubSection id="A50BCD3664108A799982270DE1FDBD1F" pageId="null" pageNumber="208" type="description">
<paragraph id="92F575C43A931933EF6AE9DFE346F1E8" pageId="null" pageNumber="208">
Unterscheidet sich von 
<taxonomicName id="03932259082F16302D0C1150EAB844B3" class="Magnoliopsida" family="Brassicaceae" genus="Cardamine" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="208" phylum="Tracheophyta" rank="species" species="kitaibelii">
<emphasis id="BB325721C2559CE87D9F8F688AF6497A" italics="true" pageId="null" pageNumber="208">C. Kitaibelii</emphasis>
</taxonomicName>
(Nr. 13) durch folgende Merkmale: 30 
<emphasis id="D2550DF57859B1B2EEBDDD6F59D6A6CB" italics="true" pageId="null" pageNumber="208">-</emphasis>
60 cm hoch; 
<emphasis id="C0CE200E14F492E988544AF50FA80263" italics="true" pageId="null" pageNumber="208">
<normalizedToken id="3ED7C883521E914115D0F377CD5C7661" originalValue="Blätter" pageId="null" pageNumber="208">Blaetter</normalizedToken>
mit meist 5 
<normalizedToken id="FA7CCEC65CA77851DB9A79E724A3F548" originalValue="radiär" pageId="null" pageNumber="208">radiaer</normalizedToken>
angeordneten 
<normalizedToken id="C310EA781A5FFC720B1B8F96066CF2FE" originalValue="Teilblättern" pageId="null" pageNumber="208">Teilblaettern</normalizedToken>
, am Stengel 
<normalizedToken id="978EFC3CE2A8576A06E7BA432D506175" originalValue="wechselständig" pageId="null" pageNumber="208">wechselstaendig</normalizedToken>
; 
<normalizedToken id="F81AC95DBED339A06FCAC34FF2C98FBC" originalValue="Kronblätter" pageId="null" pageNumber="208">Kronblaetter</normalizedToken>
violett;
</emphasis>
Griffel an der Frucht 7 
<emphasis id="F5FE0282F49A79BB82C6B85CBF50C29A" italics="true" pageId="null" pageNumber="208">-</emphasis>
10 mm lang. - 
<normalizedToken id="C0DB7FBBB29678E5874D6BD46EBA6DFC" originalValue="Blüte" pageId="null" pageNumber="208">Bluete</normalizedToken>
: 
<normalizedToken id="DAF2C69233870626EC3FF21E1369CECA" originalValue="Später" pageId="null" pageNumber="208">Spaeter</normalizedToken>
<normalizedToken id="B1A8210392CEA78C3979AE817C3C44F3" originalValue="Frühling" pageId="null" pageNumber="208">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="12BAC67AD96D94002AF820F9C23D35C5" pageId="null" pageNumber="208">
<emphasis id="D9CEDA428067551521E3CC7CEC876EE6" italics="true" pageId="null" pageNumber="208">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="3D334CEFC264FC2F97003B7569DEFA77" italics="true" pageId="null" pageNumber="208">48:</emphasis>
Material aus der Schweiz (Schwarzenbach 1922).
</paragraph>
<paragraph id="541D00CA9BDF12B561635E78B8EC153C" pageId="null" pageNumber="208">
<emphasis id="CBA9EB3E4655F15273583F6919317FD0" italics="true" pageId="null" pageNumber="208">Standort.</emphasis>
Montan, selten kollin und subalpin. Lockere, feuchte, 
<normalizedToken id="43624FBB5029F65A26DA49A28801B44A" originalValue="nährstoffreiche" pageId="null" pageNumber="208">naehrstoffreiche</normalizedToken>
, meist kalkhaltige, humose, tonige 
<normalizedToken id="752E9AAC304527E6522635D29E2AA1CC" originalValue="Böden" pageId="null" pageNumber="208">Boeden</normalizedToken>
in schattigen Lagen. 
<normalizedToken id="1FCFD56659A02A36241FFEA41C246FE5" originalValue="Schluchtwälder" pageId="null" pageNumber="208">Schluchtwaelder</normalizedToken>
, 
<normalizedToken id="A65B262B6036177137A7215413D673C9" originalValue="Buchenwälder" pageId="null" pageNumber="208">Buchenwaelder</normalizedToken>
, 
<normalizedToken id="7A6051A5B616B1CC6425D3DEA855F1B9" originalValue="Buchenmischwälder" pageId="null" pageNumber="208">Buchenmischwaelder</normalizedToken>
. 
<emphasis id="B192BD81E49B9DB390CAC85B4D3A7D24" italics="true" pageId="null" pageNumber="208">Fagion</emphasis>
<normalizedToken id="9B330607EAEECD82375B8BB5485BCA64" originalValue="Tüxen" pageId="null" pageNumber="208">Tuexen</normalizedToken>
et Diem. 1936.
</paragraph>
<paragraph id="C4A7D2CC98600CD9528A8BDFFA0E8D11" pageId="null" pageNumber="208">
<emphasis id="9FCA38EC4E4DA5B52B33580E194A8E54" italics="true" pageId="null" pageNumber="208">Verbreitung. Mittel</emphasis>
- 
<emphasis id="E908A36792836DB5D6F1BBD2A2417EBC" italics="true" pageId="null" pageNumber="208">
und 
<normalizedToken id="FE4FEC7E4064265541EBEBE7AF4F276B" originalValue="südeuropäische" pageId="null" pageNumber="208">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="93520D3EF446FEF84CD71A2CD55686B1" italics="true" pageId="null" pageNumber="208">westlich</emphasis>
): 
<normalizedToken id="92C18A8F81C53403DF7F6C19E5DC1462" originalValue="Pyrenäen" pageId="null" pageNumber="208">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="875E9178E2F63A74CF527D9C2A96E280" originalValue="Corbières" pageId="null" pageNumber="208">Corbieres</normalizedToken>
, Cevennen, Auvergne, Vogesen, Schwarzwald, Jura, Alpen und Alpenvorland, Bosnien - Herzegowina (Macelj). Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: Nordalpen und Jura, ziemlich verbreitet, nicht 
<normalizedToken id="9B1D866013D4A3AD20D3503C47208EFA" originalValue="häufig" pageId="null" pageNumber="208">haeufig</normalizedToken>
; sonst zerstreut und selten.
</paragraph>
</subSubSection>
