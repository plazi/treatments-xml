<taxonomicName id="4C264D55FFA0FFCEFF48F9EEFDDDF9DE" authority="(Shaw, 1802)" baseAuthorityName="Shaw" baseAuthorityYear="1802" box="[151,530,1627,1653]" class="Reptilia" family="Elapidae" genus="Hydrophis" kingdom="Animalia" order="Squamata" pageId="4" pageNumber="355" phylum="Chordata" rank="species" species="spiralis">
<emphasis id="B952EAC4FFA0FFCEFF48F9EEFEA1F9DF" bold="true" box="[151,366,1627,1652]" italics="true" pageId="4" pageNumber="355">Hydrophis spiralis</emphasis>
(
<bibRefCitation id="EFB74B27FFA0FFCEFEA0F9E9FDC5F9DE" author="Shaw, G." box="[383,522,1628,1653]" pageId="4" pageNumber="355" refId="ref14986" refString="Shaw, G. (1802) General zoology, or systematic natural history. Vol. 3. Part 2. G. Kearsley, Thomas Davison, London, 302 pp." type="book" year="1802">Shaw, 1802</bibRefCitation>
