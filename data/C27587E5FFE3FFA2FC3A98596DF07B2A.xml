Zone
</taxonomicName>
and 
<taxonomicName id="8DDC4D70FFE3FFA2FC959A776D9D7B2A" authority="Zone" authorityName="Zone" box="[831,1168,1587,1611]" class="Globothalamea" family="Truncorotaloididae" genus="Morozovella" kingdom="Chromista" order="Rotaliida" pageId="14" pageNumber="28" phylum="Foraminifera" rank="species" species="velascoensis">
<emphasis id="78A8EAE1FFE3FFA2FC959A776D5C7B2A" box="[831,1105,1587,1611]" italics="true" pageId="14" pageNumber="28">Morozovella velascoensis</emphasis>
