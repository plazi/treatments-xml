<subSubSection id="F43733F35060DC3DD8F44EB9866B715B" pageId="null" pageNumber="424" type="description">
<paragraph id="0C0635AA165FC07CBAD532571E4DBD2D" pageId="null" pageNumber="424">
1- oder 2 
<normalizedToken id="BD0A6445FCF5B55B1A4874AF661718C2" originalValue="jährig" pageId="null" pageNumber="424">jaehrig</normalizedToken>
, mit Pfahlwurzel; 30-75 cm hoch. Stengel und 
<normalizedToken id="103FB07352CD7E8F77F291F33EF96F3A" originalValue="Blätter" pageId="null" pageNumber="424">Blaetter</normalizedToken>
wie bei 
<taxonomicName id="3E8D9A1E78A927896358F1A7107BADEC" class="Magnoliopsida" family="Asteraceae" genus="Carduus" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="424" phylum="Tracheophyta" rank="species" species="pycnocephalus">
<emphasis id="14330BE99067F89D8BB6B23D6959D9EC" italics="true" pageId="null" pageNumber="424">C. pycnocephalus</emphasis>
</taxonomicName>
(Nr. 1). 
<emphasis id="EB1EE30CC5BB04A58D8D99C87015D551" italics="true" pageId="null" pageNumber="424">
<normalizedToken id="156B5674E6F001C37E916ABCC324C018" originalValue="Köpfe" pageId="null" pageNumber="424">Koepfe</normalizedToken>
meist zu 3
</emphasis>
- 
<emphasis id="CC752A51D1220442E91AF9F8C9BDC8AB" italics="true" pageId="null" pageNumber="424">8 am Ende der Zweige</emphasis>
<normalizedToken id="1C125F6B68A4DEC13F5009ABBFBBF06F" originalValue="knäuelig" pageId="null" pageNumber="424">knaeuelig</normalizedToken>
<normalizedToken id="CCF7D7DA73955F20CDAB1ACCF816C0D8" originalValue="gehäuft" pageId="null" pageNumber="424">gehaeuft</normalizedToken>
, zur 
<normalizedToken id="045E3D1DB1E25BD7DB841D1FEAE12DE6" originalValue="Blütezeit" pageId="null" pageNumber="424">Bluetezeit</normalizedToken>
<emphasis id="2A6B4D8EFB1C89B4F7CC2422A4D3EB0C" italics="true" pageId="null" pageNumber="424">0,6</emphasis>
- 
<emphasis id="ABE399B5FFF45E2D67270D4917C947E6" italics="true" pageId="null" pageNumber="424">1,1 cm dick</emphasis>
und doppelt so lang, zur Fruchtzeit als Ganzes abfallend. 
<normalizedToken id="5735A4088A42D6B14803525A9CCD423D" originalValue="Äußere" pageId="null" pageNumber="424">Aeussere</normalizedToken>
<normalizedToken id="67EA4804BBE0D9BD486818E9B17DDB3E" originalValue="Hüllblätter" pageId="null" pageNumber="424">Huellblaetter</normalizedToken>
etwa 2 mm breit 
<pageBreakToken id="CEFC47B9D9CF0A90B896EE319BF6E5DD" pageId="null" pageNumber="424">und</pageBreakToken>
meist 
<normalizedToken id="E9AAE134A65554BF5CB284D8299174DA" originalValue="allmählich" pageId="null" pageNumber="424">allmaehlich</normalizedToken>
zugespitzt, anliegend, mit kahlem Mittelnerv und kahlem, 
<normalizedToken id="A3C157622A22291E9F1138482E14C6CE" originalValue="häutigem" pageId="null" pageNumber="424">haeutigem</normalizedToken>
Rand, mit kurzem Stachel; die innern lang zugespitzt, 
<emphasis id="F57F6C5511A5619CABEA0FC1C22D0F3C" italics="true" pageId="null" pageNumber="424">
<normalizedToken id="C875E4FF711406188E7879458157C39D" originalValue="länger" pageId="null" pageNumber="424">laenger</normalizedToken>
als die 
<normalizedToken id="921950DAD6DCB8609EDAFAF7307123BE" originalValue="Blüten" pageId="null" pageNumber="424">Blueten</normalizedToken>
</emphasis>
. Kronen mit 
<normalizedToken id="5DF57A0D117761BA6F31A7A247C38D0B" originalValue="regelmäßigem" pageId="null" pageNumber="424">regelmaessigem</normalizedToken>
, 5teiligem obermTeil, 
<emphasis id="949114F3F2E0D8BBEDD53970D423C890" italics="true" pageId="null" pageNumber="424">0,9</emphasis>
- 
<emphasis id="87898036A9229A5CA19D54150470EBC8" italics="true" pageId="null" pageNumber="424">1,3 cm lang</emphasis>
, hell purpurn. 
<emphasis id="AE80A8C7F8B25D75BC8C95E781B69483" italics="true" pageId="null" pageNumber="424">
<normalizedToken id="8BC86F67C29B3C16406BCDAA61914082" originalValue="Früchte" pageId="null" pageNumber="424">Fruechte</normalizedToken>
3
</emphasis>
- 
<emphasis id="63013F9DC5B36A77981AE11E1BA9418F" italics="true" pageId="null" pageNumber="424">4 mm lang</emphasis>
. 
<taxonomicName id="46FDE23F7748F760D79DAE736C65572D" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="424" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
0,9-1,2 cm lang. - 
<normalizedToken id="87AEF7E2250DDE4F4C3F794878314726" originalValue="Blüte" pageId="null" pageNumber="424">Bluete</normalizedToken>
: 
<normalizedToken id="33F6F1EC4F3DC7BA253D41E1D3E6E698" originalValue="Später" pageId="null" pageNumber="424">Spaeter</normalizedToken>
<normalizedToken id="368AD3104F263036C4D7BB96503EE545" originalValue="Frühling" pageId="null" pageNumber="424">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="90507A67EBA05358B8CC75C9875C553F" pageId="null" pageNumber="424">
<emphasis id="55E3BE82722A23A2707E30E134D35948" italics="true" pageId="null" pageNumber="424">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="612C28154898CCD28662470051BA9C63" italics="true" pageId="null" pageNumber="424">54:</emphasis>
Material aus Argentinien (Moore und Frankton 1962), aus 
<normalizedToken id="1B2AAE25B0A7BA56D9688688C7AE3587" originalValue="Südfrankreich" pageId="null" pageNumber="424">Suedfrankreich</normalizedToken>
(Loon et al. 1971).
</paragraph>
<paragraph id="5D666FCCA3D5DFD4C281DAA34ED56268" pageId="null" pageNumber="424">
<emphasis id="2DB60A0E43450DF46974A45DB44814B8" italics="true" pageId="null" pageNumber="424">Standort</emphasis>
. Kollin. Trockene, warme Orte. 
<normalizedToken id="0232D23D54AE71DD9BA1B501576DA575" originalValue="Schuttplätze" pageId="null" pageNumber="424">Schuttplaetze</normalizedToken>
, Bahnareale.
</paragraph>
<paragraph id="4E8BEFF6AA83FA1F8E6B70CB262A2209" pageId="null" pageNumber="424">
<emphasis id="57350BBD22D13FF4A665BF29C1078F58" italics="true" pageId="null" pageNumber="424">
Verbreitung. 
<normalizedToken id="AA00099C1D97C00FB376140FB9912F0D" originalValue="Westeuropäisch-westmediterrane" pageId="null" pageNumber="424">Westeuropaeisch-westmediterrane</normalizedToken>
Pflanze:
</emphasis>
Ost- und 
<normalizedToken id="2712117DE883A26811930C1D0EA24BB1" originalValue="nordwärts" pageId="null" pageNumber="424">nordwaerts</normalizedToken>
bis Sardinien, Rhonetal, 
<normalizedToken id="386DF903A35B0CB9C4CBCB9F23685067" originalValue="Dänemark" pageId="null" pageNumber="424">Daenemark</normalizedToken>
, England und Irland; 
<normalizedToken id="B168FD1A8D7EFF98F6B58EA66F38F95B" originalValue="südwärts" pageId="null" pageNumber="424">suedwaerts</normalizedToken>
bis Marokko; in Amerika eingeschleppt. - Im Gebiet: 
<normalizedToken id="D2C39B9A824D0A7132899EB40D9A3A34" originalValue="Dép" pageId="null" pageNumber="424">Dep</normalizedToken>
. Ain, Genf (Confignon); sonst gelegentlich adventiv.
</paragraph>
</subSubSection>
