<tr id="84047DF149E86B135D621BE710668576" pageId="null" pageNumber="417">
<td id="DFA4A715975401F9C73C1E725EFD094F" align="left" pageId="null" pageNumber="417" valign="top">
1*. 
<normalizedToken id="8F426CA94067427C52FE2C9E24040043" originalValue="Hochblätter" pageId="null" pageNumber="417">Hochblaetter</normalizedToken>
die 
<normalizedToken id="43466278617077B817F43F16A316F321" originalValue="Teilblütenstände" pageId="null" pageNumber="417">Teilbluetenstaende</normalizedToken>
<normalizedToken id="1C1B56A3B75D291F0A404F0B5F6D1716" originalValue="überragend" pageId="null" pageNumber="417">ueberragend</normalizedToken>
(2-4mal so lang wie die 
<normalizedToken id="F82CA2E94EB292D817773F1BA7B25B76" originalValue="Teilblütenstände" pageId="null" pageNumber="417">Teilbluetenstaende</normalizedToken>
); 
<normalizedToken id="4B3736EF1F51A74F3478AB2BF0C9EF3B" originalValue="Blütenstände" pageId="null" pageNumber="417">Bluetenstaende</normalizedToken>
rotbraun; Perigonborsten 5-6; Pflanze mit unterirdischen 
<normalizedToken id="C0A80CD727C42F1ACEE5C48FC3F0B494" originalValue="Ausläufern" pageId="null" pageNumber="417">Auslaeufern</normalizedToken>
</td>
<td id="B5EAC3DA77FE50B153ADCE6775D9D10D" align="left" pageId="null" pageNumber="417" valign="bottom">
<italic id="8CC32EC1E0DAC5A76387C41935860932" pageId="null" pageNumber="417">R. fucsa</italic>
(Nr. 2)
</td>
