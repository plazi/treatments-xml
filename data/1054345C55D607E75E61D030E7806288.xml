<td id="4887EDB9A4354535C52A2E2EB1FE084B" align="left" pageId="null" pageNumber="417" valign="top">
1. 
<normalizedToken id="E4BF969544595844B58DB58D6F715811" originalValue="Hochblätter" pageId="null" pageNumber="417">Hochblaetter</normalizedToken>
die 
<normalizedToken id="4A9D8CF00B2530F050920C1A330D63CD" originalValue="Teilblütenstände" pageId="null" pageNumber="417">Teilbluetenstaende</normalizedToken>
meist nicht 
<normalizedToken id="C81CB700F5D1A28326CEE3BFF7167BD0" originalValue="überragend" pageId="null" pageNumber="417">ueberragend</normalizedToken>
; 
<normalizedToken id="18BF22C67F59040D19409CF28274B5A2" originalValue="Blütenstände" pageId="null" pageNumber="417">Bluetenstaende</normalizedToken>
<normalizedToken id="C1FAE19D44E41ADB25139258CB2D8762" originalValue="weiß" pageId="null" pageNumber="417">weiss</normalizedToken>
bis gelbbraun; Perigonborsten 9-13; Pflanze horstbildend
</td>
<td id="9C3305944AA6968FF25EB2FDA0ED2D38" align="left" pageId="null" pageNumber="417" valign="bottom">
<taxonomicName id="ACCE7DA9F4BD05D1E6CF985330C1FCF5" class="Pinopsida" family="Pinaceae" genus="Abies" kingdom="Plantae" order="Pinales" pageId="null" pageNumber="417" phylum="Tracheophyta" rank="species" species="alba">
