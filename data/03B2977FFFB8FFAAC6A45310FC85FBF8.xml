<collectingCountry id="F30C66F9FFB9FFAAC7545255FE27FC20" box="[359,426,870,896]" name="China" pageId="13" pageNumber="214">China</collectingCountry>
(
<collectingRegion id="49DFE88BFFB9FFAAC78A5255FDA8FC21" box="[441,549,870,897]" country="China" name="Liaoning" pageId="13" pageNumber="214">Liaoning</collectingRegion>
).
