No information.
</paragraph>
</subSubSection>
<subSubSection id="C31D6540FF98BD14FAE5F9DBF8A6F92F" box="[1378,1853,1636,1669]" pageId="4" pageNumber="133" type="activity">
<paragraph id="8BB836CBFF98BD14FAE5F9DBF8A6F92F" blockId="4.[1378,2585,1164,2064]" box="[1378,1853,1636,1669]" pageId="4" pageNumber="133">
<emphasis id="B973EAD9FF98BD14FAE5F9DBF9D6F92F" bold="true" box="[1378,1613,1636,1669]" pageId="4" pageNumber="133">Activity patterns.</emphasis>
