<subSubSection id="AD6884264E86C769789EB067C6FF4A1F" pageId="null" pageNumber="462" type="description">
<paragraph id="23B0E69217AED76992AC1367DC340760" pageId="null" pageNumber="462">
20-40 cm hoch; 
<emphasis id="54B092C6DC7A5280043C0A83FCD84C7E" italics="true" pageId="null" pageNumber="462">
lange, unterirdische 
<normalizedToken id="40CCA25CB1599ECBD372FF62543BCBDB" originalValue="Ausläufer" pageId="null" pageNumber="462">Auslaeufer</normalizedToken>
treibend.
</emphasis>
<normalizedToken id="07E1A057CC8F050E8E4379A00C76942F" originalValue="Grundständige" pageId="null" pageNumber="462">Grundstaendige</normalizedToken>
Blattscheiden rotbraun bis schwarz, 
<normalizedToken id="134134D364D4EB7E5223DF745EC6C43B" originalValue="glänzend" pageId="null" pageNumber="462">glaenzend</normalizedToken>
; kein Faserschopf. 
<normalizedToken id="9C0F60E26FDA77C97EB2E6983D962364" originalValue="Blätter" pageId="null" pageNumber="462">Blaetter</normalizedToken>
1,5-2 mm breit, flach, steif, den 
<normalizedToken id="66ECE24E5CA91DCB50D6E53839E1C9D2" originalValue="Blütenstand" pageId="null" pageNumber="462">Bluetenstand</normalizedToken>
nicht erreichend. Stengel 3kantig, nur im obern Teil rauh, 
<emphasis id="0123E914AB141CA70B29A8E51EBE02D6" italics="true" pageId="null" pageNumber="462">steif aufrecht.</emphasis>
<normalizedToken id="66B2E2C26EC5B02C5FB177D17F2A5CC0" originalValue="Blütenstand" pageId="null" pageNumber="462">Bluetenstand</normalizedToken>
2-3 cm lang, aus 1-3 seitlichen, 
<normalizedToken id="BBE6C2136186C8BF863466DA1B7D6960" originalValue="eiförmigen" pageId="null" pageNumber="462">eifoermigen</normalizedToken>
oder zylindrischen, 0,5-1,5 cm langen, sitzenden, aufrechten ♀ 
<normalizedToken id="B06AD37125DA7041C9B23D1895120AD2" originalValue="Ähren" pageId="null" pageNumber="462">Aehren</normalizedToken>
und 
<normalizedToken id="34FDE13BC0119E985ECFB40260004863" originalValue="darüber" pageId="null" pageNumber="462">darueber</normalizedToken>
1 
<normalizedToken id="683024F5194E24D0042E016344038FA3" originalValue="endständigen" pageId="null" pageNumber="462">endstaendigen</normalizedToken>
♂ 
<normalizedToken id="01DB44BD954A820E451C3E9C06F0F5ED" originalValue="Ähre" pageId="null" pageNumber="462">Aehre</normalizedToken>
. 
<emphasis id="103366B260BBE9BE35FC6EFF0C468708" italics="true" pageId="null" pageNumber="462">
Unterstes Hochblatt 
<normalizedToken id="8CA6362123A67EB1294F9D40CEB9EDA1" originalValue="blattähnlich" pageId="null" pageNumber="462">blattaehnlich</normalizedToken>
, abstehend, bis doppelt so lang wie die 
<normalizedToken id="29F290A8300DCB1A2B5EC63F19D3CABC" originalValue="zugehörige" pageId="null" pageNumber="462">zugehoerige</normalizedToken>
<normalizedToken id="C01073AB1ABBC9A909CA0DA9D30DE16A" originalValue="Ähre" pageId="null" pageNumber="462">Aehre</normalizedToken>
; Scheide etwa 2 mm lang.
</emphasis>
<normalizedToken id="E5F2ACB2E926681E4B96073BF2E1D452" originalValue="Tragblätter" pageId="null" pageNumber="462">Tragblaetter</normalizedToken>
etwa 
<normalizedToken id="9C26C1ABA4984822C56EB5A007D092E9" originalValue="¾" pageId="null" pageNumber="462">3/4</normalizedToken>
so lang wie die reifen 
<normalizedToken id="66E2801B3027A73E65353E2D3E57BC64" originalValue="Fruchtschläuche" pageId="null" pageNumber="462">Fruchtschlaeuche</normalizedToken>
, spitz, rotbraun, mit hellem Mittelnerv. 
<normalizedToken id="D90DA4A9B42CC3386727370A72492EB1" originalValue="Fruchtschläuche" pageId="null" pageNumber="462">Fruchtschlaeuche</normalizedToken>
1,5-2 mm lang, im obersten Drittel am breitesten (1-1,5 mm), 3kantig, ohne Nerven, graubraun, dicht behaart, 
<normalizedToken id="5D3A16A7CF3AC438661AE3713F0DB014" originalValue="plötzlich" pageId="null" pageNumber="462">ploetzlich</normalizedToken>
in die 2 
<normalizedToken id="FCBD457801C6326C9FA1A8215DB2223A" originalValue="zähnige" pageId="null" pageNumber="462">zaehnige</normalizedToken>
<normalizedToken id="00474FF4770341255426802DE0DFF5C1" originalValue="Mündung" pageId="null" pageNumber="462">Muendung</normalizedToken>
<normalizedToken id="88A8C02E62A7C592623840C5080FA5A5" originalValue="verschmälert" pageId="null" pageNumber="462">verschmaelert</normalizedToken>
(kein Schnabel). Narben 3.
</paragraph>
<paragraph id="A9B1D042A89583931BA4089B7497DA0B" pageId="null" pageNumber="462">
<emphasis id="24545EFF68A69754DA194E00846A7241" italics="true" pageId="null" pageNumber="462">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="9870F5A3560626A008679CF477A81E17" italics="true" pageId="null" pageNumber="462">48:</emphasis>
Material aus Schweden (Heilborn 1924).
</paragraph>
<paragraph id="E9F281FA76EB31272C9D3CA0CF525EC8" pageId="null" pageNumber="462">
<emphasis id="A039B28A06904B18FE9AA20904C2C018" italics="true" pageId="null" pageNumber="462">Standort.</emphasis>
Kollin und montan. Kalkreiche, nasse, im Sommer 
<normalizedToken id="39DF34B0B8BD49D3BDCECBFD52BCDA74" originalValue="oberflächlich" pageId="null" pageNumber="462">oberflaechlich</normalizedToken>
austrocknende, 
<normalizedToken id="CA5C6EC38B4A6E9AC8436272CA36371D" originalValue="ungedüngte" pageId="null" pageNumber="462">ungeduengte</normalizedToken>
, humose oder humusarme, dichte 
<normalizedToken id="BA20B2B7A7626776EC27B9E3562E7FC7" originalValue="Tonböden" pageId="null" pageNumber="462">Tonboeden</normalizedToken>
. Streuewiesen, lichte 
<normalizedToken id="2D1A4FC7917592C10C7AA96AA32B7B1D" originalValue="Laubmischwälder" pageId="null" pageNumber="462">Laubmischwaelder</normalizedToken>
.
</paragraph>
<paragraph id="66CD5C190C194E0B7888789918413820" pageId="null" pageNumber="462">
<emphasis id="7E67897D9F59BD4AC55A085030B07250" italics="true" pageId="null" pageNumber="462">Verbreitung. Eurasiatische Pflanze:</emphasis>
<taxonomicName id="D874DA9FAB1F637E0F58C0198E7CA911" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="462" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
(ohne arktische Gebiete und Mediterrangebiete), Kaukasus, Zentralasien, Sibirien (bis Baikalseegebiet). - Im Gebiet verbreitet, ziemlich 
<normalizedToken id="272B985B48BD1A4C499FB7C60F9A9CC5" originalValue="häufig" pageId="null" pageNumber="462">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
