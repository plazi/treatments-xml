<emphasis id="6C9E8265FFCE3357FDCDFCCF7066FCBF" bold="true" box="[580,597,781,807]" pageId="22" pageNumber="217">n</emphasis>
.
</taxonomicNameLabel>
, 
<taxonomicName id="99EA25F4FFCE3357FDFCFCCF76F7FCB0" authority="(Vanschuytbroeck, 1963)" authorityName="Korneyev" authorityYear="2016" baseAuthorityName="Vanschuytbroeck" baseAuthorityYear="1963" box="[629,1220,781,808]" class="Insecta" family="Pyrgotidae" genus="Campylocera" kingdom="Animalia" order="Diptera" pageId="22" pageNumber="217" phylum="Arthropoda" rank="species" species="obscura" status="comb. n.">
<emphasis id="6C9E8265FFCE3357FDFCFCCF7149FCBF" box="[629,890,781,807]" italics="true" pageId="22" pageNumber="217">Campylocera obscura</emphasis>
(
<bibRefCitation id="3A7B2386FFCE3357FC1CFCCF7688FCB0" author="Vanschuytbroeck, P." box="[917,1211,781,808]" pageId="22" pageNumber="217" pagination="1 - 76" refId="ref12157" refString="Vanschuytbroeck, P. 1963. Pyrgotidae (Diptera Otitoidea). Institut des Parcs Nationaux du Congo et du Rwanda, Exploration du Parc National de la Garamba, Miss. H. De Saeger, 38, 1 - 76." type="journal article" year="1963">Vanschuytbroeck, 1963</bibRefCitation>
)
</taxonomicName>
, 
<taxonomicNameLabel id="77AD3F1EFFCE3357FF2FFCEF733DFCD0" box="[166,270,813,840]" pageId="22" pageNumber="217" rank="species">
<emphasis id="6C9E8265FFCE3357FF2FFCEF72D9FCDF" bold="true" box="[166,234,813,839]" pageId="22" pageNumber="217">comb</emphasis>
. 
<emphasis id="6C9E8265FFCE3357FF71FCEF733AFCDF" bold="true" box="[248,265,813,839]" pageId="22" pageNumber="217">n</emphasis>
.
</taxonomicNameLabel>
, 
<taxonomicName id="99EA25F4FFCE3357FE96FCEF70E2FCD0" authority="(Steyskal, 1963)" authorityName="Korneyev" authorityYear="2016" baseAuthorityName="Steyskal" baseAuthorityYear="1963" box="[287,721,813,840]" class="Insecta" family="Pyrgotidae" genus="Campylocera" kingdom="Animalia" order="Diptera" pageId="22" pageNumber="217" phylum="Arthropoda" rank="species" species="similis" status="comb. n.">
<emphasis id="6C9E8265FFCE3357FE96FCEF7038FCDF" box="[287,523,813,839]" italics="true" pageId="22" pageNumber="217">Campylocera similis</emphasis>
(Steyskal, 1963)
</taxonomicName>
, 
<taxonomicNameLabel id="77AD3F1EFFCE3357FD56FCEF717AFCD0" box="[735,841,813,840]" pageId="22" pageNumber="217" rank="species">
<emphasis id="6C9E8265FFCE3357FD56FCEF7110FCDF" bold="true" box="[735,803,813,839]" pageId="22" pageNumber="217">comb</emphasis>
. 
<emphasis id="6C9E8265FFCE3357FCBAFCEF7177FCDF" bold="true" box="[819,836,813,839]" pageId="22" pageNumber="217">n</emphasis>
.
</taxonomicNameLabel>
, 
<taxonomicName id="99EA25F4FFCE3357FCD3FCEF72D8FCF0" authority="(Curran, 1928)" authorityName="Korneyev" authorityYear="2016" baseAuthorityName="Curran" baseAuthorityYear="1928" class="Insecta" family="Pyrgotidae" genus="Campylocera" kingdom="Animalia" order="Diptera" pageId="22" pageNumber="217" phylum="Arthropoda" rank="species" species="variceps" status="comb. n.">
<emphasis id="6C9E8265FFCE3357FCD3FCEF766AFCDF" box="[858,1113,813,839]" italics="true" pageId="22" pageNumber="217">Campylocera variceps</emphasis>
