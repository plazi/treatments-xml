</emphasis>
<treatmentCitation id="0AFBDD5E101BFFAEFEF5FEE77C105531" author="Corda" box="[300,1118,266,293]" page="41" pageId="12" pageNumber="49" score="0.2477259968713947" volumeTitle="Deutschlands Flora (Nurnberg)" year="1832">
