<subSubSection id="8B79E5E481677B259DAB6A74A71A0AB9" pageId="null" pageNumber="638" type="description">
<paragraph id="923AF2902BC9B1AB8CE82FC41DB53BBD" pageId="null" pageNumber="638">
Unterscheidet sich von 
<taxonomicName id="CFCC309F87D89B4D7DB5E01292F24BDD" class="Magnoliopsida" family="Linaceae" genus="Linum" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="638" phylum="Tracheophyta" rank="species" species="usitatissimum">
<emphasis id="4DFB2A3B96422A85C7A01688184FEEB3" italics="true" pageId="null" pageNumber="638">
<authorityName id="B5D600165DD838FD98EB71F3C2FDF987" pageId="null" pageNumber="638">L.</authorityName>
usitatissimum
</emphasis>
</taxonomicName>
(Nr. 6) durch folgende Merkmale: 
<emphasis id="B7A1E7D025F0C01B75E20AFD243E65B2" italics="true" pageId="null" pageNumber="638">
2 
<normalizedToken id="B8BCD987A97DB5F25D28401638CD1F9F" originalValue="jährig" pageId="null" pageNumber="638">jaehrig</normalizedToken>
oder ausdauernd;
</emphasis>
20-50 cm hoch; 
<emphasis id="495FF92AAFC39111078E4BC5D1D519EB" italics="true" pageId="null" pageNumber="638">
mit 
<normalizedToken id="775B7A6A5CF191CC4133306B7364BC7E" originalValue="nichtblühenden" pageId="null" pageNumber="638">nichtbluehenden</normalizedToken>
Sprossen;
</emphasis>
Stengel meist niederliegend oder aufsteigend; 
<normalizedToken id="CE40F877DA0D540D890322B285622FB8" originalValue="Blätter" pageId="null" pageNumber="638">Blaetter</normalizedToken>
8-20mal so lang wie breit, bis 5 cm lang; 
<normalizedToken id="B8A27CEBA8F2D8CBFAD2C2347D7B33EE" originalValue="Kelchblätter" pageId="null" pageNumber="638">Kelchblaetter</normalizedToken>
undeutlich 3nervig; 
<emphasis id="0154BB7B16622A9A07AC1E12597D2DE2" italics="true" pageId="null" pageNumber="638">
<normalizedToken id="66D55A55C156FD16A714B9875B1ED0F7" originalValue="Kronblätter" pageId="null" pageNumber="638">Kronblaetter</normalizedToken>
9-13 mm lang
</emphasis>
, hellblau; 
<emphasis id="8E4C79501C132B067B4882AA772C5833" italics="true" pageId="null" pageNumber="638">
Narben 
<normalizedToken id="26C50C5120B7C37AD9D0F3F753998F70" originalValue="fadenförmig" pageId="null" pageNumber="638">fadenfoermig</normalizedToken>
;
</emphasis>
Frucht 5-6,5 mm lang. - 
<normalizedToken id="B891077B303A6A4CC8E1674B00E0063E" originalValue="Blüte" pageId="null" pageNumber="638">Bluete</normalizedToken>
: 
<normalizedToken id="6FFECE1938212CB8C95BF761D4BDA64F" originalValue="Frühling" pageId="null" pageNumber="638">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="2DC6CF66C8568F01B4782B14ED3B8F7C" pageId="null" pageNumber="638">
<emphasis id="4AE8BE80B7E284510B670BDCEC758BBF" italics="true" pageId="null" pageNumber="638">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="C8CB5D4654853644D66637556EB6A5A0" italics="true" pageId="null" pageNumber="638">30:</emphasis>
Material aus botanischen 
<normalizedToken id="19DF63E8DE63FDD89823F1CB95B26BFD" originalValue="Gärten" pageId="null" pageNumber="638">Gaerten</normalizedToken>
(Vilmorin und Simonet 1927, Ray 1944, Gill und Yermanos 1967), aus Frankreich (Simonet 1929a). 
<emphasis id="4A24A95E3E45B3ACE96F3E10C5153633" italics="true" pageId="null" pageNumber="638">2n</emphasis>
= 
<emphasis id="1238531B7A1C89C60887851855A84BF5" italics="true" pageId="null" pageNumber="638">32:</emphasis>
Material aus Italien (Martzenitzina 1927).
</paragraph>
<paragraph id="4AE37CA868D4F548068B662895AF2C78" pageId="null" pageNumber="638">
<emphasis id="4A417A028B99CAD644D8DE8DE66250A5" italics="true" pageId="null" pageNumber="638">Standort.</emphasis>
Kollin. Trockene 
<normalizedToken id="EEFB91E2C0209492A365162B278BAC8D" originalValue="Böden" pageId="null" pageNumber="638">Boeden</normalizedToken>
in warmen Lagen. Buschige 
<normalizedToken id="8132CF49B49654E1185CC456EBACE443" originalValue="Hänge" pageId="null" pageNumber="638">Haenge</normalizedToken>
, Trockenwiesen.
</paragraph>
<paragraph id="1C0E5400A3485D7568864EC8204FA0D7" pageId="null" pageNumber="638">
<emphasis id="061267DDE1299E415F467AA6EF47B228" italics="true" pageId="null" pageNumber="638">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="39A95AFE37B8D44F343DC5E49F09B2AC" originalValue="Nordwärts" pageId="null" pageNumber="638">Nordwaerts</normalizedToken>
vereinzelt bis 
<normalizedToken id="628F3355D8074CB3C3D4457D217CB27E" originalValue="Großbritannien" pageId="null" pageNumber="638">Grossbritannien</normalizedToken>
, Gebiet der Loire, Alpen, Ungarn, Krim; Kaukasus, Kleinasien; Nordwestafrika; atlantische Inseln. - Im Gebiet: Comerseegebiet (Monte Grona), Valle San Martino; sonst selten adventiv.
</paragraph>
</subSubSection>
