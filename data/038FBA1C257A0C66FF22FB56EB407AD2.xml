<subSubSection id="C33C5881257A0C66FF72F92CEBDD7C4E" lastPageId="18" lastPageNumber="469" pageId="17" pageNumber="468" type="diagnosis">
<paragraph id="8B990B0A257A0C66FF72F92CEBDD7C4E" blockId="17.[151,1437,1396,2035]" lastBlockId="18.[151,1436,150,285]" lastPageId="18" lastPageNumber="469" pageId="17" pageNumber="468">
<emphasis id="B952D718257A0C65FF72F92CEE2D7BA5" bold="true" box="[199,322,1756,1782]" pageId="17" pageNumber="468">Diagnosis.</emphasis>
<taxonomicName id="4C267089257A0C65FEFCF92CEDD57BA5" box="[329,698,1756,1782]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="mediterraneus">
<emphasis id="B952D718257A0C65FEFCF92CEDD57BA5" box="[329,698,1756,1782]" italics="true" pageId="17" pageNumber="468">Oxynoemacheilus mediterraneus</emphasis>
</taxonomicName>
is distinguished from all species of the 
<taxonomicName id="4C267089257A0C65FBCEF92CEB947BA5" baseAuthorityName="Steindachner" baseAuthorityYear="1897" box="[1147,1275,1756,1782]" class="Actinopterygii" family="Nemacheilidae" genus="Orthrias" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="angorae">
<emphasis id="B952D718257A0C65FBCEF92CEB947BA5" box="[1147,1275,1756,1782]" italics="true" pageId="17" pageNumber="468">O. angorae</emphasis>
</taxonomicName>
species group by having a deeply emarginate caudal fin in which the shortest middle caudal-fin ray is 65–76% of the longest ray of the upper caudal-fin lobe (vs. moderately emarginate to almost truncate, 
<quantity id="4CDEA6EF257A0C65FC49F8D4EB0E7A6D" box="[1020,1121,1828,1854]" metricMagnitude="0" metricUnit="m" metricValue="2.2479" metricValueMax="2.3622" metricValueMin="2.1336" pageId="17" pageNumber="468" unit="in" value="88.5" valueMax="93.0" valueMin="84.0">84–93 in</quantity>
<taxonomicName id="4C267089257A0C65FBDFF8D4EA6C7A6D" box="[1130,1283,1828,1854]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="anatolicus">
<emphasis id="B952D718257A0C65FBDFF8D4EA6C7A6D" box="[1130,1283,1828,1854]" italics="true" pageId="17" pageNumber="468">O. anatolicus</emphasis>
</taxonomicName>
, 
<quantity id="4CDEA6EF257A0C65FAA6F8D4EA177A6D" box="[1299,1400,1828,1854]" metricMagnitude="0" metricUnit="m" metricValue="2.286" metricValueMax="2.3368" metricValueMin="2.2352" pageId="17" pageNumber="468" unit="in" value="90.0" valueMax="92.0" valueMin="88.0">88–92 in</quantity>
<taxonomicName id="4C267089257A0C65FA34F8D4EF9B7A31" baseAuthorityName="Steindachner" baseAuthorityYear="1897" class="Actinopterygii" family="Nemacheilidae" genus="Orthrias" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="angorae">
<emphasis id="B952D718257A0C65FA34F8D4EF9B7A31" italics="true" pageId="17" pageNumber="468">O. angorae</emphasis>
</taxonomicName>
, 
<quantity id="4CDEA6EF257A0C65FEB7F8B8EE0A7A31" box="[258,357,1864,1890]" metricMagnitude="0" metricUnit="m" metricValue="2.2098" metricValueMax="2.3114" metricValueMin="2.1082" pageId="17" pageNumber="468" unit="in" value="87.0" valueMax="91.0" valueMin="83.0">83–91 in</quantity>
<taxonomicName id="4C267089257A0C65FEDEF8B8ED6A7A31" box="[363,517,1864,1890]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="eregliensis">
<emphasis id="B952D718257A0C65FEDEF8B8ED6A7A31" box="[363,517,1864,1890]" italics="true" pageId="17" pageNumber="468">O. eregliensis</emphasis>
</taxonomicName>
; 
<quantity id="4CDEA6EF257A0C65FDA1F8B8ED187A31" box="[532,631,1864,1890]" metricMagnitude="0" metricUnit="m" metricValue="1.9558" metricValueMax="2.0827999999999998" metricValueMin="1.8288" pageId="17" pageNumber="468" unit="in" value="77.0" valueMax="82.0" valueMin="72.0">72–82 in</quantity>
<taxonomicName id="4C267089257A0C65FDC8F8B8EC427A31" baseAuthorityName="FSJF" baseAuthorityYear="2323" box="[637,813,1864,1890]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="germencicus">
<emphasis id="B952D718257A0C65FDC8F8B8EC427A31" box="[637,813,1864,1890]" italics="true" pageId="17" pageNumber="468">O. germencicus</emphasis>
</taxonomicName>
, and 
<quantity id="4CDEA6EF257A0C65FCDCF8B8ECA37A31" box="[873,972,1864,1891]" metricMagnitude="0" metricUnit="m" metricValue="1.9812" metricValueMax="2.159" metricValueMin="1.8034" pageId="17" pageNumber="468" unit="in" value="78.0" valueMax="85.0" valueMin="71.0">71–85 in</quantity>
<taxonomicName id="4C267089257A0C65FC66F8B8EB347A31" authorityName="Yogurtcuoglu, Kaya, Ozulug &amp; Freyhof" authorityYear="2021" box="[979,1115,1864,1890]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="isauricus">
<emphasis id="B952D718257A0C65FC66F8B8EB347A31" box="[979,1115,1864,1890]" italics="true" pageId="17" pageNumber="468">O. isauricus</emphasis>
</taxonomicName>
; see details for other species below). It is further distinguished by a combination of characters not unique to the species: body depth slightly decreasing or almost uniform between the dorsal- and caudal-fin base (depth of caudal peduncle 85–92% of body depth at anterior-most dorsal fin base vs. 
<quantity id="4CDEA6EF257A0C65FDD0F844EDA77A9D" box="[613,712,1972,1998]" metricMagnitude="0" metricUnit="m" metricValue="1.8669" metricValueMax="2.0065999999999997" metricValueMin="1.7271999999999998" pageId="17" pageNumber="468" unit="in" value="73.5" valueMax="79.0" valueMin="68.0">68–79 in</quantity>
<taxonomicName id="4C267089257A0C65FD7BF844EC0A7A9D" box="[718,869,1972,1998]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="anatolicus">
<emphasis id="B952D718257A0C65FD7BF844EC0A7A9D" box="[718,869,1972,1998]" italics="true" pageId="17" pageNumber="468">O. anatolicus</emphasis>
</taxonomicName>
, 
<quantity id="4CDEA6EF257A0C65FCC6F844ECBA7A9D" box="[883,981,1972,1998]" metricMagnitude="0" metricUnit="m" metricValue="1.9431" metricValueMax="2.1082" metricValueMin="1.778" pageId="17" pageNumber="468" unit="in" value="76.5" valueMax="83.0" valueMin="70.0">70–83 in</quantity>
<taxonomicName id="4C267089257A0C65FC69F844EB347A9D" baseAuthorityName="Steindachner" baseAuthorityYear="1897" box="[988,1115,1972,1998]" class="Actinopterygii" family="Nemacheilidae" genus="Orthrias" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="angorae">
<emphasis id="B952D718257A0C65FC69F844EB347A9D" box="[988,1115,1972,1998]" italics="true" pageId="17" pageNumber="468">O. angorae</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C267089257A0C65FB27F844EA437A9D" box="[1170,1324,1972,1998]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="eregliensis">
<emphasis id="B952D718257A0C65FB27F844EA437A9D" box="[1170,1324,1972,1998]" italics="true" pageId="17" pageNumber="468">O. eregliensis</emphasis>
</taxonomicName>
, 
<quantity id="4CDEA6EF257A0C65FA8FF844EAF37A9D" box="[1338,1436,1972,1998]" metricMagnitude="0" metricUnit="m" metricValue="1.9558" metricValueMax="2.0827999999999998" metricValueMin="1.8288" pageId="17" pageNumber="468" unit="in" value="77.0" valueMax="82.0" valueMin="72.0">72–82 in</quantity>
<taxonomicName id="4C267089257A0C65FF22F828EE287AA1" baseAuthorityName="FSJF" baseAuthorityYear="2323" box="[151,327,2008,2034]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="germencicus">
<emphasis id="B952D718257A0C65FF22F828EE287AA1" box="[151,327,2008,2034]" italics="true" pageId="17" pageNumber="468">O. germencicus</emphasis>
</taxonomicName>
, 
<quantity id="4CDEA6EF257A0C65FEE3F828EED67AA1" box="[342,441,2008,2034]" metricMagnitude="0" metricUnit="m" metricValue="1.7399" metricValueMax="1.9558" metricValueMin="1.524" pageId="17" pageNumber="468" unit="in" value="68.5" valueMax="77.0" valueMin="60.0">60–77 in</quantity>
<taxonomicName id="4C267089257A0C65FE75F828ED257AA1" authorityName="Yogurtcuoglu, Kaya, Ozulug &amp; Freyhof" authorityYear="2021" box="[448,586,2008,2034]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="isauricus">
<emphasis id="B952D718257A0C65FE75F828ED257AA1" box="[448,586,2008,2034]" italics="true" pageId="17" pageNumber="468">O. isauricus</emphasis>
</taxonomicName>
), elongated blotches on flank being usually connected to the saddles on the back, meeting contralateral on flank (vs. usually disconnected), caudal peduncle depth 1.2–1.5 times in its length (vs. 
<quantity id="4CDEA6EF25790C66FF7FFF4AEE517D86" box="[202,318,186,213]" metricMagnitude="-2" metricUnit="m" metricValue="4.191" metricValueMax="4.572" metricValueMin="3.81" pageId="18" pageNumber="469" unit="in" value="1.65" valueMax="1.8" valueMin="1.5">1.5–1.8 in</quantity>
<taxonomicName id="4C26708925790C66FEFDFF4BEEA57D87" baseAuthorityName="Steindachner" baseAuthorityYear="1897" box="[328,458,187,213]" class="Actinopterygii" family="Nemacheilidae" genus="Orthrias" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="angorae">
<emphasis id="B952D71825790C66FEFDFF4BEEA57D87" box="[328,458,187,213]" italics="true" pageId="18" pageNumber="469">O. angorae</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C26708925790C66FDB3FF4BEDD77D87" baseAuthorityName="FSJF" baseAuthorityYear="2323" box="[518,696,187,213]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="germencicus">
<emphasis id="B952D71825790C66FDB3FF4BEDD77D87" box="[518,696,187,213]" italics="true" pageId="18" pageNumber="469">O. germencicus</emphasis>
</taxonomicName>
, 
<quantity id="4CDEA6EF25790C66FD7FFF4AEC527D86" box="[714,829,186,213]" metricMagnitude="-2" metricUnit="m" metricValue="4.318" metricValueMax="4.826" metricValueMin="3.81" pageId="18" pageNumber="469" unit="in" value="1.7" valueMax="1.9" valueMin="1.5">1.5–1.9 in</quantity>
<taxonomicName id="4C26708925790C66FCF2FF4BEC8B7D86" box="[839,996,187,213]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="eregliensis">
<emphasis id="B952D71825790C66FCF2FF4BEC8B7D86" box="[839,996,187,213]" italics="true" pageId="18" pageNumber="469">O. eregliensis</emphasis>
</taxonomicName>
, 
<quantity id="4CDEA6EF25790C66FC40FF4BEB067D86" box="[1013,1129,187,213]" metricMagnitude="-2" metricUnit="m" metricValue="6.096" metricValueMax="6.604" metricValueMin="5.588" pageId="18" pageNumber="469" unit="in" value="2.4" valueMax="2.6" valueMin="2.2">2.2–2.6 in</quantity>
<taxonomicName id="4C26708925790C66FBC6FF4BEB907D87" authorityName="Yogurtcuoglu, Kaya, Ozulug &amp; Freyhof" authorityYear="2021" box="[1139,1279,187,213]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="isauricus">
<emphasis id="B952D71825790C66FBC6FF4BEB907D87" box="[1139,1279,187,213]" italics="true" pageId="18" pageNumber="469">O. isauricus</emphasis>
</taxonomicName>
). It is further distinguished from 
<taxonomicName id="4C26708925790C66FEC4FF2FED667DAA" box="[369,521,223,249]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="anatolicus">
<emphasis id="B952D71825790C66FEC4FF2FED667DAA" box="[369,521,223,249]" italics="true" pageId="18" pageNumber="469">O. anatolicus</emphasis>
</taxonomicName>
by a narrower interorbital distance (26–35% HL vs. 33–40) and from 
<taxonomicName id="4C26708925790C66FAA8FF2FEAF37DAB" baseAuthorityName="Steindachner" baseAuthorityYear="1897" box="[1309,1436,223,249]" class="Actinopterygii" family="Nemacheilidae" genus="Orthrias" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="angorae">
<emphasis id="B952D71825790C66FAA8FF2FEAF37DAB" box="[1309,1436,223,249]" italics="true" pageId="18" pageNumber="469">O. angorae</emphasis>
</taxonomicName>
by lacking a depigmented stripe along the anterior part of the lateral line (vs. usually present).
</paragraph>
</subSubSection>
<caption id="DF595B8225790C66FF22F9F1ED077B6E" ID-DOI="http://doi.org/10.5281/zenodo.6530921" ID-Zenodo-Dep="6530921" httpUri="https://zenodo.org/record/6530921/files/figure.png" pageId="18" pageNumber="469" startId="18.[151,250,1537,1561]" targetBox="[151,1436,309,1514]" targetPageId="18">
<paragraph id="8B990B0A25790C66FF22F9F1ED077B6E" blockId="18.[151,1437,1537,1597]" pageId="18" pageNumber="469">
<emphasis id="B952D71825790C66FF22F9F1EE4F7B4A" bold="true" box="[151,288,1537,1561]" pageId="18" pageNumber="469">FIGURE 11.</emphasis>
<taxonomicName id="4C26708925790C66FE9CF9F1ED187B4A" box="[297,631,1537,1561]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="mediterraneus">
<emphasis id="B952D71825790C66FE9CF9F1ED187B4A" box="[297,631,1537,1561]" italics="true" pageId="18" pageNumber="469">Oxynoemacheilus mediterraneus</emphasis>
</taxonomicName>
, from top: FSJF 3111, 48 mm SL; Köprüçay; FSJF 3029, 45 mm SL; stream Çığırgan; FSJF 2314, 61 mm SL; Aksu River.
</paragraph>
</caption>
<subSubSection id="C33C588125790C66FF72F99BED7C7BF9" pageId="18" pageNumber="469" type="distribution">
<paragraph id="8B990B0A25790C66FF72F99BED7C7BF9" blockId="18.[151,1437,1643,1922]" pageId="18" pageNumber="469">
<emphasis id="B952D71825790C66FF72F99BEE0E7BD6" bold="true" box="[199,353,1643,1669]" pageId="18" pageNumber="469">Distribution.</emphasis>
<taxonomicName id="4C26708925790C66FEDDF99BEDB67BD6" box="[360,729,1643,1669]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="mediterraneus">
<emphasis id="B952D71825790C66FEDDF99BEDB67BD6" box="[360,729,1643,1669]" italics="true" pageId="18" pageNumber="469">Oxynoemacheilus mediterraneus</emphasis>
</taxonomicName>
is widespread in the Aksu and Köprüçay drainages in the Gulf of 
<collectingRegion id="49E2C5E825790C66FF01F97FEE627BFA" box="[180,269,1679,1705]" country="Turkey" name="Antalya" pageId="18" pageNumber="469">Antalya</collectingRegion>
(Mediterranean basin).
</paragraph>
</subSubSection>
<subSubSection id="C33C588125790C66FF72F944EB407AD2" pageId="18" pageNumber="469" type="discussion">
<paragraph id="8B990B0A25790C66FF72F944EB407AD2" blockId="18.[151,1437,1643,1922]" pageId="18" pageNumber="469">
<emphasis id="B952D71825790C66FF72F944EE547B9D" bold="true" box="[199,315,1716,1742]" pageId="18" pageNumber="469">Remarks.</emphasis>
Our molecular data suggested that 
<taxonomicName id="4C26708925790C66FD73F943EB597B9E" box="[710,1078,1715,1741]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="mediterraneus">
<emphasis id="B952D71825790C66FD73F943EB597B9E" box="[710,1078,1715,1741]" italics="true" pageId="18" pageNumber="469">Oxynoemacheilus mediterraneus</emphasis>
</taxonomicName>
is separated from 
<taxonomicName id="4C26708925790C66FAB1F944EAF37B9E" box="[1284,1436,1715,1742]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="nasreddini">
<emphasis id="B952D71825790C66FAB1F944EAF37B9E" box="[1284,1436,1715,1742]" italics="true" pageId="18" pageNumber="469">O. nasreddini</emphasis>
</taxonomicName>
by a minimum K2P distance of only 1.2% in the mtDNA COI barcode region. The two taxa are, however, well distinguished morphologically (
<bibRefCitation id="EFB776FB25790C66FDB3F90BEC2E7A45" author="Yogurtcuoglu, B. &amp; Kaya, C. &amp; Freyhof, J." box="[518,833,1787,1814]" pageId="18" pageNumber="469" pagination="135 - 150" refId="ref23389" refString="Yogurtcuoglu, B., Kaya, C. &amp; Freyhof, J. (2021 a) Oxynoemacheilus nasreddini, a new nemacheilid loach from the Central Anatolia (Teleostei: Nemacheilidae). Zootaxa, 4974 (1), 135 - 150. https: // doi. org / 10.11646 / zootaxa. 4974.1.5" type="journal article" year="2021">
Yoğurtçuoğlu 
<emphasis id="B952D71825790C66FD1BF90CED837A46" box="[686,748,1787,1813]" italics="true" pageId="18" pageNumber="469">et al.</emphasis>
2021a
</bibRefCitation>
). In addition, loaches from Lake Eğirdir basin are identified as 
<taxonomicName id="4C26708925790C66FE9DF8D0EEAE7A6A" box="[296,449,1823,1850]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="nasreddini">
<emphasis id="B952D71825790C66FE9DF8D0EEAE7A6A" box="[296,449,1823,1850]" italics="true" pageId="18" pageNumber="469">O. nasreddini</emphasis>
</taxonomicName>
, despite the analysis of their mtDNA COI, which placed them within 
<emphasis id="B952D71825790C66FB64F8D0EAF27A6A" box="[1233,1437,1823,1850]" italics="true" pageId="18" pageNumber="469">
<taxonomicName id="4C26708925790C66FB64F8D0EAF77A6A" box="[1233,1432,1823,1850]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="mediterraneus">O. mediterraneus</taxonomicName>
.
</emphasis>
<bibRefCitation id="EFB776FB25790C66FF22F8B3EEA07A0D" author="Yogurtcuoglu, B. &amp; Kaya, C. &amp; Freyhof, J." box="[151,463,1859,1886]" pageId="18" pageNumber="469" pagination="135 - 150" refId="ref23389" refString="Yogurtcuoglu, B., Kaya, C. &amp; Freyhof, J. (2021 a) Oxynoemacheilus nasreddini, a new nemacheilid loach from the Central Anatolia (Teleostei: Nemacheilidae). Zootaxa, 4974 (1), 135 - 150. https: // doi. org / 10.11646 / zootaxa. 4974.1.5" type="journal article" year="2021">
Yoğurtçuoğlu 
<emphasis id="B952D71825790C66FE8DF8B4EE057A0E" box="[312,362,1859,1885]" italics="true" pageId="18" pageNumber="469">et al</emphasis>
. (2021a)
</bibRefCitation>
suspect that this disagreement between morphological and mtDNA data might be due to a past introgressive hybridization between 
<taxonomicName id="4C26708925790C66FD21F898EC377AD2" box="[660,856,1895,1922]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="mediterraneus">
<emphasis id="B952D71825790C66FD21F898EC377AD2" box="[660,856,1895,1922]" italics="true" pageId="18" pageNumber="469">O. mediterraneus</emphasis>
</taxonomicName>
and 
<emphasis id="B952D71825790C66FC3BF898EB407AD2" box="[910,1071,1895,1922]" italics="true" pageId="18" pageNumber="469">
<taxonomicName id="4C26708925790C66FC3BF898EB457AD2" box="[910,1066,1895,1922]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="nasreddini">O. nasreddini</taxonomicName>
.
</emphasis>
</paragraph>
</subSubSection>
</treatment>
