<taxonomicName id="4C7D4D1A330EFFCCFCEAF8D022AEF89D" box="[865,1020,1850,1876]" class="Magnoliopsida" family="Juglandaceae" kingdom="Plantae" order="Fagales" pageId="9" pageNumber="46" phylum="Tracheophyta" rank="family">
