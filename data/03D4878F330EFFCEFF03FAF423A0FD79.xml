<taxonomicName id="4C7D4D1A330EFFCCFD51F8B52210F8B1" box="[730,834,1887,1912]" class="Magnoliopsida" family="Rutaceae" kingdom="Plantae" order="Sapindales" pageId="9" pageNumber="46" phylum="Tracheophyta" rank="family">
