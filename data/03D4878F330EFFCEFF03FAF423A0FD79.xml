</bibRefCitation>
, 
<bibRefCitation id="EFEC4B68330EFFCCFB6FF8B524F5F8B1" author="Wang, X. &amp; Guo, Y. &amp; Du, Y. &amp; Yang, Z. &amp; Huang, X. &amp; Hong, N. &amp; Xu, W. &amp; Wang, G." box="[1252,1447,1886,1913]" pageId="9" pageNumber="46" pagination="77 - 90" refId="ref9902" refString="Wang, X., Guo, Y., Du, Y., Yang, Z., Huang, X., Hong, N., Xu, W. &amp; Wang, G. (2021) Characterization of Diaporthe species associated with peach constriction canker, with two novel species from China. MycoKeys 80: 77 - 90. https: // doi. org / 10.3897 / mycokeys. 80.63816" type="journal article" year="2021">
