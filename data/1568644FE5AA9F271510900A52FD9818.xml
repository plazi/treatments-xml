<subSubSection id="C68C1E6290E3B3C64DF9CBE85B237667" pageId="null" pageNumber="216" type="description">
<paragraph id="FBDFB689163890D8133AB597F2E48AB3" pageId="null" pageNumber="216">
1-2 
<normalizedToken id="44E0170844CBCB112395C85BBFDE2071" originalValue="jährig" pageId="null" pageNumber="216">jaehrig</normalizedToken>
. 
<emphasis id="74484F7D3561AA4D769C2561822DE185" italics="true" pageId="null" pageNumber="216">
Alle 
<normalizedToken id="6CE40D6471DF79A99CE6FC1F8E954CB8" originalValue="Blätter" pageId="null" pageNumber="216">Blaetter</normalizedToken>
<normalizedToken id="B6F67FACB85618F476C94175131B35D4" originalValue="grundständig" pageId="null" pageNumber="216">grundstaendig</normalizedToken>
</emphasis>
, die ersten 
<normalizedToken id="8BC0A81F5437756B7CDE3DA1C0BF9BBD" originalValue="bandförmig" pageId="null" pageNumber="216">bandfoermig</normalizedToken>
, bis 25 cm lang und 0,5 cm breit, schlaff. 
<normalizedToken id="9A3BD433A3BE6131E1C962C095BD1115" originalValue="Sommerblätter" pageId="null" pageNumber="216">Sommerblaetter</normalizedToken>
lang (bis 30 cm) gestielt; 
<emphasis id="7B0DC92064BAFD3C7C1F93EF9D5F344B" italics="true" pageId="null" pageNumber="216">Spreite oval</emphasis>
, 3-10 cm lang, 1-3 cm breit, am Grunde abgerundet oder 
<normalizedToken id="A5390976D13CEDA1B66B433D7B58BC14" originalValue="herzförmig" pageId="null" pageNumber="216">herzfoermig</normalizedToken>
, mit stumpfer Spitze, schwimmend (bei Landformen aufrecht). 
<normalizedToken id="B82E7C7169DDDC72BA9892FD82116DAC" originalValue="Blütenstand" pageId="null" pageNumber="216">Bluetenstand</normalizedToken>
aus dem Wasser ragend, aus 1-7 
<normalizedToken id="1B15A9D5889B63A7AD5DF531E482EA6D" originalValue="Blütenquirlen" pageId="null" pageNumber="216">Bluetenquirlen</normalizedToken>
. 
<emphasis id="449FAF0D7C7E52BB15569A154D6DA294" italics="true" pageId="null" pageNumber="216">
Innere 
<normalizedToken id="799E0CCDFB8E68F578F95D09C711633B" originalValue="Perigonblätter" pageId="null" pageNumber="216">Perigonblaetter</normalizedToken>
doppelt so lang wie die 
<normalizedToken id="74336E8C2DC7098DD58DC56367BEE5E0" originalValue="äußern" pageId="null" pageNumber="216">aeussern</normalizedToken>
, oval, 
<normalizedToken id="306597747106231DD0C71EDBA8D58012" originalValue="weiß" pageId="null" pageNumber="216">weiss</normalizedToken>
mit gelbem Grund.
</emphasis>
<normalizedToken id="0E4EB2B73B3280156DCEA3ABA70F9208" originalValue="Früchtchen" pageId="null" pageNumber="216">Fruechtchen</normalizedToken>
6, 2samig, 
<normalizedToken id="95535F602D15FA209DAC308CCC339B3E" originalValue="kegelförmig" pageId="null" pageNumber="216">kegelfoermig</normalizedToken>
, bis 8 mm lang, vom Grunde an 
<normalizedToken id="6709F2027D9896AD3A7C01238B84EC65" originalValue="verschmälert" pageId="null" pageNumber="216">verschmaelert</normalizedToken>
, spitz. - 
<normalizedToken id="5BA990F3626E670DDBD9819AEB8BC63F" originalValue="Blüte" pageId="null" pageNumber="216">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="555301E4005522DA7A66586A9114552F" pageId="null" pageNumber="216">
<emphasis id="12733A05BA73D7970762698DE0776194" italics="true" pageId="null" pageNumber="216">Zytologische Angaben</emphasis>
. Keine Untersuchungen.
</paragraph>
<paragraph id="2B0104146D85B4C1F4A6BAAE938ABD45" pageId="null" pageNumber="216">
<emphasis id="6F7C59F440DAEFB52890CE04D3D76EBA" italics="true" pageId="null" pageNumber="216">Standort.</emphasis>
Kollin. In 
<normalizedToken id="13D461B33C52F73100A33FEB81E45AB7" originalValue="Gräben" pageId="null" pageNumber="216">Graeben</normalizedToken>
und Teichen auf schlammigem Grund; kalkmeidend.
</paragraph>
<paragraph id="6BA6581EBFE3B24AD4E8316FD3BCB584" pageId="null" pageNumber="216">
<emphasis id="8072154B4E525323E5575056DDFFD516" italics="true" pageId="null" pageNumber="216">Verbreitung. Mediterrane Pflanze:</emphasis>
Frankreich, England, ganzes Mediterrangebiet, 
<normalizedToken id="75C141B3DA2659C4B9DE1B67EC1E15A2" originalValue="ostwärts" pageId="null" pageNumber="216">ostwaerts</normalizedToken>
bis 
<normalizedToken id="8253C4C1E901BFC7C4BB57E9C59B6285" originalValue="Südrußland" pageId="null" pageNumber="216">Suedrussland</normalizedToken>
und Iran. - Im Gebiet im 
<normalizedToken id="40D16FFA6EEFE9D386478BAE1F679D7B" originalValue="Dép" pageId="null" pageNumber="216">Dep</normalizedToken>
. Ain, 
<normalizedToken id="3DA16C1F3848E8108871B51381B28E90" originalValue="Dép" pageId="null" pageNumber="216">Dep</normalizedToken>
. Jura; wenige Fundorte.
</paragraph>
</subSubSection>
