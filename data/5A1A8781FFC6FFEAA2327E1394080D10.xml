ENOPLOTEUTHOIDEA 
<bibRefCitation id="B6224B66FFC6FFEAA5DA7E13951E0F13" author="Pfeffer G" box="[1235,1406,1353,1378]" pageId="15" pageNumber="1227" pagination="147 - 198" refId="ref16323" refString="Pfeffer G. 1900. Synopsis der oegopsiden Cephalopoden. Mitteilungen aus dem Naturhistorischen Museum Hamburg 17: 147 - 198." type="journal article" year="1900">PFEFFER, 1900</bibRefCitation>
