<quantity id="2E379B383F67FFF0FE36FA1FFDC3FA55" box="[471,547,1433,1460]" metricMagnitude="-2" metricUnit="m" metricValue="3.5" pageId="82" pageNumber="83" unit="cm" value="3.5">3.5 cm</quantity>
