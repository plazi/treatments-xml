<taxonomicName id="CCF14D5DF72B2326F727F88E4257B2A4" authority="Miranda, Casali, Perini, Machado &amp; Santos" authorityName="Miranda, Casali, Perini, Machado &amp; Santos" authorityYear="2017" box="[2183,2368,1919,1948]" class="Mammalia" family="Cyclopedidae" genus="Cyclopes" kingdom="Animalia" order="Pilosa" pageId="2" pageNumber="101" phylum="Chordata" rank="species" species="rufus">Cyclopes rufus</taxonomicName>
