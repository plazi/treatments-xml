<taxonomicName id="4C724D26935A8E07F0A3FA9FFBCFFAED" authority="Dejean, 1831" authorityName="Dejean" authorityYear="1831" box="[670,1054,1292,1318]" class="Insecta" family="Carabidae" genus="Ditomus" kingdom="Animalia" order="Coleoptera" pageId="3" pageNumber="487" phylum="Arthropoda" rank="species" species="tomentosus">
<emphasis id="B906EAB7935A8E07F0A3FA9FFC53FAED" box="[670,898,1293,1318]" italics="true" pageId="3" pageNumber="487">Ditomus tomentosus</emphasis>
