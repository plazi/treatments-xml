<collectingCountry id="F3657635935A8E07F6D2FB7AFA93FAC9" box="[1263,1346,1256,1282]" name="Morocco" pageId="3" pageNumber="487">Tanger</collectingCountry>
”, “Goudot”, “ex-Museo Chaudoir” and “ 
<typeStatus id="54C98807935A8E07F030FA9EFDA9FAED" box="[525,632,1292,1318]" pageId="3" pageNumber="487">Holotype</typeStatus>
