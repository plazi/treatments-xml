<taxonomicName id="12830D89FF82FFF5FCF3F22BF6D7F9BC" authority="O. Pickard-Cambridge, 1898" authorityName="O. Pickard-Cambridge" authorityYear="1898" box="[810,1260,1594,1618]" class="Arachnida" family="Corinnidae" genus="Mazax" kingdom="Animalia" order="Araneae" pageId="2" pageNumber="581" phylum="Arthropoda" rank="species" species="spinosa">
