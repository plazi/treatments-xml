</emphasis>
<taxonomicName id="12830D89FF82FFF5FEF5F22BF007F9BC" authority="Reiskind, 1969" authorityName="Reiskind" authorityYear="1969" box="[300,572,1594,1618]" class="Arachnida" family="Corinnidae" genus="Mazax" kingdom="Animalia" order="Araneae" pageId="2" pageNumber="581" phylum="Arthropoda" rank="species" species="pax">
<emphasis id="E7F7AA18FF82FFF5FEF5F22BF3A0F9BC" box="[300,411,1595,1618]" italics="true" pageId="2" pageNumber="581">Mazax pax</emphasis>
<bibRefCitation id="B1120BFBFF82FFF5FE78F22AF007F9BC" author="Reiskind, J." box="[417,572,1594,1618]" pageId="2" pageNumber="581" pagination="163 - 325" refId="ref7181" refString="Reiskind, J. (1969) The spider subfamily Castianeirinae of North and Central America (Araneae, Clubionidae). Bulletin of the Museum of Comparative Zoology, 138, 163 - 325." type="journal article" year="1969">Reiskind, 1969</bibRefCitation>
