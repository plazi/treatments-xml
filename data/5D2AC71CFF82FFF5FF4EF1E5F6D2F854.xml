<bibRefCitation id="B1120BFBFF82FFF5FC3FF22AF6D7F9BC" author="Pickard-Cambridge, O." box="[998,1260,1594,1618]" pageId="2" pageNumber="581" pagination="233 - 288" refId="ref7155" refString="Pickard-Cambridge, O. (1898) Arachnida. Araneida. In: Biologia Centrali-Americana, London, Zoology, 1, 233 - 288." type="journal article" year="1898">Pickard-Cambridge, 1898</bibRefCitation>
</taxonomicName>
