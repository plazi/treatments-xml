<subSubSection id="03FE47439088611428854C9F2B1E776E" pageId="null" pageNumber="266" type="description">
<paragraph id="F761B047444052CD3349635E1FE932BE" pageId="null" pageNumber="266">
Ausdauernd oder 1 
<normalizedToken id="727A78914C8D185AC560FA9E42336EF4" originalValue="jährig" pageId="null" pageNumber="266">jaehrig</normalizedToken>
. 
<normalizedToken id="DD065D97348A4A0C5E94DB10B354952C" originalValue="Blütenstand" pageId="null" pageNumber="266">Bluetenstand</normalizedToken>
eine weit ausladende oder eng zusammengezogene Rispe. 
<normalizedToken id="9409EFAA442A99E6B04510A6EE60AE5D" originalValue="Ährchen" pageId="null" pageNumber="266">Aehrchen</normalizedToken>
1 
<normalizedToken id="2068C44B0AED17CA16222EC96FFC984B" originalValue="blütig" pageId="null" pageNumber="266">bluetig</normalizedToken>
. 
<normalizedToken id="78B2207AF7386A9F9491E88C309BC920" originalValue="Hüllspelzen" pageId="null" pageNumber="266">Huellspelzen</normalizedToken>
2, beide gleich lang, die 
<normalizedToken id="3EF2EAA6EE4D7BE1325BE4A7EAD84446" originalValue="übrigen" pageId="null" pageNumber="266">uebrigen</normalizedToken>
Spelzen 
<normalizedToken id="5EBE46199E138F5AEA582B4000B66351" originalValue="einschließend" pageId="null" pageNumber="266">einschliessend</normalizedToken>
, 
<normalizedToken id="0AE8D3FE6F3784E2813289AD93E3DE0D" originalValue="häutig" pageId="null" pageNumber="266">haeutig</normalizedToken>
, 3nervig, 
<emphasis id="DD7E386E934D0E6E427ACECE0E600CFE" italics="true" pageId="null" pageNumber="266">mit stumpfer Spitze.</emphasis>
Deck- und Vorspelze wenig 
<normalizedToken id="C8042C20A7FFF8CC07AED0B0EA20B9EF" originalValue="kürzer" pageId="null" pageNumber="266">kuerzer</normalizedToken>
als die 
<normalizedToken id="950B159FCD7341CEF2E0C277FF76F250" originalValue="Hüllspelzen" pageId="null" pageNumber="266">Huellspelzen</normalizedToken>
, 
<emphasis id="F797DF23DB6E9AC8F6247FE603793787" italics="true" pageId="null" pageNumber="266">
beide nach der 
<normalizedToken id="87F8807995E722A597F519ED28A81977" originalValue="Blüte" pageId="null" pageNumber="266">Bluete</normalizedToken>
hart werdend, 
<normalizedToken id="990B7E945F0796EB642B1E170572BFDE" originalValue="glänzend" pageId="null" pageNumber="266">glaenzend</normalizedToken>
, kahl
</emphasis>
, ohne besondere Merkmale.
</paragraph>
<paragraph id="83F674ADE9D0F77B204EC8BFFD78274D" pageId="null" pageNumber="266">
Die Gattung 
<taxonomicName id="E3E7950FDDE09CF3293C90726BA8DED9" class="Liliopsida" family="Poaceae" genus="Milium" kingdom="Plantae" order="Poales" pageId="null" pageNumber="266" phylum="Tracheophyta" rank="genus">Milium</taxonomicName>
<normalizedToken id="3E6AF1FA32170DD8578B3EDAB484E3CC" originalValue="umfaßt" pageId="null" pageNumber="266">umfasst</normalizedToken>
etwa 8 Arten, die in Eurasien und Nordamerika verbreitet sind.
</paragraph>
</subSubSection>
