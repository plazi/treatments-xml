</taxonomicName>
(originally in the genus 
<taxonomicName id="90E64D09BD6EFFFFF9BBF868EE53F82F" baseAuthorityName="Cockerell" baseAuthorityYear="1933" box="[404,519,1921,1947]" class="Insecta" family="Pamphiliidae" genus="Cephaleia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="1" pageNumber="174" phylum="Arthropoda" rank="genus">
