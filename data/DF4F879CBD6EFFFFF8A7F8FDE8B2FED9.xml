<taxonomicName id="90E64D09BD6EFFFFF96AF8B4EF5EF8C3" authority="(Cockerell, 1933)" authorityName="Oligocene" baseAuthorityName="Cockerell" baseAuthorityYear="1933" box="[325,778,1885,1911]" class="Insecta" family="Pamphiliidae" genus="Tapholyda" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="1" pageNumber="174" phylum="Arthropoda" rank="species" species="caplani">
<emphasis id="6592EA98BD6EFFFFF96AF8B4EE76F8C3" box="[325,546,1885,1911]" italics="true" pageId="1" pageNumber="174">Tapholyda caplani</emphasis>
(
<bibRefCitation id="33774B7BBD6EFFFFFA11F8B4EF55F8C3" author="Cockerell, T. D. A." box="[574,769,1885,1911]" pageId="1" pageNumber="174" pagination="186 - 187" refId="ref4521" refString="Cockerell, T. D. A. (1933) A fossil sawfly from the Miocene shales near Creede (Colorado). Bulletin of the Brooklyn Entomological Society, 28, 186 - 187." type="journal article" year="1933">Cockerell, 1933</bibRefCitation>
