<subSubSection id="CC9A3BDC7D69E228F3BDA32C48A6FFFB" pageId="null" pageNumber="539" type="vernacular_names">
<paragraph id="E13E705A759E520EDACE7CA1B66096B7" pageId="null" pageNumber="539">Alpen-Berufkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="BD2BAAEA025B60E9F7324E11F060A7BF" pageId="null" pageNumber="539" type="description">
<paragraph id="D3168DC0EEA658AAFCCF189F37DAEE18" pageId="null" pageNumber="539">
2-30 cm hoch. 
<emphasis id="385344019C0DD06B1BBB4302FD76C8DE" italics="true" pageId="null" pageNumber="539">Stengel 1</emphasis>
- 
<emphasis id="CC418C84381CE128100965F5228C8846" italics="true" pageId="null" pageNumber="539">
5-, selten bis 10 
<normalizedToken id="15C60B0A5144D85BA4EB26DF407203E5" originalValue="köpfig" pageId="null" pageNumber="539">koepfig</normalizedToken>
</emphasis>
, meist 
<normalizedToken id="B943830BCCA9A55B0A48940554DD545B" originalValue="grün" pageId="null" pageNumber="539">gruen</normalizedToken>
. 
<emphasis id="8CB3218633952ABB72FEDBB33BBDFA9E" italics="true" pageId="null" pageNumber="539">
<normalizedToken id="9AD5855EAC84D115315E2633502CF791" originalValue="Grundständige" pageId="null" pageNumber="539">Grundstaendige</normalizedToken>
<normalizedToken id="D995C844B90834F6EEB8D085674656A7" originalValue="Blätter" pageId="null" pageNumber="539">Blaetter</normalizedToken>
lanzettlich
</emphasis>
(an beiden Enden 
<normalizedToken id="F3136435FEFB8DDCA9EF4423190776A4" originalValue="allmählich" pageId="null" pageNumber="539">allmaehlich</normalizedToken>
<normalizedToken id="43FC73FCF8C37876E0702E4EF486EBDA" originalValue="verschmälert" pageId="null" pageNumber="539">verschmaelert</normalizedToken>
), 
<emphasis id="1D1C775D658E229EA404E7A9CE2F2F6C" italics="true" pageId="null" pageNumber="539">
beiderseits behaart. 
<normalizedToken id="694D75C0B7D773BA6758731CCFCC6F66" originalValue="Hüllblätter" pageId="null" pageNumber="539">Huellblaetter</normalizedToken>
meist im untersten Drittel am breitesten und 
<normalizedToken id="143214868D9FB073FA3D9954537BBBC5" originalValue="allmählich" pageId="null" pageNumber="539">allmaehlich</normalizedToken>
zugespitzt, mit wenigen langen Haaren
</emphasis>
(nicht 
<normalizedToken id="F16FF866731544FB85E94C4ADBEC7CB9" originalValue="weißwollig" pageId="null" pageNumber="539">weisswollig</normalizedToken>
), 
<emphasis id="6F3A9377CDB4D55558C7ACA3AD8496B8" italics="true" pageId="null" pageNumber="539">
meist 
<normalizedToken id="127753C5D2FC6F46F899C0E9A534E12F" originalValue="grün" pageId="null" pageNumber="539">gruen</normalizedToken>
.
</emphasis>
<normalizedToken id="95C7009CDB53BDEA41002CD7EB2D9CE7" originalValue="Zungenförmige" pageId="null" pageNumber="539">Zungenfoermige</normalizedToken>
<normalizedToken id="883AF6DD36BD6B244BB0FD4608BD6777" originalValue="Blüten" pageId="null" pageNumber="539">Blueten</normalizedToken>
rosa oder purpurrot (selten 
<normalizedToken id="7383DF08E66A6F477ECFEB71B9F9C13D" originalValue="weiß" pageId="null" pageNumber="539">weiss</normalizedToken>
); 
<emphasis id="E4DF69E24350EBC6656050998D0C9BD0" italics="true" pageId="null" pageNumber="539">
zwischen 
<normalizedToken id="2F1C9AC9A75151BEE4AE614D023A8EE2" originalValue="Röhren-" pageId="null" pageNumber="539">Roehren-</normalizedToken>
und 
<normalizedToken id="5F5F292CA39D01AFF90A2DD1690B41F8" originalValue="Zungenblüten" pageId="null" pageNumber="539">Zungenblueten</normalizedToken>
</emphasis>
♀ 
<emphasis id="A9A08CB22C5B45AE636C536728115176" italics="true" pageId="null" pageNumber="539">
<normalizedToken id="84FB5A0A66BB83E898B54089765375EA" originalValue="Blüten" pageId="null" pageNumber="539">Blueten</normalizedToken>
mit 
<normalizedToken id="CB49B0777402CB52D2A46C3DCE43FC8B" originalValue="verkümmerter" pageId="null" pageNumber="539">verkuemmerter</normalizedToken>
, 
<normalizedToken id="72A39A78A93F68B659C3E7238BCBB05B" originalValue="fadenförmiger" pageId="null" pageNumber="539">fadenfoermiger</normalizedToken>
, aufrechter Krone
</emphasis>
(
<emphasis id="E2C16E3D209F06A1FEE03ADF37E12B66" italics="true" pageId="null" pageNumber="539">
<normalizedToken id="7B556CBB76A7F6D041CCA301FD9A27FE" originalValue="Fadenblüten" pageId="null" pageNumber="539">Fadenblueten</normalizedToken>
</emphasis>
). - 
<normalizedToken id="9BDB1886D2BDA820D2794895A5C6D205" originalValue="Blüte" pageId="null" pageNumber="539">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="6071FFDF0FCFF820F0B94FE73F70488B" originalValue="früher" pageId="null" pageNumber="539">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="52BEFF7FF6FA03CAAE27363B4CE77867" pageId="null" pageNumber="539">
<emphasis id="80F7561B038257043D0D337EE61C3887" italics="true" pageId="null" pageNumber="539">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="C8823AB61480DEEC4644122DC2781918" italics="true" pageId="null" pageNumber="539">18:</emphasis>
Material aus 
<normalizedToken id="A4CA0A1AC618CF12B76335FA8581A6D3" originalValue="Österreich" pageId="null" pageNumber="539">Oesterreich</normalizedToken>
(Mattick aus Tischler 1950), aus botanischen 
<normalizedToken id="7E478A35E912BE1499C457E9FAE6FC01" originalValue="Gärten" pageId="null" pageNumber="539">Gaerten</normalizedToken>
(Montgomery und Yang 1960), aus der Tatra (Skalinska et al. 1966); in Japan (Huziwara 1958a) wurde die gleiche Chromosomenzahl 
<normalizedToken id="48D33420B5319A624A21D4EC27D45903" originalValue="gezählt" pageId="null" pageNumber="539">gezaehlt</normalizedToken>
, doch handelt es sich wahrscheinlich um eine abweichende Sippe.
</paragraph>
<paragraph id="3BB9F000DFA8BBF7D7E44A4738A1267E" pageId="null" pageNumber="539">
<emphasis id="912B3021B47A445F6A5FA12C5B35336D" italics="true" pageId="null" pageNumber="539">Standort.</emphasis>
Subalpin und alpin, selten montan. Lockere, steinige, oft kalkarme 
<normalizedToken id="860DE2F0AEA932624988996187C039B6" originalValue="Böden" pageId="null" pageNumber="539">Boeden</normalizedToken>
. Weiden und Wiesen.
</paragraph>
<paragraph id="462D45ACD08E0B128EFD58EF129BB40C" pageId="null" pageNumber="539">
<emphasis id="0C6F3BFE2AADBE2E93508514A374D838" italics="true" pageId="null" pageNumber="539">Verbreitung. Mittel</emphasis>
- 
<emphasis id="817C72CA94E677FFE2F8EF02D7101917" italics="true" pageId="null" pageNumber="539">
und 
<normalizedToken id="4EE93EEB9ADB6739E55FED2C6250EBDA" originalValue="südeuropäische" pageId="null" pageNumber="539">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
Serrania de Cuenca, 
<normalizedToken id="F006DAB301E0197767E610210644AC68" originalValue="Pyrenäen" pageId="null" pageNumber="539">Pyrenaeen</normalizedToken>
, Auvergne, Jura, Alpen, Apennin, Karpaten, Gebirge der Balkanhalbinsel, Kaukasus. Verwandte Sippen in Zentralasien und Ostasien. - Im Gebiet: Alpen, verbreitet und ziemlich 
<normalizedToken id="04B45F4C1BDAF55EEDDB0033066964DF" originalValue="häufig" pageId="null" pageNumber="539">haeufig</normalizedToken>
; Jura (
<normalizedToken id="CDF3996E4FD9857DFDB3F77B1B76ECA1" originalValue="nordostwärts" pageId="null" pageNumber="539">nordostwaerts</normalizedToken>
bis 
<normalizedToken id="070AA2F9DE54BB79A31879E20E434B60" originalValue="Paßwang" pageId="null" pageNumber="539">Passwang</normalizedToken>
), ziemlich selten.
</paragraph>
</subSubSection>
