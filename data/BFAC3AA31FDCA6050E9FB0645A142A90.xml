<subSubSection id="A8F3DA4F730363EF875950699E6E8D3B" pageId="null" pageNumber="373" type="description">
<paragraph id="7BA81FDC1A10B5CDC3A04CD86AD17C05" pageId="null" pageNumber="373">
<emphasis id="9AC9912760B1CEDB4427C466E41ABDC5" italics="true" pageId="null" pageNumber="373">
1 
<normalizedToken id="43F5D169C0C9D1559DA463D4BA8A18D5" originalValue="jährig" pageId="null" pageNumber="373">jaehrig</normalizedToken>
</emphasis>
, 30-60 cm hoch, 
<normalizedToken id="1450AD869A045971814750A15C4B54E5" originalValue="gelbgrün" pageId="null" pageNumber="373">gelbgruen</normalizedToken>
. 
<normalizedToken id="18374286DC7BFC499AB7E4D6D3F42795" originalValue="Blätter" pageId="null" pageNumber="373">Blaetter</normalizedToken>
in der Knospenlage eingerollt, selten 
<normalizedToken id="F80A4536E9AB688401C081A04C6A1F3D" originalValue="über" pageId="null" pageNumber="373">ueber</normalizedToken>
3 mm breit, 
<normalizedToken id="CD1767EE6401B57E138621D8FBCCF18F" originalValue="allmählich" pageId="null" pageNumber="373">allmaehlich</normalizedToken>
zugespitzt, glatt oder nur oberseits rauh; 
<normalizedToken id="A532D57DB26491D37641B3A0D8B4BC3A" originalValue="Blatthäutchen" pageId="null" pageNumber="373">Blatthaeutchen</normalizedToken>
ca. 1 mm lang, gestutzt; Blattscheiden glatt. 
<normalizedToken id="5E85BABE728C6E8DA1C326AA05FAB5DD" originalValue="Ähre" pageId="null" pageNumber="373">Aehre</normalizedToken>
bis 20 cm lang, 
<emphasis id="5097E25FF20E785886668ADC52BB85CE" italics="true" pageId="null" pageNumber="373">mit glatter Achse</emphasis>
, aufrecht. 
<emphasis id="2AAD78C80B612C80D31B9166855CF9A3" italics="true" pageId="null" pageNumber="373">
<normalizedToken id="8AEB284571549B98EAAA407169BD176C" originalValue="Ährchen" pageId="null" pageNumber="373">Aehrchen</normalizedToken>
0,7
</emphasis>
- 
<emphasis id="14E4DFCA88ACF80BCF6DB00AC3E39C0F" italics="true" pageId="null" pageNumber="373">1 cm lang</emphasis>
, 4-8 
<normalizedToken id="3986C1046CE8E3002C1034EA59C6CD47" originalValue="blütig" pageId="null" pageNumber="373">bluetig</normalizedToken>
. Die 
<normalizedToken id="7582E488A26406452723743540062719" originalValue="Hüllspelze" pageId="null" pageNumber="373">Huellspelze</normalizedToken>
an den untern 
<normalizedToken id="86A1DD4B4552EE3ADE7E796A76B6D4D9" originalValue="Ährchen" pageId="null" pageNumber="373">Aehrchen</normalizedToken>
oft 
<normalizedToken id="FBB326CA3A47C2E23ECF0E01AC8B160B" originalValue="kürzer" pageId="null" pageNumber="373">kuerzer</normalizedToken>
als das 
<normalizedToken id="8DFAF374025473946ACF4081B00BA7AD" originalValue="Ährchen" pageId="null" pageNumber="373">Aehrchen</normalizedToken>
, 
<emphasis id="E63F234559E524FB0CF23F0EAF9E0ACC" italics="true" pageId="null" pageNumber="373">5nervig. Deckspelzen 4</emphasis>
- 
<emphasis id="CAFC84B7B6E1355DBD9767A5EA890966" italics="true" pageId="null" pageNumber="373">5 mm lang</emphasis>
, an der Spitze abgerundet und dort mit breitem, durchsichtigem Rand, derb, mit oder ohne Granne. 
<emphasis id="3842E45A0FC5F74E1EFEB6A6DE442AEF" italics="true" pageId="null" pageNumber="373">
Vorspelze 
<normalizedToken id="8D4BD9C712AD57506F9A8A464CB1E214" originalValue="überall" pageId="null" pageNumber="373">ueberall</normalizedToken>
kahl.
</emphasis>
- 
<normalizedToken id="CED8B2C61898FD091A81080CB11A1D82" originalValue="Blüte" pageId="null" pageNumber="373">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="F8CF57CCAE471D003CFB4F8EDB0F8DC8" pageId="null" pageNumber="373">
<emphasis id="7CC0873281851C1A2F930BE96F7162A9" italics="true" pageId="null" pageNumber="373">Zytologische Angaben.</emphasis>
Siehe unter Gattung.
</paragraph>
<paragraph id="56314EC6DECF5A45E018E3C6015B7A6A" pageId="null" pageNumber="373">
<emphasis id="90F13DA0B086F5FE316DBDE14DB1FDF6" italics="true" pageId="null" pageNumber="373">Standort.</emphasis>
Kollin. Unkraut vor allem in Flachsfeldern (vgl. die Arbeit 
<normalizedToken id="B8C5624F1E401EB1A524CE59E56E2CDB" originalValue="über" pageId="null" pageNumber="373">ueber</normalizedToken>
<normalizedToken id="6D24CBCA7FD998174A38E74D3C1EAC89" originalValue="Unkräuter" pageId="null" pageNumber="373">Unkraeuter</normalizedToken>
in Flachskulturen von Hjelmqvist 1950), 
<normalizedToken id="3EF1EDC8554A65094B699580A108064F" originalValue="Wegränder" pageId="null" pageNumber="373">Wegraender</normalizedToken>
, Ruderaistellen.
</paragraph>
<paragraph id="114EFB5859852C857F0C281322EB1FF2" pageId="null" pageNumber="373">
<emphasis id="720404E493C1CFBE094BE08DBF7162F5" italics="true" pageId="null" pageNumber="373">
Verbreitung. 
<normalizedToken id="C11668FE7FFAD486792D2EAD889DF6D6" originalValue="Europäische" pageId="null" pageNumber="373">Europaeische</normalizedToken>
Pflanze:
</emphasis>
Ganz 
<taxonomicName id="8A80F19804A2BB6DC7F109E09BE7EAE1" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="373" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
ohne arktische und engere mediterrane Gebiete, 
<normalizedToken id="2837C985F0B41555496F3044DFC76C5C" originalValue="ostwärts" pageId="null" pageNumber="373">ostwaerts</normalizedToken>
bis in den Ural, Kaukasus, isoliert in Tienschan und Taschkent (Verbreitungskarte von Hjelmqvist 1950). - Im Gebiet sehr selten geworden.
</paragraph>
</subSubSection>
</treatment>
