Campbell &amp; Engel
</taxonomicName>
and 
<taxonomicName id="4C424D56861B6B3DF8D58EA9F74DFC9F" authority="Yoo, 1994" authorityName="Yoo" authorityYear="1994" box="[1805,2263,733,772]" class="Gastropoda" family="Bellerophontidae" genus="Knightites" higherTaxonomySource="GBIF" kingdom="Animalia" order="Bellerophontida" pageId="9" pageNumber="72" phylum="Mollusca" rank="species" species="triangularis" status="n.sp." subGenus="Retispira">
