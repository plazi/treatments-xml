<subSubSection id="A7A1E0F4A439E04EF800F8E5F5BCF837" pageId="3" pageNumber="423" type="distribution">
<caption id="BBC4E3F7A439E04EF800F8E5F5BCF837" ID-DOI="http://doi.org/10.5281/zenodo.6616955" ID-Zenodo-Dep="6616955" httpUri="https://zenodo.org/record/6616955/files/figure.png" inLine="true" pageId="3" pageNumber="423" targetBox="[1407,1999,1563,1978]" targetPageId="3">
<paragraph id="EF04B37FA439E04EF800F8E5F5BCF837" blockId="3.[2022,2618,1554,1977]" lastBlockId="3.[1408,2619,1984,3439]" pageId="3" pageNumber="423">
<emphasis id="DDCF6F6DA439E04EF800F8E5F71CF895" bold="true" box="[2022,2197,1826,1859]" pageId="3" pageNumber="423">Distribution.</emphasis>
Known only from three localities in NE 
<collectingCountry id="97ACF3EFA439E04EF760F88EF74EF8BC" box="[2182,2247,1865,1898]" name="Peru" pageId="3" pageNumber="423">Peru</collectingCountry>
(Yavari and 
<collectingRegion id="2D7F7D9DA439E04EF698F88EF66BF8BC" box="[2430,2530,1865,1898]" country="Peru" name="Ucayali" pageId="3" pageNumber="423">Ucayali</collectingRegion>
interfluvial region, 
<collectingRegion id="2D7F7D9DA439E04EF749F8B6F684F844" box="[2223,2317,1905,1938]" country="Peru" name="Loreto" pageId="3" pageNumber="423">Loreto</collectingRegion>
Department) and SE 
<collectingCountry id="97ACF3EFA439E04EF801F85BF7BCF86F" box="[2023,2101,1948,1977]" name="Brazil" pageId="3" pageNumber="423">Brazil</collectingCountry>
(
<quantity id="28431E9AA439E04EF7B6F85BF720F86F" box="[2128,2217,1948,1977]" metricMagnitude="4" metricUnit="m" metricValue="2.5" pageId="3" pageNumber="423" unit="km" value="25.0">25 km</quantity>
E of Marliéria in Rio Doce State Park, 
<collectingRegion id="2D7F7D9DA439E04EF9FBF807F895F837" box="[1565,1820,1984,2017]" country="Brazil" name="Minas Gerais" pageId="3" pageNumber="423">Minas Gerais State</collectingRegion>
, and Sooretama Biological Reserve, 
<collectingRegion id="2D7F7D9DA439E04EF6F4F807F5AFF837" box="[2322,2598,1984,2017]" country="Brazil" name="Espirito Santo" pageId="3" pageNumber="423">Espirito Santo State</collectingRegion>
).
</paragraph>
