<subSubSection id="24DC108B5E5BC514FF3FB860FC92EADB" pageId="89" pageNumber="90" type="diagnosis">
<paragraph id="6C7943005E5BC514FF3FB860FC92EADB" blockId="89.[151,1436,1799,2004]" pageId="89" pageNumber="90">
<emphasis id="5EB29F125E5BC514FF3FB860FE97EAE7" bold="true" box="[199,321,1907,1932]" pageId="89" pageNumber="90">Diagnosis.</emphasis>
<quantity id="AB3EEEE55E5BC514FEB3B867FE05EAE0" box="[331,467,1908,1932]" metricMagnitude="-3" metricUnit="m" metricValue="6.05" metricValueMax="6.2" metricValueMin="5.9" pageId="89" pageNumber="90" unit="mm" value="6.05" valueMax="6.2" valueMin="5.9">5.9–6.2 mm</quantity>
long; distinguished from all other 
<taxonomicName id="ABC638835E5BC514FC90B867FC2CEAE7" authorityName="Ballantyne &amp; Lambkin" authorityYear="2013" box="[872,1018,1908,1932]" class="Insecta" family="Lampyridae" genus="Medeopteryx" kingdom="Animalia" order="Coleoptera" pageId="89" pageNumber="90" phylum="Arthropoda" rank="genus">
<emphasis id="5EB29F125E5BC514FC90B867FC2CEAE7" box="[872,1018,1908,1932]" italics="true" pageId="89" pageNumber="90">Medeopteryx</emphasis>
</taxonomicName>
by the median dark marking on the pronotum. (Characters of terminal abdomen not determined).
</paragraph>
</subSubSection>
<subSubSection id="24DC108B5E5BC517FF3FB8AFFDCBEC77" lastPageId="90" lastPageNumber="91" pageId="89" pageNumber="90" type="discussion">
<paragraph id="6C7943005E5BC514FF3FB8AFFA4AEABF" blockId="89.[151,1436,1799,2004]" box="[199,1436,1980,2004]" pageId="89" pageNumber="90">
<emphasis id="5EB29F125E5BC514FF3FB8AFFEEDEABF" bold="true" box="[199,315,1980,2004]" pageId="89" pageNumber="90">Remarks.</emphasis>
<taxonomicName id="ABC638835E5BC514FEBBB8AFFD93EABF" authority="Olivier" authorityName="Olivier" authorityYear="1910" box="[323,581,1980,2004]" class="Insecta" family="Lampyridae" genus="Luciola" kingdom="Animalia" order="Coleoptera" pageId="89" pageNumber="90" phylum="Arthropoda" rank="species" species="aspera">
<emphasis id="5EB29F125E5BC514FEBBB8AFFE3AEABF" box="[323,492,1980,2004]" italics="true" pageId="89" pageNumber="90">Luciola aspera</emphasis>
Olivier
</taxonomicName>
, described from a female, has median dark pronotal markings similar to 
<taxonomicName id="ABC638835E5BC514FA85B8AEFA4AEABF" box="[1405,1436,1981,2004]" pageId="89" pageNumber="90">
<emphasis id="5EB29F125E5BC514FA85B8AEFA4AEABF" box="[1405,1436,1981,2004]" italics="true" pageId="89" pageNumber="90">M.</emphasis>
</taxonomicName>
</paragraph>
<paragraph id="6C7943005E58C517FF6FBF8BFE63EDBF" blockId="90.[151,1436,151,284]" pageId="90" pageNumber="91">
<emphasis id="5EB29F125E58C517FF6FBF8BFF27EDDB" box="[151,241,152,176]" italics="true" pageId="90" pageNumber="91">hanedai</emphasis>
; however males without deflexed elytral apices are assigned to 
<taxonomicName id="ABC638835E58C517FBDCBF8AFBA6EDDB" authorityName="Olivier" authorityYear="1910" box="[1060,1136,153,176]" class="Insecta" family="Lampyridae" genus="Luciola" kingdom="Animalia" order="Coleoptera" pageId="90" pageNumber="91" phylum="Arthropoda" rank="species" species="aspera">
<emphasis id="5EB29F125E58C517FBDCBF8AFBA6EDDB" box="[1060,1136,153,176]" italics="true" pageId="90" pageNumber="91">aspera</emphasis>
</taxonomicName>
which is transferred to 
<taxonomicName id="ABC638835E58C517FF6FBFAFFE93EDBF" authority="Ballantyne &amp; Lambkin, 2013" authorityName="Ballantyne &amp; Lambkin" authorityYear="2013" box="[151,325,188,212]" class="Insecta" family="Lampyridae" genus="Australoluciola" kingdom="Animalia" order="Coleoptera" pageId="90" pageNumber="91" phylum="Arthropoda" rank="genus" status="gen. nov.">
<emphasis id="5EB29F125E58C517FF6FBFAFFE93EDBF" box="[151,325,188,212]" italics="true" pageId="90" pageNumber="91">Australoluciola</emphasis>
</taxonomicName>
<emphasis id="5EB29F125E58C517FEB4BFAFFE63EDBF" bold="true" box="[332,437,188,212]" pageId="90" pageNumber="91">
<taxonomicNameLabel id="458122695E58C517FEB4BFAFFE63EDBF" box="[332,437,188,212]" pageId="90" pageNumber="91" rank="genus">gen. nov.</taxonomicNameLabel>
</emphasis>
</paragraph>
<paragraph id="6C7943005E58C517FF3EBFCCFDCBEC77" blockId="90.[151,1436,151,284]" pageId="90" pageNumber="91">The Fly River male is the only representative of this species from other than the Sibil Mountains and the specimens may not be conspecific.</paragraph>
</subSubSection>
