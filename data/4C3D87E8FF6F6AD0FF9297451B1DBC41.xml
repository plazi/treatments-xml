<quantity id="036C9B1BFF6F6AD0FE45939E1C1EBEDA" box="[441,542,1479,1512]" metricMagnitude="3" metricUnit="m" metricValue="1.2129999999999999" pageId="148" pageNumber="909" unit="m" value="1213.0">1213 m</quantity>
in 
<collectingRegion id="0650F81CFF6F6AD0FDB1939E1CAFBEDA" box="[589,687,1479,1512]" country="China" name="Hunan" pageId="148" pageNumber="909">Hunan</collectingRegion>
and 
<quantity id="036C9B1BFF6F6AD0FD05939E1D5EBEDA" box="[761,862,1479,1512]" metricMagnitude="3" metricUnit="m" metricValue="1.069" pageId="148" pageNumber="909" unit="m" value="1069.0">1069 m</quantity>
in 
<collectingRegion id="0650F81CFF6F6AD0FC71939E1A08BEDA" box="[909,1032,1479,1512]" country="China" name="Guizhou" pageId="148" pageNumber="909">Guizhou</collectingRegion>
.
</paragraph>
</subSubSection>
