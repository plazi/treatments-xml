<subSubSection id="8C8E6575FF6F6AD0FF9290641AB0BDB4" pageId="148" pageNumber="909" type="activity">
<paragraph id="C42B36FEFF6F6AD0FF9290641AB0BDB4" blockId="148.[109,1317,897,1907]" pageId="148" pageNumber="909">
<emphasis id="F6E0EAECFF6F6AD0FF9290641F5ABD6C" bold="true" box="[110,346,1597,1630]" pageId="148" pageNumber="909">Activity patterns.</emphasis>
