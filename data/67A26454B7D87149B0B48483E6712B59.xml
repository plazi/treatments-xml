<subSubSection id="BBC292CF85D8989FB2FC53ABA10AB0DE" pageId="null" pageNumber="590" type="description">
<paragraph id="AD5EEE5C20F32359F8CBF44E1617D034" pageId="null" pageNumber="590">
1-2 
<normalizedToken id="BDB5D671F9B5BE2EA56B0F87A432D9AE" originalValue="jährig" pageId="null" pageNumber="590">jaehrig</normalizedToken>
; 30-50 cm hoch; 
<emphasis id="1707EF3B5D960CDE4C921C257E173E34" italics="true" pageId="null" pageNumber="590">
am Grunde wollig behaart. 
<normalizedToken id="0C36F9B317AB5BADFC00BEF57BD873E0" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
grasartig, 1
</emphasis>
- 
<emphasis id="6526E72B88479749D4FD5273F1CFF3CB" italics="true" pageId="null" pageNumber="590">
3 mm breit. Kopfstiele kaum verdickt, unter dem Kopf 
<normalizedToken id="997FA6E1166B36E54C1F66689394A899" originalValue="höchstens" pageId="null" pageNumber="590">hoechstens</normalizedToken>
1
</emphasis>
<normalizedToken id="DB6B7EDA2DB5CDA321A67CDEC7466409" originalValue="½" pageId="null" pageNumber="590">1/2</normalizedToken>
<emphasis id="9F4FCBC9D8CDACD763F4B8433EC9AA2D" italics="true" pageId="null" pageNumber="590">mal so dick wie 3 cm weiter unten.</emphasis>
<normalizedToken id="409415C94D89FCC3B4E724AA05CCA112" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
zur 
<normalizedToken id="7EF8821E6D3DF5CA9A2BC47C74BA3BDF" originalValue="Blütezeit" pageId="null" pageNumber="590">Bluetezeit</normalizedToken>
<emphasis id="D311CC4D50FB7043D7C38F0FA1E0C8DF" italics="true" pageId="null" pageNumber="590">2</emphasis>
- 
<emphasis id="03E01B4576B4D566B3561DEBFB76E1DC" italics="true" pageId="null" pageNumber="590">
2,5 cm lang, 
<normalizedToken id="FAA93962097697FC860EDBBCAE595EC0" originalValue="später" pageId="null" pageNumber="590">spaeter</normalizedToken>
bis 4 cm lang.
</emphasis>
<normalizedToken id="8D7AF07E0C48BFCF320B26355E905281" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
5-8, 
<emphasis id="DC058D6BE450BF01E7BFFA6C7FF94AA1" italics="true" pageId="null" pageNumber="590">
wenig 
<normalizedToken id="E5B4D877DC4FBCC326B1715F4EB501E8" originalValue="länger" pageId="null" pageNumber="590">laenger</normalizedToken>
als die 
<normalizedToken id="333722DBC09BBD200C7D88B6003B7716" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
. 
<normalizedToken id="C8D16341A01C91C1D40A7201470CE0AF" originalValue="Äußere" pageId="null" pageNumber="590">Aeussere</normalizedToken>
<normalizedToken id="1A36BDB414054BECDE5BE8EAAC8B4728" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
violett
</emphasis>
, 1,5-2 cm lang, 
<emphasis id="63C13DA92D42FC2BBD66DF279571A70B" italics="true" pageId="null" pageNumber="590">
innere 
<normalizedToken id="A047FAF84BCEE84180CF2327FEC75CE9" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
gelb.
</emphasis>
<normalizedToken id="4DE35CF5B17C0477F39084C72282451D" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
(mit Schnabel) 2-3 cm lang, 
<normalizedToken id="5763B0F696D4695690D061823C1269CB" originalValue="unregelmäßig" pageId="null" pageNumber="590">unregelmaessig</normalizedToken>
10rippig, die 
<normalizedToken id="C348D404E61BB35CB5736FEA9681518B" originalValue="äußern" pageId="null" pageNumber="590">aeussern</normalizedToken>
mit 
<emphasis id="3C86417C85ABB64BFB391863E70201B8" italics="true" pageId="null" pageNumber="590">spitzen Schuppen</emphasis>
, die innern fast glatt. 
<emphasis id="245C72D64814B208B967A76DB8048F58" italics="true" pageId="null" pageNumber="590">
Schnabel gegen den 
<taxonomicName id="A0001EF02DD643425E512BF45221A9F5" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
zu deutlich verdickt.
</emphasis>
- 
<normalizedToken id="00099172A1939E51B441E26E2186E40B" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: 
<normalizedToken id="F2AD0549BD083EF52B93A3C50FB89CC0" originalValue="Später" pageId="null" pageNumber="590">Spaeter</normalizedToken>
<normalizedToken id="2D55A73472341BF9F309ED57AABA5711" originalValue="Frühling" pageId="null" pageNumber="590">Fruehling</normalizedToken>
, Sommer.
</paragraph>
<paragraph id="9D26A7F0A98099D7FE9FBD863C01FAB8" pageId="null" pageNumber="590">
<emphasis id="B9668F7E02C2EBE81C6DAE9722C5F363" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="45EBD583EC764FB3DE656FF0DE966308" italics="true" pageId="null" pageNumber="590">14:</emphasis>
Material unbekannter Herkunft (Brock aus Darlington und Wylie 1955). Nach Kuzmanov (
<normalizedToken id="AF049CCF318D92716EE7FBED383BA475" originalValue="mündlich" pageId="null" pageNumber="590">muendlich</normalizedToken>
1972) ist die Zahl 
<emphasis id="2B77527BF39C9CD45D89AEC9E0482B58" italics="true" pageId="null" pageNumber="590">2n</emphasis>
= 
<emphasis id="FC8EDB38445C559C1091B16DABFD6769" italics="true" pageId="null" pageNumber="590">12</emphasis>
richtig.
</paragraph>
<paragraph id="7750EBB536B707A9CEED01135241B07A" pageId="null" pageNumber="590">
<emphasis id="FD5E233D4CE59C6D45B6BB172BE5697E" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Kollin und montan, seltener subalpin. Wiesen.
</paragraph>
<paragraph id="AF0B81E89E4467FD037F3A5A037678E5" pageId="null" pageNumber="590">
<emphasis id="6BAADE14ECEAF836A30D021C7245ECCD" italics="true" pageId="null" pageNumber="590">Verbreitung. Westmediterrane Pflanze:</emphasis>
Iberische Halbinsel, 
<normalizedToken id="A8390EF02839549C462C682AA17821EE" originalValue="Südfrankreich" pageId="null" pageNumber="590">Suedfrankreich</normalizedToken>
, Italien, isoliert in Gotland (Schweden); Algerien. - Im Gebiet: Savoyen (Gegend von 
<normalizedToken id="BFCA9C4C86D760EC90B56EC4873E0C43" originalValue="Chambéry" pageId="null" pageNumber="590">Chambery</normalizedToken>
und Gegend des Lac du Bourget), Aostatal; nicht 
<normalizedToken id="A45AE60A77D7A0938B1644A4E18C50C7" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
