<taxonomicName id="4C3890803A06FF9FFF0AEA18FE2DFAB5" authority="COIFFAIT" authorityName="COIFFAIT" box="[178,411,1368,1390]" class="Insecta" family="Staphylinidae" genus="Lithocharis" kingdom="Animalia" order="Coleoptera" pageId="6" pageNumber="1139" phylum="Arthropoda" rank="species" species="mauretanica">
<emphasis id="B94C37113A06FF9FFF0AEA18FE88FAB6" box="[178,318,1369,1390]" italics="true" pageId="6" pageNumber="1139">L. mauretanica</emphasis>
COIFFAIT
</taxonomicName>
, holotype (
