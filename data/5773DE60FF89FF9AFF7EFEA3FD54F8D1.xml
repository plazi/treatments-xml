<emphasis id="EDAEB364FF89FF9AFF7EFEA3FDD2FE71" bold="true" box="[136,549,374,401]" pageId="8" pageNumber="251">
4a. 
<taxonomicName id="18DA14F5FF89FF9AFF4BFEA3FDD2FE71" authorityName="Petagna" authorityYear="1787" box="[189,549,374,401]" class="Magnoliopsida" family="Plantaginaceae" genus="Callitriche" kingdom="Plantae" order="Lamiales" pageId="8" pageNumber="251" phylum="Tracheophyta" rank="subSpecies" species="brutia" subSpecies="brutia">
<emphasis id="EDAEB364FF89FF9AFF4BFEA3FE72FE71" bold="true" box="[189,389,374,401]" italics="true" pageId="8" pageNumber="251">Callitriche brutia</emphasis>
subsp. 
<emphasis id="EDAEB364FF89FF9AFE29FEA3FDD2FE71" bold="true" box="[479,549,374,401]" italics="true" pageId="8" pageNumber="251">brutia</emphasis>
</taxonomicName>
</emphasis>
