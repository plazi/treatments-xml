Saussure, 1869
</taxonomicName>
[
<taxonomicName id="AFA64D61FFD5297973F7E20B3A3FFA14" box="[426,524,1395,1419]" class="Insecta" family="Thespidae" genus="Oligonyx" kingdom="Animalia" order="Mantodea" pageId="2" pageNumber="263" phylum="Arthropoda" rank="genus">
