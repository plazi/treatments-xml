<taxonomicName id="F9E674B3FC0DA93EAAD8FAAAB27FAE1D" authorityName="Mayr" authorityYear="1861" box="[189,343,1345,1371]" class="Insecta" family="Formicidae" genus="Temnothorax" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="9" pageNumber="10" phylum="Arthropoda" rank="genus">
<emphasis id="0C92D322FC0DA93EAAD8FAAAB27FAE1D" box="[189,343,1345,1371]" italics="true" pageId="9" pageNumber="10">Temnothorax</emphasis>
</taxonomicName>
.
</paragraph>
