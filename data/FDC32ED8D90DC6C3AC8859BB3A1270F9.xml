<subSubSection id="7306337E17AFEB1926B430B168C99A67" pageId="null" pageNumber="656" type="description">
<paragraph id="7B170996D8EE1E5E8F3F4121BE64C515" pageId="null" pageNumber="656">
1 
<normalizedToken id="095C4E95E992B0AB5CCDCE4EFF4E8EF8" originalValue="jährig" pageId="null" pageNumber="656">jaehrig</normalizedToken>
, 
<emphasis id="BD5E8340A535778C23F20ADC1AD88896" italics="true" pageId="null" pageNumber="656">10-40 cm hoch, aufrecht, meist vom Grunde an verzweigt</emphasis>
, kahl oder zerstreut behaart. 
<emphasis id="2D387450EDADE15130CF824859DF65FB" italics="true" pageId="null" pageNumber="656">
Alle 
<normalizedToken id="D982BCB693A639B3DDF205BAADD67EB5" originalValue="Blätter" pageId="null" pageNumber="656">Blaetter</normalizedToken>
<normalizedToken id="8660AB4E7766E925307FDD6A6C753C58" originalValue="gegenständig" pageId="null" pageNumber="656">gegenstaendig</normalizedToken>
</emphasis>
(jedoch nicht kreuzweise 
<normalizedToken id="6FE497D87CFD62A82876E69DCCE3746B" originalValue="gegenständig" pageId="null" pageNumber="656">gegenstaendig</normalizedToken>
!), oval (
<normalizedToken id="AB158D65DC4E77EE8318847D7C72B2C1" originalValue="größte" pageId="null" pageNumber="656">groesste</normalizedToken>
Breite meist in oder unterhalb der Mitte), 
<emphasis id="0860129A2AB71821A4B210428A4E499B" italics="true" pageId="null" pageNumber="656">1,5-3 cm lang</emphasis>
, 2-3mal so lang wie breit, 
<emphasis id="F74CC259B94E11A6FE66C384BAB69523" italics="true" pageId="null" pageNumber="656">mit asymmetrischem Grund</emphasis>
, fein 
<normalizedToken id="3E9C59D087E84B9D8BA8EDA50B924008" originalValue="gezähnt" pageId="null" pageNumber="656">gezaehnt</normalizedToken>
; Blattstiel ca. 1 mm lang; 
<normalizedToken id="D754DAF41A6B1007F28FA39AD58F7F5E" originalValue="Nebenblätter" pageId="null" pageNumber="656">Nebenblaetter</normalizedToken>
ca. 1 mm lang. 
<normalizedToken id="DC4364DCF3236BCF6930FF9A7E0D2C07" originalValue="Gesamtblütenstände" pageId="null" pageNumber="656">Gesamtbluetenstaende</normalizedToken>
viele, doldenartig, aus zahlreichen 
<normalizedToken id="4AF26D9152115E19C19874711F7B583B" originalValue="Einzelblütenständen" pageId="null" pageNumber="656">Einzelbluetenstaenden</normalizedToken>
; 
<normalizedToken id="46401B421E768C96E531AE7AE70A7FFF" originalValue="Hüllbecher" pageId="null" pageNumber="656">Huellbecher</normalizedToken>
<normalizedToken id="A5EE94F78D0376C89793FA7D27B9BBA7" originalValue="außerseits" pageId="null" pageNumber="656">ausserseits</normalizedToken>
kahl; 
<normalizedToken id="E1E745202A81AE6C901131004C246BA3" originalValue="Drüsen" pageId="null" pageNumber="656">Druesen</normalizedToken>
mit breit ovalem 
<pageBreakToken id="D31932AB6FD26F78D88CB2BBE1B3AD39" pageId="null" pageNumber="656">
<normalizedToken id="5710C784E9980E63E7561943F0F287F7" originalValue="Anhängsel" pageId="null" pageNumber="656">Anhaengsel</normalizedToken>
</pageBreakToken>
. Frucht kahl. Samen 1,1-1,3 mm lang, 0,7-0,9 mm dick, stumpf 4kantig, mit grober, netzartig vorstehender 
<normalizedToken id="9EC195944AF017A51926DD1FB83D2BF1" originalValue="Oberflächenstruktur" pageId="null" pageNumber="656">Oberflaechenstruktur</normalizedToken>
(10fache 
<normalizedToken id="D427EDB177FEA7A3077C58D4A713C917" originalValue="Vergrößerung" pageId="null" pageNumber="656">Vergroesserung</normalizedToken>
), dunkelgrau. - 
<normalizedToken id="CDA06614B24F767DB6E63EA629A48042" originalValue="Blüte" pageId="null" pageNumber="656">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="B937C04196334F68C002CD076D86AEBD" pageId="null" pageNumber="656">
<emphasis id="053BF87A85A02F8A653DCC0EC9935D60" italics="true" pageId="null" pageNumber="656">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="4EDEAB287253148DFEA3A456DC5DEC96" italics="true" pageId="null" pageNumber="656">12:</emphasis>
Material aus Italien, normal sexuell (
<normalizedToken id="CAB166D8B6199755443DAE2EC5CB2ED2" originalValue="D’Amato" pageId="null" pageNumber="656">D'Amato</normalizedToken>
1946a). 
<emphasis id="6E3CF3A5CD92CB91C6D02DF119B90352" italics="true" pageId="null" pageNumber="656">2n</emphasis>
= 
<emphasis id="1D08134556D68113560750F54AB32B40" italics="true" pageId="null" pageNumber="656">14:</emphasis>
Material aus Virginia, USA (Perry 1943).
</paragraph>
<paragraph id="3ED6BF0BAABFF0262A4EE46B55288378" pageId="null" pageNumber="656">
<emphasis id="6FE3737DC4CE0E5367E96E0D64B30594" italics="true" pageId="null" pageNumber="656">Standort</emphasis>
. Kollin. 
<normalizedToken id="6F68AB79F2E64543F816C4900649F305" originalValue="Gärten" pageId="null" pageNumber="656">Gaerten</normalizedToken>
, Ruderalstellen, Bahnareale.
</paragraph>
<paragraph id="0BB746E4F35A09B5C437441E3B705550" pageId="null" pageNumber="656">
<emphasis id="8EB13B6EBD02DCB91661415C6BD28EC5" italics="true" pageId="null" pageNumber="656">Verbreitung</emphasis>
. 
<normalizedToken id="186997EE2A53959F41CC6BBCC3CF0F33" originalValue="Ursprünglich" pageId="null" pageNumber="656">Urspruenglich</normalizedToken>
<emphasis id="692F954625BE6F4EBCEC661907DC607D" italics="true" pageId="null" pageNumber="656">
Pflanze des subtropischen und 
<normalizedToken id="D76729F1C2BD37F8864EFAF145D4A719" originalValue="gemäßigten" pageId="null" pageNumber="656">gemaessigten</normalizedToken>
Nordamerika;
</emphasis>
heute als Unkraut weit verbreitet. - Im Gebiet in Ausbreitung begriffen, im 
<normalizedToken id="90D25798E4572E57046CF79D168E62CA" originalValue="südlichen" pageId="null" pageNumber="656">suedlichen</normalizedToken>
Teil 
<normalizedToken id="D2373453AF108BEA9019E8725354B429" originalValue="eingebürgert" pageId="null" pageNumber="656">eingebuergert</normalizedToken>
.
</paragraph>
</subSubSection>
