Key to species of the subgenus 
<taxonomicName id="4C0CE0DDFFBCFFE7FE5E7EAC451053E7" authorityName="Enderlein" authorityYear="1942" box="[472,605,204,226]" class="Insecta" family="Pyrgotidae" genus="Taeniomastix" kingdom="Animalia" order="Diptera" pageId="2" pageNumber="213" phylum="Arthropoda" rank="genus">
<emphasis id="B978474CFFBCFFE7FE5E7EAC451053E7" bold="true" box="[472,605,204,226]" italics="true" pageId="2" pageNumber="213">Taeniomastix</emphasis>
</taxonomicName>
</emphasis>
