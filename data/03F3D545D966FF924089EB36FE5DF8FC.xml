a.s.l.
</elevation>
), 
<location id="8E853288D966FF9144E8EB82FA6FFE3C" LSID="urn:lsid:plazi:treatment:03F3D545D966FF924089EB36FE5DF8FC:8E853288D966FF9144E8EB82FA6FFE3C" box="[1270,1432,475,501]" country="China" latitude="25.54" longLatPrecision="748" longitude="100.0" municipality="Mt Cangshan in Dali" name="XiZhou Town" pageId="1" pageNumber="427" stateProvince="Yunnan">XiZhou Town</location>
