<collectingDate id="EFA0BB7BD966FF91424BEB82FD37FE3C" box="[597,704,475,501]" pageId="1" pageNumber="427" value="2020-10-06">6.X.2020</collectingDate>
</date>
, Huadianba (
<geoCoordinate id="EE6E0294D966FF914346EB83FC4CFE3C" box="[856,955,474,501]" degrees="25.54" direction="north" orientation="latitude" pageId="1" pageNumber="427" precision="555" value="25.54">25.54°N</geoCoordinate>
