<geoCoordinate id="EE6E0294D966FF9143D6EB82FBC3FE3C" box="[968,1076,475,501]" degrees="100.00" direction="east" orientation="longitude" pageId="1" pageNumber="427" precision="555" value="100.0">100.00°E</geoCoordinate>
