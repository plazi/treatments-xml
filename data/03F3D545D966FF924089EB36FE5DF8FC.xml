, 
<collectingCountry id="F34D24C3D966FF9141C3EBA6FDD4FDD0" box="[477,547,511,537]" name="China" pageId="1" pageNumber="427">China</collectingCountry>
, 
<collectorName id="26AF0185D966FF91422EEBA6FD23FDD0" box="[560,724,511,537]" pageId="1" pageNumber="427">Guo-Hui Yang</collectorName>
