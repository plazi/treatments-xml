<subSubSection id="549C52D567595C6CFB07ADC8D551E309" pageId="null" pageNumber="471" type="description">
<paragraph id="6087210907074230AAFEB6EB727E1B71" pageId="null" pageNumber="471">
Zur 
<normalizedToken id="824B1C4872D4E2DF5C4DB73FA3C51E16" originalValue="Blütezeit" pageId="null" pageNumber="471">Bluetezeit</normalizedToken>
10-30 cm hoch, zur Fruchtzeit bis 60 cm hoch. Rhizom nicht knollig verdickt. 
<normalizedToken id="EC1710D390F7D20E551C75763E306A9B" originalValue="Grundständige" pageId="null" pageNumber="471">Grundstaendige</normalizedToken>
<normalizedToken id="5D13C8BEB305FC405545E77260BF52B9" originalValue="Blätter" pageId="null" pageNumber="471">Blaetter</normalizedToken>
nach der 
<normalizedToken id="A0FBA317CA157FADDA73D1DEBA604666" originalValue="Blüte" pageId="null" pageNumber="471">Bluete</normalizedToken>
erscheinend, 
<emphasis id="94DD2EC0DB30CEE4803FCEB3EC4AFCC4" italics="true" pageId="null" pageNumber="471">unterseits bleibend graufilzig, mit fast kahlen Nerven</emphasis>
, oberseits im Alter verkahlend, 
<emphasis id="5E70DB19F876E12956498CF6DAC94ADE" italics="true" pageId="null" pageNumber="471">
bis 40 cm breit, rundlich bis 
<normalizedToken id="06AA32D458C800C67D9F623227DDC98F" originalValue="nierenförmig" pageId="null" pageNumber="471">nierenfoermig</normalizedToken>
, breiter als lang
</emphasis>
, doppelt und flachbuchtig 
<normalizedToken id="53757FA6E4E0DBC97DF81475643D841A" originalValue="gezähnt" pageId="null" pageNumber="471">gezaehnt</normalizedToken>
; 
<normalizedToken id="8FC327A8B61CD7D08A8F19C0BCA1C951" originalValue="Zähne" pageId="null" pageNumber="471">Zaehne</normalizedToken>
fein, schmal, spitz, aufgesetzt; Blattstiel (frisch) seitlich abgeflacht, an den Seiten glatt. Stengel graufilzig, 
<normalizedToken id="EC528F8F906E4DE85DA068410A6BE150" originalValue="später" pageId="null" pageNumber="471">spaeter</normalizedToken>
oft verkahlend, im obern Teil 
<normalizedToken id="46DACF23562B3FA568E658C73803DA2F" originalValue="drüsig" pageId="null" pageNumber="471">druesig</normalizedToken>
behaart. 
<normalizedToken id="70920F8AD1C24AE6D8830B46DA86D62B" originalValue="Schuppenblätter" pageId="null" pageNumber="471">Schuppenblaetter</normalizedToken>
(am Stengel) oval bis lanzettlich (
<normalizedToken id="801EFD57F67A1DFA4D433357BBA34620" originalValue="größte" pageId="null" pageNumber="471">groesste</normalizedToken>
Breite oberhalb der Anwachs- 
<pageBreakToken id="56765276E6CD721B421C3104CFB8436B" pageId="null" pageNumber="471">stelle</pageBreakToken>
), zerstreut filzig behaart, 
<emphasis id="41461E58A4089E65C859E064BD92CC81" italics="true" pageId="null" pageNumber="471">
<normalizedToken id="90D61D05482D29CDA4E398B6AE67FFC4" originalValue="bleichgrün" pageId="null" pageNumber="471">bleichgruen</normalizedToken>
</emphasis>
, nur die untersten den Stengel 
<normalizedToken id="0A8B1FF610575EB8E0766A1E95E19080" originalValue="scheidenförmig" pageId="null" pageNumber="471">scheidenfoermig</normalizedToken>
umfassend. Durchmesser der 
<normalizedToken id="5C7745CD4B17C7308BD2C71E83579A02" originalValue="Blütenköpfe" pageId="null" pageNumber="471">Bluetenkoepfe</normalizedToken>
etwa 0,8 cm. 
<normalizedToken id="199F80607381A4E2D0326D74D68EA53E" originalValue="Hüllblätter" pageId="null" pageNumber="471">Huellblaetter</normalizedToken>
14-18, 
<emphasis id="51DBB2AF5EE4EC60638A8FFB639A2D73" italics="true" pageId="null" pageNumber="471">
<normalizedToken id="8B8C82A2686B074C1F60F9B5AABB30BC" originalValue="bleichgrün" pageId="null" pageNumber="471">bleichgruen</normalizedToken>
</emphasis>
, etwa 1 cm lang, 
<emphasis id="C07AD4B8F31FA569C842201D4A526191" italics="true" pageId="null" pageNumber="471">
<normalizedToken id="0294CA0E700130C00B2AE15CBA3D5E89" originalValue="drüsig" pageId="null" pageNumber="471">druesig</normalizedToken>
behaart. Kronen 
<normalizedToken id="987A035153370D4B5557F91E314AEDF7" originalValue="gelblichweiß" pageId="null" pageNumber="471">gelblichweiss</normalizedToken>
.
</emphasis>
Narben der innern 
<normalizedToken id="B4F7DD89088FA8D672630CF84E7F9B31" originalValue="Blüten" pageId="null" pageNumber="471">Blueten</normalizedToken>
bei 
<normalizedToken id="67D557E004BE840ACB9F8FC2C1683B90" originalValue="«♂»" pageId="null" pageNumber="471">&quot;♂&quot;</normalizedToken>
Pflanzen schmal lanzettlich. 
<normalizedToken id="09BA53B9862DC9DABB0BA13FB5B9D17B" originalValue="Früchte" pageId="null" pageNumber="471">Fruechte</normalizedToken>
2-3 mm lang. 
<taxonomicName id="2FF4EACA753ABEB8A3627DF937E6FC15" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="471" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
<normalizedToken id="285BA91419374D486610093F217DA25C" originalValue="weiß" pageId="null" pageNumber="471">weiss</normalizedToken>
, etwa 12 mm lang. - 
<normalizedToken id="18BD92D504913A8D5F1779855D6ED0C6" originalValue="Blüte" pageId="null" pageNumber="471">Bluete</normalizedToken>
: 
<normalizedToken id="207600DFAFE617B6463435BA7D90D0BA" originalValue="Früher" pageId="null" pageNumber="471">Frueher</normalizedToken>
<normalizedToken id="461A87F3B901DBFD33C38042ABFE596A" originalValue="Frühling" pageId="null" pageNumber="471">Fruehling</normalizedToken>
(bald nach der Schneeschmelze).
</paragraph>
<paragraph id="8E6A52019FEE2D578F36A2A0FC2559ED" pageId="null" pageNumber="471">
<emphasis id="54ED8A6F29B1C2D5DC1FEB1500A74498" italics="true" pageId="null" pageNumber="471">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E1E4C0C9453FF7F53224F3AD545CF406" italics="true" pageId="null" pageNumber="471">60:</emphasis>
Material aus botanischem Garten (Langlet 1936), aus Schleswig-Holstein (Scheerer 1939).
</paragraph>
<paragraph id="447C6F7F6CD79C55AB5E5881761D3A3B" pageId="null" pageNumber="471">
<emphasis id="AB67268C02CE47703BE93932F022EADA" italics="true" pageId="null" pageNumber="471">Standort.</emphasis>
Montan, seltener kollin und subalpin. Sickerfeuchte, 
<normalizedToken id="D1513434166DFC5D34BC9FDA451DB960" originalValue="nährstoffreiche" pageId="null" pageNumber="471">naehrstoffreiche</normalizedToken>
, humose, tonige 
<normalizedToken id="95C6082C5279B5C82B082DF9865D94CF" originalValue="Böden" pageId="null" pageNumber="471">Boeden</normalizedToken>
in schattigen Lagen. Krautreiche Buchen-, Tannen- und 
<normalizedToken id="868EF7DB947E868B1CAD3E1EC7A34247" originalValue="Fichtenwälder" pageId="null" pageNumber="471">Fichtenwaelder</normalizedToken>
, 
<normalizedToken id="F08E7C89D0FB57A3718FFF51DE70D871" originalValue="Schluchtwälder" pageId="null" pageNumber="471">Schluchtwaelder</normalizedToken>
, 
<normalizedToken id="0AB27EB37605F06DE8CFED77FBFB65B9" originalValue="Gebüsche" pageId="null" pageNumber="471">Gebuesche</normalizedToken>
, 
<normalizedToken id="F06CC3CA72FAE25E983F7041BA127BC5" originalValue="Wegränder" pageId="null" pageNumber="471">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="6CD61E14696225AEE389585A249D929D" pageId="null" pageNumber="471">
<emphasis id="0A7D9090501DB09CB7E568DB22793669" italics="true" pageId="null" pageNumber="471">Verbreitung. Eurasiatische Pflanze:</emphasis>
West- und 
<normalizedToken id="775C32EFFF62174A685C194E61E7BAD6" originalValue="nordwärts" pageId="null" pageNumber="471">nordwaerts</normalizedToken>
bis Rhonetal, Vogesen, 
<normalizedToken id="0F9C4413B1484E5B3DE842B295D6BF6C" originalValue="Südskandinavien" pageId="null" pageNumber="471">Suedskandinavien</normalizedToken>
, Baltische Staaten; ost- und 
<normalizedToken id="4D1283B87FD9FEC62DF3785662A22867" originalValue="südwärts" pageId="null" pageNumber="471">suedwaerts</normalizedToken>
bis Altai, 
<normalizedToken id="EC9D9E164EDA7591310D6378D22D4FF5" originalValue="Südkarpaten" pageId="null" pageNumber="471">Suedkarpaten</normalizedToken>
, Bulgarien, Apennin. - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="D5CC2EB75CD31E6A62D696FE88601BD2" originalValue="häufig" pageId="null" pageNumber="471">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
