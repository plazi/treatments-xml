<taxonomicName authorityName="Pellegrini, Ferreira &amp; Vieira" authorityYear="2022" class="Insecta" family="Carabidae" genus="Coarazuphium" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Coarazuphium xikrin" order="Coleoptera" pageId="0" pageNumber="97" phylum="Arthropoda" rank="species" species="xikrin">
