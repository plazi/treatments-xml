<paragraph id="E97036DD3F62FFF5FF76FC4BFC59FC09" blockId="87.[151,1437,973,2008]" box="[151,953,973,1000]" pageId="87" pageNumber="88">
Size. Maximum known size about 
<quantity id="2E379B383F62FFF5FDFDFC4BFD88FC09" box="[540,616,973,1000]" metricMagnitude="-2" metricUnit="m" metricValue="3.9" pageId="87" pageNumber="88" unit="cm" value="3.9">3.9 cm</quantity>
total length (
<bibRefCitation id="8D5E4B2C3F62FFF5FD1CFC4BFC4EFC09" author="Kovacic, M." box="[765,942,973,1000]" pageId="87" pageNumber="88" pagination="1019 - 1023" refId="ref58016" refString="Kovacic, M. (2008 b) Live colouration, morphology and habitat of Vanneaugobius dollfusi (Gobiidae) in the northern Adriatic Sea. Journal of Fish Biology, 73, 1019 - 1023. https: // doi. org / 10.1111 / j. 1095 - 8649.2008.01918. x" type="journal article" year="2008">Kovačić 2008b</bibRefCitation>
