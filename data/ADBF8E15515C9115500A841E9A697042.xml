<subSubSection id="42A3D4DCB3D87459FA0BF3A952AB61FD" pageId="null" pageNumber="460" type="description">
<paragraph id="1177BA5DC884D671E6F5A3461D9763B4" pageId="null" pageNumber="460">
40-65 cm hoch; dichte, feste Horste bildend. 
<emphasis id="400BDEAC8578AA21B2E9C54140CBC967" italics="true" pageId="null" pageNumber="460">
<normalizedToken id="44B56C885F00A3B5FDF6093E9A54A8C5" originalValue="Grundständige" pageId="null" pageNumber="460">Grundstaendige</normalizedToken>
Blattscheiden gelbbraun bis rotbraun
</emphasis>
, nach dem Zerfall einen 
<emphasis id="64A5EB36C2CA4D4AAD299D6E8A047319" italics="true" pageId="null" pageNumber="460">auffallenden Faserschopf</emphasis>
bildend (wie 
<taxonomicName id="4C403785169763899A3738B0BB97A816" authority="Nr." authorityName="Nr." class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="460" phylum="Tracheophyta" rank="species" species="umbrosa">
<emphasis id="D7A3829D055BD9CDFC03CA34103F465B" italics="true" pageId="null" pageNumber="460">C. umbrosa</emphasis>
, Nr.
</taxonomicName>
58). 
<normalizedToken id="DA784791B7112656DFC0AB938D74B37A" originalValue="Blätter" pageId="null" pageNumber="460">Blaetter</normalizedToken>
2-4 mm breit, flach, steif, 
<emphasis id="B186A2B91CB01B9079B710B258267DA7" italics="true" pageId="null" pageNumber="460">oberseits ohne weiche Haare</emphasis>
, die 
<normalizedToken id="8BA8F8546F087F932C0BD6E4CCA3C947" originalValue="Blütenstände" pageId="null" pageNumber="460">Bluetenstaende</normalizedToken>
<normalizedToken id="A31461FC5C79C74FE0EBC30AB4CC7505" originalValue="überragend" pageId="null" pageNumber="460">ueberragend</normalizedToken>
. 
<normalizedToken id="131BECD826C1D71ABD1DB4C27778FF35" originalValue="Blütenstand" pageId="null" pageNumber="460">Bluetenstand</normalizedToken>
im Habitus wie bei 
<emphasis id="91CE4CB61F5A6E923EC352DEDD1CFFA0" italics="true" pageId="null" pageNumber="460">
<taxonomicName id="182B4A5A8621F1FD93D43B9FAF1598FC" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="460" phylum="Tracheophyta" rank="species" species="umbrosa">C. umbrosa</taxonomicName>
. 
<normalizedToken id="6ECFDDBECB4597A652A5D18308259DAF" originalValue="Hochblätter" pageId="null" pageNumber="460">Hochblaetter</normalizedToken>
<normalizedToken id="A838970A9AB09BDDC66C539FA60943B3" originalValue="tragblattähnlich" pageId="null" pageNumber="460">tragblattaehnlich</normalizedToken>
, ohne deutliche Scheiden.
</emphasis>
<normalizedToken id="CD24B380E46B0295B0B90ECAED372B94" originalValue="Tragblätter" pageId="null" pageNumber="460">Tragblaetter</normalizedToken>
etwa so lang wie die reifen 
<normalizedToken id="629BFDA74AB599CAB8311B18992B2EFD" originalValue="Fruchtschläuche" pageId="null" pageNumber="460">Fruchtschlaeuche</normalizedToken>
, spitz, rotbraun, mit 
<normalizedToken id="FC9A626CFBC2642ABC17477144D0E346" originalValue="weißem" pageId="null" pageNumber="460">weissem</normalizedToken>
Rand und hellem Mittelnerv. 
<normalizedToken id="C38EF70402654FA6EB6C8B340FE0FCEE" originalValue="Fruchtschläuche" pageId="null" pageNumber="460">Fruchtschlaeuche</normalizedToken>
3-3,5 mm lang, 
<normalizedToken id="ADFA05CD86181FF0CDAD943EA765C8FF" originalValue="größte" pageId="null" pageNumber="460">groesste</normalizedToken>
Breite 
<normalizedToken id="33029A6F481FC1056281CDBEE0A1C1BC" originalValue="über" pageId="null" pageNumber="460">ueber</normalizedToken>
der Mitte (2-2,2 mm), im 
<emphasis id="65BCF002E8C1CA3E1CD58AB4E6FCDC28" italics="true" pageId="null" pageNumber="460">Querschnitt rundlich</emphasis>
, mit deutlichen Nerven, 
<normalizedToken id="BC6E15FA24C9D69DC540D507B6E28C31" originalValue="graugrün" pageId="null" pageNumber="460">graugruen</normalizedToken>
, behaart, 
<normalizedToken id="42311B1948D97B3F3EA5C0774092A596" originalValue="plötzlich" pageId="null" pageNumber="460">ploetzlich</normalizedToken>
in den kleinen Schnabel 
<normalizedToken id="94910FAC8D36112FBF7006FC174A2FE1" originalValue="verschmälert" pageId="null" pageNumber="460">verschmaelert</normalizedToken>
. Narben 3.
</paragraph>
<paragraph id="DA1F3AD2EA163C0350EB22450263FBF9" pageId="null" pageNumber="460">
<emphasis id="D224F09439A312FB4D810C591F3A4A27" italics="true" pageId="null" pageNumber="460">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="38CC91052A2D169225E54FA683FB179F" italics="true" pageId="null" pageNumber="460">30:</emphasis>
Material aus Ungarn (Baksay 1957b), aus Lugano (Schmidt in 
<normalizedToken id="FE885AC0984AA8B4EC8214FD7CAEBADF" originalValue="Löve" pageId="null" pageNumber="460">Loeve</normalizedToken>
und 
<normalizedToken id="3C84E56865D4920605A66C308D1E4E72" originalValue="Löve" pageId="null" pageNumber="460">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="63604B15C80B3AFBE240226C5B7009EF" pageId="null" pageNumber="460">
<emphasis id="DC9141BE544DA3A2DA3617768889113E" italics="true" pageId="null" pageNumber="460">Standort.</emphasis>
Kollin. Saure, trockene, humose 
<normalizedToken id="3A22A815C820D15C129D296A449E7286" originalValue="Böden" pageId="null" pageNumber="460">Boeden</normalizedToken>
. Azidophile, wahrscheinlich 
<normalizedToken id="1BA65368A68A5DF6DB5F7C9C1F7F0338" originalValue="wärmeliebende" pageId="null" pageNumber="460">waermeliebende</normalizedToken>
<normalizedToken id="22A03E7949EE0FCF17181BC22D868D2D" originalValue="Eichenwälder" pageId="null" pageNumber="460">Eichenwaelder</normalizedToken>
(Baksay 1957b gibt aus Ungarn 
<emphasis id="ABBB935AF6E8E7010F32AA891B3044CB" italics="true" pageId="null" pageNumber="460">Querco-Betuletum callunetosum</emphasis>
an); auf der 
<normalizedToken id="857D6CC2D1E7D7BF8D8F2B2D32D3D194" originalValue="Alpensüdseite" pageId="null" pageNumber="460">Alpensuedseite</normalizedToken>
nach 
<normalizedToken id="8865957356787E573442A5C8A8F04AAA" originalValue="Lüdi" pageId="null" pageNumber="460">Luedi</normalizedToken>
(1941) nur im 
<taxonomicName id="C79DFE9A147F7590D330D660BD11691F" authority="Luedi 1941" authorityName="Luedi" authorityYear="1941" class="Liliopsida" family="Cyperaceae" genus="Castaneetum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="460" phylum="Tracheophyta" rank="species" species="insubricum">
<emphasis id="0C9D203D04DF9C4EEA8EE4FD5E44DA21" italics="true" pageId="null" pageNumber="460">Castaneetum insubricum</emphasis>
<normalizedToken id="7384F92CBC3783B2A09D91370B850B47" originalValue="Lüdi" pageId="null" pageNumber="460">Luedi</normalizedToken>
1941
</taxonomicName>
.
</paragraph>
<paragraph id="48F5EE091FCB732E301F291099C503B2" pageId="null" pageNumber="460">
<emphasis id="BDB0594F05B8EC2F3C4B19106254DCAA" italics="true" pageId="null" pageNumber="460">
Verbreitung. 
<normalizedToken id="9F50387956FB5B648662E1ED1DD334EF" originalValue="Südeuropäische" pageId="null" pageNumber="460">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="08DB04A6DF08B1C0380CC63D590689F1" originalValue="Südlicher" pageId="null" pageNumber="460">Suedlicher</normalizedToken>
Alpenrand von Piemont bis Steiermark und Westungarn, Verbreitung 
<normalizedToken id="E9006F67F1DAF3B9552B90F1021EBA9B" originalValue="nördlich" pageId="null" pageNumber="460">noerdlich</normalizedToken>
der Alpen unklar. - Im Gebiet: 
<normalizedToken id="4F416E9276CE6969EED16BA30657176F" originalValue="Elsaß" pageId="null" pageNumber="460">Elsass</normalizedToken>
(bei Habsheim und Ottmarsheim), 
<normalizedToken id="AC5FBC33B3ADFE8E6075D9F559034C0F" originalValue="Graubünden" pageId="null" pageNumber="460">Graubuenden</normalizedToken>
(Misox), 
<normalizedToken id="95C8B21668AC8D9537A7957B065E1E88" originalValue="südliches" pageId="null" pageNumber="460">suedliches</normalizedToken>
Tessin und angrenzende Gebiete.
</paragraph>
<paragraph id="26D832716B5A451E65D1340425BD78E2" pageId="null" pageNumber="460">
<emphasis id="CE2D219CF3AF13B802D73833980671DC" italics="true" pageId="null" pageNumber="460">Bemerkungen.</emphasis>
Am Original material aus Ungarn treten die Nerven am Fruchtschlauch stark hervor (unsere Abbildung); Material aus dem Tessin hat weniger deutliche Nerven.
</paragraph>
</subSubSection>
