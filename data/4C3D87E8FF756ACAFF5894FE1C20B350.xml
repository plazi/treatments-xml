<caption id="90EB6676FF756ACAFCF4921D1DA3BFC9" ID-DOI="http://doi.org/10.5281/zenodo.6398482" ID-Zenodo-Dep="6398482" httpUri="https://zenodo.org/record/6398482/files/figure.png" inLine="true" pageId="142" pageNumber="902" targetBox="[161,753,861,1275]" targetPageId="142">
