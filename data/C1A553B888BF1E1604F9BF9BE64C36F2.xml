<subSubSection id="5B4CCDCD416FCA2B52A11500903464A4" pageId="null" pageNumber="552" type="description">
<paragraph id="46DB7A3B2C8A55525A5F8313B250E709" pageId="null" pageNumber="552">
1-2 
<normalizedToken id="2CA11B1A5A4C451EBB7290AD50A23F43" originalValue="jährig" pageId="null" pageNumber="552">jaehrig</normalizedToken>
. 
<normalizedToken id="E55DF057132CE14224699777776E71DA" originalValue="Blätter" pageId="null" pageNumber="552">Blaetter</normalizedToken>
gefiedert, mit Endteilblatt und kleinen, freien 
<normalizedToken id="9A83B6CFC5250A0F6EA724B3A6B90FA4" originalValue="Nebenblättern" pageId="null" pageNumber="552">Nebenblaettern</normalizedToken>
; 
<normalizedToken id="8F2A568769A726CF70D810DF9710607D" originalValue="Teilblätter" pageId="null" pageNumber="552">Teilblaetter</normalizedToken>
ganzrandig, oval bis lanzettlich. 
<normalizedToken id="481A669595D47FF1675CF04824B3ACC5" originalValue="Blüten" pageId="null" pageNumber="552">Blueten</normalizedToken>
aufrecht, in aufrechten Dolden oder 
<normalizedToken id="0075D8D5B97808F70CB0EEDF7333B6AE" originalValue="Köpfen" pageId="null" pageNumber="552">Koepfen</normalizedToken>
, die in den Achseln von 
<normalizedToken id="DB9581D666846A5FF3296FC1C4DDC4B3" originalValue="Stengelblättern" pageId="null" pageNumber="552">Stengelblaettern</normalizedToken>
stehen. 
<emphasis id="F01C9B9537F52FE7D076973ED290B6BF" italics="true" pageId="null" pageNumber="552">
<normalizedToken id="1B4ED3EF146B5BEF32D53C60A9DB7FE3" originalValue="Blütenstiele" pageId="null" pageNumber="552">Bluetenstiele</normalizedToken>
sehr kurz, bedeutend 
<normalizedToken id="872CF1EC15EF44E986D99D32386B06A6" originalValue="kürzer" pageId="null" pageNumber="552">kuerzer</normalizedToken>
als der Kelch.
</emphasis>
Kelch 
<normalizedToken id="F0F19F3E55918DF96C3C9747B541DE3F" originalValue="glockenförmig" pageId="null" pageNumber="552">glockenfoermig</normalizedToken>
, mit 5 schmal 3eckigen, gleichartigen 
<normalizedToken id="08E26DA836E9405417141447092F8357" originalValue="Zähnen" pageId="null" pageNumber="552">Zaehnen</normalizedToken>
. Krone gelb, rosa oder 
<normalizedToken id="B791C21394AF86ECE269D086317EC70A" originalValue="weiß" pageId="null" pageNumber="552">weiss</normalizedToken>
; Fahne 
<normalizedToken id="B013E98C5CDC527F48029FDF58E6DB63" originalValue="länger" pageId="null" pageNumber="552">laenger</normalizedToken>
als die 
<normalizedToken id="79AF3E86C021382028E5DB5A0C160478" originalValue="Flügel" pageId="null" pageNumber="552">Fluegel</normalizedToken>
; Schiffchen 
<normalizedToken id="0716EEF5159530B8B0E6B061808249D8" originalValue="kürzer" pageId="null" pageNumber="552">kuerzer</normalizedToken>
als die 
<normalizedToken id="0437A639F8EC7C342738A0825D3AA412" originalValue="Flügel" pageId="null" pageNumber="552">Fluegel</normalizedToken>
, 
<emphasis id="3F1917E8F6A1CF42ACE79F04D6F80A62" italics="true" pageId="null" pageNumber="552">gerade, vorn abgerundet.</emphasis>
Oberstes Staubblatt frei. Frucht im Kelch ungestielt, etwas gebogen (Fruchtstand 
<normalizedToken id="F3752AED4ED61EE841A1DFC639AD74E0" originalValue="«vogelfußartig»" pageId="null" pageNumber="552">&quot;vogelfussartig&quot;</normalizedToken>
), 
<emphasis id="4BE94E84F4D8D14F664299422B345FB9" italics="true" pageId="null" pageNumber="552">flach</emphasis>
, vielsamig, 
<emphasis id="1EF7550EF696D7815BFFB1950BFE9C4F" italics="true" pageId="null" pageNumber="552">
zwischen den Samen 
<normalizedToken id="C9370AD4E46D380B4E2D8CEFDBD74548" originalValue="eingeschnürt" pageId="null" pageNumber="552">eingeschnuert</normalizedToken>
und zur Reifezeit in einzelne Glieder zerfallend.
</emphasis>
</paragraph>
<paragraph id="0967A115A714DEAEABF1F9D2F2177AE3" pageId="null" pageNumber="552">
Die Gattung 
<taxonomicName id="EE46F00E6E9E199D966D85F3A9DA2523" class="Magnoliopsida" family="Fabaceae" genus="Ornithopus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="552" phylum="Tracheophyta" rank="genus">
<emphasis id="395A84D40AC208EF8F255CBBDC2259A7" italics="true" pageId="null" pageNumber="552">Ornithopus</emphasis>
</taxonomicName>
<normalizedToken id="15186A2909F5693881AA2EA5A2F12B37" originalValue="umfaßt" pageId="null" pageNumber="552">umfasst</normalizedToken>
etwa 
<emphasis id="A00F9DA672018E86DAE286FF69BC9964" italics="true" pageId="null" pageNumber="552">9 Arten, die im Mittelmeergebiet und Westasien verbreitet sind</emphasis>
(1 Art in 
<normalizedToken id="9A042CE5C21919259F6463D2C0D10EC4" originalValue="Südamerika" pageId="null" pageNumber="552">Suedamerika</normalizedToken>
). 
<emphasis id="7326088333A3E9E759C0D9EDC2855C9E" italics="true" pageId="null" pageNumber="552">Chromosomengrundzahl</emphasis>
n = 7. 
<normalizedToken id="18C7B529DC351FDC48B20D5E1A466B1D" originalValue="Über" pageId="null" pageNumber="552">Ueber</normalizedToken>
die 
<normalizedToken id="1E4624F1687A75AE6C98CCCFE6F8E551" originalValue="europäischen" pageId="null" pageNumber="552">europaeischen</normalizedToken>
Arten geben Griesinger und Klinkowski (1939) pflanzengeographische und zytologische Angaben und 
<normalizedToken id="4C092DD2A4F82917F2A4AC93C31800A1" originalValue="erwähnen" pageId="null" pageNumber="552">erwaehnen</normalizedToken>
die Bastarde zwischen den Arten.
</paragraph>
</subSubSection>
