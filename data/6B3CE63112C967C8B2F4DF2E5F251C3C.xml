<subSubSection id="20086A4A8D29624F7FE820413F589F56" pageId="null" pageNumber="280" type="description">
<paragraph id="8E8C7E16E1D543CA8F8A529F8521BCAD" pageId="null" pageNumber="280">
1 
<normalizedToken id="9DA06C376216210018F97E61E3665EF3" originalValue="jährig" pageId="null" pageNumber="280">jaehrig</normalizedToken>
, mit 
<normalizedToken id="B018C92DC3016CF09544DD8B4556DC03" originalValue="dünner" pageId="null" pageNumber="280">duenner</normalizedToken>
Hauptwurzel; 5-2 5 cm hoch. Stengel aufsteigend, vom Grunde an verzweigt, 4kantig, meist mit 
<normalizedToken id="3CD6CBA279872F2E2FA5F7BCFE24376D" originalValue="zurückgekrümmten" pageId="null" pageNumber="280">zurueckgekruemmten</normalizedToken>
, seltener abstehenden, 0,4-0,7 mm langen Haaren. Mittlere und obere 
<normalizedToken id="6395B12FC39B428871B04BC159028BE6" originalValue="Blätter" pageId="null" pageNumber="280">Blaetter</normalizedToken>
zu 6 im Quirl, 0,4-1,5 cm lang, lanzettlich, 3-6mal so lang wie breit, mit kurzer Spitze, 1nervig (zudem mit verdicktem Rand), am Rand und unterseits auf dem Mittelnerv gelegentlich auch oberseits mit abstehenden Haaren. 
<normalizedToken id="612AE0E88AAF361B87E161D01DB14AC0" originalValue="Blüten" pageId="null" pageNumber="280">Blueten</normalizedToken>
meist ⚥, 
<emphasis id="D6CB4711B445402162CBD603EFF441B9" italics="true" pageId="null" pageNumber="280">
in 
<normalizedToken id="E367AFA7928DA5D1787598BE21824FC4" originalValue="wenigblütigen" pageId="null" pageNumber="280">wenigbluetigen</normalizedToken>
, kopfartigen 
<normalizedToken id="411C378AAC45381710A9D90E27587186" originalValue="Blutenständen" pageId="null" pageNumber="280">Blutenstaenden</normalizedToken>
am Ende der Zweige, die 
<normalizedToken id="F444467D0061090AD648CB45648056B5" originalValue="sternförmig" pageId="null" pageNumber="280">sternfoermig</normalizedToken>
von 8
</emphasis>
- 
<emphasis id="9CC1E6593F274A58DEEBC44765A2018C" italics="true" pageId="null" pageNumber="280">
1 0 
<normalizedToken id="2573B6142FBF59157952F05DFA050A05" originalValue="Hüllblättern" pageId="null" pageNumber="280">Huellblaettern</normalizedToken>
umgeben sind. 
<normalizedToken id="60F829759E7757AADA764281CFD0FE91" originalValue="Hüllblätter" pageId="null" pageNumber="280">Huellblaetter</normalizedToken>
am Grunde verwachsen
</emphasis>
, die 
<normalizedToken id="1E2F40ACBD285AC23048176F5AA80471" originalValue="Blüten" pageId="null" pageNumber="280">Blueten</normalizedToken>
wenig 
<normalizedToken id="62206517D4861A7EB8586DF2D50649F9" originalValue="überragend" pageId="null" pageNumber="280">ueberragend</normalizedToken>
. 
<emphasis id="C031A2F182424D503802843E1DDE1557" italics="true" pageId="null" pageNumber="280">
Kelch aus 6 deutlich sichtbaren, meist etwa 0,5 mm langen, 3eckigen 
<normalizedToken id="3CD509B0854B4E3C9AE120470D733AA2" originalValue="Zähnen" pageId="null" pageNumber="280">Zaehnen</normalizedToken>
bestehend.
</emphasis>
Krone mit 2-3 mm langer 
<normalizedToken id="C223974A469B74638B8CC7689D6D8C57" originalValue="Kronröhre" pageId="null" pageNumber="280">Kronroehre</normalizedToken>
und 4 ausgebreiteten, 
<normalizedToken id="F0F5B4BDE2528E1C91F4AFD6E9926981" originalValue="kürzeren" pageId="null" pageNumber="280">kuerzeren</normalizedToken>
Zipfeln, lila (selten 
<normalizedToken id="0482F478720D45FBA1EA44949FB6E52F" originalValue="weiß" pageId="null" pageNumber="280">weiss</normalizedToken>
). 
<normalizedToken id="919D7587BEC6D4810B88AB04EEBF2303" originalValue="Teilfrüchte" pageId="null" pageNumber="280">Teilfruechte</normalizedToken>
3-4 mm hoch, 
<emphasis id="25F608AC4DA5456E6E9ED73C65D46CE4" italics="true" pageId="null" pageNumber="280">
bedeutend 
<normalizedToken id="2F1DF6BEF087C3D2A95D62BB7E1A3637" originalValue="höher" pageId="null" pageNumber="280">hoeher</normalizedToken>
als dick
</emphasis>
(im Gebiet nur bei dieser Art so!), 
<emphasis id="1C1C11F4A02DD469B9CF8723BA89B924" italics="true" pageId="null" pageNumber="280">
an der Spitze mit 6 
<normalizedToken id="5FDD8DFD6B5821DE30E7551662C51AB8" originalValue="Kelchzähnen" pageId="null" pageNumber="280">Kelchzaehnen</normalizedToken>
</emphasis>
, anliegend kurzhaarig. - 
<normalizedToken id="D5C6F50DB33F82F425327D67DF060AFC" originalValue="Blüte" pageId="null" pageNumber="280">Bluete</normalizedToken>
: 
<normalizedToken id="0D337232C3242EC38A70C924A471A658" originalValue="Später" pageId="null" pageNumber="280">Spaeter</normalizedToken>
<normalizedToken id="2BB193A30DF7A77872A3AB3F7280F5C0" originalValue="Frühling" pageId="null" pageNumber="280">Fruehling</normalizedToken>
bis Herbst.
</paragraph>
<paragraph id="693599E70250C05404632CD65B42CB96" pageId="null" pageNumber="280">
<emphasis id="A4A762EA722B47CCE16ED357B1A2E343" italics="true" pageId="null" pageNumber="280">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="3277027501284B0C4FD9060F820319D6" italics="true" pageId="null" pageNumber="280">22:</emphasis>
Material ohne Herkunftsangabe oder aus botanischen 
<normalizedToken id="D21F239DE9479C44B752E6D3AACA4E50" originalValue="Gärten" pageId="null" pageNumber="280">Gaerten</normalizedToken>
(Homeyer 1932 1936, Fagerlind 1934 1937, Poucques 1949), aus Kalifornien (Heiser und Whitaker 1948), aus Island (
<normalizedToken id="AAC16111AB5B4178EB5187D903B5F855" originalValue="Löve" pageId="null" pageNumber="280">Loeve</normalizedToken>
und 
<normalizedToken id="4A49DC68EDAEB5C34A34E6F3441ECC67" originalValue="Löve" pageId="null" pageNumber="280">Loeve</normalizedToken>
1956b), aus Nordafrika (Reese 1957), von den Balearen (Dahlgren et al. 1971).
</paragraph>
<paragraph id="E5B97ECBE08C7335F09C1CB9816CD4F0" pageId="null" pageNumber="280">
<emphasis id="849377AEFDB90FD51F87BC5F30763FBA" italics="true" pageId="null" pageNumber="280">Standort.</emphasis>
Kollin und montan, selten subalpin. 
<normalizedToken id="547FC061DCFB54617B0377328D80BF9E" originalValue="Mäßig" pageId="null" pageNumber="280">Maessig</normalizedToken>
trockene, kalkarme bis kalkhaltige 
<normalizedToken id="1DA1A5B6254717CAF66BB515301ACA78" originalValue="Böden" pageId="null" pageNumber="280">Boeden</normalizedToken>
. Getreidefelder, Brachen, Gartenrasen, 
<normalizedToken id="B3419B04573A56A01A9BF95F59172BC0" originalValue="Schuttplätze" pageId="null" pageNumber="280">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="47B7E43E4AE0F1D5D17A99FB3A4F5C4E" pageId="null" pageNumber="280">
<emphasis id="BDBDF6F6C001BC9A09D184B910FBD022" italics="true" pageId="null" pageNumber="280">Verbreitung.</emphasis>
<normalizedToken id="6C98CC6E4D6D0530554E8D146CC1F339" originalValue="Ursprünglich" pageId="null" pageNumber="280">Urspruenglich</normalizedToken>
<emphasis id="4FBDC118510991001A2602FF66D1DED0" italics="true" pageId="null" pageNumber="280">mediterrane Pflanze</emphasis>
, heute 
<normalizedToken id="45DC08313F85184310B9215CDDB5E894" originalValue="außerhalb" pageId="null" pageNumber="280">ausserhalb</normalizedToken>
tropischer und arktischer Gebiete 
<normalizedToken id="D6822C4CD809AA178D23394303930DA6" originalValue="über" pageId="null" pageNumber="280">ueber</normalizedToken>
die ganze Erde verbreitet. - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="F0B28FF54D4805CF83B05D42AE1CE36F" originalValue="häufig" pageId="null" pageNumber="280">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
