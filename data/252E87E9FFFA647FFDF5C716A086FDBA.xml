<emphasis id="9FF3EAEDFFF9647FFF20C05FA036FE58" bold="true" box="[189,304,377,403]" pageId="18" pageNumber="29">Remarks</emphasis>
</heading>
</paragraph>
<paragraph id="AD3836FFFFF9647FFF20C081A086FDBA" blockId="18.[188,1399,423,625]" pageId="18" pageNumber="29">
The name 
<taxonomicName id="6A874D7CFFF9647FFEA6C08EA3EAFE0A" authority="Golikov, 1980" authorityName="Golikov" authorityYear="1980" box="[315,748,423,449]" class="Gastropoda" family="Buccinidae" genus="Buccinum" kingdom="Animalia" order="Neogastropoda" pageId="18" pageNumber="29" phylum="Mollusca" rank="species" species="coronatum">
<emphasis id="9FF3EAEDFFF9647FFEA6C08EA33FFE0A" box="[315,569,424,449]" italics="true" pageId="18" pageNumber="29">Buccinum coronatum</emphasis>
<bibRefCitation id="C9164B0EFFF9647FFDDEC081A3EAFE0A" author="Golikov A. N." box="[579,748,423,449]" pageId="18" pageNumber="29" pagination="2" refId="ref11612" refString="Golikov A. N. 1980. Molluscs Buccininae of the World Ocean. Fauna of USSR, Mollusks 5 (2). Nauka Publ., Leningrad." type="journal article" year="1980">Golikov, 1980</bibRefCitation>
</taxonomicName>
is a junior primary homonym of 
<taxonomicName id="6A874D7CFFF9647FFBE5C08EA079FE2F" authority="Bruguiere, 1789" authorityName="Bruguiere" authorityYear="1789" class="Gastropoda" family="Buccinidae" genus="Buccinum" kingdom="Animalia" order="Neogastropoda" pageId="18" pageNumber="29" phylum="Mollusca" rank="species" species="coronatum">
<emphasis id="9FF3EAEDFFF9647FFBE5C08EA470FE0A" box="[1144,1398,424,449]" italics="true" pageId="18" pageNumber="29">Buccinum coronatum</emphasis>
Bruguière, 1789
</taxonomicName>
[
<emphasis id="9FF3EAEDFFF9647FFE0CC0ECA0A4FE2F" bold="true" box="[401,418,458,484]" pageId="18" pageNumber="29">=</emphasis>
<taxonomicName id="6A874D7CFFF9647FFE37C0EDA284FE2E" authority="(Bruguiere, 1789)" baseAuthorityName="Bruguiere" baseAuthorityYear="1789" box="[426,898,458,485]" class="Gastropoda" family="Nassariidae" genus="Nassarius" kingdom="Animalia" order="Neogastropoda" pageId="18" pageNumber="29" phylum="Mollusca" rank="species" species="coronatus">
<emphasis id="9FF3EAEDFFF9647FFE37C0EDA398FE2F" box="[426,670,459,484]" italics="true" pageId="18" pageNumber="29">Nassarius coronatus</emphasis>
(Bruguière, 1789)
</taxonomicName>
], 
<taxonomicName id="6A874D7CFFF9647FFC0AC0EDA1FFFDC3" authority="Quoy &amp; Gaimard, 1833" authorityName="Quoy &amp; Gaimard" authorityYear="1833" class="Gastropoda" family="Buccinidae" genus="Buccinum" kingdom="Animalia" order="Neogastropoda" pageId="18" pageNumber="29" phylum="Mollusca" rank="species" species="coronatum">
<emphasis id="9FF3EAEDFFF9647FFC0AC0EDA593FE2F" box="[919,1173,459,484]" italics="true" pageId="18" pageNumber="29">Buccinum coronatum</emphasis>
Quoy &amp; Gaimard, 1833
</taxonomicName>
[= 
<taxonomicName id="6A874D7CFFF9647FFEBCC0C8A3E5FDC3" authority="(A. Adams, 1852)" baseAuthorityName="A. Adams" baseAuthorityYear="1852" box="[289,739,493,520]" class="Gastropoda" family="Nassariidae" genus="Nassarius" kingdom="Animalia" order="Neogastropoda" pageId="18" pageNumber="29" phylum="Mollusca" rank="species" species="distortus">
<emphasis id="9FF3EAEDFFF9647FFEBCC0C8A301FDCC" box="[289,519,493,519]" italics="true" pageId="18" pageNumber="29">Nassarius distortus</emphasis>
(A. Adams, 1852)
</taxonomicName>
