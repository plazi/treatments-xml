<subSubSection id="FAC5A19FF35FCA24520B03F5F1195703" pageId="null" pageNumber="697" type="description">
<paragraph id="D54C31E1378EC7C8A0C5B6355AE8EC56" pageId="null" pageNumber="697">
Unterscheidet sich von der Gattung 
<taxonomicName id="E8875BFC10001ECA0ED678B9328F4F7C" class="Magnoliopsida" family="Rhamnaceae" genus="Rhamnus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="697" phylum="Tracheophyta" rank="genus">
<emphasis id="33BECFE5118F67B7252EAB61289AC5A5" italics="true" pageId="null" pageNumber="697">Rhamnus</emphasis>
</taxonomicName>
durch folgende Merkmale: 
<emphasis id="7F5DAFC4EB70F575F2C70AF74F4A1638" italics="true" pageId="null" pageNumber="697">Haare mehrzellig; keine Knospensckuppen vorhanden;</emphasis>
<normalizedToken id="629B38B939340FFAB3C07A9A6B276CB0" originalValue="Blätter" pageId="null" pageNumber="697">Blaetter</normalizedToken>
und Zweige stets 
<normalizedToken id="3433A96B479A12FFF4887B6A36A2A0AB" originalValue="wechselständig" pageId="null" pageNumber="697">wechselstaendig</normalizedToken>
; 
<emphasis id="EC0C26F05D18C7336BB73B4FFF83EFC5" italics="true" pageId="null" pageNumber="697">
<normalizedToken id="0F0F13037C70E88ECC52B9C57DD95504" originalValue="Blüten" pageId="null" pageNumber="697">Blueten</normalizedToken>
stets
</emphasis>
⚥, 
<emphasis id="F97D009C64B5B0C081849FF725A491F9" italics="true" pageId="null" pageNumber="697">
5 
<normalizedToken id="3F833657C78568F09C220FB67D81ADD4" originalValue="zählig" pageId="null" pageNumber="697">zaehlig</normalizedToken>
; Samen ohne Furche.
</emphasis>
</paragraph>
<paragraph id="66EA783E4B6D7A343977DAFE35F32710" pageId="null" pageNumber="697">
Die Gattung 
<emphasis id="F013A4EEF5B8307D52244C0ED635547A" italics="true" pageId="null" pageNumber="697">Frangala</emphasis>
besitzt 
<emphasis id="7FA18C1C041C67E12F2AE464D4907AAC" italics="true" pageId="null" pageNumber="697">etwa 20 Arten</emphasis>
und hat die gleiche Verbreitung wie die Gattung 
<taxonomicName id="FD8B46F613FCA87CBA513F04D9ADEB50" class="Magnoliopsida" family="Rhamnaceae" genus="Rhamnus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="697" phylum="Tracheophyta" rank="genus">
<emphasis id="A96E44F7B248C95A7E9590EEBF6B1BB8" italics="true" pageId="null" pageNumber="697">Rhamnus</emphasis>
</taxonomicName>
, jedoch 
<emphasis id="7752320B14250F0E744018A2951A009E" italics="true" pageId="null" pageNumber="697">mit Hauptverbreitung im pazifischen Nordamerika und in Ostasien.</emphasis>
Die Gattung ist 
<normalizedToken id="834BD52EC5DEDF03A3DD2C0C94322522" originalValue="früher" pageId="null" pageNumber="697">frueher</normalizedToken>
mit 
<taxonomicName id="0DA408E792D98C9B422F7A5779E1E351" class="Magnoliopsida" family="Rhamnaceae" genus="Rhamnus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="697" phylum="Tracheophyta" rank="genus">
<emphasis id="3C75F939C68879A126D185562B10DCD1" italics="true" pageId="null" pageNumber="697">Rhamnus</emphasis>
</taxonomicName>
vereinigt worden.
</paragraph>
<paragraph id="D2D0E4F62B8DBFC066394CA8E1A75275" pageId="null" pageNumber="697">
