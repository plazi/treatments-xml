<subSubSection id="7BEC6E6867CF3EC04D91575E1A8B5596" pageId="null" pageNumber="42" type="description">
<paragraph id="CF95A6832B532EB3C362C8478E946287" pageId="null" pageNumber="42">
<normalizedToken id="F9920B8EA0AAB5003B97B31BE2CE19C3" originalValue="Kräuter" pageId="null" pageNumber="42">Kraeuter</normalizedToken>
, am Grunde meist verholzt. 
<normalizedToken id="3388A22765CB8F85D1C1141DCFF2CDE4" originalValue="Blüten" pageId="null" pageNumber="42">Blueten</normalizedToken>
in Dolden oder einzeln, in Blattachseln oder 
<normalizedToken id="9261F8950081030CF0EA2A460473F9C6" originalValue="endständig" pageId="null" pageNumber="42">endstaendig</normalizedToken>
. 
<normalizedToken id="79DFB4D69C9E89B6E00F07B0CCCDC2B6" originalValue="Kelchblätter" pageId="null" pageNumber="42">Kelchblaetter</normalizedToken>
schmal und spitz, 
<emphasis id="98E53E0673CFB5B40FBA642B7F1C714E" italics="true" pageId="null" pageNumber="42">
<normalizedToken id="F6ECD252F68BE3388DA5B3487EEFF924" originalValue="rückwärts" pageId="null" pageNumber="42">rueckwaerts</normalizedToken>
gerichtet
</emphasis>
. Krone fast bis zum Grunde geteilt, 
<normalizedToken id="7E599CD682D100D3DAC9A54E77CCD797" originalValue="schalenförmig" pageId="null" pageNumber="42">schalenfoermig</normalizedToken>
oder die 
<emphasis id="7A82A90792B1A9ADDF58E8EF1DF38A41" italics="true" pageId="null" pageNumber="42">
<normalizedToken id="B3ACE387D1DD0954DF6E39A95E3C9DF8" originalValue="Kronblätter" pageId="null" pageNumber="42">Kronblaetter</normalizedToken>
<normalizedToken id="2E54B28B76BD850622818526672ADF58" originalValue="rückwärts" pageId="null" pageNumber="42">rueckwaerts</normalizedToken>
gerichtet
</emphasis>
. 
<normalizedToken id="167A123190BBF2B576DB38165E8F8632" originalValue="Anhängsel" pageId="null" pageNumber="42">Anhaengsel</normalizedToken>
am Gynostegium kronblattartig, oft 
<normalizedToken id="0ACF8B6EBABF3A2DD9B09141E8554D7C" originalValue="trichterförmig" pageId="null" pageNumber="42">trichterfoermig</normalizedToken>
, 
<emphasis id="CEF9CE6BC623991353892FDDDC51497E" italics="true" pageId="null" pageNumber="42">
mit 
<normalizedToken id="6756337E7F8466AF881EF062AA2FF660" originalValue="einwärts" pageId="null" pageNumber="42">einwaerts</normalizedToken>
gebogenem Sporn
</emphasis>
.
</paragraph>
<paragraph id="C3DAE81CA44120B48FE29161F3D36967" pageId="null" pageNumber="42">
Die Gattung 
<taxonomicName id="6B0917637C8BBE6E70CA881ED7D1C76A" class="Magnoliopsida" family="Apocynaceae" genus="Asclepias" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="42" phylum="Tracheophyta" rank="genus">
<emphasis id="0920F02B5355C41CF31BE2F63ECE2363" italics="true" pageId="null" pageNumber="42">Asclepias</emphasis>
</taxonomicName>
<normalizedToken id="62EC04A7328D54529E4C15C33FE4B014" originalValue="umfaßt" pageId="null" pageNumber="42">umfasst</normalizedToken>
<emphasis id="EEE62219DF6589A2613F12D85969C033" italics="true" pageId="null" pageNumber="42">
ca. 100 Arten, die alle 
<normalizedToken id="428E691D0F9CB701C862213FCCAC688B" originalValue="ursprünglich" pageId="null" pageNumber="42">urspruenglich</normalizedToken>
in Amerika vorkommen. Chromosomengrundzahl
</emphasis>
n = 11.
</paragraph>
