<taxonomicName id="8E6D9B3D42DCE554E2F17413B6CBFDEF" authority="Br." authorityName="Br." class="Magnoliopsida" family="Brassicaceae" genus="Draba" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="164" phylum="Tracheophyta" rank="species" species="ladina">
<pageBreakToken id="C04C5DC8C8805CF9A9F9144E1B01E786" pageId="null" pageNumber="164" start="start">Draba</pageBreakToken>
<normalizedToken id="E36FC49DFDE5F5AD4E860159F5D435AF" originalValue="ladína" pageId="null" pageNumber="164">ladina</normalizedToken>
Br.
