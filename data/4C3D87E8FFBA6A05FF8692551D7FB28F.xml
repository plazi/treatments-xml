<paragraph id="C42B36FEFFBA6A05FD2593B21A36BD00" blockId="65.[729,1323,1164,1586]" pageId="65" pageNumber="823">
<emphasis id="F6E0EAECFFBA6A05FD2593B21D89BD3E" bold="true" box="[729,905,1515,1548]" pageId="65" pageNumber="823">Distribution.</emphasis>
<collectingCountry id="BC83766EFFBA6A05FC6093B21A02BD3E" box="[924,1026,1515,1548]" name="Guinea-Bissau" pageId="65" pageNumber="823">Guinea</collectingCountry>
