<subSubSection id="24CB1080FFADFFF3FAB2AEDF8302FDD3" pageId="25" pageNumber="26" type="distribution">
<paragraph id="6C6E430BFFADFFF3FAB2AEDF8302FDD3" blockId="25.[151,1437,397,675]" pageId="25" pageNumber="26">
<emphasis id="5EA59F19FFADFFF3FAB2AEDF8104FE2F" bold="true" box="[199,353,433,459]" pageId="25" pageNumber="26">Distribution.</emphasis>
Western Atlantic— 
<collectingCountry id="14C6039BFFADFFF3F833AEDF82CBFE2F" box="[582,686,433,459]" name="Bermuda" pageId="25" pageNumber="26">Bermuda</collectingCountry>
, 
<collectingCountry id="14C6039BFFADFFF3F8C9AEDF8297FE2F" box="[700,754,433,459]" name="United States of America" pageId="25" pageNumber="26">USA</collectingCountry>
(
<collectingRegion id="AE158DE9FFADFFF3F971AEDF83D4FE2F" box="[772,945,433,459]" country="United States of America" name="North Carolina" pageId="25" pageNumber="26">North Carolina</collectingRegion>
to Florida), Gulf of Mexico, 
<collectingCountry id="14C6039BFFADFFF3FF78AEDC85FDFE2F" box="[1293,1432,433,460]" name="Puerto Rico" pageId="25" pageNumber="26">Puerto Rico</collectingCountry>
, Antilles, 
<collectingCountry id="14C6039BFFADFFF3FA89AEBB8117FE0B" box="[252,370,469,495]" name="Venezuela" pageId="25" pageNumber="26">Venezuela</collectingCountry>
, and 
<collectingCountry id="14C6039BFFADFFF3FBDEAEBB818AFE0B" box="[427,495,469,495]" name="Brazil" pageId="25" pageNumber="26">Brazil</collectingCountry>
(
<collectingRegion id="AE158DE9FFADFFF3FB88AEBB8237FE0B" box="[509,594,469,495]" country="Brazil" name="Amapa" pageId="25" pageNumber="26">Amapá</collectingRegion>
