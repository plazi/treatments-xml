<bibRefCitation id="08403EFAFFADFFF3FB49AD7381DCFDD3" author="Melo, G. A. S." box="[316,441,541,567]" pageId="25" pageNumber="26" refId="ref69664" refString="Melo, G. A. S. (1999) Manual de identificacao dos Crustacea Decapoda do litoral brasileiro: Anomura, Thalassinidea, Palinuridea, Astacidea. Ed. Pleidae, Sao Paulo, 551 pp." type="book" year="1999">Melo 1999</bibRefCitation>
; 
<bibRefCitation id="08403EFAFFADFFF3FBB0AD7382F3FDD3" author="Coelho, P. A. &amp; Almeida, A. O. &amp; Bezerra, L. E. A. &amp; Souza-Filho J. F." box="[453,662,541,567]" pageId="25" pageNumber="26" pagination="1 - 16" refId="ref58699" refString="Coelho, P. A., Almeida, A. O., Bezerra, L. E. A. &amp; Souza-Filho J. F. (2007) An updated checklist of decapod crustaceans (infraorders Astacidea, Thalassinidea, Polychelida, Palinura, and Anomura) from the northern and northeastern Brazilian coast. Zootaxa, 1519 (1), 1 - 16. https: // doi. org / 10.11646 / zootaxa. 1519.1.1" type="journal article" year="2007">
Coelho 
<emphasis id="5EA59F19FFADFFF3F869AD708230FDD3" box="[540,597,541,567]" italics="true" pageId="25" pageNumber="26">et al.</emphasis>
2007
</bibRefCitation>
; 
<bibRefCitation id="08403EFAFFADFFF3F8D7AD73833EFDD3" author="Dall'Occo, P. L." box="[674,859,541,567]" pageId="25" pageNumber="26" refId="ref60273" refString="Dall'Occo, P. L. (2010) Taxonomia e Distribuicao das Lagostas (Crustacea: Decapoda: Achelata e Polychelida) no Oceano Atlantico. PhD Thesis (unpublished), Universidade Estadual Paulista (Unesp), Rio Claro, 432 pp." type="book" year="2010">Dall’Occo 2010</bibRefCitation>
