<subSubSection id="24CB1080FFADFFF3FAB2AD2F8085FD47" pageId="25" pageNumber="26" type="discussion">
<paragraph id="6C6E430BFFADFFF3FAB2AD2F8085FD47" blockId="25.[151,1437,397,675]" pageId="25" pageNumber="26">
<emphasis id="5EA59F19FFADFFF3FAB2AD2F815EFDBF" bold="true" box="[199,315,577,603]" pageId="25" pageNumber="26">Remarks.</emphasis>
Previous records from the coast of 
<collectingRegion id="AE158DE9FFADFFF3F8B7AD2F8357FDBF" box="[706,818,577,603]" country="Brazil" name="Sao Paulo" pageId="25" pageNumber="26">São Paulo</collectingRegion>
include Santos region (
<bibRefCitation id="08403EFAFFADFFF3FE40AD2F84AAFDBF" author="Tavares, M." box="[1077,1231,577,603]" pageId="25" pageNumber="26" pagination="716 - 724" refId="ref80026" refString="Tavares, M. (1997) Scyllarus ramosae, new species, from Brazilian continental slope, with notes on congeners occurring in the area (Decapoda: Scyllaridae). Journal of Crustacean Biology, 17 (4), 716 - 724. https: // doi. org / 10.2307 / 1549374 https: // doi. org / 10.1163 / 193724097 X 00143" type="journal article" year="1997">Tavares 1997</bibRefCitation>
; 
<bibRefCitation id="08403EFAFFADFFF3FEACAD2F85F4FDBF" author="Dall'Occo, P. L." box="[1241,1425,577,603]" pageId="25" pageNumber="26" refId="ref60273" refString="Dall'Occo, P. L. (2010) Taxonomia e Distribuicao das Lagostas (Crustacea: Decapoda: Achelata e Polychelida) no Oceano Atlantico. PhD Thesis (unpublished), Universidade Estadual Paulista (Unesp), Rio Claro, 432 pp." type="book" year="2010">Dall’Occo 2010</bibRefCitation>
). It is a species found in shallow waters up to 
<quantity id="AB29EEEEFFADFFF3F8E1AD0B82AAFD64" box="[660,719,613,640]" metricMagnitude="1" metricUnit="m" metricValue="7.0" pageId="25" pageNumber="26" unit="m" value="70.0">70 m</quantity>
deep (
<bibRefCitation id="08403EFAFFADFFF3F96EAD0B83D2FD64" author="Schmitt, W. L." box="[795,951,613,640]" pageId="25" pageNumber="26" pagination="125 - 227" refId="ref77660" refString="Schmitt, W. L. (1935) Crustacea Macrura and Anomura of Porto Rico and the Virgin Islands. New York Academy of Sciences, 15 (2), 125 - 227." type="journal article" year="1935">Schmitt 1935</bibRefCitation>
; 
<bibRefCitation id="08403EFAFFADFFF3F9B0AD0B8576FD64" author="Coelho, P. A. &amp; Ramos-Porto, M." box="[965,1299,613,640]" pageId="25" pageNumber="26" pagination="113 - 127" refId="ref58590" refString="Coelho, P. A. &amp; Ramos-Porto, M. (1994 / 1995) Distribuicao ecologica dos crustaceos decapodos marinhos do nordeste do Brasil. Trabalhos do Instituto Oceanografico da Universidade Federal de Pernambuco, 23, 113 - 127. https: // doi. org / 10.5914 / tropocean. v 23 i 1.2682" type="journal article" year="1994">Coelho &amp; Ramos-Porto 1994</bibRefCitation>
-1995; 
<bibRefCitation id="08403EFAFFADFFF3FF14AD0B80B6FD47" author="Melo, G. A. S." pageId="25" pageNumber="26" refId="ref69664" refString="Melo, G. A. S. (1999) Manual de identificacao dos Crustacea Decapoda do litoral brasileiro: Anomura, Thalassinidea, Palinuridea, Astacidea. Ed. Pleidae, Sao Paulo, 551 pp." type="book" year="1999">Melo 1999</bibRefCitation>
).
</paragraph>
