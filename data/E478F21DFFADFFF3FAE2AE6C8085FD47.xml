<collectingRegion id="AE158DE9FFADFFF3F8EEAEBB8297FE0B" box="[667,754,469,495]" country="Brazil" name="Paraiba" pageId="25" pageNumber="26">Paraíba</collectingRegion>
, 
<collectingRegion id="AE158DE9FFADFFF3F889AEBB83EEFE0B" box="[764,907,469,495]" country="Brazil" name="Pernambuco" pageId="25" pageNumber="26">Pernambuco</collectingRegion>
, 
<collectingRegion id="AE158DE9FFADFFF3F9E6AEBB8397FE0B" box="[915,1010,469,495]" country="Brazil" name="Alagoas" pageId="25" pageNumber="26">Alagoas</collectingRegion>
, 
<collectingRegion id="AE158DE9FFADFFF3F989AEBB8425FE0B" box="[1020,1088,469,495]" country="Brazil" name="Bahia" pageId="25" pageNumber="26">Bahia</collectingRegion>
, 
<collectingRegion id="AE158DE9FFADFFF3FE3FAEBB8489FE0B" box="[1098,1260,469,495]" country="Brazil" name="Espirito Santo" pageId="25" pageNumber="26">Espírito Santo</collectingRegion>
, 
<collectingRegion id="AE158DE9FFADFFF3FE83AEBB85FDFE0B" box="[1270,1432,469,495]" country="Brazil" name="Rio de Janeiro" pageId="25" pageNumber="26">Rio de Janeiro</collectingRegion>
, 
<collectingRegion id="AE158DE9FFADFFF3FAE2AE97816FFDF0" box="[151,266,505,532]" country="Brazil" name="Sao Paulo" pageId="25" pageNumber="26">São Paulo</collectingRegion>
) (Verril 1922; 
<bibRefCitation id="08403EFAFFADFFF3FBD8AE978223FDF0" author="Schmitt, W. L." box="[429,582,505,532]" pageId="25" pageNumber="26" pagination="125 - 227" refId="ref77660" refString="Schmitt, W. L. (1935) Crustacea Macrura and Anomura of Porto Rico and the Virgin Islands. New York Academy of Sciences, 15 (2), 125 - 227." type="journal article" year="1935">Schmitt 1935</bibRefCitation>
; 
<bibRefCitation id="08403EFAFFADFFF3F824AE9482BCFDF7" author="Rouse, W." box="[593,729,505,532]" pageId="25" pageNumber="26" pagination="127 - 152" refId="ref76647" refString="Rouse, W. (1970) Littoral Crustacea from Southwest Florida. Quarterly Journal of the Florida Academy of Sciences, 32 (2), 127 - 152." type="journal article" year="1970">Rouse 1970</bibRefCitation>
; 
<bibRefCitation id="08403EFAFFADFFF3F896AE9783D9FDF7" author="Abele, L. G. &amp; Kim, W." box="[739,956,505,531]" pageId="25" pageNumber="26" pagination="1 - 760" refId="ref51541" refString="Abele, L. G. &amp; Kim, W. (1986) An illustrated guide to the marine decapod crustaceans of Florida. Florida Department of Environmental Regulation, Technical Series, 8 (1 - 2), 1 - 760." type="journal article" year="1986">Abele &amp; Kim 1986</bibRefCitation>
; 
<bibRefCitation id="08403EFAFFADFFF3F9B2AE978574FDF0" author="Coelho, P. A. &amp; Ramos-Porto, M." box="[967,1297,505,532]" pageId="25" pageNumber="26" pagination="113 - 127" refId="ref58590" refString="Coelho, P. A. &amp; Ramos-Porto, M. (1994 / 1995) Distribuicao ecologica dos crustaceos decapodos marinhos do nordeste do Brasil. Trabalhos do Instituto Oceanografico da Universidade Federal de Pernambuco, 23, 113 - 127. https: // doi. org / 10.5914 / tropocean. v 23 i 1.2682" type="journal article" year="1994">Coelho &amp; Ramos-Porto 1994</bibRefCitation>
-1995, 1998; 
<bibRefCitation id="08403EFAFFADFFF3FAE2AD708155FDD3" author="Tavares, M." box="[151,304,541,568]" pageId="25" pageNumber="26" pagination="716 - 724" refId="ref80026" refString="Tavares, M. (1997) Scyllarus ramosae, new species, from Brazilian continental slope, with notes on congeners occurring in the area (Decapoda: Scyllaridae). Journal of Crustacean Biology, 17 (4), 716 - 724. https: // doi. org / 10.2307 / 1549374 https: // doi. org / 10.1163 / 193724097 X 00143" type="journal article" year="1997">Tavares 1997</bibRefCitation>
