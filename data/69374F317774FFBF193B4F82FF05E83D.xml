<emphasis id="D3EA22357774FFBF19754C3AFDF3E81D" box="[273,537,1837,1861]" italics="true" pageId="12" pageNumber="49">Terebratula Ehningensis</emphasis>
<quantity id="266653C27774FFBF1A474C3AFDB2E81D" box="[547,600,1837,1861]" metricMagnitude="1" metricUnit="m" metricValue="4.71678" pageId="12" pageNumber="49" unit="in" value="1857.0">1857</quantity>
</taxonomicName>
