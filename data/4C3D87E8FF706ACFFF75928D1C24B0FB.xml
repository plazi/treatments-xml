<subSubSection id="8C8E6575FF706ACFFD11938A1AF0BD87" pageId="139" pageNumber="899" type="discussion">
<paragraph id="C42B36FEFF706ACFFD11938A1AF0BD87" blockId="139.[747,1340,1368,1796]" pageId="139" pageNumber="899">
<collectingRegion id="0650F81CFF706ACFFD11938A1D1CBEC2" box="[749,796,1491,1520]" country="South Sudan" name="Lakes" pageId="139" pageNumber="899">See</collectingRegion>
<taxonomicName id="03944D7DFF706ACFFCD7938A1DDBBEC2" authorityName="Horsfield" authorityYear="1824" box="[811,987,1491,1520]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="139" pageNumber="899" phylum="Chordata" rank="species" species="hardwickii">K. hardwickii</taxonomicName>
and 
<taxonomicName id="03944D7DFF706ACFFBD6938A1AACBEC2" box="[1066,1196,1491,1520]" class="Mammalia" family="Vespertilionidae" genus="Kerivoula" kingdom="Animalia" order="Chiroptera" pageId="139" pageNumber="899" phylum="Chordata" rank="species" species="titania">K. titania</taxonomicName>
. 
<taxonomicName id="03944D7DFF706ACFFB3C938A1D4BBD25" authorityName="G. S. Miller" authorityYear="1898" class="Mammalia" family="Vespertilionidae" genus="Kerivoula" kingdom="Animalia" order="Chiroptera" pageId="139" pageNumber="899" phylum="Chordata" rank="species" species="minuta">Kerivoula minuta</taxonomicName>
might be related to 
<taxonomicName id="03944D7DFF706ACFFB6993AF1B3CBD25" box="[1173,1340,1526,1559]" class="Mammalia" family="Vespertilionidae" genus="Kerivoula" kingdom="Animalia" order="Chiroptera" pageId="139" pageNumber="899" phylum="Chordata" rank="species" species="krauensis">K. krauensis</taxonomicName>
and 
<taxonomicName id="03944D7DFF706ACFFCD090471DD9BD0D" authorityName="Hill &amp; Francis" authorityYear="1984" box="[812,985,1566,1599]" class="Mammalia" family="Vespertilionidae" genus="Kerivoula" kingdom="Animalia" order="Chiroptera" pageId="139" pageNumber="899" phylum="Chordata" rank="species" species="intermedia">K. intermedia</taxonomicName>
(likely due to their identical karyotypes); it is often confused with 
<taxonomicName id="03944D7DFF706ACFFD1090341DA2BDBC" authorityName="Hill &amp; Francis" authorityYear="1984" box="[748,930,1645,1678]" class="Mammalia" family="Vespertilionidae" genus="Kerivoula" kingdom="Animalia" order="Chiroptera" pageId="139" pageNumber="899" phylum="Chordata" rank="species" species="intermedia">K. intermedia</taxonomicName>
, and some authors suggest that they are conspecific. Monotypic.
</paragraph>
</subSubSection>
