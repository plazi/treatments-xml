<subSubSection id="C34472A7FFF2682F45CA376EB84FFD45" pageId="7" pageNumber="290" type="reference_group">
<paragraph id="8BE1212CFFF2682F45CA376EB84FFD45" blockId="7.[151,1436,613,712]" pageId="7" pageNumber="290">
<taxonomicName id="4C5E5AAFFFF2682F45CA376EBB62FDF2" authority="Cartwright 2010" authorityName="Cartwright" authorityYear="2010" box="[151,281,613,639]" class="Insecta" family="Ecnomidae" genus="Wellsomina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trichoptera" pageId="7" pageNumber="290" phylum="Arthropoda" rank="genus">
<emphasis id="B92AFD3EFFF2682F45CA376EBB62FDF2" box="[151,281,613,639]" italics="true" pageId="7" pageNumber="290">Wellsomina</emphasis>
</taxonomicName>
is endemic to northern 
<collectingCountry id="F34961BCFFF2682F4746376EB8FEFDF2" box="[539,645,613,639]" name="Australia" pageId="7" pageNumber="290">Australia</collectingCountry>
, presently represented by 12 described species (
<bibRefCitation id="EFCF5CDDFFF2682F41CB376EBF2EFDF2" author="Cartwright, D. I." box="[1174,1365,613,639]" pageId="7" pageNumber="290" pagination="1 - 21" refId="ref14689" refString="Cartwright, D. I. (2010) Descriptions of 2 new genera and 13 new species of caddisflies from Australia (Trichoptera: Ecnomidae). Zootaxa, 2415 (1), 1 - 21. https: // doi. org / 10.11646 / zootaxa. 2415.1.1" type="journal article" year="2010">Cartwright 2010</bibRefCitation>
). With one newly described species, 
<taxonomicName id="4C5E5AAFFFF2682F44B83781B816FD2E" authority="Cartwright &amp; Dostine, 2022" authorityName="Cartwright &amp; Dostine" authorityYear="2022" box="[485,621,649,675]" class="Insecta" family="Ecnomidae" genus="Wellsomina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trichoptera" pageId="7" pageNumber="290" phylum="Arthropoda" rank="species" species="tamoides" status="sp. nov.">
<emphasis id="B92AFD3EFFF2682F44B83781B816FD2E" box="[485,621,649,675]" italics="true" pageId="7" pageNumber="290">W. tamoides</emphasis>
</taxonomicName>
<emphasis id="B92AFD3EFFF2682F47283782B8B4FD2E" bold="true" box="[629,719,649,675]" pageId="7" pageNumber="290">
<taxonomicNameLabel id="A2194045FFF2682F47283782B8B4FD2E" box="[629,719,649,675]" pageId="7" pageNumber="290" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
, and a first NT record for 
<taxonomicName id="4C5E5AAFFFF2682F46A43781BF2AFD2E" authority="Cartwright 2010" authorityName="Cartwright" authorityYear="2010" box="[1017,1361,649,675]" class="Insecta" family="Ecnomidae" genus="Wellsomina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trichoptera" pageId="7" pageNumber="290" phylum="Arthropoda" rank="species" species="jalgoodoo">
<emphasis id="B92AFD3EFFF2682F46A43781BEF5FD2E" box="[1017,1166,649,675]" italics="true" pageId="7" pageNumber="290">W. jalgoodoo</emphasis>
<bibRefCitation id="EFCF5CDDFFF2682F41C83782BF2AFD2E" author="Cartwright, D. I." box="[1173,1361,649,675]" pageId="7" pageNumber="290" pagination="1 - 21" refId="ref14689" refString="Cartwright, D. I. (2010) Descriptions of 2 new genera and 13 new species of caddisflies from Australia (Trichoptera: Ecnomidae). Zootaxa, 2415 (1), 1 - 21. https: // doi. org / 10.11646 / zootaxa. 2415.1.1" type="journal article" year="2010">Cartwright 2010</bibRefCitation>
</taxonomicName>
, seven species are now recorded for the NT.
</paragraph>
</subSubSection>
