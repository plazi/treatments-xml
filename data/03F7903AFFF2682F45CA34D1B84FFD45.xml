<taxonomicName id="4C5E5AAFFFF2682F447E3714B8EBFDBA" authority="Cartwright 2010" authorityName="Cartwright" authorityYear="2010" box="[291,656,543,567]" class="Insecta" family="Ecnomidae" genus="Wellsomina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trichoptera" pageId="7" pageNumber="290" phylum="Arthropoda" rank="species" species="stuarti">
<emphasis id="B92AFD3EFFF2682F447E3714BB9BFDBA" box="[291,480,543,567]" italics="true" pageId="7" pageNumber="290">Wellsomina stuarti</emphasis>
<bibRefCitation id="EFCF5CDDFFF2682F44BA3714B8EBFDBA" author="Cartwright, D. I." box="[487,656,543,567]" pageId="7" pageNumber="290" pagination="1 - 21" refId="ref14689" refString="Cartwright, D. I. (2010) Descriptions of 2 new genera and 13 new species of caddisflies from Australia (Trichoptera: Ecnomidae). Zootaxa, 2415 (1), 1 - 21. https: // doi. org / 10.11646 / zootaxa. 2415.1.1" type="journal article" year="2010">Cartwright 2010</bibRefCitation>
