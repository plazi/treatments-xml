<collectingMunicipality id="803AAC95FFC6D6480388F71C1B163F10" box="[2498,2617,2288,2313]" pageId="16" pageNumber="707">Province</collectingMunicipality>
d’Antsiranana, 
<location id="653E6034FFC6D648028FF6FF19193F41" LSID="urn:lsid:plazi:treatment:E84887F9FFC6D6490FCCF80314203471:653E6034FFC6D648028FF6FF19193F41" country="Madagascar" longitude="49.171974" municipality="Province" name="Parc National de la Montagne" pageId="16" pageNumber="707">Parc National de la Montagne</location>
