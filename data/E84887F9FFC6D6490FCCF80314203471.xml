<locationDeviation id="71EC2FCDFFC6D6480286F6D318083F41" box="[2252,2343,2367,2392]" metricMagnitude="3" metricUnit="m" metricValue="5.5" pageId="16" pageNumber="707" unit="km" value="5.5">5.5 km</locationDeviation>
