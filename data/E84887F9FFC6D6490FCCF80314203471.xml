SWJoffreville (
<location id="653E6034FFC6D648004BF6D3197A3F66" LSID="urn:lsid:plazi:treatment:E84887F9FFC6D6490FCCF80314203471:653E6034FFC6D648004BF6D3197A3F66" country="Madagascar" longitude="49.171974" municipality="Province" name="Ambohitra" pageId="16" pageNumber="707">Ambohitra</location>
