<materialsCitation id="D0893CB2FFC6D64802B2F71C18CA3FBE" ID-GBIF-Occurrence="3747914335" country="Madagascar" location="Parc National de la Montagne" municipality="Province" pageId="16" pageNumber="707" specimenCount="1">
