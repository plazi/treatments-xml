<heading id="D09A81B1EFBF3ADBFF4DFA9DFE3AFAAC" bold="true" box="[136,511,1363,1390]" fontSize="11" level="1" pageId="238" pageNumber="239" reason="1">
<emphasis id="B919EACFEFBF3ADBFF4DFA9DFE3AFAAC" bold="true" box="[136,511,1363,1390]" pageId="238" pageNumber="239">
Genus 
<taxonomicName id="4C6D4D5EEFBF3ADBFF1AFA9DFE3AFAAC" authority="Canu, 1891" authorityName="Canu" authorityYear="1891" box="[223,511,1363,1390]" class="Maxillopoda" family="Notodelphyidae" genus="Bonnierilla" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="238" pageNumber="239" phylum="Arthropoda" rank="genus">
