<bibRefCitation id="EFFC4B2CEFBF3ADBFEB4FA9DFE3AFAAC" author="Canu, E." box="[369,511,1363,1389]" journalOrPublisher="Bulletin Scientifique de la France et de la Belgique" pageId="238" pageNumber="239" pagination="467 - 487" part="23" refId="ref327421" refString="Canu, E. (1891) Les Copepodes marins du Boulonnais. V. Les semiparasites. Bulletin Scientifique de la France et de la Belgique, 23, 467 - 487." title="Les Copepodes marins du Boulonnais. V. Les semiparasites" type="journal article" year="1891">Canu, 1891</bibRefCitation>
