Syn. 
<taxonomicName id="4C5A62FB3E433C689EDDFE4BF010FE1C" authority="Kaiser, 1893" authorityName="Kaiser" authorityYear="1893" box="[223,594,477,500]" class="Palaeacanthocephala" family="Echinorhynchidae" genus="Echinorhynchus" kingdom="Animalia" order="Echinorhynchida" pageId="9" pageNumber="204" phylum="Acanthocephala" rank="species" species="spinosus">
