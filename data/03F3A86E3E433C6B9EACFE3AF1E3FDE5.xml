<emphasis id="B92EC56A3E403C6B9FF8FEC5F073FE85" box="[506,561,336,362]" italics="true" pageId="10" pageNumber="205">Strix</emphasis>
</taxonomicName>
, 
<taxonomicName id="4C5A62FB3E403C6B9C42FEC5F0C8FE85" authorityName="Lacepede" authorityYear="1799" box="[576,650,336,362]" class="Globothalamea" family="Ammosphaeroidinidae" genus="Circus" kingdom="Chromista" order="Lituolida" pageId="10" pageNumber="205" phylum="Foraminifera" rank="genus">
