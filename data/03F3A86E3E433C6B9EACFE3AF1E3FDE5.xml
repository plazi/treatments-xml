Kaiser, 1893
</taxonomicName>
; 
<taxonomicName id="4C5A62FB3E433C689C5CFE4BF646FE1C" authority="Van Cleave, 1916" authorityName="Van Cleave" authorityYear="1916" box="[606,1028,477,500]" class="Palaeacanthocephala" family="Centrorhynchidae" genus="Centrorhynchus" kingdom="Animalia" order="Polymorphida" pageId="9" pageNumber="204" phylum="Acanthocephala" rank="species" species="spinosus">
