<subSubSection id="41DE081C33BE755BA7D9CC89B794B483" pageId="null" pageNumber="291" type="description">
<paragraph id="6636B8628BDBBCA4CEC75210A6307C85" pageId="null" pageNumber="291">
30-70 cm hoch, Horste bildend. Stengel aufrecht. 
<normalizedToken id="F0CF057CDAA968AD8D8E117FEEF4DE05" originalValue="Blätter" pageId="null" pageNumber="291">Blaetter</normalizedToken>
bis 2,5 mm breit, 
<normalizedToken id="1F84EADFDF1CF445F79C757402013FCA" originalValue="allmählich" pageId="null" pageNumber="291">allmaehlich</normalizedToken>
zugespitzt, oft etwas eingerollt, rauh; 
<emphasis id="61FD20EA0379C81848437DBAC5FEB89B" italics="true" pageId="null" pageNumber="291">
anstelle des 
<normalizedToken id="437B02C06401390ADD07229C01FF1A19" originalValue="Blatthäutchens" pageId="null" pageNumber="291">Blatthaeutchens</normalizedToken>
ein Haarkranz
</emphasis>
(Haare ca. 4 mm lang). 
<normalizedToken id="655943D98BDC0E1249BCDE14032373FE" originalValue="Blütenstand" pageId="null" pageNumber="291">Bluetenstand</normalizedToken>
meist eine Traube (gelegentlich die untersten 
<normalizedToken id="E26EBB3EB57B0B6BF756DCECA4B67683" originalValue="Äste" pageId="null" pageNumber="291">Aeste</normalizedToken>
verzweigt), aus 4-8 aufrecht abstehenden 
<normalizedToken id="8EA3A47308E844E14D67D7FD22FE6310" originalValue="Ährchen" pageId="null" pageNumber="291">Aehrchen</normalizedToken>
bestehend. 
<normalizedToken id="C987D89467C085909D929C214A044A84" originalValue="Ährchen" pageId="null" pageNumber="291">Aehrchen</normalizedToken>
meist 2-3 
<normalizedToken id="05AFAC26D3D6EF75E78CD589A2F93098" originalValue="blütig" pageId="null" pageNumber="291">bluetig</normalizedToken>
. 
<emphasis id="BA20509A62AE11871362C98D3C0D4C4C" italics="true" pageId="null" pageNumber="291">
<normalizedToken id="2E1ED28FFD5517496F22481E87CF054B" originalValue="Hüllspelzen" pageId="null" pageNumber="291">Huellspelzen</normalizedToken>
etwa 15 mm lang, fein zugespitzt.
</emphasis>
Deckspelzen etwa 
<normalizedToken id="73171044E1486107141F44779A7E7EC2" originalValue="½" pageId="null" pageNumber="291">1/2</normalizedToken>
so lang wie die 
<normalizedToken id="EB894DCDF46CC839576532C1BCD47811" originalValue="Hüllspelzen" pageId="null" pageNumber="291">Huellspelzen</normalizedToken>
, am Rande borstig behaart, hart; 
<emphasis id="F1145F0283440FAB90227EA1E52C0C4F" italics="true" pageId="null" pageNumber="291">
Granne 
<normalizedToken id="871FB932EDF2836F4E142D1229236195" originalValue="ungefähr" pageId="null" pageNumber="291">ungefaehr</normalizedToken>
5 mm lang.
</emphasis>
Vorspelzen fast so lang wie die Deckspelzen, am Rande fein bewimpert, 
<normalizedToken id="8ABD210E1DAA98BE913E01EBA301A970" originalValue="häutig" pageId="null" pageNumber="291">haeutig</normalizedToken>
. - 
<normalizedToken id="7BB91363599A7244B3714FE59792EC12" originalValue="Blüte" pageId="null" pageNumber="291">Bluete</normalizedToken>
: 
<normalizedToken id="CDEC7990378989807B77F024E23DF801" originalValue="Später" pageId="null" pageNumber="291">Spaeter</normalizedToken>
<normalizedToken id="AD61B4CEF192622E40E6BC7CCE7F786A" originalValue="Frühling" pageId="null" pageNumber="291">Fruehling</normalizedToken>
und 
<normalizedToken id="42C88DB25FC818F41EE44DF98F11A45B" originalValue="früher" pageId="null" pageNumber="291">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="D14E1F8E31B8D2B1F36AAF6E74713180" pageId="null" pageNumber="291">
<emphasis id="79DE698EC8FB8E364FCC2A08DD86352C" italics="true" pageId="null" pageNumber="291">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0B53C9B243609E4F8E94502B9E9166CF" italics="true" pageId="null" pageNumber="291">36:</emphasis>
Material aus 
<taxonomicName id="0A2D480BD85A1E4BF9F5F11843BDC714" authority="(Packer in Loeve und Loeve 1961)" baseAuthorityName="Packer in Loeve und Loeve" baseAuthorityYear="1961" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="291" phylum="Arthropoda" rank="genus">
Europa (Packer in 
<normalizedToken id="05C442E2AAB407834D64AE2325EA0750" originalValue="Löve" pageId="null" pageNumber="291">Loeve</normalizedToken>
und 
<normalizedToken id="641CBE9594C52A7DE4238075C1832D08" originalValue="Löve" pageId="null" pageNumber="291">Loeve</normalizedToken>
1961)
</taxonomicName>
.
</paragraph>
<paragraph id="08C7566F429D32B995BD9C9B208ED59E" pageId="null" pageNumber="291">
<emphasis id="9E748DBB22E0083998D0C77272372E7D" italics="true" pageId="null" pageNumber="291">Standort.</emphasis>
Kollin und montan. Kalkhaltige, trockene 
<normalizedToken id="D6290AC5544F5653C3975E1A1B852E59" originalValue="Böden" pageId="null" pageNumber="291">Boeden</normalizedToken>
. 
<emphasis id="A23E17B2BB3CBB6F2917090BA604DC4B" italics="true" pageId="null" pageNumber="291">
<taxonomicName id="4E949F3CD75929A660E4507EF28C79DC" class="Liliopsida" family="Poaceae" genus="Bromus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="genus">Bromus</taxonomicName>
erectus-Wiesen.
</emphasis>
</paragraph>
<paragraph id="5AA2BDC2C79F4C79BED40EAFFF703561" pageId="null" pageNumber="291">
<emphasis id="254BE95327555C085F270ABC62B8A224" italics="true" pageId="null" pageNumber="291">
Verbreitung. 
<normalizedToken id="CDAEA5871456A28532F0DD2752409438" originalValue="Südosteuropäische" pageId="null" pageNumber="291">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Westlichste Fundorte in den 
<normalizedToken id="2748B250BC291CD427C09D36B4D8260C" originalValue="französischen" pageId="null" pageNumber="291">franzoesischen</normalizedToken>
Alpen (Gap); Italien (
<normalizedToken id="431EA729429D0B801CEEBCB040B09E05" originalValue="südwärts" pageId="null" pageNumber="291">suedwaerts</normalizedToken>
bis in die apulische Ebene), Balkanhalbinsel, Donaugebiet (
<normalizedToken id="DADFF63DB1D8FD8397F0E5C61CC0A2BF" originalValue="nordwestwärts" pageId="null" pageNumber="291">nordwestwaerts</normalizedToken>
bis ins Gebiet von 
<normalizedToken id="DE0F656BE923DA8B10A3A522D3F8ACB7" originalValue="München" pageId="null" pageNumber="291">Muenchen</normalizedToken>
und slowakische Gebirge). Verbreitungskarten von Suessenguth und 
<normalizedToken id="7CC9254E2CE9B6B63D86285CAA54EC7B" originalValue="Merxmüller" pageId="null" pageNumber="291">Merxmueller</normalizedToken>
(1952) und Meusel (1964). - Im Gebiet: Piemont (Val Oropa), Tessin (Monte San Giorgio, Poncione 
<normalizedToken id="4EA4D0A10F96C5EDFF245F558D31ECB5" originalValue="d’Arzo" pageId="null" pageNumber="291">d'Arzo</normalizedToken>
und Denti della Vecchia), Monti dei Pizzoni bei Porlezza, Griante, Bergamasker Alpen (
<taxonomicName id="9FACC8ABE8679955694F5D4CE97A0F8E" authority="Val Caleppio" authorityName="Val Caleppio" genus="Val" pageId="null" pageNumber="291" rank="species" species="brembana">Val Brembana, Val Caleppio</taxonomicName>
).
</paragraph>
</subSubSection>
