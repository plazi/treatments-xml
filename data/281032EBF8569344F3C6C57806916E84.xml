<normalizedToken id="91F0A15FAC0E0CBEAA5ECF1E12BFBFAB" originalValue="Blütenregion" pageId="null" pageNumber="151">Bluetenregion</normalizedToken>
nur selten 
<normalizedToken id="889B7CEF6E126577274F33718E4892A9" originalValue="über" pageId="null" pageNumber="151">ueber</normalizedToken>
3 cm breit, jederseits 
<normalizedToken id="328F4872BA04082CDB7EE65CEEDCC41A" originalValue="höchstens" pageId="null" pageNumber="151">hoechstens</normalizedToken>
bis zur Mitte der 
<normalizedToken id="71376ECE10B207B2780F62FC047624CB" originalValue="Blatthälfte" pageId="null" pageNumber="151">Blatthaelfte</normalizedToken>
geteilt, meist aber nur 
<normalizedToken id="05B6755A0B134A5CCAB14E8C74CEB2B8" originalValue="gezähnt" pageId="null" pageNumber="151">gezaehnt</normalizedToken>
; 
<normalizedToken id="BB50D58599F863AB02C746B0A440806A" originalValue="Kelchzähne" pageId="null" pageNumber="151">Kelchzaehne</normalizedToken>
etwa doppelt so lang wie die 
<normalizedToken id="4DF911FF29D2243677A8B2368A000212" originalValue="Kelchröhre" pageId="null" pageNumber="151">Kelchroehre</normalizedToken>
.
</td>
