<subSubSection id="CC97A2CFDD16825732622BD563505CF1" lastPageNumber="151" pageId="null" pageNumber="152" type="description">
<paragraph id="D73D45EB903F414FB5F1EF8BFCF0AC89" pageId="null" pageNumber="152">
Kelch 
<normalizedToken id="8E7709865E9163F8B797FAC11020CF99" originalValue="glockenförmig" pageId="null" pageNumber="152">glockenfoermig</normalizedToken>
, 10-13nervig, 
<emphasis id="CC5BF901A095013868B494F610E96EBD" italics="true" pageId="null" pageNumber="152">
<normalizedToken id="F92E0E9866E8F55E2776581F27EF6606" originalValue="gleichmäßig" pageId="null" pageNumber="152">gleichmaessig</normalizedToken>
4- oder 5 
<normalizedToken id="0C614B8B66B2CCE95E8A17909A658F86" originalValue="zähnig" pageId="null" pageNumber="152">zaehnig</normalizedToken>
</emphasis>
(nicht 2lippig); 
<emphasis id="DEB2168910D0D16247274B3CAA26C8BF" italics="true" pageId="null" pageNumber="152">
innere Seite der 
<normalizedToken id="B5AE763DB0FA85F48E39D16E24E169C4" originalValue="Kelchröhre" pageId="null" pageNumber="152">Kelchroehre</normalizedToken>
kahl.
</emphasis>
Krone behaart, mit einer 
<normalizedToken id="0BF2D80E1F5825B96CC557171A69AD19" originalValue="Röhre" pageId="null" pageNumber="152">Roehre</normalizedToken>
und 
<emphasis id="DCDA358CA44241E5FAC3BD575B8097AE" italics="true" pageId="null" pageNumber="152">mit 4teiligem Rand;</emphasis>
Kronzipfel fast gleich, flach, 
<normalizedToken id="2590951A2B25724D62FF60E973C0C87C" originalValue="außen" pageId="null" pageNumber="152">aussen</normalizedToken>
gerundet oder ausgerandet. 
<emphasis id="E08E14C0C6C026F725CA3E81CA793799" italics="true" pageId="null" pageNumber="152">
Fertile 
<normalizedToken id="7C1DE848D6440D9BC77C8D59779254E4" originalValue="Staubblätter" pageId="null" pageNumber="152">Staubblaetter</normalizedToken>
2, frei, aus der Krone herausragend und spreizend;
</emphasis>
Staubbeutel mit zuerst parallelen, 
<normalizedToken id="AF59F5F9CFFD2A591F268F7222E0267B" originalValue="später" pageId="null" pageNumber="152">spaeter</normalizedToken>
mit spreizenden 
<normalizedToken id="9CC407AFD38BB70CF8E40549F574FFAF" originalValue="Hälften" pageId="null" pageNumber="152">Haelften</normalizedToken>
; 
<emphasis id="6476D80EAAE518E9E6AEE9023DC52934" italics="true" pageId="null" pageNumber="152">
die beiden obern 
<normalizedToken id="A3699E16CE93C061E9A8D34EE8D35BA3" originalValue="Staubblätter" pageId="null" pageNumber="152">Staubblaetter</normalizedToken>
<normalizedToken id="E0811B5756EC937D1539B2865B9A3DA2" originalValue="verkümmert" pageId="null" pageNumber="152">verkuemmert</normalizedToken>
oder nicht vorhanden.
</emphasis>
<normalizedToken id="933A9B8C814297156C7D4AC989682F45" originalValue="Teilfrüchte" pageId="null" pageNumber="152">Teilfruechte</normalizedToken>
tetraedrisch, 
<emphasis id="4329C657953FE7AB01CE4C175CFE8C71" italics="true" pageId="null" pageNumber="152">
auf der 
<normalizedToken id="3ABB9E6683EBB6C7CF81A9A8AB893867" originalValue="äußern" pageId="null" pageNumber="152">aeussern</normalizedToken>
Seite mit verdickten Kanten.
</emphasis>
</paragraph>
<paragraph id="6AD18B498F11EE17D80A4409F1D1B4AE" pageId="null" pageNumber="152">
Die Gattung 
<taxonomicName id="683CD5A2A5044DB1DB23E5C30D443E07" class="Arachnida" family="Thomisidae" genus="Lycopus" kingdom="Animalia" order="Araneae" pageId="null" pageNumber="152" phylum="Arthropoda" rank="genus">
<emphasis id="DF218F98E1F8574554BC087AFB9D6A28" italics="true" pageId="null" pageNumber="152">Lycopus</emphasis>
</taxonomicName>
<normalizedToken id="73CE7DA8D56C1C1389B3D6E76D5B8966" originalValue="umfaßt" pageId="null" pageNumber="152">umfasst</normalizedToken>
<emphasis id="CB943632BF5F0FEF1DB2660BA0559F89" italics="true" pageId="null" pageNumber="152">5 eurasiatische und etwa 8 amerikanische Arten, zudem 1 Art in Australien</emphasis>
, alle Arten wachsen in 
<normalizedToken id="63A05874F64757B20CAA2E7D89061F6E" originalValue="Sümpfen" pageId="null" pageNumber="152">Suempfen</normalizedToken>
. 
<emphasis id="EEF16DC30C0AA5DDE9BD64BDCA6CB53C" italics="true" pageId="null" pageNumber="152">Chromosomengrundzahl</emphasis>
n = 11. 
<normalizedToken id="2FDCC228156C9C4DF4A8EDDA5D965350" originalValue="Über" pageId="null" pageNumber="152">Ueber</normalizedToken>
die Gattung besteht eine Monographie von Henderson (1962) mit morphologischen und pflanzengeographischen Angaben und eine Studie von 
<normalizedToken id="A4C243D5ACB2D643EDE553F013386613" originalValue="Skalický" pageId="null" pageNumber="152">Skalicky</normalizedToken>
(1968) mit morphologischen und pflanzengeographischen Angaben der 
<normalizedToken id="EAEE42F6E56D322291254C304AE18B72" originalValue="europäischen" pageId="null" pageNumber="152">europaeischen</normalizedToken>
Arten.
</paragraph>
<paragraph id="6DB4BDD76CB3AEA444D6168954AC6AAE" pageId="null" pageNumber="151">
