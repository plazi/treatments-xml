<subSubSection id="1438BC36FB36BB17535B4B4925E620A5" pageId="null" pageNumber="278" type="description">
<paragraph id="E9EC3FB14F1B9AD05B5EA8C82B9ED1D3" pageId="null" pageNumber="278">
1-2 
<normalizedToken id="FF65E5D5FE28BB6BA3620491B89C2770" originalValue="jährig" pageId="null" pageNumber="278">jaehrig</normalizedToken>
oder ausdauernd; 5-30 cm hoch. Alle 
<normalizedToken id="B15899638C0737E332104586233637B4" originalValue="Blätter" pageId="null" pageNumber="278">Blaetter</normalizedToken>
in 
<normalizedToken id="FD3C5F41A45894C255E2300ACC7B7AF9" originalValue="grundständiger" pageId="null" pageNumber="278">grundstaendiger</normalizedToken>
Rosette, niederliegend, aufsteigend oder aufrecht, im 
<normalizedToken id="FEA90D7048BDABD467DC2AA436242FC4" originalValue="Umriß" pageId="null" pageNumber="278">Umriss</normalizedToken>
lanzettlich, 
<emphasis id="134D7BD717AAA9AD3845DFE3DB07B0A5" italics="true" pageId="null" pageNumber="278">
zur 
<normalizedToken id="561D233BC5A72D19F6B255F4854F5D3B" originalValue="Blütezeit" pageId="null" pageNumber="278">Bluetezeit</normalizedToken>
bis 
<normalizedToken id="CDB5890CA00BACF585DCE2C02F26CFF0" originalValue="über" pageId="null" pageNumber="278">ueber</normalizedToken>
die 
<normalizedToken id="7D0448E61563A523F31BB97CB39DFA3D" originalValue="Hälfte" pageId="null" pageNumber="278">Haelfte</normalizedToken>
gegen den Mittelnerv fiederteilig, mit beiderseits 4
</emphasis>
- 
<emphasis id="80B006EACD07AF85388AAD02B6F26987" italics="true" pageId="null" pageNumber="278">
8 entfernt stehenden, schmal lanzettlichen, oft nochmals 
<normalizedToken id="86E91855CC899A34881B286A368D66EF" originalValue="gezähnten" pageId="null" pageNumber="278">gezaehnten</normalizedToken>
Abschnitten
</emphasis>
(
<emphasis id="3A8939EE8705C0621D284DA42253DC9A" italics="true" pageId="null" pageNumber="278">
alle andern Arten im Gebiet haben ungeteilte 
<normalizedToken id="ADA63E2D778867A7F94DA0223A1DEB53" originalValue="Blätter" pageId="null" pageNumber="278">Blaetter</normalizedToken>
</emphasis>
), mit wenigen bis zahlreichen, bis 
<normalizedToken id="6B1337501508A79400939FC02B7AE381" originalValue="über" pageId="null" pageNumber="278">ueber</normalizedToken>
1 mm langen Haaren. Stiel der 
<normalizedToken id="996943A0839E6DCFA0333E7C950CE4E7" originalValue="Blütenähre" pageId="null" pageNumber="278">Bluetenaehre</normalizedToken>
meist aufrecht (
<normalizedToken id="8587CCAB641185268A7D29BC2625C095" originalValue="Ähre" pageId="null" pageNumber="278">Aehre</normalizedToken>
aber vor dem 
<normalizedToken id="FDB6BC3187D6224819B6761E8A6ED906" originalValue="Aufblühen" pageId="null" pageNumber="278">Aufbluehen</normalizedToken>
nickend), anliegend behaart (Haare 0,6-1 mm lang), meist 
<normalizedToken id="21DBE40A1D0B5D1B9AE25B1A32C1A459" originalValue="länger" pageId="null" pageNumber="278">laenger</normalizedToken>
als die 
<normalizedToken id="B058984C1B2629DA18DD51F9558D2510" originalValue="Blätter" pageId="null" pageNumber="278">Blaetter</normalizedToken>
. 
<normalizedToken id="6292455B564ED9733F3A19E2B25425DF" originalValue="Blütenähre" pageId="null" pageNumber="278">Bluetenaehre</normalizedToken>
zylindrisch, 2-4 cm lang (zur Fruchtzeit bis 8 cm lang und 
<emphasis id="9F439DCEA49CE4D893B8D8F3BD2A4555" italics="true" pageId="null" pageNumber="278">kaum 0,5 cm dick</emphasis>
). 
<normalizedToken id="A3F6D63FEDBBCB2C9460D0C1D848E67B" originalValue="Tragblätter" pageId="null" pageNumber="278">Tragblaetter</normalizedToken>
grannenartig zugespitzt, fast so lang bis wenig 
<normalizedToken id="4A70476BD2A217083F7FE2A82B0BEBBF" originalValue="länger" pageId="null" pageNumber="278">laenger</normalizedToken>
als der Kelch, kahl oder am Rande und auf dem Mittelnerv behaart; der Mittelnerv 
<normalizedToken id="B9CEB94AD86433492A276EBE7701B9AB" originalValue="schmäler" pageId="null" pageNumber="278">schmaeler</normalizedToken>
als die 
<normalizedToken id="A6A98BF8A64F940B90DFEE5D04D95F4C" originalValue="anschließenden" pageId="null" pageNumber="278">anschliessenden</normalizedToken>
<normalizedToken id="4085ED9AF4CEDCDEBDA80999644BEA53" originalValue="häutigen" pageId="null" pageNumber="278">haeutigen</normalizedToken>
Teile. Alle 
<normalizedToken id="8E4E4E993FD41949B58ACD0C435DDD40" originalValue="Kelchblätter" pageId="null" pageNumber="278">Kelchblaetter</normalizedToken>
bis fast zum Grunde frei. Krone 2-3 mm lang; 
<normalizedToken id="C6C54FDB2CC2D1215F4513CF12987630" originalValue="Kronröhre" pageId="null" pageNumber="278">Kronroehre</normalizedToken>
<normalizedToken id="250378D7D8FCBE653BE72F978506F51D" originalValue="außen" pageId="null" pageNumber="278">aussen</normalizedToken>
in der untern 
<normalizedToken id="D4861DABF3B92E7D5955573C3C185899" originalValue="Hälfte" pageId="null" pageNumber="278">Haelfte</normalizedToken>
behaart; Kronzipfel 
<normalizedToken id="D361FF959AB7A5325E086A2518CA1868" originalValue="weißlich" pageId="null" pageNumber="278">weisslich</normalizedToken>
. 
<normalizedToken id="14935C676ED42BA86C96256ABCA13D7C" originalValue="Staubblätter" pageId="null" pageNumber="278">Staubblaetter</normalizedToken>
gelb. Frucht 2-5samig, spitz. Samen 1-1,5 mm lang. - 
<normalizedToken id="BF8E53EC3AC7D22D24C8FD9ABE5AD728" originalValue="Blüte" pageId="null" pageNumber="278">Bluete</normalizedToken>
: 
<normalizedToken id="257EC44FD36F4FBE37446E7BF76B35A4" originalValue="Später" pageId="null" pageNumber="278">Spaeter</normalizedToken>
<normalizedToken id="E7D100EA8E775678D823B83618A7822B" originalValue="Frühling" pageId="null" pageNumber="278">Fruehling</normalizedToken>
, Sommer.
</paragraph>
<paragraph id="D7101122C9422866DBEAAFBC65A24545" pageId="null" pageNumber="278">
<emphasis id="441777347F66346071C17E5E0FBB2C16" italics="true" pageId="null" pageNumber="278">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D924D90BDD1A06EF3CE6EADF2ACAE5C1" italics="true" pageId="null" pageNumber="278">10:</emphasis>
Material aus England (McCullagh 1934), aus Skandinavien (
<normalizedToken id="936A478E0F6EA75E06B10C809EEC422C" originalValue="Löve" pageId="null" pageNumber="278">Loeve</normalizedToken>
und 
<normalizedToken id="20FD4AFE51268D7A61A316CDCBF5D3BE" originalValue="Löve" pageId="null" pageNumber="278">Loeve</normalizedToken>
1944b), aus Algerien (Gorenflot 1966), aus Portugal (Rodrigues 1953), von zahlreichen Stellen aus Europa, Nordafrika und Westasien (
<normalizedToken id="BA624D475895B8A35D5F4321CC5E35E7" originalValue="Böcher" pageId="null" pageNumber="278">Boecher</normalizedToken>
et al. 1955b), aus botanischem Garten (Hyde 1953), aus Holland (Gadella 
<pageBreakToken id="8A0B7573D7D41528DA84BB2E66D7C27C" pageId="null" pageNumber="278">und</pageBreakToken>
Kliphuis 1967 1968), aus der 
<normalizedToken id="D7838986B61D492524BBCE0BC6D5F04B" originalValue="Ägäis" pageId="null" pageNumber="278">Aegaeis</normalizedToken>
(Runemark 1967), aus Nordfrankreich (Gorenflot 1964 1968). 
<normalizedToken id="7728F688064736463884A78105A1CD67" originalValue="Böcher" pageId="null" pageNumber="278">Boecher</normalizedToken>
et al. (1955b), Gorenflot (1959 1964) und Paliwal und Hyde (1959) 
<normalizedToken id="7297B07E8398FA31818D37A366E60804" originalValue="zählten" pageId="null" pageNumber="278">zaehlten</normalizedToken>
auch 1 B-Chromosom. An Sippen aus dem Mittelmeergebiet wurden auch 2 n = 20 und 30 
<normalizedToken id="794836888B60FB82ED8DF6EBECB6C0FA" originalValue="gezählt" pageId="null" pageNumber="278">gezaehlt</normalizedToken>
(Gorenflot 1959 1960 1966, 
<normalizedToken id="6BEFA9841F259D82E70AB9629074F33F" originalValue="Böcher" pageId="null" pageNumber="278">Boecher</normalizedToken>
et al. 1953, Larsen 1960a).
</paragraph>
<paragraph id="409A8DD0785589222A7AD19AFF3793DD" pageId="null" pageNumber="278">
<emphasis id="90AA830F1BAE15D56F945A6E3180AE51" italics="true" pageId="null" pageNumber="278">Standort.</emphasis>
Kollin. Offene, ziemlich feuchte, salzhaltige, tonige oder sandige 
<normalizedToken id="5D22F71F27E641438FDD9CD9975DA948" originalValue="Böden" pageId="null" pageNumber="278">Boeden</normalizedToken>
in wintermilden Lagen. 
<normalizedToken id="F8E09B8FD043D10E2AB12D5BDB52901F" originalValue="Wegränder" pageId="null" pageNumber="278">Wegraender</normalizedToken>
, Weiden, 
<normalizedToken id="93C12F46911FAE11C6648ABB6FAAB5AF" originalValue="Schuttplätze" pageId="null" pageNumber="278">Schuttplaetze</normalizedToken>
(
<normalizedToken id="94C80036B18D44D31531BE1232F64542" originalValue="außerhalb" pageId="null" pageNumber="278">ausserhalb</normalizedToken>
des Gebiets besonders in 
<normalizedToken id="CCB8633E12ADBB145409BA7A79F05EAC" originalValue="Küstenvegetationen" pageId="null" pageNumber="278">Kuestenvegetationen</normalizedToken>
).
</paragraph>
<paragraph id="8DD4429E224916B8B09400D4B6062AFB" pageId="null" pageNumber="278">
<emphasis id="E099CD9F03D0067042E05A6AC129EF30" italics="true" pageId="null" pageNumber="278">
Verbreitung. 
<normalizedToken id="60BB4652A7E1D8E16E95536C90D082E7" originalValue="Westeuropäisch-mediterrane" pageId="null" pageNumber="278">Westeuropaeisch-mediterrane</normalizedToken>
Pflanze:
</emphasis>
Ganzes Mittelmeergebiet; 
<normalizedToken id="C8AEE48197D453336EAA7C97B322B8F9" originalValue="ostwärts" pageId="null" pageNumber="278">ostwaerts</normalizedToken>
bis Krim, Kleinasien, Syrien; 
<normalizedToken id="D57FC740B015843865F6617882CC386D" originalValue="südwärts" pageId="null" pageNumber="278">suedwaerts</normalizedToken>
bis Nordafrika und Azoren; 
<normalizedToken id="F7D6F8B7E12A65A78E138F0E6EFCFC47" originalValue="nordwärts" pageId="null" pageNumber="278">nordwaerts</normalizedToken>
der atlantischen 
<normalizedToken id="3A5B9A0954BD19160574FCE30E693103" originalValue="Küste" pageId="null" pageNumber="278">Kueste</normalizedToken>
entlang bis Norwegen, 
<normalizedToken id="E0D3677B010DD2A14CA4A8BCF5846EDE" originalValue="Öland" pageId="null" pageNumber="278">Oeland</normalizedToken>
und zur 
<normalizedToken id="86B5E73BCA920F7FB9FE3B7D71276027" originalValue="Odermündung" pageId="null" pageNumber="278">Odermuendung</normalizedToken>
, sonst 
<normalizedToken id="EF0EBF71D0BD8ADE0A721BFA5859BB42" originalValue="nordwärts" pageId="null" pageNumber="278">nordwaerts</normalizedToken>
nur bis in die 
<normalizedToken id="4AF3E26A681D7FD9BD0F6AB2210D181F" originalValue="Südalpen" pageId="null" pageNumber="278">Suedalpen</normalizedToken>
. - Im Gebiet: 
<normalizedToken id="76CE7A1891542B591672FFBC44E8913C" originalValue="Dép" pageId="null" pageNumber="278">Dep</normalizedToken>
. Ain, sonst gelegentlich eingeschleppt.
</paragraph>
<paragraph id="9253BE2F71AA2D2B8048AA6DCC715087" pageId="null" pageNumber="278">
<emphasis id="61E42A9A6F225BAF788FA064884120A7" italics="true" pageId="null" pageNumber="278">Bemerkungen.</emphasis>
<normalizedToken id="1BACDE0E175BD9DC6B3B401F1910DB95" originalValue="Über" pageId="null" pageNumber="278">Ueber</normalizedToken>
die Vielgestaltigkeit der Art und deren Ursachen s. Gorenflot (1959 1964). Es 
<normalizedToken id="9DC842FFE5ADC37FA06D093668B61777" originalValue="können" pageId="null" pageNumber="278">koennen</normalizedToken>
zahlreiche Unterarten und 
<normalizedToken id="8E2B873852468FF9E068F2E19F7DC32C" originalValue="Varietäten" pageId="null" pageNumber="278">Varietaeten</normalizedToken>
abgetrennt werden (s. Pilger 1937).
</paragraph>
</subSubSection>
