<subSubSection id="A805679064641A03DBE55E3C64F4085E" pageId="null" pageNumber="497" type="description">
<paragraph id="B5F9411ED2B3316D9FCEE5C2557445F9" pageId="null" pageNumber="497">
<emphasis id="ACB2AC58D68F188094162A4D0E849B2E" italics="true" pageId="null" pageNumber="497">
<normalizedToken id="C4D9E8DB9F3E48D761FE3CDDCE8F0966" originalValue="Zähne" pageId="null" pageNumber="497">Zaehne</normalizedToken>
der untern 
<normalizedToken id="FB6FD1C33590A1E80E90B3E00C686AFE" originalValue="Blätter" pageId="null" pageNumber="497">Blaetter</normalizedToken>
<normalizedToken id="C5A3F0E9AC91018D79BE264D967895D5" originalValue="kürzer" pageId="null" pageNumber="497">kuerzer</normalizedToken>
als 2 mm. 
<normalizedToken id="4CA30EB3B02E5090DCFAB8659ABE6C9E" originalValue="Blätter" pageId="null" pageNumber="497">Blaetter</normalizedToken>
im obersten Stengeldrittel 5
</emphasis>
- 
<emphasis id="EC4B0FFF3FD052C288E5C3B60B29737A" italics="true" pageId="null" pageNumber="497">10mal so lang wie breit, deutlich gestielt</emphasis>
. 
<normalizedToken id="62DDC632680C4638C8CF5A86EB2FBCBB" originalValue="Blütenköpfe" pageId="null" pageNumber="497">Bluetenkoepfe</normalizedToken>
mit 4-8 
<normalizedToken id="FB2D2F623C0961AB2218A4C714B80AD5" originalValue="zungenförmigen" pageId="null" pageNumber="497">zungenfoermigen</normalizedToken>
<normalizedToken id="FDEE871C242C8E331CBEDB31EBBDD4D3" originalValue="Blüten" pageId="null" pageNumber="497">Blueten</normalizedToken>
, im Durchmesser 2,5-3 cm. 
<emphasis id="E1FF725FD5244CC161A0F332492872E8" italics="true" pageId="null" pageNumber="497">
<normalizedToken id="06F483A4E7849413423CE4C09EE318E4" originalValue="Hülle" pageId="null" pageNumber="497">Huelle</normalizedToken>
in der Mitte 2
</emphasis>
- 
<emphasis id="40354E29155D9812ACFBD14BF8176CA8" italics="true" pageId="null" pageNumber="497">3 mm dick</emphasis>
, von wenigen halb bis fast so langen, kahlen 
<normalizedToken id="1A5F41C898A8D7CF284C394F021076E3" originalValue="Blättern" pageId="null" pageNumber="497">Blaettern</normalizedToken>
umgeben; innere 
<normalizedToken id="8FE19319025D838BAE1BDC4EBB4364B5" originalValue="Hüllblätter" pageId="null" pageNumber="497">Huellblaetter</normalizedToken>
meist 8, meist kahl. Kronen gelb. - 
<normalizedToken id="D4E485A3278C487E2875D52CBF6F10F9" originalValue="Blüte" pageId="null" pageNumber="497">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="FE0288556EDFD451DF57033C68D9945A" originalValue="früher" pageId="null" pageNumber="497">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="8865B6A2DE4DEE835EF6D66F28082B7D" pageId="null" pageNumber="497">
<emphasis id="35427AD7C5ECDA153D16237084A19ACB" italics="true" pageId="null" pageNumber="497">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="3DD140A2CA21CE4EAB23BAB73330D7BD" italics="true" pageId="null" pageNumber="497">40:</emphasis>
Material aus botanischen 
<normalizedToken id="A03460D95CADB970F22D1BC28CFE27AA" originalValue="Gärten" pageId="null" pageNumber="497">Gaerten</normalizedToken>
(Afzelius 1924), aus den Niederlanden (Gadella und Kliphuis 1963), aus der Tschechoslowakei (Palmblad 1965), aus der Tatra (Skalinska et al. 1966), aus den 
<normalizedToken id="28F5B1ED69482C98CCFFC40B8053147D" originalValue="Südwestalpen" pageId="null" pageNumber="497">Suedwestalpen</normalizedToken>
(Zickler 1968a).
</paragraph>
<paragraph id="E7FC72AA17CB444413EB4765C0B78FD0" pageId="null" pageNumber="497">
<emphasis id="F33E971F0B1F9D21550595DD980C5D4A" italics="true" pageId="null" pageNumber="497">Standort</emphasis>
. Montan, selten kollin und subalpin. 
<normalizedToken id="B46ED9E0716CE91FC2E291503AA16557" originalValue="Mäßig" pageId="null" pageNumber="497">Maessig</normalizedToken>
feuchte, lockere, 
<normalizedToken id="827955EB8F4184F85B255B33E994E17F" originalValue="nährstoffreiche" pageId="null" pageNumber="497">naehrstoffreiche</normalizedToken>
<normalizedToken id="F2A2D7F12CB882A1455B916480196BF1" originalValue="Böden" pageId="null" pageNumber="497">Boeden</normalizedToken>
in halbschattigen Lagen. Lichte, krautreiche 
<normalizedToken id="207887C770BCF94831FA06F14189DC20" originalValue="Wälder" pageId="null" pageNumber="497">Waelder</normalizedToken>
, 
<normalizedToken id="26FC053344010FEBF0856423DF4D8275" originalValue="Gebüsche" pageId="null" pageNumber="497">Gebuesche</normalizedToken>
, 
<normalizedToken id="28B9957A4A5A239E8B2B7F4BB6FFC56D" originalValue="Waldschläge" pageId="null" pageNumber="497">Waldschlaege</normalizedToken>
.
</paragraph>
<paragraph id="8FA5893ADE6E9F0AF5552E133A5F5ABB" pageId="null" pageNumber="497">
<emphasis id="A0FB9491410194C1C20AC5574BEF573A" italics="true" pageId="null" pageNumber="497">
Verbreitung. 
<normalizedToken id="1C7E6D9C5A4BF26E66197BC61C5918BC" originalValue="Mitteleuropäische" pageId="null" pageNumber="497">Mitteleuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="61C5A7B601232F04416269CABDF29D15" originalValue="Nordwärts" pageId="null" pageNumber="497">Nordwaerts</normalizedToken>
bis Mittelfrankreich, Schlesien, 
<normalizedToken id="81806C20B8E0AA6209C2EF8334F631EB" originalValue="Südpolen" pageId="null" pageNumber="497">Suedpolen</normalizedToken>
; 
<normalizedToken id="B3E462E93C4591223974DFCD4458891E" originalValue="südwärts" pageId="null" pageNumber="497">suedwaerts</normalizedToken>
bis 
<normalizedToken id="E896D944F8E0FB84D1DFED94984025DF" originalValue="Südapennin" pageId="null" pageNumber="497">Suedapennin</normalizedToken>
, Bulgarien; 
<normalizedToken id="87DDF4A0D3982A9B1B357F02388EC6B9" originalValue="westwärts" pageId="null" pageNumber="497">westwaerts</normalizedToken>
bis Rhonetal; 
<normalizedToken id="07E58C332C713B47084F38385EFFE93B" originalValue="ostwärts" pageId="null" pageNumber="497">ostwaerts</normalizedToken>
bis Karpaten. - Im Gebiet (vor allem in Berggebieten) verbreitet und ziemlich 
<normalizedToken id="AC5414CB1CA862928DB145A6E5D4C3F0" originalValue="häufig" pageId="null" pageNumber="497">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
