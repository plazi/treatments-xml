, ♀: 
<emphasis id="B962D642FB1BFFAF7ED3AD87012BF92C" box="[475,513,1710,1732]" italics="true" pageId="9" pageNumber="34">1 —</emphasis>
holotype, lateral view; 
<emphasis id="B962D642FB1BFFAF7DD2AD8701D7F92C" box="[730,765,1710,1732]" italics="true" pageId="9" pageNumber="34">2–4</emphasis>
— head (
<emphasis id="B962D642FB1BFFAF7C5FAD870048F92C" box="[855,866,1710,1732]" italics="true" pageId="9" pageNumber="34">2</emphasis>
— left, 
<emphasis id="B962D642FB1BFFAF7CA2AD87009FF92C" box="[938,949,1710,1732]" italics="true" pageId="9" pageNumber="34">3</emphasis>
— anterior, 
<emphasis id="B962D642FB1BFFAF7B24AD87071DF92C" box="[1068,1079,1710,1732]" italics="true" pageId="9" pageNumber="34">4</emphasis>
— dorsal view); 
<emphasis id="B962D642FB1BFFAF7FA6ADE00393F937" box="[174,185,1737,1759]" italics="true" pageId="9" pageNumber="34">5</emphasis>
— wing; 
<emphasis id="B962D642FB1BFFAF7E1CADE00235F937" box="[276,287,1737,1759]" italics="true" pageId="9" pageNumber="34">6</emphasis>
— mid leg, anterior; 
<emphasis id="B962D642FB1BFFAF7EE4ADE002DDF937" box="[492,503,1737,1759]" italics="true" pageId="9" pageNumber="34">7</emphasis>
— prosternum, anteroventral; 
<emphasis id="B962D642FB1BFFAF7C2BADE00060F936" box="[803,842,1737,1759]" italics="true" pageId="9" pageNumber="34">8 —</emphasis>
paratype abdomen, lateral view.
</paragraph>
<paragraph id="8BA90A50FB1BFFAF7FA6ADDA02B5F8D7" blockId="9.[174,1232,1777,1855]" pageId="9" pageNumber="34">
Рис. 6. 
<taxonomicName id="4C1671D3FB1BFFAF7FFEADDA02A6F8E1" authority="Korneyev, 2015" authorityName="V. Korneyev" authorityYear="2015" box="[246,396,1779,1801]" class="Insecta" family="Pyrgotidae" genus="Afropyrgota" kingdom="Animalia" order="Diptera" pageId="9" pageNumber="34" phylum="Arthropoda" rank="species" species="ota" status="sp. n.">
<emphasis id="B962D642FB1BFFAF7FFEADDA02A6F8E1" box="[246,396,1779,1801]" italics="true" pageId="9" pageNumber="34">Afropyrgota ota</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A2516B39FB1BFFAF7E9BADDA02E2F8E1" box="[403,456,1779,1801]" pageId="9" pageNumber="34" rank="species">sp. n.</taxonomicNameLabel>
, 
<specimenCount id="9D10C1D9FB1BFFAF7EDAADD802CBF8E1" box="[466,481,1777,1801]" pageId="9" pageNumber="34" type="female">♀</specimenCount>
