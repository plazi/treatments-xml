<figureCitation id="FDD1E3AFFFFFFFC0FF79FC7CFF05FC66" box="[159,248,942,968]" captionStart="FIGURE 16" captionStartId="69.[151,250,1930,1954]" captionTargetBox="[211,1383,199,1895]" captionTargetId="figure-19@69.[195,1393,181,1905]" captionTargetPageId="69" captionText="FIGURE 16. Eudocima phalonia group and Hemiceratoides adults (dorsal aspect)." figureDoi="http://doi.org/10.5281/zenodo.6605543" httpUri="https://zenodo.org/record/6605543/files/figure.png" pageId="23" pageNumber="24">Figs 16</figureCitation>
