<taxonomicName id="2EC2C4D8B528CB88335F35363B950990" authority="Willd." class="Polypodiopsida" family="Aspleniaceae" genus="Asplenium" kingdom="Plantae" order="Polypodiales" pageId="null" pageNumber="137" phylum="Tracheophyta" rank="species" species="ceterach">
