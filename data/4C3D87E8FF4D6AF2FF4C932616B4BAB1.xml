<taxonomicName id="03944D7DFF4D6AF2FBDD90211A8FBDAB" authorityName="E. Geoffroy Saint-Hilaire" authorityYear="1806" box="[1057,1167,1656,1689]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="182" pageNumber="944" phylum="Chordata" rank="species" species="albescens">albescens</taxonomicName>
