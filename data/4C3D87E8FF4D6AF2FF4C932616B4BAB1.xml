<taxonomicName id="03944D7DFF4D6AF2FCB991431DBDBC05" authorityName="G. S. Miller" authorityYear="1900" box="[837,957,1818,1847]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="182" pageNumber="944" phylum="Chordata" rank="species" species="nesopolus">nesopolus</taxonomicName>
