<taxonomicName id="46DCD9FFFF3CCEECFDA0FF39D9933D2C" authorityName="Rios-Tamayo &amp; Goloboff" authorityYear="2018" box="[607,704,232,258]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="177" pageNumber="178" phylum="Arthropoda" rank="species" species="coylei">
