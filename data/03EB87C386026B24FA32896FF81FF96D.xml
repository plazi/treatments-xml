<taxonomicName id="4C424D5686026B24FB24899DFA7EF98B" authorityName="Foerste" authorityYear="1914" box="[1276,1508,1513,1552]" class="Gastropoda" family="Lophospiridae" genus="Ruedemannia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Murchisoniina" pageId="16" pageNumber="79" phylum="Mollusca" rank="genus">
