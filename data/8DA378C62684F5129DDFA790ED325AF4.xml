<subSubSection id="E5479EC2D453606009901BF19BCC14A7" pageId="null" pageNumber="422" type="nomenclature">
<paragraph id="476F1852DCB30D8FDC31D56DB2B8336D" pageId="null" pageNumber="422">
<taxonomicName id="EB857758D120EB12AD07DD3BC495CCE2" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Cynara" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="422" phylum="Tracheophyta" rank="species" species="cardunculus">
Cynara 
<normalizedToken id="11049B9FE5F63642EF4F2D0835BA7312" originalValue="Cardúnculus" pageId="null" pageNumber="422">Cardunculus</normalizedToken>
<authorityName id="FE52DEB4B078415D8E45040F9F8AD221" pageId="null" pageNumber="422">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="8812E5D67A3862A69FD2E824B519DB5A" pageId="null" pageNumber="422" type="vernacular_names">
<paragraph id="6387DF0E4C4F0F169EC33A4C6A48C8EC" pageId="null" pageNumber="422">Artischocke, Kardone</paragraph>
</subSubSection>
</title>
<subSubSection id="F6D9F7C79E219AD61FE5715F0AC7A59C" pageId="null" pageNumber="422" type="description">
<paragraph id="4505858A909F6DE4547C1B777F925BF4" pageId="null" pageNumber="422">
Ausdauernd; 50-120 cm hoch. 
<normalizedToken id="A6AF0BBD045217B0B3ED5D267ABD70D6" originalValue="Blätter" pageId="null" pageNumber="422">Blaetter</normalizedToken>
kahl oder, vor allem unterseits, filzig behaart, sehr 
<normalizedToken id="3C4C038CA5949081D5A6C3CCA2B17574" originalValue="groß" pageId="null" pageNumber="422">gross</normalizedToken>
(bis 70 cm lang), fiederteilig, mit lanzettlichen, stachligen oder nicht stachligen Abschnitten. 
<emphasis id="692F0D5B3FC023F3DB7DE66F1F2CED0B" italics="true" pageId="null" pageNumber="422">
<normalizedToken id="3288FD644552F3F3CC287EF11BA6DAE2" originalValue="Köpfe" pageId="null" pageNumber="422">Koepfe</normalizedToken>
<normalizedToken id="106107618022BFDFE4825B9DEBF16D77" originalValue="groß" pageId="null" pageNumber="422">gross</normalizedToken>
, 3
</emphasis>
- 
<emphasis id="9A1027674A4E9FD635BAC748812A43D4" italics="true" pageId="null" pageNumber="422">8 cm im Durchmesser</emphasis>
. 
<normalizedToken id="7AD1C8538570B057DDA1CC8DC6639A74" originalValue="Hülle" pageId="null" pageNumber="422">Huelle</normalizedToken>
kugelig, kahl. 
<normalizedToken id="46579267C3363EA0C5BD06EB4D8A4533" originalValue="Hüllblätter" pageId="null" pageNumber="422">Huellblaetter</normalizedToken>
mit oder (in Kulturformen) ohne Stachel, 
<emphasis id="189F3F02B77CE2921CC98ABC6E7CBC33" italics="true" pageId="null" pageNumber="422">am Grunde 0,8</emphasis>
- 
<emphasis id="6755488C197616EEADCCCB4D9B53A9B1" italics="true" pageId="null" pageNumber="422">3 cm breit</emphasis>
. Kronen mit 2lippigem oberm Teil, 
<emphasis id="0E7F4FFD8E9A4D42CEF94C9C364A5730" italics="true" pageId="null" pageNumber="422">bis 4 cm lang</emphasis>
, blau oder violett. 
<normalizedToken id="6D621B9C17462ED2E1F65C77A6D31080" originalValue="Früchte" pageId="null" pageNumber="422">Fruechte</normalizedToken>
2-4 mm lang. 
<taxonomicName id="5BAF24E4BA5EB84B463C0504C4BC1370" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="422" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
20-35 mm lang. - 
<normalizedToken id="DA86C59CDA5722282DB6E8F0F170EB4F" originalValue="Blüte" pageId="null" pageNumber="422">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="A7DD369EB36F13F4FAD3BFCB60C32778" pageId="null" pageNumber="422">
<emphasis id="463DBCD8000B74ECAE9DB74A23CC348A" italics="true" pageId="null" pageNumber="422">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="9E099376A56C48A1749F148381BFC018" italics="true" pageId="null" pageNumber="422">34:</emphasis>
Material aus Argentinien (Covas und Schnack aus Darlington und Wylie 1955).
</paragraph>
<paragraph id="18AA5C5398476A9889A90E4D0BC576E2" pageId="null" pageNumber="422">
<emphasis id="F9532217DDE5A81491AE005AA24B1DED" italics="true" pageId="null" pageNumber="422">Bemerkungen</emphasis>
. Die 
<normalizedToken id="C2484197ABD7AB81F05AC4C65346FF0E" originalValue="ursprünglich" pageId="null" pageNumber="422">urspruenglich</normalizedToken>
mediterrane Pflanze wird bei uns im Genferseegebiet und auf der 
<normalizedToken id="A8C4E2712D6B692CDF0E381B925961AC" originalValue="Alpensüdseite" pageId="null" pageNumber="422">Alpensuedseite</normalizedToken>
(z. B. Comerseegebiet, Veltlin, Bergamo, Val Camonica) in 2 fast stachellosen Sorten als 
<normalizedToken id="750500E96365413ECA74AA07CCEB50E0" originalValue="Gemüse" pageId="null" pageNumber="422">Gemuese</normalizedToken>
kultiviert: 1. Artischocke (
<taxonomicName id="AF026D81E7AFD72BF8C5435AC5984031" authority="L." authorityName="L." class="Magnoliopsida" family="Asteraceae" genus="Cynara" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="422" phylum="Tracheophyta" rank="species" species="scolymus">
<emphasis id="A3D990E21C02B30A997937F5737A3890" italics="true" pageId="null" pageNumber="422">C. Scolymus</emphasis>
<authorityName id="A30234FA6FB91D7F2606F1BD5B431753" pageId="null" pageNumber="422">L.</authorityName>
</taxonomicName>
) mit besonders fleischigem 
<normalizedToken id="CDC90E6FF64D4B356AD33FCF792F1153" originalValue="Blütenboden" pageId="null" pageNumber="422">Bluetenboden</normalizedToken>
und 
<normalizedToken id="F6A543D57D34D911A697FB70DC2D1C76" originalValue="Hüllblattgrund" pageId="null" pageNumber="422">Huellblattgrund</normalizedToken>
; 2. Kardone oder spanische Artischocke (
<taxonomicName id="5966BA30AD1FCE92EDB7828C03DD1A33" class="Magnoliopsida" family="Asteraceae" genus="Cynara" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="422" phylum="Tracheophyta" rank="species" sensu="stricto" species="cardunculus">
<emphasis id="685480C587C8D815666BDDB3EC339DED" italics="true" pageId="null" pageNumber="422">C. Cardunculus</emphasis>
</taxonomicName>
<taxonomicNameLabel id="85BB503BC0D82EE701B665E372E6F22C" pageId="null" pageNumber="422" sensu="stricto">s.str.</taxonomicNameLabel>
) mit fleischigen Blattstielen und Blattrippen.
</paragraph>
</subSubSection>
</treatment>
