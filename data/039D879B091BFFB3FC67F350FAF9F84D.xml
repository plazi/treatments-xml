<taxonomicName id="4C344D0E091BFFB3FAC9F111FA39F8EA" authorityName="Daniker" authorityYear="1932" box="[1308,1453,1842,1868]" class="Magnoliopsida" family="Fabaceae" genus="Nephrodesmus" kingdom="Plantae" order="Fabales" pageId="5" pageNumber="106" phylum="Tracheophyta" rank="species" species="ferrugineus">
