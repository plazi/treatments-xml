<paragraph id="8B834E6B6661FFF81984FBDEFDA1E8D8" blockId="5.[192,778,1099,1637]" pageId="5" pageNumber="4">
<emphasis id="B94892796661FFF81984FBDEFE12E8F8" box="[240,459,1133,1157]" italics="true" pageId="5" pageNumber="4">Published Record</emphasis>
. 
<collectingRegion id="49F880896661FFF818AEFBDEFDB8E8F8" box="[474,609,1133,1157]" country="United States of America" name="Minnesota" pageId="5" pageNumber="4">Minnesota</collectingRegion>
