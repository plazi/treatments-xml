<bibRefCitation id="E92D4B5AFFF2FF84AB6277BBFE0FF92B" author="Rondani, C." box="[329,500,1669,1695]" pageId="3" pageNumber="38" pagination="1 - 27" refId="ref11421" refString="Rondani, C. Sopra alcuni nuovi generi di insetti ditteri // Memoria seconda per servire alla ditterologia italiana. - Parma, 1840. - P. 1 - 27, Pl. 1." type="book chapter" year="1840">Rondani, 1840</bibRefCitation>
