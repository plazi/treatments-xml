<subSubSection id="2281606D85F1B17BE3A4DCA8E691A2E8" pageId="null" pageNumber="715" type="description">
<paragraph id="F062C90AFC7C787B89A711DB566B662E" pageId="null" pageNumber="715">
0,2-0,5 m hoch. 
<emphasis id="BB80FCEC7993A49DADAD931793247AED" italics="true" pageId="null" pageNumber="715">
Stengel 
<normalizedToken id="78941EFD7E30433BCF383AC08B42F006" originalValue="überall" pageId="null" pageNumber="715">ueberall</normalizedToken>
4kantig, die Kanten jedoch nicht 
<normalizedToken id="B67E3151390E205D9DB65083DB233D76" originalValue="geflügelt" pageId="null" pageNumber="715">gefluegelt</normalizedToken>
</emphasis>
, im untern Teil oft nur 2kantig. 
<normalizedToken id="D03D20D0AA094C0BAA8125E5A0DB6D98" originalValue="Stengelblätter" pageId="null" pageNumber="715">Stengelblaetter</normalizedToken>
2-4 cm lang, meist 
<normalizedToken id="B98DC8E4EC11A659E273B9CB25D984AD" originalValue="1½" pageId="null" pageNumber="715">11/2</normalizedToken>
mal so lang wie breit, 
<emphasis id="81EB7295A27C2961BB617A6D2CB6DF04" italics="true" pageId="null" pageNumber="715">mit flachem. Rand</emphasis>
(frisches Material!). 
<normalizedToken id="B4C59CA9A3989C9980FEEB8162BF3649" originalValue="Kelchblätter" pageId="null" pageNumber="715">Kelchblaetter</normalizedToken>
4-6 mm lang, etwa 2mal so lang wie breit, 
<emphasis id="F1262CBC7FCA993D53F82C9E0E24BEE3" italics="true" pageId="null" pageNumber="715">oval oder mit stumpfer Spitze</emphasis>
, meist ohne feine 
<normalizedToken id="6E26835A71AA4BB43D561A1892D55656" originalValue="Zähne" pageId="null" pageNumber="715">Zaehne</normalizedToken>
. 
<normalizedToken id="A4E74F9998DE2A322F6008CFD1720C15" originalValue="Kronblätter" pageId="null" pageNumber="715">Kronblaetter</normalizedToken>
2-3mal so lang wie der Kelch, 
<emphasis id="03EC68BB1EA3ECF7EC9CEBC5B4E26646" italics="true" pageId="null" pageNumber="715">symmetrisch</emphasis>
, nicht mit einseitig 
<normalizedToken id="630966CC084870EE94A7086E7C6FA451" originalValue="gezähntem" pageId="null" pageNumber="715">gezaehntem</normalizedToken>
Rand.
</paragraph>
<paragraph id="EA532D580913D19005FE3CFD717FE947" pageId="null" pageNumber="715">
<emphasis id="41A81D939A42F3485AEF4238C142A87D" italics="true" pageId="null" pageNumber="715">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="29D72FA8FD31EBC08753409123F6E6DC" italics="true" pageId="null" pageNumber="715">16:</emphasis>
Material aus 
<normalizedToken id="1376C4FC90D031D383C88684D493E3CA" originalValue="Dänemark" pageId="null" pageNumber="715">Daenemark</normalizedToken>
, Pollenmeiose normal (Nielsen 1924), aus verschiedenen Gebieten Europas (Noack 1939), aus England (Chattaway 1926, Robson 1957, Robson 1958), aus Finnland (Sorsa 1962).
</paragraph>
<paragraph id="E2E09F9310E8430C82772C7B1CFA84B5" pageId="null" pageNumber="715">
<emphasis id="D4050CFBEAF378F060C3F8C3640C6E90" italics="true" pageId="null" pageNumber="715">Standort.</emphasis>
Montan (selten unter 900 m), subalpin und alpin. Feuchte bis nasse 
<normalizedToken id="5BE7FD55D16C1C76E84DE4443C2E10D8" originalValue="Böden" pageId="null" pageNumber="715">Boeden</normalizedToken>
. Wildheurasen, Fettwiesen, 
<taxonomicName id="F90671671BEC626D793337156A2C05F4" class="Magnoliopsida" family="Betulaceae" genus="Alnus" kingdom="Plantae" order="Fagales" pageId="null" pageNumber="715" phylum="Tracheophyta" rank="species" species="viridis">
<emphasis id="1F0B64D34F6EDFB8667E52123D8114FD" italics="true" pageId="null" pageNumber="715">Alnus viridis</emphasis>
</taxonomicName>
- 
<normalizedToken id="CD771BDA5F98309CA51FE10FDC6CD149" originalValue="Gebüsch" pageId="null" pageNumber="715">Gebuesch</normalizedToken>
, Hochstaudenfluren, Waldlichtungen.
</paragraph>
<paragraph id="EC208647D6DF02846CE95F5C57604C3C" pageId="null" pageNumber="715">
<emphasis id="3BCB3B6E18DD6BFB12728E9D70B98E41" italics="true" pageId="null" pageNumber="715">Verbreitung. Eurosibirische Pflanze:</emphasis>
<normalizedToken id="842A6D555F4582C6AFC7BE4006BB93F6" originalValue="Nordwärts" pageId="null" pageNumber="715">Nordwaerts</normalizedToken>
bis 70° NB; 
<normalizedToken id="AC03136DE72D6C5429558808F7495CD7" originalValue="ostwärts" pageId="null" pageNumber="715">ostwaerts</normalizedToken>
bis Obgebiet; 
<normalizedToken id="9355778701AEB8EFBB83F47B25DE3109" originalValue="südwärts" pageId="null" pageNumber="715">suedwaerts</normalizedToken>
bis 
<normalizedToken id="DAB941D56018B66B84C5D02605B4A404" originalValue="Pyrenäen" pageId="null" pageNumber="715">Pyrenaeen</normalizedToken>
, Sardinien, Griechenland. - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="3E561B2801278B3B6F475909AB1C0242" originalValue="häufig" pageId="null" pageNumber="715">haeufig</normalizedToken>
. Angaben aus dem Schwarzwald unsicher (Sulger 
<normalizedToken id="CE23FEC899FC5727745651A5F074C833" originalValue="Büel" pageId="null" pageNumber="715">Bueel</normalizedToken>
1969 
<normalizedToken id="184F5F8532D64B08733CF567AC517917" originalValue="mündlich" pageId="null" pageNumber="715">muendlich</normalizedToken>
).
</paragraph>
</subSubSection>
