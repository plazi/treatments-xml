<subSubSection id="BC5B4EE20579CF1985F71C4DAD995FCA" pageId="null" pageNumber="175" type="description">
<paragraph id="3F1B6EC6736249006CF826384E1AECFA" pageId="null" pageNumber="175">
Unterscheidet sich von 
<taxonomicName id="0BBE9BC729EC057182201FF60D97AE2C" class="Magnoliopsida" family="Scrophulariaceae" genus="Verbascum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="175" phylum="Tracheophyta" rank="species" species="blattaria">
<emphasis id="FEF8E4C651FD898A1CA13B9DD556FC11" italics="true" pageId="null" pageNumber="175">V. Blattaria</emphasis>
</taxonomicName>
(Nr. 1) nur durch die 
<emphasis id="501B619F717D9E6693D56E33B43F7A11" italics="true" pageId="null" pageNumber="175">
<normalizedToken id="619C505FF75991175C8A7F151D76BB2E" originalValue="kürzer" pageId="null" pageNumber="175">kuerzer</normalizedToken>
gestielten 
<normalizedToken id="A5A918A9DE9A795E53FF8C973ACEF23E" originalValue="Blüten" pageId="null" pageNumber="175">Blueten</normalizedToken>
</emphasis>
(
<emphasis id="B5C29AD93A908A711C06E3900ACD3616" italics="true" pageId="null" pageNumber="175">
die 
<normalizedToken id="EF7E82DF0337AD9F931E3DE69AFFA275" originalValue="längsten" pageId="null" pageNumber="175">laengsten</normalizedToken>
Stiele zur Fruchtzeit 2
</emphasis>
- 
<emphasis id="43D9B0E966662AA7428C3A4C30C626C5" italics="true" pageId="null" pageNumber="175">
6 mm lang, so lang oder 
<normalizedToken id="69CE2C373774EE1413C625BE9BF823FE" originalValue="kürzer" pageId="null" pageNumber="175">kuerzer</normalizedToken>
als der Kelch
</emphasis>
), 
<emphasis id="500E7ECCD45211EFBDA7FD753FE31342" italics="true" pageId="null" pageNumber="175">die zu 1</emphasis>
- 
<emphasis id="7D10CACEFC53A9952150E66198934EFF" italics="true" pageId="null" pageNumber="175">4 in den Achseln der obern 8</emphasis>
- 
<emphasis id="07D964C2A21F75933DA5355D2382C0B1" italics="true" pageId="null" pageNumber="175">
15 mm langen 
<normalizedToken id="F7273FFDB78110B977C489A89BEDA58F" originalValue="Blätter" pageId="null" pageNumber="175">Blaetter</normalizedToken>
stehen
</emphasis>
, und durch die 
<emphasis id="1FF604F24F1E5BE4B5F969636C88D4B1" italics="true" pageId="null" pageNumber="175">
<normalizedToken id="0F723B4435346A2231F146151156F192" originalValue="größere" pageId="null" pageNumber="175">groessere</normalizedToken>
Krone
</emphasis>
(
<emphasis id="27D68BAB4DF2F329F64CCD76E5CCBDEE" italics="true" pageId="null" pageNumber="175">3</emphasis>
- 
<emphasis id="DAD7C0279D1B5E56B2BBF10A848E4E57" italics="true" pageId="null" pageNumber="175">4 cm im Durchmesser</emphasis>
). - 
<normalizedToken id="D781D30FD7E7CC9AF14A1D406F673D0F" originalValue="Blüte" pageId="null" pageNumber="175">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="14C00FE8C7672419BE9CAF282F5816FD" originalValue="früher" pageId="null" pageNumber="175">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="DCEC03238EE304598619D5F47DCC26CE" pageId="null" pageNumber="175">
<emphasis id="620FB8241EE4B6483A61B3CE51607293" italics="true" pageId="null" pageNumber="175">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="EDC98F3ABAEF9F74E18DBFC1D9BD3869" italics="true" pageId="null" pageNumber="175">32:</emphasis>
Material aus botanischen 
<normalizedToken id="72FFC7587D257C3C440A20BB8F79770B" originalValue="Gärten" pageId="null" pageNumber="175">Gaerten</normalizedToken>
(
<normalizedToken id="22BFB1CE3045A8E4CC0BF7E57E0A174D" originalValue="Häkansson" pageId="null" pageNumber="175">Haekansson</normalizedToken>
1926). 
<emphasis id="A8FF6846ADC60DB19AF256D9D7271BE3" italics="true" pageId="null" pageNumber="175">2n</emphasis>
= 
<emphasis id="E125C7BB2B05D69C7922EC6DB031D501" italics="true" pageId="null" pageNumber="175">56:</emphasis>
Material aus botanischem Garten (Arts-Damler 1960).
</paragraph>
<paragraph id="2581654385C5FB2D8C1B492883867599" pageId="null" pageNumber="175">
<emphasis id="D8242BD5AD71BF8EADD5FA8DB0C69062" italics="true" pageId="null" pageNumber="175">Standort.</emphasis>
Kollin. Magere, kalkarme 
<normalizedToken id="66BA5463BBE8C3EED7B6A2CDC07EF2E2" originalValue="Böden" pageId="null" pageNumber="175">Boeden</normalizedToken>
in warmen Lagen. Unbebaute Orte, 
<normalizedToken id="D65673F22DBFEBBD529FA0A3A0B50D19" originalValue="Äcker" pageId="null" pageNumber="175">Aecker</normalizedToken>
.
</paragraph>
<paragraph id="D7576D90EF3C625D44E1D148695094A3" pageId="null" pageNumber="175">
<emphasis id="7CD23048A0844751C62574E178565A55" italics="true" pageId="null" pageNumber="175">Verbreitung. Westmediterrane Pflanze:</emphasis>
<normalizedToken id="F6264B7C88AA1803D88E43C9DF7359B4" originalValue="Süd-" pageId="null" pageNumber="175">Sued-</normalizedToken>
und 
<normalizedToken id="14B08E392CAEC1AE859D51932D58E1CF" originalValue="ostwärts" pageId="null" pageNumber="175">ostwaerts</normalizedToken>
bis Marokko, Algerien, Sizilien, Kroatien, 
<normalizedToken id="FAB4187F64966202E4AB70B196C8575B" originalValue="Südalpen" pageId="null" pageNumber="175">Suedalpen</normalizedToken>
, Jura; 
<normalizedToken id="0C027F801617218FFFF06810647B780D" originalValue="nordwärts" pageId="null" pageNumber="175">nordwaerts</normalizedToken>
bis 
<normalizedToken id="1BDFE857719F3F136478722C5420379A" originalValue="Südengland" pageId="null" pageNumber="175">Suedengland</normalizedToken>
. - Im Gebiet: 
<normalizedToken id="DF3F46C1ABA15728A8812B4A4C2546E8" originalValue="Elsaß" pageId="null" pageNumber="175">Elsass</normalizedToken>
(
<normalizedToken id="DD5B3FC9B16B30065B0E4AFA5B181636" originalValue="Mülhausen" pageId="null" pageNumber="175">Muelhausen</normalizedToken>
), 
<normalizedToken id="74228A8045F9D5459EBB43047CC0AB60" originalValue="Dép" pageId="null" pageNumber="175">Dep</normalizedToken>
. Ain und Jura (unteres Doubs- und 
<normalizedToken id="09280B2A48879BCD292024560845F585" originalValue="Saônegebiet" pageId="null" pageNumber="175">Saonegebiet</normalizedToken>
), sonst gelegentlich adventiv.
</paragraph>
</subSubSection>
