<subSubSection id="141DA6316708AC04BF2220F2A795FA3F" pageId="null" pageNumber="86" type="description">
<paragraph id="F4442321D30B21282B390902F4283ECE" pageId="null" pageNumber="86">
<emphasis id="F58F3E172595E4F1EBD389CF7312E519" italics="true" pageId="null" pageNumber="86">
<normalizedToken id="219F5ADD2F37715BA3F3CC8AD0244C50" originalValue="Grundständige" pageId="null" pageNumber="86">Grundstaendige</normalizedToken>
<normalizedToken id="B8135EA5CB9A85E5383F2C65686DD10C" originalValue="Blätter" pageId="null" pageNumber="86">Blaetter</normalizedToken>
meist bis auf den Grund 3teilig
</emphasis>
, oft mit etwas gestielten Abschnitten; die beiden seitlichen Abschnitte bis mindestens zur Mitte 2teilig, wie der Mittelabschnitt mit langen 
<normalizedToken id="5187E3F0ECD98CA94AA14480688CE065" originalValue="Zähnen" pageId="null" pageNumber="86">Zaehnen</normalizedToken>
. 
<emphasis id="D1F58F61DB58C88480241609FF921B0A" italics="true" pageId="null" pageNumber="86">
Abschnitte der untern 
<normalizedToken id="DFEFFF9B36AAB83DF31100D840AB8166" originalValue="Stengelblätter" pageId="null" pageNumber="86">Stengelblaetter</normalizedToken>
schmal lanzettlich
</emphasis>
(
<emphasis id="19543497991EE6E5AA9A8F01B6C7F230" italics="true" pageId="null" pageNumber="86">mindestens 10mal so lang wie breit</emphasis>
), oft mit 1-2 langen 
<normalizedToken id="E969B5097D1675D71092E228FEF25CF1" originalValue="Zähnen" pageId="null" pageNumber="86">Zaehnen</normalizedToken>
. 
<emphasis id="B7902ABF283B0919250BE78EF734EA50" italics="true" pageId="null" pageNumber="86">
<normalizedToken id="20E9A90FEE2062FA9EDD56223103043E" originalValue="Blütenboden" pageId="null" pageNumber="86">Bluetenboden</normalizedToken>
kahl
</emphasis>
.
</paragraph>
<paragraph id="12AA52CD110AE83A3F57E0175FB9984B" pageId="null" pageNumber="86">
<emphasis id="E5FE9F4BE4D17A185EB9EFB86C9126BB" italics="true" pageId="null" pageNumber="86">Zytologische Angaben</emphasis>
. Siehe unter der Artengruppe.
</paragraph>
<paragraph id="119B10679D1390001E2CBD87B318312E" pageId="null" pageNumber="86">
<emphasis id="A086C5AC5D443ECCBB4E8BE3AA1A63E7" italics="true" pageId="null" pageNumber="86">Standort</emphasis>
. Kollin, selten montan (Jura). Feuchte, lehmige, 
<normalizedToken id="609BFAFAB637E7CF38995ABBE676650D" originalValue="nährstoffreiche" pageId="null" pageNumber="86">naehrstoffreiche</normalizedToken>
<normalizedToken id="A6D02B56BA3F9E0AED2E740BF6698D70" originalValue="Böden" pageId="null" pageNumber="86">Boeden</normalizedToken>
. Die typische Sippe bevorzugt unbeschattete Stellen. Feuchte Laubmisch- und 
<normalizedToken id="9A5E42B435FAEC5795CDC8260D29EEA7" originalValue="Auenwälder" pageId="null" pageNumber="86">Auenwaelder</normalizedToken>
, 
<normalizedToken id="333003F469648B60300E2F16D7F6F29B" originalValue="Gebüsche" pageId="null" pageNumber="86">Gebuesche</normalizedToken>
, 
<normalizedToken id="7B4A8A64D1D8C2B0400E4A8A1EE590CD" originalValue="Bachgehölze" pageId="null" pageNumber="86">Bachgehoelze</normalizedToken>
, feuchte Fettwiesen.
</paragraph>
<paragraph id="2E0F986932F6A433203AF21B051A8DEB" pageId="null" pageNumber="86">
<emphasis id="8396373F11BB0DF8A1E3C9E4D5327A8A" italics="true" pageId="null" pageNumber="86">Verbreitung. Eurosibirische Pflanze:</emphasis>
Ganz Europa (im Mittelmeergebiet nur in den Gebirgen), Kaukasus, durch 
<normalizedToken id="D16805E1422E620494BAE1B7480C2E0D" originalValue="Südsibirien" pageId="null" pageNumber="86">Suedsibirien</normalizedToken>
<normalizedToken id="AD687785FD743080C274016B1D3B4B16" originalValue="ostwärts" pageId="null" pageNumber="86">ostwaerts</normalizedToken>
bis ins Gebiet des Jenissei; 
<normalizedToken id="6ABB2C4C3329A4B48B269506ADC2F30B" originalValue="Grönland" pageId="null" pageNumber="86">Groenland</normalizedToken>
. Verbreitungskarte von Meusel (1965). - Im Gebiet: Oberrheinische Tiefebene, Mittelland. In 
<normalizedToken id="1BE1810A6E57616E961B01C5DAF62E85" originalValue="ähnlichen" pageId="null" pageNumber="86">aehnlichen</normalizedToken>
Sippen auch im Jura, in den Vogesen, im Schwarzwald, in der Baar, im Hegau, Bodenseegebiet und Rhonetal (Waadt).
</paragraph>
</subSubSection>
