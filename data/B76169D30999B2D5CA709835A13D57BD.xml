<subSubSection id="60FC520374A01AB2C9CCC17E2E7A56AD" pageId="null" pageNumber="460" type="description">
<paragraph id="B668FB3327FB157BC585D7B07FD90607" pageId="null" pageNumber="460">
Die Gattung 
<taxonomicName id="7827C8DF0104A645225E775115543637" class="Magnoliopsida" family="Asteraceae" genus="Cnicus" higherTaxonomySource="GBIF" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="460" phylum="Tracheophyta" rank="genus">
<emphasis id="82C8817D4A4118982A92D5299769F885" italics="true" pageId="null" pageNumber="460">Cnicus</emphasis>
</taxonomicName>
<normalizedToken id="1CA99B2AB7669CA9367DED4759C349B8" originalValue="umfaßt" pageId="null" pageNumber="460">umfasst</normalizedToken>
nur 
<emphasis id="01E09F2605DDF39865DC3C208BAEBEAA" italics="true" pageId="null" pageNumber="460">1 Art.</emphasis>
Sie unterscheidet sich von 
<taxonomicName id="66AD17198613BD6E530264F6FB02B2A3" class="Magnoliopsida" family="Asteraceae" genus="Carthamus" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="460" phylum="Tracheophyta" rank="genus">
<emphasis id="A12AF88DA73E791291625DEF24E598DF" italics="true" pageId="null" pageNumber="460">Carthamus</emphasis>
</taxonomicName>
(S. 458) nur durch den 
<taxonomicName id="D62EED3B5C995A9FE7E988AEA0EC2AC7" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="460" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
, 
<emphasis id="D874490B584878D9FEF774672C890CB8" italics="true" pageId="null" pageNumber="460">
der aus 10 langen 
<normalizedToken id="6484F8F1A56C76A8A904E4B8BDCE2B60" originalValue="äußern" pageId="null" pageNumber="460">aeussern</normalizedToken>
und 10 kurzen innern Borsten besteht.
</emphasis>
</paragraph>
