<paragraph id="D126FA521B0DFFC1F7B9F60CF6CDF534" blockId="19.[2089,2683,2563,2989]" pageId="19" pageNumber="530">
<taxonomicName id="169981D11B0DFFC1F7B9F60CF76DF546" authorityName="Thomas" authorityYear="1920" box="[2093,2301,2685,2714]" class="Mammalia" family="Ctenomyidae" genus="Ctenomys" kingdom="Animalia" order="Rodentia" pageId="19" pageNumber="530" phylum="Chordata" rank="species" species="coludo">Ctenomys coludo</taxonomicName>
