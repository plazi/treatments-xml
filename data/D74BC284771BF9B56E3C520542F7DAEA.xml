<subSubSection id="7D46B88039F26406F2138242AC008C9C" pageId="null" pageNumber="33" type="description">
<paragraph id="03BB4931C605157662D55875DE1724DA" pageId="null" pageNumber="33">
30-80 cm hoch. 
<normalizedToken id="AFE4CBDA56619FA0162F8EF519F8E6F1" originalValue="Grundständige" pageId="null" pageNumber="33">Grundstaendige</normalizedToken>
<normalizedToken id="7AA10D9E55DD6538E9B349F210A25008" originalValue="Blätter" pageId="null" pageNumber="33">Blaetter</normalizedToken>
wie bei 
<emphasis id="8AE861D07FE51B3261654E0E5BE3BAC8" italics="true" pageId="null" pageNumber="33">
<taxonomicName id="EAE692502C822A6C97F1544BE93E70AE" class="Magnoliopsida" family="Ranunculaceae" genus="Aquilegia" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="33" phylum="Tracheophyta" rank="species" species="alpina">A. alpina</taxonomicName>
;
</emphasis>
die rundlichen 
<normalizedToken id="AD0AADE6E3DDF1245BF8362405BBCFF4" originalValue="Zähne" pageId="null" pageNumber="33">Zaehne</normalizedToken>
jedoch etwa doppelt so breit und oft auch weniger tief eingeschnitten als bei 
<emphasis id="81298271EE7929EE13467BC8998B34F0" italics="true" pageId="null" pageNumber="33">
<taxonomicName id="D526AB2244A202208BF854C263889DF2" class="Magnoliopsida" family="Ranunculaceae" genus="Aquilegia" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="33" phylum="Tracheophyta" rank="species" species="alpina">A. alpina</taxonomicName>
.
</emphasis>
Stengel 1, seltener 2-3, meist reich verzweigt. Untere 
<normalizedToken id="DFCB3D1254BFF5DC1AE009842DFE10FF" originalValue="Stengelblätter" pageId="null" pageNumber="33">Stengelblaetter</normalizedToken>
wie die 
<normalizedToken id="5FB646D9958C5C3145A782AC0745A2E7" originalValue="grundständigen" pageId="null" pageNumber="33">grundstaendigen</normalizedToken>
, obere einfacher bis ungeteilt (schmal oval). 
<normalizedToken id="6B8C8A0EBE71AA0CBE8798E682169FA0" originalValue="Blüten" pageId="null" pageNumber="33">Blueten</normalizedToken>
bis 12; 
<emphasis id="6BD00FD4CD76D6D6A6967ED1E2A4BBE5" italics="true" pageId="null" pageNumber="33">Durchmesser 3-5 cm.</emphasis>
<normalizedToken id="3A1C7BC3B784FA0BE2F6BC45E6E46872" originalValue="Perigonblätter" pageId="null" pageNumber="33">Perigonblaetter</normalizedToken>
spitz, 1,5-2,5 cm lang, 
<emphasis id="6C8C4AEABCEF2D26D075E0DB89955773" italics="true" pageId="null" pageNumber="33">in der Mitte 1-1,5 cm breit.</emphasis>
<normalizedToken id="07A07EB6E193F9A0C86049A7B8E104F4" originalValue="Honigblätter" pageId="null" pageNumber="33">Honigblaetter</normalizedToken>
wenig ausgerandet; Sporn 1-1,5 cm lang, 
<emphasis id="2BE78DEDF4E51EF3B89814677AB59B5C" italics="true" pageId="null" pageNumber="33">
an der Spitze hakig 
<normalizedToken id="D82DD81BEBC348CE8833A0B16224DD5A" originalValue="gekrümmt" pageId="null" pageNumber="33">gekruemmt</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="8414420B0AFA61F1212FCDDC8A7ED6BD" pageId="null" pageNumber="33">
In die Artengruppe der 
<taxonomicName id="2A35144186B78C60BF087AAA85DDF61C" class="Magnoliopsida" family="Ranunculaceae" genus="Aquilegia" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="33" phylum="Tracheophyta" rank="species" species="vulgaris">
<emphasis id="5446AE84C8616BE29132A9ECCE5AD959" italics="true" pageId="null" pageNumber="33">A. vulgaris</emphasis>
</taxonomicName>
<normalizedToken id="DEE425E081995BF8D7CA15B15233874C" originalValue="gehören" pageId="null" pageNumber="33">gehoeren</normalizedToken>
mehrere Arten in 
<normalizedToken id="75E86CCE10505EC76002E8B4A4820935" originalValue="Südosteuropa" pageId="null" pageNumber="33">Suedosteuropa</normalizedToken>
und Asien.
</paragraph>
