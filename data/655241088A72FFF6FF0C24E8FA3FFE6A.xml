<taxonomicName id="2AFB8B9D8A72FFF5FF0C24E8FE6AFA86" authority="Cumming &amp; Brooks 2022" box="[151,457,1267,1294]" class="Insecta" family="Dolichopodidae" genus="Microphorella" kingdom="Animalia" order="Diptera" pageId="1" pageNumber="198" phylum="Arthropoda" rank="species" species="breviradia">
<emphasis id="DF8F2C0C8A72FFF5FF0C24E8FE6AFA86" bold="true" box="[151,457,1267,1294]" italics="true" pageId="1" pageNumber="198">Microphorella breviradia</emphasis>
