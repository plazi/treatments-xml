<taxonomicName id="946321EBCCC7AF1DC9C97E6C1DF238B7" authority="L." class="Magnoliopsida" family="Adoxaceae" genus="Sambucus" kingdom="Plantae" order="Dipsacales" pageId="null" pageNumber="313" phylum="Tracheophyta" rank="species" species="ebulus">
