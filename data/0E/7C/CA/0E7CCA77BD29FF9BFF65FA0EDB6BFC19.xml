<subSubSection lastPageId="5" lastPageNumber="582" pageId="2" pageNumber="579" type="description">
<paragraph blockId="2.[151,881,1454,1517]" box="[151,274,1491,1517]" pageId="2" pageNumber="579">
(
<figureCitation box="[159,239,1491,1517]" captionStart="FIGURE 2" captionStartId="3.[151,250,1708,1732]" captionTargetBox="[151,1437,179,1682]" captionTargetId="figure-19@3.[151,1437,179,1682]" captionTargetPageId="3" captionText="FIGURE 2. Nigrimacula platycerca sp. nov.: A–B, H–I. head and pronotum: A, H. lateral view; B, I. dorsal view; C–G: apex of abdomen: C. dorsal view; D. dorso-apical view; E. dorso-lateral view; F. ventral view; G. lateral view; J. subgenital plate; K. ovipositor in lateral view. A–G. male; H–K. female." pageId="2" pageNumber="579">Figs. 2</figureCitation>
