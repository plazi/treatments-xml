<taxonomicName authority="Duan &amp; Guo &amp; Shi, 2022" authorityName="Duan &amp; Guo &amp; Shi" authorityYear="2022" box="[1160,1400,1956,1980]" class="Insecta" family="Tettigoniidae" genus="Nigrimacula" kingdom="Animalia" order="Orthoptera" pageId="4" pageNumber="581" phylum="Arthropoda" rank="species" species="platycerca" status="sp. nov.">
