<subSubSection pageId="8" pageNumber="183" type="discussion">
<paragraph blockId="8.[323,1719,462,981]" pageId="8" pageNumber="183">
<materialsCitation country="Guam" location="Fullaway" pageId="8" pageNumber="183" specimenCount="1">
The subspecies of this black wood ant was described from 
<specimenCount box="[1463,1637,836,879]" pageId="8" pageNumber="183" type="generic">specimens</specimenCount>
collected in 
<collectingCountry box="[488,592,887,929]" name="Guam" pageId="8" pageNumber="183">Guam</collectingCountry>
by 
<location LSID="urn:lsid:plazi:treatment:0E4F7F497E6C5A27B411FE4A13E17581:833998847E6C5A27B7CBFCF3156C75F5" box="[665,827,887,929]" country="Guam" name="Fullaway" pageId="8" pageNumber="183">Fullaway</location>
in 1911
</materialsCitation>
. It is not so abundant as C. 
<emphasis italics="true" pageId="8" pageNumber="183">
<taxonomicName baseAuthorityName="F.Smith" baseAuthorityYear="1857" class="Insecta" family="Formicidae" genus="Camponotus" kingdom="Animalia" order="Hymenoptera" pageId="8" pageNumber="183" phylum="Arthropoda" rank="species" species="irritans" subGenus="Tanaemyrmex">(Tanaemyrmex) irritans chlorotirns</taxonomicName>
,
</emphasis>
but we collected it in several localities.
</paragraph>
</subSubSection>
