Node 110 = 
<taxonomicName box="[309,474,1225,1249]" class="Actinopterygii" family="Stromateidae" kingdom="Animalia" order="Perciformes" pageId="111" pageNumber="952" phylum="Chordata" rank="family">Stromateidae</taxonomicName>
</emphasis>
