<subSubSection id="060D1058CD2B31073E373A193FDAF5B1" pageId="null" pageNumber="763" type="description">
<paragraph id="160E26E731787E037195184B1E68B9D5" pageId="null" pageNumber="763">
Unterscheidet sich von 
<taxonomicName id="69BD9C949E1EF3634786F50B8617257B" class="Magnoliopsida" family="Amaranthaceae" genus="Atriplex" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="763" phylum="Tracheophyta" rank="species" species="oblongifolia">
<emphasis id="F8330DDE9B24B1993173B0F4B6E1F18E" italics="true" pageId="null" pageNumber="763">A. oblongifolia</emphasis>
</taxonomicName>
(Nr. 3) durch folgende Merkmale: 
<emphasis id="42A572B739364AE6AF95C63293FF4948" italics="true" pageId="null" pageNumber="763">
<normalizedToken id="447EC5C566601CE0E9F40E7D3768F2BE" originalValue="Vorblätter" pageId="null" pageNumber="763">Vorblaetter</normalizedToken>
in
</emphasis>
⅓- 
<normalizedToken id="5CF6AF19818983324AECA80E935FF5CA" originalValue="½" pageId="null" pageNumber="763">1/2</normalizedToken>
<emphasis id="960AF8EF4B9AAFFD93CC484FF6ABA2F4" italics="true" pageId="null" pageNumber="763">
der 
<normalizedToken id="801107717A9E5296AB50A14A8152BC1E" originalValue="Länge" pageId="null" pageNumber="763">Laenge</normalizedToken>
verwachsen
</emphasis>
, bis 7 mm lang, 
<emphasis id="D4430687C042D988D50A5D1DB8F5290C" italics="true" pageId="null" pageNumber="763">
oft mit 
<normalizedToken id="33EA03230A7A091A17F098EA751C121D" originalValue="Anhängseln" pageId="null" pageNumber="763">Anhaengseln</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="A523AFB12243D3B959BBB70E4D1873C2" originalValue="Blüte" pageId="null" pageNumber="763">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="E15A257491BADE0F1BB9D6A18A523D7E" pageId="null" pageNumber="763">
<emphasis id="24E38F13E806DC9ED53D3C7C631BD796" italics="true" pageId="null" pageNumber="763">Zytologische Angaben. 2n = 36:</emphasis>
Material aus Nordamerika (Cooper 1935), aus Island (
<normalizedToken id="F26B4A9E06C8052A9EE68049EB5D7AAD" originalValue="Löve" pageId="null" pageNumber="763">Loeve</normalizedToken>
und 
<normalizedToken id="2819BBB92212225141475E63B9C61CE8" originalValue="Löve" pageId="null" pageNumber="763">Loeve</normalizedToken>
1956b), aus England (Hulme 1958).
</paragraph>
<paragraph id="D794B8CE811E7415C0C4A57EB948D871" pageId="null" pageNumber="763">
<emphasis id="8D553865DB386C342FA4D56BFFFE975C" italics="true" pageId="null" pageNumber="763">Standort.</emphasis>
Kollin, montan und subalpin. 
<normalizedToken id="16ECA60461A28196E6A6AA5FCDE88153" originalValue="Nährstoffreiche" pageId="null" pageNumber="763">Naehrstoffreiche</normalizedToken>
<normalizedToken id="6329103F245BCA3143A6FE9E06F51F87" originalValue="Böden" pageId="null" pageNumber="763">Boeden</normalizedToken>
. 
<normalizedToken id="CA4C33D18515C728B5132271955A6BCA" originalValue="Äcker" pageId="null" pageNumber="763">Aecker</normalizedToken>
, 
<normalizedToken id="E7A941EAD8C4D2FD284B08BB223007D7" originalValue="Gärten" pageId="null" pageNumber="763">Gaerten</normalizedToken>
, 
<normalizedToken id="316C22052D90EE27E81F6CA87BCEAA24" originalValue="Wegränder" pageId="null" pageNumber="763">Wegraender</normalizedToken>
, 
<normalizedToken id="A660D9FD68103A6098106333D26165C5" originalValue="Schuttplätze" pageId="null" pageNumber="763">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="3CEDB933901E51764002A193ACADD33E" pageId="null" pageNumber="763">
<emphasis id="39B3DDE332ADC8804B831FC3180E484A" italics="true" pageId="null" pageNumber="763">
Verbreitung. 
<normalizedToken id="375FAE2533659CAFF6DBA4AD200B3CF8" originalValue="Ursprünglich" pageId="null" pageNumber="763">Urspruenglich</normalizedToken>
wahrscheinlich asiatische Pflanze;
</emphasis>
heute durch ganz Eurasien und Nordamerika verbreitet. - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="74C1E81745F4FB32E38137BB0B1BB49A" originalValue="häufig" pageId="null" pageNumber="763">haeufig</normalizedToken>
in den 
<normalizedToken id="F12FFF2F8C62D1D274AD69CE33790172" originalValue="wärmeren" pageId="null" pageNumber="763">waermeren</normalizedToken>
Gegenden.
</paragraph>
<paragraph id="FAB196CC84C9DA4A2429E5DE9418821A" pageId="null" pageNumber="763">
<emphasis id="14990C62863E5E7B368CBFC54B1C0806" italics="true" pageId="null" pageNumber="763">Bemerkungen.</emphasis>
Im Gebiet verbreitet wie 
<taxonomicName id="88752DF589DDC7F9158785F364696EA8" class="Magnoliopsida" family="Amaranthaceae" genus="Atriplex" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="763" phylum="Tracheophyta" rank="species" species="patula">
<emphasis id="867E6BACE231299F1DFD311638268B10" italics="true" pageId="null" pageNumber="763">A. patula</emphasis>
</taxonomicName>
ist 
<taxonomicName id="75FD0DB5D07A5620DEF0AAEE8A4A041A" authority="L." authorityName="L." class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="763" phylum="Chordata" rank="species" species="hastata">
<emphasis id="F93939D29C7DC2C39D93CBD66199D370" italics="true" pageId="null" pageNumber="763">A. hastata</emphasis>
<authorityName id="33EDDE2BF0E969B8720E5CC33D982808" pageId="null" pageNumber="763">L.</authorityName>
</taxonomicName>
; da sich 
<taxonomicName id="1664E958C37B1BC677B1E1B3EC6422D7" class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="763" phylum="Chordata" rank="species" species="hastata">
<emphasis id="CAAF91ADFD6835315AABAEDEC27A6EDD" italics="true" pageId="null" pageNumber="763">A. hastata</emphasis>
</taxonomicName>
nur in variablen Merkmalen (die meisten 
<normalizedToken id="E490D0466DBD761E048E111A5FD105D6" originalValue="Blätter" pageId="null" pageNumber="763">Blaetter</normalizedToken>
<normalizedToken id="A0129E5A4CB8D2D74824203C7EDA8B20" originalValue="gegenständig" pageId="null" pageNumber="763">gegenstaendig</normalizedToken>
, 
<normalizedToken id="4DF4F5D1BC476CA834662880834786AD" originalValue="Vorblätter" pageId="null" pageNumber="763">Vorblaetter</normalizedToken>
2-5 mm lang) von der vielgestaltigen 
<taxonomicName id="084B101F3F3B8846259976279FAF720E" class="Magnoliopsida" family="Amaranthaceae" genus="Atriplex" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="763" phylum="Tracheophyta" rank="species" species="patula">
<emphasis id="ED0DE0ED15D442F2C2DFB4DB7263F9E8" italics="true" pageId="null" pageNumber="763">A. patula</emphasis>
</taxonomicName>
unterscheidet und Bastarde nachgewiesen sind (Hulme 1958), wird 
<taxonomicName id="676F5410CBAAFBD0D5C9029BEB200E70" class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="763" phylum="Chordata" rank="species" species="hastata">
<emphasis id="843568C10834E30F50A54C2B24605DB2" italics="true" pageId="null" pageNumber="763">A. hastata</emphasis>
</taxonomicName>
oft nur als 
<normalizedToken id="E869DE34E058E4F7E7AB874C9C7A9ABA" originalValue="Varietät" pageId="null" pageNumber="763">Varietaet</normalizedToken>
von 
<taxonomicName id="C528C7F87CC432EA5838E53CE3D984F9" class="Magnoliopsida" family="Amaranthaceae" genus="Atriplex" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="763" phylum="Tracheophyta" rank="species" species="patula">
<emphasis id="0E570AABE61400E4D8B5264D66F5FB6A" italics="true" pageId="null" pageNumber="763">A. patula</emphasis>
</taxonomicName>
<normalizedToken id="4D8874042CEDAA2132ECCD7B73D78750" originalValue="aufgefaßt" pageId="null" pageNumber="763">aufgefasst</normalizedToken>
(z. B. Fernald 1950). 
<taxonomicName id="A563DB39F19553DDB9D41161FC53B2AA" class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="763" phylum="Chordata" rank="species" species="hastata">
<emphasis id="FD49793783BF5162A3220DF8DF3F2E93" italics="true" pageId="null" pageNumber="763">A. hastata</emphasis>
</taxonomicName>
besitzt nach 
<normalizedToken id="D811723B707E00CD4C24E8EDB454463F" originalValue="Zählungen" pageId="null" pageNumber="763">Zaehlungen</normalizedToken>
an Material aus Schleswig-Holstein, England, 
<normalizedToken id="0C175CC859A3944E98B3508D2F855B52" originalValue="Rumänien" pageId="null" pageNumber="763">Rumaenien</normalizedToken>
und Kanada 
<emphasis id="6DFA6BFB5EF83FC1EA4CFB8C31F330AE" italics="true" pageId="null" pageNumber="763">2n</emphasis>
= 
<emphasis id="82B4C5BD37188EDE248B962387C19902" italics="true" pageId="null" pageNumber="763">18</emphasis>
Chromosomen (vgl. 
<normalizedToken id="7903776652DB3C72D39FD74B2386B6B4" originalValue="Löve" pageId="null" pageNumber="763">Loeve</normalizedToken>
und 
<normalizedToken id="FD3D6DB10B8CBF4AD07E4F1D610E5AEF" originalValue="Löve" pageId="null" pageNumber="763">Loeve</normalizedToken>
1961, 
<normalizedToken id="F602CF2EE96FE5D0ADE0DD867AA839F3" originalValue="Löve" pageId="null" pageNumber="763">Loeve</normalizedToken>
und Solbrig 1964). 
<taxonomicName id="DB731A868543457BD04DA6ECE5429AEF" class="Magnoliopsida" family="Amaranthaceae" genus="Atriplex" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="763" phylum="Tracheophyta" rank="species" species="patula">
<emphasis id="25DB744664C1F79452C7CA6AB8FBE1F3" italics="true" pageId="null" pageNumber="763">A. patula</emphasis>
</taxonomicName>
und 
<taxonomicName id="43EEA1F8775718F8C0E013C0A4FBD2E1" class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="763" phylum="Chordata" rank="species" species="hastata">
<emphasis id="A40E4ACC858AC6CE3E37611D2EB9B455" italics="true" pageId="null" pageNumber="763">A. hastata</emphasis>
</taxonomicName>
sollten experimentell miteinander verglichen und trennende Merkmale herausgearbeitet werden.
</paragraph>
</subSubSection>
