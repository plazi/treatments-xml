<taxonomicName id="02D8949DD8259F8E846FCC097FA3C6F8" authority="Sm." class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="424" phylum="Tracheophyta" rank="species" species="davalliana">
