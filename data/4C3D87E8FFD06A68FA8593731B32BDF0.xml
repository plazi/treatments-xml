<subSubSection id="8C8E6575FFD06A6FF826907017D0B23D" pageId="43" pageNumber="801" type="discussion">
<paragraph id="C42B36FEFFD06A6FF826907017D0B23D" blockId="43.[2010,2605,1497,1926]" lastBlockId="43.[1394,2605,1931,3266]" pageId="43" pageNumber="801">
As currently recognized, 
<taxonomicName id="03944D7DFFD06A6FF69D907017F4BD78" authorityName="Leach" authorityYear="1821" box="[2401,2548,1577,1610]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="genus">Nyctophilus</taxonomicName>
includes seven species groups: 
<taxonomicName id="03944D7DFFD06A6FF680900917C3BD43" authorityName="J. E. Gray" authorityYear="1844" box="[2428,2499,1616,1649]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="major">major</taxonomicName>
, goulds, 
<taxonomicName id="03944D7DFFD06A6FF82290D9163DBDAB" authorityName="Thomas" authorityYear="1888" box="[2014,2109,1664,1689]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="microtis">microtis</taxonomicName>
, 
<taxonomicName id="03944D7DFFD06A6FF7B290D9168CBDAB" authorityName="Thomas" authorityYear="1915" box="[2126,2188,1664,1689]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="bifax">bifax</taxonomicName>
, 
<taxonomicName id="03944D7DFFD06A6FF76290D91711BDAB" authorityName="Laurie &amp; Hill" authorityYear="1954" box="[2206,2321,1664,1689]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="microdon">microdon</taxonomicName>
, 
<taxonomicName id="03944D7DFFD06A6FF6DC90D91788BDAB" authorityName="Leach" authorityYear="1821" box="[2336,2440,1664,1689]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="geoffroyi">geoffroyi</taxonomicName>
, and 
<taxonomicName id="03944D7DFFD06A6FF62B90D919FBBDF2" authorityName="McKean" authorityYear="1975" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="howensis">howensis</taxonomicName>
. 
<taxonomicName id="03944D7DFFD06A6FF7F190FA16F4BDF2" authorityName="J. E. Gray" authorityYear="1844" box="[2061,2292,1699,1728]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="major">Nyctophilus major</taxonomicName>
is in the 
<taxonomicName id="03944D7DFFD06A6FF68690FA17C3BDF2" authorityName="J. E. Gray" authorityYear="1844" box="[2426,2499,1699,1728]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="major">major</taxonomicName>
species group along with N. 
<taxonomicName id="03944D7DFFD06A6FF6EA909E176DBDDA" authorityName="Parnaby" authorityYear="2009" box="[2326,2413,1735,1768]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="corbeni">corbeni</taxonomicName>
and possibly N. 
<taxonomicName id="03944D7DFFD06A6FF7F290B7167FBC3D" authorityName="Thomas" authorityYear="1915" box="[2062,2175,1774,1807]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="daedalus">daedalus</taxonomicName>
. 
<taxonomicName id="03944D7DFFD06A6FF76A90B7172ABC3D" authorityName="Leach" authorityYear="1821" box="[2198,2346,1774,1807]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="genus">Nyctophilus</taxonomicName>
and sister genus 
<taxonomicName id="03944D7DFFD06A6FF827914F1643BC05" authorityName="Thomas" authorityYear="1914" box="[2011,2115,1814,1847]" class="Mammalia" family="Vespertilionidae" genus="Pharotis" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="genus">Pharotis</taxonomicName>
have generally been included as a separate tribe in 
<taxonomicName id="03944D7DFFD06A6FF712916417D3BC6C" authorityName="Gray" authorityYear="1821" box="[2286,2515,1853,1886]" class="Mammalia" family="Vespertilionidae" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="subFamily" subFamily="Vespertilioninae">Vespertilioninae</taxonomicName>
(
<taxonomicName id="03944D7DFFD06A6FF61191641654BCB4" authorityName="Peters" authorityYear="1865" class="Mammalia" family="Vespertilionidae" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="tribe" tribe="Nyctophilini">Nyctophilini</taxonomicName>
) or as a separate subfamily (
<taxonomicName id="03944D7DFFD06A6FF61F913C1800BC9E" class="Mammalia" family="Vespertilionidae" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="subFamily" subFamily="Nyctophilinae">Nyctophilinae</taxonomicName>
), but genetic data from 
<taxonomicName id="03944D7DFFD06A6FF8AA91D219E9BC9E" authorityName="Leach" authorityYear="1821" box="[1878,2025,1931,1964]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="genus">Nyctophilus</taxonomicName>
have recently placed it sister to 
<taxonomicName id="03944D7DFFD06A6FF65091D21BA1BCE6" authorityName="Peters" authorityYear="1867" class="Mammalia" family="Vespertilionidae" genus="Chalinolobus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="genus">Chalinolobus</taxonomicName>
in 
<taxonomicName id="03944D7DFFD06A6FFA3291EA18A0BCE6" authorityName="Gray" authorityYear="1821" box="[1486,1696,1971,2004]" class="Mammalia" family="Vespertilionidae" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="993" phylum="Chordata" rank="tribe" tribe="Vespertilionini">Vespertilionini</taxonomicName>
. 
<taxonomicName id="03944D7DFFD06A6FF94D91EA1998BCE6" authorityName="J. E. Gray" authorityYear="1844" box="[1713,1944,1971,2004]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="major">Nyctophilus major</taxonomicName>
was previously included under 
<taxonomicName id="03944D7DFFD06A6FF6A491EA1408BCE6" baseAuthorityName="E. Geoffroy" baseAuthorityYear="1806" box="[2392,2568,1971,2004]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="803" phylum="Chordata" rank="species" species="timoriensis">N. timoriensis</taxonomicName>
as a subspecies; however, the name 
<taxonomicName id="03944D7DFFD06A6FF8B9918319CABCC9" baseAuthorityName="E. Geoffroy" baseAuthorityYear="1806" box="[1861,1994,2010,2043]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="timoriensis">timoriensis</taxonomicName>
is considered a species inquirenda because of ambiguity of type locality, lack of definitive type specimen, and lack of an adequate enough description or illustration to identify the name to any currently recognized species. What was previously recognized as 
<taxonomicName id="03944D7DFFD06A6FF8609E08164AB340" baseAuthorityName="E. Geoffroy" baseAuthorityYear="1806" box="[1948,2122,2129,2162]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="803" phylum="Chordata" rank="species" species="timoriensis">N. timoriensis</taxonomicName>
has been broken into four distinct species: 
<taxonomicName id="03944D7DFFD06A6FFA1A9E211856B3AB" authorityName="J. E. Gray" authorityYear="1844" box="[1510,1622,2168,2201]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="803" phylum="Chordata" rank="species" species="major">N. major</taxonomicName>
, N. 
<taxonomicName id="03944D7DFFD06A6FF9779E2118E2B3AB" authorityName="Parnaby" authorityYear="2009" box="[1675,1762,2168,2201]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="corbeni">corbeni</taxonomicName>
, N. 
<taxonomicName id="03944D7DFFD06A6FF8EB9E211978B3AB" authorityName="Thomas" authorityYear="1915" box="[1815,1912,2168,2201]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="sherrini">sherrini</taxonomicName>
, and N. 
<taxonomicName id="03944D7DFFD06A6FF8159E211653B3AB" authorityName="Parnaby" authorityYear="2009" box="[2025,2131,2168,2201]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="shirleyae">shirleyae</taxonomicName>
. Specimens of 
<taxonomicName id="03944D7DFFD06A6FF6DD9E2117B4B3AB" authorityName="Leach" authorityYear="1821" box="[2337,2484,2168,2201]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="genus">Nyctophilus</taxonomicName>
from TimorIsland recently obtained by K. M. Helgen apparently bare resemblance to N. 
<taxonomicName id="03944D7DFFD06A6FF6219EF91424B3F3" authorityName="Kitchener, How &amp; Maharadatunkamsi" authorityYear="1991" box="[2525,2596,2208,2241]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="species" species="heran">heran</taxonomicName>
, but comparison of these specimens to other 
<taxonomicName id="03944D7DFFD06A6FF8079E9E168EB3DA" authorityName="Leach" authorityYear="1821" box="[2043,2190,2247,2280]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="43" pageNumber="801" phylum="Chordata" rank="genus">Nyctophilus</taxonomicName>
has not been done, and the name fimoriensis will continue to go unused for now. Two subspecies recognized.
</paragraph>
</subSubSection>
