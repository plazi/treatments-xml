<figureCitation id="13062A74EF3D4A5EA9F88E24FCCDFDAE" box="[742,846,583,609]" captionStart="Fig" captionStartId="18.[189,232,1875,1901]" captionTargetBox="[269,1342,290,1800]" captionTargetId="figure-14@18.[239,1349,265,1835]" captionTargetPageId="18" captionText="Fig. 16. A–B. Glyptapanteles afiamaluanus (Fullaway, 1941), holotype, ♀ (BPBM) A. Propodeum and T1–2. B. Fore wing. C. G. fullawayi Austin &amp; Dangerfield, 1992, holotype, ♂ (BPBM), dorsal scutellum, propodeum and T1–2. D. G. operculinae (Fullaway, 1941), holotype, ♀ (BPBM), dorsal scutellum, propodeum and T1–2. Reproduced from Austin &amp; Dangerfield (1992)." figureDoi="http://doi.org/10.5281/zenodo.6037105" httpUri="https://zenodo.org/record/6037105/files/figure.png" pageId="93" pageNumber="94">Fig. 16D</figureCitation>
