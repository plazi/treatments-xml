<taxonomicName id="15B34D14FFC5FFE9A2327F38939D0E09" authorityName="BERRY" authorityYear="1920" box="[827,1021,1122,1144]" pageId="12" pageNumber="1224" rank="superFamily" superFamily="Architeuthoidea">Architeuthoidea</taxonomicName>
