<subSubSection id="92FAEC3181E787E19D39EDF7A9AC8760" pageId="null" pageNumber="170" type="description">
<paragraph id="203418EFC9A6B6E70C7ADD57B5507DDD" pageId="null" pageNumber="170">
Unterscheidet sich von 
<taxonomicName id="CF8234DDD577527CE335BD3F1190FB6B" class="Magnoliopsida" family="Brassicaceae" genus="Alyssum" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="170" phylum="Tracheophyta" rank="species" species="calycinum">
<emphasis id="A52A22E1489E7722E54C08501A22812F" italics="true" pageId="null" pageNumber="170">A. calycinum</emphasis>
</taxonomicName>
(Nr. 4) durch folgende Merkmale: 
<emphasis id="051CD61C2D02D35E4D96ACB9E260877C" italics="true" pageId="null" pageNumber="170">
<normalizedToken id="954E337B8A50F2ACA1F339CAE94104C1" originalValue="Kelchblätter" pageId="null" pageNumber="170">Kelchblaetter</normalizedToken>
zur Fruchtzeit nicht mehr vorhanden;
</emphasis>
<normalizedToken id="4B093CD4A45079A126F572C01181D7E7" originalValue="Kronblätter" pageId="null" pageNumber="170">Kronblaetter</normalizedToken>
meist gelblich bleibend; 
<normalizedToken id="0A422E85D4B26BE062E85BD39BC5C7FB" originalValue="Staubfäden" pageId="null" pageNumber="170">Staubfaeden</normalizedToken>
am Grunde mit 
<normalizedToken id="3971B29F81B538DF8F41B4BD01E17337" originalValue="großem" pageId="null" pageNumber="170">grossem</normalizedToken>
Zahn; 
<emphasis id="CF8FCF12A87D389FEEC13A529B93F7B1" italics="true" pageId="null" pageNumber="170">
<normalizedToken id="AD20BE71CF0075E0BDD7F6C7E653584B" originalValue="Früchte" pageId="null" pageNumber="170">Fruechte</normalizedToken>
4-6 mm lang und 4-4,5 mm breit, mit 0,7-1,5 mm langem, nicht eingesenktem Griffel. -
</emphasis>
<normalizedToken id="847C7533F6C91F64DA085EDA2309A0BC" originalValue="Blüte" pageId="null" pageNumber="170">Bluete</normalizedToken>
: 
<normalizedToken id="30B52F99570ABE514C60F7E8BDCB93B0" originalValue="Frühling" pageId="null" pageNumber="170">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="1DD5068D39BF5BD59A4DC9A49CFC3E61" pageId="null" pageNumber="170">
<emphasis id="5046342D54CC14781F51EC0806612540" italics="true" pageId="null" pageNumber="170">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="ACAA62D65D6133E3B96818A7420BDD69" italics="true" pageId="null" pageNumber="170">16:</emphasis>
Material aus botanischen 
<normalizedToken id="5C751BD86111D7F2C12B447C8430CF0C" originalValue="Gärten" pageId="null" pageNumber="170">Gaerten</normalizedToken>
(Jaretzky 1932, Manton 1932), aus 
<normalizedToken id="8F002D34A56146639DECEDDCF0478D0E" originalValue="Südeuropa" pageId="null" pageNumber="170">Suedeuropa</normalizedToken>
(
<normalizedToken id="61FDA8066BBB9471456BF835B908A67E" originalValue="Gardé" pageId="null" pageNumber="170">Garde</normalizedToken>
und 
<normalizedToken id="6F75EB7EFD11FC319DD5A5A27A2B16A5" originalValue="Malheiros-Gardé" pageId="null" pageNumber="170">Malheiros-Garde</normalizedToken>
1953, 
<normalizedToken id="5AB30A80CD983F81082F7C9CE9F280CD" originalValue="Böcher" pageId="null" pageNumber="170">Boecher</normalizedToken>
und Larsen 1958).
</paragraph>
<paragraph id="B8DBBC645E63C4D75064AE43E9ED350A" pageId="null" pageNumber="170">
<emphasis id="DCF7F35EBFD0AE4FDF8DE004CF8593A3" italics="true" pageId="null" pageNumber="170">Standort.</emphasis>
Kollin und montan. Trockene, lockere, sandige 
<normalizedToken id="62C5257D3D0107B3543311A17622C4D6" originalValue="Böden" pageId="null" pageNumber="170">Boeden</normalizedToken>
in warmen Lagen. Trockenwiesen, Felder.
</paragraph>
<paragraph id="CE9A4F69C5E44C72939EB6D04E1BE31F" pageId="null" pageNumber="170">
<emphasis id="3C08BA312275F2A8FE78020924B1A650" italics="true" pageId="null" pageNumber="170">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="E03C97DBD7435CBFB244CC2FD2C95600" originalValue="Südeuropa" pageId="null" pageNumber="170">Suedeuropa</normalizedToken>
(
<normalizedToken id="182F9C8FE8678F4CA8857B2459214A2F" originalValue="nordwärts" pageId="null" pageNumber="170">nordwaerts</normalizedToken>
bis zur Loire und zu den Alpen); Nordwestafrika, 
<normalizedToken id="D61DD482556F4D1C1395C785323A892D" originalValue="Südwestasien" pageId="null" pageNumber="170">Suedwestasien</normalizedToken>
(
<normalizedToken id="84E819043DF0C7A490724810CB362214" originalValue="ostwärts" pageId="null" pageNumber="170">ostwaerts</normalizedToken>
bis Turkestan). - Im Gebiet: Aostatal (Gebiet von Cogne und San Martino bei Aosta), Gegend von Bergamo.
</paragraph>
</subSubSection>
