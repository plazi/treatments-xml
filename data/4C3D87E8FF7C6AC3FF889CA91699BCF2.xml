, 
<collectingCountry id="BC83766EFF7C6AC3F6BE97751783BA7B" box="[2370,2435,300,329]" name="Laos" pageId="135" pageNumber="895">Laos</collectingCountry>
, NW &amp; SW 
<collectingCountry id="BC83766EFF7C6AC3F82A9716164EBA42" box="[2006,2126,335,368]" name="Vietnam" pageId="135" pageNumber="895">Vietnam</collectingCountry>
, C Peninsular 
<collectingCountry id="BC83766EFF7C6AC3F6BE971617B5BA42" box="[2370,2485,335,368]" name="Malaysia" pageId="135" pageNumber="895">Malaysia</collectingCountry>
(along with 
<collectingRegion id="0650F81CFF7C6AC3F7E797261684BAAA" box="[2075,2180,383,408]" country="Malaysia" name="Pulau Pinang" pageId="135" pageNumber="895">Penang</collectingRegion>
I), NE &amp; SW Borneo, W Java, Bali I, N Sulawesi, and 
<collectingCountry id="BC83766EFF7C6AC3F6E097FB17B6BA8D" box="[2332,2486,418,447]" name="Philippines" pageId="135" pageNumber="895">Philippines</collectingCountry>
(Samar and 
<collectingRegion id="0650F81CFF7C6AC3F7E8979C1666BAD4" box="[2068,2150,453,486]" country="Philippines" name="Bohol" pageId="135" pageNumber="895">Bohol</collectingRegion>
Is); possibly in N 
<collectingCountry id="BC83766EFF7C6AC3F6A1979C17EDBAD4" box="[2397,2541,453,486]" name="Cambodia" pageId="135" pageNumber="895">Cambodia</collectingCountry>
.
</paragraph>
