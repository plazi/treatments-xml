<bibRefCitation id="EF84ECE08E3AFFD9FF10FB137049FB26" author="ZIMSEN E." box="[237,363,1240,1259]" firstAuthor="ZIMSEN" pageId="6" pageNumber="663" refId="ref19364" refString="ZIMSEN E. 1964: The type material of I. C. Fabricius. Munksgaard, Copenhagen, 656 pp." type="book" year="1964">ZIMSEN (1964)</bibRefCitation>
