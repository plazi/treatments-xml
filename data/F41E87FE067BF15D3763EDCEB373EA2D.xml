<subSubSection id="34AD6563067AF15D3312EC2EB373EA2D" pageId="1" pageNumber="130" type="distribution">
<paragraph id="7C0836E8067AF15D3312EC2EB373EA2D" blockId="1.[113,752,1565,1621]" pageId="1" pageNumber="130">
<emphasis id="4EC3EAFA067AF15D3312EC2EB34CEA4D" bold="true" box="[113,263,1565,1589]" pageId="1" pageNumber="130">Distribution.</emphasis>
Southeastern Tibet (
<bibRefCitation id="18264B19067AF15D3290EC2EB0FCEA4D" author="Song YJ &amp; Li SQ" box="[499,695,1565,1589]" firstAuthor="Song" journalOrPublisher="Acta Zootaxonomica Sinica" pageId="1" pageNumber="130" pagination="703 - 715" part="35" refId="ref3061" refString="Song YJ &amp; Li SQ (2010) Three new record genera and three new species of Erigoninae from China (Araneae, Linyphiidae). Acta Zootaxonomica Sinica, 35: 703 - 715." title="Three new record genera and three new species of Erigoninae from China (Araneae, Linyphiidae)" type="journal article" year="2010">Song &amp; Li, 2010</bibRefCitation>
) and northern 
<collectingCountry id="04A07678067AF15D33B7EC0EB378EA2D" box="[212,307,1597,1621]" name="Vietnam" pageId="1" pageNumber="130">Vietnam</collectingCountry>
.
</paragraph>
