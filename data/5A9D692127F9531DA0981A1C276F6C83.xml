<subSubSection id="194DE5DAC6499508DC83D7FA13366EBB" pageId="0" pageNumber="105" type="description">
<paragraph id="034D3ED0DDEDC3A14F6C70911991357F" pageId="0" pageNumber="105">Description.</paragraph>
<paragraph id="F32AC8A084709D8CA0B3A30053638A7E" pageId="0" pageNumber="105">
<emphasis id="B8D1E16977778F46F99D368CE44914AC" bold="true" pageId="0" pageNumber="105">Females</emphasis>
(
<emphasis id="92E368C792C4B3BE80ED23133A7DA803" italics="true" pageId="0" pageNumber="105">N</emphasis>
= 3) (Fig. 
<figureCitation id="6AAC6BBFE0B1FB575CEC829BF84A023F" captionStart="Figure 1" captionStartId="F1" captionText="Figure 1. Aridelus dubius Belokobylskij, 1981, ♀ from Niigata Prefecture, Japan A habitus B head, frontal view C head, dorsal view D basal antennal segments E apical antennal segments F wings G hind femur." figureDoi="10.3897/zookeys.1092.73299.figure1" httpUri="https://binary.pensoft.net/fig/669141" pageId="0" pageNumber="105">1</figureCitation>
). Body length 5.1-6.1 mm.
</paragraph>
<caption id="0B2EEFD320D281E8DF082BF62DDD559A" doi="10.3897/zookeys.1092.73299.figure1" httpUri="https://binary.pensoft.net/fig/669141" pageId="0" pageNumber="105" start="Figure 1" startId="F1">
<paragraph id="AC8B6E0A477B32A8152A75FF96EA70BD" pageId="0" pageNumber="105">
<emphasis id="1F5FD1517E6D6A2AF75B200553167257" bold="true" pageId="0" pageNumber="105">Figure 1.</emphasis>
<taxonomicName id="EAFCEA48410EEEEB94A0458E8D79D227" authorityName="Belokobylskij" authorityYear="1981" class="Insecta" family="Braconidae" genus="Aridelus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Aridelus dubius" order="Hymenoptera" pageId="0" pageNumber="105" phylum="Arthropoda" rank="species" species="dubius">
<emphasis id="A13A3FD7BB9CF9FB6A9F150F799D96A7" italics="true" pageId="0" pageNumber="105">Aridelus dubius</emphasis>
</taxonomicName>
Belokobylskij, 1981, ♀ from Niigata Prefecture, Japan 
<emphasis id="66407A01AFF6DEDC18C002EA85DCA9E5" bold="true" pageId="0" pageNumber="105">A</emphasis>
habitus 
<emphasis id="98C2D461EDBF2FF7079F34C9B29A7075" bold="true" pageId="0" pageNumber="105">B</emphasis>
head, frontal view 
<emphasis id="A83AD96177D26A9DCCEA693BC9732510" bold="true" pageId="0" pageNumber="105">C</emphasis>
head, dorsal view 
<emphasis id="E8300744BFD0AC30DD6D3D6139886A17" bold="true" pageId="0" pageNumber="105">D</emphasis>
basal antennal segments 
<emphasis id="772351DFD2A113074EB76EE568B211AF" bold="true" pageId="0" pageNumber="105">E</emphasis>
apical antennal segments 
<emphasis id="6A0C23B87017E30544589FABF66FAA88" bold="true" pageId="0" pageNumber="105">F</emphasis>
wings 
<emphasis id="FD3FB0C09809B9BB91E08A842A02183A" bold="true" pageId="0" pageNumber="105">G</emphasis>
hind femur.
</paragraph>
</caption>
<paragraph id="9342C6F97EB6DA38FAF3F9529F2B5088" pageId="0" pageNumber="105">
<emphasis id="F58FB3AF9752ACFD99E09B6F96006F18" bold="true" italics="true" pageId="0" pageNumber="105">Head</emphasis>
(Fig. 
<figureCitation id="CE1872F86FCF9D5EF75F60B3A40E9576" captionStart="Figure 1" captionStartId="F1" captionText="Figure 1. Aridelus dubius Belokobylskij, 1981, ♀ from Niigata Prefecture, Japan A habitus B head, frontal view C head, dorsal view D basal antennal segments E apical antennal segments F wings G hind femur." figureDoi="10.3897/zookeys.1092.73299.figure1" httpUri="https://binary.pensoft.net/fig/669141" pageId="0" pageNumber="105">1B, C, D, E</figureCitation>
). Width of head 2.0-2.2
<normalizedToken id="D6A479BADD8A6AC632DF0AF8C04056F8" originalValue="×">x</normalizedToken>
median length and 1.0
<normalizedToken id="E882E1694373567671BB6ED24F0D3ADD" originalValue="×">x</normalizedToken>
width of mesonotum. Length of eye 1.1-1.3
<normalizedToken id="36BA3B373BE57E751E90F88E6E85D141" originalValue="×">x</normalizedToken>
length of temple in dorsal view. OOL / OD = 4.0-4.1. POL / OD = 1.7. Vertex and temple densely punctate. Occipital carina complete. Frons smooth and shiny, with a distinct median carina. Face 1.8
<normalizedToken id="930C3A7D3D067128DBF634420AD8C3E5" originalValue="×">x</normalizedToken>
as wide as high; finely punctate. Intertentorial distance / tentorio-ocular distance = 0.4-0.5
<normalizedToken id="878F3298E804EDD82D4925A8E886D044" originalValue="×">x</normalizedToken>
. Clypeus finely punctate, slightly concave medially, without apical teeth. Length of malar space 0.4-0.5
<normalizedToken id="974F39E4098E205D9F22DC651E66D69D" originalValue="×">x</normalizedToken>
eye height. Malar suture distinct. Antenna filiform with 18 segments; 3rd segment 3.8-4.0
<normalizedToken id="546A622C8341800E5A7510036A2F7916" originalValue="×">x</normalizedToken>
longer than wide and 1.3
<normalizedToken id="7BC04480835087B2EB13BD869E3BE9DC" originalValue="×">x</normalizedToken>
longer than 4th one; penultimate one 1.6-1.7
<normalizedToken id="61A638821CDAC069919C3EEDA8C0CF3E" originalValue="×">x</normalizedToken>
longer than wide.
</paragraph>
<paragraph id="51879D28C018D4B44253EAAF51EBC431" pageId="0" pageNumber="105">
<emphasis id="2A9F152D80CC9566B956EBB8E3B3AC5F" bold="true" pageId="0" pageNumber="105">
<emphasis id="BF18EF36555F729CF92843439B55AEA4" italics="true" pageId="0" pageNumber="105">Mesosoma</emphasis>
.
</emphasis>
Mesosoma areolate, 1.3
<normalizedToken id="3E4CB19A68AF25B1B02D5B20DDB9351C" originalValue="×">x</normalizedToken>
as long as high. Scutellum without median smooth area.
</paragraph>
<paragraph id="CCD9ED28FE157C5026DF3F85FFD08717" pageId="0" pageNumber="105">
<emphasis id="26A6DA9B8A58FDC764B72FB79D0B2F2F" bold="true" italics="true" pageId="0" pageNumber="105">Wings</emphasis>
(Fig. 
<figureCitation id="5AA0201950568404613605A50393DACA" captionStart="Figure 1" captionStartId="F1" captionText="Figure 1. Aridelus dubius Belokobylskij, 1981, ♀ from Niigata Prefecture, Japan A habitus B head, frontal view C head, dorsal view D basal antennal segments E apical antennal segments F wings G hind femur." figureDoi="10.3897/zookeys.1092.73299.figure1" httpUri="https://binary.pensoft.net/fig/669141" pageId="0" pageNumber="105">1F</figureCitation>
). Fore wing 4.4-4.7 mm in length, 1-R1 / length of pterostigma = 1.3-1.4, r / 3-SR = 2.3-3.5, m-cu slightly postfurcal. Hind wing with 1r-m / 2-SC+R = 0.7-0.9.
</paragraph>
<paragraph id="1E254C23568B686EF9A3C1D4B1B3BD39" pageId="0" pageNumber="105">
<emphasis id="50065F4DA557E354BAF204D0A9A168E3" bold="true" italics="true" pageId="0" pageNumber="105">Legs</emphasis>
(Fig. 
<figureCitation id="BD0DE8F21AF6A60BCFFCF08D8E118613" captionStart="Figure 1" captionStartId="F1" captionText="Figure 1. Aridelus dubius Belokobylskij, 1981, ♀ from Niigata Prefecture, Japan A habitus B head, frontal view C head, dorsal view D basal antennal segments E apical antennal segments F wings G hind femur." figureDoi="10.3897/zookeys.1092.73299.figure1" httpUri="https://binary.pensoft.net/fig/669141" pageId="0" pageNumber="105">1G</figureCitation>
). Hind leg: femur 4.1-4.3
<normalizedToken id="53B566AFD36EBD06C0525B093E345B3F" originalValue="×">x</normalizedToken>
longer than wide, length of femur: tibia: basitarsus = 1: 1.3: 0.6.
</paragraph>
<paragraph id="F4D81FCB1E6455D4650C611F28B72613" pageId="0" pageNumber="105">
<emphasis id="EBBAE80B34696A7631090A497E33E684" bold="true" pageId="0" pageNumber="105">
<emphasis id="6ACA12089808AA88D6670F03344341B3" italics="true" pageId="0" pageNumber="105">Metasoma</emphasis>
.
</emphasis>
Metasoma smooth and polished. First metasomal tergite 6.0
<normalizedToken id="7A751B40235357CBC80646DB70CFD071" originalValue="×">x</normalizedToken>
longer than its apical width. Hypopygium truncated and excised apically. Ovipositor sheath hardly exserted beyond apex of metasoma.
</paragraph>
<paragraph id="A56E62E9889ABF04767FFE3831741129" pageId="0" pageNumber="105">
<emphasis id="4AB2B77BEE09D312D3D9F60651C09747" bold="true" pageId="0" pageNumber="105">
<emphasis id="5C6AD51CD54F9BF2BEC0931FD34D9CB2" italics="true" pageId="0" pageNumber="105">Colour</emphasis>
.
</emphasis>
Black. Palpi, antenna entirely, mandible, tegula, legs except for telotarsus and first metasomal tergite dark reddish brown; remainder of metasoma reddish brown, telotarsus and veins dark brown; pterostigma pale in basal 1/5 or faintly pale basally. Fore wing hyaline with two fuscous bands. Hind wing with a fuscous band in its apical third.
</paragraph>
</subSubSection>
<subSubSection id="71085C5C8D308A6995BA780A88D4C81E" pageId="0" pageNumber="105" type="distribution">
<paragraph id="F8406347706AE37F8AA22E513897D748" pageId="0" pageNumber="105">Distribution.</paragraph>
<paragraph id="35FF576417D7C25FEC76A1D1CFF9A835" pageId="0" pageNumber="105">
Japan (
<normalizedToken id="5D981B050D0ADA6772CE0CC70080B253" originalValue="Honshû">Honshu</normalizedToken>
: Niigata and Hiroshima Prefectures); Russian Far East (
<bibRefCitation id="EA40E9D9C43791A3ED1F7CBD3D1F1208" author="Belokobylskij, SA" editor="Ler, PA" journalOrPublisher="Akademiya Nauk Sssr, Vladivostok" pageId="0" pageNumber="105" pagination="41 - 47" refId="B1" refString="Belokobylskij, SA, 1981. New and little known Braconidae (Hymenoptera) species from the south of Far East. In: Ler, PA, Kupyanskaya, AN, Lelej, AS, Fedikova, VS, Eds., Hymenoptera of the Far East. Akademiya Nauk Sssr, Vladivostok: 41 - 47" title="New and little known Braconidae (Hymenoptera) species from the south of Far East." volumeTitle="Hymenoptera of the Far East." year="1981">Belokobylskij 1981</bibRefCitation>
, 
<bibRefCitation id="07C7F2564CA25E7839BA3905D11E64FA" author="Belokobylskij, SA" editor="Ler, PA" journalOrPublisher="Vol. IV. Neuroperoidea, Mecoptera, Hymenoptera. Dal'nauka, Vladivostok" pageId="0" pageNumber="105" pagination="192 - 399" refId="B2" refString="Belokobylskij, SA, 2000. Euphorinae. In: Ler, PA, Ed., Key to the Insects of Russian Far East. Vol. IV. Neuroperoidea, Mecoptera, Hymenoptera. Dal'nauka, Vladivostok: 192 - 399" title="Euphorinae." volumeTitle="Key to the Insects of Russian Far East." year="2000">2000</bibRefCitation>
).
</paragraph>
</subSubSection>
<subSubSection id="6ED367A2C3D484434336D23106A3094C" pageId="0" pageNumber="105" type="host">
<paragraph id="5C43C6EF53D593C84449A0EB6A2A1D4D" pageId="0" pageNumber="105">Hosts.</paragraph>
<paragraph id="20CD855984AD04F4E9020FBA2A1322AD" pageId="0" pageNumber="105">Unknown.</paragraph>
</subSubSection>
<subSubSection id="BF367132403136D0FB9286B48648C3CD" pageId="0" pageNumber="105" type="remarks">
<paragraph id="43B43AF96A067D3AA1032224F02D79CC" pageId="0" pageNumber="105">Remarks.</paragraph>
<paragraph id="01E3B821D07280657FF3866D2D116461" pageId="0" pageNumber="105">
This species was described with only the male holotype available. The Japanese specimens mostly agree well with the original description (
<bibRefCitation id="69F7D40D8F9EFE4DA29E69A4366CF4E5" author="Belokobylskij, SA" editor="Ler, PA" journalOrPublisher="Akademiya Nauk Sssr, Vladivostok" pageId="0" pageNumber="105" pagination="41 - 47" refId="B1" refString="Belokobylskij, SA, 1981. New and little known Braconidae (Hymenoptera) species from the south of Far East. In: Ler, PA, Kupyanskaya, AN, Lelej, AS, Fedikova, VS, Eds., Hymenoptera of the Far East. Akademiya Nauk Sssr, Vladivostok: 41 - 47" title="New and little known Braconidae (Hymenoptera) species from the south of Far East." volumeTitle="Hymenoptera of the Far East." year="1981">Belokobylskij 1981</bibRefCitation>
) and run in the key by 
<bibRefCitation id="D11C8DD6BE55129204B239A4E480260A" author="Belokobylskij, SA" editor="Ler, PA" journalOrPublisher="Vol. IV. Neuroperoidea, Mecoptera, Hymenoptera. Dal'nauka, Vladivostok" pageId="0" pageNumber="105" pagination="192 - 399" refId="B2" refString="Belokobylskij, SA, 2000. Euphorinae. In: Ler, PA, Ed., Key to the Insects of Russian Far East. Vol. IV. Neuroperoidea, Mecoptera, Hymenoptera. Dal'nauka, Vladivostok: 192 - 399" title="Euphorinae." volumeTitle="Key to the Insects of Russian Far East." year="2000">Belokobylskij (2000)</bibRefCitation>
to 
<taxonomicName id="36CF87FD283D468A60A5609AC2C1A1F8" genus="A." lsidName="A. dubius" pageId="0" pageNumber="105" rank="species" species="dubius">
<emphasis id="5C1CD3D76067856684CE9BA6A94ADA21" italics="true" pageId="0" pageNumber="105">A. dubius</emphasis>
</taxonomicName>
. The redescription of this species based on Japanese female specimens is represented here.
</paragraph>
<paragraph id="6E56EB76A0127FD1926AA8AAC8ACE882" pageId="0" pageNumber="105">
This species resembles 
<taxonomicName id="7FD9386A6A49335AF8D94AB14C17FC2E" genus="A." lsidName="A. rutilipes" pageId="0" pageNumber="105" rank="species" species="rutilipes">
<emphasis id="A02DD7E4BCA0E6F73E60465F7EF4CF9E" italics="true" pageId="0" pageNumber="105">A. rutilipes</emphasis>
</taxonomicName>
Papp described from Taiwan (Fig. 
<figureCitation id="5F017FF8F598E30F6F45CDDEA06E6B37" captionStart="Figure 6" captionStartId="F6" captionText="Figure 6. Aridelus rutilipes Papp, 1965, ♀ from Taiwan A habitus B head, dorsal view C apical antennal segments." figureDoi="10.3897/zookeys.1092.73299.figure6" httpUri="https://binary.pensoft.net/fig/669146" pageId="0" pageNumber="105">6</figureCitation>
) but differs in having the distinct malar suture (absent in 
<taxonomicName id="EC861821763FA44CB8C1DC7D765FE9B1" authorityName="Papp" authorityYear="1965" class="Insecta" family="Braconidae" genus="Aridelus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Aridelus rutilipes" order="Hymenoptera" pageId="0" pageNumber="105" phylum="Arthropoda" rank="species" species="rutilipes">
<emphasis id="403A06725A7403D718856B7709843784" italics="true" pageId="0" pageNumber="105">Aridelus rutilipes</emphasis>
</taxonomicName>
), the palpi dark reddish brown (light reddish brown in 
<taxonomicName id="F173964A9513227A4868BE0488B68F1C" authorityName="Papp" authorityYear="1965" class="Insecta" family="Braconidae" genus="Aridelus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Aridelus rutilipes" order="Hymenoptera" pageId="0" pageNumber="105" phylum="Arthropoda" rank="species" species="rutilipes">
<emphasis id="DB5B2AAE54EEC9D3961518F348BF811D" italics="true" pageId="0" pageNumber="105">Aridelus rutilipes</emphasis>
</taxonomicName>
), the apical hyaline area of the fore wing comparatively small, not reaching the apex of marginal cell (Fig. 
<figureCitation id="7D7DC7D97E19E35BD29C86C8103D7966" captionStart="Figure 1" captionStartId="F1" captionText="Figure 1. Aridelus dubius Belokobylskij, 1981, ♀ from Niigata Prefecture, Japan A habitus B head, frontal view C head, dorsal view D basal antennal segments E apical antennal segments F wings G hind femur." figureDoi="10.3897/zookeys.1092.73299.figure1" httpUri="https://binary.pensoft.net/fig/669141" pageId="0" pageNumber="105">1F</figureCitation>
) and the apico-posterior edge of the fore wing (in 
<taxonomicName id="B7EC1763320E2B12CFCEC5249818B445" authorityName="Papp" authorityYear="1965" class="Insecta" family="Braconidae" genus="Aridelus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Aridelus rutilipes" order="Hymenoptera" pageId="0" pageNumber="105" phylum="Arthropoda" rank="species" species="rutilipes">
<emphasis id="7F3DFBBD6B51202E7E376EADBE0DA6A6" italics="true" pageId="0" pageNumber="105">Aridelus rutilipes</emphasis>
</taxonomicName>
comparatively large, almost reaching the apex of marginal cell and reaching the apico-posterior edge (Fig. 
<figureCitation id="8A9E54F3A70844314BCE35EB6A8F027D" captionStart="Figure 6" captionStartId="F6" captionText="Figure 6. Aridelus rutilipes Papp, 1965, ♀ from Taiwan A habitus B head, dorsal view C apical antennal segments." figureDoi="10.3897/zookeys.1092.73299.figure6" httpUri="https://binary.pensoft.net/fig/669146" pageId="0" pageNumber="105">6A</figureCitation>
)), and the metasoma reddish brown to dark reddish brown (Fig. 
<figureCitation id="F61C826297B713D5ECCBE6EAB5EB46A2" captionStart="Figure 1" captionStartId="F1" captionText="Figure 1. Aridelus dubius Belokobylskij, 1981, ♀ from Niigata Prefecture, Japan A habitus B head, frontal view C head, dorsal view D basal antennal segments E apical antennal segments F wings G hind femur." figureDoi="10.3897/zookeys.1092.73299.figure1" httpUri="https://binary.pensoft.net/fig/669141" pageId="0" pageNumber="105">1A</figureCitation>
) (dark brown in 
<taxonomicName id="51B3ED45FA20C3075F55594286AD77FE" authorityName="Papp" authorityYear="1965" class="Insecta" family="Braconidae" genus="Aridelus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Aridelus rutilipes" order="Hymenoptera" pageId="0" pageNumber="105" phylum="Arthropoda" rank="species" species="rutilipes">
<emphasis id="2DFE2A966210086D4778BB6DD3AC00E8" italics="true" pageId="0" pageNumber="105">Aridelus rutilipes</emphasis>
</taxonomicName>
(Fig. 
<figureCitation id="CF66C6C5F2F1790AC68BB063B3418915" captionStart="Figure 6" captionStartId="F6" captionText="Figure 6. Aridelus rutilipes Papp, 1965, ♀ from Taiwan A habitus B head, dorsal view C apical antennal segments." figureDoi="10.3897/zookeys.1092.73299.figure6" httpUri="https://binary.pensoft.net/fig/669146" pageId="0" pageNumber="105">6A</figureCitation>
)).
</paragraph>
</subSubSection>
</treatment>
