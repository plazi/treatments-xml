See 
<tableCitation id="4A6897D8FFBDFFF7A7FEFCD0FE80DF58" box="[238,326,831,857]" captionStart="Table 1" captionStartId="16.[181,251,550,579]" captionTargetBox="[181,1927,606,1741]" captionTargetId="graphics-41@16.[181,1934,631,1743]" captionTargetPageId="16" captionText="Table 1 (continued on next two pages). Measurements of all Caribbean and Central American species of Charinus Simon, 1892." httpUri="http://table.plazi.org/id/5395F2EBFF89FFC3A7A5FDC9F95BDE43" pageId="36" pageNumber="37" tableUuid="5395F2EBFF89FFC3A7A5FDC9F95BDE43">Table 1</tableCitation>
