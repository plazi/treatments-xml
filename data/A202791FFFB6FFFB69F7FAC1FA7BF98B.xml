(
<bibRefCitation id="4E3AB5F8FFB6FFFB6C46F98DFA72F98B" author="Scott, J." box="[1318,1429,1626,1648]" pageId="6" pageNumber="7" pagination="289 - 304" refId="ref40256" refString="Scott, J. (1874) On a collection of Hemiptera Heteroptera from Japan. Descriptions of various new genera and species [part 1]. Annals and Magazine of Natural History, Series 4, 14 (82), 289 - 304. https: // doi. org / 10.1080 / 00222937408680968" type="journal article" year="1874">Scott, 1874</bibRefCitation>
