<taxonomicName id="A93C205C42DEE7CB69E5378BD49D5E63" authority="F. Schultz" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="434" phylum="Tracheophyta" rank="species" species="leersii">
