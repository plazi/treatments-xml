<subSubSection id="F2199FB8293489C64EBBEC00DE5CF43F" pageId="null" pageNumber="812" type="description">
<paragraph id="5384908401197E873BA66ED66D05BF95" pageId="null" pageNumber="812">
Pflanze 
<normalizedToken id="2CED71DC257F26B9FC0E29BB16FEBE4D" originalValue="gelbgrün" pageId="null" pageNumber="812">gelbgruen</normalizedToken>
. Stengel (und 
<normalizedToken id="3B5997D677AF703F02A4383CCFB31FC6" originalValue="Blütenstiele" pageId="null" pageNumber="812">Bluetenstiele</normalizedToken>
) mit abstehenden, bis 2 mm langen, mehrzelligen Haaren, im obern Teil auch mit 
<normalizedToken id="88A83ADA057A9C57A421F10D4A63A977" originalValue="Drüsenhaaren" pageId="null" pageNumber="812">Druesenhaaren</normalizedToken>
. Alle 
<normalizedToken id="F075A65E1415F020E66942ED29BE0AA0" originalValue="Blätter" pageId="null" pageNumber="812">Blaetter</normalizedToken>
im 
<normalizedToken id="381C2E2B3E1D1E5E17C14F0339CDC8CA" originalValue="Blütenstand" pageId="null" pageNumber="812">Bluetenstand</normalizedToken>
krautig, ohne 
<normalizedToken id="6598BD82B163F1A5AA6EA82392844D5C" originalValue="häutigen" pageId="null" pageNumber="812">haeutigen</normalizedToken>
Rand, beiderseits bis zur Spitze mit 0,5-2 mm langen Haaren; die Spitze deutlich von Haaren 
<normalizedToken id="0C241DE0B684B264503E4CD3329794E7" originalValue="überragt" pageId="null" pageNumber="812">ueberragt</normalizedToken>
. 
<emphasis id="78BE651A318F008078C9A7FA3B64C0F0" italics="true" pageId="null" pageNumber="812">Fruchtstiele</emphasis>
⅓ 
<emphasis id="04065519B8245C752473A293781B554E" italics="true" pageId="null" pageNumber="812">-1mal so lang wie der Kelch</emphasis>
(
<emphasis id="5218D97D2ECE6820757416D4436C3A68" italics="true" pageId="null" pageNumber="812">
<normalizedToken id="F44739D99C99FBBE877DC3933069B5F1" originalValue="Blüten-" pageId="null" pageNumber="812">Blueten-</normalizedToken>
und 
<normalizedToken id="B3F80967090987B7DDB734EA145E6BEC" originalValue="Fruchtstände" pageId="null" pageNumber="812">Fruchtstaende</normalizedToken>
deshalb 
<normalizedToken id="C8ED5749C606E0392627F55B30D42207" originalValue="geknäuelt" pageId="null" pageNumber="812">geknaeuelt</normalizedToken>
</emphasis>
). 
<normalizedToken id="60B724CE7C657BCE28D2C0F846036FA3" originalValue="Kelchblätter" pageId="null" pageNumber="812">Kelchblaetter</normalizedToken>
bis zur Spitze mit 0,5-2 mm langen Haaren und 
<normalizedToken id="283FB152AF09625C780B624C4756BD24" originalValue="kürzeren" pageId="null" pageNumber="812">kuerzeren</normalizedToken>
<normalizedToken id="FB81BD912DE5864EDEDA571244DDF545" originalValue="Drüsenhaaren" pageId="null" pageNumber="812">Druesenhaaren</normalizedToken>
, mit 
<emphasis id="7AF282A91F4305C8996558E8DDC11399" italics="true" pageId="null" pageNumber="812">
<normalizedToken id="092ABB10DB1BDE1F1AC16C9D391D4B7C" originalValue="±" pageId="null" pageNumber="812">+/-</normalizedToken>
</emphasis>
behaarter und von den Haaren 
<normalizedToken id="9ED0C635D170F009829D28BA13C8DB0E" originalValue="überragter" pageId="null" pageNumber="812">ueberragter</normalizedToken>
Spitze. 
<normalizedToken id="F5E2A1A719E8CF39EC9F7A6AEAFBBE07" originalValue="Kronblätter" pageId="null" pageNumber="812">Kronblaetter</normalizedToken>
wenig 
<normalizedToken id="C8CA2CDC181DBC4C72814DE6ACDE5C6F" originalValue="kürzer" pageId="null" pageNumber="812">kuerzer</normalizedToken>
bis wenig 
<normalizedToken id="44EAEF0DD55F5448112425F9A15E01A1" originalValue="länger" pageId="null" pageNumber="812">laenger</normalizedToken>
als die 
<normalizedToken id="5B8660B34DE7F51DA03ADC596EE7600E" originalValue="Kelchblätter" pageId="null" pageNumber="812">Kelchblaetter</normalizedToken>
, 
<emphasis id="4F3A8C98F4AB92CAB3437AD737D3A6AC" italics="true" pageId="null" pageNumber="812">kahl.</emphasis>
<normalizedToken id="B760B6961E56BD3189EA5BA2CEB9B511" originalValue="Staubblätter" pageId="null" pageNumber="812">Staubblaetter</normalizedToken>
10; 
<emphasis id="36199864D916E2B52D11852DE8DECB9B" italics="true" pageId="null" pageNumber="812">
<normalizedToken id="48D9AF1EF4457027750A8469077AAD25" originalValue="Staubfäden" pageId="null" pageNumber="812">Staubfaeden</normalizedToken>
kahl.
</emphasis>
- 
<normalizedToken id="EEAA065BA01B4AA2FCD8DE66899B882D" originalValue="Blüte" pageId="null" pageNumber="812">Bluete</normalizedToken>
: 
<normalizedToken id="5A83E8001AE74458F571908DF9C82571" originalValue="Frühling" pageId="null" pageNumber="812">Fruehling</normalizedToken>
bis Herbst.
</paragraph>
<paragraph id="8B6FDA2956929978635AFD0433B8CA5B" pageId="null" pageNumber="812">
<emphasis id="6F5A5ECE5E5636A390190EEB6FBEF5CB" italics="true" pageId="null" pageNumber="812">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="28BDFB0B89EE86A2605258919ABD9E16" italics="true" pageId="null" pageNumber="812">72:</emphasis>
Material aus Schleswig-Holstein (Rohweder 1939), aus England (Brett 1955, Blackburn und Morton 1957), aus botanischem Garten, aus Neuenburg und aus Algier (
<normalizedToken id="2A91261C38BCC946CE926BBEA2C5DF3E" originalValue="Söllner" pageId="null" pageNumber="812">Soellner</normalizedToken>
1954), aus Island (
<normalizedToken id="2126E288E48F81BF0219B2B889AB18C9" originalValue="Löve" pageId="null" pageNumber="812">Loeve</normalizedToken>
und 
<normalizedToken id="09DBEE06D9135EAF58279EAB204052BE" originalValue="Löve" pageId="null" pageNumber="812">Loeve</normalizedToken>
1956b).
</paragraph>
<paragraph id="6ED5A70BC2241ADF3D92168245F26195" pageId="null" pageNumber="812">
<emphasis id="771D0122906F395BE5C0AF726A07A938" italics="true" pageId="null" pageNumber="812">Standort.</emphasis>
Kollin, montan und subalpin. Nicht zu trockene, lockere, offene, oft kalkarme, sandige 
<normalizedToken id="5EDF2365E92B2C43C3395EB4D4B48F5E" originalValue="Böden" pageId="null" pageNumber="812">Boeden</normalizedToken>
in 
<normalizedToken id="F69C96CF72E369B6256E023AEFB9A5D4" originalValue="wärmeren" pageId="null" pageNumber="812">waermeren</normalizedToken>
Lagen. Hackkulturen, Brachland, 
<normalizedToken id="FB8E3C2CD67A2E96867054545F5F558F" originalValue="Wegränder" pageId="null" pageNumber="812">Wegraender</normalizedToken>
, 
<normalizedToken id="769C9BE838FC32FEE2B09C903DDF5B83" originalValue="Schuttplätze" pageId="null" pageNumber="812">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="D291840447E260BCEBFFB65334A2B8AE" pageId="null" pageNumber="812">
<emphasis id="057352E1AECBB029086DD3F57FE6CED0" italics="true" pageId="null" pageNumber="812">
Verbreitung. 
<normalizedToken id="FC31BFC9F2E7AC17D4C2BB5522A943AE" originalValue="Ursprünglich" pageId="null" pageNumber="812">Urspruenglich</normalizedToken>
wahrscheinlich mediterrane Pflanze, heute mit weltweiter Verbreitung. -
</emphasis>
Im Gebiet verbreitet, nicht 
<normalizedToken id="730F6C413D84C1D251A0172AB1ECECF4" originalValue="häufig" pageId="null" pageNumber="812">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
