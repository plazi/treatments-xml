<taxonomicName id="B21EE9763B33BE72C20A89191E4BB240" authority="A. Br. et Milde" class="Polypodiopsida" family="Cystopteridaceae" genus="Cystopteris" kingdom="Plantae" order="Polypodiales" pageId="null" pageNumber="127" phylum="Tracheophyta" rank="species" species="sudetica">
Cystopteris 
<normalizedToken id="C691457270EE7D0388ED4A144811FDA8" originalValue="sudética" pageId="null" pageNumber="127">sudetica</normalizedToken>
A. Br. et Milde
</taxonomicName>
</paragraph>
