<taxonomicName id="4C724D2693508E0DF3E9FAE5FCEAFA5A" authority="Dej. G. Colas" box="[468,827,1399,1425]" class="Insecta" family="Carabidae" genus="Ophonus" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="493" phylum="Arthropoda" rank="species" species="diffinis">Ophonus diffinis Dej. G. Colas</taxonomicName>
