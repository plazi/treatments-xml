<subSubSection id="378AF48882373373A0C18E321639FE7E" pageId="null" pageNumber="509" type="description">
<paragraph id="9D0E90B023945744D0F998F0FED205A9" pageId="null" pageNumber="509">
Unterscheidet sich von 
<taxonomicName id="9FDE5512F495257D8CE7DA7F8B252A2F" class="Liliopsida" family="Juncaceae" genus="Juncus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="509" phylum="Tracheophyta" rank="species" species="capitatus">
<emphasis id="E8AB7D42C0D3D716B88B37C84E143503" italics="true" pageId="null" pageNumber="509">J. capitatus</emphasis>
</taxonomicName>
(Nr. 15) durch folgende Merkmale: 
<emphasis id="920E4EA7CF8AC994E76269D202AF45A5" italics="true" pageId="null" pageNumber="509">
Blattscheiden mit 0,5-1 mm langen, ganzrandigen 
<normalizedToken id="E690853EECAADB62F178ED1F6738C92D" originalValue="Öhrchen" pageId="null" pageNumber="509">Oehrchen</normalizedToken>
; alle 
<normalizedToken id="ED21A7B390AD01DD3A41CE257390547A" originalValue="Perigonblätter" pageId="null" pageNumber="509">Perigonblaetter</normalizedToken>
gleich lang, kurz zugespitzt oder stumpf.
</emphasis>
- 
<normalizedToken id="526621ECB4B7F20C742AC22C961F97A0" originalValue="Blüte" pageId="null" pageNumber="509">Bluete</normalizedToken>
: 
<normalizedToken id="E092077755BE21394353E20B2B9090E1" originalValue="Frühling" pageId="null" pageNumber="509">Fruehling</normalizedToken>
bis Herbst.
</paragraph>
<paragraph id="82B0696986A816CE60CFCA89D702DDC7" pageId="null" pageNumber="509">
<emphasis id="C3803DA136A3053BC75EDC68B989892A" italics="true" pageId="null" pageNumber="509">Zytologische Angaben. 2n = 40:</emphasis>
Material aus Portugal (Snogerup 1963).
</paragraph>
<paragraph id="D35FEF8A7E2AE3CA018CD457C905FD3D" pageId="null" pageNumber="509">
<emphasis id="63DAD4BC5A78CF9AE88EF94AAFCCD0F5" italics="true" pageId="null" pageNumber="509">Standort.</emphasis>
Kollin. Feuchte 
<normalizedToken id="12D6EA253C5F4E290268AE09AF9D004A" originalValue="Sandböden" pageId="null" pageNumber="509">Sandboeden</normalizedToken>
.
</paragraph>
<paragraph id="B27E7091B4B8282E351948E1FBD1BF3F" pageId="null" pageNumber="509">
<emphasis id="765B39C1D5F2F7ACB3E8B2D1DFD27FAA" italics="true" pageId="null" pageNumber="509">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="F145B9639772306CE31175A1D03EF221" originalValue="Nordwärts" pageId="null" pageNumber="509">Nordwaerts</normalizedToken>
bis England (Cornwall), 
<normalizedToken id="DB0A37A2A4BA5E576D5D8EB3364BC292" originalValue="Nordjütland" pageId="null" pageNumber="509">Nordjuetland</normalizedToken>
, 
<normalizedToken id="C80DD513879C9165EE7392875E43915E" originalValue="früher" pageId="null" pageNumber="509">frueher</normalizedToken>
vereinzelt in Schweden; mediterrane 
<normalizedToken id="582E6A4209EE730963E96B3A73393204" originalValue="Küstengebiete" pageId="null" pageNumber="509">Kuestengebiete</normalizedToken>
(
<normalizedToken id="E5B2AF2600714D510E614280DB4888B3" originalValue="einschließlich" pageId="null" pageNumber="509">einschliesslich</normalizedToken>
Nordwestafrika), 
<normalizedToken id="6818812A6DF6602E8B39F5D599077856" originalValue="ostwärts" pageId="null" pageNumber="509">ostwaerts</normalizedToken>
bis Kleinasien. - Im Gebiet im 
<normalizedToken id="11F990B112E93D94B69BC9F68FEF32E5" originalValue="Dép" pageId="null" pageNumber="509">Dep</normalizedToken>
. Ain (besonders Dombes), Savoyen (Lac du Bourget).
</paragraph>
</subSubSection>
