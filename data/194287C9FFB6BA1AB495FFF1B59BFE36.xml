<subSubSection id="D9F16554FFB6BA1AB6F8FEF2B1DFF5EB" pageId="10" pageNumber="629" type="discussion">
<paragraph id="915436DFFFB6BA1AB6F8FEF2B1DFF5EB" blockId="10.[744,1338,2371,2794]" pageId="10" pageNumber="629">
<taxonomicName id="56EB4D5CFFB6BA1AB6F8FEF2B1FFF661" authorityName="Thomas" authorityYear="1921" box="[746,985,2450,2479]" class="Mammalia" family="Molossidae" genus="Promops" kingdom="Animalia" order="Chiroptera" pageId="10" pageNumber="629" phylum="Chordata" rank="species" species="davisoni">Promops davisoni</taxonomicName>
