<taxonomicName id="56EB4D5CFFB6BA1AB723FED9B1E7F618" authorityName="Thomas" authorityYear="1915" box="[817,961,2489,2518]" class="Mammalia" family="Molossidae" genus="Promops" kingdom="Animalia" order="Chiroptera" pageId="10" pageNumber="629" phylum="Chordata" rank="species" species="centralis">P. centralis</taxonomicName>
