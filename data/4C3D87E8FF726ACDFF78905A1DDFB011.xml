<taxonomicName id="03944D7DFF726ACDFC7790D31D76BDE1" authority="W. W. A. Phillips, 1932" authorityName="W. W. A. Phillips" authorityYear="1932" class="Mammalia" family="Vespertilionidae" genus="Kerivoula" kingdom="Animalia" order="Chiroptera" pageId="137" pageNumber="897" phylum="Chordata" rank="species" species="malpasi">Kerivoula malpasi W. W. A. Phillips, 1932</taxonomicName>
, 
<materialsCitation id="74FC3CA3FF726ACDFC6D90EF1AB3BC10" ID-GBIF-Occurrence="3783319616" pageId="137" pageNumber="897">
“Kumbalgamuwa (
<quantity id="036C9B1BFF726ACDFB6390EF1B35BDE1" box="[1183,1333,1718,1747]" metricMagnitude="-1" metricUnit="m" metricValue="9.144" pageId="137" pageNumber="897" unit="ft" value="3.0">3,000 feet</quantity>
[= 
