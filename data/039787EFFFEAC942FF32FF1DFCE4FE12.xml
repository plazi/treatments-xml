<subSubSection id="C3246572FFEAC945FF62FE19FAC1FDA2" pageId="75" pageNumber="76" type="diagnosis">
<paragraph id="8B8136F9FFEAC945FF62FE19FAC1FDA2" blockId="75.[151,1437,258,610]" pageId="75" pageNumber="76">
<emphasis id="B94AEAEBFFEAC945FF62FE19FECCFE6E" bold="true" box="[199,322,403,429]" pageId="75" pageNumber="76">Diagnosis.</emphasis>
Females of 
<taxonomicName id="4C3E4D7AFFEAC945FE6AFE1EFDB8FE6E" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[463,566,403,429]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="75" pageNumber="76" phylum="Arthropoda" rank="species" species="zeteki" status="comb. nov.">
<emphasis id="B94AEAEBFFEAC945FE6AFE1EFDB8FE6E" box="[463,566,403,429]" italics="true" pageId="75" pageNumber="76">M. zeteki</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFFEAC945FD9BFE19FD4EFE6E" bold="true" box="[574,704,403,429]" pageId="75" pageNumber="76">
<taxonomicNameLabel id="A2795790FFEAC945FD9BFE19FD4EFE6E" box="[574,704,403,429]" pageId="75" pageNumber="76" rank="species">comb. nov.</taxonomicNameLabel>
</emphasis>
resemble those of 
<taxonomicName id="4C3E4D7AFFEAC945FC3FFE1EFBD3FE6E" authorityName="Rheims &amp; Jäger" authorityYear="2022" baseAuthorityName="Simon" baseAuthorityYear="1898" box="[922,1117,404,429]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="75" pageNumber="76" phylum="Arthropoda" rank="species" species="sanctivincenti" status="comb. nov.">
<emphasis id="B94AEAEBFFEAC945FC3FFE1EFBD3FE6E" box="[922,1117,404,429]" italics="true" pageId="75" pageNumber="76">M. sanctivincenti</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFFEAC945FBC0FE19FB68FE6E" bold="true" box="[1125,1254,403,429]" pageId="75" pageNumber="76">
<taxonomicNameLabel id="A2795790FFEAC945FBC0FE19FB68FE6E" box="[1125,1254,403,429]" pageId="75" pageNumber="76" rank="species">comb. nov.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13052A7CFFEAC945FB52FE19FA1BFE6D" box="[1271,1429,403,430]" captionStart="FIGURES 250–252" captionStartId="61.[151,264,1938,1962]" captionTargetBox="[189,1403,1171,1906]" captionTargetId="figure-364@61.[181,1406,1166,1915]" captionTargetPageId="61" captionText="FIGURES 250–252. Meri sanctivincenti (Simon) comb. nov., female (250 epigyne, 251 vulva, 252 schematic course of internal duct system). EP—epigynal pocket; ft—first turn of duct system; FD—fertilization duct; GP—glandular projection; LL—lateral lobe; MS—median septum; SP—spermathecae. Scale line: 1 mm. Modified from Jäger 2020 (94: figs 349–351)." figureDoi="http://doi.org/10.5281/zenodo.6550498" httpUri="https://zenodo.org/record/6550498/files/figure.png" pageId="75" pageNumber="76">Figs 250–252</figureCitation>
) and 
<taxonomicName id="4C3E4D7AFFEAC945FF6CFE32FEE7FE12" authority="Rheims &amp; Jäger, 2022" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[201,361,440,465]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="75" pageNumber="76" phylum="Arthropoda" rank="species" species="tapirapeco" status="spec. nov.">
<emphasis id="B94AEAEBFFEAC945FF6CFE32FEE7FE12" box="[201,361,440,465]" italics="true" pageId="75" pageNumber="76">M. tapirapeco</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFFEAC945FED7FE3DFE69FE12" bold="true" box="[370,487,439,465]" pageId="75" pageNumber="76">
<taxonomicNameLabel id="A2795790FFEAC945FED7FE3DFE69FE12" box="[370,487,439,465]" pageId="75" pageNumber="76" rank="species">spec. nov.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13052A7CFFEAC945FE52FE3DFD18FE11" box="[503,662,439,466]" captionStart="FIGURES 253–259" captionStartId="63.[151,264,1813,1837]" captionTargetBox="[163,1422,393,1776]" captionTargetId="figure-80@63.[154,1434,381,1790]" captionTargetPageId="63" captionText="FIGURES 253–259. 253–256 Meri tambor spec. nov., male (INPA 3522), left palp (253 prolateral, 254 ventral, 255 retrolateral, 256 detail of embolus); 257–259 Meri tapirapeco spec. nov., female (INPA) (257 epigyne, 258 vulva, 259 schematic course of internal duct system). C—conductor; E—embolus; EP— epigynal pocket; FD—fertilization duct; ft—first turn of duct system; GP—glandular projection; LL—lateral lobe; MS—median septum; PTA—prolateral tibial apophysis; RpP—retro proximal projection; RTA—retrolateral tibial projection; SdP—subdistal projection; SP—spermathecae; tp—tegular protrusion. Scale lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6550500" httpUri="https://zenodo.org/record/6550500/files/figure.png" pageId="75" pageNumber="76">Figs 257–259</figureCitation>
) by the epigyne with EP opening medially on MS. They are distinguished from both species by the epigyne with transversal anterior groove, MS with anterior margins bottlenecked (
<figureCitation id="13052A7CFFEAC945FF05FE75FF70FDDA" box="[160,254,511,537]" captionStart="FIGURES 309–311" captionStartId="75.[151,264,1172,1196]" captionTargetBox="[177,1410,642,1141]" captionTargetId="figure-185@75.[170,1418,633,1148]" captionTargetPageId="75" captionText="FIGURES 309–311. Meri zeteki spec. nov. female (MCZ 99617, holotype) (309 epigyne, 310 vulva, 311 schematic course of internal duct system). ag—anterior groove; EP—epigynal pocket; FD—fertilization duct; ft—first turn of duct system; GP— glandular projection; LL—lateral lobe; MS—median septum; SP—spermathecae. Scale lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6550416" httpUri="https://zenodo.org/record/6550416/files/figure.png" pageId="75" pageNumber="76">Fig. 309</figureCitation>
) and by the vulva with FW postero laterad, liver-shaped (
<figureCitation id="13052A7CFFEAC945FCDAFE75FB95FDDA" box="[895,1051,511,537]" captionStart="FIGURES 309–311" captionStartId="75.[151,264,1172,1196]" captionTargetBox="[177,1410,642,1141]" captionTargetId="figure-185@75.[170,1418,633,1148]" captionTargetPageId="75" captionText="FIGURES 309–311. Meri zeteki spec. nov. female (MCZ 99617, holotype) (309 epigyne, 310 vulva, 311 schematic course of internal duct system). ag—anterior groove; EP—epigynal pocket; FD—fertilization duct; ft—first turn of duct system; GP— glandular projection; LL—lateral lobe; MS—median septum; SP—spermathecae. Scale lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6550416" httpUri="https://zenodo.org/record/6550416/files/figure.png" pageId="75" pageNumber="76">Figs 310–311</figureCitation>
) (anterior groove absent in the latter species; MS with lateral margins diverging and FW posteriad in 
<taxonomicName id="4C3E4D7AFFEAC945FC2CFDAEFBC7FDFE" authorityName="Rheims &amp; Jäger" authorityYear="2022" baseAuthorityName="Simon" baseAuthorityYear="1898" box="[905,1097,548,573]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="75" pageNumber="76" phylum="Arthropoda" rank="species" species="sanctivincenti" status="comb. nov.">
