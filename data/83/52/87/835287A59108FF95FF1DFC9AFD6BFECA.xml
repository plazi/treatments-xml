(black star), and 
<taxonomicName authority="Assing, 2016" authorityName="Assing" authorityYear="2016" box="[545,672,1292,1313]" class="Insecta" family="Staphylinidae" genus="Oxypoda" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="1121" phylum="Arthropoda" rank="species" species="subplicata" status="nov.sp.">
<emphasis box="[545,672,1292,1313]" italics="true" pageId="2" pageNumber="1121">O. subplicata</emphasis>
