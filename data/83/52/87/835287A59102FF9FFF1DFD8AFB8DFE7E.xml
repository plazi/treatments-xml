: Type locality of 
<taxonomicName authority="Assing, 2016" authorityName="Assing" authorityYear="2016" box="[409,626,808,829]" class="Insecta" family="Staphylinidae" genus="Oxypoda" kingdom="Animalia" order="Coleoptera" pageId="14" pageNumber="1133" phylum="Arthropoda" rank="species" species="grandicristata" status="nov.sp.">
<emphasis box="[409,626,808,829]" italics="true" pageId="14" pageNumber="1133">Oxypoda grandicristata</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[632,698,809,830]" pageId="14" pageNumber="1133" rank="species">nov.sp.</taxonomicNameLabel>
