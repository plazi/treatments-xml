<paragraph blockId="3.[1440,2648,737,1594]" box="[1442,2410,1324,1357]" pageId="3" pageNumber="102">
<emphasis bold="true" box="[1442,1576,1324,1357]" pageId="3" pageNumber="102">Breeding.</emphasis>
