<subSubSection box="[1440,2257,1367,1396]" pageId="3" pageNumber="102" type="activity">
<paragraph blockId="3.[1440,2648,737,1594]" box="[1440,2257,1367,1396]" pageId="3" pageNumber="102">
<emphasis bold="true" box="[1440,1676,1367,1396]" pageId="3" pageNumber="102">Activity patterns.</emphasis>
The Amboro Silky Anteater is nocturnal.
</paragraph>
</subSubSection>
<subSubSection box="[1442,2381,1407,1436]" pageId="3" pageNumber="102" type="biology_ecology">
