<emphasis id="B9614D038E33FFD0FF8CFC67706BFC72" bold="true" box="[113,329,940,959]" pageId="15" pageNumber="672">
Status in 
<bibRefCitation id="EF84ECE08E33FFD0FF3AFC677067FC72" author="ZIMSEN E." box="[199,325,940,959]" firstAuthor="ZIMSEN" pageId="15" pageNumber="672" refId="ref19364" refString="ZIMSEN E. 1964: The type material of I. C. Fabricius. Munksgaard, Copenhagen, 656 pp." type="book" year="1964">ZIMSEN (1964)</bibRefCitation>
