<taxonomicName id="356B53A0B3A505708011FCB7E450B0AB" authority="L." class="Magnoliopsida" family="Plantaginaceae" genus="Veronica" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="189" phylum="Tracheophyta" rank="species" species="scutellata">
Veronica 
<normalizedToken id="826E268586837EC20BA74C002B687187" originalValue="scutelláta" pageId="null" pageNumber="189">scutellata</normalizedToken>
<authorityName id="20B12EA94E751EF9AE21D0A43FD7110E" pageId="null" pageNumber="189">L.</authorityName>
