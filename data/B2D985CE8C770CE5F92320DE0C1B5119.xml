<taxonomicName id="EB265D7E36452E4AF9A9DE4AF83A177E" authority="Schkuhr" class="Liliopsida" family="Cyperaceae" genus="Scirpus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="409" phylum="Tracheophyta" rank="species" species="radicans">
