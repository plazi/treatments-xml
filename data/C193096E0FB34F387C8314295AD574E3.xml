<subSubSection id="587AB514CD2E638E29AB73C196A89A0D" pageId="null" pageNumber="18" type="description">
<paragraph id="42B3AF82B173C815D2BB2C9E2D004D24" pageId="null" pageNumber="18">
Ausdauernd, mit weit kriechenden, gegliederten Rhizomen, die 
<normalizedToken id="1A79817B0EC95E46D50E68171DF4F13E" originalValue="schuppenförmige" pageId="null" pageNumber="18">schuppenfoermige</normalizedToken>
<normalizedToken id="C6AB1E9BF563E9D76679D0D1F015E857" originalValue="Blätter" pageId="null" pageNumber="18">Blaetter</normalizedToken>
tragen. 
<emphasis id="E402772F813F5A7651CF1132E0FF0547" italics="true" pageId="null" pageNumber="18">
<normalizedToken id="02D499A7B56B4A101575EB0C273312E3" originalValue="Blätter" pageId="null" pageNumber="18">Blaetter</normalizedToken>
<normalizedToken id="60E80239165B09BF17998C776FCD6E74" originalValue="wechselständig" pageId="null" pageNumber="18">wechselstaendig</normalizedToken>
, in der 
<normalizedToken id="3E557E47D55440D8D396FFA14FC23E23" originalValue="Blütenregion" pageId="null" pageNumber="18">Bluetenregion</normalizedToken>
<normalizedToken id="1F7D5B7BE4105DC50B4EC999F97D8C28" originalValue="gegenständig" pageId="null" pageNumber="18">gegenstaendig</normalizedToken>
, rund, lederartig
</emphasis>
, unterseits 
<normalizedToken id="A9A6F4A935309CA8D6848A4E08E517C7" originalValue="drüsig" pageId="null" pageNumber="18">druesig</normalizedToken>
punktiert, 
<emphasis id="4ACD10F1C31D33EDE184B648A13FFD73" italics="true" pageId="null" pageNumber="18">
auf der 
<normalizedToken id="889FF3A3B4654B434B9C50DF69726FAB" originalValue="Wasseroberfläche" pageId="null" pageNumber="18">Wasseroberflaeche</normalizedToken>
schwimmend.
</emphasis>
<normalizedToken id="A5CB6DE519C3BDAE5D38E3F52C919A5D" originalValue="Blüten" pageId="null" pageNumber="18">Blueten</normalizedToken>
gestielt, nur wenig 
<normalizedToken id="4804BD2D4F4D4BA2BCA0D06805C172E8" originalValue="über" pageId="null" pageNumber="18">ueber</normalizedToken>
die 
<normalizedToken id="EC7483F4FF8BCE5ADFB478CB07D8A703" originalValue="Wasseroberfläche" pageId="null" pageNumber="18">Wasseroberflaeche</normalizedToken>
herausragend. 
<emphasis id="437AB445246731DF3815B626424A152F" italics="true" pageId="null" pageNumber="18">Krone 3</emphasis>
- 
<emphasis id="FFE1D60A272C776FFEA87CBADE49396E" italics="true" pageId="null" pageNumber="18">
5 cm im Durchmesser, gelb, am Rande gefranst, im Schlunde 
<normalizedToken id="40FDAD356E23C6309257950BD01DC164" originalValue="bärtig" pageId="null" pageNumber="18">baertig</normalizedToken>
.
</emphasis>
Frucht 1,5-2,5 cm lang. - 
<normalizedToken id="8254E6323B729C71157CD3B7422B0B30" originalValue="Blüte" pageId="null" pageNumber="18">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="E6BF1936BE3E87D9546448DF7028AA80" pageId="null" pageNumber="18">
<emphasis id="C83127569C4E674006CD761322682FCC" italics="true" pageId="null" pageNumber="18">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B081AE8507AC1D272D54B8185A5655B2" italics="true" pageId="null" pageNumber="18">54:</emphasis>
Material aus Schleswig-Holstein (Scheerer 1939), aus Japan (Harada 1952, Wada 1966), aus Indien (Sobti und Singh 1961).
</paragraph>
<paragraph id="42F313DDA8EAC5F5A328B7FD0A7368D7" pageId="null" pageNumber="18">
<emphasis id="295C6DCF4422F976FB8EE544E57C36CE" italics="true" pageId="null" pageNumber="18">Standort.</emphasis>
Kollin, selten montan. 
<normalizedToken id="CB106A2A03D65B4769F3B125698410E7" originalValue="Nährstoffreiche" pageId="null" pageNumber="18">Naehrstoffreiche</normalizedToken>
, sommerwarme 
<normalizedToken id="6F062607C22CC22CC2AA81244D2677F2" originalValue="Gewässer" pageId="null" pageNumber="18">Gewaesser</normalizedToken>
<normalizedToken id="6DD4D00A7E4E8A6D998915855E27D63F" originalValue="über" pageId="null" pageNumber="18">ueber</normalizedToken>
schlammigen 
<normalizedToken id="437DD79E68D73BC623086E61B224457D" originalValue="Tonböden" pageId="null" pageNumber="18">Tonboeden</normalizedToken>
in wintermilden Lagen. Teiche, 
<normalizedToken id="A4295DFA978F8789C390104EC31DBE40" originalValue="Altwässer" pageId="null" pageNumber="18">Altwaesser</normalizedToken>
. 
<emphasis id="323798257DF3C7E5281FE7F2B3023740" italics="true" pageId="null" pageNumber="18">Trapo-Nymphoidetum</emphasis>
Oberd. 1957.
</paragraph>
<paragraph id="175FD356BD3C95975A7BF1F57A962AA5" pageId="null" pageNumber="18">
<emphasis id="8DB7D747BBE4BD58827C3B173943AFF7" italics="true" pageId="null" pageNumber="18">Verbreitung. Eurasiatische Pflanze:</emphasis>
Mittel- und 
<normalizedToken id="58DD746FB9E2DADBED49C26B34B9D978" originalValue="Südeuropa" pageId="null" pageNumber="18">Suedeuropa</normalizedToken>
(
<normalizedToken id="4A9E2634C41023338276460058754C07" originalValue="nordwärts" pageId="null" pageNumber="18">nordwaerts</normalizedToken>
bis England, Holland und zur Ostsee), Asien (
<normalizedToken id="31CCD382FE8674DD067008702E8318D3" originalValue="ostwärts" pageId="null" pageNumber="18">ostwaerts</normalizedToken>
bis Indien und Japan). - Im Gebiet: Savoyen (Gebiet des Lac du Bourget und der untern Tarentaise), Bresse (
<normalizedToken id="FD30E2673AD197E668982C1B5C1DB87C" originalValue="Dép" pageId="null" pageNumber="18">Dep</normalizedToken>
. Ain, Doubs und Jura), Seen von Varese, bei Fopenico unterhalb Lecco im Comerseegebiet; sonst gelegentlich angepflanzt und verwildert (z. B. bei Genf, Tramelan im Berner Jura).
</paragraph>
</subSubSection>
