<materialsCitation id="74FC3CA3FFE56A5AF7C49A07197DB796" ID-GBIF-Occurrence="3783319628" country="Thailand" elevation="1067" location="Kao Nawng" municipality="Bandon" pageId="30" pageNumber="788" specimenCount="1" stateProvince="Malay Peninsula">
