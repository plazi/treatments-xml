<location id="C14B6025FFE56A5AF7BE9A0716EBB749" LSID="urn:lsid:plazi:treatment:4C3D87E8FFE56A5BFA449DED1ECBB298:C14B6025FFE56A5AF7BE9A0716EBB749" box="[2114,2283,3166,3195]" country="Thailand" municipality="Bandon" name="Kao Nawng" pageId="30" pageNumber="788" stateProvince="Malay Peninsula">Kao Nawng</location>
