<subSubSection id="24CB1080FFA3FFF2FAB2A8678196FF55" lastPageId="24" lastPageNumber="25" pageId="23" pageNumber="24" type="discussion">
<paragraph id="6C6E430BFFA3FFFDFAB2A86784EEF857" blockId="23.[151,1437,1513,1972]" pageId="23" pageNumber="24">
<emphasis id="5EA59F19FFA3FFFDFAB2A867815EF8C7" bold="true" box="[199,315,1801,1827]" pageId="23" pageNumber="24">Remarks.</emphasis>
Previous records from the coast of 
<collectingRegion id="AE158DE9FFA3FFFDF894A8678330F8C7" box="[737,853,1801,1827]" country="Brazil" name="Sao Paulo" pageId="23" pageNumber="24">São Paulo</collectingRegion>
include Santos Bay (MZUSP 
<quantity id="AB29EEEEFFA3FFFDFEC2A867857BF8C7" box="[1207,1310,1801,1827]" metricMagnitude="2" metricUnit="m" metricValue="2.766568" pageId="23" pageNumber="24" unit="in" value="10892.0">10892 in</quantity>
<bibRefCitation id="08403EFAFFA3FFFDFF5DA86780B1F8A3" author="Dall'Occo, P. L." pageId="23" pageNumber="24" refId="ref60273" refString="Dall'Occo, P. L. (2010) Taxonomia e Distribuicao das Lagostas (Crustacea: Decapoda: Achelata e Polychelida) no Oceano Atlantico. PhD Thesis (unpublished), Universidade Estadual Paulista (Unesp), Rio Claro, 432 pp." type="book" year="2010">Dall’Occo 2010</bibRefCitation>
). This species is locally consumed, but there is no special fishery for it on a commercial scale (
<bibRefCitation id="08403EFAFFA3FFFDFE9EA84385EAF8A3" author="Holthuis, L. B." box="[1259,1423,1837,1863]" pageId="23" pageNumber="24" pagination="1 - 292" refId="ref64998" refString="Holthuis, L. B. (1991) Marine lobsters of the world. An annotated and illustrated catalogue of species of interest to fisheries known to date. FAO Fisheries Synopsis, 125 (13), 1 - 292." type="journal article" year="1991">Holthuis 1991</bibRefCitation>
); it is captured as bycatch with the pink shrimp 
<taxonomicName id="ABD13888FFA3FFFDF8D9A83F83A1F88F" baseAuthorityName="Perez Farfante" baseAuthorityYear="1967" box="[684,964,1873,1899]" class="Malacostraca" family="Penaeidae" genus="Farfantepenaeus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="23" pageNumber="24" phylum="Arthropoda" rank="species" species="subtilis">
<emphasis id="5EA59F19FFA3FFFDF8D9A83F83A1F88F" box="[684,964,1873,1899]" italics="true" pageId="23" pageNumber="24">Farfantepenaeus subtilis</emphasis>
</taxonomicName>
in the north coast of 
<collectingCountry id="14C6039BFFA3FFFDFEC8A83F8564F88F" box="[1213,1281,1873,1899]" name="Brazil" pageId="23" pageNumber="24">Brazil</collectingCountry>
(
<bibRefCitation id="08403EFAFFA3FFFDFF67A83F80B1F86B" author="Cintra, I. H. A. &amp; Paiva, K. S. &amp; Herrmann, M. &amp; Barbosa, J. M. &amp; Klautau, A. G. M. &amp; de Araujo Silva, K. C. A." pageId="23" pageNumber="24" pagination="69 - 77" refId="ref57898" refString="Cintra, I. H. A., Paiva, K. S., Herrmann, M., Barbosa, J. M., Klautau, A. G. M. &amp; de Araujo Silva, K. C. A. (2017) Carcinofauna acompanhante do camarao-rosa em pescarias industriais na plataforma continental amazonica. Acta of Fisheries and Aquatic Resources, 5 (2), 69 - 77. https: // doi. org / 10.2312 / ActaFish. 2017.5.2.69 - 77" type="journal article" year="2017">
Cintra 
<emphasis id="5EA59F19FFA3FFFDFF17A83C85F8F88F" box="[1378,1437,1873,1899]" italics="true" pageId="23" pageNumber="24">et al.</emphasis>
2017
</bibRefCitation>
). Sequences accession number (GenBank): CCDB 5741—16S (
<accessionNumber id="7382DEE8FFA3FFFDF9E8A81B847AF874" box="[925,1055,1909,1936]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/MF490150" pageId="23" pageNumber="24">MF490150</accessionNumber>
), COI (
<accessionNumber id="7382DEE8FFA3FFFDFE05A81B8494F86B" box="[1136,1265,1909,1935]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/MF490044" pageId="23" pageNumber="24">MF490044</accessionNumber>
) (
<bibRefCitation id="08403EFAFFA3FFFDFF73A81B8096F850" author="Mantelatto, F. L. &amp; Terossi, M. &amp; Negri, M. &amp; Buranelli, R. C. &amp; Robles, R. &amp; Magalhaes, T. &amp; Tamburus, A. F. &amp; Rossi, N. &amp; Miyazaki, M. J." pageId="23" pageNumber="24" pagination="805 - 815" refId="ref68637" refString="Mantelatto, F. L., Terossi, M., Negri, M., Buranelli, R. C., Robles, R., Magalhaes, T., Tamburus, A. F., Rossi, N. &amp; Miyazaki, M. J. (2018) DNA sequence database as a tool to identify decapod crustaceans on the Sao Paulo coastline. Mitochondrial DNA Part A: DNA Mapping, Sequencing and Analysis, 29 (5), 805 - 815. https: // doi. org / 10.1080 / 24701394.2017.1365848" type="journal article" year="2018">
Mantelatto 
<emphasis id="5EA59F19FFA3FFFDFFFDA81880D1F857" italics="true" pageId="23" pageNumber="24">et al.</emphasis>
2018
</bibRefCitation>
)—this sequenced sample is a female collected from Ipojuca, 
<collectingRegion id="AE158DE9FFA3FFFDF9D0A8F78451F857" box="[933,1076,1945,1971]" country="Brazil" name="Pernambuco" pageId="23" pageNumber="24">Pernambuco</collectingRegion>
, 
<collectingCountry id="14C6039BFFA3FFFDFE4AA8F784E2F857" box="[1087,1159,1945,1971]" name="Brazil" pageId="23" pageNumber="24">Brazil</collectingCountry>
.
</paragraph>
