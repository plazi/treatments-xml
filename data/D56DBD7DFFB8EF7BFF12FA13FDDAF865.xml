<geoCoordinate id="38F06AACFFB8EF7BFD92F877FDDFF865" box="[535,618,1986,2013]" degrees="0.003" direction="south" orientation="latitude" pageId="16" pageNumber="17" precision="55" value="-0.003">0.003 s</geoCoordinate>
.
</paragraph>
</subSubSection>
