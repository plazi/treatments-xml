<date id="FF937DC6F77CB13DB4C5FDB8331841C7" pageId="9" pageNumber="530" value="1842-03-30">
<collectingDate id="EFD7842EF77CB13DB4C5FDB8331841C7" pageId="9" pageNumber="530" value="1842-03-30">30 March 1842</collectingDate>
</date>
at 
<collectingMunicipality id="6BF6C17CF77CB13DB003FD94339D41C7" box="[326,420,619,645]" pageId="9" pageNumber="530">Tswaing</collectingMunicipality>
(Saltpannen); NRM 554747 [7259], a juvenile male collected 
<date id="FF937DC6F77CB13DB534FD94372641C7" box="[1137,1311,619,645]" pageId="9" pageNumber="530" value="1844-03-27">
<collectingDate id="EFD7842EF77CB13DB534FD94372641C7" box="[1137,1311,619,645]" pageId="9" pageNumber="530" value="1844-03-27">27 March 1844</collectingDate>
