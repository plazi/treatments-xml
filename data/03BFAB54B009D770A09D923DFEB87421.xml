<taxonomicName id="4C1661C1B009D770A1B4907BFCF47441" authority="(Vander Lind.)" baseAuthorityName="Vander Lind." box="[391,815,1567,1594]" class="Insecta" family="Crabronidae" genus="Tachysphex" kingdom="Animalia" order="Hymenoptera" pageId="7" pageNumber="190" phylum="Arthropoda" rank="species" species="panzeri">
