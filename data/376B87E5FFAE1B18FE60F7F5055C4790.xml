<taxonomicName id="78C24D70FFAE1B19FD19F6C404F04FAB" box="[707,1014,2417,2461]" class="Magnoliopsida" family="Elaeocarpaceae" genus="Elaeocarpus" kingdom="Plantae" order="Oxalidales" pageId="16" pageNumber="166" phylum="Tracheophyta" rank="species" species="joga">
