<subSubSection id="FD9102D0ED0AFF88FF54FE91FBFFFEE9" box="[199,1149,295,321]" pageId="24" pageNumber="175" type="etymology">
<paragraph id="B534515BED0AFF88FF54FE91FBFFFEE9" blockId="24.[151,1437,150,321]" box="[199,1149,295,321]" pageId="24" pageNumber="175">
<emphasis id="87FF8D49ED0AFF88FF54FE91FECCFEE9" bold="true" box="[199,334,295,321]" pageId="24" pageNumber="175">Etymology.</emphasis>
