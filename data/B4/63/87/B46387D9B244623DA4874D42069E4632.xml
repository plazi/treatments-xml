<subSubSection box="[151,799,151,177]" pageId="20" pageNumber="507" type="discussion">
<paragraph blockId="20.[151,799,151,177]" box="[151,799,151,177]" pageId="20" pageNumber="507">
<heading bold="true" box="[151,799,151,177]" fontSize="11" level="1" pageId="20" pageNumber="507" reason="1">
<emphasis bold="true" box="[151,799,151,177]" pageId="20" pageNumber="507">
Identification key to subgenera of 
<taxonomicName authority="Latreille" authorityName="Latreille" box="[579,799,151,177]" class="Insecta" family="Eumenidae" genus="Synagris" kingdom="Animalia" order="Hymenoptera" pageId="20" pageNumber="507" phylum="Arthropoda" rank="genus">
<emphasis bold="true" box="[579,685,151,177]" italics="true" pageId="20" pageNumber="507">Synagris</emphasis>
Latreille
</taxonomicName>
</emphasis>
</heading>
