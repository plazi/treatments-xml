. (
<taxonomicName authorityName="de Saussure" authorityYear="1855" box="[534,624,1981,2004]" class="Insecta" family="Eumenidae" genus="Synagris" kingdom="Animalia" order="Hymenoptera" pageId="21" pageNumber="503" phylum="Arthropoda" rank="subGenus" subGenus="Paragris">
