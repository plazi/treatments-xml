<taxonomicName authorityName="de Saussure" authorityYear="1855" box="[834,933,1981,2005]" class="Insecta" family="Eumenidae" genus="Synagris" kingdom="Animalia" order="Hymenoptera" pageId="21" pageNumber="508" phylum="Arthropoda" rank="species" species="huberti">
<emphasis box="[834,933,1981,2005]" italics="true" pageId="21" pageNumber="508">S. huberti</emphasis>
</taxonomicName>
. b, habitus of female 
<taxonomicName baseAuthorityName="Tullgren" baseAuthorityYear="1904" box="[1155,1274,1981,2005]" class="Insecta" family="Eumenidae" genus="Synagris" kingdom="Animalia" order="Hymenoptera" pageId="21" pageNumber="508" phylum="Arthropoda" rank="species" species="rufopicta">
<emphasis box="[1155,1274,1981,2005]" italics="true" pageId="21" pageNumber="508">S. rufopicta</emphasis>
</taxonomicName>
. c, flagellum of male 
<taxonomicName authorityName="de Saussure" authorityYear="1855" box="[207,305,2017,2041]" class="Insecta" family="Eumenidae" genus="Synagris" kingdom="Animalia" order="Hymenoptera" pageId="21" pageNumber="508" phylum="Arthropoda" rank="species" species="huberti">
<emphasis box="[207,305,2017,2041]" italics="true" pageId="21" pageNumber="508">S. huberti</emphasis>
</taxonomicName>
.
</paragraph>
</caption>
