<subSubSection id="AD5E60F423B7DE481ECC28CF8511AE26" pageId="null" pageNumber="203" type="description">
<paragraph id="FD961441C08E581F1486A4A8ECD58C69" pageId="null" pageNumber="203">
Unterscheidet sich von 
<taxonomicName id="18BC072EBEBE402683E7612FE750A3A1" class="Liliopsida" family="Potamogetonaceae" genus="Potamogeton" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="203" phylum="Tracheophyta" rank="species" species="compressus">
<emphasis id="15E5D6A6596B0987606FADCE90478D32" italics="true" pageId="null" pageNumber="203">P. compressus</emphasis>
</taxonomicName>
(Nr. 12) durch folgende Merkmale: 
<emphasis id="473FFA8D8C96D6E8BA1E4D44E8E1E3FE" italics="true" pageId="null" pageNumber="203">
Stengel rund oder mit 2 stumpfen, nicht 
<normalizedToken id="D72B36096BDE9AD74A48A4E4C22297B4" originalValue="geflügelten" pageId="null" pageNumber="203">gefluegelten</normalizedToken>
Kanten; 
<normalizedToken id="05BE8C063D24B36F2F5AD0256516790F" originalValue="Blätter" pageId="null" pageNumber="203">Blaetter</normalizedToken>
weniger als 10 cm lang, mit breit abgerundeter Spitze, mit 3, seltener 5 
<normalizedToken id="5F8FCF91F30806AD951A482B1A51A98B" originalValue="Längsnerven" pageId="null" pageNumber="203">Laengsnerven</normalizedToken>
; Stiele der 
<normalizedToken id="B9FB79FD6881212C6E34455B8B9A997B" originalValue="Blütenstände" pageId="null" pageNumber="203">Bluetenstaende</normalizedToken>
nicht 
<normalizedToken id="5C570AD6EC009D25730FFF3BBBDC076E" originalValue="über" pageId="null" pageNumber="203">ueber</normalizedToken>
2 cm lang, so lang wie der 5-10 
<normalizedToken id="80A5D8243DE5240151447515FAB1045C" originalValue="blütige" pageId="null" pageNumber="203">bluetige</normalizedToken>
<normalizedToken id="41C7DF8A2330B0D456377830CA31580E" originalValue="Blütenstand" pageId="null" pageNumber="203">Bluetenstand</normalizedToken>
</emphasis>
oder wenig 
<normalizedToken id="2056DB2E12B45690E6A0468C26C9C1A3" originalValue="länger" pageId="null" pageNumber="203">laenger</normalizedToken>
. - 
<normalizedToken id="827B97885044B0C2C408237902457840" originalValue="Blüte" pageId="null" pageNumber="203">Bluete</normalizedToken>
: 
<normalizedToken id="F6884976FE9152227894017B0C63003C" originalValue="Früher" pageId="null" pageNumber="203">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="8B2D6E454DB1F867408D7F451480E160" pageId="null" pageNumber="203">
<emphasis id="4377917DF1920900708E2FC9694C0AFC" italics="true" pageId="null" pageNumber="203">Zytologische Angaben. 2n = 26:</emphasis>
Material aus Schweden (Palmgren 1939).
</paragraph>
<paragraph id="87FE2EA478C9DEB5A648639F9C84BB00" pageId="null" pageNumber="203">
<emphasis id="79FBC751F17EBC5E0939704DFA2D8D4B" italics="true" pageId="null" pageNumber="203">Standort.</emphasis>
Wie 
<taxonomicName id="381E302F8769CD1B7FCFC023D3C5F0DA" class="Liliopsida" family="Potamogetonaceae" genus="Potamogeton" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="203" phylum="Tracheophyta" rank="species" species="acutifolius">
<emphasis id="785709DB6B2276C504D3CBBD796CA09B" italics="true" pageId="null" pageNumber="203">P. acutifolius</emphasis>
</taxonomicName>
(Nr. 13).
</paragraph>
<paragraph id="54FD54B46036678E38157C5F5BF7E600" pageId="null" pageNumber="203">
<emphasis id="CEF8110CC4BF33FADCB15CBC5C675B9B" italics="true" pageId="null" pageNumber="203">Verbreitung. Eurasiatisch-nordamerikanische Pflanze:</emphasis>
<normalizedToken id="51DFE748C2770EA1366B6BD7BE4C9E5A" originalValue="Nordwärts" pageId="null" pageNumber="203">Nordwaerts</normalizedToken>
bis Schottland, Nordskandinavien, Finnland, 
<normalizedToken id="7A2BE5EF9E851F7A1EF85C118BF8DC35" originalValue="südwärts" pageId="null" pageNumber="203">suedwaerts</normalizedToken>
bis Nordspanien, Zentralfrankreich, schweizerisches Mittelland, Jugoslawien, Bulgarien; vereinzelte und weit auseinanderliegende Fundstellen durch 
<normalizedToken id="78F17DA9CA7644903B3486A37C8E775F" originalValue="Rußland" pageId="null" pageNumber="203">Russland</normalizedToken>
, Sibirien und Zentralasien 
<normalizedToken id="B3C805A66E249264EF90E1FA955C054A" originalValue="ostwärts" pageId="null" pageNumber="203">ostwaerts</normalizedToken>
bis ins Amurgebiet; in Nordamerika vor allem im 
<normalizedToken id="AAC83D0A9F7EBE5C924ED7C4D103C916" originalValue="östlichen" pageId="null" pageNumber="203">oestlichen</normalizedToken>
Teil zwischen 40 und 60° NB. Verbreitungskarte von Meusel (1964). - Im Gebiet: 
<normalizedToken id="C1CB703B6273B9FEE141EDAD105D6935" originalValue="Dép" pageId="null" pageNumber="203">Dep</normalizedToken>
. Jura, 
<normalizedToken id="455A233DD86D29E6F02ED20A7A2A085C" originalValue="Dép" pageId="null" pageNumber="203">Dep</normalizedToken>
. Doubs, Bonfol (einziger Fundort in der Schweiz, 
<normalizedToken id="E6ED646ABC2B0FA89C0B83F637E21A12" originalValue="früher" pageId="null" pageNumber="203">frueher</normalizedToken>
auch bei La 
<normalizedToken id="F76C354763D7F20D0EB0FCA82F50436C" originalValue="Brévine" pageId="null" pageNumber="203">Brevine</normalizedToken>
), Gebiet von Belfort, 
<normalizedToken id="DA1FC93A08B20B6405B5F5FAF1C258C9" originalValue="Elsaß" pageId="null" pageNumber="203">Elsass</normalizedToken>
, deutsches Bodenseegebiet; sehr selten.
</paragraph>
</subSubSection>
