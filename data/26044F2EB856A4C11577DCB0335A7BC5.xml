<subSubSection id="5A170D0AA4B3D241E6DE97D5811009AD" pageId="null" pageNumber="185" type="vernacular_names">
<paragraph id="EC112B9DC4EBA14B06889F0B36F6B8BE" pageId="null" pageNumber="185">Bachbungen-Ehrenpreis</paragraph>
</subSubSection>
</title>
<subSubSection id="381DE89F42EF6E590D81F09E3F145F28" pageId="null" pageNumber="185" type="description">
<paragraph id="32D5B900508508E3ED47D99120256484" pageId="null" pageNumber="185">
<normalizedToken id="3684A6CA44AE33508B49DADD3A7048D9" originalValue="Mehrjährig" pageId="null" pageNumber="185">Mehrjaehrig</normalizedToken>
; bis 
<normalizedToken id="4C246CC073A16EBFB5A9F69C8DF42B8A" originalValue="über" pageId="null" pageNumber="185">ueber</normalizedToken>
50 cm hoch. Stengel rund, markig, niederliegend und aufsteigend. 
<emphasis id="872FD637F0F5D873F41A2536FD52AB52" italics="true" pageId="null" pageNumber="185">
<normalizedToken id="2EABFE3FD57C0DBAEBE2DDC6849B3150" originalValue="Blätter" pageId="null" pageNumber="185">Blaetter</normalizedToken>
kurz gestielt, oval bis rundlich
</emphasis>
, in oder 
<normalizedToken id="911C8B919774F7A22558034DE4512990" originalValue="über" pageId="null" pageNumber="185">ueber</normalizedToken>
der Mitte am breitesten, 1-4 cm lang und 1-2 cm breit. Kelch zur Fruchtzeit 3-5 mm lang. Krone im Durchmesser 5-7,5 mm, 
<emphasis id="AC4B90CD611D93CCC059765F3237E385" italics="true" pageId="null" pageNumber="185">blau bis dunkelviolett.</emphasis>
Fruchtstiele schief 
<normalizedToken id="44FA4AFC16E54C280C82015C9AD5D55A" originalValue="aufwärts" pageId="null" pageNumber="185">aufwaerts</normalizedToken>
gerichtet. 
<normalizedToken id="A60B926FEB9D3380094153725FBAC526" originalValue="Früchte" pageId="null" pageNumber="185">Fruechte</normalizedToken>
fast kugelig, 3-4 mm im Durchmesser. - 
<normalizedToken id="01AE7464F682890A88FC44E5C7DCEB58" originalValue="Blüte" pageId="null" pageNumber="185">Bluete</normalizedToken>
: 
<normalizedToken id="5A7E16063C01396A11DEAD6D48BA79E0" originalValue="Später" pageId="null" pageNumber="185">Spaeter</normalizedToken>
<normalizedToken id="EDD6B3BEFF84AFE69E15AB94A80713FC" originalValue="Frühling" pageId="null" pageNumber="185">Fruehling</normalizedToken>
bis Herbst.
</paragraph>
<paragraph id="539649DF01AC2EA50C835A74370BAAAE" pageId="null" pageNumber="185">
<emphasis id="EB37362683C3114D6A3C993B9203E228" italics="true" pageId="null" pageNumber="185">
<pageBreakToken id="B8EEEBA1865FD14E3C43B64E7F2E9CCC" pageId="null" pageNumber="185">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="8923A4E1BE5F5FA7986B85F9A2448893" italics="true" pageId="null" pageNumber="185">18:</emphasis>
Material aus botanischen 
<normalizedToken id="0B91DAA228D66C0B2B51AAFFBA9893D9" originalValue="Gärten" pageId="null" pageNumber="185">Gaerten</normalizedToken>
und verschiedenen Teilen Europas (Huber 1927, Simonet 1934b, Schlenker 1936, Mattick in Tischler 1950, 
<normalizedToken id="9AD32742FB867D9840C49D800B14FEFE" originalValue="Löve" pageId="null" pageNumber="185">Loeve</normalizedToken>
1954b, Skalinska et al. 1964, Marchant 1967, Kuzmanov und 
<normalizedToken id="902629A5ECF2559483204AFF5CCC5850" originalValue="Kožuharov" pageId="null" pageNumber="185">Kozuharov</normalizedToken>
1969). In Polen wurden auch 
<emphasis id="56B2EC7B7445F0E76D660082C5F31025" italics="true" pageId="null" pageNumber="185">2n</emphasis>
= 
<emphasis id="EC9A50F1AE77A1385B25AE1800457B35" italics="true" pageId="null" pageNumber="185">36</emphasis>
<normalizedToken id="23A2FE460B7822EFB86E7940A3530973" originalValue="gezählt" pageId="null" pageNumber="185">gezaehlt</normalizedToken>
(Skalinska et al. 1964).
</paragraph>
<paragraph id="BE3B61D4C35F4976136301ED08383015" pageId="null" pageNumber="185">
<emphasis id="792E5D7B58C2D78FB838B440F59E057F" italics="true" pageId="null" pageNumber="185">Standort.</emphasis>
Kollin, montan und subalpin. 
<normalizedToken id="2D485C8A1AC75D880F96FF1A7428D63D" originalValue="Nährstoffreiche" pageId="null" pageNumber="185">Naehrstoffreiche</normalizedToken>
, humose 
<normalizedToken id="77B5A987AEA083A12EC84E2454980A48" originalValue="Schlammböden" pageId="null" pageNumber="185">Schlammboeden</normalizedToken>
an langsam 
<normalizedToken id="C2F409832566FAFFE81F340002538A3D" originalValue="fließenden" pageId="null" pageNumber="185">fliessenden</normalizedToken>
<normalizedToken id="1D88D3C708946BF0316F47A73611743D" originalValue="Gewässern" pageId="null" pageNumber="185">Gewaessern</normalizedToken>
oder sickernasse 
<normalizedToken id="06DBF715149F1C5EE5A1D636FDE758AC" originalValue="Böden" pageId="null" pageNumber="185">Boeden</normalizedToken>
. 
<normalizedToken id="3DF79FC70E58B5B9BDA3B0B958E966FC" originalValue="Gräben" pageId="null" pageNumber="185">Graeben</normalizedToken>
, Quellfluren, 
<normalizedToken id="A8F37C853D2385B9DC4F0B97561AEB32" originalValue="Bachränder" pageId="null" pageNumber="185">Bachraender</normalizedToken>
. 
<emphasis id="9F5CF162992ED1AD70029BC83F703CE3" italics="true" pageId="null" pageNumber="185">Sparganio-Glycerion</emphasis>
Br.-Bl. et Siss. 1942.
</paragraph>
<paragraph id="3CE4E386AA2B5857BBF3DBF9DB0DC8D1" pageId="null" pageNumber="185">
<emphasis id="E51329CF6845EA725299AA28360F2E5C" italics="true" pageId="null" pageNumber="185">Verbreitung. Eurasiatische Pflanze:</emphasis>
Europa und 
<normalizedToken id="CBE219082E44165F69A53C89BD808279" originalValue="nördliches" pageId="null" pageNumber="185">noerdliches</normalizedToken>
Asien (ohne arktische Gebiete); Nordafrika. - Im Gebiet verbreitet und 
<normalizedToken id="2A641489F1293FB1F753C29BA350A9ED" originalValue="häufig" pageId="null" pageNumber="185">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
