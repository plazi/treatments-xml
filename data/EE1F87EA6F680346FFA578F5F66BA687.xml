<taxonomicName id="A1B64D7F6F680346FA597570F989A35A" box="[1437,1565,2101,2130]" class="Magnoliopsida" family="Euphorbiaceae" genus="Euphorbia" kingdom="Plantae" order="Malpighiales" pageId="1" pageNumber="303" phylum="Tracheophyta" rank="genus">Euphorbia</taxonomicName>
