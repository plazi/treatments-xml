), Alangium ridley: (
<taxonomicName id="A1B64D7F6F680346F81A7A30F71FAC86" box="[2014,2187,1909,1934]" class="Magnoliopsida" family="Alangiaceae" higherTaxonomySource="GBIF" kingdom="Plantae" order="Cornales" pageId="1" pageNumber="303" phylum="Tracheophyta" rank="family">Alangiaceae</taxonomicName>
