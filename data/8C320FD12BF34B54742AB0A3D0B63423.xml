<subSubSection id="4AF80F7AAC6BAF23847792212B2E69DD" pageId="null" pageNumber="577" type="vernacular_names">
<paragraph id="C2343F1A67BEA22820D8A1A5A2C252A6" pageId="null" pageNumber="577">Linsen-Wicke</paragraph>
</subSubSection>
</title>
<subSubSection id="211FDCF1F3E427C5FAA9418C04C26F59" pageId="null" pageNumber="577" type="description">
<paragraph id="320E98810B8ED53979A0D426F1E36DF2" pageId="null" pageNumber="577">
1 
<normalizedToken id="D6D5372A7FCD29E5CE577DD863561FC6" originalValue="jährig" pageId="null" pageNumber="577">jaehrig</normalizedToken>
; 20-50 cm hoch. Stengel aufrecht oder aufsteigend, unverzweigt oder im obern Teil verzweigt, kahl. 
<normalizedToken id="5964ED2836CC590EF7D9061285379E48" originalValue="Blätter" pageId="null" pageNumber="577">Blaetter</normalizedToken>
mit 10-28 
<normalizedToken id="DE0FC354D9BBA0250412EB3155B53D2A" originalValue="Teilblättern" pageId="null" pageNumber="577">Teilblaettern</normalizedToken>
und 
<emphasis id="6FB1EF801F4247581BE0CB3B4FB750AF" italics="true" pageId="null" pageNumber="577">
kurzer, 
<normalizedToken id="39151F8E4CD0AE4E7ADCC1D0A9371745" originalValue="endständiger" pageId="null" pageNumber="577">endstaendiger</normalizedToken>
, grannenartiger Spitze
</emphasis>
(keine Ranke); 
<normalizedToken id="C249D9B09EA4534BAA1461BED68F25AD" originalValue="Teilblätter" pageId="null" pageNumber="577">Teilblaetter</normalizedToken>
0,5-1,5 cm lang und 3-6mal so lang wie breit, vorn gestutzt und 3 
<normalizedToken id="73CB3E6AC375972834537F0415688D52" originalValue="zähnig" pageId="null" pageNumber="577">zaehnig</normalizedToken>
, kahl; 
<normalizedToken id="34B7AB317DF41CD791B31443BB169491" originalValue="Nebenblätter" pageId="null" pageNumber="577">Nebenblaetter</normalizedToken>
sehr schmal, etwa ⅓ so lang wie die untern 
<normalizedToken id="B463F6E0CBAE0758378A2CE0E385410F" originalValue="Teilblätter" pageId="null" pageNumber="577">Teilblaetter</normalizedToken>
, am Grunde meist 
<normalizedToken id="D30C434AA5FB056790F5E35AE7102472" originalValue="gezähnt" pageId="null" pageNumber="577">gezaehnt</normalizedToken>
, ohne 
<normalizedToken id="A88BA99D8EFA0E3B23983190AECFD3FF" originalValue="Nektardrüse" pageId="null" pageNumber="577">Nektardruese</normalizedToken>
. 
<normalizedToken id="DB275975A1D7EF1F4B508702984D3400" originalValue="Blüten" pageId="null" pageNumber="577">Blueten</normalizedToken>
in 1-4 
<normalizedToken id="540B1CB8CACB4DCBC6E3D74A1AAC47FC" originalValue="blütigen" pageId="null" pageNumber="577">bluetigen</normalizedToken>
, gestielten Trauben, nickend. 
<emphasis id="E1EC94A7209E8FA7C6FF194DC8968910" italics="true" pageId="null" pageNumber="577">Stiel des Blutenstandes</emphasis>
⅙-⅓ 
<emphasis id="05DBEEC816952A885010FDEC9BA2DC06" italics="true" pageId="null" pageNumber="577">
so lang wie das 
<normalizedToken id="F970427A63143F7086ACFB30AEEF20EE" originalValue="nächststehende" pageId="null" pageNumber="577">naechststehende</normalizedToken>
Blatt
</emphasis>
, 
<normalizedToken id="F8A6426804690465EDB5A739B026FE57" originalValue="länger" pageId="null" pageNumber="577">laenger</normalizedToken>
als die 
<normalizedToken id="FD226F39C2736E83B45DC46F572FFA74" originalValue="Blüte" pageId="null" pageNumber="577">Bluete</normalizedToken>
. Kelch kahl; 
<normalizedToken id="63C98312E92DC1B3F1B84EBA26392CBD" originalValue="Kelchzähne" pageId="null" pageNumber="577">Kelchzaehne</normalizedToken>
so lang oder etwas 
<normalizedToken id="68D45FDABD4B27D212894FB78CEAD2E5" originalValue="länger" pageId="null" pageNumber="577">laenger</normalizedToken>
als die 
<normalizedToken id="01C0646559643518CD633E454ADDDC33" originalValue="Kelchröhre" pageId="null" pageNumber="577">Kelchroehre</normalizedToken>
. Krone 0,7-0,9 cm lang, 
<normalizedToken id="5FD1AECF37714C10A86833D096B10E8C" originalValue="weiß" pageId="null" pageNumber="577">weiss</normalizedToken>
, 
<emphasis id="510C7CD1A78427847B2A502A2061C0C7" italics="true" pageId="null" pageNumber="577">mit violett gestreifter Fahne.</emphasis>
Frucht 
<normalizedToken id="C8D18CC4DA076D085E793AFB7EA4461C" originalValue="hängend" pageId="null" pageNumber="577">haengend</normalizedToken>
, flach, 
<emphasis id="14861CA1F0ED0F302B2DCFF9F87D0EBA" italics="true" pageId="null" pageNumber="577">1,5-2,5 cm lang und 0,4-0,5 cm breit</emphasis>
, kahl, meist 3-4samig. Samen 3,5 bis 5,5 mm lang. - 
<normalizedToken id="A3EFE63BC098727C0032A975E55831DA" originalValue="Blüte" pageId="null" pageNumber="577">Bluete</normalizedToken>
: 
<normalizedToken id="D82F426E8669BC9A47626AFE0F3F8DE9" originalValue="Später" pageId="null" pageNumber="577">Spaeter</normalizedToken>
<normalizedToken id="FF8C6F15E03F718557F064189C13EB86" originalValue="Frühling" pageId="null" pageNumber="577">Fruehling</normalizedToken>
und 
<normalizedToken id="7F6CCDF4BD45868E247D614E03D4987E" originalValue="früher" pageId="null" pageNumber="577">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="312BD4F2D5EF5F7A5A104821835BC008" pageId="null" pageNumber="577">
<emphasis id="21BC524875FABE24F48868894C1F5DDA" italics="true" pageId="null" pageNumber="577">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="373B998108C78958944745236AD909E6" italics="true" pageId="null" pageNumber="577">14:</emphasis>
Material aus Kulturen oder unbekannter Herkunft (Sveshnikova 1927, Heitz 1931b, Kumar 1960, Srivastava 1963).
</paragraph>
<paragraph id="BADC2879E57273D6D02EF132002802D0" pageId="null" pageNumber="577">
<emphasis id="68DB55AE4D7AF8B356230A0FEF8DCD77" italics="true" pageId="null" pageNumber="577">Standort.</emphasis>
Kollin. Lockere, trockene, kalkarme 
<normalizedToken id="7365A3916DD8D689EBBDBFB49A587817" originalValue="Böden" pageId="null" pageNumber="577">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="D88F66B377D12F2347CA5670955D0FE1" originalValue="Äcker" pageId="null" pageNumber="577">Aecker</normalizedToken>
, Weinberge, 
<normalizedToken id="86DA86F593FFB5A24CD80A078994200E" originalValue="Schuttplätze" pageId="null" pageNumber="577">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="0EE546138738E13E63E540BB98F121D3" pageId="null" pageNumber="577">
<emphasis id="0C2E20355E63EF2095E28AFCB21F9CB4" italics="true" pageId="null" pageNumber="577">Verbreitung.</emphasis>
<normalizedToken id="021B0D6E5B679A0C89C202D136E6570E" originalValue="Ursprünglich" pageId="null" pageNumber="577">Urspruenglich</normalizedToken>
vielleicht 
<emphasis id="25B5A534AAB3D2B4BC1A3C283A5F5EF5" italics="true" pageId="null" pageNumber="577">ostmediterrane Pflanze;</emphasis>
heute im ganzen Mittelmeergebiet gelegentlich als Futterpflanze angebaut und oft verwildert. - Im Gebiet selten verwildert oder adventiv, so in der Oberrheinischen Tiefebene und im 
<normalizedToken id="6FA8E74B1E19700B1CAE1D9E6555E3A5" originalValue="südlichen" pageId="null" pageNumber="577">suedlichen</normalizedToken>
Teil des Gebiets.
</paragraph>
</subSubSection>
