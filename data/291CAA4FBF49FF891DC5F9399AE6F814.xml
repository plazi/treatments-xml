<emphasis id="93C1C74BBF49FF891DC5F9399A1EF948" bold="true" box="[151,552,1724,1751]" pageId="20" pageNumber="271">
[
<taxonomicName id="66B560DABF49FF891DF3F9389A17F948" authority="Sato, 1985" authorityName="Sato" authorityYear="1985" box="[161,545,1724,1751]" class="Insecta" family="Dytiscidae" genus="Copelatus" kingdom="Animalia" order="Coleoptera" pageId="20" pageNumber="271" phylum="Arthropoda" rank="species" species="takakurai">
<emphasis id="93C1C74BBF49FF891DF3F93899A0F949" bold="true" box="[161,406,1724,1751]" italics="true" pageId="20" pageNumber="271">Copelatus takakurai</emphasis>
<bibRefCitation id="C52466A8BF49FF891CCCF9389A17F948" author="Sato, M." box="[414,545,1724,1750]" pageId="20" pageNumber="271" pagination="57 - 67" refId="ref33445" refString="Sato, M. (1985) The genus Copelatus of Japan (Coleoptera: Dytiscidae). Transactions of the Shikoku Entomological Society, 17, 57 - 67." type="journal article" year="1985">Satô, 1985</bibRefCitation>
