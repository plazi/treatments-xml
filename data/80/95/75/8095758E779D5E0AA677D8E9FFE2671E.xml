<emphasis bold="true" italics="true" pageId="0" pageNumber="1">Eye width</emphasis>
: 0.4 mm. 
<emphasis bold="true" italics="true" pageId="0" pageNumber="1">Vertex width</emphasis>
: 1.2 mm. 
<emphasis bold="true" italics="true" pageId="0" pageNumber="1">Fore femur length</emphasis>
: 2.2 mm. 
<emphasis bold="true" italics="true" pageId="0" pageNumber="1">Fore femur width</emphasis>
: 0.5 mm. 
<emphasis bold="true" italics="true" pageId="0" pageNumber="1">Mid femur length</emphasis>
: 2.5 mm. 
<emphasis bold="true" italics="true" pageId="0" pageNumber="1">Mid femur width</emphasis>
: 0.8 mm. 
<emphasis bold="true" italics="true" pageId="0" pageNumber="1">Hind femur length</emphasis>
