<typeStatus box="[199,258,1004,1030]" pageId="18" pageNumber="155">Type</typeStatus>
species
</emphasis>
. 
<taxonomicName authority="Lapointe &amp; Watling, 2022" authorityName="Lapointe &amp; Watling" authorityYear="2022" box="[361,572,1004,1030]" class="Anthozoa" family="Mopseidae" genus="Dokidisis" higherTaxonomySource="GBIF" kingdom="Animalia" order="Alcyonacea" pageId="18" pageNumber="155" phylum="Cnidaria" rank="species" species="australis" status="new species">
