<figureCitation id="135A2A7BC45D7C3ADAA8FB8EBBEFFBD3" box="[144,242,1045,1072]" captionStart-0="FIGURE 1" captionStart-1="FIGURE 2" captionStart-2="FIGURE 3" captionStart-3="FIGURE 4" captionStart-4="FIGURE 5" captionStartId-0="1.[136,235,2015,2039]" captionStartId-1="2.[136,235,2009,2033]" captionStartId-2="3.[136,235,1157,1181]" captionStartId-3="4.[136,235,1533,1557]" captionStartId-4="5.[136,235,1428,1452]" captionTargetBox-0="[215,1372,1047,1992]" captionTargetBox-1="[215,1372,1328,1985]" captionTargetBox-2="[215,1372,189,1134]" captionTargetBox-3="[145,1443,198,1509]" captionTargetBox-4="[151,1436,189,1405]" captionTargetId-0="figure-334@1.[215,1372,1047,1992]" captionTargetId-1="figure-390@2.[215,1372,1328,1985]" captionTargetId-2="figure-312@3.[215,1372,189,1134]" captionTargetId-3="figure-132@4.[145,1443,198,1509]" captionTargetId-4="figure-217@5.[151,1436,189,1405]" captionTargetPageId-0="1" captionTargetPageId-1="2" captionTargetPageId-2="3" captionTargetPageId-3="4" captionTargetPageId-4="5" captionText-0="FIGURE 1. General habitus of Rhomeocalpsua torosa Li, Tomaszewska &amp; Cai, gen. et sp. nov., holotype, NIGP180054, under incident light. A, Dorsal view. B, Ventral view. Scale bars = 500 μm." captionText-1="FIGURE 2. General habitus of Rhomeocalpsua torosa Li, Tomaszewska &amp; Cai, gen. et sp. nov., holotype, NIGP180054, under widefield fluorescence. A, Dorsal view. B, Ventral view. Scale bars = 500 μm." captionText-2="FIGURE 3. General habitus of Rhomeocalpsua torosa Li, Tomaszewska &amp; Cai, gen. et sp. nov., holotype, NIGP180054, under confocal microscopy. A, Dorsal view. B, Ventral view. Scale bars = 500 μm." captionText-3="FIGURE 4. Details of Rhomeocalpsua torosa Li, Tomaszewska &amp; Cai, gen. et sp. nov., holotype, NIGP180054, under confocal microscopy. A, Head, dorsal view. B, Head, ventral view. C, Antenna, dorsal view. D, Antenna, ventral view. E, Mesothorax, ventral view. F, Abdominal base, ventral view. G, Abdominal apex, ventral view. H, Mesotarsus, ventral view. I, Metatarsus, dorsal view. Abbreviations: a1–9, antennomeres 1–9; cl, clypeus; lbp, labial palp; msc, mesocoxa; msf, mesofemur; mst1–3, mesotarsomeres 1–3; msv, mesoventrite; mtf, metafemur; mtt1–3, metatarsomeres 1–3; mtv, metaventrite; mxp, maxillary palp; v1–6, ventrites 1–6. Scale bars = 100 μm." captionText-4="FIGURE 5. X-ray microtomographic reconstruction of Rhomeocalpsua torosa Li, Tomaszewska &amp; Cai, gen. et sp. nov., holotype, NIGP180054. A, Dorsal view. B, Ventral view. C, Anterodorsal view. D, Lateral view. E, Posterior view. F, Antenna, rendered under “Sum along Ray” mode. Scale bars = 500 μm in A–E, 200 μm in F." figureDoi-0="http://doi.org/10.5281/zenodo.6530505" figureDoi-1="http://doi.org/10.5281/zenodo.6530509" figureDoi-2="http://doi.org/10.5281/zenodo.6530511" figureDoi-3="http://doi.org/10.5281/zenodo.6530513" figureDoi-4="http://doi.org/10.5281/zenodo.6530517" httpUri-0="https://zenodo.org/record/6530505/files/figure.png" httpUri-1="https://zenodo.org/record/6530509/files/figure.png" httpUri-2="https://zenodo.org/record/6530511/files/figure.png" httpUri-3="https://zenodo.org/record/6530513/files/figure.png" httpUri-4="https://zenodo.org/record/6530517/files/figure.png" pageId="2" pageNumber="148">Figs 1–5</figureCitation>
)
