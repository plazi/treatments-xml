<emphasis id="B923C857FFFFC87CFF0DBC48FD68F9F7" bold="true" box="[151,697,1555,1581]" pageId="1" pageNumber="356">
Key to Caucasus species of 
<taxonomicName id="4C576FC6FFFFC87CFE77BC48FD68F9F7" authority="Meigen" authorityName="Meigen" authorityYear="1826" box="[493,697,1555,1581]" class="Insecta" family="Muscidae" genus="Drymeia" kingdom="Animalia" order="Diptera" pageId="1" pageNumber="356" phylum="Arthropoda" rank="genus">
<emphasis id="B923C857FFFFC87CFE77BC48FD84F9F7" bold="true" box="[493,597,1555,1581]" italics="true" pageId="1" pageNumber="356">Drymeia</emphasis>
Meigen
</taxonomicName>
</emphasis>
