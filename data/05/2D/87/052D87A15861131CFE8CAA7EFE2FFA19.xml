<collectingCountry box="[250,343,1427,1451]" name="Malaysia" pageId="8" pageNumber="2600">Sarawak</collectingCountry>
(
<figureCitation box="[358,463,1427,1451]" captionStart="Figure 18" captionStartId="25.[160,225,1675,1698]" captionTargetBox="[163,1153,977,1643]" captionTargetId="figure@25.[163,1153,977,1643]" captionTargetPageId="25" captionText="Figure 18. Map of Sabah and Brunei (Borneo) with collecting site of Grouvellinus species with new species record in red fonts." figureDoi="http://doi.org/10.5281/zenodo.3666562" httpUri="https://zenodo.org/record/3666562/files/figure.png" pageId="8" pageNumber="2600">Figure 18</figureCitation>
