<paragraph blockId="8.[160,1155,1322,1451]" pageId="8" pageNumber="2600">
<taxonomicName authorityName="Freitag, Pangantihon and Njunjic" authorityYear="2018" box="[160,447,1356,1381]" class="Insecta" family="Elmidae" genus="Grouvellinus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="2600" phylum="Arthropoda" rank="species" species="andrekuipersi">
<emphasis box="[160,447,1356,1381]" italics="true" pageId="8" pageNumber="2600">Grouvellinus andrekuipersi</emphasis>
