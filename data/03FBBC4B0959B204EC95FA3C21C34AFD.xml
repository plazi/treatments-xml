<subSubSection id="C3485ED60959B207EC95F99523A24CDA" pageId="13" pageNumber="464" type="etymology">
<paragraph id="8BED0D5D0959B207EC95F995229C4CAE" blockId="13.[151,1436,1608,2031]" pageId="13" pageNumber="464">
<emphasis id="B926D14F0959B207EC95F99521294C4A" bold="true" box="[151,290,1609,1635]" pageId="13" pageNumber="464">Etymology:</emphasis>
<taxonomicName id="4C5276DE0959B207ED28F995217B4C4A" authorityName="Hamilton" authorityYear="1822" box="[298,368,1609,1635]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="13" pageNumber="464" phylum="Chordata" rank="genus">
<emphasis id="B926D14F0959B207ED28F995217B4C4A" box="[298,368,1609,1635]" italics="true" pageId="13" pageNumber="464">Garra</emphasis>
</taxonomicName>
: named based on a vernacular Indian name, a fish living in mud; 
<taxonomicName id="4C5276DE0959B207E862F99424D04C4B" authorityName="Fowler &amp; Steinitz" authorityYear="1956" box="[1120,1243,1608,1634]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="13" pageNumber="464" phylum="Chordata" rank="species" species="barreimiae">
<emphasis id="B926D14F0959B207E862F99424D04C4B" box="[1120,1243,1608,1634]" italics="true" pageId="13" pageNumber="464">barreimiae</emphasis>
</taxonomicName>
: composed from 
<collectingRegion id="4996C3BF0959B207EC95F9B020FD4CAF" box="[151,246,1644,1670]" country="Oman" name="Al Buraymi" pageId="13" pageNumber="464">Buraimi</collectingRegion>
, a city/region in northwestern 
<collectingCountry id="F3454DCD0959B207EE49F9B122984CAE" box="[587,659,1645,1671]" name="Oman" pageId="13" pageNumber="464">Oman</collectingCountry>
.
</paragraph>
<paragraph id="8BED0D5D0959B207ECC5F94C230F4C82" blockId="13.[151,1436,1608,2031]" box="[199,772,1680,1707]" pageId="13" pageNumber="464">
<emphasis id="B926D14F0959B207ECC5F94C218C4C82" bold="true" box="[199,391,1680,1707]" pageId="13" pageNumber="464">Common name:</emphasis>
Orange-ear 
<taxonomicName id="4C5276DE0959B207EE11F94D225D4C82" authorityName="Hamilton" authorityYear="1822" box="[531,598,1681,1707]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="13" pageNumber="464" phylum="Chordata" rank="genus">Garra</taxonomicName>
, 
<collectingRegion id="4996C3BF0959B207EE63F94C22B64C83" box="[609,701,1680,1706]" country="Oman" name="Al Buraymi" pageId="13" pageNumber="464">Buraimi</collectingRegion>
<taxonomicName id="4C5276DE0959B207EEC6F94D230F4C82" authorityName="Hamilton" authorityYear="1822" box="[708,772,1681,1707]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="13" pageNumber="464" phylum="Chordata" rank="genus">Garra</taxonomicName>
</paragraph>
<paragraph id="8BED0D5D0959B207ECC5F96923A24CDA" blockId="13.[151,1436,1608,2031]" pageId="13" pageNumber="464">
<emphasis id="B926D14F0959B207ECC5F96921454CE6" bold="true" box="[199,334,1717,1743]" pageId="13" pageNumber="464">Taxonomy:</emphasis>
<taxonomicName id="4C5276DE0959B207ED57F96922154CE7" authorityName="Fowler &amp; Steinitz" authorityYear="1956" box="[341,542,1716,1743]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="13" pageNumber="464" phylum="Chordata" rank="species" species="barreimiae">
<emphasis id="B926D14F0959B207ED57F96922154CE7" box="[341,542,1716,1743]" italics="true" pageId="13" pageNumber="464">Garra barreimiae</emphasis>
</taxonomicName>
was described by Fowler ([H. W.) &amp; Steinitz (H.) 1956:262, figs. 1-4 (Bulletin of the Research Council of 
<collectingCountry id="F3454DCD0959B207EDC8F90422034CDB" box="[458,520,1752,1778]" name="Israel" pageId="13" pageNumber="464">Israel</collectingCountry>
v. 5B, no. 3-4, from 
<collectingRegion id="4996C3BF0959B207EEF1F90423594CDB" box="[755,850,1752,1778]" country="Oman" name="Al Buraymi" pageId="13" pageNumber="464">Buraimi</collectingRegion>
