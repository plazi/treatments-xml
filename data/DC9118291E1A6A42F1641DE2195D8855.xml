<subSubSection id="D3B27CE252A5E7320CDE2CCF3325D784" pageId="null" pageNumber="620" type="description">
<paragraph id="B4A16860C5A7CB94C88799118A46130F" pageId="null" pageNumber="620">
Die beiden seitlichen, 
<normalizedToken id="FD04CB378D52E46AEC2CEFB1E1401CF7" originalValue="äußern" pageId="null" pageNumber="620">aeussern</normalizedToken>
<normalizedToken id="51758987F6C05F99B66B00136C407AF7" originalValue="Perigonblätter" pageId="null" pageNumber="620">Perigonblaetter</normalizedToken>
etwa 3mal so lang wie breit; 
<emphasis id="C4E34F56E1960074E2C736FF0A1A2835" italics="true" pageId="null" pageNumber="620">
<normalizedToken id="45834FBDAC58A8153E21F3C71BE92C3A" originalValue="Fächer" pageId="null" pageNumber="620">Faecher</normalizedToken>
der Staubbeutel vertikal, fast parallel gerichtet, Zwischenraum zwischen den 
<normalizedToken id="BF52ADC8755013ECA25DCE1E0616E4CD" originalValue="Fächern" pageId="null" pageNumber="620">Faechern</normalizedToken>
0,5-1 mm; 
<taxonomicName id="C31AE499B1FA45E6ECB49A644262FB34" class="Liliopsida" family="Orchidaceae" genus="Sporn" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="620" phylum="Tracheophyta" rank="species" species="gegen">Sporn gegen</taxonomicName>
die Spitze hin 
<normalizedToken id="B41ED6BDA44045E9A975306D83CBBDC4" originalValue="allmählich" pageId="null" pageNumber="620">allmaehlich</normalizedToken>
<normalizedToken id="D9DC86CF21EE708CFF53B6FCEE601EB6" originalValue="dünner" pageId="null" pageNumber="620">duenner</normalizedToken>
werdend, spitz
</emphasis>
. - 
<normalizedToken id="368FDDCD78285348DB707C76CE72E9A9" originalValue="Blüte" pageId="null" pageNumber="620">Bluete</normalizedToken>
: 
<normalizedToken id="AE534DC4F1C82A8C7ECB339C8BA0D95B" originalValue="Früher" pageId="null" pageNumber="620">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="DE1F91AAACFF726F54BEC136CDAC1764" pageId="null" pageNumber="620">
<emphasis id="FCF94594F9849EE069B3A60AEA345818" italics="true" pageId="null" pageNumber="620">Zytologische Angaben. 2n = 42:</emphasis>
Material aus 
<normalizedToken id="451394A96E3EFCA1F041768CBB9534CB" originalValue="Südschweden" pageId="null" pageNumber="620">Suedschweden</normalizedToken>
; Embryosackentwicklung normal (Afzelius 1922); Material aus England Richardson 1934), aus dem Norden des Kantons 
<normalizedToken id="ADB2C46A423BF063024AC020F2AA9F1A" originalValue="Zürich" pageId="null" pageNumber="620">Zuerich</normalizedToken>
(400 m) und von Cresta (Avers, 
<normalizedToken id="3215F73B3A3F45CC32E531D0CE314802" originalValue="Graubünden" pageId="null" pageNumber="620">Graubuenden</normalizedToken>
) (Heusser 1938), aus 
<normalizedToken id="7CBC1A4CA96C0446950EDCDBE3F99DDD" originalValue="Österreich" pageId="null" pageNumber="620">Oesterreich</normalizedToken>
(Diannelidis 1948), aus Polen (Skalinska et al. 1957), aus Finnland (Sorsa 1963), aus Holland (Kliphuis 1963).
</paragraph>
<paragraph id="91BD954098AA4BDE9278E787512A9493" pageId="null" pageNumber="620">
<emphasis id="FE13FC3F25D910894D021AFF384DC390" italics="true" pageId="null" pageNumber="620">Standort.</emphasis>
Kollin, montan und subalpin. Kalkhaltige, feuchte bis frische, lockere, 
<normalizedToken id="250DB74390FE26A24C9F4B44ECE28556" originalValue="ungedüngte" pageId="null" pageNumber="620">ungeduengte</normalizedToken>
, humose 
<normalizedToken id="80474BD73AF0F774EAADB6688DA5ACB8" originalValue="Böden" pageId="null" pageNumber="620">Boeden</normalizedToken>
. Lichte Laub- und 
<normalizedToken id="09E0B8990E2B611A43191EA417DD1414" originalValue="Nadelwälder" pageId="null" pageNumber="620">Nadelwaelder</normalizedToken>
(besonders 
<normalizedToken id="93C81C2867D9B91772C890FB2F44C31A" originalValue="Föhrenwälder" pageId="null" pageNumber="620">Foehrenwaelder</normalizedToken>
), Borstgraswiesen, Riedwiesen in sommerwarmen Gegenden.
</paragraph>
<paragraph id="8257B3649C3FA561921F8076EF78A7F5" pageId="null" pageNumber="620">
<emphasis id="3BA415199F0683CF29A31C3C1CF3E8E7" italics="true" pageId="null" pageNumber="620">Verbreitung. Eurasiatische Pflanze:</emphasis>
Nordgrenze durch Schottland, Nordskandinavien, Nordsibirien; 
<normalizedToken id="A029737C2D276415D60A8CFEF4FBA3AB" originalValue="Südgrenze" pageId="null" pageNumber="620">Suedgrenze</normalizedToken>
durch das Mediterrangebiet (auch Nordwestafrika), Kaukasus, Kleinasien, Himalaja. - Im Gebiet verbreitet, ziemlich 
<normalizedToken id="0CBE961F13612CCD703E1488AD1B882C" originalValue="häufig" pageId="null" pageNumber="620">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
</treatment>
