<bibRefCitation id="EBE1C8422461313029230A9F76093ED5" author="Yu, DS" journalOrPublisher="Folia Entomologica Hungarica" pageId="0" pageNumber="45" refId="B25" refString="Yu, DS, van Achterberg, K, Horstmann, K, 2016. World Ichneumonoidea 2015. Taxonomy, biology, morphology and distribution. [Database on flash drive]. Taxapad, Vancouver." title="World Ichneumonoidea 2015. Taxonomy, biology, morphology and distribution. [Database on flash drive]. Taxapad, Vancouver." year="2016">Yu et al. 2016</bibRefCitation>
).
</paragraph>
</subSubSection>
<subSubSection id="0D29CD65C705240F940926CAB034AB8B" pageId="0" pageNumber="45" type="remarks">
