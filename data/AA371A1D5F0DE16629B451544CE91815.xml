<subSubSection id="3AF6E8A06A3DE61D5E9D6866236CEF56" pageId="null" pageNumber="312" type="description">
<paragraph id="5C9462A20F7484B7556E9CEF77B509C8" pageId="null" pageNumber="312">
Ausdauernd; 
<emphasis id="A4904D8C47289734BE3F548C7C4DB99A" italics="true" pageId="null" pageNumber="312">
kurze, unterirdische 
<normalizedToken id="6F9EDD5F70EC6A4DA63492AB89915446" originalValue="Ausläufer" pageId="null" pageNumber="312">Auslaeufer</normalizedToken>
treibend, die dicht und dachziegelartig mit gelblichen Blattschuppen bedeckt sind. Anstelle des 
<normalizedToken id="F81762F4FA06B165100930A7E494B5D3" originalValue="Blatthäutchens" pageId="null" pageNumber="312">Blatthaeutchens</normalizedToken>
ein Haarkranz.
</emphasis>
<normalizedToken id="547C3DAEF5AE15690537283B9514B19B" originalValue="Blütenstand" pageId="null" pageNumber="312">Bluetenstand</normalizedToken>
eine Traube oder Rispe. 
<normalizedToken id="3C367E2A06A4B19ECACD445D2086F303" originalValue="Ährchen" pageId="null" pageNumber="312">Aehrchen</normalizedToken>
<normalizedToken id="9726F23627E0F2769F24D4DE998E937B" originalValue="mehrblütig" pageId="null" pageNumber="312">mehrbluetig</normalizedToken>
, 
<normalizedToken id="080F3CBD1F5EDEFC05124FBC4481434A" originalValue="Blüten" pageId="null" pageNumber="312">Blueten</normalizedToken>
zwitterig. 
<normalizedToken id="F4E18E8E0B30B165E85BA103CACF4316" originalValue="Hüllspelzen" pageId="null" pageNumber="312">Huellspelzen</normalizedToken>
2, die 
<normalizedToken id="0B688F13865EC7DCD662489798639414" originalValue="längere" pageId="null" pageNumber="312">laengere</normalizedToken>
<normalizedToken id="E40106695845629D1D794B5D8762B551" originalValue="kürzer" pageId="null" pageNumber="312">kuerzer</normalizedToken>
als die 
<normalizedToken id="2F3DE46C7E7258E7E4466B896FD2FC96" originalValue="längste" pageId="null" pageNumber="312">laengste</normalizedToken>
Deckspelze.
</paragraph>
<paragraph id="CE9F52A8A637EA69321012158A1719BC" pageId="null" pageNumber="312">
Die Gattung 
<taxonomicName id="53D99946D86E17257000D19AD44B9B87" class="Liliopsida" family="Poaceae" genus="Diplachne" kingdom="Plantae" order="Poales" pageId="null" pageNumber="312" phylum="Tracheophyta" rank="genus">
<emphasis id="A540C1562F2573F222987120D3DE5D52" italics="true" pageId="null" pageNumber="312">Diplachne</emphasis>
</taxonomicName>
<normalizedToken id="F1510928EA2F461879F2FB8A1E0B9D25" originalValue="umfaßt" pageId="null" pageNumber="312">umfasst</normalizedToken>
<emphasis id="AE76717D1CD7CCB5DE8D66BF0AFF19FF" italics="true" pageId="null" pageNumber="312">etwa 20 Arten in West- und Zentralasien.</emphasis>
Von Janchen (1959) ist der Gattungsname 
<taxonomicName id="1F81E4CB7C2602D6CFB403BDD8D00275" authority="Keng" authorityName="Keng" class="Liliopsida" family="Poaceae" genus="Cleistogenes" kingdom="Plantae" order="Poales" pageId="null" pageNumber="312" phylum="Tracheophyta" rank="genus">
<emphasis id="B86FBBE78A7CD1833FC70F1D4C9CABE2" italics="true" pageId="null" pageNumber="312">Cleistogenes</emphasis>
Keng
</taxonomicName>
<normalizedToken id="CA76ADB27A7C9D2619EF67D0916702D0" originalValue="übernommen" pageId="null" pageNumber="312">uebernommen</normalizedToken>
worden (vgl. die dort zitierte Literatur).
</paragraph>
