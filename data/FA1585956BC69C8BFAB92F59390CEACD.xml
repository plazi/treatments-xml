<subSubSection id="8AC872D71102B4A5A05305C718D165E3" type="description">
<paragraph id="1C90565CD3D1E0FC14A379A6CD158EF7">
<normalizedToken id="F893174A53AE1D6F566F340CE0C64B3D" originalValue="Blüten">Blueten</normalizedToken>
in 
<normalizedToken id="323189A1398E465EF786E5FA17141259" originalValue="endständigen">endstaendigen</normalizedToken>
, 
<normalizedToken id="997B754440423D85372199DAFBAE8600" originalValue="ährigen">aehrigen</normalizedToken>
, rispigen oder doldigen 
<normalizedToken id="5E2216796C8AA96D05003F8241492CE2" originalValue="Blütenständen">Bluetenstaenden</normalizedToken>
. 
<emphasis id="88D5BA4E58A270E945BDFB6D03BD6099" italics="true">
Kelch 
<normalizedToken id="E06E5119FFDEBE979A64536E67E5C7A8" originalValue="röhrenförmig">roehrenfoermig</normalizedToken>
, 4
</emphasis>
- 
<emphasis id="53A3335FCBF724986490995B7C7E04E4" italics="true">
5 
<normalizedToken id="AB18BFD263128CEADFA1C27890BC5DD1" originalValue="zähnig">zaehnig</normalizedToken>
.
</emphasis>
Krone mit 
<normalizedToken id="1B06EB49DAADFF19EED1309E6E5AF9C6" originalValue="Röhre">Roehre</normalizedToken>
und flach ausgebreitetem, 5teiligem, 2lippigem Rand. Fruchtknoten 4 
<normalizedToken id="46E155C780FFE843AF2FD064064D03EF" originalValue="fächerig">faecherig</normalizedToken>
, 
<emphasis id="6C9BFA0663737E89F3CC55C9286C6A7B" italics="true">
zur Fruchtzeit sich in 4 
<normalizedToken id="B883171216430D7D91AC4F24CFA82D8E" originalValue="Teilfrüchte">Teilfruechte</normalizedToken>
trennend.
</emphasis>
</paragraph>
<paragraph id="35D285EC06637528C8363C5965B030B8">
Die Gattung 
<taxonomicName id="6B624747CC47E9A32236D69A221E4A1C" class="Magnoliopsida" family="Verbenaceae" genus="Verbena" kingdom="Plantae" order="Lamiales" phylum="Tracheophyta" rank="genus">
<emphasis id="7736B7C68B2A0D76E2C03B2D527EDA84" italics="true">Verbena</emphasis>
</taxonomicName>
<normalizedToken id="66AE836065DDD52A706EBA04E9CF9201" originalValue="umfaßt">umfasst</normalizedToken>
etwa 
<emphasis id="9CAD22CA77553EC738D89F222F5E24DE" italics="true">230 Arten</emphasis>
, die vorwiegend in den 
<emphasis id="51FB68068A70CC2A35396C0CC6029D07" italics="true">tropischen Gebieten Amerikas</emphasis>
verbreitet sind.
</paragraph>
