<subSubSection id="358D34C32DC6BEC4B413A1E2EE550F67" pageId="null" pageNumber="94" type="description">
<paragraph id="093A0C2864E5F2F60EB81BAFA6861A4D" pageId="null" pageNumber="94">
<normalizedToken id="45B61DFD2BF88C581D8792F59321479B" originalValue="Grundständige" pageId="null" pageNumber="94">Grundstaendige</normalizedToken>
<normalizedToken id="E0E2905A10B61BCEA1BDA68942A6316F" originalValue="Blätter" pageId="null" pageNumber="94">Blaetter</normalizedToken>
<normalizedToken id="EE1ECFDD3EAF560EAAE5DC42BAD586F7" originalValue="ähnlich" pageId="null" pageNumber="94">aehnlich</normalizedToken>
den 
<normalizedToken id="37FB6E4D6CC8F51E02A694BEB26EFCC8" originalValue="Frühlingsblättern" pageId="null" pageNumber="94">Fruehlingsblaettern</normalizedToken>
von 
<taxonomicName id="224A0D360E752DF438E2690660FD6FF7" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="94" phylum="Tracheophyta" rank="species" species="polyanthemophyllus">
<emphasis id="F63265D93B7AAF78A25677A088EE1240" italics="true" pageId="null" pageNumber="94">R. polyanthemophyllus</emphasis>
</taxonomicName>
(Nr. 25d). Charakteristische Unterschiede an den 
<normalizedToken id="852D8A239E28D454DB6A94B3D19C2DCB" originalValue="Früchtchen" pageId="null" pageNumber="94">Fruechtchen</normalizedToken>
: bei 
<emphasis id="032B8C73FD4DAD4147D74767E0288F5F" italics="true" pageId="null" pageNumber="94">R. polyanthemus ist der Schnabel kurz, etwa</emphasis>
⅕ 
<emphasis id="1331D66EA45ECDC9974CFC99DF39EE1B" italics="true" pageId="null" pageNumber="94">
so lang wie das 
<normalizedToken id="45279929017951AB8E44DD894EF4B806" originalValue="Früchtchen" pageId="null" pageNumber="94">Fruechtchen</normalizedToken>
, schwach gebogen, nicht eingerollt.
</emphasis>
- 
<normalizedToken id="AEC0EB5A4E63655731A6472E07D28301" originalValue="Blüte" pageId="null" pageNumber="94">Bluete</normalizedToken>
: 
<normalizedToken id="DCA25C77FE8FB82EFAF2F536542C01F6" originalValue="Frühling" pageId="null" pageNumber="94">Fruehling</normalizedToken>
und 
<normalizedToken id="1439FDCDF9CAA384EA0491FFE58FC650" originalValue="früher" pageId="null" pageNumber="94">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="C1E3250E60367D8320C182F934394613" pageId="null" pageNumber="94">
<emphasis id="FA5A75E4B18E837A342A7742885A971F" italics="true" pageId="null" pageNumber="94">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="29851271B6F7032A85A9747A85EB1074" italics="true" pageId="null" pageNumber="94">16:</emphasis>
Material aus botanischen 
<normalizedToken id="64222CE57BCAEF29C69EDC08953F8A8F" originalValue="Gärten" pageId="null" pageNumber="94">Gaerten</normalizedToken>
(Larter 1932), aus Polen (Skalinska et al. 1961), 
<emphasis id="54EC967CF720D66A3F762967EBA54829" italics="true" pageId="null" pageNumber="94">2n</emphasis>
= 
<emphasis id="6923529BC5084B7192DBF81C48AAA8E6" italics="true" pageId="null" pageNumber="94">16</emphasis>
+ 
<emphasis id="B3B3A6D473B823E07CBB3681B5E8A7D7" italics="true" pageId="null" pageNumber="94">0-4</emphasis>
B-Chromosomen: Material aus 
<normalizedToken id="F9489B13761D9D4A7C42487DB86ECFD7" originalValue="Dänemark" pageId="null" pageNumber="94">Daenemark</normalizedToken>
(
<normalizedToken id="7B125F32C28D60896EFC43CB6C20C009" originalValue="Böcher" pageId="null" pageNumber="94">Boecher</normalizedToken>
1958).
</paragraph>
<paragraph id="611495BA819E90F7E2BB5D83F2A99325" pageId="null" pageNumber="94">
<pageBreakToken id="182D1595F64B91544B0316E078D67C4A" pageId="null" pageNumber="94">der</pageBreakToken>
, Trockenwiesen. Schwerpunkt vielleicht im 
<normalizedToken id="934C4EE5F5EAEC365603B5A3D679B47A" originalValue="östlichen" pageId="null" pageNumber="94">oestlichen</normalizedToken>
<emphasis id="2262215DDBB4DA3B54701A68762A6407" italics="true" pageId="null" pageNumber="94">Potentillo-Quercetum</emphasis>
Libb. 1933.
</paragraph>
<paragraph id="7D1F9CBAE0C4347C06BA15DCC3848B8A" pageId="null" pageNumber="94">
<emphasis id="B282D64526E33DD8297DF3B5D7AC1030" italics="true" pageId="null" pageNumber="94">Verbreitung.</emphasis>
Angaben unsicher, da 
<emphasis id="E9BCB87B9181922BCA1E10C17D54F775" italics="true" pageId="null" pageNumber="94">R. polyanthemus</emphasis>
oft mit andern Arten verwechselt wurde. 
<emphasis id="44077440BDA7B683C3F3F784EE7A8E9D" italics="true" pageId="null" pageNumber="94">Eurasiatische Pflanze:</emphasis>
<normalizedToken id="BA5C053906D039D9C579AD2EDF8BB273" originalValue="Westwärts" pageId="null" pageNumber="94">Westwaerts</normalizedToken>
bis ins Rheinland, 
<normalizedToken id="85350D3C8BEF11F8E4568EE284C4AC3A" originalValue="nordwärts" pageId="null" pageNumber="94">nordwaerts</normalizedToken>
bis 60° NB (in Skandinavien), 
<normalizedToken id="77C224E8950EE48A16495D9D3FE420BE" originalValue="südwärts" pageId="null" pageNumber="94">suedwaerts</normalizedToken>
bis 
<normalizedToken id="BB38A1CE8F4D3876DC3EDD318D935EF8" originalValue="Süddeutschland" pageId="null" pageNumber="94">Sueddeutschland</normalizedToken>
, Balkanhalbinsel und Kaukasus, 
<normalizedToken id="8230BCD7123320020C16B9219B0DF3C3" originalValue="ostwärts" pageId="null" pageNumber="94">ostwaerts</normalizedToken>
bis Baikalsee und Turkestan. Verbreitungskarte von Meusel (1965). - Im Gebiet: Kaiserstuhl in der Oberrheinischen Tiefebene (Angabe bedarf der 
<normalizedToken id="9F2DF5B5068DC870ECF13858A5F2C87B" originalValue="Nachprüfung" pageId="null" pageNumber="94">Nachpruefung</normalizedToken>
); durch das Donautal 
<normalizedToken id="64CA8A9114548007C8FEA703E9553A97" originalValue="aufwärts" pageId="null" pageNumber="94">aufwaerts</normalizedToken>
bis nahe an unser Gebiet; die Angabe aus dem Tessin (Val Colla) ist kaum richtig.
</paragraph>
</subSubSection>
