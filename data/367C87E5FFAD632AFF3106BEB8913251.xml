<taxonomicName id="79D54D70FFAC6329FE310085BAD53507" authority="MZSP" authorityName="MZSP" box="[416,665,1259,1282]" class="Gastropoda" family="Solaropsidae" genus="Solaropsis" kingdom="Animalia" order="Stylommatophora" pageId="5" pageNumber="84" phylum="Mollusca" rank="species" species="caperata">
