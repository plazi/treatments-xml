<subSubSection id="F6CF6578FFAF632AFF3105ADB8913251" pageId="6" pageNumber="85" type="distribution">
<paragraph id="BE6A36F3FFAF632AFF3105ADBAD131D9" blockId="6.[160,669,451,477]" box="[160,669,451,477]" pageId="6" pageNumber="85">
<emphasis id="8CA1EAE1FFAF632AFF3105ADB97F31D8" bold="true" box="[160,307,451,477]" italics="true" pageId="6" pageNumber="85">Distribution.</emphasis>
Known only from 
<typeStatus id="616E8851FFAF632AFD9C05ADBA7331D9" box="[525,575,451,476]" pageId="6" pageNumber="85">type</typeStatus>
locality.
</paragraph>
<paragraph id="BE6A36F3FFAF632AFF310676B8913251" blockId="6.[160,1155,536,596]" pageId="6" pageNumber="85">
