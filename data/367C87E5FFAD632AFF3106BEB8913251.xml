<paragraph id="BE6A36F3FFAF632AFF310546BA2A3182" blockId="6.[160,1155,296,391]" pageId="6" pageNumber="85">
<emphasis id="8CA1EAE1FFAF632AFF310546BAC43147" bold="true" box="[160,648,296,322]" italics="true" pageId="6" pageNumber="85">Measurements (width and height in mm).</emphasis>
<typeStatus id="616E8851FFAF632AFD090547BAB33147" box="[664,767,297,322]" pageId="6" pageNumber="85">Holotype</typeStatus>
MZSP 14400 (
<figureCitation id="26EE2A76FFAF632AFC0F0547BC533147" box="[926,1055,297,322]" captionStart-0="Figures 2–7" captionStart-1="Figures 8, 9" captionStartId-0="5.[160,235,1259,1282]" captionStartId-1="6.[160,235,1704,1727]" captionTargetBox-0="[163,1153,142,1228]" captionTargetBox-1="[165,1148,1303,1671]" captionTargetId-0="figure-112@5.[163,1153,142,1228]" captionTargetId-1="figure-293@6.[162,1152,1299,1673]" captionTargetPageId-0="5" captionTargetPageId-1="6" captionText-0="Figures 2–7. Holotype of Solaropsis caperata MZSP 144000 (W = 50.2 mm): 2, apical view; 3, inferior view; 4, left view; 5, apertural view; 6, detail of region half a whorl preceding the peristome, showing characteristic depression, dorsal-slightly inferior view; 7, detail of apical region, apical view, scale = 1 mm." captionText-1="Figures 8, 9. Holotype, details of punctuation in the sculpture, scales = 1 mm." figureDoi-0="http://doi.org/10.5281/zenodo.6457015" figureDoi-1="http://doi.org/10.5281/zenodo.6457017" httpUri-0="https://zenodo.org/record/6457015/files/figure.png" httpUri-1="https://zenodo.org/record/6457017/files/figure.png" pageId="6" pageNumber="85">Figures 2–9</figureCitation>
): 50.2 by 33.3; 
<typeStatus id="616E8851FFAF632AFF4A0522B9733160" box="[219,319,332,357]" pageId="6" pageNumber="85">paratype</typeStatus>
MZSP 154136 (
<figureCitation id="26EE2A76FFAF632AFE7A0522BAC63160" box="[491,650,332,357]" captionStart="Figures 10–16" captionStartId="7.[160,235,840,863]" captionTargetBox="[163,1153,142,808]" captionTargetId="figure-3@7.[163,1153,142,808]" captionTargetPageId="7" captionText="Figures 10–16. Paratypes of Solaropsis caperata. 10, MZSP 154136 (W 45.1 mm), frontal view; 11, same apical view; 12, same, inferior view; 13, MZSP 154137 (W 39.0 mm), frontal view; 14, same, frontalslightly inferior view to show depression; 15, same, apical view; 16, inferior view." figureDoi="http://doi.org/10.5281/zenodo.6457021" httpUri="https://zenodo.org/record/6457021/files/figure.png" pageId="6" pageNumber="85">Figures 10–12</figureCitation>
): 45.1 by 28.5; MZSP 154137 (
<figureCitation id="26EE2A76FFAF632AFC480522BC3A3160" box="[985,1142,332,357]" captionStart="Figures 10–16" captionStartId="7.[160,235,840,863]" captionTargetBox="[163,1153,142,808]" captionTargetId="figure-3@7.[163,1153,142,808]" captionTargetPageId="7" captionText="Figures 10–16. Paratypes of Solaropsis caperata. 10, MZSP 154136 (W 45.1 mm), frontal view; 11, same apical view; 12, same, inferior view; 13, MZSP 154137 (W 39.0 mm), frontal view; 14, same, frontalslightly inferior view to show depression; 15, same, apical view; 16, inferior view." figureDoi="http://doi.org/10.5281/zenodo.6457021" httpUri="https://zenodo.org/record/6457021/files/figure.png" pageId="6" pageNumber="85">Figures 13–16</figureCitation>
): 39.5 by 26.4 (specimen not fully grown).
</paragraph>
