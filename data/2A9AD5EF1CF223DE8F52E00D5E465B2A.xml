<subSubSection id="6BB7E1F5C0B98299C179C9CB5BFD8687" pageId="null" pageNumber="271" type="description">
<paragraph id="94EA88A4CF2A1917B5EF77C64FC87226" pageId="null" pageNumber="271">
Wie 
<taxonomicName id="3E8B66CE28378224260BA1F73DD1799F" class="Magnoliopsida" family="Crassulaceae" genus="Sedum" kingdom="Plantae" order="Saxifragales" pageId="null" pageNumber="271" phylum="Tracheophyta" rank="genus">
<emphasis id="93B61A86E0BFBDF40137E77B614EFE90" italics="true" pageId="null" pageNumber="271">Sedum</emphasis>
</taxonomicName>
(S. 259), 
<emphasis id="278D81DB7DFDF1CDC497BE7B74467D9C" italics="true" pageId="null" pageNumber="271">
jedoch 
<normalizedToken id="1634C99239EBD41CF9AB645B1E53F633" originalValue="Staubblätter" pageId="null" pageNumber="271">Staubblaetter</normalizedToken>
so viele wie 
<normalizedToken id="AE4795781894835A77637F65389025B9" originalValue="Kronblätter" pageId="null" pageNumber="271">Kronblaetter</normalizedToken>
, meist 5
</emphasis>
, selten 4 oder 3.
</paragraph>
<paragraph id="A87867A5C503F0E5DBDF4B7A4EEDE05A" pageId="null" pageNumber="271">
Die Gattung 
<emphasis id="3E3AF66A89D23D5074741983B8A00A16" italics="true" pageId="null" pageNumber="271">
<taxonomicName id="E3A5B2AB7E8CDFCD30AD5FAB7A7BB2E9" class="Bivalvia" family="Mactridae" genus="Crassula" kingdom="Animalia" order="Venerida" pageId="null" pageNumber="271" phylum="Mollusca" rank="genus">Crassula</taxonomicName>
ist fast 
<normalizedToken id="04065AE5306336A94C6896A4E750A10E" originalValue="über" pageId="null" pageNumber="271">ueber</normalizedToken>
die ganze Erde verbreitet und 
<normalizedToken id="E3B21933A1ED2B101445A6729BA424BB" originalValue="umfaßt" pageId="null" pageNumber="271">umfasst</normalizedToken>
etwa 200 Arten;
</emphasis>
<normalizedToken id="B51654F17AE7E68686FEB387037268DF" originalValue="grö" pageId="null" pageNumber="271">groe</normalizedToken>
<emphasis id="022A12EDA63534C39D6DB32711A994C2" italics="true" pageId="null" pageNumber="271">
<normalizedToken id="C6AE7939699E10F1B24C4C6732ABFA88" originalValue="ß" pageId="null" pageNumber="271">ss</normalizedToken>
</emphasis>
te Artenzahl in 
<normalizedToken id="FADCCE0937F4096FD9F73132CC093EF1" originalValue="Südafrika" pageId="null" pageNumber="271">Suedafrika</normalizedToken>
. 
<emphasis id="D97E133D1BAE9998F9B8492DCD24DEF3" italics="true" pageId="null" pageNumber="271">Chromosomengrundzahl</emphasis>
n = 7; polyploide Reihe bis n = 28 (Zusammenstellung der Ergebnisse von Uhl 1948).
</paragraph>
