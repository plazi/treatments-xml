<subSubSection id="54E33ABFB017E3896855CB5BF1018A79" pageId="null" pageNumber="405" type="description">
<paragraph id="23FAEE0B272CAF5C5334F73953D8D47F" pageId="null" pageNumber="405">
<emphasis id="EAEA4B0D68D283B11AAAD9F3CA0497FA" italics="true" pageId="null" pageNumber="405">Pflanze ausdauernd, niederliegend, verholzt</emphasis>
(
<emphasis id="5F65ACE6BF08116E1293775C75DE1CBA" italics="true" pageId="null" pageNumber="405">Spalierstrauch</emphasis>
)
<emphasis id="6175FB435F76B66A55B1A754B9E0EEC2" italics="true" pageId="null" pageNumber="405">
. 
<normalizedToken id="7595AB862FE2A9D7467220CACBC9A90B" originalValue="Blätter" pageId="null" pageNumber="405">Blaetter</normalizedToken>
<normalizedToken id="A1CA4AD4A09E5B46C5B34A8CA2DE0879" originalValue="immergrün" pageId="null" pageNumber="405">immergruen</normalizedToken>
, ungeteilt, 
<normalizedToken id="757D506C259E577977C1E5705BC15B42" originalValue="gezähnt" pageId="null" pageNumber="405">gezaehnt</normalizedToken>
.
</emphasis>
<normalizedToken id="8EEEC1EC744B7A6D6F2DD18B5D5ED970" originalValue="Blüten" pageId="null" pageNumber="405">Blueten</normalizedToken>
zwitterig, einzeln in den Blattachseln, 
<emphasis id="A4740561B12EF25C3C30E684A3D9B338" italics="true" pageId="null" pageNumber="405">
<normalizedToken id="F2EC174726009B9BAEB5153C9796AA4F" originalValue="groß" pageId="null" pageNumber="405">gross</normalizedToken>
</emphasis>
(Durchmesser 2-4 cm). Kelch 1fach (kein 
<normalizedToken id="F60D3CDDEDD78990904DCF50BFA1DB7A" originalValue="Außenkelch" pageId="null" pageNumber="405">Aussenkelch</normalizedToken>
). Kelch- und 
<normalizedToken id="7A8035684266252B3A93FF3C7032F602" originalValue="Kronblätter" pageId="null" pageNumber="405">Kronblaetter</normalizedToken>
6-9. 
<normalizedToken id="6CE6DF51BA87259935D7B2194F067EBF" originalValue="Staubblätter" pageId="null" pageNumber="405">Staubblaetter</normalizedToken>
zahlreich (
<normalizedToken id="44424036D794CC22FB0BF23B28BDE4F1" originalValue="über" pageId="null" pageNumber="405">ueber</normalizedToken>
20). 
<emphasis id="8964E157B43C385C8B4538331B8B1F1A" italics="true" pageId="null" pageNumber="405">
<normalizedToken id="C8437BFD84DC5E3BCE6145F98CDF3E79" originalValue="Früchtchen" pageId="null" pageNumber="405">Fruechtchen</normalizedToken>
auf wenig 
<normalizedToken id="2B7103C3DE84238F91823635B8D2E7FA" originalValue="gewölbtem" pageId="null" pageNumber="405">gewoelbtem</normalizedToken>
Fruchtboden, zahlreich, dicht behaart
</emphasis>
, hart (nicht fleischig), 1samig. 
<emphasis id="1D1836D567386F018D8B07F4EB79E9A4" italics="true" pageId="null" pageNumber="405">
Griffel 
<normalizedToken id="8C1EFE9DA70E7EB014D4F54E9D7D33E3" originalValue="endständig" pageId="null" pageNumber="405">endstaendig</normalizedToken>
</emphasis>
, 
<emphasis id="DF6315682F41B0E2E69A71AABE86562F" italics="true" pageId="null" pageNumber="405">
nach der 
<normalizedToken id="344397FA3151057F2E08C2C3715E3EF5" originalValue="Blüte" pageId="null" pageNumber="405">Bluete</normalizedToken>
weiterwachsend und deshalb auffallend 
<normalizedToken id="40C36422EDC5034AE1D5C58C5EDE66CA" originalValue="verlängert" pageId="null" pageNumber="405">verlaengert</normalizedToken>
, federig behaart, bis zur Reife am 
<normalizedToken id="151267BD174257FB90C296928E02BF32" originalValue="Früchtchen" pageId="null" pageNumber="405">Fruechtchen</normalizedToken>
bleibend.
</emphasis>
</paragraph>
<paragraph id="03484DC063E47EC5268B838F60C2B5A5" pageId="null" pageNumber="405">
Die Gattung 
<emphasis id="279749360C27F4E25C08E231EE855B86" italics="true" pageId="null" pageNumber="405">
<taxonomicName id="66491846E3CC08235496266076464C38" class="Insecta" family="Nymphalidae" genus="Dryas" kingdom="Animalia" order="Lepidoptera" pageId="null" pageNumber="405" phylum="Arthropoda" rank="genus">Dryas</taxonomicName>
hat eurasiatisch-nordamerikanische Verbreitung;
</emphasis>
<normalizedToken id="383ABBAF0E7717B96203D8780BCA3A96" originalValue="südlich" pageId="null" pageNumber="405">suedlich</normalizedToken>
der Arktis kommt die Gattung nur in Gebirgen vor. Die Artenzahl 
<normalizedToken id="49BFC9580F05339D0796DA42F4842759" originalValue="hängt" pageId="null" pageNumber="405">haengt</normalizedToken>
von den Auffassungen des Autors ab: In der Flora der URSS (Band 10, 
<pageBreakToken id="C322B2D215CE63551BEFBFAE61F52255" pageId="null" pageNumber="405">1941</pageBreakToken>
) werden neben 
<taxonomicName id="0D0AD2F7FF4E810258D8DE8958AE2089" class="Insecta" family="Nymphalidae" genus="Dryas" kingdom="Animalia" order="Lepidoptera" pageId="null" pageNumber="405" phylum="Arthropoda" rank="species" species="octopetala">
<emphasis id="069E97FC69F781E8BF411EB89C47E15A" italics="true" pageId="null" pageNumber="405">D. octopetala</emphasis>
</taxonomicName>
10 weitere Arten genannt, die jedoch von andern Autoren nur als Rassen, 
<normalizedToken id="EE28A9A2A71339E7F4FD82BB69EB1594" originalValue="Varietäten" pageId="null" pageNumber="405">Varietaeten</normalizedToken>
oder Unterarten von 
<taxonomicName id="B0797D6A100C23922903D66EA448FAF8" class="Insecta" family="Nymphalidae" genus="Dryas" kingdom="Animalia" order="Lepidoptera" pageId="null" pageNumber="405" phylum="Arthropoda" rank="species" species="octopetala">
<emphasis id="EE6C64DB76757AD91A48F05BD50E676B" italics="true" pageId="null" pageNumber="405">D. octopetala</emphasis>
</taxonomicName>
gewertet werden. 
<normalizedToken id="CB3FC458FAA80477946378121144CF1F" originalValue="Hultén" pageId="null" pageNumber="405">Hulten</normalizedToken>
(1959a) unterscheidet in seiner Bearbeitung der Gattung 
<taxonomicName id="819BCB1091E4309714AB324F5F1E2941" authority="(Schluessel, Diagnosen, Abbildungen, Verbreitungskarten)" baseAuthorityName="Schluessel, Diagnosen, Abbildungen, Verbreitungskarten" class="Insecta" family="Nymphalidae" genus="Dryas" kingdom="Animalia" order="Lepidoptera" pageId="null" pageNumber="405" phylum="Arthropoda" rank="genus">
<emphasis id="D080B6F7EA2AE35B517169EDB520B6FE" italics="true" pageId="null" pageNumber="405">Dryas</emphasis>
(
<normalizedToken id="8C8569E92751124A0C812AED0BB398F5" originalValue="Schlüssel" pageId="null" pageNumber="405">Schluessel</normalizedToken>
, Diagnosen, Abbildungen, Verbreitungskarten)
</taxonomicName>
4 Arten; dabei wird 
<taxonomicName id="04FED74D2A1091BCF11BAB0D437FCF69" class="Insecta" family="Nymphalidae" genus="Dryas" kingdom="Animalia" order="Lepidoptera" pageId="null" pageNumber="405" phylum="Arthropoda" rank="species" species="octopetala">
<emphasis id="78139BF6AEEFE1CA3CFF69B3D427B9B9" italics="true" pageId="null" pageNumber="405">D. octopetala</emphasis>
</taxonomicName>
in 10 Unterarten und 
<normalizedToken id="83D2E3F9986586739B52472E50406A04" originalValue="Varietäten" pageId="null" pageNumber="405">Varietaeten</normalizedToken>
gegliedert. Die 
<normalizedToken id="5DC39CC9248F7ADAE7591196CC9B29FA" originalValue="Variabilität" pageId="null" pageNumber="405">Variabilitaet</normalizedToken>
der Gattung 
<taxonomicName id="9D89D3D7A4459BDF846CCBBC22475E32" class="Insecta" family="Nymphalidae" genus="Dryas" kingdom="Animalia" order="Lepidoptera" pageId="null" pageNumber="405" phylum="Arthropoda" rank="genus">
<emphasis id="929C0C6B86867A7797964100D3CE8D99" italics="true" pageId="null" pageNumber="405">Dryas</emphasis>
</taxonomicName>
in 
<normalizedToken id="702A4990306EE288B6B64F0117A5B2C7" originalValue="Grönland" pageId="null" pageNumber="405">Groenland</normalizedToken>
hat Elkington (1965) untersucht.
</paragraph>
</subSubSection>
