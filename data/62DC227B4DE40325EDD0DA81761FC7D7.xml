<subSubSection id="A6445FCED49A569DC737C92ACC152533" pageId="null" pageNumber="903" type="description">
<paragraph id="555105313F7D57D1D75D8E15B2486061" pageId="null" pageNumber="903">
Bis 1 m hoher Strauch, mit bogig aufsteigenden 
<normalizedToken id="D40F22D0F8A369936CE29D458139AA64" originalValue="Ästen" pageId="null" pageNumber="903">Aesten</normalizedToken>
, reich verzweigt. 
<normalizedToken id="7B95737F6B9CAF3E0C21674C315CB5AE" originalValue="Blätter" pageId="null" pageNumber="903">Blaetter</normalizedToken>
zu 3 oder 4 
<normalizedToken id="32E09A8618AE0D542DD1EFD040FC8580" originalValue="quirlständig" pageId="null" pageNumber="903">quirlstaendig</normalizedToken>
, dicht stehend und 
<normalizedToken id="1BD1519150F3AEDEF4A411FB2C041414" originalValue="±" pageId="null" pageNumber="903">+/-</normalizedToken>
senkrecht abstehend, 
<normalizedToken id="9BA420F778033774248CBE6493B6D743" originalValue="nadelförmig" pageId="null" pageNumber="903">nadelfoermig</normalizedToken>
, 6-10 mm lang, 0,6-1 mm breit, spitz, ohne hellen Rand, unterseits mit tiefer 
<normalizedToken id="A11BAA1D325FB186F6789661774D3C60" originalValue="Längsfurche" pageId="null" pageNumber="903">Laengsfurche</normalizedToken>
, kahl; Stiel ca. 0,5 mm lang. 
<normalizedToken id="65B4E636D525CCF4329A07265F8BBC6D" originalValue="Blütenstand" pageId="null" pageNumber="903">Bluetenstand</normalizedToken>
2-15 cm lang, traubig, 
<normalizedToken id="6AA41DB1C0B8CE1772664D0DC89E79F3" originalValue="vielblütig" pageId="null" pageNumber="903">vielbluetig</normalizedToken>
, allseitswendig. 
<emphasis id="1D71C6F50D5EA1A98AFC95E266E67211" italics="true" pageId="null" pageNumber="903">
<normalizedToken id="6368ED5D160DE64EE79DCF2F1C842A93" originalValue="Blütenstiele" pageId="null" pageNumber="903">Bluetenstiele</normalizedToken>
2-3mal so lang wie die Krone.
</emphasis>
<normalizedToken id="46453B82FADD60A40B588BC396C46F28" originalValue="Vorblätter" pageId="null" pageNumber="903">Vorblaetter</normalizedToken>
3 oder mehr, in der untern 
<normalizedToken id="1FCA464529E53B0C881ED20593C12002" originalValue="Hälfte" pageId="null" pageNumber="903">Haelfte</normalizedToken>
des 
<normalizedToken id="ED20402E5A6AA6A778DA92BCC1D64C70" originalValue="Blütenstiels" pageId="null" pageNumber="903">Bluetenstiels</normalizedToken>
. 
<normalizedToken id="E632CF102BA7EF2BF350FE7203BED458" originalValue="Blüten" pageId="null" pageNumber="903">Blueten</normalizedToken>
rosa. Krone kugelig, im Durchmesser 3-4 mm, etwa 3mal so lang wie die 
<normalizedToken id="106B580AC5ADD795F5C7ED8AA5769382" originalValue="Kelchblätter" pageId="null" pageNumber="903">Kelchblaetter</normalizedToken>
. 
<emphasis id="478BB843700321D20BD415B3B743AA25" italics="true" pageId="null" pageNumber="903">
<normalizedToken id="22660B160F0F77EA44C7D55D556DCE35" originalValue="Staubblätter" pageId="null" pageNumber="903">Staubblaetter</normalizedToken>
weit aus der 
<normalizedToken id="2CCCD079DE7D894D1D85F43F1C8FB14E" originalValue="Kronröhre" pageId="null" pageNumber="903">Kronroehre</normalizedToken>
hervortretend;
</emphasis>
Staubbeutel auf dem 
<normalizedToken id="2B0180CE8C221339AEE0D62C6B946F44" originalValue="Rücken" pageId="null" pageNumber="903">Ruecken</normalizedToken>
angewachsen, 
<emphasis id="7E605D830C06B770C8AD43C15DBDA9B7" italics="true" pageId="null" pageNumber="903">
die beiden Staubbeutel jedoch 
<normalizedToken id="4E2918161BAAF8A8A1281AA098436D33" originalValue="vollständig" pageId="null" pageNumber="903">vollstaendig</normalizedToken>
getrennt
</emphasis>
(im Gebiet nur bei dieser Art so!), 
<emphasis id="CA90BB6C6FA770716770ED44207E3CAF" italics="true" pageId="null" pageNumber="903">
keine 
<normalizedToken id="BB871D94F43456755726D8AE7094A881" originalValue="Anhängsel" pageId="null" pageNumber="903">Anhaengsel</normalizedToken>
vorhanden.
</emphasis>
- 
<normalizedToken id="8FDD025F5E46BD54E26D9C72EA28A61A" originalValue="Blüte" pageId="null" pageNumber="903">Bluete</normalizedToken>
: 
<normalizedToken id="4CB1016888417D8026EE4FD2977F7613" originalValue="Früher" pageId="null" pageNumber="903">Frueher</normalizedToken>
<normalizedToken id="104A3473BA7CA2D2298CE508E51A4667" originalValue="Frühling" pageId="null" pageNumber="903">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="56D4AD460D0755D143EC09E89EC2E6EA" pageId="null" pageNumber="903">
<emphasis id="D29EB459857CA5C6C607DB620472D646" italics="true" pageId="null" pageNumber="903">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="74CCDBFD70C34D2E0D634FB43CABA61F" italics="true" pageId="null" pageNumber="903">24:</emphasis>
Material aus England (Maude 1939Maude 1940).
</paragraph>
<paragraph id="369D05EEBE12861F3AA53131C3193522" pageId="null" pageNumber="903">
<emphasis id="4EB99356CDA048A93DA30204B3A0861B" italics="true" pageId="null" pageNumber="903">Standort.</emphasis>
Kollin. Kalkfreie 
<normalizedToken id="C12C19B73AB7D95627252750FB1F0B5F" originalValue="Böden" pageId="null" pageNumber="903">Boeden</normalizedToken>
in milden Lagen. Buschige 
<normalizedToken id="A3FB215FA639623D8EF1487E8894161C" originalValue="Hänge" pageId="null" pageNumber="903">Haenge</normalizedToken>
, 
<normalizedToken id="0574A4366BB46D6763E3E5C39270B960" originalValue="Waldränder" pageId="null" pageNumber="903">Waldraender</normalizedToken>
.
</paragraph>
<paragraph id="1CB03E1C78A07B64AB22C709E53BD8F3" pageId="null" pageNumber="903">
<emphasis id="4FED422D325C9D518AB00AD6F9DC4C47" italics="true" pageId="null" pageNumber="903">
Verbreitung. 
<normalizedToken id="A79B32927509EDBA7AEF4AE24321F615" originalValue="Westeuropäische" pageId="null" pageNumber="903">Westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Von Zentralspanien durch Frankreich 
<normalizedToken id="78676ABE3A5C0012A1D78262BB6D7186" originalValue="nordwärts" pageId="null" pageNumber="903">nordwaerts</normalizedToken>
bis 
<normalizedToken id="6985263F64FEE2A029F220533C8B7DE1" originalValue="Südwestengland" pageId="null" pageNumber="903">Suedwestengland</normalizedToken>
. Verbreitungskarte von Hansen (1950). - Im Gebiet: Savoyen (Les Voirons, Massif des Bauges), Genf (Bois de Jussy bei 
<normalizedToken id="80067077821A1B32DE5FF634951DA22B" originalValue="Présinge" pageId="null" pageNumber="903">Presinge</normalizedToken>
).
</paragraph>
</subSubSection>
