<subSubSection id="3E390A3F8E6675C6CD5072335F274974" pageId="null" pageNumber="197" type="description">
<paragraph id="51A568AF1975A40B1C0FAB3970A03682" pageId="null" pageNumber="197">
5-20 cm hoch. 
<emphasis id="106848391FC88EAF1A7A2CFA7EB65279" italics="true" pageId="null" pageNumber="197">
Alle 
<normalizedToken id="6CD1975271590F542C1FA8E7D5057B3C" originalValue="Blätter" pageId="null" pageNumber="197">Blaetter</normalizedToken>
ungeteilt, grob 
<normalizedToken id="08B7D1174021EAE9A5107F6D345E39C1" originalValue="gezähnt" pageId="null" pageNumber="197">gezaehnt</normalizedToken>
</emphasis>
, die untern 0,3-1,5 cm lang und 0,2-1 cm breit. 
<emphasis id="002A8D8AD6828FF55BE06AEA7A4181B4" italics="true" pageId="null" pageNumber="197">Kelchzipfel zur Fruchtzeit 3</emphasis>
- 
<emphasis id="E52B50F849CB5C8F563D88CD91440D80" italics="true" pageId="null" pageNumber="197">5 mm lang. Krone im Durchmesser 5</emphasis>
- 
<emphasis id="AB74202E9AC28F7113C2BEB301F6FF3D" italics="true" pageId="null" pageNumber="197">7 mm</emphasis>
, dunkelblau. 
<emphasis id="765BB1553B7B43DF21B5AF7215202F69" italics="true" pageId="null" pageNumber="197">
Frucht 
<normalizedToken id="96556BA8DEE75C4F71CA3266F97A1A68" originalValue="länger" pageId="null" pageNumber="197">laenger</normalizedToken>
als breit
</emphasis>
, 4-5 mm lang und etwa 4 mm breit. Griffel 1-1,5 mm lang. Samen 
<normalizedToken id="86AECA4CCBE60C0265348570C82EAE39" originalValue="schalenförmig" pageId="null" pageNumber="197">schalenfoermig</normalizedToken>
, 
<emphasis id="676B210DAAC6C4059C86407794C851D3" italics="true" pageId="null" pageNumber="197">glatt, 0,7</emphasis>
- 
<emphasis id="428433C4E976A44F64346766EE696011" italics="true" pageId="null" pageNumber="197">1 mm lang</emphasis>
, 12-20 Samen je Frucht. - 
<normalizedToken id="66CF8B995FDD35E004BDD5E75951F83E" originalValue="Blüte" pageId="null" pageNumber="197">Bluete</normalizedToken>
: 
<normalizedToken id="465CF782D3161F2254CBA669512A7685" originalValue="Frühling" pageId="null" pageNumber="197">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="91152F935386B7F7AACC2424559B1EE6" pageId="null" pageNumber="197">
<emphasis id="B7E4251B370BDF26B2CF4E205C0F857B" italics="true" pageId="null" pageNumber="197">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="9FB6238F9DBC371BBCBCEF92C2B7071E" italics="true" pageId="null" pageNumber="197">18:</emphasis>
Material aus botanischem Garten (Hofelich 1935), aus 
<normalizedToken id="0F0988C704ECFC2DCE1CD7F58A3935C7" originalValue="Niederösterreich" pageId="null" pageNumber="197">Niederoesterreich</normalizedToken>
(Fischer 1969).
</paragraph>
<paragraph id="4BF98516697BFAD4220CCBB62C887430" pageId="null" pageNumber="197">
<emphasis id="73EC0624DFA0C88CC91C5C72E0E11C90" italics="true" pageId="null" pageNumber="197">Standort.</emphasis>
Kollin und montan, seltener subalpin. Lockere, 
<normalizedToken id="5146A9B953AD4654CA29F5FF7DE37685" originalValue="nährstoffreiche" pageId="null" pageNumber="197">naehrstoffreiche</normalizedToken>
, meist kalkhaltige, sandige 
<normalizedToken id="D6DA57CB5C819FF47C7913C6743E7076" originalValue="Böden" pageId="null" pageNumber="197">Boeden</normalizedToken>
in warmen Lagen. Trockenwiesen, 
<normalizedToken id="F3F4ED7BA5AF6F82D2A3C03C8D7A8909" originalValue="Äcker" pageId="null" pageNumber="197">Aecker</normalizedToken>
.
</paragraph>
<paragraph id="273134DB7C8268D8F50D366333BF957A" pageId="null" pageNumber="197">
<emphasis id="11873FAB7868F4F1DA0EBBB208A919DC" italics="true" pageId="null" pageNumber="197">Verbreitung. Mediterrane Pflanze:</emphasis>
Europa (
<normalizedToken id="4E321D5E0C75714F80F98ECB7A9BB8B0" originalValue="nordwärts" pageId="null" pageNumber="197">nordwaerts</normalizedToken>
vereinzelt bis England, Schweden, 
<normalizedToken id="FF62CF1C0CF75BF1149C15D6D909D73F" originalValue="Mittelrußland" pageId="null" pageNumber="197">Mittelrussland</normalizedToken>
); Kleinasien, Kaukasus; Nordwestafrika. - Im Gebiet: Nordschweiz, Hegau, Oberrheinische Tiefebene, 
<normalizedToken id="D2D94E92D960907F80FD4D7821B3F4B0" originalValue="früher" pageId="null" pageNumber="197">frueher</normalizedToken>
bei Genf, 
<normalizedToken id="BCF176C0E7EFDF99F767D7A861DB59C9" originalValue="Dép" pageId="null" pageNumber="197">Dep</normalizedToken>
. Ain, Savoyen, Wallis, Aostatal; Veltlin (?); nicht 
<normalizedToken id="4B97A01AE5E6B58C72FEEFEE0FCAB7CC" originalValue="häufig" pageId="null" pageNumber="197">haeufig</normalizedToken>
, selten adventiv.
</paragraph>
</subSubSection>
