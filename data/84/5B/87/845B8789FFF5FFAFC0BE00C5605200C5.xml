CLÉ D’ IDENTIFICATION DES 
<taxonomicName authority="ADULTES DE" authorityName="ADULTES DE" box="[762,1025,1413,1439]" class="Insecta" family="Tetrigidae" kingdom="Animalia" order="Orthoptera" pageId="15" pageNumber="418" phylum="Arthropoda" rank="family">TETRIGIDAE ADULTES DE</taxonomicName>
<collectingCountry box="[1032,1123,1414,1440]" name="French Guiana" pageId="15" pageNumber="418">GUYANE</collectingCountry>
</heading>
</paragraph>
