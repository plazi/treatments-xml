(
<bibRefCitation author="Bruner" box="[1231,1370,910,934]" firstAuthor="Bruner" pageId="16" pageNumber="419" pagination="89 - 143" refId="ref10873" refString="BRUNER L. 1910. - South American Tetrigidae. Annals of the Carnegie Museum 7: 89 - 143." type="journal article" year="1910">Bruner, 1910</bibRefCitation>
)
</taxonomicName>
</keyLead>
</paragraph>
</keyStep>
<keyStep pageId="16" pageNumber="419">
