</paragraph>
</subSubSection>
<subSubSection pageId="13" pageNumber="470" type="biology_ecology">
<paragraph blockId="13.[173,1380,876,1850]" pageId="13" pageNumber="470">
<emphasis bold="true" box="[174,884,1584,1613]" pageId="13" pageNumber="470">Movements, Home range and Social organization.</emphasis>
