</paragraph>
<paragraph id="8BE936D1FFB253422D0EF908553CBDA1" blockId="3.[2096,2688,1558,1980]" box="[2096,2562,1711,1744]" pageId="3" pageNumber="434">Three subspecies are recognized.</paragraph>
</subSubSection>
<subSubSection id="C34C655AFFB253422D0FF9705695B32B" pageId="3" pageNumber="434" type="synonymic_list">
<caption id="DF296659FFB253422D0FF9705695B32B" ID-DOI="http://doi.org/10.5281/zenodo.6585532" ID-Zenodo-Dep="6585532" httpUri="https://zenodo.org/record/6585532/files/figure.png" inLine="true" pageId="3" pageNumber="434" targetBox="[1482,2072,1561,1975]" targetPageId="3">
<paragraph id="8BE936D1FFB253422D0FF97056FEBD89" blockId="3.[2096,2688,1558,1980]" box="[2097,2496,1751,1784]" pageId="3" pageNumber="434">
<emphasis id="B922EAC3FFB253422D0FF97056FEBD89" bold="true" box="[2097,2496,1751,1784]" pageId="3" pageNumber="434">Subspecies and Distribution.</emphasis>
</paragraph>
<paragraph id="8BE936D1FFB253422D0FF9595798BCCD" blockId="3.[2096,2688,1558,1980]" pageId="3" pageNumber="434">
<taxonomicName id="4C564D52FFB253422D0FF959562EBC37" authority="I.  Geoffroy Saint-Hilaire &amp; d’Orbigny, 1833" authorityName="I. Geoffroy Saint-Hilaire &amp; d’Orbigny" authorityYear="1833" class="Mammalia" family="Caviidae" genus="Microcavia" kingdom="Animalia" order="Rodentia" pageId="3" pageNumber="434" phylum="Chordata" rank="subSpecies" species="australis" subSpecies="australis">M.a.australis1.GeoffroySaint-Hilaire&amp;d’Orbigny,1833—W&amp;SArgentina,fromSanJuanSEtoSBuenosAiresandStoSantaCruzprovinces,andWChile(AysénRegion).</taxonomicName>
</paragraph>
<paragraph id="8BE936D1FFB2534220F3F8605997B378" blockId="3.[1480,2688,1991,3476]" pageId="3" pageNumber="434">
<taxonomicName id="4C564D52FFB2534220F3F860586ABC95" authority="Thomas, 1898" authorityName="Thomas" authorityYear="1898" baseAuthorityName="Thomas" baseAuthorityYear="1898" box="[1485,1876,1991,2020]" class="Mammalia" family="Caviidae" genus="Microcavia" kingdom="Animalia" order="Rodentia" pageId="3" pageNumber="434" phylum="Chordata" rank="subSpecies" species="australis" subSpecies="maenas">M.a.maenasThomas,1898—NWArgentina,MtsofJujuy,Salta,Catamarca,andLaRiojaprovinces.</taxonomicName>
</paragraph>
<paragraph id="8BE936D1FFB2534220F3F7B65695B32B" blockId="3.[1480,2688,1991,3476]" pageId="3" pageNumber="434">
<taxonomicName id="4C564D52FFB2534220F3F7B65801B343" authority="Thomas, 1921" authorityName="Thomas" authorityYear="1921" box="[1485,1855,2065,2098]" class="Mammalia" family="Caviidae" genus="Microcavia" kingdom="Animalia" order="Rodentia" pageId="3" pageNumber="434" phylum="Chordata" rank="subSpecies" species="australis" subSpecies="salinia">M. a. salinia Thomas, 1921</taxonomicName>
— NW Argentina,salt flat regions of E Catamarca and E La Rioja, SW Santiago del Estero, NW Cordoba S to N San Luis provinces.
</paragraph>
