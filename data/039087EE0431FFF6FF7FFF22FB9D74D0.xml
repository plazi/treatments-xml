<subSubSection id="C32365730431FFF6FF2FFAC6FA4C7447" box="[199,1415,1339,1366]" pageId="3" pageNumber="324" type="etymology">
<paragraph id="8B8636F80431FFF6FF2FFAC6FA4C7447" blockId="3.[151,1437,331,1474]" box="[199,1415,1339,1366]" pageId="3" pageNumber="324">
<emphasis id="B94DEAEA0431FFF6FF2FFAC6FE837447" bold="true" box="[199,328,1339,1365]" pageId="3" pageNumber="324">Etymology</emphasis>
. From the Latin 
<emphasis id="B94DEAEA0431FFF6FDEDFAC6FD897447" box="[517,578,1339,1365]" italics="true" pageId="3" pageNumber="324">albus</emphasis>
= white, and 
<emphasis id="B94DEAEA0431FFF6FD33FAC6FCD37447" box="[731,792,1339,1365]" italics="true" pageId="3" pageNumber="324">clava</emphasis>
= club, referring to the yellowish-white antennal clava.
</paragraph>
</subSubSection>
