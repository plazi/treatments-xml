<paragraph id="C42B36FEFF336A8CFCF5974E1D5FBA82" blockId="200.[772,1370,279,706]" pageId="200" pageNumber="962">
<emphasis id="F6E0EAECFF336A8CFCF5974E1DA4BA0A" bold="true" box="[777,932,279,312]" pageId="200" pageNumber="962">Taxonomy.</emphasis>
<taxonomicName id="03944D7DFF336A8CFC41974E1A01BA6D" authority="Maeda &amp; Matsumura, 1998" authorityName="Maeda &amp; Matsumura" authorityYear="1998" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="200" pageNumber="962" phylum="Chordata" rank="species" species="yanbarensis">Myotis yanbarensis Maeda &amp; Matsumura, 1998</taxonomicName>
, 
<materialsCitation id="74FC3CA3FF336A8CFBEE97671D5FBA82" ID-GBIF-Occurrence="3783319395" pageId="200" pageNumber="962">
upper stream of Funga River, Aha, Kunigami-mura, Okinawajima, 
<collectingCountry id="BC83766EFF336A8CFCF897CA1D5BBA82" box="[772,859,403,432]" name="Japan" pageId="200" pageNumber="962">Japan</collectingCountry>
