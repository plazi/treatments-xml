<subSubSection id="57A90C6BA386A011FE82D7383F3CFE7C" pageId="null" pageNumber="181" type="description">
<paragraph id="40CB306D0718147C836D3EA4E93F92F0" pageId="null" pageNumber="181">
Unterscheidet sich von 
<taxonomicName id="64DB77556A457C179A8BFA111ACFB949" class="Magnoliopsida" family="Brassicaceae" genus="Brassica" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="181" phylum="Tracheophyta" rank="genus">
<emphasis id="875F3D7A9920D4E1A1EFBDB53CEA3BF0" italics="true" pageId="null" pageNumber="181">Brassica</emphasis>
</taxonomicName>
(S. 184) durch folgende Merkmale: 
<emphasis id="AFE16D8E390F03949B5923691CE6AD00" italics="true" pageId="null" pageNumber="181">
<normalizedToken id="5BD19BCC2277B5CA2C455AA0A9D557FF" originalValue="Kelchblätter" pageId="null" pageNumber="181">Kelchblaetter</normalizedToken>
am Grunde nicht ausgebuchtet; jedes Fruchtblatt 3- oder 5 nervig; Fruchtschnabel wenig bis deutlich abgeflacht.
</emphasis>
</paragraph>
<paragraph id="60083D040116EB5955CEDD6D150416A9" pageId="null" pageNumber="181">
Die Gattung 
<taxonomicName id="C01E9582A646EA9F232862A9FA7A159F" class="Magnoliopsida" family="Brassicaceae" genus="Sinapis" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="181" phylum="Tracheophyta" rank="genus">
<emphasis id="9CE4D5DBE59667B5DCB08369378B9E06" italics="true" pageId="null" pageNumber="181">Sinapis</emphasis>
</taxonomicName>
<normalizedToken id="5ECABE12A98EF2B544F95052FED8C96D" originalValue="umfaßt" pageId="null" pageNumber="181">umfasst</normalizedToken>
<emphasis id="6C0609A92B7A557F043C61888A5A9D89" italics="true" pageId="null" pageNumber="181">10 mediterrane Arten.</emphasis>
</paragraph>
<paragraph id="0DAAD991DE8465C0AE12C24085536D99" pageId="null" pageNumber="181">
<table id="A2224B0DABA0F41CBC75772CE9368787" frame="void" pageId="null" pageNumber="181" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="DEA66CE890F1EDBA724D454F91ED2317" pageId="null" pageNumber="181">
<tr id="ACADCEB694AD7995D725CCF23F0C41B0" pageId="null" pageNumber="181">
<td id="236EF7E140B9D758E4BC02C310D0AD9E" align="left" pageId="null" pageNumber="181" valign="top">
1. 
<normalizedToken id="38E92EC4897309A58E8F8F5AD1068FCC" originalValue="Früchte" pageId="null" pageNumber="181">Fruechte</normalizedToken>
8-13samig, kahl oder mit 0,3-0,6 mm langen, steifen, 
<normalizedToken id="09231A211768E1FF8299A3A6812D2363" originalValue="rückwärts" pageId="null" pageNumber="181">rueckwaerts</normalizedToken>
gerichteten Haaren; 
<normalizedToken id="FD6BF19568EED8D461DB5F0FB874E6BC" originalValue="Blütenstiele" pageId="null" pageNumber="181">Bluetenstiele</normalizedToken>
<normalizedToken id="B0F6240225DA383EB66CFA3C556C499F" originalValue="½" pageId="null" pageNumber="181">1/2</normalizedToken>
-1mal so lang wie die 
<normalizedToken id="2B1094ED4CD284921C2D87D5E88740BE" originalValue="Kelchblätter" pageId="null" pageNumber="181">Kelchblaetter</normalizedToken>
</td>
<td id="EAB7D45596F1B9CAE85842AA05BA56D4" align="left" pageId="null" pageNumber="181" valign="bottom">
<taxonomicName id="4A69FE8C8BB3E9571B7C0F1C5CE6CBF4" class="Magnoliopsida" family="Brassicaceae" genus="Sinapis" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="181" phylum="Tracheophyta" rank="species" species="arvensis">
<italic id="F65E4401446A000090B10BB411DB13D6" pageId="null" pageNumber="181">S. arvensis</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="8A9C731ECBB7FFC42C0FCB364E0D8C36" pageId="null" pageNumber="181">
<td id="F180408C5AB6C5EC41AF18AC6F5F949C" align="left" pageId="null" pageNumber="181" valign="top">
1*. 
<normalizedToken id="C6B6749972E689CC8DBCF431888C491B" originalValue="Früchte" pageId="null" pageNumber="181">Fruechte</normalizedToken>
4-8samig, mit zahlreichen 0,6-1 mm langen, steifen, abstehenden Haaren und ca. 0,2 mm langen, 
<normalizedToken id="D5BD9687F8F89CD1DD6ACD78212201D2" originalValue="rückwärts" pageId="null" pageNumber="181">rueckwaerts</normalizedToken>
anliegenden Haaren; 
<normalizedToken id="C67028F9020A98E2F7D0DF54440E6153" originalValue="Blütenstiele" pageId="null" pageNumber="181">Bluetenstiele</normalizedToken>
1- 
<normalizedToken id="2D260CDAFA0816386CF8F5C4F5252C2E" originalValue="1½" pageId="null" pageNumber="181">11/2</normalizedToken>
mal so lang wie die 
<normalizedToken id="7F702A5C27203625B0AFD642173E5C3E" originalValue="Kelchblätter" pageId="null" pageNumber="181">Kelchblaetter</normalizedToken>
</td>
<td id="E18A11FA5396CC7F4DCFF858A5B6E28C" align="left" pageId="null" pageNumber="181" valign="bottom">
<taxonomicName id="5BF2E1919461B5950E2C3AC0E57A52C9" class="Magnoliopsida" family="Brassicaceae" genus="Sinapis" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="181" phylum="Tracheophyta" rank="species" species="alba">
<italic id="CBC95C01B858F2F2AA4CC78EDAF143CD" pageId="null" pageNumber="181">S. alba</italic>
</taxonomicName>
(Nr. 2)
</td>
</tr>
</tbody>
</table>
</paragraph>
