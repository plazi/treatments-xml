<subSubSection id="DAD8EDEE4989554E2189A0345597B80D" pageId="null" pageNumber="711" type="description">
<paragraph id="3847827C9EFF9A04B7C532CC17E04407" pageId="null" pageNumber="711">
Unterscheidet sich von 
<taxonomicName id="FE09861D43C7D898DCDF3FD21DFAC9BC" class="Insecta" family="Staphylinidae" genus="Thesium" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="711" phylum="Arthropoda" rank="species" species="linophyllon">
<emphasis id="7CB7288C640D3E8CC08D49186D8D5EB1" italics="true" pageId="null" pageNumber="711">T. Linophyllon</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="4444109A9D3E44BDE881B4F2FF79C0D3" italics="true" pageId="null" pageNumber="711">Stengel</emphasis>
<normalizedToken id="98049BF3F92E782452B069503D222B14" originalValue="±" pageId="null" pageNumber="711">+/-</normalizedToken>
<emphasis id="8CC8E2BE1E41A831048317ABE7FAD534" italics="true" pageId="null" pageNumber="711">
niederligend; 
<normalizedToken id="78AA9E901D3A2DF53F57AD3F65819303" originalValue="Blätter" pageId="null" pageNumber="711">Blaetter</normalizedToken>
meist nicht 
<normalizedToken id="E776DE47E2C3738791C789629B757FB9" originalValue="über" pageId="null" pageNumber="711">ueber</normalizedToken>
1 mm breit
</emphasis>
, stets 1nervig; 
<emphasis id="F9E642B257D19F5AA487D1E6A0F3E225" italics="true" pageId="null" pageNumber="711">
<normalizedToken id="F10A5A2CA9724B76F0E87BE08AB67EDB" originalValue="Äste" pageId="null" pageNumber="711">Aeste</normalizedToken>
im 
<normalizedToken id="AA8E938405A67CC2863F654281BB5DA0" originalValue="Blütenstand" pageId="null" pageNumber="711">Bluetenstand</normalizedToken>
rauh
</emphasis>
(30fache 
<normalizedToken id="FDD02ADB5863A2DCA2CA2A1124F99FA9" originalValue="Vergrößerung" pageId="null" pageNumber="711">Vergroesserung</normalizedToken>
!). - 
<normalizedToken id="3CDC655738CD451C2BCB363DEFF4648F" originalValue="Blüte" pageId="null" pageNumber="711">Bluete</normalizedToken>
: 
<normalizedToken id="97CD6ACF445025CEFFF0F35A0154E3F5" originalValue="Früher" pageId="null" pageNumber="711">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="C4310ECF9A2710C1B64CD7B825CCD23A" pageId="null" pageNumber="711">
<emphasis id="1559E496076F3EA69B728AA37CFADED3" italics="true" pageId="null" pageNumber="711">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="25CB0BF8B8E332EDA56F47C4670B9B0B" pageId="null" pageNumber="711">
<emphasis id="4D2E3F35F4D53E16A6BB29F7AB4D6051" italics="true" pageId="null" pageNumber="711">Standort.</emphasis>
Montan, seltener kollin. Kalkhaltige, trockene 
<normalizedToken id="616ECC3D75095AAA3F5F0BF8F0F6DD52" originalValue="Böden" pageId="null" pageNumber="711">Boeden</normalizedToken>
in sonniger Lage. Trockenwiesen.
</paragraph>
<paragraph id="ACED4DEF7577EF41EAE83BD1B4CCC97D" pageId="null" pageNumber="711">
<emphasis id="97002C4272291C5510E253EADF7DDEC4" italics="true" pageId="null" pageNumber="711">
Verbreitung. 
<normalizedToken id="37122475DBB6A0D32CED2B0B01C8A1A2" originalValue="Westeuropäische" pageId="null" pageNumber="711">Westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="EE1D5CA5BF0B0C92FAB7F2D504C7AFC3" originalValue="Nordwärts" pageId="null" pageNumber="711">Nordwaerts</normalizedToken>
bis England, 
<normalizedToken id="2D63D0767A84EC2711604A6DCDFE45D7" originalValue="ostwärts" pageId="null" pageNumber="711">ostwaerts</normalizedToken>
bis Ardennen, Metz, 
<normalizedToken id="C497369F1F86D5D28119415AF0086D69" originalValue="Französischer" pageId="null" pageNumber="711">Franzoesischer</normalizedToken>
Jura, 
<normalizedToken id="6CCED9920D1EC364D4FE04E501F3CBC9" originalValue="südwärts" pageId="null" pageNumber="711">suedwaerts</normalizedToken>
bis 
<normalizedToken id="C8F73F8BA55BF15A52813868A0B35B57" originalValue="Pyrenäen" pageId="null" pageNumber="711">Pyrenaeen</normalizedToken>
. - Im Gebiet: 
<normalizedToken id="BFB9E8B8BC548FA76EE5C7626F3470CC" originalValue="Dép" pageId="null" pageNumber="711">Dep</normalizedToken>
. Doubs, 
<normalizedToken id="E5E3DC54852CECC93A985648A2FC4E45" originalValue="Dép" pageId="null" pageNumber="711">Dep</normalizedToken>
. Jura, 
<normalizedToken id="ABD137DC4E6B6831F17E5550CC5F2E2E" originalValue="Dép" pageId="null" pageNumber="711">Dep</normalizedToken>
. Ain.
</paragraph>
</subSubSection>
