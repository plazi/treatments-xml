(
<figureCitation id="889F6FFCE331FFDFFD8DFCD390E4FC91" box="[544,648,802,826]" captionStart="Figures 101–106" captionStartId="73.[192,288,1875,1897]" captionTargetBox="[192,1440,192,1857]" captionTargetId="figure-47@73.[192,1440,192,1857]" captionTargetPageId="73" captionText="Figures 101–106. Species distribution maps. 101) Bembidion tillyardi. 102) B. townsendi. 103) B. urewerense. 104) B. waiho new species. 105) B. waimarama new species. 106) B. wanakense." figureDoi="http://doi.org/10.5281/zenodo.5181796" httpUri="https://zenodo.org/record/5181796/files/figure.png" pageId="26" pageNumber="25">Fig. 102</figureCitation>
