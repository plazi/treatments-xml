. Similar to 
<taxonomicName id="4C78A989FFC20A2277823A9FAE4FFF05" authority="Ermilov &amp; Starý, 2022" authorityName="Ermilov &amp; Starý" authorityYear="2022" box="[386,536,151,177]" class="Arachnida" family="Galumnidae" genus="Pergalumna" kingdom="Animalia" order="Sarcoptiformes" pageId="10" pageNumber="236" phylum="Arthropoda" rank="species" species="dedzaensis" status="sp. nov.">
