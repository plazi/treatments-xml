<date id="FFBD1006FFF9FF90FC9BFB88FC3D535E" box="[810,1008,1057,1083]" pageId="12" pageNumber="11" value="2021-02-11">11 February 2021</date>
; J. Campos. Host: Unidentified species (
<taxonomicName id="4C034D45FFF9FF90FF79FBEDFEF7533A" authorityName="Blackwall" authorityYear="1841" box="[200,314,1092,1119]" class="Arachnida" family="Salticidae" kingdom="Animalia" order="Araneae" pageId="12" pageNumber="11" phylum="Arthropoda" rank="family">Salticidae</taxonomicName>
