in Himachal Pradesh, ¢. 
<quantity id="036C9B1BFF606ADFF62E9AF0143EB7F8" box="[2514,2622,3241,3274]" metricMagnitude="3" metricUnit="m" metricValue="2.6149999999999998" pageId="155" pageNumber="916" unit="m" value="2615.0">2615 m</quantity>
in 
<collectingCountry id="BC83766EFF606ADFFA4C9A8A1827B7C6" box="[1456,1575,3283,3316]" name="Pakistan" pageId="155" pageNumber="916">Pakistan</collectingCountry>
, and ¢. 
<quantity id="036C9B1BFF606ADFF97B9A8A18F3B7C6" box="[1671,1779,3283,3316]" metricMagnitude="3" metricUnit="m" metricValue="2.154" pageId="155" pageNumber="916" unit="m" value="2154.0">2154 m</quantity>
