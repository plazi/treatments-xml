<bibRefCitation id="08403EFAFF92FFCCFAE2AEB581EDFE11" author="Rodrigues, S. A." box="[151,392,474,501]" pageId="38" pageNumber="39" pagination="195 - 211" refId="ref76135" refString="Rodrigues, S. A. (1985) Sobre o crescimento relativo de Callichirus major (Say, 1818) (Crustacea, Decapoda, Thalassinidea). Boletim de Zoologia da Universidade de Sao Paulo, 9, 195 - 211. https: // doi. org / 10.11606 / issn. 2526 - 3358. bolzoo. 1985.122297" type="journal article" year="1985">
