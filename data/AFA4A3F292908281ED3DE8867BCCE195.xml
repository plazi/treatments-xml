<subSubSection id="43469E10AEE436BD8525404388B77D11" pageId="null" pageNumber="358" type="vernacular_names">
<paragraph id="491CE74402595C07A88BE2E673DC7563" pageId="null" pageNumber="358">Alpen-Schwingel</paragraph>
</subSubSection>
</title>
<subSubSection id="0230E0FAF65B7B3B659142E153D9DF8D" pageId="null" pageNumber="358" type="description">
<paragraph id="7C75CC4B82E845ABEAB91D69F7768FBA" pageId="null" pageNumber="358">
6-20 cm hoch. 
<emphasis id="918B8D9C96E5ED6758DB7E144E1A189F" italics="true" pageId="null" pageNumber="358">
<normalizedToken id="B3AAB896523BB5651148E398B9725B32" originalValue="Blätter" pageId="null" pageNumber="358">Blaetter</normalizedToken>
auffallend 
<normalizedToken id="99AD24A7ED4834F6A5113A9925D4F0DF" originalValue="dünn" pageId="null" pageNumber="358">duenn</normalizedToken>
, 0,3-0,4 mm dick
</emphasis>
(bei den andern Arten der Gruppe 0,5-0,7 mm dick), 
<emphasis id="422554BBA0AA3F023210C16531DCB5D8" italics="true" pageId="null" pageNumber="358">mit 3, selten 5 Nerven</emphasis>
und 3 
<normalizedToken id="189BEF08859939BD4164BD7B673D1948" originalValue="Strängen" pageId="null" pageNumber="358">Straengen</normalizedToken>
von Festigungsgewebe. 
<normalizedToken id="83717C147443D7C32A7C4A4427BE018B" originalValue="Blütenstand" pageId="null" pageNumber="358">Bluetenstand</normalizedToken>
(Traube oder Rispe) 1,5-3 cm lang. Obere 
<normalizedToken id="C409A6535AF18FD794F46E647ADD02AA" originalValue="Hüllspelze" pageId="null" pageNumber="358">Huellspelze</normalizedToken>
3-3,5 mm lang. Deckspelzen begrannt; Granne wenigstens 
<normalizedToken id="DE163E0165E1E4A9F2CB136F599C5DB9" originalValue="½" pageId="null" pageNumber="358">1/2</normalizedToken>
so lang wie die 
<normalizedToken id="2E51571A95218A5EB3C772106F5ABFE9" originalValue="zugehörige" pageId="null" pageNumber="358">zugehoerige</normalizedToken>
Spelze. 
<emphasis id="73E7F18F0AD0BBCD820302C987D00057" italics="true" pageId="null" pageNumber="358">Staubbeutel 0,8-1,5 mm lang</emphasis>
(selten bis 2 mm). - 
<normalizedToken id="535CBE23718C9D9B0EF909E90B932BF8" originalValue="Blüte" pageId="null" pageNumber="358">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="C4C4BC81580A61B2D797636AFDAA0725" pageId="null" pageNumber="358">
<emphasis id="727EA1824406F9BFCD1B49BEE619CCA1" italics="true" pageId="null" pageNumber="358">Zytologische Angaben. 2n = 14:</emphasis>
Material aus botanischen 
<normalizedToken id="C8D62EB78C0A8BA5FFCA70CCF6765A30" originalValue="Gärten" pageId="null" pageNumber="358">Gaerten</normalizedToken>
(
<normalizedToken id="5A48E699BCD287263FCEF4A37EEF2B03" originalValue="Stählin" pageId="null" pageNumber="358">Staehlin</normalizedToken>
1929).
</paragraph>
<paragraph id="4736D3096C2C301D27B9499E7B44789B" pageId="null" pageNumber="358">
<emphasis id="8B5065FBE0AEAD152B8991FC98AA9AE6" italics="true" pageId="null" pageNumber="358">Standort.</emphasis>
Alpin, seltener subalpin. Windexponierte Kalkfelsspalten. 
<emphasis id="6E0ED673E2A42E1A16237B3A969548B0" italics="true" pageId="null" pageNumber="358">Androsacetum helveticae</emphasis>
Br.-Bl. 1918.
</paragraph>
<paragraph id="D6E5BE325FF88C00D69C0B9D4DDFA9C1" pageId="null" pageNumber="358">
<emphasis id="F12A26B44A10D4909DDE96BFFACE4428" italics="true" pageId="null" pageNumber="358">
Verbreitung. Mittel- und 
<normalizedToken id="5EC0A66B39DD9451145E66199FE3AE94" originalValue="südeuropäische" pageId="null" pageNumber="358">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
<normalizedToken id="3405A948F38F52D3DF0780CE788699C8" originalValue="Pyrenäen" pageId="null" pageNumber="358">Pyrenaeen</normalizedToken>
, Alpen (
<normalizedToken id="1AA58206D8AAA2BCC19464357BE4337A" originalValue="ostwärts" pageId="null" pageNumber="358">ostwaerts</normalizedToken>
bis zum Dachstein und zu den Julischen Alpen), Apennin, Gebirge der Balkanhalbinsel. - Im Gebiet: In den Alpen verbreitet.
</paragraph>
</subSubSection>
