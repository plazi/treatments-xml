and 
<tableCitation id="C6B5D9C4D907FFF8FE7155016714116B" box="[508,591,331,357]" captionStart="TABLE 1" captionStartId="5.[151,239,151,175]" captionTargetPageId="5" captionText="TABLE 1. Measurements (mm) of Amitermes soldiers." httpUri="http://table.plazi.org/id/DF48BCF7D900FFFFFF1A54DD67BE10A1" pageId="2" pageNumber="583" tableUuid="DF48BCF7D900FFFFFF1A54DD67BE10A1">Table 1</tableCitation>
.
</paragraph>
