<subSubSection id="2EFC65048936EF2FFF41D7BCAC69FD87" pageId="10" pageNumber="9" type="discussion">
<paragraph id="6659368F8936EF2FFF41D7BCAC69FD87" blockId="10.[192,1440,418,602]" pageId="10" pageNumber="9">
<emphasis id="5492EA9D8936EF2FFF41D7BCAE53FE67" bold="true" box="[192,324,418,442]" pageId="10" pageNumber="9">Remarks:</emphasis>
There are multiple records for 
<taxonomicName id="A1E64D0C8936EF2FFD41D7BCAC2BFE64" baseAuthorityName="Ewing" baseAuthorityYear="1933" box="[704,828,418,441]" class="Arachnida" family="Laelapidae" genus="Hyperlaelaps" higherTaxonomySource="GBIF" kingdom="Animalia" order="Mesostigmata" pageId="10" pageNumber="9" phylum="Arthropoda" rank="species" species="microti">
<emphasis id="5492EA9D8936EF2FFD41D7BCAC2BFE64" box="[704,828,418,441]" italics="true" pageId="10" pageNumber="9">H. microti</emphasis>
</taxonomicName>
in 
<collectingRegion id="A422F86D8936EF2FFCE3D7BCACCAFE67" box="[866,989,418,442]" country="United States of America" name="Nebraska" pageId="10" pageNumber="9">Nebraska</collectingRegion>
. 
<bibRefCitation id="02774B7E8936EF2FFC66D7BCAB6BFE67" author="Rapp, W. F., Jr." box="[999,1148,418,442]" pageId="10" pageNumber="9" pagination="31 - 33" refId="ref10782" refString="Rapp, W. F., Jr. 1962. Distributional notes on parasitic mites. Acarologia 4: 31 - 33." type="journal article" year="1962">Rapp (1962)</bibRefCitation>
reported this mite from 
<taxonomicName id="A1E64D0C8936EF2FFF41D7DCAE63FE07" baseAuthorityName="Wagner" baseAuthorityYear="1842" box="[192,372,450,474]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="10" pageNumber="9" phylum="Chordata" rank="species" species="ochrogaster">
<emphasis id="5492EA9D8936EF2FFF41D7DCAE63FE07" box="[192,372,450,474]" italics="true" pageId="10" pageNumber="9">M. ochrogaster</emphasis>
</taxonomicName>
near Chadron, in Dawes County. Later, 
<bibRefCitation id="02774B7E8936EF2FFCE1D7DCACEAFE07" author="Timm, R. M." box="[864,1021,450,474]" pageId="10" pageNumber="9" pagination="41 - 46" refId="ref11140" refString="Timm, R. M. 1973. Comments on ectoparasites of two species of Microtus in Nebraska. Transactions of the Kansas Academy of Sciences 75: 41 - 46." type="journal article" year="1973">Timm (1973)</bibRefCitation>
collected 
<taxonomicName id="A1E64D0C8936EF2FFBF2D7DCABF8FE04" baseAuthorityName="Ewing" baseAuthorityYear="1933" box="[1139,1263,450,473]" class="Arachnida" family="Laelapidae" genus="Hyperlaelaps" higherTaxonomySource="GBIF" kingdom="Animalia" order="Mesostigmata" pageId="10" pageNumber="9" phylum="Arthropoda" rank="species" species="microti">
<emphasis id="5492EA9D8936EF2FFBF2D7DCABF8FE04" box="[1139,1263,450,473]" italics="true" pageId="10" pageNumber="9">H. microti</emphasis>
</taxonomicName>
from 
<taxonomicName id="A1E64D0C8936EF2FFAB4D7DCAE57FE27" baseAuthorityName="Ord" baseAuthorityYear="1815" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="10" pageNumber="9" phylum="Chordata" rank="species" species="pennsylvanicus">
<emphasis id="5492EA9D8936EF2FFAB4D7DCAE57FE27" italics="true" pageId="10" pageNumber="9">M. pennsylvanicus</emphasis>
</taxonomicName>
in Kearney County, and from 
<taxonomicName id="A1E64D0C8936EF2FFD34D7FCAC7EFE27" baseAuthorityName="Wagner" baseAuthorityYear="1842" box="[693,873,482,506]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="10" pageNumber="9" phylum="Chordata" rank="species" species="ochrogaster">
<emphasis id="5492EA9D8936EF2FFD34D7FCAC7EFE27" box="[693,873,482,506]" italics="true" pageId="10" pageNumber="9">M. ochrogaster</emphasis>
</taxonomicName>
in Saline County. 
<bibRefCitation id="02774B7E8936EF2FFBCCD7FCAA0BFE27" author="Jameson, E. W., Jr." box="[1101,1308,482,506]" pageId="10" pageNumber="9" pagination="127 - 151" refId="ref10078" refString="Jameson, E. W., Jr. 1947 b. Natural History of the Prairie Vole. University of Kansas Publications of the Museum of National History 1: 127 - 151." type="journal article" year="1947">Jameson (1947b)</bibRefCitation>
reports 
<taxonomicName id="A1E64D0C8936EF2FFA03D7FCAE0FFDC4" baseAuthorityName="Ewing" baseAuthorityYear="1933" class="Arachnida" family="Laelapidae" genus="Hyperlaelaps" higherTaxonomySource="GBIF" kingdom="Animalia" order="Mesostigmata" pageId="10" pageNumber="9" phylum="Arthropoda" rank="species" species="microti">
<emphasis id="5492EA9D8936EF2FFA03D7FCAE0FFDC4" italics="true" pageId="10" pageNumber="9">H. microti</emphasis>
</taxonomicName>
as common on 
<taxonomicName id="A1E64D0C8936EF2FFE54D41CAD9DFDC7" baseAuthorityName="Wagner" baseAuthorityYear="1842" box="[469,650,514,538]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="10" pageNumber="9" phylum="Chordata" rank="species" species="ochrogaster">
<emphasis id="5492EA9D8936EF2FFE54D41CAEF9FDC4" box="[469,494,514,537]" italics="true" pageId="10" pageNumber="9">M</emphasis>
. 
<emphasis id="5492EA9D8936EF2FFE7CD41CAD9DFDC7" box="[509,650,514,538]" italics="true" pageId="10" pageNumber="9">ochrogaster</emphasis>
</taxonomicName>
in 
<collectingRegion id="A422F86D8936EF2FFD33D41CAC07FDC4" box="[690,784,514,537]" country="United States of America" name="Kansas" pageId="10" pageNumber="9">Kansas</collectingRegion>
, on 
<taxonomicName id="A1E64D0C8936EF2FFCC3D41CAB31FDC7" baseAuthorityName="Ord" baseAuthorityYear="1815" box="[834,1062,514,538]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="10" pageNumber="9" phylum="Chordata" rank="species" species="pennsylvanicus">
<emphasis id="5492EA9D8936EF2FFCC3D41CAB31FDC7" box="[834,1062,514,538]" italics="true" pageId="10" pageNumber="9">M. pennsylvanicus</emphasis>
</taxonomicName>
in 
<collectingRegion id="A422F86D8936EF2FFBCFD41CABDBFDC7" box="[1102,1228,514,538]" country="United States of America" name="New York" pageId="10" pageNumber="9">New York</collectingRegion>
, and on 
<taxonomicName id="A1E64D0C8936EF2FFAB2D41CAEE2FDE7" authority="(Peale, 1848)" baseAuthorityName="Peale" baseAuthorityYear="1848" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="10" pageNumber="9" phylum="Chordata" rank="species" species="californicus">
<emphasis id="5492EA9D8936EF2FFAB2D41CAE47FDE7" italics="true" pageId="10" pageNumber="9">Microtus californicus</emphasis>
(Peale, 1848)
</taxonomicName>
in Alameda County, 
<collectingRegion id="A422F86D8936EF2FFD77D43CAC61FDE7" box="[758,886,546,570]" country="United States of America" name="California" pageId="10" pageNumber="9">California</collectingRegion>
. This species is collected primarily from voles of the genus 
<taxonomicName id="A1E64D0C8936EF2FFEDCD45CAEDDFD84" authorityName="Schrank" authorityYear="1798" box="[349,458,578,601]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="10" pageNumber="9" phylum="Chordata" rank="genus">
<emphasis id="5492EA9D8936EF2FFEDCD45CAEDDFD84" box="[349,458,578,601]" italics="true" pageId="10" pageNumber="9">Microtus</emphasis>
</taxonomicName>
(
<bibRefCitation id="02774B7E8936EF2FFE5BD45CADC2FD87" author="Evans, G. O. &amp; W. M. Till" box="[474,725,578,602]" pageId="10" pageNumber="9" pagination="107 - 370" refId="ref9440" refString="Evans, G. O., and W. M. Till. 1966. Studies on the British Dermanyssidae (Acari: Mesostigmata). Part II. Classification. Bulletin of the British Museum (Natural History) 14: 107 - 370." type="journal article" year="1966">Evans and Till 1966</bibRefCitation>
; 
<bibRefCitation id="02774B7E8936EF2FFD60D45CAC66FD87" author="Timm, R. M." box="[737,881,578,602]" pageId="10" pageNumber="9" pagination="18 - 20" refId="ref11110" refString="Timm, R. M. 1972. Mites (Acari: Laelapidae) parasitic on the meadow vole, Microtus pennsylvanicus. Acarologia 14: 18 - 20." type="journal article" year="1972">Timm 1972</bibRefCitation>
).
</paragraph>
