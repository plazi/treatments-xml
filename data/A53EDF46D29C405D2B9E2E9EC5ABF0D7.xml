<subSubSection id="1DC955E54CDA5C518DCE955F59442A91" pageId="null" pageNumber="79" type="description">
<paragraph id="943DEAE6CC968CEDDA2AFF7355563576" pageId="null" pageNumber="79">
Ausdauernd (
<taxonomicName id="F31F8C101466E737B78BA299BC602369" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="79" phylum="Tracheophyta" rank="species" species="ophioglossifolius">
<emphasis id="9F1DB49BF32BD271255E684B428E65CA" italics="true" pageId="null" pageNumber="79">R. ophioglossifolius</emphasis>
</taxonomicName>
auch 1 
<normalizedToken id="992B3E2B9375C4DA6E484642F5E02DA0" originalValue="jährig" pageId="null" pageNumber="79">jaehrig</normalizedToken>
); 
<emphasis id="52BD5B60BABDA751EEFF24A51E33D8A5" italics="true" pageId="null" pageNumber="79">
ohne unterirdische 
<normalizedToken id="935F3356BD6EEA22D669131434547E01" originalValue="Ausläufer" pageId="null" pageNumber="79">Auslaeufer</normalizedToken>
</emphasis>
, kahl. 
<normalizedToken id="B14CCF85BA6AE031514FF21DB45C111C" originalValue="Blätter" pageId="null" pageNumber="79">Blaetter</normalizedToken>
lanzettlich, 
<emphasis id="29FE17928E0EA9EBD32B24D101074904" italics="true" pageId="null" pageNumber="79">
meist nicht 
<normalizedToken id="9AD0A90E31F3F5C314DDD483E6D6FB53" originalValue="über" pageId="null" pageNumber="79">ueber</normalizedToken>
10 cm lang
</emphasis>
, an der Basis oft abgerundet. 
<emphasis id="35287321EBCF2014F154CEED8F0FE188" italics="true" pageId="null" pageNumber="79">
<normalizedToken id="0CD020A9C355C8B67F6D0D3EDC06D041" originalValue="Blüten" pageId="null" pageNumber="79">Blueten</normalizedToken>
klein
</emphasis>
(
<emphasis id="0A61855033E5C899A79D80D939373FD5" italics="true" pageId="null" pageNumber="79">Durchmesser 0,5-1,5 cm</emphasis>
), gelb. 
<normalizedToken id="DEF4748BF46C8E34FB20D8C0E31AA62C" originalValue="Früchtchen" pageId="null" pageNumber="79">Fruechtchen</normalizedToken>
kahl. 
<normalizedToken id="1183A3A5FCCE4BABC1CD90EE8BBE89E0" originalValue="Blütenboden" pageId="null" pageNumber="79">Bluetenboden</normalizedToken>
kahl.
</paragraph>
<paragraph id="21937A2DA5AC0DDE0AC5C3290A9266F6" pageId="null" pageNumber="79">
Die Artengruppe 
<normalizedToken id="C62EFE72DC73C7D70B8DDF0276E675D3" originalValue="umfaßt" pageId="null" pageNumber="79">umfasst</normalizedToken>
etwa 
<emphasis id="83395DEFEAF09A4C4068A50EA6162523" italics="true" pageId="null" pageNumber="79">10 Arten;</emphasis>
sie hat eine 
<emphasis id="2AA6EBC43EE523208FE77F9C87599FDD" italics="true" pageId="null" pageNumber="79">eurasiatisch-nordamerikanische Verbreitung.</emphasis>
Polyploide Reihe: 
<emphasis id="6222D1A0F35B6D152B0D995C40AB08A9" italics="true" pageId="null" pageNumber="79">2n</emphasis>
= 
<emphasis id="F12619C29AA42C2D0281E0CE41602C3C" italics="true" pageId="null" pageNumber="79">16, 32, 48</emphasis>
(Neves 1945).
</paragraph>
<paragraph id="6EA52AEAED4F4F5870A57D66B8324C81" pageId="null" pageNumber="79">
<table id="E0A749698F819475278C19B5FBF54E98" frame="void" pageId="null" pageNumber="79" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="039832A01375B7C88931CC167F3E0603" pageId="null" pageNumber="79">
<tr id="3A1B72AABD110C684F5E559AD89E8F98" pageId="null" pageNumber="79">
<td id="99A2A5F04FDCC740D021E5414243AEFA" align="left" pageId="null" pageNumber="79" valign="top">
1. 
<normalizedToken id="231E72F25DB70AAB3ACD8BB7B526E9BF" originalValue="Oberfläche" pageId="null" pageNumber="79">Oberflaeche</normalizedToken>
der 
<normalizedToken id="FA88AA7C222CCCD6E0DD121E6D11AB85" originalValue="Früchtchen" pageId="null" pageNumber="79">Fruechtchen</normalizedToken>
glatt.
</td>
</tr>
<tr id="5B18A711F33C074BFD33F4A33424168F" pageId="null" pageNumber="79">
<td id="1967B652B5E93A76738BD7E34DA844BB" align="left" pageId="null" pageNumber="79" valign="top">
2. Pflanze 20-70 cm hoch, aufrecht oder bogig aufsteigend; Schnabel bis 
<sup id="BFD4118B920133F6B12AEE5F3955A4E9" pageId="null" pageNumber="79">1</sup>
/ 
<sub id="B4E7ACD155D033002F056984D15ED111" pageId="null" pageNumber="79">10</sub>
so lang wie das 
<normalizedToken id="668CEE4497C5FA401500400776D5B1BA" originalValue="Früchtchen" pageId="null" pageNumber="79">Fruechtchen</normalizedToken>
, gerade
</td>
<td id="28603165A9401AE925004997195C0382" align="left" pageId="null" pageNumber="79" valign="bottom">
<taxonomicName id="4E69D497DAF9C8E663D9EE29E81B5BE5" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="79" phylum="Tracheophyta" rank="species" species="flammula">
<italic id="10F4713368C3D461ED6F6D5E636C9A81" pageId="null" pageNumber="79">R. Flammula</italic>
</taxonomicName>
(Nr. 13a)
</td>
</tr>
<tr id="F176C8D09FACF910008610C357D54C76" pageId="null" pageNumber="79">
<td id="AB9CE4A2769D8FFA961271F2041AE7AA" align="left" pageId="null" pageNumber="79" valign="top">
2*. Pflanze 5-50 cm lang, in der ganzen 
<normalizedToken id="3904DE0ADF0ED4A3C7145BD84D98EC11" originalValue="Länge" pageId="null" pageNumber="79">Laenge</normalizedToken>
niederliegend; die Stengelglieder 
<normalizedToken id="1127C9CA88785ADADB3FB4926F2DE938" originalValue="fadenförmig" pageId="null" pageNumber="79">fadenfoermig</normalizedToken>
und bogig 
<normalizedToken id="9A8A496CAE82068D1A0A4BBB005B1EB3" originalValue="gekrümmt" pageId="null" pageNumber="79">gekruemmt</normalizedToken>
; Schnabel etwa ⅓ so lang wie das 
<normalizedToken id="B53458C9CF25D3685ED95F188B6FEE40" originalValue="Früchtchen" pageId="null" pageNumber="79">Fruechtchen</normalizedToken>
, hakig gebogen
</td>
<td id="61F407D2D345FE1A006125F12AD19EA7" align="left" pageId="null" pageNumber="79" valign="bottom">
<taxonomicName id="CD15F2F7496AAD86D281B992CED1FEB2" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="79" phylum="Tracheophyta" rank="species" species="reptans">
<italic id="6E6276D4CFAA0E49E9263FBADE904FCB" pageId="null" pageNumber="79">R. reptans</italic>
</taxonomicName>
(Nr. 13b)
</td>
</tr>
<tr id="83B4CE03AEE7EF4749F751FBDFD98016" pageId="null" pageNumber="79">
<td id="E6648234F6EC522EE9DD3B43B30B2411" align="left" pageId="null" pageNumber="79" valign="top">
1*. 
<normalizedToken id="1F5DDBF220160F2E2AB1CB1FB969D018" originalValue="Oberfläche" pageId="null" pageNumber="79">Oberflaeche</normalizedToken>
der 
<normalizedToken id="A8A246AF548F9F488C8D2C72ED686A4D" originalValue="Früchtchen" pageId="null" pageNumber="79">Fruechtchen</normalizedToken>
mit hyalinen Warzen 
<normalizedToken id="7E89F10208505CEF6DA3639D8DDDCDD0" originalValue="±" pageId="null" pageNumber="79">+/-</normalizedToken>
dicht besetzt
</td>
<td id="7DFE4B32745A0EED8286D6647E20A03C" align="left" pageId="null" pageNumber="79" valign="bottom">
<taxonomicName id="90926872DEF65DB72844860EE6788AD2" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="79" phylum="Tracheophyta" rank="species" species="ophioglossifolius">
<italic id="5225B17257E0E7AED0D87280F17A20D7" pageId="null" pageNumber="79">R. ophioglossifolius</italic>
</taxonomicName>
(Nr. 13c)
</td>
</tr>
</tbody>
</table>
</paragraph>
