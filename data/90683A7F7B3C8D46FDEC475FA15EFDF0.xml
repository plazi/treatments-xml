<figureCitation id="80FA97EC7B3C8D48FD6D47A6A11FFA59" box="[726,801,1442,1468]" captionStart="Fig" captionStartId="24.[189,232,1928,1954]" captionTargetBox="[189,1398,680,1872]" captionTargetId="figure-147@24.[189,1398,680,1872]" captionTargetPageId="24" captionText="Fig. 7. Austrosphecodes lucifersp. nov. A–C. Holotype, ♀ (DZUP 568517). D–F. Paratype, ♂. A. Female head. B. Female mesosoma. C. Female propodeum and metasoma. D. Male head. E. Male mesosoma. F. Male metasoma. Scale bar =1 mm." figureDoi="http://doi.org/10.5281/zenodo.6544425" httpUri="https://zenodo.org/record/6544425/files/figure.png" pageId="22" pageNumber="77">Figs 7</figureCitation>
