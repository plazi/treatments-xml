<subSubSection id="801C1638047E39EBFE50B8145DFA01C5" pageId="null" pageNumber="393" type="description">
<paragraph id="40B8682A0A699E507B7F57578EC2F718" pageId="null" pageNumber="393">
<emphasis id="42ECBD0C884482503522A71944BDB849" italics="true" pageId="null" pageNumber="393">
<normalizedToken id="BC7B26D103B0B77397ADAA81A732E1B9" originalValue="Grundständige" pageId="null" pageNumber="393">Grundstaendige</normalizedToken>
<normalizedToken id="A1D8EEFD78AF778B17D48292EC572616" originalValue="Blätter" pageId="null" pageNumber="393">Blaetter</normalizedToken>
zur 
<normalizedToken id="3C20FB6BFAB779111F9BD58E4C567D66" originalValue="Blütezeit" pageId="null" pageNumber="393">Bluetezeit</normalizedToken>
noch nicht abgestorben
</emphasis>
, unterseits grau, filzig (Behaarung weniger dicht als bei 
<taxonomicName id="8D981A6674863D30AD2813684FB53735" authority="Nr." authorityName="Nr." class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="393" phylum="Tracheophyta" rank="species" species="argentea">
<emphasis id="12FD15311449707D6E6206A724402607" italics="true" pageId="null" pageNumber="393">P. argentea</emphasis>
Nr.
</taxonomicName>
13a); 
<emphasis id="13576A7966BBA38FBB9B071F2CCB0A4C" italics="true" pageId="null" pageNumber="393">
Rand aller 
<normalizedToken id="7B479C30014754DF12E09256715A1B79" originalValue="Blätter" pageId="null" pageNumber="393">Blaetter</normalizedToken>
flach, nicht nach unten umgebogen
</emphasis>
, 
<normalizedToken id="33E30ED4E06241AB9CA5038BEEA50E16" originalValue="übrige" pageId="null" pageNumber="393">uebrige</normalizedToken>
Blattmerkmale wie bei 
<emphasis id="00A0922D4C8C37CCD1ECA3AB04F53DC6" italics="true" pageId="null" pageNumber="393">
<taxonomicName id="32DDCDF22DC82EAD93214FAA6FC4B2A8" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="393" phylum="Tracheophyta" rank="species" species="argentea">P. argentea</taxonomicName>
. Stengel niederliegend, an der Spitze bogig aufsteigend, kaum 
<normalizedToken id="ED18F6EE326C41DBDE3C820B40B891A5" originalValue="über" pageId="null" pageNumber="393">ueber</normalizedToken>
10 cm hoch, reich 
<normalizedToken id="42D1638B139743DCD9F3A29B51D0276C" originalValue="beblättert" pageId="null" pageNumber="393">beblaettert</normalizedToken>
, locker und flaumig behaart, meist schon zur 
<normalizedToken id="3DA8D0E88EC0043F1B041D9683DB2642" originalValue="Blütezeit" pageId="null" pageNumber="393">Bluetezeit</normalizedToken>
im 
<normalizedToken id="B3496BD36110101CDFE0E9C2E79FDEEB" originalValue="Frühjahr" pageId="null" pageNumber="393">Fruehjahr</normalizedToken>
vom Grunde an verzweigt. 
<normalizedToken id="E31AFB52AE8FA86A7E45D341A1363544" originalValue="Blütenstiele" pageId="null" pageNumber="393">Bluetenstiele</normalizedToken>
zur Fruchtzeit nickend.
</emphasis>
- 
<normalizedToken id="05D3DC9AC457E5EF6593170EEE91D15A" originalValue="Blüte" pageId="null" pageNumber="393">Bluete</normalizedToken>
: 
<normalizedToken id="546ADA95124286ACE7D399873B27961B" originalValue="Frühling" pageId="null" pageNumber="393">Fruehling</normalizedToken>
bis Sommer.
</paragraph>
<paragraph id="8EFB4D578DD8ACFD72DF485B943DB6E4" pageId="null" pageNumber="393">
<emphasis id="B79958296D6FECE1020A06C6224CDD8E" italics="true" pageId="null" pageNumber="393">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="88348F0E4FBA60195833D9028576B2BE" pageId="null" pageNumber="393">
<emphasis id="25F5C6D2713E1E15013EE23B140EC293" italics="true" pageId="null" pageNumber="393">Standort.</emphasis>
Kollin. Trockene, sandige bis kiesige 
<normalizedToken id="B7C15523866C60D4313C2E88039F2800" originalValue="Böden" pageId="null" pageNumber="393">Boeden</normalizedToken>
, an warmen 
<normalizedToken id="D0D3903D2E57D43B56D730A57602A166" originalValue="Hängen" pageId="null" pageNumber="393">Haengen</normalizedToken>
. 
<normalizedToken id="1383F00EB73F09899DC051753D5AB13E" originalValue="Steppenähnliche" pageId="null" pageNumber="393">Steppenaehnliche</normalizedToken>
Wiesen (keine geschlossene Pflanzendecke).
</paragraph>
<paragraph id="0BBECD0A1B6DCCDAAD2BED8CEB2035E5" pageId="null" pageNumber="393">
<emphasis id="03C45AEFB21A26F6A5B0A346678273E3" italics="true" pageId="null" pageNumber="393">
Verbreitung. 
<normalizedToken id="811E28350D5929CAC102E228DFC8E630" originalValue="Osteuropäische" pageId="null" pageNumber="393">Osteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Von der Oberrheinischen Tiefebene 
<normalizedToken id="2AF81D08E3414256FD66428F5381485A" originalValue="ostwärts" pageId="null" pageNumber="393">ostwaerts</normalizedToken>
bis ins Wolgagebiet. - Im Gebiet in den 
<normalizedToken id="1649AEDEADCBAEECEDD34AF369A33691" originalValue="niederschlagsärmsten" pageId="null" pageNumber="393">niederschlagsaermsten</normalizedToken>
Gegenden der Nordschweiz (Glattfelden) und der Oberrheinischen Tiefebene.
</paragraph>
<paragraph id="D76BC021E22AE4FD1F1FEE377FF56FF1" pageId="null" pageNumber="393">
<emphasis id="44156D7F3D8A25E981B43CD718523FA0" italics="true" pageId="null" pageNumber="393">Bemerkungen.</emphasis>
Unter 
<taxonomicName id="83E5DCC8AA723E79EEA178E0E0ADD183" authority="F. Schultz" authorityName="F. Schultz" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="393" phylum="Tracheophyta" rank="species" species="praecox">
<emphasis id="E8D3FB7EAF5170FB2E03FB0A93EF3FB2" italics="true" pageId="null" pageNumber="393">P. praecox</emphasis>
F. Schultz
</taxonomicName>
ist eine im Gebiet des Hochrheins (Schaffhausen) endemische Sippe beschrieben, die sich von 
<taxonomicName id="0C4AFD762BD9D639DC1F1D6ADAF6F5E8" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="393" phylum="Tracheophyta" rank="species" species="leucopolitana">
<emphasis id="D8C35629683815AE29B5AE80266EA08B" italics="true" pageId="null" pageNumber="393">P. leucopolitana</emphasis>
</taxonomicName>
durch lockeren Haarfilz auf der Blattunterseite, 
<normalizedToken id="7B1DD9A01E5A31B6BB4645A3333E3D26" originalValue="frühere" pageId="null" pageNumber="393">fruehere</normalizedToken>
<normalizedToken id="B1FDAC1132B348AEDA6D300F8CC20A50" originalValue="Blütezeit" pageId="null" pageNumber="393">Bluetezeit</normalizedToken>
und etwas 
<normalizedToken id="950AA99F47539822C3869416E90C056B" originalValue="größere" pageId="null" pageNumber="393">groessere</normalizedToken>
<normalizedToken id="B8C9F9CA3128C3991933D631ACE35CBF" originalValue="Blüten" pageId="null" pageNumber="393">Blueten</normalizedToken>
unterscheidet. Es handelt sich dabei um eine postglazial entstandene Sippe mit kleinem Verbreitungsgebiet, wie sie 
<normalizedToken id="875A94889CC75C966E8B41FF3E47BCC4" originalValue="für" pageId="null" pageNumber="393">fuer</normalizedToken>
Apomikten typisch ist.
</paragraph>
</subSubSection>
