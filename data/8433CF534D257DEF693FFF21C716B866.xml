<subSubSection id="0C68CFF1D5796C41F66544AC79C65717" pageId="null" pageNumber="175" type="description">
<paragraph id="37068D2F83220BDF712153AB346BDFD5" pageId="null" pageNumber="175">
<emphasis id="86EE2A4EF2317B96B0725BBA78DFF9D4" italics="true" pageId="null" pageNumber="175">1fache und gabelig verzweigte, 2strahlige Haare vorhanden.</emphasis>
<normalizedToken id="41CFFF0944EE26E6029F426C48116DDE" originalValue="Blätter" pageId="null" pageNumber="175">Blaetter</normalizedToken>
ungeteilt und 
<normalizedToken id="0476BC1723997B9EE9E35ED9A6ADD150" originalValue="gezähnt" pageId="null" pageNumber="175">gezaehnt</normalizedToken>
oder ganzrandig. 
<normalizedToken id="735218663BF9BAB94BFB3177D6A6B9A4" originalValue="Kelchblätter" pageId="null" pageNumber="175">Kelchblaetter</normalizedToken>
am Grunde kaum ausgebuchtet. 
<normalizedToken id="896CF5B82FB412E6237F89143C25E31D" originalValue="Kronblätter" pageId="null" pageNumber="175">Kronblaetter</normalizedToken>
vorn gerundet, kurz gestielt, 
<normalizedToken id="1439DBAF7EEFDDC57DF5843498E980BA" originalValue="weiß" pageId="null" pageNumber="175">weiss</normalizedToken>
. 
<normalizedToken id="8DF0AAB671F144F92909C44FD28CDBAA" originalValue="Staubfäden" pageId="null" pageNumber="175">Staubfaeden</normalizedToken>
am Grunde ohne Zahn. 
<normalizedToken id="53507263E1CA488CB05096AFE92F20E6" originalValue="Früchte" pageId="null" pageNumber="175">Fruechte</normalizedToken>
<normalizedToken id="2506693C05221C52347DCD001D79BBBB" originalValue="eiförmig" pageId="null" pageNumber="175">eifoermig</normalizedToken>
(ohne Griffel), 1-2mal so lang wie breit, mit einem 
<emphasis id="000C1DF713C5163C34057DBA85F7E459" italics="true" pageId="null" pageNumber="175">durch den kurzen Griffel gebildeten Schnabel</emphasis>
, ohne Nerven, 2samig.
</paragraph>
<paragraph id="9BC21C99A891F3D2947BEB047D3B19AE" pageId="null" pageNumber="175">
Die Gattung 
<taxonomicName id="47946C2246CF11431B325CB863561635" class="Magnoliopsida" family="Brassicaceae" genus="Euclidium" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="175" phylum="Tracheophyta" rank="genus">
<emphasis id="75677B964D2448BA0AEED09D26866F76" italics="true" pageId="null" pageNumber="175">Euclidium</emphasis>
</taxonomicName>
<normalizedToken id="F9334F8DED9F94EFCBAF020EE830784F" originalValue="umfaßt" pageId="null" pageNumber="175">umfasst</normalizedToken>
<emphasis id="E97303B677983E2658DD7091DC7E2E66" italics="true" pageId="null" pageNumber="175">
2 
<normalizedToken id="174BFDDC5D594D0AB162BB2E3449F337" originalValue="osteuropäisch-westasiatische" pageId="null" pageNumber="175">osteuropaeisch-westasiatische</normalizedToken>
Arten
</emphasis>
, von denen die eine allerdings auch als eigene Gattung (
<emphasis id="48A9825CE4D03B13AC7ADC6D7A1091BA" italics="true" pageId="null" pageNumber="175">Litvinovia</emphasis>
Woron.) abgetrennt wird.
</paragraph>
</subSubSection>
