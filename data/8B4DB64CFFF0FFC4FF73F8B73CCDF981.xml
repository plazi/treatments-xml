<taxonomicName id="C4E47CD9FFF5FFC4FEB9FAF13F04FA11" authorityName="Lin, Yu &amp; Hu" authorityYear="2022" box="[349,512,1397,1420]" class="Insecta" family="Staphylinidae" genus="Nazeris" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="45" phylum="Arthropoda" rank="species" species="resimus">
