</taxonomicName>
<emphasis id="3190DB48FFF5FFC4FDE3FAF03F24FA11" bold="true" box="[519,544,1396,1420]" pageId="4" pageNumber="45">13</emphasis>
forebody; 
<emphasis id="3190DB48FFF5FFC4FD76FAF03FAFFA11" bold="true" box="[658,683,1396,1420]" pageId="4" pageNumber="45">14</emphasis>
male sternite VII; 
<emphasis id="3190DB48FFF5FFC4FC8BFAF03E8CFA11" bold="true" box="[879,904,1396,1420]" pageId="4" pageNumber="45">15</emphasis>
