<emphasis id="3190DB48FFF2FFC3FEB0FA303CFFFA56" box="[340,507,1460,1483]" italics="true" pageId="3" pageNumber="44">Nazeris ingentis</emphasis>
</taxonomicName>
<emphasis id="3190DB48FFF2FFC3FDE0FA373F15FA56" bold="true" box="[516,529,1459,1483]" pageId="3" pageNumber="44">8</emphasis>
forebody; 
<emphasis id="3190DB48FFF2FFC3FD63FA373F90FA56" bold="true" box="[647,660,1459,1483]" pageId="3" pageNumber="44">9</emphasis>
male sternite VII; 
<emphasis id="3190DB48FFF2FFC3FCBBFA373E7CFA56" bold="true" box="[863,888,1459,1483]" pageId="3" pageNumber="44">10</emphasis>
male sternite VIII; 
<emphasis id="3190DB48FFF2FFC3FBA8FA373960FA56" bold="true" box="[1100,1124,1459,1483]" pageId="3" pageNumber="44">11</emphasis>
