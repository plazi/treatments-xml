<taxonomicName id="3C844D19E4406E1A4E90FAD1FDAFFA85" box="[415,537,1326,1350]" class="Magnoliopsida" family="Myrtaceae" kingdom="Plantae" order="Myrtales" pageId="101" pageNumber="102" phylum="Tracheophyta" rank="family">Myrtaceae</taxonomicName>
