<taxonomicName id="EE2C9A980E0BA4F16262BF2B6E25C4EC" class="Magnoliopsida" family="Solanaceae" genus="Solanum" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Solanum putii" order="Solanales" pageId="0" pageNumber="1" phylum="Tracheophyta" rank="species" species="putii">
<emphasis id="D3643429939454878E0F188663CCA54F" italics="true" pageId="0" pageNumber="1">Solanum putii</emphasis>
</taxonomicName>
