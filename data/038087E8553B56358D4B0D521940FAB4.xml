</caption>
<caption id="DF566676553B56358A900B5B149EFBF9" ID-DOI="http://doi.org/10.5281/zenodo.6557988" ID-Zenodo-Dep="6557988" httpUri="https://zenodo.org/record/6557988/files/figure.png" inLine="true" pageId="0" pageNumber="248" startId="0.[1387,1557,1116,1149]" targetBox="[248,1194,685,1309]" targetPageId="0">
