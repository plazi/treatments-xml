<taxonomicName id="FEBD4D68D050FFEDC2B3F8F6FBF26120" box="[945,1070,1823,1849]" class="Lecanoromycetes" family="Xylographaceae" genus="Lambiella" kingdom="Fungi" pageId="2" pageNumber="211" phylum="Ascomycota" rank="species" species="plumbea">
