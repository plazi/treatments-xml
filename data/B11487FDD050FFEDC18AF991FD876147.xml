</taxonomicName>
(see 
<tableCitation id="743F0350D050FFEDC56AF8C9FB656123" box="[1128,1209,1823,1850]" captionStart="TABLE 1" captionStartId="3.[136,224,159,183]" captionTargetPageId="3" captionText="TABLE 1. Comparison of salient features of the Lambiella applanata group. including the newly described L. plumbea." httpUri="http://table.plazi.org/id/6DC26663D051FFECC18AFF49FA5766AE" pageId="2" pageNumber="211" tableUuid="6DC26663D051FFECC18AFF49FA5766AE">Table 1</tableCitation>
