<bibRefCitation id="EFCF5CDDFFE46839458D37C9BBEDFD51" author="Cartwright, D. I." box="[208,406,706,732]" pageId="17" pageNumber="300" pagination="1 - 21" refId="ref14689" refString="Cartwright, D. I. (2010) Descriptions of 2 new genera and 13 new species of caddisflies from Australia (Trichoptera: Ecnomidae). Zootaxa, 2415 (1), 1 - 21. https: // doi. org / 10.11646 / zootaxa. 2415.1.1" type="journal article" year="2010">Cartwright, 2010</bibRefCitation>
