<taxonomicName id="4C5E5AAFFFE46839441E3795B87CFD35" authorityName="Cartwright" authorityYear="2010" box="[323,519,670,696]" class="Insecta" family="Ecnomidae" genus="Wellsomina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trichoptera" pageId="17" pageNumber="300" phylum="Arthropoda" rank="species" species="saeta">
