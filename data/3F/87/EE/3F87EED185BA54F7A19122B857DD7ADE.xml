<bibRefCitation DOI="https://doi.org/10.1002/mmnz.20030790207" author="Hansen, M" editor="Hansen, M" journalOrPublisher="Vol. 2. M. Apollo Books, Copenhague" pageId="0" pageNumber="301" pagination="1 - 416" refId="B38" refString="Hansen, M, 1999. Hydrophiloidea (s. str.) (Coleoptera). In: Hansen, M, Ed., World catalogue of insects. Vol. 2. M. Apollo Books, Copenhague: 1 - 416, DOI: https://doi.org/10.1002/mmnz.20030790207" title="Hydrophiloidea (s. str.) (Coleoptera)." url="https://doi.org/10.1002/mmnz.20030790207" volumeTitle="World catalogue of insects." year="1999">Hansen 1999</bibRefCitation>
; 
<bibRefCitation author="Short, AEZ" journalOrPublisher="Koleopterologische Rundschau" pageId="0" pageNumber="301" pagination="315 - 359" publicationUrl="http://www.cercyon.eu/Publications_PDF/ShortFikacek_CatalogueUpdateII.pdf" refId="B94" refString="Short, AEZ, Hebauer, F, 2006. World catalogue of Hydrophiloidea - additions and corrections, 1 (1999-2005) (Coleoptera). Koleopterologische Rundschau 76: 315 - 359, http://www.cercyon.eu/Publications_PDF/ShortFikacek_CatalogueUpdateII.pdf" title="World catalogue of Hydrophiloidea - additions and corrections, 1 (1999 - 2005) (Coleoptera)." url="http://www.cercyon.eu/Publications_PDF/ShortFikacek_CatalogueUpdateII.pdf" volume="76" year="2006">Short and Hebauer 2006</bibRefCitation>
