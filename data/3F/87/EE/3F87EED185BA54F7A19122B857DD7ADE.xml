<bibRefCitation DOI="https://doi.org/10.11646/zootaxa.1917.1.6" author="Spangler, PJ" journalOrPublisher="Zootaxa" pageId="0" pageNumber="301" pagination="65 - 68" refId="B102" refString="Spangler, PJ, Short, AEZ., 2008. Three new species of Neotropical Tropisternus Solier (Coleoptera: Hydrophilidae). Zootaxa 1917 (1): 65 - 68, DOI: https://doi.org/10.11646/zootaxa.1917.1.6" title="Three new species of Neotropical Tropisternus Solier (Coleoptera: Hydrophilidae)." url="https://doi.org/10.11646/zootaxa.1917.1.6" volume="1917" year="2008">Spangler and Short 2008</bibRefCitation>
