<bibRefCitation id="BC7D4B6CF947FFD0FDC9FDEFFC86EEBE" author="SCHMIEDEKNECHT O" box="[628,844,631,652]" pageId="11" pageNumber="950" refId="ref8019" refString="SCHMIEDEKNECHT O. (1930): Die Hymenopteren Nord- und Mitteleuropas mit Einschluss von England, Sudschweiz, Sudtirol und Ungarn. - 2. Auflage, Jena, X + 1062 pp." type="book" year="1930">SCHMIEDEKNECHT 1930</bibRefCitation>
; 
<bibRefCitation id="BC7D4B6CF947FFD0FCE9FDE0FC24EEBF" author="BELLMANN H" box="[852,1006,631,653]" pageId="11" pageNumber="950" refId="ref6889" refString="BELLMANN H. (1995): Bienen, Wespen, Ameisen. Hautflugler Mitteleuropas. - Stuttgart, 336 pp." type="book" year="1995">BELLMANN 1995</bibRefCitation>
).
</paragraph>
<paragraph id="D853369DF947FFD0FF0FFD01FBEFEE9C" blockId="11.[178,1087,547,686]" box="[178,1061,664,686]" pageId="11" pageNumber="950">
