<subSubSection id="2DBC5604F6190B5B7956CBAEB4097FC0" pageId="null" pageNumber="202" type="description">
<paragraph id="2A622E50A88FC20F5D780E0CF8EAD38B" pageId="null" pageNumber="202">
<normalizedToken id="B0C9D0948B1F9C7E67A895941D027235" originalValue="Blätter" pageId="null" pageNumber="202">Blaetter</normalizedToken>
nicht fleischig, meist 
<normalizedToken id="CCD87196D17EB652DBA70061EAF0627C" originalValue="hellgrün" pageId="null" pageNumber="202">hellgruen</normalizedToken>
, die mittleren und obern bis 2 cm breit, mit 1 Endzahn und 
<emphasis id="2DFFC7421E2A1B23BFDA2CA351B599A6" italics="true" pageId="null" pageNumber="202">jederseits mit 2</emphasis>
- 
<emphasis id="1AC55EC0DDE93E25B533B5B4B57A43AF" italics="true" pageId="null" pageNumber="202">3</emphasis>
, oft sehr kleinen 
<normalizedToken id="BC9E67B9D07B0AB08E47A73BE6BEDDD3" originalValue="Zähnen" pageId="null" pageNumber="202">Zaehnen</normalizedToken>
; 
<emphasis id="F3C0FC1EEF4568CEE5F141E502573FE2" italics="true" pageId="null" pageNumber="202">
Endzahn meist 
<normalizedToken id="6DCBB61F7FE4854CF4F6DB70ADC928DE" originalValue="schmäler" pageId="null" pageNumber="202">schmaeler</normalizedToken>
als lang
</emphasis>
, 
<normalizedToken id="6D88382C25E6E8FD8D8D9A0D3CE023B6" originalValue="±" pageId="null" pageNumber="202">+/-</normalizedToken>
stumpf, ohne Spitze. 
<emphasis id="8D11252934256F1972BB095F4E9AA13A" italics="true" pageId="null" pageNumber="202">Fruchtstiel 3</emphasis>
<normalizedToken id="C71DE933537D76F538E54D8B58C6F495" originalValue="½" pageId="null" pageNumber="202">1/2</normalizedToken>
- 
<emphasis id="3F549D96D1D441817C10072D6AE477D8" italics="true" pageId="null" pageNumber="202">7mal so lang wie der Kelch, auf der obern Seite mit 1 Haarreihe, sonst abstehend behaart.</emphasis>
Kelch zerstreut behaart bis kahl, am Rande der Zipfel mit 0,5-0,9 mm langen Haaren. Krone im Durchmesser 4-6 mm, hellila, mit 16-19 purpurroten Adern. Staubbeutel 0,4-0,8 mm lang. 
<emphasis id="94CF44D991B247377FA0D12A2A357E6F" italics="true" pageId="null" pageNumber="202">Griffel 0,3</emphasis>
- 
<emphasis id="053A96079FDE77803AA39F9EA9F7E39B" italics="true" pageId="null" pageNumber="202">0,5 mm lang.</emphasis>
- 
<normalizedToken id="4A3C908AE9C8BEAC6AEF2D744C4CF329" originalValue="Blüte" pageId="null" pageNumber="202">Bluete</normalizedToken>
: 
<normalizedToken id="E6061C466C9CE3F78895145B493F2316" originalValue="Frühling" pageId="null" pageNumber="202">Fruehling</normalizedToken>
und Herbst.
</paragraph>
<paragraph id="87490BD27A61CD585A8A2127D2E694DC" pageId="null" pageNumber="202">
<emphasis id="47E5F0E95F787AF77C6EF4D80E9A9D83" italics="true" pageId="null" pageNumber="202">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="CD0A558DC84D98905CE008CB44BAA3CF" italics="true" pageId="null" pageNumber="202">36:</emphasis>
Material von 
<normalizedToken id="BAB2165AC42C57231AC6BADDB9807C06" originalValue="Zürich" pageId="null" pageNumber="202">Zuerich</normalizedToken>
, von zahlreichen Stellen in 
<normalizedToken id="7F9CCD0A27705DB52F741C719ACE093F" originalValue="Österreich" pageId="null" pageNumber="202">Oesterreich</normalizedToken>
, aus Polen (Fischer 1967), aus Schweden (an einer Pflanze wurden auch 2n = 18 
<normalizedToken id="3A3074425C91040502A0DDB650045430" originalValue="gezählt" pageId="null" pageNumber="202">gezaehlt</normalizedToken>
; Nordenstam und Nilsson 1969), aus 
<normalizedToken id="59FDB00268BCB66E5C7AD48F423E77E1" originalValue="Oberösterreich" pageId="null" pageNumber="202">Oberoesterreich</normalizedToken>
(Speta 1970), aus 
<normalizedToken id="ACB370610600566D297C4D01E49BBCCA" originalValue="Niederösterreich" pageId="null" pageNumber="202">Niederoesterreich</normalizedToken>
(Speta 1971).
</paragraph>
<paragraph id="B8CAF6803A3CA76C2A9D87075D54FB31" pageId="null" pageNumber="202">
<emphasis id="A33E9DBDBF4D5BD9FC1B842AB1CEE5E0" italics="true" pageId="null" pageNumber="202">Standort.</emphasis>
Kollin und montan, selten subalpin. Ziemlich feuchte, 
<normalizedToken id="60FF2DA7E63C22AE53FD8D4FC0FC2E7C" originalValue="nährstoffreiche" pageId="null" pageNumber="202">naehrstoffreiche</normalizedToken>
<normalizedToken id="A019E33C5C5429DB78F7A780A8A78D13" originalValue="Böden" pageId="null" pageNumber="202">Boeden</normalizedToken>
in halbschattigen Lagen. 
<normalizedToken id="A79FD25E5E79E64EB96484B96B8094B5" originalValue="Auenwälder" pageId="null" pageNumber="202">Auenwaelder</normalizedToken>
, 
<normalizedToken id="68DABAA474139682196F5BF3CF05E728" originalValue="Gebüsche" pageId="null" pageNumber="202">Gebuesche</normalizedToken>
, Hecken, Fettwiesen, 
<normalizedToken id="1F59ECDDC06EE0CA86AA79EC71A6CA0A" originalValue="Wegränder" pageId="null" pageNumber="202">Wegraender</normalizedToken>
, 
<normalizedToken id="28D868F7566522CC9EA74A7C0AB957EB" originalValue="Schuttplätte" pageId="null" pageNumber="202">Schuttplaette</normalizedToken>
, Weinberge, 
<normalizedToken id="311AEE1FBFB183D97D52106D9F168843" originalValue="Äcker" pageId="null" pageNumber="202">Aecker</normalizedToken>
, Gartenbeete.
</paragraph>
<paragraph id="6925513F1642A019171F801B367D1141" pageId="null" pageNumber="202">
<emphasis id="4499103FA364AEBE5A54F760471AB6DA" italics="true" pageId="null" pageNumber="202">
Verbreitung. 
<normalizedToken id="22EBC2AFF5A459A3B1F61B889DBEF290" originalValue="Europäische" pageId="null" pageNumber="202">Europaeische</normalizedToken>
Pflanze:
</emphasis>
West- und 
<normalizedToken id="5DD4BAACC3BB19238C243C5E02B3FFE2" originalValue="nordwärts" pageId="null" pageNumber="202">nordwaerts</normalizedToken>
bis Mittelfrankreich, Schottland, 
<normalizedToken id="7142E338BFEDCAF934ECF97D3C35415D" originalValue="Südschweden" pageId="null" pageNumber="202">Suedschweden</normalizedToken>
; ostund 
<normalizedToken id="5481AB4EB4996779ADE44D7B58FBA2AD" originalValue="südwärts" pageId="null" pageNumber="202">suedwaerts</normalizedToken>
bis 
<normalizedToken id="A7829773DFF52C7E2A0F50A85E59143C" originalValue="Westrußland" pageId="null" pageNumber="202">Westrussland</normalizedToken>
, westliche 
<normalizedToken id="0A71E5838A3751D37CD4BB638EE57D35" originalValue="Schwarzmeerküste" pageId="null" pageNumber="202">Schwarzmeerkueste</normalizedToken>
, 
<normalizedToken id="D0FA88FB3E985EEE1A206E447FA788F6" originalValue="südliches" pageId="null" pageNumber="202">suedliches</normalizedToken>
Jugoslawien, Alpen. - Im Gebiet verbreitet, ziemlich 
<normalizedToken id="45EDA80CE4EE86523CE90CA81B47854C" originalValue="häufig" pageId="null" pageNumber="202">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
