<taxonomicName id="4C30F2BDFFF80F5CF660FD65C47DFCBC" baseAuthorityName="Thomas &amp; Hinton" baseAuthorityYear="1925" class="Mammalia" family="Nesomyidae" genus="Petromyscus" kingdom="Animalia" order="Rodentia" pageId="10" pageNumber="193" phylum="Chordata" rank="species" species="collinus">collinus</taxonomicName>
