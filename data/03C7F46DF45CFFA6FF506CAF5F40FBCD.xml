<taxonomicName id="4C6E3EF8F45BFFA6FEBC6AD45963FB95" box="[356,564,1008,1034]" class="Pucciniomycetes" family="Phakopsoraceae" genus="Kweilingia" kingdom="Fungi" order="Pucciniales" pageId="4" pageNumber="131" phylum="Basidiomycota" rank="species" species="divina">
