<bibRefCitation id="EFFF388AF45BFFA6FEB76D1C5ABBFBCC" author="Eboh, D. O." box="[367,492,1080,1107]" pageId="4" pageNumber="131" pagination="205 - 211" refId="ref11515" refString="Eboh, D. O. (1985) Nigerian graminicolous Uredinales: grass rusts from Nsukka II. Mycologia 77: 205 - 211. https: // doi. org / 10.1080 / 00275514.1985.12025086" type="journal article" year="1985">Eboh 1985</bibRefCitation>
