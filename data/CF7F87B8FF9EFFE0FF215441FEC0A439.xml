<taxonomicName id="80D64D2DFF9EFFE0FE9C548CFCF0A2B5" authority="Logunov &amp; Ponomarev, 2020" authorityName="Logunov &amp; Ponomarev" authorityYear="2020" box="[298,815,651,676]" class="Arachnida" family="Lycosidae" genus="Karakumosa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Araneae" pageId="4" pageNumber="505" phylum="Arthropoda" rank="species" species="repetek">
