</subSubSection>
<subSubSection id="46C552E20C20BFCBEA6DC068F729A2D8" pageId="0" pageNumber="79" type="remarks">
<paragraph id="BD3D251686AD8B9505F37754E2D65FF1" pageId="0" pageNumber="79">Remark.</paragraph>
<paragraph id="97C63A8E0D403156E610DAC789C73D14" pageId="0" pageNumber="79">
<taxonomicName id="3D8115FA6F91A073AECAE9A23FE66618" authorityName="J. S. Kim &amp; Y. W. Lim" authorityYear="2022" class="Agaricomycetes" family="Marasmiaceae" genus="Collybiopsis" higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Collybiopsis orientisubnuda" order="Agaricales" pageId="0" pageNumber="79" phylum="Basidiomycota" rank="species" species="orientisubnuda">
<emphasis id="506721BA044519946CC35746DA6CDCE8" italics="true" pageId="0" pageNumber="79">Collybiopsis orientisubnuda</emphasis>
</taxonomicName>
is morphologically similar to 
<taxonomicName id="74960FB047FD19EC668A5CEFF0E99A20" genus="Co." kingdom="Fungi" lsidName="Co. peronata" pageId="0" pageNumber="79" rank="species" species="peronata">
<emphasis id="9FCFCACA6132AAD942F51E94967B6848" italics="true" pageId="0" pageNumber="79">Co. peronata</emphasis>
</taxonomicName>
(Bolton) R.H. Petersen and 
<taxonomicName id="0FF2AB0181E114AA5FC718F9CCC15840" genus="Co." kingdom="Fungi" lsidName="Co. subnuda" pageId="0" pageNumber="79" rank="species" species="subnuda">
<emphasis id="0CC072A2C9155D60E76C3CBCF69551E1" italics="true" pageId="0" pageNumber="79">Co. subnuda</emphasis>
</taxonomicName>
(Ellis ex Peck) R.H. Petersen. 
<taxonomicName id="4DA3E62881059CD3363B3D0C05BBE555" authorityName="R.H.Petersen" authorityYear="2021" baseAuthorityName="Bolton" class="Agaricomycetes" family="Marasmiaceae" genus="Collybiopsis" higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Collybiopsis peronata" order="Agaricales" pageId="0" pageNumber="79" phylum="Basidiomycota" rank="species" species="peronata">
<emphasis id="13B001BA0065D8F62240429EC2F664D8" italics="true" pageId="0" pageNumber="79">Collybiopsis peronata</emphasis>
</taxonomicName>
can be distinguished from 
<taxonomicName id="CA2815805A1DF83ACAAED09E2FA8ED62" genus="Co." kingdom="Fungi" lsidName="Co. orientisubnuda" pageId="0" pageNumber="79" rank="species" species="orientisubnuda">
<emphasis id="35DE8D3AF7C7861D08A76B2BE516519A" italics="true" pageId="0" pageNumber="79">Co. orientisubnuda</emphasis>
</taxonomicName>
by fewer and buff lamellulae (1-3), a thicker stipe (3-8 mm), smaller Q value (2.3), longer basidia (20-40 
<normalizedToken id="34CD7D7A0A197C3B9AB2603C889CCECE" originalValue="μm">μm</normalizedToken>
), and longer cheilocystidia (25-90 
<normalizedToken id="D097C08A19A1D306393862BFF5D97DD6" originalValue="×">x</normalizedToken>
5-10 
<normalizedToken id="1B74B9F29C6DF085FB4CB9EF953F4801" originalValue="μm">μm</normalizedToken>
) (
<bibRefCitation id="FE5EABA39469EBC8011C50AD1427ED35" author="Noordeloos, ME" journalOrPublisher="Persoonia-Molecular Phylogeny and Evolution of Fungi" pageId="0" pageNumber="79" refId="B39" refString="Noordeloos, ME, Kuyper, TW, Vellinga, E, 1999. Flora Agaricina Neerlandica Vol 4. CRC Press, Florida." title="Flora Agaricina Neerlandica Vol 4. CRC Press, Florida." year="1999">Noordeloos et al. 1999</bibRefCitation>
). 
<taxonomicName id="CF71FA88D8A53A174F911978221F4A48" class="Agaricomycetes" family="Marasmiaceae" genus="Collybiopsis" higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Collybiopsis subnuda" order="Agaricales" pageId="0" pageNumber="79" phylum="Basidiomycota" rank="species" species="subnuda">
<emphasis id="55C4637485684159DB6517D93A9A9429" italics="true" pageId="0" pageNumber="79">Collybiopsis subnuda</emphasis>
</taxonomicName>
differs from 
<taxonomicName id="A1794B38C6461295B40A8FE22BC83706" genus="Co." kingdom="Fungi" lsidName="Co. orientisubnuda" pageId="0" pageNumber="79" rank="species" species="orientisubnuda">
<emphasis id="DAD08D658A59074ABD9CF529F6ACDAC8" italics="true" pageId="0" pageNumber="79">Co. orientisubnuda</emphasis>
</taxonomicName>
with thinner stipe (~3 mm), larger basidiospores (8-11 
<normalizedToken id="CBD2C712280CEBC7295BF6E6FD403625" originalValue="×">x</normalizedToken>
3-4.5 
<normalizedToken id="948CA400B143D9F5F23EB62C8D051E93" originalValue="μm">μm</normalizedToken>
) and the absence of pleurocystidia (
<bibRefCitation id="D50F5D98243072C2B7F0D7BFA0BFDA50" DOI="https://doi.org/10.12905/0380.sydowia72-2020-0271" author="Tekpinar, A" journalOrPublisher="Nova Beih Nova Hedwigia" pageId="0" pageNumber="79" refId="B55" refString="Tekpinar, A, Acar, I, 2020. Fungal Systematics and Evolution: FUSE 6. Sydowia: 231-356. https://doi.org/10.12905/0380.sydowia72-2020-0271" title="Fungal Systematics and Evolution: FUSE 6. Sydowia: 231 - 356." url="https://doi.org/10.12905/0380.sydowia72-2020-0271" year="2020">
<normalizedToken id="C22168C7D076F6A0B2BDBB6CA42FBA92" originalValue="Tekpınar">Tekpinar</normalizedToken>
and Acar 2020
</bibRefCitation>
).
</paragraph>
</subSubSection>
