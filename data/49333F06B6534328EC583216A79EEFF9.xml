<paragraph id="0C4C1B614B2432BF0AB61F6A2683CF28" pageId="0" pageNumber="1">
<taxonomicName id="6CEE76DB3E22E646CCE702BBC55A5A86" class="Magnoliopsida" family="Solanaceae" genus="Solanum" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Solanum camranhense" order="Solanales" pageId="0" pageNumber="1" phylum="Tracheophyta" rank="species" species="camranhense">
