Subgenus 
<taxonomicName id="03944D7DFF2E6A91F79690AC16BCBC20" authority="Kaup, 1829" box="[2154,2236,1781,1810]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="213" pageNumber="975" phylum="Chordata" rank="genus">Myotis</taxonomicName>
