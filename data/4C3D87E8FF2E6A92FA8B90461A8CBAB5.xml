<taxonomicName id="03944D7DFF2E6A91F73190AC1761BC20" baseAuthorityName="Kuhl" baseAuthorityYear="1817" box="[2253,2401,1781,1810]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="213" pageNumber="975" phylum="Chordata" rank="species" species="daubentonii">daubentonii</taxonomicName>
