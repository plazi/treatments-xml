<taxonomicName authorityName="Costa &amp; Duarte &amp; Iannuzzi &amp; Grossi" authorityYear="2022" baseAuthorityName="Endrodi" baseAuthorityYear="1977" box="[160,388,486,511]" class="Insecta" family="Scarabaeidae" genus="Tetragus" higherTaxonomySource="CoL" kingdom="Animalia" order="Coleoptera" pageId="29" pageNumber="219" phylum="Arthropoda" rank="species" species="waldenfelsi">
<emphasis box="[160,388,486,511]" italics="true" pageId="29" pageNumber="219">Tetragus waldenfelsi</emphasis>
</taxonomicName>
