<taxonomicName authority="Costa &amp; Duarte &amp; Iannuzzi &amp; Grossi, 2022" authorityName="Costa &amp; Duarte &amp; Iannuzzi &amp; Grossi" authorityYear="2022" box="[259,461,1050,1073]" class="Insecta" family="Dynastidae" genus="Gibboryctes" kingdom="Animalia" order="Coleoptera" pageId="5" pageNumber="195" phylum="Arthropoda" rank="species" species="ebeninus" status="sp. nov.">
