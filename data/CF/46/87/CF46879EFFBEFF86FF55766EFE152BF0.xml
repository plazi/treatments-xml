<subSubSection pageId="21" pageNumber="211" type="etymology">
<paragraph blockId="21.[160,1155,1520,1616]" box="[160,285,1520,1546]" pageId="21" pageNumber="211">
<emphasis bold="true" box="[160,285,1520,1546]" italics="true" pageId="21" pageNumber="211">Etymology</emphasis>
</paragraph>
<paragraph blockId="21.[160,1155,1520,1616]" pageId="21" pageNumber="211">
From latin ‘ 
<taxonomicName authorityName="Costa &amp; Duarte &amp; Iannuzzi &amp; Grossi" authorityYear="2022" box="[288,385,1556,1581]" class="Insecta" family="Dynastidae" genus="Gibboryctes" kingdom="Animalia" order="Coleoptera" pageId="21" pageNumber="211" phylum="Arthropoda" rank="species" species="ebeninus">
<emphasis box="[288,385,1556,1581]" italics="true" pageId="21" pageNumber="211">ebeninus</emphasis>
</taxonomicName>
’, meaning ‘ebony’, in reference to the black and shiny surface of the body.
</paragraph>
</subSubSection>
