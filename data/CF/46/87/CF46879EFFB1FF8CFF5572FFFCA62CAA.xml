<bibRefCitation author="Dupuis F" box="[868,1016,1284,1309]" pageId="28" pageNumber="218" pagination="179 - 184" refId="ref13276" refString="Dupuis F. 2019. Gibboryctes impunctatus, nouvelle espece du Perou (Coleoptera, Dynastidae). Coleopteres. 25: 179 - 184." type="journal article" year="2019">Dupuis, 2019</bibRefCitation>
