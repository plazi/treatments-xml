<emphasis box="[160,382,1284,1309]" italics="true" pageId="28" pageNumber="218">Tetragus waldenfelsi</emphasis>
(
<bibRefCitation author="Endrodi S" box="[395,553,1284,1309]" pageId="28" pageNumber="218" pagination="335 - 336" refId="ref13398" refString="Endrodi S. 1977. Strategus waldenfelsi sp. n. (Coleoptera, Dynastinae). Reichenbachia. 16: 335 - 336." type="journal article" year="1977">Endrödi, 1977</bibRefCitation>
)
</taxonomicName>
and 
<taxonomicName authority="(Dupuis, 2019)" authorityName="Costa &amp; Duarte &amp; Iannuzzi &amp; Grossi" authorityYear="2022" baseAuthorityName="Dupuis" baseAuthorityYear="2019" box="[617,1025,1284,1309]" class="Insecta" family="Scarabaeidae" genus="Tetragus" higherTaxonomySource="CoL" kingdom="Animalia" order="Coleoptera" pageId="28" pageNumber="218" phylum="Arthropoda" rank="species" species="impunctatus">
