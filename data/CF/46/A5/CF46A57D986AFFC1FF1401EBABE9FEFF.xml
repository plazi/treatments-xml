&amp; 
<figureCitation box="[1212,1243,464,490]" captionStart="FIGURES 88–89" captionStartId="18.[151,264,1650,1674]" captionTargetBox="[151,1436,181,1626]" captionTargetId="figure-21@18.[151,1436,181,1626]" captionTargetPageId="18" captionText="FIGURES 88–89. 88 Distribution of A. nigricornis, 89 Distribution of A. nigriventris." figureDoi="http://doi.org/10.5281/zenodo.6810085" httpUri="https://zenodo.org/record/6810085/files/figure.png" pageId="1" pageNumber="202">88</figureCitation>
