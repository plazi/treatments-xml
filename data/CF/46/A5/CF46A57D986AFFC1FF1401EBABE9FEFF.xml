<bibRefCitation author="Gauld, I. D." box="[882,1034,464,490]" pageId="1" pageNumber="202" pagination="1 - 453" refId="ref5550" refString="Gauld, I. D. (2000) The Ichneumonidae of Costa Rica 3. Memoirs of the American Entomological Institute, 63, 1 - 453. https: // doi. org / 10.1111 / j. 1096 - 3642.2000. tb 00015. x" type="journal article" year="2000">Gauld, 2000</bibRefCitation>
