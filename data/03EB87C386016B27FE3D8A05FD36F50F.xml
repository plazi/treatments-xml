<subSubSection id="C358655E86016B27FECB855FFD36F50F" pageId="19" pageNumber="82" type="discussion">
<paragraph id="8BFD36D586016B27FECB855FFD36F50F" blockId="19.[225,1210,2116,2708]" pageId="19" pageNumber="82">
Remarks. 
<taxonomicName id="4C424D5686016B27FE0A855FFC0EF6C9" authority="Yoo" authorityName="Yoo" box="[466,916,2347,2386]" class="Gastropoda" family="Microdomatidae" genus="Microdoma" higherTaxonomySource="GBIF" kingdom="Animalia" order="Vetigastropoda" pageId="19" pageNumber="82" phylum="Mollusca" rank="species" species="angulata">
<emphasis id="B936EAC786016B27FE0A855FFCA1F6C9" box="[466,827,2347,2386]" italics="true" pageId="19" pageNumber="82">Microdoma angulata</emphasis>
Yoo
</taxonomicName>
is similar to the European species 
<taxonomicName id="4C424D5686016B27FDE4852EFBC4F61B" authority="Batten" authorityName="Batten" box="[572,1118,2394,2432]" class="Gastropoda" family="Microdomatidae" genus="Microdoma" higherTaxonomySource="GBIF" kingdom="Animalia" order="Vetigastropoda" pageId="19" pageNumber="82" phylum="Mollusca" rank="species" species="uniserrata">
<emphasis id="B936EAC786016B27FDE4852EFC57F61B" box="[572,973,2394,2432]" italics="true" pageId="19" pageNumber="82">Microdoma uniserrata</emphasis>
Batten
</taxonomicName>
, but differs in having a large pleural angle and more collabral cords. This species is very different from other European species 
<taxonomicName id="4C424D5686016B27FE5E8597FC5AF590" authority="Batten" authorityName="Batten" box="[390,960,2531,2571]" class="Gastropoda" family="Microdomatidae" genus="Microdoma" higherTaxonomySource="GBIF" kingdom="Animalia" order="Vetigastropoda" pageId="19" pageNumber="82" phylum="Mollusca" rank="species" species="triserrata">
<emphasis id="B936EAC786016B27FE5E8597FCBEF590" box="[390,804,2531,2571]" italics="true" pageId="19" pageNumber="82">Microdoma triserrata</emphasis>
Batten
</taxonomicName>
, 
<taxonomicName id="4C424D5686016B27FC328597FD0DF5A3" authority="de Koninck" authorityName="de Koninck" class="Gastropoda" family="Microdomatidae" genus="Microdoma" higherTaxonomySource="GBIF" kingdom="Animalia" order="Vetigastropoda" pageId="19" pageNumber="82" phylum="Mollusca" rank="species" species="bicrenulata">
<emphasis id="B936EAC786016B27FC328597FE3FF5A3" italics="true" pageId="19" pageNumber="82">Microdoma bicrenulata</emphasis>
de Koninck
</taxonomicName>
, as well as North American species 
<taxonomicName id="4C424D5686016B27FE588634FBC1F5FC" authority="Meek &amp; Worthen" authorityName="Meek &amp; Worthen" authorityYear="1867" box="[384,1115,2624,2663]" class="Gastropoda" family="Microdomatidae" genus="Microdoma" higherTaxonomySource="GBIF" kingdom="Animalia" order="Vetigastropoda" pageId="19" pageNumber="82" phylum="Mollusca" rank="species" species="conica">
<emphasis id="B936EAC786016B27FE588634FD44F5FC" box="[384,734,2624,2663]" italics="true" pageId="19" pageNumber="82">Microdoma conica</emphasis>
Meek &amp; Worthen
</taxonomicName>
and 
<taxonomicName id="4C424D5686016B27FF398619FD36F50F" authority="Sayre." box="[225,684,2669,2708]" class="Gastropoda" family="Microdomatidae" genus="Microdoma" higherTaxonomySource="GBIF" kingdom="Animalia" order="Vetigastropoda" pageId="19" pageNumber="82" phylum="Mollusca" rank="species" species="ornata">
<emphasis id="B936EAC786016B27FF398619FDB7F50F" box="[225,557,2669,2708]" italics="true" pageId="19" pageNumber="82">Microdoma ornata</emphasis>
Sayre.
</taxonomicName>
</paragraph>
