<taxonomicName id="52B1F7DACAB0CBFE0965225286311AA1" authorityName="Liu" authorityYear="2022" class="Arachnida" family="Thomisidae" genus="Lysiteles" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Lysiteles subspirellus" order="Araneae" pageId="0" pageNumber="43" phylum="Arthropoda" rank="species" species="subspirellus">
<emphasis id="AA92017B19516660A324DB5520DB639F" italics="true" pageId="0" pageNumber="43">Lysiteles subspirellus</emphasis>
