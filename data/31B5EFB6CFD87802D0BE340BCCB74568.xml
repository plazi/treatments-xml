<subSubSection id="ABB0EB6895A0C2652E8CDE57855C6798" pageId="null" pageNumber="590" type="description">
<paragraph id="A0501EA730B0D508DCC7016D198321A8" pageId="null" pageNumber="590">
<emphasis id="F5F47734050B8D84F374D4C0A6916E68" italics="true" pageId="null" pageNumber="590">Stengel meist 2</emphasis>
- 
<emphasis id="1612ECBBD87F51AE3D3155F25751505B" italics="true" pageId="null" pageNumber="590">
5 
<normalizedToken id="1B6175A2038625AF51FF5C856288EF56" originalValue="köpfig" pageId="null" pageNumber="590">koepfig</normalizedToken>
.
</emphasis>
<normalizedToken id="03868A53708255B3995DF405EEED7285" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
lanzettlich, meist ganzrandig, 
<emphasis id="3703103BA2D528D8F11570596BC2CAA2" italics="true" pageId="null" pageNumber="590">
die 
<normalizedToken id="5E146EEF95B12B70700182C82F6F6BC9" originalValue="größeren" pageId="null" pageNumber="590">groesseren</normalizedToken>
5
</emphasis>
- 
<emphasis id="E464BC15BF8773279B5A245B3EB9CE79" italics="true" pageId="null" pageNumber="590">
25mal so lang wie breit, zwischen Spreite und Blattgrund nicht auf den Mittelnerv 
<normalizedToken id="20C11CF36C545BACEC5340BD18602F81" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
</emphasis>
(
<emphasis id="D141B6BFEE499ED1B30DAAC1425D6F00" italics="true" pageId="null" pageNumber="590">2</emphasis>
- 
<emphasis id="7F7AC926D980575E3B2B0A211EF81EC6" italics="true" pageId="null" pageNumber="590">6 mm breit</emphasis>
)
<emphasis id="6BB8D88F9CC771FA9597202D4165C897" italics="true" pageId="null" pageNumber="590">
. 
<normalizedToken id="D15F20174EA44BEC9240F77212C0353D" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
11
</emphasis>
- 
<emphasis id="B1E4DD587326C39843D0509F19730566" italics="true" pageId="null" pageNumber="590">
15 mm lang. 
<normalizedToken id="D6FA6A61D428CAF1DEB4E5189E7C3DA6" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
1,5
</emphasis>
- 
<emphasis id="67F38485430DA058E3F7E615BD0B7F32" italics="true" pageId="null" pageNumber="590">2,5 mm breit.</emphasis>
<normalizedToken id="416990DA40282E874FBB753122728727" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
hell- oder dunkelbraun. - 
<normalizedToken id="39AB2996114AB88FF25DB1C4E564366A" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="9F87C19FC63AE31232885C7EE4FCD46F" pageId="null" pageNumber="590">
<emphasis id="8C6AB5FD06FF602535C800FE11067788" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="15F9B7074D4CFF96D4640B7BD6797D84" italics="true" pageId="null" pageNumber="590">27:</emphasis>
Material unbekannter Herkunft; Fortpflanzung apomiktisch (Christoff und Popoff 1933), aus der Steiermark (Polatschek 1966a), aus der Slowakei (Majovsky et al. 1970).
</paragraph>
<paragraph id="068D0D6A5770A989CC852EB2AC3DC7A8" pageId="null" pageNumber="590">
<emphasis id="873DE17D3898D58A5FFF04976585FD6A" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Subalpin, seltener montan und kollin (herabgeschwemmt). Steinige, kalkreiche 
<normalizedToken id="115D556E675964ABE733E29E80697169" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
. Felsspalten, steinige 
<normalizedToken id="10A5F53990A96131EAF0708B20906483" originalValue="Hänge" pageId="null" pageNumber="590">Haenge</normalizedToken>
, 
<normalizedToken id="DA5EB989C2E40AF5063BAF16C7104B14" originalValue="Geröll" pageId="null" pageNumber="590">Geroell</normalizedToken>
.
</paragraph>
<paragraph id="01489CDDB972C379286CC1E021C568B4" pageId="null" pageNumber="590">
<emphasis id="99208C9EAF28E14ECF05FE7D7DDA8F03" italics="true" pageId="null" pageNumber="590">
Verbreitung. Mittel- und 
<normalizedToken id="AFEA51FD22802E5C7631789282430C53" originalValue="südeuropäische" pageId="null" pageNumber="590">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="1E7BE8C66442D917CDD88152D84EDF4D" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="D4D29C819E39ECC438A456D251AB14D1" originalValue="östlich" pageId="null" pageNumber="590">oestlich</normalizedToken>
</emphasis>
)
<emphasis id="F2452E893D04F93CB9778DF5EC6ECDB7" italics="true" pageId="null" pageNumber="590">:</emphasis>
Jura, Alpen und Alpenvorland, Abruzzen, Istrien, Gebirge der 
<normalizedToken id="4C9839F54D346EF8BB2397FCCF06CA31" originalValue="nördlichen" pageId="null" pageNumber="590">noerdlichen</normalizedToken>
Balkanhalbinsel (
<normalizedToken id="8476047D693058360D6822FAF72380EC" originalValue="südwärts" pageId="null" pageNumber="590">suedwaerts</normalizedToken>
bis Albanien), Westkarpaten. - Im Gebiet: Alpen, Alpenvorland, Jura (
<normalizedToken id="68E8EDB44AA08487098AFA9FDFFAB83D" originalValue="nordostwärts" pageId="null" pageNumber="590">nordostwaerts</normalizedToken>
bis 
<normalizedToken id="36C6B842EF4DF0210FFA7D34D57D4FEE" originalValue="Geißberg" pageId="null" pageNumber="590">Geissberg</normalizedToken>
bei Brugg; 
<normalizedToken id="3437FAFB86C32CBA77F1AEB503566A7E" originalValue="Schwäbische" pageId="null" pageNumber="590">Schwaebische</normalizedToken>
Alb); ziemlich 
<normalizedToken id="43BD21EF0B13D5CE98F472578FCC6CDB" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
.
</paragraph>
