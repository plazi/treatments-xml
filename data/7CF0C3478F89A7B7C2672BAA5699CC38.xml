<taxonomicName id="37956D6C36E3BE04831B09A3FDCF8C74" authority="F. W. Schulz" class="Magnoliopsida" family="Ranunculaceae" genus="Aquilegia" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="33" phylum="Tracheophyta" rank="species" species="einseleana">
Aquilegia 
<normalizedToken id="264D4422DCBCB805F941502C3B064CBA" originalValue="Einseleána" pageId="null" pageNumber="33">Einseleana</normalizedToken>
F. W. Schulz
