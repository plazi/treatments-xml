<subSubSection id="3DB3A4ACBEB4D34758B5DD63705B1AAF" pageId="null" pageNumber="737" type="description">
<paragraph id="263E729FD384F3FA52C9B9D99033C2E7" pageId="null" pageNumber="737">
1 
<normalizedToken id="B154E1A94DF8B1437736A0FF63CBDAED" originalValue="jährig" pageId="null" pageNumber="737">jaehrig</normalizedToken>
. 
<emphasis id="BC47D11719E56D8E46AD5576F14E3A55" italics="true" pageId="null" pageNumber="737">Ganze Pflanze abstehend behaart. Stengel bis 3 m hoch</emphasis>
, meist verzweigt, bis 
<normalizedToken id="704B25D950DBD338FC5E417DACD2B518" originalValue="über" pageId="null" pageNumber="737">ueber</normalizedToken>
1 cm dick. 
<emphasis id="32841CBF42C26FABAFC8EF2C6F82F48B" italics="true" pageId="null" pageNumber="737">
<normalizedToken id="71FD83A46708BBD27CDD8BF92E1DC6B5" originalValue="Blätter" pageId="null" pageNumber="737">Blaetter</normalizedToken>
im 
<normalizedToken id="9E275FD17A1A8409BDBCC20AF408875C" originalValue="Umriβ" pageId="null" pageNumber="737">Umriβ</normalizedToken>
breit oval, 
<normalizedToken id="7BD23243081FF60AC093400A39A29E58" originalValue="groβ" pageId="null" pageNumber="737">groβ</normalizedToken>
, 8-20 cm lang
</emphasis>
, l,3-2mal so lang wie breit, in eine Spitze ausgezogen, am Grunde 
<normalizedToken id="21CFBCC00B36377D6B6EDE9B25A72F03" originalValue="herzförmig" pageId="null" pageNumber="737">herzfoermig</normalizedToken>
oder abgerundet; Blattstiel weniger als 
<normalizedToken id="218DE4C810A64C22EF04708BAAC0FCCC" originalValue="½" pageId="null" pageNumber="737">1/2</normalizedToken>
so lang wie die Spreite; 
<emphasis id="C37F13D98DC73ECF00BDF163BB9D394E" italics="true" pageId="null" pageNumber="737">
in der obern 
<normalizedToken id="CA153E95AA90F4A0138FF40C012D6875" originalValue="Hälfte" pageId="null" pageNumber="737">Haelfte</normalizedToken>
mit 2 
<normalizedToken id="E1818EC1CD12CE21AE6CE98397D7C783" originalValue="grünen" pageId="null" pageNumber="737">gruenen</normalizedToken>
<normalizedToken id="BDB8862C9E503E554E5215EE59C0AC05" originalValue="Flügeln" pageId="null" pageNumber="737">Fluegeln</normalizedToken>
</emphasis>
(schmale Fortsetzung der Blattspreite); Nebenblattscheiden bis 1 cm lang, dem Stengel locker anliegend, ganzrandig, behaart. 
<normalizedToken id="EB4052E41632CBD33943D08325852014" originalValue="Teilblütenstände" pageId="null" pageNumber="737">Teilbluetenstaende</normalizedToken>
2-6 
<normalizedToken id="82DBF76B598A846546BCF91662029966" originalValue="blütig" pageId="null" pageNumber="737">bluetig</normalizedToken>
, in den Achseln schuppenartiger, borstig bewimperter 
<normalizedToken id="4313DBB7DA6DC7E9E95D643BB8F6090E" originalValue="Tragblätter" pageId="null" pageNumber="737">Tragblaetter</normalizedToken>
, zu 
<normalizedToken id="0E26562A384F734FB4E35D50A3A3A9F1" originalValue="endständigen" pageId="null" pageNumber="737">endstaendigen</normalizedToken>
und oft auch 
<normalizedToken id="6E00BDEDD2A0E0FF32B243E6EDD2E450" originalValue="blattachselständigen" pageId="null" pageNumber="737">blattachselstaendigen</normalizedToken>
, gelegentlich verzweigten, 
<normalizedToken id="8B18A239DDF0E801167BB84FC4B654E7" originalValue="ährenartigen" pageId="null" pageNumber="737">aehrenartigen</normalizedToken>
<normalizedToken id="F673D48A10BAFFB5CBCDC15540A88687" originalValue="Blütenständen" pageId="null" pageNumber="737">Bluetenstaenden</normalizedToken>
vereinigt. 
<normalizedToken id="C21E0DC8AA6CF1EAE490D35499C5352D" originalValue="Perigonblätter" pageId="null" pageNumber="737">Perigonblaetter</normalizedToken>
5, rot oder 
<normalizedToken id="A6E418D7AC5011A827C1A74660C701ED" originalValue="weiß" pageId="null" pageNumber="737">weiss</normalizedToken>
, 4-5 mm lang, 
<emphasis id="6110972C9963C10DDEED5E7726BE574C" italics="true" pageId="null" pageNumber="737">
nicht 
<normalizedToken id="0177A63FF7412CEB884485E4F775DDC8" originalValue="geflügelt" pageId="null" pageNumber="737">gefluegelt</normalizedToken>
.
</emphasis>
Frucht 3-5 mm lan 
<emphasis id="AB2CE71017AD892642382A95EBAD48B6" italics="true" pageId="null" pageNumber="737">g, flach</emphasis>
, dunkelbraun bis schwarz, wenig 
<normalizedToken id="198CAB0E6771C5011D0B565FE17473B5" originalValue="glänzend" pageId="null" pageNumber="737">glaenzend</normalizedToken>
. - 
<normalizedToken id="558254079C7CA2C1FDC1FAE31A4BC151" originalValue="Blüte" pageId="null" pageNumber="737">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="34434713A2985A64E55086BA17DC6BAE" pageId="null" pageNumber="737">
<emphasis id="94CF2C7C131173603E091F259169003E" italics="true" pageId="null" pageNumber="737">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D4FA992959214D884893BEACC54D8FDE" italics="true" pageId="null" pageNumber="737">22:</emphasis>
Ohne Herkunftsangabe des Materials (Jaretzky 1928), aus Japan (Doida 1960Doida 1962). 
<emphasis id="A1D5A80E620AE5A6E0F84785BB2234EE" italics="true" pageId="null" pageNumber="737">2n</emphasis>
= 
<emphasis id="1AB47CA0DD21BE639B8EEEAF446F712F" italics="true" pageId="null" pageNumber="737">24:</emphasis>
Material aus Indien, Umgebung von Kalkutta (Sharma und Chatterji 1960).
</paragraph>
<paragraph id="3920214F9D437A7FA8CC4314AAEC8D77" pageId="null" pageNumber="737">
<emphasis id="937FB78DA264A17E06557A2E04C895A1" italics="true" pageId="null" pageNumber="737">Standort.</emphasis>
Kollin. Kalkarme 
<normalizedToken id="DB4078E1AF473C4E42B699EB1876C329" originalValue="Böden" pageId="null" pageNumber="737">Boeden</normalizedToken>
. Hecken, 
<normalizedToken id="EAC89AFF1483738380B68DDC92EC2968" originalValue="Schuttplätze" pageId="null" pageNumber="737">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="D27DC2FE875B1D27763033EF14613E6C" pageId="null" pageNumber="737">
<emphasis id="17A45611701F3454D9C7F32A40F56BC7" italics="true" pageId="null" pageNumber="737">
Verbreitung. 
<normalizedToken id="42F4A060191688FF12067D3F93C42AE3" originalValue="Ursprünglich" pageId="null" pageNumber="737">Urspruenglich</normalizedToken>
ostasiatische Pflanze:
</emphasis>
Seit etwa 200 Jahren in 
<taxonomicName id="F00C7CEA8C2092A8FFA5F1E42C5A50B4" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="737" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
als Zierpflanze. - Im Gebiet im 
<normalizedToken id="CA34E38EBA9434ED6C10B9412F8B14CE" originalValue="südlichen" pageId="null" pageNumber="737">suedlichen</normalizedToken>
Teil (Tessin) gelegentlich verwildert.
</paragraph>
</subSubSection>
