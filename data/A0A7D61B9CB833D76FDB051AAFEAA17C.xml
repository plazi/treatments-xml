<subSubSection id="5086E62FFD222968D8B77DFF9E88985B" pageId="null" pageNumber="214" type="description">
<paragraph id="AF726A1BCE9F5207158DFADD7AAD5D1A" pageId="null" pageNumber="214">
<emphasis id="DBCC5D946A4912A9E5FCB6B1CFCADF2D" italics="true" pageId="null" pageNumber="214">
<normalizedToken id="6C430E2C5B9D5006DD69A573C32516D5" originalValue="Blätter" pageId="null" pageNumber="214">Blaetter</normalizedToken>
<normalizedToken id="0DCA6943981A7D41FB8DC3BFB093400D" originalValue="gegenständig" pageId="null" pageNumber="214">gegenstaendig</normalizedToken>
. Kelch 5teilig oder 5 
<normalizedToken id="ACD4264417C9A4B5C724A4D8FCB39120" originalValue="zähnig" pageId="null" pageNumber="214">zaehnig</normalizedToken>
. Krone mit bauchiger 
<normalizedToken id="6B8D01559BC47560885780670D4774B8" originalValue="Röhre" pageId="null" pageNumber="214">Roehre</normalizedToken>
</emphasis>
und 21ippigem Rand; Oberlippe ausgerandet; Unterlippe 3teilig. 
<normalizedToken id="4A56F094DF3DB0C134E8EA32B1BF3085" originalValue="Staubblätter" pageId="null" pageNumber="214">Staubblaetter</normalizedToken>
4. Frucht sich mit 2 Klappen 
<normalizedToken id="EB4BA044C4C92176175EA44EAF5131C3" originalValue="öffnend" pageId="null" pageNumber="214">oeffnend</normalizedToken>
.
</paragraph>
<paragraph id="84ABEC93CECE56FA59D6CA89753F5142" pageId="null" pageNumber="214">
Die Gattung 
<taxonomicName id="E95181D35774BF3C6428EC16372040A8" class="Magnoliopsida" family="Linderniaceae" genus="Lindernia" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="214" phylum="Tracheophyta" rank="genus">
<emphasis id="89AF4644896A5B016C7386BCCC40FB1F" italics="true" pageId="null" pageNumber="214">Lindernia</emphasis>
</taxonomicName>
<normalizedToken id="72E3B2E310603642B068BD05BC82839E" originalValue="umfaßt" pageId="null" pageNumber="214">umfasst</normalizedToken>
etwa 
<emphasis id="9CEECACDD50F01F78CC30F2DD4487384" italics="true" pageId="null" pageNumber="214">30 meist tropische Arten.</emphasis>
Zytologische Untersuchungen von 22 Arten und 
<normalizedToken id="4C11F322DE1CA9020FD854E1724EDC34" originalValue="Varietäten" pageId="null" pageNumber="214">Varietaeten</normalizedToken>
von Bhattacharyya (1968). 
<emphasis id="E4DC87859C507E2FB32433FF8388C6DB" italics="true" pageId="null" pageNumber="214">Chromosomenzahlen</emphasis>
zwischen 2n = 18 und 42.
</paragraph>
