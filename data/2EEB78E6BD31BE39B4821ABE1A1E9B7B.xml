<taxonomicName id="37084292D6FE8A97A6FE6BC2D5AFCD7D" authority="L." class="Magnoliopsida" family="Plantaginaceae" genus="Veronica" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="192" phylum="Tracheophyta" rank="species" species="fruticulosa">
Veronica 
<normalizedToken id="2D2751FEF62F36992243BB0E5B90A2B7" originalValue="fruticulósa" pageId="null" pageNumber="192">fruticulosa</normalizedToken>
<authorityName id="9C9477339AF5BC8F5C2AF9F586687B27" pageId="null" pageNumber="192">L.</authorityName>
