<subSubSection id="893A2AF5E1305ADC639159CA2E49B0CF" pageId="null" pageNumber="263" type="description">
<paragraph id="B3633ED1348420F7FF39AA5362508452" pageId="null" pageNumber="263">
<normalizedToken id="F86FAC841293C2F67839E6BCA3C413F5" originalValue="Stengelblätter" pageId="null" pageNumber="263">Stengelblaetter</normalizedToken>
breit lanzettlich, 
<emphasis id="6BC62C5B4F4B33926AEFBB4AF32E9C02" italics="true" pageId="null" pageNumber="263">3</emphasis>
- 
<emphasis id="1671294B85218E2DC49800359F389E38" italics="true" pageId="null" pageNumber="263">
4mal so lang wie breit, alle nach dem Grunde 
<normalizedToken id="91F9027B3102C6572D74B0CF1CC9022E" originalValue="keilförmig" pageId="null" pageNumber="263">keilfoermig</normalizedToken>
<normalizedToken id="EF810C0A7DC7B24F3331B969A9E491E0" originalValue="verschmälert" pageId="null" pageNumber="263">verschmaelert</normalizedToken>
</emphasis>
und in diesem Teil meist ohne 
<normalizedToken id="E70BCDA1360FB4DEC43322AF67FAABF2" originalValue="Zähne" pageId="null" pageNumber="263">Zaehne</normalizedToken>
, 
<normalizedToken id="1E0C6FBE78D8A75253727787D379E57F" originalValue="wechselständig" pageId="null" pageNumber="263">wechselstaendig</normalizedToken>
; 
<emphasis id="4FBAC2D65A3148856C0320B09FBEFD7C" italics="true" pageId="null" pageNumber="263">
<normalizedToken id="44C8CDB08ED86219929AD7A407B5F410" originalValue="Zähne" pageId="null" pageNumber="263">Zaehne</normalizedToken>
spitz. 
<normalizedToken id="D36A5A9C9EB109651280407A94D85065" originalValue="Kronblätter" pageId="null" pageNumber="263">Kronblaetter</normalizedToken>
purpurrot, flach ausgebreitet. -
</emphasis>
<normalizedToken id="93D28D67DF55DDC8BAD530D5374A9FCF" originalValue="Blüte" pageId="null" pageNumber="263">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="90992631A52DEA42A02228194B45014F" pageId="null" pageNumber="263">
<emphasis id="FDAEB781AEDDDC9DAD850366D11D20D6" italics="true" pageId="null" pageNumber="263">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="EBC0C03DCBF0988430050627AE855DC3" italics="true" pageId="null" pageNumber="263">24:</emphasis>
Material von 11 Fundorten in den Karpaten (Banach-Pogan 1958), aus Russisch-Karelien (Jalas und 
<normalizedToken id="014A4C6C2502C9458DCCE62F48DEF882" originalValue="Rönkkö" pageId="null" pageNumber="263">Roenkkoe</normalizedToken>
1960).
</paragraph>
<paragraph id="7DAA79DA58E5F9300A67A89E29BA0B56" pageId="null" pageNumber="263">
<emphasis id="2DEE0009D776E1BCD03BC320A7E7C298" italics="true" pageId="null" pageNumber="263">Standort.</emphasis>
Kollin und montan. Feuchte Felsspalten, auf saurem und kalkhaltigem Gestein. Schattige Schluchten, 
<normalizedToken id="8640A509801B1BEE76D42343C094C112" originalValue="Bergwälder" pageId="null" pageNumber="263">Bergwaelder</normalizedToken>
.
</paragraph>
<paragraph id="C6205B288F3414AEE4C173DB657CDD30" pageId="null" pageNumber="263">
<emphasis id="E8C99D8452D92D03BB1236C4861B6C26" italics="true" pageId="null" pageNumber="263">Verbreitung</emphasis>
(
<normalizedToken id="267F83F8F4C73A5C6FC70F80035A2062" originalValue="ungenügend" pageId="null" pageNumber="263">ungenuegend</normalizedToken>
bekannt, da oft mit 
<emphasis id="F69BF0F9E44E2F62DBAFE96C8E4218CE" italics="true" pageId="null" pageNumber="263">S. purpureum</emphasis>
vereinigt). 
<emphasis id="D5902E4A109E920647847A9A2B951EBD" italics="true" pageId="null" pageNumber="263">
<normalizedToken id="8D4547A630CF87B1F3560284B75C3892" originalValue="Osteuropäische" pageId="null" pageNumber="263">Osteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Baltikum, Karelien, 
<normalizedToken id="617E74C4CC75ACD9AA820A2C4CD5A778" originalValue="Böhmerwald" pageId="null" pageNumber="263">Boehmerwald</normalizedToken>
, Karpaten, Balkanhalbinsel. - Im Gebiet wahrscheinlich verwilderte Gartenpflanze: Vogesen, Schwarzwald, Jura, Mittelland (Freiburg und Bern).
</paragraph>
</subSubSection>
