<taxonomicName id="42D071A81CC63113129E0AA16FBD3995" authority="Ry" class="Magnoliopsida" family="Euphorbiaceae" genus="Euphorbia" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="660" phylum="Tracheophyta" rank="species" species="loiseleurii">
