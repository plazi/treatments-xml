<taxonomicName id="62DD9777B57186C7401D30A76660A585" authority="Planchon" class="Magnoliopsida" family="Vitaceae" genus="Parthenocissus" kingdom="Plantae" order="Vitales" pageId="null" pageNumber="700" phylum="Tracheophyta" rank="genus">
