<subSubSection id="311D1F01BC716E395AED3962C87D8987" pageId="null" pageNumber="812" type="vernacular_names">
<paragraph id="48CC89B358B2CB1DA36767A42F8F27AA" pageId="null" pageNumber="812">Tenores Hornkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="07CC6CCF309CE3979D48855DBB647907" pageId="null" pageNumber="812" type="description">
<paragraph id="112F5971F250D38ECED961ADBCB8880E" pageId="null" pageNumber="812">
Unterscheidet sich von 
<taxonomicName id="E43344704BC86A8C79967A73D6374DA5" class="Magnoliopsida" family="Caryophyllaceae" genus="Cerastium" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="812" phylum="Tracheophyta" rank="species" species="brachypetalum">
<emphasis id="E9D821DD43952B1A248EAD46D70D5376" italics="true" pageId="null" pageNumber="812">C. brachypetalum</emphasis>
</taxonomicName>
(Nr. 3e) nur durch folgende Merkmale: 
<emphasis id="13BE3AB11FE62FE7AF10B385ACDF45AD" italics="true" pageId="null" pageNumber="812">Stengel</emphasis>
(
<emphasis id="5BFEE3F72C6C72074BCBE4F6CF8C3068" italics="true" pageId="null" pageNumber="812">
und 
<normalizedToken id="00E1092F4D405FA8C3FFEABBBA579D84" originalValue="Blütenstiele" pageId="null" pageNumber="812">Bluetenstiele</normalizedToken>
</emphasis>
) 
<emphasis id="0AA0CDB951DF6EFB098DC2981F3E077D" italics="true" pageId="null" pageNumber="812">mit bis 1 mm langen</emphasis>
, 
<normalizedToken id="849B636B68D05D416DDCB0DB82B61E8E" originalValue="±" pageId="null" pageNumber="812">+/-</normalizedToken>
<emphasis id="D6A716C3E99E1624CAED8558D7092D4E" italics="true" pageId="null" pageNumber="812">
anliegenden, mehrzelligen Haaren, ohne 
<normalizedToken id="D66B7B41E82BD3E18B29E64380078266" originalValue="Drüsenhaare" pageId="null" pageNumber="812">Druesenhaare</normalizedToken>
. Kelch nur mit 
<normalizedToken id="7BEB94E1A98FE4DFC3A929E9E0D4252E" originalValue="drüsenlosen" pageId="null" pageNumber="812">druesenlosen</normalizedToken>
Haaren.
</emphasis>
- 
<normalizedToken id="9FB1D5C62000A7BA8403A68936F6434C" originalValue="Blüte" pageId="null" pageNumber="812">Bluete</normalizedToken>
: 
<normalizedToken id="CC39C97F087CBAE515F345D00EFBB597" originalValue="Später" pageId="null" pageNumber="812">Spaeter</normalizedToken>
<normalizedToken id="F78F518B222F1157265A97B9104EB2E1" originalValue="Frühling" pageId="null" pageNumber="812">Fruehling</normalizedToken>
und 
<normalizedToken id="ED4868F73CD09A01B86696D7371A476C" originalValue="früher" pageId="null" pageNumber="812">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="4C387F3F886D6BEC52EBCE3FD4507025" pageId="null" pageNumber="812">
<emphasis id="3EA09CCCA665F5420F3797A9D52FC8F5" italics="true" pageId="null" pageNumber="812">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="7EAEADBB78827FAB0FE8B66FE4DE95B4" italics="true" pageId="null" pageNumber="812">52:</emphasis>
Material aus 
<normalizedToken id="CC7B81C4907178B46D96AA8BF4088D9F" originalValue="Oberösterreich" pageId="null" pageNumber="812">Oberoesterreich</normalizedToken>
und von 2 Stellen im Tessin (
<normalizedToken id="B6004A6E6F195127D651B4B59373394C" originalValue="Söllner" pageId="null" pageNumber="812">Soellner</normalizedToken>
1954).
</paragraph>
<paragraph id="7493A2E6787972A0F445AB3F580EE386" pageId="null" pageNumber="812">
<emphasis id="AEF2772C9E22BEAD2F086D632FF71595" italics="true" pageId="null" pageNumber="812">Standort.</emphasis>
Kollin. 
<normalizedToken id="21E9725E4764474D8262F903295F57C0" originalValue="Ähnlich" pageId="null" pageNumber="812">Aehnlich</normalizedToken>
wie 
<taxonomicName id="8D1CF666EBCD74A9F492E52BAD647730" class="Magnoliopsida" family="Caryophyllaceae" genus="Cerastium" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="812" phylum="Tracheophyta" rank="species" species="semidecandrum">
<emphasis id="C47E014429979844AD6349C09A3AE269" italics="true" pageId="null" pageNumber="812">C. semidecandrum</emphasis>
</taxonomicName>
(Nr. 3a).
</paragraph>
<paragraph id="727ECEC1DF120210CE92EB39F93DC605" pageId="null" pageNumber="812">
<emphasis id="E9FE7747F332081BF54FD74E46C57375" italics="true" pageId="null" pageNumber="812">
Verbreitung. 
<normalizedToken id="6288471606D315C8BBF47DEE62DC43D9" originalValue="Südeuropäische" pageId="null" pageNumber="812">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Westgrenze nicht genau bekannt, 
<normalizedToken id="1C670B3A3D54C3C2AA1DB7ED4B22994B" originalValue="nordwärts" pageId="null" pageNumber="812">nordwaerts</normalizedToken>
bis Oberrheinische Tiefebene, Alpen, Karpaten. - Im Gebiet: Oberrheinische Tiefebene (
<normalizedToken id="35941BCFA8912E1CC0CD1B44AF91D924" originalValue="südwärts" pageId="null" pageNumber="812">suedwaerts</normalizedToken>
bis Basel), Genfersee- und Neuenburgerseegebiet, unteres Misox, 
<normalizedToken id="6B997D8DA97A3A54375172D04CDC3A19" originalValue="Südtessin" pageId="null" pageNumber="812">Suedtessin</normalizedToken>
, Comerseegebiet; nicht 
<normalizedToken id="A1D70EAEC3B043290CF22DD7B89C0932" originalValue="häufig" pageId="null" pageNumber="812">haeufig</normalizedToken>
, gelegentlich auch adventiv.
</paragraph>
</subSubSection>
