<paragraph pageId="0" pageNumber="151">
<taxonomicName authority="Panzer, 1801" authorityName="Panzer" authorityYear="1801" class="Insecta" family="Tenthredinidae" genus="Dolerus" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Dolerus willoughbyi" order="Hymenoptera" pageId="0" pageNumber="151" phylum="Arthropoda" rank="species" species="willoughbyi">
