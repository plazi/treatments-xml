<quantity box="[1282,1436,1904,1931]" metricMagnitude="3" metricUnit="m" metricValue="2.475" metricValueMax="2.65" metricValueMin="2.3" pageId="5" pageNumber="158" unit="m" value="2475.0" valueMax="2650.0" valueMin="2300.0">2300–2650 m</quantity>
elevation.
</paragraph>
</subSubSection>
