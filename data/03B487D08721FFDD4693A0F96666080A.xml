<taxonomicName id="4C1D4D458721FFDE472FA75E674E0DFA" authority="Bates, 1872" authorityName="Bates" authorityYear="1872" box="[299,587,1912,1937]" class="Insecta" family="Cerambycidae" genus="Estola" kingdom="Animalia" order="Coleoptera" pageId="5" pageNumber="594" phylum="Arthropoda" rank="species" species="ignobilis">
