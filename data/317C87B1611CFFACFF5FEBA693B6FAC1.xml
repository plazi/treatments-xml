<emphasis id="8BA1EAB5611BFFACFF54E959903AFEFF" bold="true" box="[203,303,264,286]" pageId="4" pageNumber="3">Character</emphasis>
</th>
<th id="44345D99611B0057FE08E9569297FEFF" box="[407,898,263,286]" gridcol="1" gridrow="0" pageId="4" pageNumber="3">
<taxonomicName id="7ED54D24611BFFACFE08E95993ACFEFC" authority="Mondaca and Beeche" authorityName="Mondaca and Beeche" authorityYear="2022" box="[407,697,263,286]" class="Insecta" family="Cerambycidae" genus="Malcho" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="3" phylum="Arthropoda" rank="genus">
<emphasis id="8BA1EAB5611BFFACFE08E95993ACFEFC" bold="true" box="[407,697,263,286]" italics="true" pageId="4" pageNumber="3">Malcho Mondaca and Beéche</emphasis>
