<taxonomicName authority="Saravanan &amp; Kaliamoorthy" authorityName="Saravanan &amp; Kaliamoorthy" authorityYear="2022" box="[136,691,1908,1935]" class="Magnoliopsida" family="Balsaminaceae" genus="Impatiens" kingdom="Plantae" order="Ericales" pageId="0" pageNumber="107" phylum="Tracheophyta" rank="species" species="keralensis" status="sp. nov.">
<emphasis bold="true" box="[136,375,1908,1935]" italics="true" pageId="0" pageNumber="107">Impatiens keralensis</emphasis>
Saravanan &amp; Kaliamoorthy
</taxonomicName>
, 
<emphasis box="[702,787,1909,1934]" italics="true" pageId="0" pageNumber="107">
<taxonomicNameLabel box="[702,787,1909,1934]" pageId="0" pageNumber="107" rank="species">sp. nov.</taxonomicNameLabel>
