<subSubSection id="94EA14DC0D8CC52CC1D534490404853A" pageId="null" pageNumber="217" type="description">
<paragraph id="54D942A52F9B5A922D49558DB7771EF9" pageId="null" pageNumber="217">
2 
<normalizedToken id="C5C09B4D7C362D749826464ABB65091C" originalValue="jährig" pageId="null" pageNumber="217">jaehrig</normalizedToken>
, mit 
<normalizedToken id="625237FF284F07A4B8C93CEEC3DD9BA4" originalValue="dünner" pageId="null" pageNumber="217">duenner</normalizedToken>
Pfahlwurzel; 10-80 cm hoch. Stengel aufrecht, einfach oder verzweigt, kahl. 
<normalizedToken id="7B69FB56094D566528B28A321AEB0058" originalValue="Grundständige" pageId="null" pageNumber="217">Grundstaendige</normalizedToken>
<normalizedToken id="EAD34F5EFE627745B5177919448A1977" originalValue="Blätter" pageId="null" pageNumber="217">Blaetter</normalizedToken>
in einer Rosette, gestielt, jederseits mit 3-10 ovalen Abschnitten, 
<emphasis id="3C0D82789A7CEA51CDC7722F39DBD6CF" italics="true" pageId="null" pageNumber="217">am Blattstielrand mit einzelnen ca. 0,5 mm langen Haaren.</emphasis>
Untere 
<normalizedToken id="9580498252815BC31DA3AC9DC0FF9C8E" originalValue="Stengelblätter" pageId="null" pageNumber="217">Stengelblaetter</normalizedToken>
am Grunde mit 2 Zipfeln 
<pageBreakToken id="983C97E070C6CBB4B742C5C4F824B751" pageId="null" pageNumber="217">Abschnitten</pageBreakToken>
; auch die obersten sitzenden 
<normalizedToken id="7F51B048740BB665477F2E65A3ADF953" originalValue="Stengelblätter" pageId="null" pageNumber="217">Stengelblaetter</normalizedToken>
bis 
<normalizedToken id="033C0B7B4D7104326F057A9E307F84C3" originalValue="über" pageId="null" pageNumber="217">ueber</normalizedToken>
die Mitte fiederteilig. 
<emphasis id="E8FE74422620B448BB174834A4DD779C" italics="true" pageId="null" pageNumber="217">
<normalizedToken id="AFDB825FF293A997B52C9CFCEB5DA587" originalValue="Kelchblätter" pageId="null" pageNumber="217">Kelchblaetter</normalizedToken>
3,5
</emphasis>
- 
<emphasis id="83E570401ED7BDBF281D554BFCE4CC9E" italics="true" pageId="null" pageNumber="217">4,5 mm lang, kahl</emphasis>
, die beiden 
<normalizedToken id="76AD21A90C2041D508F378CD6FACBA28" originalValue="äußern" pageId="null" pageNumber="217">aeussern</normalizedToken>
an der Spitze mit je einem ca. 0,3 mm langen hornartigen Fortsatz. 
<emphasis id="02E613B1ED7D613F68A51230DABCA493" italics="true" pageId="null" pageNumber="217">
<normalizedToken id="0ABDD8ADCE9D6F15734774684E70984C" originalValue="Kronblätter" pageId="null" pageNumber="217">Kronblaetter</normalizedToken>
6
</emphasis>
- 
<emphasis id="D42FB4F434E902C0C878AE9CDBDD3536" italics="true" pageId="null" pageNumber="217">8 mm lang</emphasis>
, gelb. 
<emphasis id="01B6EB9AD85DECBA681A4DE8C63322E8" italics="true" pageId="null" pageNumber="217">Fruchtstiele</emphasis>
1/9-1/12 
<emphasis id="28FC4C8366E978B0059B7289827A91F1" italics="true" pageId="null" pageNumber="217">
so lang und nur wenig 
<normalizedToken id="747F9F7822522674D35EAC2E1B3FD8B9" originalValue="dünner" pageId="null" pageNumber="217">duenner</normalizedToken>
als die 
<normalizedToken id="B04D9A0B6DBFFF64BF080768E70ABADD" originalValue="Früchte" pageId="null" pageNumber="217">Fruechte</normalizedToken>
. 
<normalizedToken id="3D48288D0D7DF255A6BD348BC1BB31FF" originalValue="Früchte" pageId="null" pageNumber="217">Fruechte</normalizedToken>
40
</emphasis>
- 
<emphasis id="A991F45AF0AF2C0D469EB67622269F7D" italics="true" pageId="null" pageNumber="217">70 mm lang</emphasis>
, 1,4-2 mm dick. Griffel an der Frucht 1-1,8 mm lang. - 
<normalizedToken id="18103C28D9DF36E67D009607768C267F" originalValue="Blüte" pageId="null" pageNumber="217">Bluete</normalizedToken>
: 
<normalizedToken id="3440454420ACC82E0B412D3C2BBE8E45" originalValue="Später" pageId="null" pageNumber="217">Spaeter</normalizedToken>
<normalizedToken id="2A9CE6CC1413864428293B4EA41774C6" originalValue="Frühling" pageId="null" pageNumber="217">Fruehling</normalizedToken>
und 
<normalizedToken id="0170F25B3A0BBEA21033992D2C9CC9DD" originalValue="früher" pageId="null" pageNumber="217">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="B8DE87C0C66AF7403F469445AFD283B4" pageId="null" pageNumber="217">
<emphasis id="CC57B39828558313269D2B697F433D2A" italics="true" pageId="null" pageNumber="217">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0ADC13097AA8C58000F628400DA4F748" italics="true" pageId="null" pageNumber="217">16:</emphasis>
Material aus botanischem Garten (Manton 1932).
</paragraph>
<paragraph id="3EC898DCF9269D0ADE4B55A7DD1B8723" pageId="null" pageNumber="217">
<emphasis id="C8FBFABD594D81A91F9FE1D7362351AE" italics="true" pageId="null" pageNumber="217">Standort.</emphasis>
Kollin und montan. Ziemlich feuchte, 
<normalizedToken id="269BBF5F0B263F7162A5514074F7D75C" originalValue="nährstoffreiche" pageId="null" pageNumber="217">naehrstoffreiche</normalizedToken>
, steinige 
<normalizedToken id="53CD60C5F376DA8B4C5B456CDC9E3996" originalValue="Böden" pageId="null" pageNumber="217">Boeden</normalizedToken>
in 
<normalizedToken id="211577FE261015A3B8CDC160E7E75463" originalValue="wärmeren" pageId="null" pageNumber="217">waermeren</normalizedToken>
Lagen. Schuttstellen, 
<normalizedToken id="DC4971FB844F484D9599834601FE3ECD" originalValue="Wegränder" pageId="null" pageNumber="217">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="2138DF6DE8D2AEFF13FE8158696604D6" pageId="null" pageNumber="217">
<emphasis id="417A0BB1B71E22A6EE72965BC17D3616" italics="true" pageId="null" pageNumber="217">Verbreitung.</emphasis>
<normalizedToken id="760D29513ABB31FA351BF01A7FDA7444" originalValue="Ursprünglich" pageId="null" pageNumber="217">Urspruenglich</normalizedToken>
<emphasis id="F8A50C973EDDEB0E73ADE0B9F42B8550" italics="true" pageId="null" pageNumber="217">
<normalizedToken id="35E51F37ACC73FBE0A6F49CF22628CCE" originalValue="südwesteuropäische" pageId="null" pageNumber="217">suedwesteuropaeische</normalizedToken>
Pflanze
</emphasis>
, 
<normalizedToken id="84DDF20DCC6AD4014382F694084FF8D5" originalValue="früher" pageId="null" pageNumber="217">frueher</normalizedToken>
als 
<normalizedToken id="33869478F7F3314204A4E09F31035E90" originalValue="Ölpflanze" pageId="null" pageNumber="217">Oelpflanze</normalizedToken>
angebaut und deshalb mancherorts verschleppt. - Im Gebiet nicht 
<normalizedToken id="4311A2CF3049CE38FD0588F9A995FB28" originalValue="ursprünglich" pageId="null" pageNumber="217">urspruenglich</normalizedToken>
, besonders im westlichen Teil gelegentlich verwildert.
</paragraph>
</subSubSection>
