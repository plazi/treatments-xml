<emphasis id="B914B41EFFC3FFAEFE5A1EEFFDD4F91A" box="[421,588,1744,1769]" italics="true" pageId="1" pageNumber="22">Microrchestia</emphasis>
</taxonomicName>
includes 4 species: 
<taxonomicName id="4C60138FFFC3FFAEFCBF1EEFFC47F91A" authority="Lowry &amp; Peart, 2010" authorityName="Lowry &amp; Peart" authorityYear="2010" box="[832,991,1744,1769]" class="Malacostraca" family="Protorchestiidae" genus="Microrchestia" kingdom="Animalia" order="Amphipoda" pageId="1" pageNumber="22" phylum="Arthropoda" rank="species" species="bousfieldi" status="sp. nov.">
<emphasis id="B914B41EFFC3FFAEFCBF1EEFFC47F91A" box="[832,991,1744,1769]" italics="true" pageId="1" pageNumber="22">M. bousfieldi</emphasis>
</taxonomicName>
