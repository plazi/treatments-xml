<subSubSection id="C3776556ED5B383FFF4DF98FFE9FF99D" box="[136,346,1601,1628]" pageId="522" pageNumber="523" type="nomenclature">
<paragraph id="8BD236DDED5B383FFF4DF98FFE9FF99D" blockId="522.[136,346,1601,1628]" box="[136,346,1601,1628]" pageId="522" pageNumber="523">
<heading id="D09A81B1ED5B383FFF4DF98FFE9FF99D" bold="true" box="[136,346,1601,1628]" fontSize="11" level="1" pageId="522" pageNumber="523" reason="1">
<emphasis id="B919EACFED5B383FFF4DF98FFE9FF99D" bold="true" box="[136,346,1601,1628]" pageId="522" pageNumber="523">
<taxonomicName id="4C6D4D5EED5B383FFF4DF98FFF20F99A" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[136,229,1601,1627]" class="Maxillopoda" family="Notodelphyidae" genus="Borixys" kingdom="Animalia" order="Cyclopoida" pageId="522" pageNumber="523" phylum="Arthropoda" rank="genus" status="gen. nov.">
<emphasis id="B919EACFED5B383FFF4DF98FFF20F99A" bold="true" box="[136,229,1601,1627]" italics="true" pageId="522" pageNumber="523">Borixys</emphasis>
