<subSubSection id="C30644A7FFB81B52F6BCFDBD9C47D70C" pageId="4" pageNumber="309" type="diagnosis">
<paragraph id="8BA3172CFFB81B52F6BCFDBD9C47D70C" blockId="4.[151,1436,487,586]" pageId="4" pageNumber="309">
<emphasis id="B968CB3EFFB81B52F6BCFDBD9E09D763" bold="true" box="[199,322,523,549]" pageId="4" pageNumber="309">Diagnosis.</emphasis>
Head triangular in lateral view (
<figureCitation id="13270BA9FFB81B52F4CAFDBD9C44D760" box="[689,783,523,550]" captionStart="FIGURE 2" captionStartId="5.[151,250,1804,1828]" captionTargetBox="[151,1436,181,1780]" captionTargetId="figure-21@5.[151,1436,181,1780]" captionTargetPageId="5" captionText="FIGURE 2. Ampulicomorpha thauma Rasnitsyn &amp; Matveev, 1989, female from Iran (MOLC). A. Body, lateral view; B. Fore wing; C–E. Head; C. Ventro-frontal view; D. Lateral view; E. Dorsal view; F, I. Mesosoma; F. Dorsal view; I. Lateral view; G. Metapectal-propodeal complex, dorsal view; H, J. Metasoma; H. Dorsal view; J. Lateral view; K. Antennae." figureDoi="http://doi.org/10.5281/zenodo.6559817" httpUri="https://zenodo.org/record/6559817/files/figure.png" pageId="4" pageNumber="309">Figs 2D</figureCitation>
, 
<figureCitation id="13270BA9FFB81B52F567FDBA9C0BD760" box="[796,832,524,550]" captionStart="FIGURE 3" captionStartId="7.[151,250,1804,1828]" captionTargetBox="[151,1436,184,1780]" captionTargetId="figure-21@7.[151,1436,181,1780]" captionTargetPageId="7" captionText="FIGURE 3. Embolemus ruddii Westwood, 1833, holotype, male from United Kingdom, (OUMNH). A. Body, dorsal view; B. Fore wing; C–E. Head; C. Frontal view; D. Lateral view; E. Dorsal view; F, I. Mesosoma; F. Dorsal view; I. Lateral view; G. Metapectal-propodeal complex, dorsal view; H, J. Metasoma; H. Dorsal view; J. Lateral view; K. Holotype labels." figureDoi="http://doi.org/10.5281/zenodo.6559821" httpUri="https://zenodo.org/record/6559821/files/figure.png" pageId="4" pageNumber="309">3D</figureCitation>
, 
<figureCitation id="13270BA9FFB81B52F537FDBA9C38D760" box="[844,883,524,550]" captionStart="FIGURE 4" captionStartId="9.[151,250,1772,1796]" captionTargetBox="[151,1436,181,1748]" captionTargetId="figure-21@9.[151,1436,181,1748]" captionTargetPageId="9" captionText="FIGURE 4. Embolemus harteni Olmi, 1997, male from Yemen, (MOLC). A. Body, dorsal view; B. Fore wing; C–E. Head; C. Frontal view; D. Lateral view; E. Dorsal view; F, I, K. Mesosoma; F. Dorsal view; I. Lateral view; K. Ventral view; G. Metapectal-propodeal complex, dorsal view; H, J. Metasoma; H. Dorsal view; J. Lateral view." figureDoi="http://doi.org/10.5281/zenodo.6559823" httpUri="https://zenodo.org/record/6559823/files/figure.png" pageId="4" pageNumber="309">4D</figureCitation>
); antenna projecting from two frontal contiguous prominences remote from mouth (
<figureCitation id="13270BA9FFB81B52F46DFD999DE8D70C" box="[534,675,559,586]" captionStart="FIGURE 2" captionStartId="5.[151,250,1804,1828]" captionTargetBox="[151,1436,181,1780]" captionTargetId="figure-21@5.[151,1436,181,1780]" captionTargetPageId="5" captionText="FIGURE 2. Ampulicomorpha thauma Rasnitsyn &amp; Matveev, 1989, female from Iran (MOLC). A. Body, lateral view; B. Fore wing; C–E. Head; C. Ventro-frontal view; D. Lateral view; E. Dorsal view; F, I. Mesosoma; F. Dorsal view; I. Lateral view; G. Metapectal-propodeal complex, dorsal view; H, J. Metasoma; H. Dorsal view; J. Lateral view; K. Antennae." figureDoi="http://doi.org/10.5281/zenodo.6559817" httpUri="https://zenodo.org/record/6559817/files/figure.png" pageId="4" pageNumber="309">Figs 2D, 2K</figureCitation>
, 
<figureCitation id="13270BA9FFB81B52F4D4FD869D9BD70C" box="[687,720,560,586]" captionStart="FIGURE 3" captionStartId="7.[151,250,1804,1828]" captionTargetBox="[151,1436,184,1780]" captionTargetId="figure-21@7.[151,1436,181,1780]" captionTargetPageId="7" captionText="FIGURE 3. Embolemus ruddii Westwood, 1833, holotype, male from United Kingdom, (OUMNH). A. Body, dorsal view; B. Fore wing; C–E. Head; C. Frontal view; D. Lateral view; E. Dorsal view; F, I. Mesosoma; F. Dorsal view; I. Lateral view; G. Metapectal-propodeal complex, dorsal view; H, J. Metasoma; H. Dorsal view; J. Lateral view; K. Holotype labels." figureDoi="http://doi.org/10.5281/zenodo.6559821" httpUri="https://zenodo.org/record/6559821/files/figure.png" pageId="4" pageNumber="309">3E</figureCitation>
, 
<figureCitation id="13270BA9FFB81B52F4A7FD869C4BD70C" box="[732,768,560,586]" captionStart="FIGURE 4" captionStartId="9.[151,250,1772,1796]" captionTargetBox="[151,1436,181,1748]" captionTargetId="figure-21@9.[151,1436,181,1748]" captionTargetPageId="9" captionText="FIGURE 4. Embolemus harteni Olmi, 1997, male from Yemen, (MOLC). A. Body, dorsal view; B. Fore wing; C–E. Head; C. Frontal view; D. Lateral view; E. Dorsal view; F, I, K. Mesosoma; F. Dorsal view; I. Lateral view; K. Ventral view; G. Metapectal-propodeal complex, dorsal view; H, J. Metasoma; H. Dorsal view; J. Lateral view." figureDoi="http://doi.org/10.5281/zenodo.6559823" httpUri="https://zenodo.org/record/6559823/files/figure.png" pageId="4" pageNumber="309">4E</figureCitation>
