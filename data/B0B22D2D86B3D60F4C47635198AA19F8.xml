<subSubSection id="6DABFD35CFDD6C33C6B6E09BD0E9620C" pageId="null" pageNumber="243" type="nomenclature">
<paragraph id="28A90017635D56E7EFFF121E19A4C380" pageId="null" pageNumber="243">
<taxonomicName id="08DC561421A525B059FDD16B6D45EE48" authority="P. B." class="Insecta" family="Ichneumonidae" genus="Hoplismenus" kingdom="Animalia" order="Hymenoptera" pageId="null" pageNumber="243" phylum="Arthropoda" rank="genus">
