<taxonomicName id="4C304D15FFEF762030E5FA0DB97755DA" authority="(Linnaeus, 1758)" baseAuthorityName="Linnaeus" baseAuthorityYear="1758" box="[174,603,1431,1458]" class="Insecta" family="Cleridae" genus="Trichodes" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="20" phylum="Arthropoda" rank="species" species="apiarius">
<emphasis id="B944EA84FFEF762030E5FA0DBABC55D9" bold="true" box="[174,400,1431,1458]" italics="true" pageId="9" pageNumber="20">Trichodes apiarius</emphasis>
