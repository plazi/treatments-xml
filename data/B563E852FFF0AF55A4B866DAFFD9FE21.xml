</paragraph>
<paragraph id="3D755944FFF7AF55A48D6258FFD9FE21" blockId="4.[136,1452,158,509]" pageId="4" pageNumber="236">
<taxonomicName id="FACA22C7FFF7AF55A48D6258FE2AFE4D" box="[189,605,374,400]" class="Dothideomycetes" family="Pseudoberkleasmiaceae" genus="Pseudoberkleasmium" kingdom="Fungi" order="Pleosporales" pageId="4" pageNumber="236" phylum="Ascomycota" rank="species" species="chiangmaiense">
