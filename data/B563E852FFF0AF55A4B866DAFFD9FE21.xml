<taxonomicName id="FACA22C7FFF7AF55A6CB627DFFC8FEB1" box="[763,959,338,364]" class="Dothideomycetes" family="Pseudoberkleasmiaceae" genus="Pseudoberkleasmium" kingdom="Fungi" order="Pleosporales" pageId="4" pageNumber="236" phylum="Ascomycota" rank="species" species="chiangmaiense">
