<paragraph id="2C00AFAC0B83B1A8B70057A8F52B30EF" pageId="0" pageNumber="19">Type species.</paragraph>
<paragraph id="E91EEEEA05C747575F697447E55924AF" pageId="0" pageNumber="19">
<taxonomicName id="AAA8DDF7DCB93733355479A35265D915" authorityName="Li, Biffi, Kundrata &amp; Cai" authorityYear="2022" class="Insecta" family="Cantharidae" genus="Nothotytthonyx" kingdom="Animalia" lsidName="Nothotytthonyx serratus" order="Coleoptera" pageId="0" pageNumber="19" rank="species" species="serratus">
<emphasis id="8A97673943DAB1F199B40C5C35868D9D" italics="true" pageId="0" pageNumber="19">Nothotytthonyx serratus</emphasis>
</taxonomicName>
