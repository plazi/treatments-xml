<subSubSection id="FF6CEB7C43D31378F7920769ACE43076" pageId="null" pageNumber="110" type="description">
<paragraph id="6AD723F3FDB0EACDB796642C2F276A55" pageId="null" pageNumber="110">
1 
<normalizedToken id="D00C06A408F6A595B402DD227B0A42C1" originalValue="jährig" pageId="null" pageNumber="110">jaehrig</normalizedToken>
; 15-45 cm hoch; aromatisch riechend. Stengel verzweigt, aufrecht, fast kahl. 
<normalizedToken id="2B7CA343B7AE2A077986850209268FB0" originalValue="Blätter" pageId="null" pageNumber="110">Blaetter</normalizedToken>
gestielt, oval bis lanzettlich, 3-5 cm lang und 2-3 cm breit, ganzrandig, oder 
<normalizedToken id="18F9038CE4E73FEF1854B54A658263D0" originalValue="gezähnt" pageId="null" pageNumber="110">gezaehnt</normalizedToken>
, 
<normalizedToken id="E88B505B0000EA24F49E1AD0F33CD9B2" originalValue="±" pageId="null" pageNumber="110">+/-</normalizedToken>
kahl. 
<normalizedToken id="D7C87C5EE4DA76C8B5919FC9414CBE49" originalValue="Blüten" pageId="null" pageNumber="110">Blueten</normalizedToken>
kurz gestielt, in meist 6 
<normalizedToken id="F55619BBF7A2EF8B48EE8CDBD8C1E526" originalValue="blütigen" pageId="null" pageNumber="110">bluetigen</normalizedToken>
, am Ende der Zweige locker 
<normalizedToken id="7F708A5B5845C750B0F328F35E0F28E0" originalValue="ährenähnlich" pageId="null" pageNumber="110">aehrenaehnlich</normalizedToken>
<normalizedToken id="01B04CA4C6AE1EFDB93C95D7B8461A9F" originalValue="übereinanderstehenden" pageId="null" pageNumber="110">uebereinanderstehenden</normalizedToken>
, 
<normalizedToken id="1179C0E3FE61BF58BEBDA5D1B2522BB9" originalValue="quirlähnlichen" pageId="null" pageNumber="110">quirlaehnlichen</normalizedToken>
<normalizedToken id="4BB065AAE511F2296E14ECD93394ACD5" originalValue="Teilblütenständen" pageId="null" pageNumber="110">Teilbluetenstaenden</normalizedToken>
. Kelch 5-7 mm lang, zerstreut behaart. Krone 1-1,5 cm lang, 
<normalizedToken id="21A633DBE54BB910BABF5E0DBE805607" originalValue="rötlich" pageId="null" pageNumber="110">roetlich</normalizedToken>
oder gelblich. 
<normalizedToken id="1671753233507CC659065C7A5CFD2BCB" originalValue="Teilfrüchte" pageId="null" pageNumber="110">Teilfruechte</normalizedToken>
etwa 2 mm lang, fast glatt. - 
<normalizedToken id="49032A7B87B233BAB395447783C77CEF" originalValue="Blüte" pageId="null" pageNumber="110">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="8AC2D8D0105F2B31AD211910BF0465B2" pageId="null" pageNumber="110">
<emphasis id="CD775F81F61A12707D972F432BCABCB5" italics="true" pageId="null" pageNumber="110">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="66CD4A8BD994A38DA19E671ADB588E94" italics="true" pageId="null" pageNumber="110">48:</emphasis>
Material aus botanischem Garten (Vaarama 1947), aus Westafrika (Morton 1962).
</paragraph>
<paragraph id="82C1EFC218B449E5227EC0D63E245524" pageId="null" pageNumber="110">
<emphasis id="21AF870481A5726973B6E2BF9E21E7C5" italics="true" pageId="null" pageNumber="110">Standort.</emphasis>
Kollin und montan. Lockere 
<normalizedToken id="29EC582756CBC62BC2BB724480C2BA40" originalValue="Böden" pageId="null" pageNumber="110">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="68070B7D2BBC6BEBDCC0F98382A76014" originalValue="Schuttplätze" pageId="null" pageNumber="110">Schuttplaetze</normalizedToken>
, Brachland.
</paragraph>
<paragraph id="D434240730C49183BD83706EE00D723C" pageId="null" pageNumber="110">
<emphasis id="1672ACCFF7A9EA7D716D67116645E5C1" italics="true" pageId="null" pageNumber="110">Verbreitung.</emphasis>
<normalizedToken id="0E652CEC99AF852934903CC2FBF099B0" originalValue="Ursprünglich" pageId="null" pageNumber="110">Urspruenglich</normalizedToken>
<emphasis id="170908376C1453FD9F4AC63046B4633A" italics="true" pageId="null" pageNumber="110">
<normalizedToken id="D9A88CB21D730D26409742A336A7271A" originalValue="südasiatische" pageId="null" pageNumber="110">suedasiatische</normalizedToken>
Pflanze;
</emphasis>
heute fast 
<normalizedToken id="C6C30F132BDB8E763D6886DD68AC9F94" originalValue="überall" pageId="null" pageNumber="110">ueberall</normalizedToken>
als Heil- und 
<normalizedToken id="B6C7A3172086C82F6B6ED273626E4697" originalValue="Gewürzpflanze" pageId="null" pageNumber="110">Gewuerzpflanze</normalizedToken>
kultiviert. - Im Gebiet gelegentlich kultiviert und selten verwildert.
</paragraph>
</subSubSection>
