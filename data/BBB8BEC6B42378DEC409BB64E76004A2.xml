<subSubSection id="0D821F897CE806E1C74137F211D471F2" pageId="null" pageNumber="590" type="nomenclature">
<paragraph id="47C47537E4AE87627D17AF4BEF81F018" pageId="null" pageNumber="590">
<taxonomicName id="BDEE12735727FA735198B8E8048C0929" authority="(Gouan) L." class="Magnoliopsida" family="Asteraceae" genus="Scorzonera" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="hirsuta">
Scorzonera 
<normalizedToken id="3C936FEFB54F8AA1EF805DB3BB1A7494" originalValue="hirsúta" pageId="null" pageNumber="590">hirsuta</normalizedToken>
(Gouan) 
<authorityName id="EFBA80FA328353B11BBCB73D8805DFA0" pageId="null" pageNumber="590">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="6443B368D8A07505C5A41584DD28A18A" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="BDAB444730C81D9521A44B1F8DB0B456" pageId="null" pageNumber="590">Rauhhaarige Schwarzwurzel</paragraph>
</subSubSection>
</title>
<subSubSection id="00197C060BB109EB82D7FA8014E44003" pageId="null" pageNumber="590" type="description">
<paragraph id="A1DA56FB09C6C8DDEF629559E95965E4" pageId="null" pageNumber="590">
Ausdauernd; 10-40 cm hoch; am Grunde mit einzelnen schwarzen Schuppen, ohne Fasern 
<normalizedToken id="12BE195290963FEA5A961D5EA7A22233" originalValue="vorjähriger" pageId="null" pageNumber="590">vorjaehriger</normalizedToken>
<normalizedToken id="8AF54FE45038547A072A9BE968D80A34" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
, aber 
<emphasis id="3E5EC97E58BC5366D307B4490A906574" italics="true" pageId="null" pageNumber="590">
mit dichten 
<normalizedToken id="0472268D04C2AC84158AAAAE8721A0FB" originalValue="Haarbüscheln" pageId="null" pageNumber="590">Haarbuescheln</normalizedToken>
; Haare bis 10 mm lang, braun
</emphasis>
(im Gebiet nur bei dieser Art so!). 
<emphasis id="A032B747ABCFDC21482AB808BE4A6382" italics="true" pageId="null" pageNumber="590">
Stengel in der untern 
<normalizedToken id="16BF82B52403E8A8E8DD8945379F99F9" originalValue="Hälfte" pageId="null" pageNumber="590">Haelfte</normalizedToken>
dicht 
<normalizedToken id="EE8C7B419837AED1E4C556C87945ABFB" originalValue="beblättert" pageId="null" pageNumber="590">beblaettert</normalizedToken>
und braun behaart
</emphasis>
(im Gebiet nur bei dieser Art so!). 
<emphasis id="C45617AB1CBA532960E8170286EBA7F8" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="5E43C183BA2693C1E600ED88FE099F26" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
grasartig, behaart; Haare 1
</emphasis>
- 
<emphasis id="48D7CC8E5B04615BCBB21E110DCD9997" italics="true" pageId="null" pageNumber="590">2 mm lang</emphasis>
(im Gebiet nur bei dieser Art so!). 
<normalizedToken id="14AAF4B626401B6A3EB2792F3A4482F8" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
zur 
<normalizedToken id="7F08B26C55A306A464936EBB739E30D2" originalValue="Blütezeit" pageId="null" pageNumber="590">Bluetezeit</normalizedToken>
1-1,5 cm lang, zur Fruchtzeit ca. 2 cm lang. 
<normalizedToken id="2AE50F8E84CD1A1BEF69B03D8BAE2B61" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
auf der Innenseite kahl; die 
<normalizedToken id="12CF094ECA660B02EA6993CD7CF1324F" originalValue="äußern" pageId="null" pageNumber="590">aeussern</normalizedToken>
<normalizedToken id="87C5F59FAA8993A0A822362B47C28EE2" originalValue="höchstens" pageId="null" pageNumber="590">hoechstens</normalizedToken>
halb so lang wie die innern. Kronen 1,2-2,5 cm lang, hellgelb. 
<normalizedToken id="6423D520169B4E158214B12363972577" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
5-7 mm lang, 
<emphasis id="1509F49C3C051FED88B29963E34CE059" italics="true" pageId="null" pageNumber="590">dicht und braun behaart</emphasis>
(im Gebiet nur bei dieser Art so!). 
<emphasis id="3FE7C382D89A1FAB5A155D5C74F77E43" italics="true" pageId="null" pageNumber="590">
<taxonomicName id="151B4EFA289411CA14EB0CE656C50721" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
<normalizedToken id="D3C66379476416D4C46E87AA33BB29E0" originalValue="rötlichbraun" pageId="null" pageNumber="590">roetlichbraun</normalizedToken>
, 2
</emphasis>
- 
<emphasis id="9E43F0F109DAE890B16C0E929C8E8E69" italics="true" pageId="null" pageNumber="590">3mal so lang wie die Frucht;</emphasis>
Pappusborsten ungleich lang. - 
<normalizedToken id="81F6F007ED521075BBAABACA79CAB707" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: 
<normalizedToken id="8044B0E9B4E6D5D43E2C6B0865F864DA" originalValue="Später" pageId="null" pageNumber="590">Spaeter</normalizedToken>
<normalizedToken id="79FB2EA8B2DF3E6508274E23579C9322" originalValue="Frühling" pageId="null" pageNumber="590">Fruehling</normalizedToken>
und 
<normalizedToken id="1979BC4289DE602FA3B55040641A0575" originalValue="früher" pageId="null" pageNumber="590">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="3B5422AC667B70057A855606ADE41532" pageId="null" pageNumber="590">
<emphasis id="E05C118C4F486BF368165FB7C18AE2C3" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="672496812E82FD68F054640FBE884F7D" italics="true" pageId="null" pageNumber="590">12 und 14:</emphasis>
Material aus Frankreich (Pointe du Chay) (Delay 1968a).
</paragraph>
<paragraph id="A6882917A5DF32F6A086F147A9E02D3B" pageId="null" pageNumber="590">
<emphasis id="85C7BBD39236FDF417F468AE31F0E0F5" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Kollin. Steinige, trockene Orte.
</paragraph>
<paragraph id="DA2B2CEB61FEF457D4BAF79FFC094DF6" pageId="null" pageNumber="590">
<emphasis id="A563639C06D8B38E28A246D64DAB3F72" italics="true" pageId="null" pageNumber="590">
Verbreitung. 
<normalizedToken id="4AF0612C57A36546A8F83764847DAEA3" originalValue="Südwesteuropäische" pageId="null" pageNumber="590">Suedwesteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Nordspanien, 
<normalizedToken id="F6678F122DD3534603C3EAC9596133A6" originalValue="Südfrankreich" pageId="null" pageNumber="590">Suedfrankreich</normalizedToken>
, Italien (
<normalizedToken id="37569DD266012BDB63CEC1EF5C37A7C1" originalValue="südwärts" pageId="null" pageNumber="590">suedwaerts</normalizedToken>
bis Sizilien). - Im Gebiet: 
<normalizedToken id="CB045A7930F79489745EF50E6F257FD5" originalValue="Dép" pageId="null" pageNumber="590">Dep</normalizedToken>
. Ain.
</paragraph>
</subSubSection>
