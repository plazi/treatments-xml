<subSubSection id="E58D0E5AB2AF8A389E2322754C701EA7" pageId="null" pageNumber="686" type="description">
<paragraph id="2757E7D6BC0219DA087A1E2A0BE02A04" pageId="null" pageNumber="686">
Selten 
<normalizedToken id="82AE72ABF1438D98C2151BAB712C3DFA" originalValue="über" pageId="null" pageNumber="686">ueber</normalizedToken>
5 m hoch. 
<normalizedToken id="F1D092903ABB1B4AAE37A72A2BEFACEF" originalValue="Blätter" pageId="null" pageNumber="686">Blaetter</normalizedToken>
meist weniger als 7 cm breit, breiter als lang, 
<emphasis id="3D6AC6B3983140355FB75BF8D2848CAE" italics="true" pageId="null" pageNumber="686">bis auf etwa</emphasis>
<normalizedToken id="CB00FFAA1CF4112C4D688599F5159C21" originalValue="½" pageId="null" pageNumber="686">1/2</normalizedToken>
<emphasis id="A776301D17B0B3AAE387BC1DECD02456" italics="true" pageId="null" pageNumber="686">
in 3 fast gleich 
<normalizedToken id="F37BF8E41706F66FCCE00487EDD48032" originalValue="große" pageId="null" pageNumber="686">grosse</normalizedToken>
und stets ganzrandige, stumpfe Abschnitte mit weiten Ausschnitten geteilt
</emphasis>
(keine sterilen Triebe sammeln!), oberseits 
<normalizedToken id="EB26835DE1239C36D55494485BB216D5" originalValue="dunkelgrün" pageId="null" pageNumber="686">dunkelgruen</normalizedToken>
und 
<normalizedToken id="FD1B573141CFCF9176E574FFC1967C95" originalValue="glänzend" pageId="null" pageNumber="686">glaenzend</normalizedToken>
, unterseits 
<normalizedToken id="C8DFBADBC7B0630F7976EC1818801F05" originalValue="graugrün" pageId="null" pageNumber="686">graugruen</normalizedToken>
, matt, zuerst 
<normalizedToken id="6753F8A626B5F51B0CE7B7F837195881" originalValue="überall" pageId="null" pageNumber="686">ueberall</normalizedToken>
behaart, 
<normalizedToken id="1378B3ECFAEFCB4E6C38EAC060000820" originalValue="später" pageId="null" pageNumber="686">spaeter</normalizedToken>
kahl; Blattstiel 
<normalizedToken id="24E554D014403D2667DE68EDE4B8D31B" originalValue="kürzer" pageId="null" pageNumber="686">kuerzer</normalizedToken>
bis 
<normalizedToken id="509972C048AED24C2C74D84EBC7604F0" originalValue="länger" pageId="null" pageNumber="686">laenger</normalizedToken>
als das Blatt. 
<normalizedToken id="501B106F0843CCE43A681A18BF859BE9" originalValue="Blüten" pageId="null" pageNumber="686">Blueten</normalizedToken>
in abstehenden, doldenartigen, 
<normalizedToken id="62046E2892C2B491CA684118F1046FC1" originalValue="wenigblütigen" pageId="null" pageNumber="686">wenigbluetigen</normalizedToken>
<normalizedToken id="926D3191BC9D9B29C992534BE22E8888" originalValue="Blütenständen" pageId="null" pageNumber="686">Bluetenstaenden</normalizedToken>
; die einzelnen 
<normalizedToken id="5CDAA44AA5F5403F2FBD0C4CC366AC17" originalValue="Blüten" pageId="null" pageNumber="686">Blueten</normalizedToken>
auf 3-4 cm langen Stielen. ⚥, ♂ und ♀ 
<normalizedToken id="049CD511A38EECFDB159447728C7E09F" originalValue="Blüten" pageId="null" pageNumber="686">Blueten</normalizedToken>
im gleichen 
<normalizedToken id="F3CB7931DF02DE03B5BD96A4E0F6232A" originalValue="Blütenstand" pageId="null" pageNumber="686">Bluetenstand</normalizedToken>
. 
<normalizedToken id="8C418682E09E552F09DE5CD27E5AD921" originalValue="Kelchblätter" pageId="null" pageNumber="686">Kelchblaetter</normalizedToken>
und 
<normalizedToken id="1946A0424AA9F98FFEC6223E5C139424" originalValue="Kronblätter" pageId="null" pageNumber="686">Kronblaetter</normalizedToken>
je 5, 4-5 mm lang, 2-3 mm breit, beiderseits kahl, 
<normalizedToken id="FBD29B738B16FFEA824F379EF95097CC" originalValue="gelbgrün" pageId="null" pageNumber="686">gelbgruen</normalizedToken>
. 
<normalizedToken id="BE92919D2DCFB28D47EA2C977ECE3123" originalValue="Staubblätter" pageId="null" pageNumber="686">Staubblaetter</normalizedToken>
der ♂ 
<normalizedToken id="7A17331DC716535446838F9823AE57EC" originalValue="Blüten" pageId="null" pageNumber="686">Blueten</normalizedToken>
<normalizedToken id="D4DE4C5822BFFF21A7C47BAEEFF04200" originalValue="länger" pageId="null" pageNumber="686">laenger</normalizedToken>
als die 
<normalizedToken id="F616BB7882322E2CC44A2A0B0C298964" originalValue="Kronblätter" pageId="null" pageNumber="686">Kronblaetter</normalizedToken>
, jene der ⚥ 
<normalizedToken id="F54C66A03874A8EAEF88F345675B45D9" originalValue="Blüten" pageId="null" pageNumber="686">Blueten</normalizedToken>
<normalizedToken id="AC731CA8E0B04D6EA574EA87FD0402FE" originalValue="kürzer" pageId="null" pageNumber="686">kuerzer</normalizedToken>
. 
<normalizedToken id="54E3ACC7C0FCCD862339834A6EB3CC60" originalValue="Früchte" pageId="null" pageNumber="686">Fruechte</normalizedToken>
kahl; 
<normalizedToken id="0344EBDEA84FA1FA93838039F5D0A0F6" originalValue="Teilfrüchte" pageId="null" pageNumber="686">Teilfruechte</normalizedToken>
2-3 cm lang, 
<emphasis id="E985D029BBEBCB9FBE22C064EB637FEE" italics="true" pageId="null" pageNumber="686">
die 
<normalizedToken id="4157469235A89F3F9A1E5DE944F6E8D2" originalValue="Flügel" pageId="null" pageNumber="686">Fluegel</normalizedToken>
</emphasis>
<normalizedToken id="E4C7E6FC09E8C5733879F7A26EF3195A" originalValue="±" pageId="null" pageNumber="686">+/-</normalizedToken>
<emphasis id="E5EC3723C924CBED3D2EED9DDE148B7C" italics="true" pageId="null" pageNumber="686">parallel verlaufend.</emphasis>
- 
<normalizedToken id="E9CDBE05D64C21EA833BCE508AB63691" originalValue="Blüte" pageId="null" pageNumber="686">Bluete</normalizedToken>
: 
<normalizedToken id="A5E9C3DD38821DA797B430E14A3ADE9A" originalValue="Frühling" pageId="null" pageNumber="686">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="A3113D2EE3D0B52B6F39BEEEA3C24CF8" pageId="null" pageNumber="686">
<emphasis id="5377096451F2E8B9184D3EAD4EEAA631" italics="true" pageId="null" pageNumber="686">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="9D206002A95379B3345A044D044C308B" pageId="null" pageNumber="686">
<emphasis id="351F017B7DC76CD5B0744FF5A8FCC78C" italics="true" pageId="null" pageNumber="686">Standort.</emphasis>
Kollin. Meist kalkreiche 
<normalizedToken id="8B4B830A6BB702F78E15C3CD2745E8C6" originalValue="Böden" pageId="null" pageNumber="686">Boeden</normalizedToken>
in 
<normalizedToken id="9151D73F6BBA47D58B704BDC784ABE61" originalValue="heißen" pageId="null" pageNumber="686">heissen</normalizedToken>
Lagen. 
<normalizedToken id="5B4F0712C1CF1281221687C47B5ECC51" originalValue="Flaumeichenwälder" pageId="null" pageNumber="686">Flaumeichenwaelder</normalizedToken>
.
</paragraph>
<paragraph id="7367E9B1D8C0577BA1F8048A3937ED3D" pageId="null" pageNumber="686">
<emphasis id="BCEB8B4F2F5AF898261F5B061A4F1C6A" italics="true" pageId="null" pageNumber="686">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="EF15DDB7BA79D338BF8A95A469092239" originalValue="Nordwärts" pageId="null" pageNumber="686">Nordwaerts</normalizedToken>
bis 
<normalizedToken id="026E3F6AC423A9697A1B168D3180991A" originalValue="Vendée" pageId="null" pageNumber="686">Vendee</normalizedToken>
, 
<normalizedToken id="675360785D2DA6FCCE7B956B3212E8EB" originalValue="Côte" pageId="null" pageNumber="686">Cote</normalizedToken>
<normalizedToken id="7F3B0E71EC21AFB4AB63B24E18FCC72E" originalValue="d’Or" pageId="null" pageNumber="686">d'Or</normalizedToken>
, Eifel, Mosel, 
<normalizedToken id="9DB67B18416158027FB2097FBCB3829E" originalValue="östlich" pageId="null" pageNumber="686">oestlich</normalizedToken>
des Rheins nur im Unterlahntal und Maintal 
<normalizedToken id="C93BA3A7DDBD66019638AA2B55BCE0EE" originalValue="ursprünglich" pageId="null" pageNumber="686">urspruenglich</normalizedToken>
, Norditalien (Brescia, Monte Baldo, Friaul), 
<normalizedToken id="8F4298E2C5FFFCA5A324504502339DD2" originalValue="südliche" pageId="null" pageNumber="686">suedliche</normalizedToken>
Balkanhalbinsel (
<normalizedToken id="82488A3D531E1F4F9A75C8090449AA9B" originalValue="südlich" pageId="null" pageNumber="686">suedlich</normalizedToken>
der Donau), Kaukasus; 
<normalizedToken id="63ABA0D0EC131035C5F26FEF3E6425FA" originalValue="südwärts" pageId="null" pageNumber="686">suedwaerts</normalizedToken>
bis Nordafrika, Kleinasien; 
<normalizedToken id="8E89E8ED7B922853986AE40F68ABA3B7" originalValue="ostwärts" pageId="null" pageNumber="686">ostwaerts</normalizedToken>
bis Turkestan. Verbreitungskarte von Ruhe (1936). - Im Gebiet: Von 
<normalizedToken id="F40BC379C1172BD7EB507C2F5D22C480" originalValue="Süden" pageId="null" pageNumber="686">Sueden</normalizedToken>
her den Jura 
<normalizedToken id="DCC59A785207CA352AFB6C07A0B04E04" originalValue="aufwärts" pageId="null" pageNumber="686">aufwaerts</normalizedToken>
bis Fort de 
<normalizedToken id="AE14DE5E3CDBED61750E038000A3EC0F" originalValue="l’Ecluse" pageId="null" pageNumber="686">l'Ecluse</normalizedToken>
bei Genf; in Savoyen 
<normalizedToken id="25A8A40CC596B7CFD3E2C2DEB58C8356" originalValue="außerhalb" pageId="null" pageNumber="686">ausserhalb</normalizedToken>
des Juras in der Maurienne und Tarentaise; sonst gelegentlich angepflanzt.
</paragraph>
</subSubSection>
