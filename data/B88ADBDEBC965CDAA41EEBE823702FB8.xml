<taxonomicName id="C1334670CE90F020DC34453A062D9964" baseAuthorityName="Linnaeus" baseAuthorityYear="1758" class="Insecta" family="Pentatomidae" genus="Nezara" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Nezara viridula" order="Hymenoptera" pageId="0" pageNumber="105" phylum="Arthropoda" rank="species" species="viridula">
