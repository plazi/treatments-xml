</paragraph>
</subSubSection>
<subSubSection id="8C8E6575FFCB6A74FF489B781A5FB670" box="[180,1119,3361,3394]" pageId="48" pageNumber="806" type="biology_ecology">
<paragraph id="C42B36FEFFCB6A74FF489B781A5FB670" blockId="48.[175,1385,2374,3472]" box="[180,1119,3361,3394]" pageId="48" pageNumber="806">
