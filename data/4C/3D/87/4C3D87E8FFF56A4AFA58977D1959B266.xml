, 
<geoCoordinate box="[2310,2434,579,612]" degrees="24" direction="east" minutes="55" orientation="longitude" pageId="14" pageNumber="772" precision="925" value="24.916666">24° 55’ E</geoCoordinate>
, 
<quantity box="[2446,2528,579,612]" metricMagnitude="2" metricUnit="m" metricValue="9.4" pageId="14" pageNumber="772" unit="m" value="940.0">
<elevation box="[2446,2528,579,612]" metricMagnitude="2" metricUnit="m" metricValue="9.4" pageId="14" pageNumber="772" unit="m" value="940.0">940 m</elevation>
