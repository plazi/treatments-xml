in Benda et al, 2009,
</subSubSection>
<subSubSection pageId="14" pageNumber="772" type="materials_examined">
<materialsCitation ID-GBIF-Occurrence="3783319601" country="Greece" elevation="940" latitude="35.183334" location="Rouva oak forest" longitude="24.916666" municipality="Irakleio" pageId="14" pageNumber="772" specimenCount="1" stateProvince="Crete">
“ 
