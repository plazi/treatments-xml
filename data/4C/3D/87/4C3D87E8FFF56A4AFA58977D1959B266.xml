, 
<collectingRegion box="[2471,2546,465,494]" country="Greece" name="Kriti" pageId="14" pageNumber="772">Crete</collectingRegion>
, 
<location LSID="urn:lsid:plazi:treatment:4C3D87E8FFF56A4AFA58977D1959B266:C14B6025FFF56A4AF5FF9788168CB927" country="Greece" latitude="35.183334" municipality="Irakleio" name="Rouva oak forest" pageId="14" pageNumber="772" stateProvince="Crete">Rouva oak forest</location>
