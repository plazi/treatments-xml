<taxonomicName box="[2101,2217,1312,1345]" class="Mammalia" family="Vespertilionidae" genus="Eptesicus" kingdom="Animalia" order="Chiroptera" pageId="95" pageNumber="853" phylum="Chordata" rank="genus">Eptesicus</taxonomicName>
