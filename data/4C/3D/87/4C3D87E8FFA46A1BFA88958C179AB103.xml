<taxonomicName authorityName="Thomas" authorityYear="1916" box="[2248,2399,1352,1385]" class="Mammalia" family="Vespertilionidae" genus="Eptesicus" kingdom="Animalia" order="Chiroptera" pageId="95" pageNumber="853" phylum="Chordata" rank="species" species="dimissus">E. dimissus</taxonomicName>
