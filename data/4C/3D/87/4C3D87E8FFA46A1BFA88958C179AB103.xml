<taxonomicName box="[2257,2410,1431,1464]" class="Mammalia" family="Vespertilionidae" genus="Cassistrellus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Chiroptera" pageId="95" pageNumber="853" phylum="Chordata" rank="genus">Cassistrellus</taxonomicName>
