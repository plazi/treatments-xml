, 
<collectingRegion box="[308,370,1298,1331]" country="Thailand" name="Loei" pageId="161" pageNumber="923">Loei</collectingRegion>
, 
<collectingRegion box="[384,535,1298,1331]" country="Thailand" name="Ratchaburi" pageId="161" pageNumber="923">Ratchaburi</collectingRegion>
