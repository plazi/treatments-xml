<collectingRegion box="[607,765,1298,1331]" country="Thailand" name="Surat Thani" pageId="161" pageNumber="923">Surat Thani</collectingRegion>
provinces), N 
<collectingCountry box="[960,1022,1298,1331]" name="Laos" pageId="161" pageNumber="923">Laos</collectingCountry>
