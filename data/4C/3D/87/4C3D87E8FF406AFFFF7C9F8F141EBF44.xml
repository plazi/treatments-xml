<collectingRegion box="[1088,1135,2811,2840]" country="South Sudan" name="Lakes" pageId="187" pageNumber="949">See</collectingRegion>
<taxonomicName baseAuthorityName="Hodgson" baseAuthorityYear="1835" box="[1159,1327,2811,2840]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="187" pageNumber="950" phylum="Chordata" rank="species" species="formosus">M. formosus</taxonomicName>
