<taxonomicName id="03944D7DFFE66A59FF8491BC1FB7B334" authority="Peters, 1872" authorityName="Peters" authorityYear="1872" box="[120,439,2021,2054]" class="Mammalia" family="Vespertilionidae" genus="Tylonycteris" kingdom="Animalia" order="Chiroptera" pageId="29" pageNumber="787" phylum="Chordata" rank="subSpecies" species="pachypus" subSpecies="meyeri">T. p. meyeri Peters, 1872</taxonomicName>
