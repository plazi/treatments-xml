<subSubSection id="15E02A36A73183C22F447C6C53711609" pageId="null" pageNumber="513" type="description">
<paragraph id="5CA38C0C9D5932EEB7904EDB44E15A1A" pageId="null" pageNumber="513">
1 
<normalizedToken id="4F4C93A0F045D00041809FC4A6354CD7" originalValue="jährig" pageId="null" pageNumber="513">jaehrig</normalizedToken>
, mit Pfahlwurzel, meist kahl; 20-100 cm hoch. 
<emphasis id="B8F1C7CA7CFD784D9468837A00CFF51F" italics="true" pageId="null" pageNumber="513">
<normalizedToken id="CB5390FAEDA6C0FA1A6943033433254D" originalValue="Blätter" pageId="null" pageNumber="513">Blaetter</normalizedToken>
<normalizedToken id="3C039818D1FD5120055C98DED4D56316" originalValue="gegenständig" pageId="null" pageNumber="513">gegenstaendig</normalizedToken>
, bis auf die Mittelnerven doppelt fiederteilig, mit sehr schmal lanzettlichen
</emphasis>
, bis 1,5 mm breiten, 
<emphasis id="7E5D45864DBA616D2CD1FB1EF14494B9" italics="true" pageId="null" pageNumber="513">
fast 
<normalizedToken id="C890443470156CF5CBDAF2E20A8E884D" originalValue="fadenförmigen" pageId="null" pageNumber="513">fadenfoermigen</normalizedToken>
Abschnitten.
</emphasis>
<normalizedToken id="6D1FC6E1B4FB632194C2BF5B0E027243" originalValue="Blütenköpfe" pageId="null" pageNumber="513">Bluetenkoepfe</normalizedToken>
lang gestielt. 
<normalizedToken id="15762FF20586F6F887E848F20795506D" originalValue="Äußere" pageId="null" pageNumber="513">Aeussere</normalizedToken>
Kronen 
<normalizedToken id="9591A676CAE33C2B9A52B74D159EB71A" originalValue="zungenförmig" pageId="null" pageNumber="513">zungenfoermig</normalizedToken>
, 
<emphasis id="63CB15484BAE9E987FBDD32DDFA8EE22" italics="true" pageId="null" pageNumber="513">
rot, rosa oder 
<normalizedToken id="3B530B5E996B653BDB34BB71738C6BE6" originalValue="weiß" pageId="null" pageNumber="513">weiss</normalizedToken>
, 2
</emphasis>
- 
<emphasis id="12DDF6BEC8B15DB5B0825AB9F51EAC9D" italics="true" pageId="null" pageNumber="513">3 cm lang</emphasis>
, die innern 
<normalizedToken id="5C8A3DA10C1F01E92FF67970FE071C87" originalValue="röhrenförmig" pageId="null" pageNumber="513">roehrenfoermig</normalizedToken>
und gelb. 
<normalizedToken id="7727CBC18F3A6552DD523E39E4B54BC7" originalValue="Früchte" pageId="null" pageNumber="513">Fruechte</normalizedToken>
kahl, 
<emphasis id="542EC3DA9BC67C0EA1F36D076263EB0B" italics="true" pageId="null" pageNumber="513">1</emphasis>
- 
<emphasis id="993A27D9A946D9CD9163BB6139AD2041" italics="true" pageId="null" pageNumber="513">1,8 cm lang.</emphasis>
- 
<normalizedToken id="EECD7441739DDB1607001E8E90359AF4" originalValue="Blüte" pageId="null" pageNumber="513">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="C19C5DC41B1247934A690EB4A73E7028" pageId="null" pageNumber="513">
<emphasis id="76C41A179D28E05C17C6582780552DB9" italics="true" pageId="null" pageNumber="513">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="F698DF78AB0DF96440313A66C45DC59C" italics="true" pageId="null" pageNumber="513">24:</emphasis>
Material aus botanischen 
<normalizedToken id="7CEA9079FF94318F15D14293F4A7E98F" originalValue="Gärten" pageId="null" pageNumber="513">Gaerten</normalizedToken>
(Sugiura 1936b, Sharma 1947, Crowe 1954, Mehra et al. 1965), aus Nordamerika (Powell und Turner 1963, Melchert 1968).
</paragraph>
<paragraph id="D103DC01DBEE99107E65855D86D73008" pageId="null" pageNumber="513">
<emphasis id="62AC73923FB21A0F56579AA50DC8E378" italics="true" pageId="null" pageNumber="513">Standort.</emphasis>
Kollin. 
<normalizedToken id="4CF65C4CC5CFC3BD4590035AFABFAD33" originalValue="Mäßig" pageId="null" pageNumber="513">Maessig</normalizedToken>
feuchte, lockere 
<normalizedToken id="EAA7C938CD7FAC5746AD705BD3816590" originalValue="Böden" pageId="null" pageNumber="513">Boeden</normalizedToken>
. 
<normalizedToken id="7B7C5FD2BB637AB4E84BB746F3343310" originalValue="Schuttplätze" pageId="null" pageNumber="513">Schuttplaetze</normalizedToken>
(verwildert).
</paragraph>
<paragraph id="54A841E6AC474C6BBF79209F0D16CAA4" pageId="null" pageNumber="513">
<emphasis id="3A32BA25E84799AB99A720A1B1731359" italics="true" pageId="null" pageNumber="513">Verbreitung. Mexikanische Pflanze.</emphasis>
An vielen Orten in 
<normalizedToken id="CA2CF31DC256EC44BB8A7AA80666A80C" originalValue="Gärten" pageId="null" pageNumber="513">Gaerten</normalizedToken>
kultiviert und selten verwildert.
</paragraph>
</subSubSection>
