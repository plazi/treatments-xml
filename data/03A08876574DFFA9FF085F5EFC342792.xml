</emphasis>
<taxonomicName id="4C0942E3574DFFA9FEB55FEBFD7F24F2" authority="Galiano, 1988" authorityName="Galiano" authorityYear="1988" box="[298,712,1443,1467]" class="Arachnida" family="Salticidae" genus="Admesturius" kingdom="Animalia" order="Araneae" pageId="10" pageNumber="441" phylum="Arthropoda" rank="species" species="schajovskoyi">
<emphasis id="B97DE572574DFFA9FEB55FEBFD8724F2" box="[298,560,1443,1467]" italics="true" pageId="10" pageNumber="441">Admesturius schajovskoyi</emphasis>
<bibRefCitation id="EF984491574DFFA9FDA85FEBFD7F24F2" author="Galiano, M. E." box="[567,712,1443,1467]" pageId="10" pageNumber="441" pagination="285 - 301" refId="ref17400" refString="Galiano, M. E. (1988) Revision de los generos del grupo Hurieae (Araneae, Salticidae). Journal of Arachnology, 15, 285 - 301." type="journal article" year="1988">Galiano, 1988</bibRefCitation>
