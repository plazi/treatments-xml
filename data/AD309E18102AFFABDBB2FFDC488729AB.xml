<taxonomicName id="E299548D1035FFAADA79F8234E192CAD" authority="Okajima &amp; Masumoto, 2022" authorityName="Okajima &amp; Masumoto" authorityYear="2022" box="[348,556,1896,1920]" class="Insecta" family="Phlaeothripidae" genus="Asianthrips" kingdom="Animalia" order="Thysanoptera" pageId="16" pageNumber="117" phylum="Arthropoda" rank="species" species="dentipes" status="sp. n.">
