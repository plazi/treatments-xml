<paragraph id="C7FC9EDBF2EB5D64CBADE679AF8451E4" pageId="null" pageNumber="113">
<pageBreakToken id="A97E618C3354A549B5A2E13BEA09F59B" pageId="null" pageNumber="113" start="start">Artengruppe</pageBreakToken>
des 
<taxonomicName id="CCC4B4A284244C83493203351074A6FD" authority="L." class="Magnoliopsida" family="Papaveraceae" genus="Papaver" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="113" phylum="Tracheophyta" rank="species" species="hybridum">
