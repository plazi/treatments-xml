<subSubSection id="15B7844E091234947EE0FE53AFF1BCB8" pageId="null" pageNumber="113" type="vernacular_names">
<paragraph id="847EC6A976A8F35EC8EA27490ACDE3AF" pageId="null" pageNumber="113">Bastard-Mohn</paragraph>
</subSubSection>
</title>
<subSubSection id="C6D8CC9B65AC9CC4D36FB3F0F989E9A3" pageId="null" pageNumber="113" type="description">
<paragraph id="B4198C4097E0B9D7DFF73FDB29A91532" pageId="null" pageNumber="113">
1-2 
<normalizedToken id="B62F28A22DF8D5CC42C7D78D3D00D108" originalValue="jährig" pageId="null" pageNumber="113">jaehrig</normalizedToken>
; 15-50 cm hoch. Stengel aufrecht oder aufsteigend, einfach oder verzweigt, 
<normalizedToken id="9F2D3E6E5B50DF1388D1357EA3B420F9" originalValue="beblättert" pageId="null" pageNumber="113">beblaettert</normalizedToken>
, behaart. 
<normalizedToken id="9AA0B05FF346933A4D2BCD8FA3DDFF44" originalValue="Blätter" pageId="null" pageNumber="113">Blaetter</normalizedToken>
bis fast auf den Mittelnerv 1-3fach fiederteilig, mit bis 3 mm breiten, meist spitzen Zipfeln, meist zerstreut behaart, 
<normalizedToken id="CFF23252A26D94633BCBB1EC0A8D39D0" originalValue="grün" pageId="null" pageNumber="113">gruen</normalizedToken>
; untere 
<normalizedToken id="06350C2AF31B2B2CEEACFA99E374CF6F" originalValue="Blätter" pageId="null" pageNumber="113">Blaetter</normalizedToken>
gestielt, die mittleren und oberen mit schmalem Grunde sitzend. 
<normalizedToken id="7CFECFD0F20B644929857F3F5D5BFD86" originalValue="Kelchblätter" pageId="null" pageNumber="113">Kelchblaetter</normalizedToken>
mit hellen Haaren. 
<normalizedToken id="394C0809650B2D3477B960DCB332269E" originalValue="Kronblätter" pageId="null" pageNumber="113">Kronblaetter</normalizedToken>
1,2-2,5 cm lang, dunkelrot, am Grunde mit schwarzem Fleck. 
<emphasis id="388B37F70AEC4FB9573917798A677AB8" italics="true" pageId="null" pageNumber="113">
<normalizedToken id="5736DD634939B038EA65760FB8C3D274" originalValue="Staubfäden" pageId="null" pageNumber="113">Staubfaeden</normalizedToken>
nach oben 
<normalizedToken id="3BB18A470161FEE3A23C5D28CD0A7E60" originalValue="keulenförmig" pageId="null" pageNumber="113">keulenfoermig</normalizedToken>
verdickt und unterhalb der Staubbeutel 
<normalizedToken id="414C941B045F205D715DA304070CE3F5" originalValue="plötzlich" pageId="null" pageNumber="113">ploetzlich</normalizedToken>
in einen kurzen Stiel 
<normalizedToken id="329549E0C102EE77DFAB0E32A4F2A228" originalValue="verschmälert" pageId="null" pageNumber="113">verschmaelert</normalizedToken>
</emphasis>
, dunkelviolett. 
<emphasis id="9D6F1C09566F95EFC5941DF08CF49F92" italics="true" pageId="null" pageNumber="113">Frucht mit hellen, borsten-</emphasis>
<emphasis id="AE85A38C2975C2768D54C1C963B8D481" italics="true" pageId="null" pageNumber="113">
<pageBreakToken id="CD0FFFE178C7FE5697A81041110CDB8D" pageId="null" pageNumber="113">jormigen</pageBreakToken>
Haaren
</emphasis>
, mit oft undeutlichen 
<normalizedToken id="A31595B3314B2784C8D2827A8DC9537C" originalValue="Längslinien" pageId="null" pageNumber="113">Laengslinien</normalizedToken>
, mit 4-8 Narbenstrahlen. Deckel der Frucht zur Reifezeit 
<normalizedToken id="D990D27470F6A00151EE392D96FBE58A" originalValue="gewölbt" pageId="null" pageNumber="113">gewoelbt</normalizedToken>
.
</paragraph>
<paragraph id="931F3B35BBF6EBBA81D955688BA85368" pageId="null" pageNumber="113">
Die Artengruppe des 
<taxonomicName id="9B31B75AE51CC266C8457DD94BCE4879" class="Magnoliopsida" family="Papaveraceae" genus="Papaver" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="113" phylum="Tracheophyta" rank="species" species="hybridum">
<emphasis id="52CBBA210FCC38031CB83FA9687CCA37" italics="true" pageId="null" pageNumber="113">P. hybridum</emphasis>
</taxonomicName>
<normalizedToken id="9F66A800FED982F9AA87182756100BB5" originalValue="umfaßt" pageId="null" pageNumber="113">umfasst</normalizedToken>
etwa 
<emphasis id="8377975A192112F9FA109AC39AFE18A4" italics="true" pageId="null" pageNumber="113">
6 Arten; Hauptverbreitung im Mittelmeergebiet. 
<taxonomicName id="939F561729CD202DCEC3552626BE446D" class="Magnoliopsida" family="Papaveraceae" genus="Papaver" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="113" phylum="Tracheophyta" rank="species" species="hybridum">P. hybridum</taxonomicName>
</emphasis>
und 
<taxonomicName id="2EA17012E776964698C0C95315AD8A1D" class="Magnoliopsida" family="Papaveraceae" genus="Papaver" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="113" phylum="Tracheophyta" rank="species" species="argemone">
<emphasis id="398BCC6BBAB34377A81A142D280A1254" italics="true" pageId="null" pageNumber="113">P. Argemone</emphasis>
</taxonomicName>
sind selbstfertil, 
<taxonomicName id="24C05A3811B87F8647009CD21B60E470" class="Magnoliopsida" family="Papaveraceae" genus="Papaver" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="113" phylum="Tracheophyta" rank="species" species="apulum">
<emphasis id="29C72F1CCC0E13577F5E7792E6F6608F" italics="true" pageId="null" pageNumber="113">P. apulum</emphasis>
</taxonomicName>
selbststeril (nach Rogers 1969).
</paragraph>
