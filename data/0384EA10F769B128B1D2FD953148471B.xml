LOCALITY: 
<collectingMunicipality id="6BF6C17CF769B128B091FC08300A4753" box="[468,563,1015,1041]" pageId="28" pageNumber="549">Leroma</collectingMunicipality>
, near 
<location id="8EF20DDDF769B128B33DFC08313D4753" LSID="urn:lsid:plazi:treatment:0384EA10F769B128B1D2FD953148471B:8EF20DDDF769B128B33DFC08313D4753" box="[632,772,1015,1041]" municipality="Leroma" name="Pilanesberg" pageId="28" pageNumber="549" stateProvince="North West">Pilanesberg</location>
, 
<collectingRegion id="49E995E4F769B128B24AFC0836314753" box="[783,1032,1015,1041]" country="Botswana" name="North West" pageId="28" pageNumber="549">North West Province</collectingRegion>
