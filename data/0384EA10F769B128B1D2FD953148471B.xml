<taxonomicName id="4C2D2085F769B128B330FBE431564777" authorityName="Sundevall" authorityYear="1850" box="[629,879,1051,1077]" class="Aves" family="Cisticolidae" genus="Eremomela" kingdom="Animalia" order="Passeriformes" pageId="28" pageNumber="549" phylum="Chordata" rank="species" species="usticollis">
