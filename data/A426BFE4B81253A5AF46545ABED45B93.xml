<emphasis id="FC9EC96E2811B749080521763DBCFFE7" bold="true" pageId="0" pageNumber="59">Figure 3.</emphasis>
<taxonomicName id="CE08087DF866636806CE97F56805ACB1" authorityName="S. Jin Zeng &amp; N. H. Xia" authorityYear="2022" class="Magnoliopsida" family="Melastomataceae" genus="Fordiophyton" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Fordiophyton tereticaule" order="Myrtales" pageId="0" pageNumber="59" phylum="Tracheophyta" rank="species" species="tereticaule">
<emphasis id="56EA8EBD895CEB64F20B9DB8E5FFD0C6" italics="true" pageId="0" pageNumber="59">Fordiophyton tereticaule</emphasis>
</taxonomicName>
