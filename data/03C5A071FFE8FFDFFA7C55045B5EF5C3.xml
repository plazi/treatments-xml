</paragraph>
<paragraph id="8BD31167FFEBFFDFFD715A5A5E22FD36" blockId="6.[716,1310,288,715]" pageId="6" pageNumber="558">
<taxonomicName id="4C6C6AE4FFEBFFDFFD715A5A5E1FFDE9" authority="Chapman, 1901" authorityName="Chapman" authorityYear="1901" baseAuthorityName="Chapman" baseAuthorityYear="1901" box="[717,1150,595,637]" class="Mammalia" family="Capromyidae" genus="Mysateles" kingdom="Animalia" order="Rodentia" pageId="6" pageNumber="558" phylum="Chordata" rank="subSpecies" species="prehensilis" subSpecies="gundlachi">M.p.gundlachiChapman,1901—NIslade</taxonomicName>
laJuventud(offSWCuba)
</paragraph>
<paragraph id="8BD31167FFEBFFDFFBFF5A755E26FD36" blockId="6.[716,1310,288,715]" box="[1091,1095,636,674]" pageId="6" pageNumber="558">.</paragraph>
<paragraph id="8BD31167FFEBFFDFFD715ABB5B85FD67" blockId="6.[716,1310,288,715]" lastBlockId="6.[100,1312,726,2647]" pageId="6" pageNumber="558">
<taxonomicName id="4C6C6AE4FFEBFFDFFD715ABB5E1EFD5F" authority="Varona, 1986" authorityName="Varona" authorityYear="1986" box="[717,1151,690,715]" class="Mammalia" family="Capromyidae" genus="Mysateles" kingdom="Animalia" order="Rodentia" pageId="6" pageNumber="558" phylum="Chordata" rank="subSpecies" species="prehensilis" subSpecies="meridionalis">M. p. meridionalis Varona, 1986</taxonomicName>
— S Isla de la Juventud (off SW Cuba).
