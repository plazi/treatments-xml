<taxonomicName id="4C6C6AE4FFEBFFDFFC2C59295939FEFC" authority="Poeppig, 1824" authorityName="Poeppig" authorityYear="1824" class="Mammalia" family="Capromyidae" genus="Capromys" kingdom="Animalia" order="Rodentia" pageId="6" pageNumber="558" phylum="Chordata" rank="species" species="prehensilis">Capromys prehensilis Poeppig, 1824</taxonomicName>
, 
<materialsCitation id="3B041B3AFFEBFFDFFCCD594E5959FE23" ID-GBIF-Occurrence="3804303364" pageId="6" pageNumber="558">“in sylvis versus oram Cubae australe obvia [= wooded south coast, Cuba].”</materialsCitation>
</paragraph>
<paragraph id="8BD31167FFEBFFDFFD7059B75EFCFE4B" blockId="6.[716,1310,288,715]" box="[716,1181,446,479]" pageId="6" pageNumber="558">Three subspecies are recognized.</paragraph>
</subSubSection>
<subSubSection id="C37642ECFFEBFFDFFD7159EC5B85FD67" pageId="6" pageNumber="558" type="synonymic_list">
<caption id="DF1341EFFFEBFFDFFD7159EC5B85FD67" ID-DOI="http://doi.org/10.5281/zenodo.6623673" ID-Zenodo-Dep="6623673" httpUri="https://zenodo.org/record/6623673/files/figure.png" inLine="true" pageId="6" pageNumber="558" targetBox="[101,692,299,713]" targetPageId="6">
