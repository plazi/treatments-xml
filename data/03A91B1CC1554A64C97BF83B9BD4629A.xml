<subSubSection id="C31AF981C1554A64CBDEF6C09B0D6699" pageId="4" pageNumber="308" type="distribution">
<caption id="DF7FFA82C1554A64CBDEF6C09B0D6699" ID-DOI="http://doi.org/10.5281/zenodo.6612233" ID-Zenodo-Dep="6612233" httpUri="https://zenodo.org/record/6612233/files/figure.png" inLine="true" pageId="4" pageNumber="308" targetBox="[104,694,2194,2607]" targetPageId="4">
<paragraph id="8BBFAA0AC1554A64CBDEF6C09B0D6699" blockId="4.[717,1312,2183,2610]" pageId="4" pageNumber="308">
<emphasis id="B9747618C1554A64CBDEF6C09B57664A" bold="true" box="[718,894,2341,2374]" pageId="4" pageNumber="308">Distribution.</emphasis>
