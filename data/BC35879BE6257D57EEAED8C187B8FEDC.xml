<subSubSection id="7C866506E6257D54EEAED88A8588FD63" pageId="1" pageNumber="96" type="reference_group">
<paragraph id="3423368DE6257D54EEAED88A8588FD63" blockId="1.[151,1437,151,748]" pageId="1" pageNumber="96">
<treatmentCitationGroup id="148C11A3E6257D54EEAED88A8588FD63" pageId="1" pageNumber="96">
<treatmentCitation id="B53D109CE6257D54EEAED88A841CFF17" author="Shatalkin, A. I." box="[151,534,220,244]" page="143" pageId="1" pageNumber="96" year="1994">
<taxonomicName id="F39C4D0EE6257D54EEAED88A841CFF17" authority="Shatalkin, 1994: 143" authorityName="Shatalkin" authorityPageNumber="143" authorityYear="1994" box="[151,534,220,244]" class="Insecta" family="Cypselosomatidae" genus="Tenuia" kingdom="Animalia" order="Diptera" pageId="1" pageNumber="96" phylum="Arthropoda" rank="species" species="smirnovi">
<emphasis id="06E8EA9FE6257D54EEAED88A8730FF10" box="[151,314,220,243]" italics="true" pageId="1" pageNumber="96">Tenuia smirnovi</emphasis>
<bibRefCitation id="500D4B7CE6257D54EF79D88A841CFF17" author="Shatalkin, A. I." box="[320,534,220,244]" pageId="1" pageNumber="96" pagination="129 - 145" refId="ref2327" refString="Shatalkin, A. I. (1994) Palaearctic species of Pseudopomyzidae (Diptera). Russian Entomological Journal, 3 (3 - 4), 129 - 145." type="journal article" year="1994">Shatalkin, 1994: 143</bibRefCitation>
</taxonomicName>
</treatmentCitation>
. 
<typeStatus id="EB27882FE6257D54EC26D88A8477FF17" box="[543,637,220,244]" pageId="1" pageNumber="96">Holotype</typeStatus>
<specimenCount id="229AFD04E6257D54ECBDD88A8493FF10" box="[644,665,220,243]" pageId="1" pageNumber="96" type="male">♂</specimenCount>
, 
<collectingRegion id="F658F86FE6257D54EC9DD88A8549FF17" box="[676,835,220,244]" country="Russia" name="Primorskiy" pageId="1" pageNumber="96">Primorsky Krai</collectingRegion>
, Khasan area, “Kedrovaya Pad” Reserve, 
<collectingCountry id="4C8B761DE6257D54EAD5D88A833AFF17" box="[1260,1328,220,244]" name="Russia" pageId="1" pageNumber="96">Russia</collectingCountry>
[ZMMU]. 
<emphasis id="06E8EA9FE6257D54EEAED8A98706FEF4" bold="true" box="[151,268,255,279]" inLineHeading="true" pageId="1" pageNumber="96" reason="1">Diagnosis.</emphasis>
Small-sized flies; body-length 
<quantity id="F3649B68E6257D54EC58D8A984ECFEF4" box="[609,742,255,279]" metricMagnitude="-3" metricUnit="m" metricValue="3.95" metricValueMax="4.3" metricValueMin="3.6" pageId="1" pageNumber="96" unit="mm" value="3.95" valueMax="4.3" valueMin="3.6">3.6–4.3 mm</quantity>
; wing-length 
<quantity id="F3649B68E6257D54ED42D956820BFEF4" box="[891,1025,256,280]" metricMagnitude="-3" metricUnit="m" metricValue="3.9" metricValueMax="4.1" metricValueMin="3.7" pageId="1" pageNumber="96" unit="mm" value="3.9" valueMax="4.1" valueMin="3.7">3.7–4.1 mm</quantity>
; colour black, with yellow regions on head (
<figureCitation id="ACA72A08E6257D54EEE3D972875DFEDF" box="[218,343,292,316]" captionStart="FIGURE1" captionStartId="1.[151,254,1885,1909]" captionTargetBox="[151,1435,772,1861]" captionTargetId="figure-264@1.[151,1435,772,1861]" captionTargetPageId="1" captionText="FIGURE1. Tenuia smirnovi Shatalkin, 1994, male: A, body, dorsal view; B, body, lateral view; C, head, front view." figureDoi="http://doi.org/10.5281/zenodo.6404836" httpUri="https://zenodo.org/record/6404836/files/figure.png" pageId="1" pageNumber="96">Fig. 1 A–C</figureCitation>
); paravertical setae present (
<figureCitation id="ACA72A08E6257D54ECB5D9728508FEDF" box="[652,770,292,316]" captionStart="FIGURE 2" captionStartId="2.[151,250,1955,1979]" captionTargetBox="[151,1436,344,1908]" captionTargetId="figure-103@2.[151,1436,344,1931]" captionTargetPageId="2" captionText="FIGURE 2. Tenuia smirnovi Shatalkin, 1994, male: A, whole mount specimen, lateral view; B, head, lateral view; C, head, dorsal view; D, mesosoma, lateral view; E, mesosoma, dorsal view; F, wing." figureDoi="http://doi.org/10.5281/zenodo.6404842" httpUri="https://zenodo.org/record/6404842/files/figure.png" pageId="1" pageNumber="96">Fig. 2B–C</figureCitation>
); 5 (rarely 6) dorsocentrals (
<figureCitation id="ACA72A08E6257D54EA0ED97282A7FEDF" box="[1079,1197,292,316]" captionStart="FIGURE 2" captionStartId="2.[151,250,1955,1979]" captionTargetBox="[151,1436,344,1908]" captionTargetId="figure-103@2.[151,1436,344,1931]" captionTargetPageId="2" captionText="FIGURE 2. Tenuia smirnovi Shatalkin, 1994, male: A, whole mount specimen, lateral view; B, head, lateral view; C, head, dorsal view; D, mesosoma, lateral view; E, mesosoma, dorsal view; F, wing." figureDoi="http://doi.org/10.5281/zenodo.6404842" httpUri="https://zenodo.org/record/6404842/files/figure.png" pageId="1" pageNumber="96">Fig. 2D–E</figureCitation>
); acrostichals biserial, prescutellar acrostichal setae enlarged (
<figureCitation id="ACA72A08E6257D54EC07D91E84BEFE83" box="[574,692,328,352]" captionStart="FIGURE 2" captionStartId="2.[151,250,1955,1979]" captionTargetBox="[151,1436,344,1908]" captionTargetId="figure-103@2.[151,1436,344,1931]" captionTargetPageId="2" captionText="FIGURE 2. Tenuia smirnovi Shatalkin, 1994, male: A, whole mount specimen, lateral view; B, head, lateral view; C, head, dorsal view; D, mesosoma, lateral view; E, mesosoma, dorsal view; F, wing." figureDoi="http://doi.org/10.5281/zenodo.6404842" httpUri="https://zenodo.org/record/6404842/files/figure.png" pageId="1" pageNumber="96">Fig. 2D–E</figureCitation>
); costa with well-developed spinules (
<figureCitation id="ACA72A08E6257D54EA76D91E82A8FE83" box="[1103,1186,328,352]" captionStart="FIGURE 2" captionStartId="2.[151,250,1955,1979]" captionTargetBox="[151,1436,344,1908]" captionTargetId="figure-103@2.[151,1436,344,1931]" captionTargetPageId="2" captionText="FIGURE 2. Tenuia smirnovi Shatalkin, 1994, male: A, whole mount specimen, lateral view; B, head, lateral view; C, head, dorsal view; D, mesosoma, lateral view; E, mesosoma, dorsal view; F, wing." figureDoi="http://doi.org/10.5281/zenodo.6404842" httpUri="https://zenodo.org/record/6404842/files/figure.png" pageId="1" pageNumber="96">Fig. 2F</figureCitation>
); anterior coxa entirely black; 6 
<superScript id="C3E99BC5E6257D54EEC9D93C86F6FE9B" attach="left" box="[240,252,362,376]" fontSize="6" pageId="1" pageNumber="96">th</superScript>
sternite pentagonal cowl, crowned with two-horned massive prominence (
<figureCitation id="ACA72A08E6257D54EA09D93A82A3FE67" box="[1072,1193,364,388]" captionStart="FIGURE 3" captionStartId="3.[151,250,1792,1816]" captionTargetBox="[151,1436,181,1769]" captionTargetId="figure-20@3.[151,1436,181,1769]" captionTargetPageId="3" captionText="FIGURE 3. Tenuia smirnovi Shatalkin, 1994, male: A, abdomen, lateral view; B, abdomen, ventral view; C, sternite 6, ventrolateral view; D, epandrium, cerci &amp; surstyli, ventral view; E, epandrium, cerci &amp; surstyli, dorsal view; F, epandrium, cerci &amp; surstyli, lateral view; G, phallapodeme &amp; hypandrium, ventral view; H, phallapodeme &amp; hypandrium, lateral view (cerc = cerci; ejapod = ejaculatory apodeme; epand = epandrium; epand l = epandrial lobe; hypd = hypandrium; ph = phallus; phapod = phallapodeme; pgt = postgonite; pregt = pregonite; st 6 = sternite 6; sur = surstylus; syntgst 7+8 = syntergite 7+8)." figureDoi="http://doi.org/10.5281/zenodo.6404844" httpUri="https://zenodo.org/record/6404844/files/figure.png" pageId="1" pageNumber="96">Fig. 3A–C</figureCitation>
); syntergosternite 7+8 mostly bare of setae except towards posterior margin (
<figureCitation id="ACA72A08E6257D54ECEBD9C6852CFE4B" box="[722,806,400,424]" captionStart="FIGURE 3" captionStartId="3.[151,250,1792,1816]" captionTargetBox="[151,1436,181,1769]" captionTargetId="figure-20@3.[151,1436,181,1769]" captionTargetPageId="3" captionText="FIGURE 3. Tenuia smirnovi Shatalkin, 1994, male: A, abdomen, lateral view; B, abdomen, ventral view; C, sternite 6, ventrolateral view; D, epandrium, cerci &amp; surstyli, ventral view; E, epandrium, cerci &amp; surstyli, dorsal view; F, epandrium, cerci &amp; surstyli, lateral view; G, phallapodeme &amp; hypandrium, ventral view; H, phallapodeme &amp; hypandrium, lateral view (cerc = cerci; ejapod = ejaculatory apodeme; epand = epandrium; epand l = epandrial lobe; hypd = hypandrium; ph = phallus; phapod = phallapodeme; pgt = postgonite; pregt = pregonite; st 6 = sternite 6; sur = surstylus; syntgst 7+8 = syntergite 7+8)." figureDoi="http://doi.org/10.5281/zenodo.6404844" httpUri="https://zenodo.org/record/6404844/files/figure.png" pageId="1" pageNumber="96">Fig. 3A</figureCitation>
), but without an outstanding pair of setae, equal to length of 5 
<superScript id="C3E99BC5E6257D54EE9CD9E486BBFE23" attach="right" box="[165,177,434,448]" fontSize="6" pageId="1" pageNumber="96">th</superScript>
–6 
<superScript id="C3E99BC5E6257D54EEF2D9E486DDFE23" attach="left" box="[203,215,434,448]" fontSize="6" pageId="1" pageNumber="96">th</superScript>
tergites taken together; epandrium also without an outstanding pair of setae, equal to length of 4 
<superScript id="C3E99BC5E6257D54EAEED9E482E9FE23" attach="none" box="[1239,1251,434,448]" fontSize="6" pageId="1" pageNumber="96">th</superScript>
–6 
<superScript id="C3E99BC5E6257D54EAC7D9E48300FE23" attach="left" box="[1278,1290,434,448]" fontSize="6" pageId="1" pageNumber="96">th</superScript>
tergites taken together (
<figureCitation id="ACA72A08E6257D54EEC6D98E8779FE13" box="[255,371,472,496]" captionStart="FIGURE 3" captionStartId="3.[151,250,1792,1816]" captionTargetBox="[151,1436,181,1769]" captionTargetId="figure-20@3.[151,1436,181,1769]" captionTargetPageId="3" captionText="FIGURE 3. Tenuia smirnovi Shatalkin, 1994, male: A, abdomen, lateral view; B, abdomen, ventral view; C, sternite 6, ventrolateral view; D, epandrium, cerci &amp; surstyli, ventral view; E, epandrium, cerci &amp; surstyli, dorsal view; F, epandrium, cerci &amp; surstyli, lateral view; G, phallapodeme &amp; hypandrium, ventral view; H, phallapodeme &amp; hypandrium, lateral view (cerc = cerci; ejapod = ejaculatory apodeme; epand = epandrium; epand l = epandrial lobe; hypd = hypandrium; ph = phallus; phapod = phallapodeme; pgt = postgonite; pregt = pregonite; st 6 = sternite 6; sur = surstylus; syntgst 7+8 = syntergite 7+8)." figureDoi="http://doi.org/10.5281/zenodo.6404844" httpUri="https://zenodo.org/record/6404844/files/figure.png" pageId="1" pageNumber="96">Fig. 3D–F</figureCitation>
); epandrium with a pair of lobes on its posteroventral angles (
<figureCitation id="ACA72A08E6257D54EA2FD98E8262FE13" box="[1046,1128,472,496]" captionStart="FIGURE 3" captionStartId="3.[151,250,1792,1816]" captionTargetBox="[151,1436,181,1769]" captionTargetId="figure-20@3.[151,1436,181,1769]" captionTargetPageId="3" captionText="FIGURE 3. Tenuia smirnovi Shatalkin, 1994, male: A, abdomen, lateral view; B, abdomen, ventral view; C, sternite 6, ventrolateral view; D, epandrium, cerci &amp; surstyli, ventral view; E, epandrium, cerci &amp; surstyli, dorsal view; F, epandrium, cerci &amp; surstyli, lateral view; G, phallapodeme &amp; hypandrium, ventral view; H, phallapodeme &amp; hypandrium, lateral view (cerc = cerci; ejapod = ejaculatory apodeme; epand = epandrium; epand l = epandrial lobe; hypd = hypandrium; ph = phallus; phapod = phallapodeme; pgt = postgonite; pregt = pregonite; st 6 = sternite 6; sur = surstylus; syntgst 7+8 = syntergite 7+8)." figureDoi="http://doi.org/10.5281/zenodo.6404844" httpUri="https://zenodo.org/record/6404844/files/figure.png" pageId="1" pageNumber="96">Fig. 3F</figureCitation>
); surstyli displaced dorsally, slightly spoon-shaped with some setae on upper cuspidated margins (
<figureCitation id="ACA72A08E6257D54ED4AD9AA85CFFDF7" box="[883,965,508,532]" captionStart="FIGURE 3" captionStartId="3.[151,250,1792,1816]" captionTargetBox="[151,1436,181,1769]" captionTargetId="figure-20@3.[151,1436,181,1769]" captionTargetPageId="3" captionText="FIGURE 3. Tenuia smirnovi Shatalkin, 1994, male: A, abdomen, lateral view; B, abdomen, ventral view; C, sternite 6, ventrolateral view; D, epandrium, cerci &amp; surstyli, ventral view; E, epandrium, cerci &amp; surstyli, dorsal view; F, epandrium, cerci &amp; surstyli, lateral view; G, phallapodeme &amp; hypandrium, ventral view; H, phallapodeme &amp; hypandrium, lateral view (cerc = cerci; ejapod = ejaculatory apodeme; epand = epandrium; epand l = epandrial lobe; hypd = hypandrium; ph = phallus; phapod = phallapodeme; pgt = postgonite; pregt = pregonite; st 6 = sternite 6; sur = surstylus; syntgst 7+8 = syntergite 7+8)." figureDoi="http://doi.org/10.5281/zenodo.6404844" httpUri="https://zenodo.org/record/6404844/files/figure.png" pageId="1" pageNumber="96">Fig. 3E</figureCitation>
); lamellar lobe present, with setae on tip and connected with base of surstylus; cerci fused, forming a structure in the shape of two-topped tent distally, and with a pair of lateral lamellar appendages directed ventrally (
<figureCitation id="ACA72A08E6257D54EC8DDA128506FDBF" box="[692,780,580,604]" captionStart="FIGURE 3" captionStartId="3.[151,250,1792,1816]" captionTargetBox="[151,1436,181,1769]" captionTargetId="figure-20@3.[151,1436,181,1769]" captionTargetPageId="3" captionText="FIGURE 3. Tenuia smirnovi Shatalkin, 1994, male: A, abdomen, lateral view; B, abdomen, ventral view; C, sternite 6, ventrolateral view; D, epandrium, cerci &amp; surstyli, ventral view; E, epandrium, cerci &amp; surstyli, dorsal view; F, epandrium, cerci &amp; surstyli, lateral view; G, phallapodeme &amp; hypandrium, ventral view; H, phallapodeme &amp; hypandrium, lateral view (cerc = cerci; ejapod = ejaculatory apodeme; epand = epandrium; epand l = epandrial lobe; hypd = hypandrium; ph = phallus; phapod = phallapodeme; pgt = postgonite; pregt = pregonite; st 6 = sternite 6; sur = surstylus; syntgst 7+8 = syntergite 7+8)." figureDoi="http://doi.org/10.5281/zenodo.6404844" httpUri="https://zenodo.org/record/6404844/files/figure.png" pageId="1" pageNumber="96">Fig. 3D</figureCitation>
); hypandrium divided ventrally with tusk-like anterior lobes (
<figureCitation id="ACA72A08E6257D54EEA6DA3E871CFD63" box="[159,278,616,640]" captionStart="FIGURE 3" captionStartId="3.[151,250,1792,1816]" captionTargetBox="[151,1436,181,1769]" captionTargetId="figure-20@3.[151,1436,181,1769]" captionTargetPageId="3" captionText="FIGURE 3. Tenuia smirnovi Shatalkin, 1994, male: A, abdomen, lateral view; B, abdomen, ventral view; C, sternite 6, ventrolateral view; D, epandrium, cerci &amp; surstyli, ventral view; E, epandrium, cerci &amp; surstyli, dorsal view; F, epandrium, cerci &amp; surstyli, lateral view; G, phallapodeme &amp; hypandrium, ventral view; H, phallapodeme &amp; hypandrium, lateral view (cerc = cerci; ejapod = ejaculatory apodeme; epand = epandrium; epand l = epandrial lobe; hypd = hypandrium; ph = phallus; phapod = phallapodeme; pgt = postgonite; pregt = pregonite; st 6 = sternite 6; sur = surstylus; syntgst 7+8 = syntergite 7+8)." figureDoi="http://doi.org/10.5281/zenodo.6404844" httpUri="https://zenodo.org/record/6404844/files/figure.png" pageId="1" pageNumber="96">Fig. 3G–H</figureCitation>
); hypandrial apodeme bilobed and short (
<bibRefCitation id="500D4B7CE6257D54ECE9DA3E857DFD63" author="Shatalkin, A. I." box="[720,887,616,640]" pageId="1" pageNumber="96" pagination="129 - 145" refId="ref2327" refString="Shatalkin, A. I. (1994) Palaearctic species of Pseudopomyzidae (Diptera). Russian Entomological Journal, 3 (3 - 4), 129 - 145." type="journal article" year="1994">Shatalkin 1994</bibRefCitation>
).
</treatmentCitationGroup>
</paragraph>
