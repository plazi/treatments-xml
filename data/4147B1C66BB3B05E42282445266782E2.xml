<subSubSection id="3F98DA30ECC703AB0B4A66683E4200E2" pageId="null" pageNumber="283" type="description">
<paragraph id="B1760D48E24FBE638372D7DE7E7B6649" pageId="null" pageNumber="283">
Habitus wie 
<taxonomicName id="3CB2A61C18973275E20ACE95DB6DB443" class="Liliopsida" family="Poaceae" genus="Melica" kingdom="Plantae" order="Poales" pageId="null" pageNumber="283" phylum="Tracheophyta" rank="species" species="nutans">
<emphasis id="6BC4913B80D819D3F90B1201227BEE58" italics="true" pageId="null" pageNumber="283">M. nutans</emphasis>
</taxonomicName>
(Nr. 3). 
<emphasis id="BBE9CBA9BFA3642DC648F787D3B512E1" italics="true" pageId="null" pageNumber="283">
<normalizedToken id="F546774ECA5E5529EFFF7825EE64BAB0" originalValue="Blatthäutchen" pageId="null" pageNumber="283">Blatthaeutchen</normalizedToken>
bis 0,2 mm lang; dem 
<normalizedToken id="450C8486EB19B4DF5558AB1B00402B8E" originalValue="Blatthäutchen" pageId="null" pageNumber="283">Blatthaeutchen</normalizedToken>
<normalizedToken id="CF440624518AABD2D9146F150F9597EF" originalValue="gegenüber" pageId="null" pageNumber="283">gegenueber</normalizedToken>
ein spitzes, bis 4 mm langes, dem Stengel anliegendes 
<normalizedToken id="B922CF94B52B17D84BF7F99BEA017E5A" originalValue="Anhängsel" pageId="null" pageNumber="283">Anhaengsel</normalizedToken>
</emphasis>
(sonst bei keiner Art vorhanden). Rispe 4-15 cm lang, einseitswendig, sehr locker, oft nickend; die 
<emphasis id="201C8EFC51A6A3A2C3BE7AC63A901B6A" italics="true" pageId="null" pageNumber="283">
untersten 
<normalizedToken id="0D1B2F73B418AED5BA9F01828B70A970" originalValue="Rispenäste" pageId="null" pageNumber="283">Rispenaeste</normalizedToken>
4-6 cm lang, schief abstehend
</emphasis>
, mit 1-4 
<normalizedToken id="3686F1C864D720E80AAA52D10071B909" originalValue="Ährchen" pageId="null" pageNumber="283">Aehrchen</normalizedToken>
; 
<emphasis id="4EF5546276C79539378E74E72910463B" italics="true" pageId="null" pageNumber="283">
<normalizedToken id="B1D695296A5FEB088084450CC1C64DEC" originalValue="Rispenäste" pageId="null" pageNumber="283">Rispenaeste</normalizedToken>
unterhalb der Spelzen nicht behaart
</emphasis>
. 
<normalizedToken id="7A5052979FF6284EE3848D8D9DCE8FC6" originalValue="Ährchen" pageId="null" pageNumber="283">Aehrchen</normalizedToken>
bis 6 mm lang, 
<emphasis id="7428934EC9F6CA9D91EAB74B3BB1D8D1" italics="true" pageId="null" pageNumber="283">
mit 1 fertilen 
<normalizedToken id="E17B45E56D01158256356091B830AB67" originalValue="Blüte" pageId="null" pageNumber="283">Bluete</normalizedToken>
</emphasis>
, meist aufrecht. Die beiden 
<normalizedToken id="C38A1CB5813BAA141197D948EC6A593D" originalValue="Hüllspelzen" pageId="null" pageNumber="283">Huellspelzen</normalizedToken>
<normalizedToken id="2FF483DBB535B7A7C768C2C3855AACA9" originalValue="ungefähr" pageId="null" pageNumber="283">ungefaehr</normalizedToken>
gleich lang (bis 6 mm), mit aufgesetzter Spitze, 5nervig, rotviolett (meist bis zum Rande 
<normalizedToken id="3F1251D2A83261D4A3C2D7A4CC050E6A" originalValue="gefärbt" pageId="null" pageNumber="283">gefaerbt</normalizedToken>
). Deckspelzen mit 7 undeutlichen Nerven, 
<emphasis id="4B59BD35AEC08C4109D42E9FA6EAAD81" italics="true" pageId="null" pageNumber="283">kahl.</emphasis>
- 
<normalizedToken id="8CED149F59DE18EBFDB1211A169D8EFE" originalValue="Blüte" pageId="null" pageNumber="283">Bluete</normalizedToken>
: 
<normalizedToken id="97D3AFBE062EC9CE2CAB5CEC109F93BE" originalValue="Später" pageId="null" pageNumber="283">Spaeter</normalizedToken>
<normalizedToken id="E66293042DE563366E7E8EC824C6727D" originalValue="Frühling" pageId="null" pageNumber="283">Fruehling</normalizedToken>
bis Herbst.
</paragraph>
<paragraph id="64ED498E157E6013D8DA80FDCADF5CC4" pageId="null" pageNumber="283">
<emphasis id="E6C18B2FB0568616661280AB8F578586" italics="true" pageId="null" pageNumber="283">Zytologische Angaben. 2n = 18:</emphasis>
Material aus botanischen 
<normalizedToken id="87E75EB347CAEB77BEFD599897090887" originalValue="Gärten" pageId="null" pageNumber="283">Gaerten</normalizedToken>
(Wulff 1939c), aus Schweden (
<normalizedToken id="42558ACB84728CA6EF513F311B8DC1CF" originalValue="Löve" pageId="null" pageNumber="283">Loeve</normalizedToken>
und 
<normalizedToken id="68775236F6846452AB07877E929F7CCE" originalValue="Löve" pageId="null" pageNumber="283">Loeve</normalizedToken>
1944b), aus Holland (Gadella und Kliphuis 1963).
</paragraph>
<paragraph id="4A3AAA171F991472528332F72C7B82ED" pageId="null" pageNumber="283">
<emphasis id="0502538A4D43934E12A1DA9C3643F9B6" italics="true" pageId="null" pageNumber="283">Standort.</emphasis>
Kollin und montan. Meist kalkarme, lehmige, feuchte 
<normalizedToken id="623383EA493FFBB554E0C3AAB6D1B0D2" originalValue="Böden" pageId="null" pageNumber="283">Boeden</normalizedToken>
. 
<normalizedToken id="B344115D012893C7333786DA4D86F879" originalValue="Laubmischwälder" pageId="null" pageNumber="283">Laubmischwaelder</normalizedToken>
.
</paragraph>
<paragraph id="CD6D6B92CCFB5A1ECA64EF08F3F8D921" pageId="null" pageNumber="283">
<emphasis id="A27502CCE8D6ED2B14BD7196C4908D80" italics="true" pageId="null" pageNumber="283">
Verbreitung. 
<normalizedToken id="7738219E0BAD6D116EC8E90E517F7035" originalValue="Europäische" pageId="null" pageNumber="283">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="63D6A7FDC1FF0C62062A08B86894A6AA" originalValue="Nordwärts" pageId="null" pageNumber="283">Nordwaerts</normalizedToken>
bis Schottland, 
<normalizedToken id="9CB5888758AC60733AB6563C59DFB2F8" originalValue="Südskandinavien" pageId="null" pageNumber="283">Suedskandinavien</normalizedToken>
(60° NB), 
<normalizedToken id="FEBE631EB181263D68A15473F823BEED" originalValue="ostwärts" pageId="null" pageNumber="283">ostwaerts</normalizedToken>
bis 
<normalizedToken id="7C7B1A4150171CF8AA2EF10C9392E279" originalValue="Westrußland" pageId="null" pageNumber="283">Westrussland</normalizedToken>
und Kaukasus, 
<normalizedToken id="5510CAC14B1DCBE3DE5234A82048E022" originalValue="südwärts" pageId="null" pageNumber="283">suedwaerts</normalizedToken>
zerstreut bis Nordafrika und Kleinasien. Verbreitungskarte von Meusel (1964). - Im Gebiet aus St. Gallen, Appenzell, Glarus, 
<normalizedToken id="71241FAD932E84F2A922AB84937ED242" originalValue="Graubünden" pageId="null" pageNumber="283">Graubuenden</normalizedToken>
und der Innerschweiz nicht angegeben, in den 
<normalizedToken id="DD2F96A72DBCBA463210FAEA437E0C2B" originalValue="übrigen" pageId="null" pageNumber="283">uebrigen</normalizedToken>
Teilen zerstreut und viel seltener als 
<taxonomicName id="1BDEEAF097C6C8AB1B449DECBFB3027F" class="Liliopsida" family="Poaceae" genus="Melica" kingdom="Plantae" order="Poales" pageId="null" pageNumber="283" phylum="Tracheophyta" rank="species" species="nutans">
<emphasis id="F65F87E3814EAD968C98D22A27796650" italics="true" pageId="null" pageNumber="283">M. nutans</emphasis>
</taxonomicName>
(Nr. 3).
</paragraph>
</subSubSection>
