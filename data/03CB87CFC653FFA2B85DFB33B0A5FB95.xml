Key to species of 
<taxonomicName id="4C624D5AC652FFA2BBD6FE65B2B3FE33" authority="Pettibone, 1997" authorityName="Pettibone" authorityYear="1997" box="[442,909,437,464]" class="Polychaeta" family="Sigalionidae" genus="Hartmanipsammolyce" kingdom="Animalia" order="Phyllodocida" pageId="13" pageNumber="14" phylum="Annelida" rank="genus">
<emphasis id="B916EACBC652FFA2BBD6FE65B3FBFE33" bold="true" box="[442,709,437,464]" italics="true" pageId="13" pageNumber="14">Hartmanipsammolyce</emphasis>
<bibRefCitation id="EFF34B28C652FFA2B8A0FE66B2B3FE33" author="Pettibone M. H." box="[716,909,438,464]" pageId="13" pageNumber="14" pagination="1 - 89" refId="ref30430" refString="Pettibone M. H. 1997. Revision of the sigalionid species (Polychaeta) referred to Psammolyce Kinberg, 1856, Pelogenia Schmarda, 1861, and belonging to the subfamily Pelogeniinae Chamberlin, 1919. Smithsonian Contributions to Zoology 581: 1 - 89. https: // doi. org / 10.5479 / si. 00810282.581" type="journal article" year="1997">Pettibone, 1997</bibRefCitation>
</taxonomicName>
