<subSubSection id="3C5850027019C9E562B10D7DAD828368" pageId="null" pageNumber="151" type="nomenclature">
<paragraph id="0BBF87EFE6D7E31E1B29F09264780E32" pageId="null" pageNumber="151">
<taxonomicName id="094F27F9EB260A89B4C6C5D23612E1AE" authority="L." class="Polypodiopsida" family="Equisetaceae" genus="Equisetum" kingdom="Plantae" order="Equisetales" pageId="null" pageNumber="151" phylum="Tracheophyta" rank="species" species="palustre">
Equisetum 
<normalizedToken id="5F2806FFD32CB61E0C190B142D745AB8" originalValue="palústre" pageId="null" pageNumber="151">palustre</normalizedToken>
<authorityName id="52037FC279457F0DAB0F25D96C5705E3" pageId="null" pageNumber="151">L.</authorityName>
