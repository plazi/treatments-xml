<taxonomicName id="4C284682FFFAC10C7FFBFA1CFD5EF399" authority="(Bosch &amp; Sande Lac.) S. He" authorityName="S. He" baseAuthorityName="Bosch &amp; Sande Lac." box="[164,711,1454,1481]" class="Bryopsida" family="Hypnaceae" genus="Phyllodon" kingdom="Plantae" order="Hypnales" pageId="10" pageNumber="235" phylum="Bryophyta" rank="species" species="similans">
<emphasis id="B95CE113FFFAC10C7FFBFA1CFE18F399" bold="true" box="[164,385,1454,1481]" italics="true" pageId="10" pageNumber="235">Phyllodon similans</emphasis>
