<collectingRegion id="0650F81CFF726ACDF93C91201925BCA8" box="[1728,1829,1913,1946]" country="China" name="Hunan" pageId="137" pageNumber="897">Hunan</collectingRegion>
, 
<collectingRegion id="0650F81CFF726ACDF8C7912019E3BCA8" box="[1851,2019,1913,1946]" country="China" name="Guangdong" pageId="137" pageNumber="897">Guangdong</collectingRegion>
, 
<collectingRegion id="0650F81CFF726ACDF80F9120165BBCA8" box="[2035,2139,1913,1946]" country="China" name="Jiangxi" pageId="137" pageNumber="897">Jiangxi</collectingRegion>
, and 
<collectingRegion id="0650F81CFF726ACDF74891201713BCA8" box="[2228,2323,1913,1946]" country="China" name="Fujian" pageId="137" pageNumber="897">Fujian</collectingRegion>
), including 
<collectingRegion id="0650F81CFF726ACDF63A9120142EBCA8" box="[2502,2606,1913,1946]" country="China" name="Hainan" pageId="137" pageNumber="897">Hainan</collectingRegion>
and 
<collectingCountry id="BC83766EFF726ACDFA4691FD181CBCF3" box="[1466,1564,1956,1985]" name="Taiwan" pageId="137" pageNumber="897">Taiwan</collectingCountry>
Is, and N 
<collectingCountry id="BC83766EFF726ACDF95791FD1925BCF3" box="[1707,1829,1956,1985]" name="Vietnam" pageId="137" pageNumber="897">Vietnam</collectingCountry>
.
