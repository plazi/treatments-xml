<subSubSection box="[1414,2010,2754,2787]" pageId="35" pageNumber="161" type="breeding">
<paragraph blockId="35.[1413,2619,1968,3062]" box="[1414,2010,2754,2787]" pageId="35" pageNumber="161">
<emphasis bold="true" box="[1414,1548,2754,2787]" pageId="35" pageNumber="161">Breeding.</emphasis>
