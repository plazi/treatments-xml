Type series of 
<taxonomicName authority="Klapalek, 1912" authorityName=": Klapalek" authorityYear="1912" box="[438,813,812,836]" class="Insecta" family="Perlodidae" genus="Perlodinella" kingdom="Animalia" order="Plecoptera" pageId="2" pageNumber="380" phylum="Arthropoda" rank="species" species="kozlovi">
<emphasis box="[438,645,812,836]" italics="true" pageId="2" pageNumber="380">Perlodinella kozlovi</emphasis>
<bibRefCitation author="Klapalek, F." box="[653,813,812,836]" pageId="2" pageNumber="380" pagination="1 - 66" refId="ref4895" refString="Klapalek, F. (1912) Plecopteres I. Fam. Perlodidae. Collections Zoologiques du Baron Edm. de Selys-Longchamps, 4 (1), 1 - 66." type="journal article" year="1912">Klapálek, 1912</bibRefCitation>
