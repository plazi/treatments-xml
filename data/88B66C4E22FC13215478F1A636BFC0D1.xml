<normalizedToken id="F654339550DFBE205D0C9CAE688478D9" originalValue="alpínum" pageId="null" pageNumber="306">alpinum</normalizedToken>
<authorityName id="AE1DC77B0F8353F410D6BAFCC3D6DD03" pageId="null" pageNumber="306">L.</authorityName>
