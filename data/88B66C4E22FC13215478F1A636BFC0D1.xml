<taxonomicName id="38CFFF212FAB7D4F668D6522E2D61CA9" authority="L." class="Magnoliopsida" family="Grossulariaceae" genus="Ribes" kingdom="Plantae" order="Saxifragales" pageId="null" pageNumber="306" phylum="Tracheophyta" rank="species" species="alpinum">
