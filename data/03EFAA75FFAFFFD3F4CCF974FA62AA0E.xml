Key to 
<taxonomicName id="4C4660E0FFAFFFD3F499F974FE7EA4C9" authority="Schulz (1924: 267)" authorityName="Schulz" authorityPageNumber="267" authorityYear="1924" box="[221,438,1720,1747]" class="Magnoliopsida" family="Brassicaceae" genus="Lemphoria" higherTaxonomySource="GBIF" kingdom="Plantae" order="Brassicales" pageId="2" pageNumber="237" phylum="Tracheophyta" rank="genus">
