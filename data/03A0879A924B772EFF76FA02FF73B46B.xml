<subSubSection id="C3136507924C772EFF43F9E2FA15BB03" pageId="28" pageNumber="181" type="materials_examined">
<paragraph id="8BB6368C924C772EFF43F9E2FB8EBA96" blockId="28.[136,1452,1586,2080]" pageId="28" pageNumber="181">
