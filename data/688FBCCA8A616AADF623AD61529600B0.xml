<subSubSection id="128BACBB7A2935532FBC3C9823A59685" pageId="null" pageNumber="226" type="vernacular_names">
<paragraph id="4191CC08EBCCD4661C532ACC1E0FE829" pageId="null" pageNumber="226">
Rosafarbenes 
<normalizedToken id="D187D90792540B600A2C145CEA69BCF2" originalValue="Läusekraut" pageId="null" pageNumber="226">Laeusekraut</normalizedToken>
</paragraph>
