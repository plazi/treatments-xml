<date id="C10E105406222E6EFA0AF924FF1D2103" pageId="8" pageNumber="309" value="2005-12-04">4- 12-2005</date>
, 
<quantity id="72489B7106222E6EFE8BF900FE812103" box="[260,363,1071,1097]" metricMagnitude="1" metricUnit="m" metricValue="9.7" metricValueMax="9.8" metricValueMin="9.6" pageId="8" pageNumber="309" unit="m" value="97.0" valueMax="98.0" valueMin="96.0">96–98 m</quantity>
, specimen details not available; South Coast, 
<geoCoordinate id="D084505306222E6EFCF9F901FC382103" box="[886,978,1070,1097]" degrees="35.35" direction="south" orientation="latitude" pageId="8" pageNumber="309" precision="555" value="-35.35">35.35°S</geoCoordinate>
