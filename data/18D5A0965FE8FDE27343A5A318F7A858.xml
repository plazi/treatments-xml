<subSubSection id="F14A0CEBB7135CB38C3B1363C9A21CD4" pageId="null" pageNumber="119" type="description">
<paragraph id="A92933A99B9510AAAAA1F10F25A9A896" pageId="null" pageNumber="119">
<normalizedToken id="CBD7E941E74136C4F20C3260675C7DB0" originalValue="Blätter" pageId="null" pageNumber="119">Blaetter</normalizedToken>
bis 3,5 cm breit und bis 5 cm lang. 
<emphasis id="46B19CE6EEC4508CF8BF93F7AEB59A65" italics="true" pageId="null" pageNumber="119">
<normalizedToken id="2F7CE55B3B664B51F07B61933059BE1D" originalValue="Kelchzähne" pageId="null" pageNumber="119">Kelchzaehne</normalizedToken>
breit 3eckig, 2
</emphasis>
- 
<emphasis id="407FA5F992B031C7D32005A7BD667FFD" italics="true" pageId="null" pageNumber="119">2,5 mm lang</emphasis>
(
<emphasis id="1A2E136B50E8A1E0D387D654550E2E1C" italics="true" pageId="null" pageNumber="119">mit der 0,2 bis 0,5 mm langen Stachelspitze</emphasis>
). - 
<normalizedToken id="6580E503DEA163A8764D18B991D2AB1C" originalValue="Blüte" pageId="null" pageNumber="119">Bluete</normalizedToken>
: 
<normalizedToken id="6D60F9BB16CBA20AA5BC91EE657BA844" originalValue="Später" pageId="null" pageNumber="119">Spaeter</normalizedToken>
<normalizedToken id="68ECBA61E809B2A9AAF1E318202C8A5D" originalValue="Frühling" pageId="null" pageNumber="119">Fruehling</normalizedToken>
, Sommer und 
<normalizedToken id="7B598C6C59480E4F35F25C653024FFFA" originalValue="früher" pageId="null" pageNumber="119">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="61BABB7F5EC2179C855BE8F3610BCFEB" pageId="null" pageNumber="119">
<emphasis id="E205599E99F991E44DC533D8A2E9AEF0" italics="true" pageId="null" pageNumber="119">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5209B88F345B366C38262CD88A0FFC07" italics="true" pageId="null" pageNumber="119">22:</emphasis>
Material aus 
<normalizedToken id="F83A48F8818BAA8DADB7A18ACAAF1AE1" originalValue="Großbritannien" pageId="null" pageNumber="119">Grossbritannien</normalizedToken>
, als 
<taxonomicName id="9B80DE24FB83354C2F22B5EBEBCFC447" class="Magnoliopsida" family="Lamiaceae" genus="Ballota" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="119" phylum="Tracheophyta" rank="species" species="nigra">
<emphasis id="526F8F927817F77BA413A5984EDE0C99" italics="true" pageId="null" pageNumber="119">B. nigra</emphasis>
</taxonomicName>
bezeichnet (Rutland 1941), aus den Niederlanden, als 
<taxonomicName id="859BB3AE2C80157BE7645D4B7222109B" class="Magnoliopsida" family="Lamiaceae" genus="Ballota" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="119" phylum="Tracheophyta" rank="species" species="nigra">
<emphasis id="23E5B94D3101362753792A4005AE313E" italics="true" pageId="null" pageNumber="119">B. nigra</emphasis>
</taxonomicName>
bezeichnet (Gadella und Kliphuis 1963 1966).
</paragraph>
<paragraph id="3AF4F7E3BBBFF6823993F39503B7871C" pageId="null" pageNumber="119">
<emphasis id="8146E88037717637FE242FE17E50BED9" italics="true" pageId="null" pageNumber="119">Standort.</emphasis>
Kollin und montan, selten subalpin. Ziemlich feuchte, stickstoffreiche, lockere 
<normalizedToken id="E2799C01AF73ECFD0B690F893E09DF96" originalValue="Böden" pageId="null" pageNumber="119">Boeden</normalizedToken>
in 
<normalizedToken id="C9BEAD17C85F4D6AEAE1228F9DE4952B" originalValue="wärmeren" pageId="null" pageNumber="119">waermeren</normalizedToken>
Lagen. 
<normalizedToken id="B99E5EFCA14B55E09D5E16DB4A9D77DE" originalValue="Wegränder" pageId="null" pageNumber="119">Wegraender</normalizedToken>
, 
<normalizedToken id="BB7B140C8733147CB8BE0A52AC4673BE" originalValue="Schuttplätze" pageId="null" pageNumber="119">Schuttplaetze</normalizedToken>
, Hausmauern.
</paragraph>
<paragraph id="5478C98B5941CF49E999521ECA9CE1E5" pageId="null" pageNumber="119">
<emphasis id="F8ADD04DD9F8761B3668870A6DB01E3E" italics="true" pageId="null" pageNumber="119">Verbreitung. Westmediterrane Pflanze:</emphasis>
Nord- und 
<normalizedToken id="68D98C1DEE703FD0C8FE1CDB15BB6498" originalValue="ostwärts" pageId="null" pageNumber="119">ostwaerts</normalizedToken>
vereinzelt bis 
<normalizedToken id="01F59DFCFA24D8DA1240C8F52630881A" originalValue="Südschweden" pageId="null" pageNumber="119">Suedschweden</normalizedToken>
, 
<normalizedToken id="C9557FAE1B0C955AD38782CA497CA878" originalValue="Dänemark" pageId="null" pageNumber="119">Daenemark</normalizedToken>
, 
<normalizedToken id="EB44411B06F56D25F821F6D6A3ED605E" originalValue="Oberösterreich" pageId="null" pageNumber="119">Oberoesterreich</normalizedToken>
und Bulgarien; Marokko; sonst oft verschleppt. - Im Gebiet in 
<normalizedToken id="753FCA84B064247730C0DB2AE5C00903" originalValue="wärmeren" pageId="null" pageNumber="119">waermeren</normalizedToken>
Gegenden, nicht 
<normalizedToken id="5039C096A660E841F1E2B2C5AD4796DB" originalValue="häufig" pageId="null" pageNumber="119">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
