<taxonomicName id="72B04D17063F2E73FD00FCF5FC5924BE" authorityName="Stimpson" authorityYear="1858" box="[655,947,474,500]" class="Malacostraca" family="Dromiidae" genus="Cryptodromia" kingdom="Animalia" order="Decapoda" pageId="21" pageNumber="322" phylum="Arthropoda" rank="species" species="tuberculata">
