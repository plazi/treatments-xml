<subSubSection id="C31343D2FFC9FFAC6180FD90C67CFC04" pageId="5" pageNumber="306" type="discussion">
<paragraph id="8BB61059FFC9FFAC6180FD90C67CFC04" blockId="5.[151,1437,474,897]" pageId="5" pageNumber="306">
<emphasis id="B97DCC4BFFC9FFAC6180FD90C460FDE5" bold="true" box="[199,315,582,608]" pageId="5" pageNumber="306">Remarks.</emphasis>
This species is a member of ‘ 
<taxonomicName id="4C096BDAFFC9FFAC63CEFD90C6D6FDE5" baseAuthorityName="Trouessart" baseAuthorityYear="1899" box="[649,909,582,608]" class="Arachnida" family="Halacaridae" genus="Copidognathus" kingdom="Animalia" order="Trombidiformes" pageId="5" pageNumber="306" phylum="Arthropoda" rank="species" species="spinula">
<emphasis id="B97DCC4BFFC9FFAC63CEFD90C6D6FDE5" box="[649,909,582,608]" italics="true" pageId="5" pageNumber="306">Copidognathus spinula</emphasis>
</taxonomicName>
group’ (a subdivision of 
<taxonomicName id="4C096BDAFFC9FFAC65E0FD90C0C7FDE5" authorityName="Newell" authorityYear="1947" box="[1191,1436,582,608]" class="Arachnida" family="Halacaridae" genus="Copidognathus" kingdom="Animalia" order="Trombidiformes" pageId="5" pageNumber="306" phylum="Arthropoda" rank="species" species="bairdi">
<emphasis id="B97DCC4BFFC9FFAC65E0FD90C0C7FDE5" box="[1191,1436,582,608]" italics="true" pageId="5" pageNumber="306">Copidognathus bairdi</emphasis>
</taxonomicName>
group) (
<bibRefCitation id="EF986DA8FFC9FFAC61B6FDBCC4D6FD01" author="Bartsch, I." box="[241,397,618,644]" pageId="5" pageNumber="306" pagination="231 - 243" refId="ref8699" refString="Bartsch, I. (1997) Copidognathinae (Halacaridae, Acari) from northern Australia; description of four new species. In: Hanley, J. R., Caswell, G., Megirian, D. &amp; Larson, H. K. (Eds.), Proceedings of the Sixth International Biological Workshop. Museums &amp; Art Galleries of Northern Territory, Darwin, pp. 231 - 243." type="book chapter" year="1997">Bartsch 1997</bibRefCitation>
). This group is characterised by: Prominent frontal spine on AD; telofemur I with one huge ventral spine (lamella); genu IV with 4 setae; telofemora III-IV without any ventral seta; tarsi III and IV with 4 dorsal setae; two pairs of prominent gland pores on posterior half of PD; dorsal setae 1 on anterior half of anterodorsal plate, dorsal setae 2 on anterior corner of OC, dorsal setae 3-5 on PD (Chatterjee &amp; Annapurna 2003). Four species were recorded so far under this natural group: 
<taxonomicName id="4C096BDAFFC9FFAC63D9FD2DC684FC91" authority="(Trouessart 1899)" baseAuthorityName="Trouessart" baseAuthorityYear="1899" box="[670,991,762,789]" class="Arachnida" family="Halacaridae" genus="Copidognathus" kingdom="Animalia" order="Trombidiformes" pageId="5" pageNumber="306" phylum="Arthropoda" rank="species" species="spinula">
<emphasis id="B97DCC4BFFC9FFAC63D9FD2DC64AFC91" box="[670,785,762,789]" italics="true" pageId="5" pageNumber="306">C. spinula</emphasis>
(
<bibRefCitation id="EF986DA8FFC9FFAC6267FD2CC68CFC91" author="Trouessart, E. L." box="[800,983,762,788]" pageId="5" pageNumber="306" pagination="209 - 223" refId="ref13838" refString="Trouessart, E. L. (1899) Description d'especes nouvelles d'Halacaridae. Bulletin de la Societe d' etudes Scientifiques d'Angers, 29, 209 - 223 + 226 - 227." type="journal article" year="1899">Trouessart 1899</bibRefCitation>
)
</taxonomicName>
from 
<collectingCountry id="F31E50C9FFC9FFAC6564FD2CC1D9FC91" box="[1059,1154,762,788]" name="Vietnam" pageId="5" pageNumber="306">Vietnam</collectingCountry>
among algae (
<bibRefCitation id="EF986DA8FFC9FFAC6462FD2CC589FCBD" author="Trouessart, E. L." pageId="5" pageNumber="306" pagination="209 - 223" refId="ref13838" refString="Trouessart, E. L. (1899) Description d'especes nouvelles d'Halacaridae. Bulletin de la Societe d' etudes Scientifiques d'Angers, 29, 209 - 223 + 226 - 227." type="journal article" year="1899">Trouessart 1899</bibRefCitation>
; 
<bibRefCitation id="EF986DA8FFC9FFAC619AFCC8C4D8FCBC" author="Bartsch, I." box="[221,387,798,825]" pageId="5" pageNumber="306" pagination="229 - 241" refId="ref8627" refString="Bartsch, I. (1992 b) Halacaridae (Acari) from Hong Kong. Three new species of Copidognathus. Entomologische Mitteilungen aus dem Zoologischen Museum Hamburg, 10, 229 - 241." type="journal article" year="1992">Bartsch 1992b</bibRefCitation>
); 
<taxonomicName id="4C096BDAFFC9FFAC60D2FCC9C781FCBD" authority="Bartsch, 1989" authorityName="Bartsch" authorityYear="1989" box="[405,730,798,825]" class="Arachnida" family="Halacaridae" genus="Copidognathus" kingdom="Animalia" order="Trombidiformes" pageId="5" pageNumber="306" phylum="Arthropoda" rank="species" species="unispinosus">
<emphasis id="B97DCC4BFFC9FFAC60D2FCC9C4F3FCBC" box="[405,424,799,825]" italics="true" pageId="5" pageNumber="306">C</emphasis>
. 
<emphasis id="B97DCC4BFFC9FFAC60F2FCC9C762FCBD" box="[437,569,799,824]" italics="true" pageId="5" pageNumber="306">unispinosus</emphasis>
<bibRefCitation id="EF986DA8FFC9FFAC6378FCC8C781FCBD" author="Bartsch, I." box="[575,730,798,824]" pageId="5" pageNumber="306" pagination="138 - 148" refId="ref8522" refString="Bartsch, I. (1989) New species of Copidognathus (Acari: Halacaridae) from Hawaiian Islands. Occasional Papers, Bernice P. Bishop Museum, 29, 138 - 148." type="journal article" year="1989">Bartsch, 1989</bibRefCitation>
</taxonomicName>
from Haiwaiian Island (
<bibRefCitation id="EF986DA8FFC9FFAC62A0FCC8C1DBFCBD" author="Bartsch, I." box="[999,1152,798,824]" pageId="5" pageNumber="306" pagination="138 - 148" refId="ref8522" refString="Bartsch, I. (1989) New species of Copidognathus (Acari: Halacaridae) from Hawaiian Islands. Occasional Papers, Bernice P. Bishop Museum, 29, 138 - 148." type="journal article" year="1989">Bartsch 1989</bibRefCitation>
); 
<taxonomicName id="4C096BDAFFC9FFAC65D4FCC9C0C7FCBD" authority="Chatterje, 1991" authorityName="Chatterjee" authorityYear="1991" box="[1171,1436,798,825]" class="Arachnida" family="Halacaridae" genus="Copidognathus" kingdom="Animalia" order="Trombidiformes" pageId="5" pageNumber="306" phylum="Arthropoda" rank="species" species="gitae">
<emphasis id="B97DCC4BFFC9FFAC65D4FCC9C1B0FCBD" box="[1171,1259,799,825]" italics="true" pageId="5" pageNumber="306">C. gitae</emphasis>
Chatterje, 1991
</taxonomicName>
from Palm beach, Visakhapatnam, 
<collectingCountry id="F31E50C9FFC9FFAC636FFC94C739FCD9" box="[552,610,834,860]" name="India" pageId="5" pageNumber="306">India</collectingCountry>
(
<bibRefCitation id="EF986DA8FFC9FFAC6335FC94C661FCD9" author="Chatterjee, T." box="[626,826,834,860]" pageId="5" pageNumber="306" pagination="272 - 275" refId="ref9855" refString="Chatterjee, T. (1991 b) Copidognathus gitae, a new species of Halacaridae (Acari) from Visakhapatnam coast, Bay of Bengal. Journal of the Bombay Natural History Society, 88, 272 - 275." type="journal article" year="1991">Chatterjee 1991b</bibRefCitation>
; Chatterjee &amp; Annapurna 2003) and 
<taxonomicName id="4C096BDAFFC9FFAC65A3FC95C468FC05" authority="Bartsch, 1992" authorityName="Bartsch" authorityYear="1992" class="Arachnida" family="Halacaridae" genus="Copidognathus" kingdom="Animalia" order="Trombidiformes" pageId="5" pageNumber="306" phylum="Arthropoda" rank="species" species="monacanthus">
<emphasis id="B97DCC4BFFC9FFAC65A3FC95C1ACFCD8" box="[1252,1271,835,861]" italics="true" pageId="5" pageNumber="306">C</emphasis>
. 
<emphasis id="B97DCC4BFFC9FFAC6440FC94C0C7FCD9" box="[1287,1436,834,860]" italics="true" pageId="5" pageNumber="306">monacanthus</emphasis>
Bartsch, 1992
</taxonomicName>
recorded from 
<collectingCountry id="F31E50C9FFC9FFAC60A7FCB1C738FC04" box="[480,611,871,897]" name="Hong Kong" pageId="5" pageNumber="306">Hong Kong</collectingCountry>
(
<bibRefCitation id="EF986DA8FFC9FFAC6335FCB0C640FC04" author="Bartsch, I." box="[626,795,870,897]" pageId="5" pageNumber="306" pagination="229 - 241" refId="ref8627" refString="Bartsch, I. (1992 b) Halacaridae (Acari) from Hong Kong. Three new species of Copidognathus. Entomologische Mitteilungen aus dem Zoologischen Museum Hamburg, 10, 229 - 241." type="journal article" year="1992">Bartsch 1992b</bibRefCitation>
