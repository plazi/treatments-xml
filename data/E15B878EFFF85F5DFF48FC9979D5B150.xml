<taxonomicName id="AEF24D1BFFF85F5CFF48FC997C50B032" authorityName="Dlussky et Radchenko" box="[166,328,840,867]" class="Insecta" family="Formicidae" genus="Eocenomyrma" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="10" pageNumber="405" phylum="Arthropoda" rank="species" species="orthospina">
