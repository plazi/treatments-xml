<bibRefCitation id="EFCB64893E433C689EF2FEBAF3BBFEA5" author="Schmidt, G. D. &amp; Kuntz, R. E." box="[240,505,303,330]" pageId="9" pageNumber="204" pagination="329 - 334" refId="ref12058" refString="Schmidt, G. D., Kuntz, R. E. Centrorhynchus spilornae sp. n. (Acanthocephla), and other Centrorhynchidae from the Far East // Journal of Parasitology. - 1969. - 55. - P. 329 - 334." type="book chapter" year="1969">Schmidt, Kuntz, 1969</bibRefCitation>
