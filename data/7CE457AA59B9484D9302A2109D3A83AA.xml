<subSubSection id="5F8368AE2EE41D5AAE36D35DDC2DA0DF" pageId="null" pageNumber="119" type="description">
<paragraph id="52B2ED57798F4673080E14063D62B365" pageId="null" pageNumber="119">
<emphasis id="DD3A251FFC6A45DF819C2D4D045610D4" italics="true" pageId="null" pageNumber="119">
Kelch 
<normalizedToken id="8594812F9DC878828000F646E1A678FA" originalValue="trichterförmig" pageId="null" pageNumber="119">trichterfoermig</normalizedToken>
</emphasis>
, 10nervig (
<emphasis id="FDC7F5AD16AC49048202F93CC1CCE7C9" italics="true" pageId="null" pageNumber="119">Nerven als starke Rippen hervortretend</emphasis>
), 5-10 
<normalizedToken id="8F8DEEF1AB81DED78EDF24C31ECA4CD0" originalValue="zähnig" pageId="null" pageNumber="119">zaehnig</normalizedToken>
(
<normalizedToken id="70880A50B1721BAEAC51F497A9D60FF4" originalValue="Zähne" pageId="null" pageNumber="119">Zaehne</normalizedToken>
oft kranzartig verwachsen). Krone mit 
<normalizedToken id="E2B174661992610B189BF03BA006863B" originalValue="Röhre" pageId="null" pageNumber="119">Roehre</normalizedToken>
und 2lippigem Rand; Oberlippe aufrecht 
<normalizedToken id="A0666902685C5BE914AC5BA5DDEC41BA" originalValue="gewölbt" pageId="null" pageNumber="119">gewoelbt</normalizedToken>
(
<normalizedToken id="D6CFF30F153620A7C1997C726FA1B7F7" originalValue="Ränder" pageId="null" pageNumber="119">Raender</normalizedToken>
nach unten gebogen), vorn ausgerandet, dicht behaart; Unterlippe 3teilig, Mittelabschnitt 
<normalizedToken id="DC71B5284AFF35A2F3FBE46CEBC01254" originalValue="größer" pageId="null" pageNumber="119">groesser</normalizedToken>
als die Seitenabschnitte. 
<normalizedToken id="E52D35A467D5C742E6FDC853613D1C50" originalValue="Staubblätter" pageId="null" pageNumber="119">Staubblaetter</normalizedToken>
4, unter der Oberlippe aufsteigend, mit spreizenden 
<normalizedToken id="2FFEE35D6799245C68248844011C2BB4" originalValue="Staubbeutelhälften" pageId="null" pageNumber="119">Staubbeutelhaelften</normalizedToken>
. 
<normalizedToken id="8E3ACA6D99DECE1D6C19352AF6818F02" originalValue="Teilfrüchte" pageId="null" pageNumber="119">Teilfruechte</normalizedToken>
<normalizedToken id="AF2CBAA5A14FDAF8FBFE0D06109186AA" originalValue="eiförmig" pageId="null" pageNumber="119">eifoermig</normalizedToken>
, 3kantig, glatt.
</paragraph>
<paragraph id="4E34738ABFB02842121C9E0EFB170DE9" pageId="null" pageNumber="119">
Die Gattung 
<taxonomicName id="3CE64402DF08DA704BF37EE4C3FCC055" class="Magnoliopsida" family="Lamiaceae" genus="Ballota" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="119" phylum="Tracheophyta" rank="genus">
<emphasis id="45BE6E179DA0F82C4EEF506854F3F96E" italics="true" pageId="null" pageNumber="119">Ballota</emphasis>
</taxonomicName>
<normalizedToken id="0F5A896ADFDA80A75C5B0BE359E2E3CF" originalValue="umfaßt" pageId="null" pageNumber="119">umfasst</normalizedToken>
<emphasis id="7B71113B101039F0D847769BC5FD8DB8" italics="true" pageId="null" pageNumber="119">25</emphasis>
- 
<emphasis id="77D945294206982D7685F1F7CA964126" italics="true" pageId="null" pageNumber="119">30 meist mediterrane Arten.</emphasis>
Im Gebiet 
<normalizedToken id="DB5D8611E4938AED57EAC5D89C054DA4" originalValue="wächst" pageId="null" pageNumber="119">waechst</normalizedToken>
nur 1 Artengruppe mit 2 Arten.
</paragraph>
