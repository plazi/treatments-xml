<subSubSection id="B02172DC28ED93DC2A2D37ED49967A8D" pageId="null" pageNumber="660" type="description">
<paragraph id="2E5442AE406BE9C68ABA598E175E5267" pageId="null" pageNumber="660">
1 
<normalizedToken id="4AD5EE652A1E37DC9340085CE18B2B85" originalValue="jährig" pageId="null" pageNumber="660">jaehrig</normalizedToken>
, 
<emphasis id="76AF9627B565895D79CFE45F090A8D60" italics="true" pageId="null" pageNumber="660">
mit einfacher Pfahlwurzel, 
<normalizedToken id="7B9577C7B26094C2460B253E5E9F7BD0" originalValue="gelbgrün" pageId="null" pageNumber="660">gelbgruen</normalizedToken>
</emphasis>
, kahl oder zerstreut flaumig behaart. 
<emphasis id="A482EB0FA4A52E206E3C27DE08BED270" italics="true" pageId="null" pageNumber="660">Stengel meist 1, nicht verzweigt, oder erst im obern Teil verzweigt.</emphasis>
<normalizedToken id="23AD546EF840EA7A1F3D45705C95399D" originalValue="Stengelblätter" pageId="null" pageNumber="660">Stengelblaetter</normalizedToken>
<normalizedToken id="BCB43BB9B302FF717AD919AF09CEC5A1" originalValue="wechselständig" pageId="null" pageNumber="660">wechselstaendig</normalizedToken>
, zur Zeit der Fruchtreife meist abgefallen, lanzettlich, mit der 
<normalizedToken id="ED4106D02155A7033F61946291F710E1" originalValue="größten" pageId="null" pageNumber="660">groessten</normalizedToken>
Breite meist 
<normalizedToken id="296F325BEB15D34C1A7EF04585952A20" originalValue="über" pageId="null" pageNumber="660">ueber</normalizedToken>
der Mitte, 2-4 cm lang, etwa 3mal so lang wie breit, mit ca. 0,1 mm langen 
<normalizedToken id="44C344F2521DCA7D6098EFFE6A4D0023" originalValue="Zähnen" pageId="null" pageNumber="660">Zaehnen</normalizedToken>
, am Grunde nicht 
<normalizedToken id="CB75235E198A577301418FBF7EB20C4F" originalValue="gezähnt" pageId="null" pageNumber="660">gezaehnt</normalizedToken>
und dort deutlich 
<emphasis id="E360DED0B9F297B05892B0B4C99ADE0E" italics="true" pageId="null" pageNumber="660">ausgerandet oder gestutzt.</emphasis>
<normalizedToken id="46E3902413FB1393EC602167040ED114" originalValue="Nebenblätter" pageId="null" pageNumber="660">Nebenblaetter</normalizedToken>
keine. 
<normalizedToken id="0F6655B1C81ABA173BAFCCABF634A8C9" originalValue="Endständiger" pageId="null" pageNumber="660">Endstaendiger</normalizedToken>
<normalizedToken id="50741323B7698D7685E0C6D0D0C40378" originalValue="Gesamtblütenstand" pageId="null" pageNumber="660">Gesamtbluetenstand</normalizedToken>
doldenartig, mit 
<normalizedToken id="F791255AF6DE4A75D65D6714E5F1980F" originalValue="höchstens" pageId="null" pageNumber="660">hoechstens</normalizedToken>
5 Stielen 1. Ordnung (diese oft mehrfach gabelig verzweigt). 
<normalizedToken id="002AD66BAB411839B0E599A4E5D1F97E" originalValue="Tragblätter" pageId="null" pageNumber="660">Tragblaetter</normalizedToken>
nicht verwachsen, breit 3eckig mit abgerundeter Spitze oder fast 
<normalizedToken id="CE5D001FD9BF5AE971A31CA36BA42B10" originalValue="halbkreisförmig" pageId="null" pageNumber="660">halbkreisfoermig</normalizedToken>
; 
<emphasis id="6E73F59335F61780D3B769033A9CA948" italics="true" pageId="null" pageNumber="660">der Mittelnerv bildet stets eine feine, aufgesetzte Spitze.</emphasis>
<normalizedToken id="8A3E7EE55BBEF38817E59E2801EEAB15" originalValue="Hüllbecher" pageId="null" pageNumber="660">Huellbecher</normalizedToken>
mit ovalen, gelben 
<normalizedToken id="20C16C01B034BFB3F481E59CE1584778" originalValue="Drüsen" pageId="null" pageNumber="660">Druesen</normalizedToken>
. Frucht 3-3,5 mm lang, 
<emphasis id="6FD205FE5AB0A87ACEDB6A56306ADBE1" italics="true" pageId="null" pageNumber="660">
mit halbkugeligen Warzen besetzt und 3 
<normalizedToken id="0A95709F63A59C40BDBD2D583C3287DC" originalValue="Längsstreifen" pageId="null" pageNumber="660">Laengsstreifen</normalizedToken>
, die keine Warzen tragen. Samen 
<normalizedToken id="CB07DFEA0CB0329D7BBAB7A0C823D2E2" originalValue="linsenförmig" pageId="null" pageNumber="660">linsenfoermig</normalizedToken>
, 1,8 bis 2,2 mm lang und 1,7
</emphasis>
- 
<emphasis id="27FD5FEBE24264D9BF5FE7B220529957" italics="true" pageId="null" pageNumber="660">1,9 mm breit</emphasis>
, glatt, dunkelbraun. - 
<normalizedToken id="7C37CF04DCA2B3A96692DF4374632E19" originalValue="Blüte" pageId="null" pageNumber="660">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="F68A95782348EAC181A563B303BB3615" pageId="null" pageNumber="660">
<emphasis id="3E309707AAC48ED891E4DA745CDB23D4" italics="true" pageId="null" pageNumber="660">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="51B6D5C3F2AF27153EAC688B92F360FC" italics="true" pageId="null" pageNumber="660">28:</emphasis>
Material aus botanischen 
<normalizedToken id="CA383F7F9E5CFF195B61A2B0D613241E" originalValue="Gärten" pageId="null" pageNumber="660">Gaerten</normalizedToken>
(Perry 1943).
</paragraph>
<paragraph id="77BF29788046B31B57AAA9DA4B85A967" pageId="null" pageNumber="660">
<emphasis id="3F04101EF575D3BC1AEC862D5D3A04FD" italics="true" pageId="null" pageNumber="660">Standort.</emphasis>
Kollin, selten montan. Frische, lehmige, 
<normalizedToken id="3BF44B191B533397DAE41091F8550E23" originalValue="nährstoffreiche" pageId="null" pageNumber="660">naehrstoffreiche</normalizedToken>
<normalizedToken id="6F9E87F27FADFCABB4C5C1755C40F271" originalValue="Böden" pageId="null" pageNumber="660">Boeden</normalizedToken>
. 
<normalizedToken id="AB7D080167D58023AF58497D2CCCD8AF" originalValue="Äcker" pageId="null" pageNumber="660">Aecker</normalizedToken>
, Weinberge, 
<normalizedToken id="FF45D07DB123CF2253EAEF2073509B32" originalValue="Gärten" pageId="null" pageNumber="660">Gaerten</normalizedToken>
, 
<normalizedToken id="A99235D79A518F893B174A761BD009BD" originalValue="Wegränder" pageId="null" pageNumber="660">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="6F3C6DBB7A672BEBC1AF1EB6448D533E" pageId="null" pageNumber="660">
<emphasis id="481F1D5D873572219956BF3167973001" italics="true" pageId="null" pageNumber="660">Verbreitung.</emphasis>
<normalizedToken id="83922BFC5290F0250F89A3B4FF37251E" originalValue="Ursprünglich" pageId="null" pageNumber="660">Urspruenglich</normalizedToken>
wahrscheinlich 
<emphasis id="E1EE7BA492D3E33BB5358EB5C750C23A" italics="true" pageId="null" pageNumber="660">
<normalizedToken id="A3D98CB320585983880AEDAD27120AF3" originalValue="südeuropäische" pageId="null" pageNumber="660">suedeuropaeische</normalizedToken>
Pflanze;
</emphasis>
heute als Unkraut in Europa und Asien weit verbreitet (ohne arktische Gebiete); in Nordamerika eingeschleppt. - Im Gebiet verbreitet, nicht 
<normalizedToken id="3B337AA5CEE93A7EDE32EA769F93557F" originalValue="häufig" pageId="null" pageNumber="660">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="1CD5331DEF56471B1C16FAA2552DC851" pageId="null" pageNumber="660">
<emphasis id="2D944241D2C3C65BAB5A9815EAB748DD" italics="true" pageId="null" pageNumber="660">
Bemerkungen. 
<taxonomicName id="681B11D29E467FAEC1463465EEF81DCB" class="Magnoliopsida" family="Euphorbiaceae" genus="Euphorbia" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="660" phylum="Tracheophyta" rank="species" species="platyphyllos">E. platyphyllos</taxonomicName>
</emphasis>
ist am unangenehmen Geruch im frischen Zustand von verwandten Arten zu unterscheiden.
</paragraph>
</subSubSection>
