<caption id="DF2D5DD50976B228EC95F8BB25584D8A" ID-DOI="http://doi.org/10.5281/zenodo.6541651" ID-Zenodo-Dep="6541651" httpUri="https://zenodo.org/record/6541651/files/figure.png" pageId="34" pageNumber="485" startId="34.[151,250,1895,1919]" targetBox="[151,1436,747,1871]" targetPageId="34">
