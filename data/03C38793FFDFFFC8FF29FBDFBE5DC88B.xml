<subSubSection id="C370650EFFDFFFC9FF29FB76BB77CBDF" pageId="12" pageNumber="233" type="diagnosis">
<paragraph id="8BD53685FFDFFFC9FF29FB76BB77CBDF" blockId="12.[136,1452,1179,2086]" pageId="12" pageNumber="233">
<emphasis id="B91EEA97FFDFFFC9FF29FB76BE14CBB3" bold="true" box="[136,289,1179,1205]" pageId="12" pageNumber="233">Diagnosis:—</emphasis>
This species is distinguished from 
<taxonomicName id="4C6A4D06FFDFFFC9FD05FB71BCC2CBB3" authority="Y. Ono &amp; Kakish." authorityName="Y. Ono &amp; Kakish." box="[676,1015,1179,1206]" class="Pucciniomycetes" family="Pucciniaceae" genus="Puccinia" kingdom="Fungi" order="Pucciniales" pageId="12" pageNumber="233" phylum="Basidiomycota" rank="species" species="pulchella">
<emphasis id="B91EEA97FFDFFFC9FD05FB71BC12CBB3" box="[676,807,1179,1205]" italics="true" pageId="12" pageNumber="233">P. pulchella</emphasis>
Y. Ono &amp; Kakish.
</taxonomicName>
having spermogonial and aecial stages on 
<taxonomicName id="4C6A4D06FFDFFFC9FF0AFB53BFD3CBDE" box="[171,230,1214,1240]" class="Magnoliopsida" family="Violaceae" genus="Viola" kingdom="Plantae" order="Malpighiales" pageId="12" pageNumber="233" phylum="Tracheophyta" rank="genus">
<emphasis id="B91EEA97FFDFFFC9FF0AFB53BFD3CBDE" box="[171,230,1214,1240]" italics="true" pageId="12" pageNumber="233">Viola</emphasis>
</taxonomicName>
due to the size of the teliospores, which are larger than those of 
<taxonomicName id="4C6A4D06FFDFFFC9FC16FB52BB0ECBDE" box="[951,1083,1214,1240]" class="Pucciniomycetes" family="Pucciniaceae" genus="Puccinia" kingdom="Fungi" order="Pucciniales" pageId="12" pageNumber="233" phylum="Basidiomycota" rank="species" species="pulchella">
<emphasis id="B91EEA97FFDFFFC9FC16FB52BB0ECBDE" box="[951,1083,1214,1240]" italics="true" pageId="12" pageNumber="233">P. pulchella</emphasis>
</taxonomicName>
.
</paragraph>
</subSubSection>
