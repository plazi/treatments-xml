) (C). Telia on 
<taxonomicName id="4C6A4D06FFDFFFC9FE05F8B6BD3AC870" box="[420,527,1883,1910]" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="12" pageNumber="233" phylum="Tracheophyta" rank="species" species="undetermined">
