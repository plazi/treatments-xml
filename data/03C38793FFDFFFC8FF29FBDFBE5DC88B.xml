<taxonomicName id="4C6A4D06FFDFFFC9FB3EF8D5BA99C854" authority="Ledeb." authorityName="Ledeb." box="[1183,1452,1848,1874]" class="Magnoliopsida" family="Violaceae" genus="Viola" kingdom="Plantae" order="Malpighiales" pageId="12" pageNumber="233" phylum="Tracheophyta" rank="species" species="acuminata">
