Groupe de 
<taxonomicName id="A4E862C21F5DFFA6FE9DFC51FDC130CC" authority="Mez" authorityName="Mez" box="[263,619,944,971]" class="Magnoliopsida" family="Primulaceae" genus="Tapeinosperma" kingdom="Plantae" order="Ericales" pageId="22" pageNumber="301" phylum="Tracheophyta" rank="species" species="sessilifolium">
<emphasis id="519CC5531F5DFFA6FE9DFC51FD9C30CC" bold="true" box="[263,566,944,971]" italics="true" pageId="22" pageNumber="301">Tapeinosperma sessilifolium</emphasis>
