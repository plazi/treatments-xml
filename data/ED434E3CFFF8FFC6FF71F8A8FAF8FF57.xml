<heading id="3E1D4846FFF8FFC7FF71F8A8FDC6F83A" bold="true" box="[151,571,1914,1941]" fontSize="11" level="2" pageId="16" pageNumber="17" reason="4">
<taxonomicName id="A2EA84A9FFF8FFC7FF71F8A8FDC6F83A" authority="(Walker, [1858])" baseAuthorityName="Walker" baseAuthorityYear="1858" box="[151,571,1914,1941]" class="Insecta" family="Noctuidae" genus="Eudocima" kingdom="Animalia" order="Lepidoptera" pageId="16" pageNumber="17" phylum="Arthropoda" rank="species" species="dividens">
