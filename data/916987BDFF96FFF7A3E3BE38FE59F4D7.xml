<materialsCitation id="A9A83CF6FF96FFF7A3E3BE10FD06F740" ID-GBIF-Occurrence="3746878301" box="[136,723,1386,1408]" collectionCode="L" pageId="8" pageNumber="161" specimenCount="1" typeStatus="holotype">
<emphasis id="2BB4EAB9FF96FFF7A3E3BE10FF6FF740" bold="true" box="[136,186,1386,1407]" pageId="8" pageNumber="161">
<typeStatus id="C67B8809FF96FFF7A3E3BE10FF6FF740" box="[136,186,1386,1407]" pageId="8" pageNumber="161">Type</typeStatus>
</emphasis>
(indicated by 
<bibRefCitation id="7D514B5AFF96FFF7A22FBE10FDD0F7BF" author="Linnaeus, C." box="[324,517,1386,1408]" pageId="8" pageNumber="161" refId="ref8931" refString="Linnaeus, C. (1753) Species plantarum, vol. 1. Salvius, Stockholm, 560 pp." type="book" year="1753">Linnaeus 1753: 468</bibRefCitation>
