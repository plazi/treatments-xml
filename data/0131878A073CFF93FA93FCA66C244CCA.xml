<taxonomicName id="4E984D1F073CFF93FAACFA3B6C4A43D9" authority="Merriam, 1895" authorityName="Merriam" authorityYear="1895" box="[1375,1861,1474,1499]" class="Mammalia" family="Geomyidae" genus="Heterogeomys" higherTaxonomySource="GBIF" kingdom="Animalia" order="Rodentia" pageId="16" pageNumber="249" phylum="Chordata" rank="subSpecies" species="heterodus" subSpecies="dolichocephalus">H. h. dolichocephalus Merriam, 1895</taxonomicName>
