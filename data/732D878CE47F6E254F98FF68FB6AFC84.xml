<taxonomicName id="3C844D19E47F6E254D44FE39FCE4FE1C" box="[587,850,454,479]" class="Magnoliopsida" family="Montiaceae" genus="Calandrinia" kingdom="Plantae" order="Caryophyllales" pageId="90" pageNumber="91" phylum="Tracheophyta" rank="species" species="polyandra">Calandrinia polyandra</taxonomicName>
