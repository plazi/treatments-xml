<taxonomicName id="3C844D19E47F6E254EAEFE39FDF7FE1C" box="[417,577,454,479]" class="Magnoliopsida" family="Portulacaceae" kingdom="Plantae" order="Caryophyllales" pageId="90" pageNumber="91" phylum="Tracheophyta" rank="family">Portulacaceae</taxonomicName>
: 
