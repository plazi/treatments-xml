<normalizedToken id="4ADD6C121BAE4143E93B63502DFE1FBF" originalValue="Später" pageId="null" pageNumber="343">Spaeter</normalizedToken>
<normalizedToken id="771466C45B064ABE0C9C86373D9DDFAC" originalValue="Frühling" pageId="null" pageNumber="343">Fruehling</normalizedToken>
