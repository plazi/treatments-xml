<subSubSection id="D5D1F0A6E71DEB651387F653C6434BB8" pageId="null" pageNumber="239" type="description">
<paragraph id="AC07B66EC7E18EBB9300E8160EFB3846" pageId="null" pageNumber="239">
Unterscheidet sich von 
<taxonomicName id="69AF2E0A5ADD2FD27F2C2E3D796C6E30" class="Liliopsida" family="Poaceae" genus="Sorghum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="239" phylum="Tracheophyta" rank="species" species="halepense">
<emphasis id="7A347D619B8A963261713A6E824356A9" italics="true" pageId="null" pageNumber="239">S. halepense</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="E46C81AEA66DE28EA7565D7160D736C2" italics="true" pageId="null" pageNumber="239">
1 
<normalizedToken id="1941DF0F3C8B87922ECBCB0E980BCB79" originalValue="jährig" pageId="null" pageNumber="239">jaehrig</normalizedToken>
, kein Rhizom
</emphasis>
, bis 2 m hoch (in den Tropen bis 6 m hoch); 
<normalizedToken id="960A19AE7B1F70CC6A8F37FD8E3568E3" originalValue="Blätter" pageId="null" pageNumber="239">Blaetter</normalizedToken>
bis 6 cm breit; 
<normalizedToken id="9D28D6EDC362A1DAA1E87455E96017D1" originalValue="Blütenstand" pageId="null" pageNumber="239">Bluetenstand</normalizedToken>
bis 50 cm lang, dicht; 
<emphasis id="32D90F32CB59EC3F2E427354FE90857A" italics="true" pageId="null" pageNumber="239">das</emphasis>
♂ (oder sterile) 
<emphasis id="9F7BAB4235D8F6B7A07FC7681BCEB8FB" italics="true" pageId="null" pageNumber="239">
<normalizedToken id="F388C238DD47B4D266FAB7D7D62B6AC7" originalValue="Ährchen" pageId="null" pageNumber="239">Aehrchen</normalizedToken>
auf nicht 
<normalizedToken id="6D176F8B31D89A21E497BB6FCE058A52" originalValue="über" pageId="null" pageNumber="239">ueber</normalizedToken>
1,5 mm langem Stiel, das zwittrige 
<normalizedToken id="29B402C5A9214869E853520C8D2FF68A" originalValue="Ährchen" pageId="null" pageNumber="239">Aehrchen</normalizedToken>
kaum 
<normalizedToken id="42C51CBA426634791C35ECFB3BD5ADF1" originalValue="überragend" pageId="null" pageNumber="239">ueberragend</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="4DE4287E8FFFC1A9519BD46EEA33C36E" originalValue="Blüte" pageId="null" pageNumber="239">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="3DD5805E8B97A0308834BE8E167D351D" pageId="null" pageNumber="239">
<emphasis id="CC02799CB845CEB82C2E1AEBE7915ABD" italics="true" pageId="null" pageNumber="239">Zytologische Angaben. 2n = 20:</emphasis>
Material aus botanischen 
<normalizedToken id="E5AD83AFBAAB7BF24F5FEB474E4C017E" originalValue="Gärten" pageId="null" pageNumber="239">Gaerten</normalizedToken>
; die Art ist allotetraploid; Meiosen normal (Garber 1950, Sharma et al. 1957, Celarier 1958).
</paragraph>
<paragraph id="133C824D9CA6290E90806103E0997354" pageId="null" pageNumber="239">
<emphasis id="73498B7D6738DA53FAB15CB1CA9C980E" italics="true" pageId="null" pageNumber="239">Standort.</emphasis>
Kollin. Trockene, sandige 
<normalizedToken id="AE643D739AB5D74366DF5B87A38B16D7" originalValue="Böden" pageId="null" pageNumber="239">Boeden</normalizedToken>
in den 
<normalizedToken id="3BAEF20052647800CFD254BA4D16DEDA" originalValue="wärmsten" pageId="null" pageNumber="239">waermsten</normalizedToken>
Gegenden. 
<normalizedToken id="69BB2FC98E0FC1E298E687014570C634" originalValue="Äcker" pageId="null" pageNumber="239">Aecker</normalizedToken>
, 
<normalizedToken id="E25ADB96313D2173FEC53CC6FD58FE7B" originalValue="Schuttplätze" pageId="null" pageNumber="239">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="CB3BD66EC5146441C8A51BBDD4C1F660" pageId="null" pageNumber="239">
<emphasis id="3898E755EF173132D7CDAAF159E3E05D" italics="true" pageId="null" pageNumber="239">
<pageBreakToken id="624609CFDC3AA25D627E587847E57E5B" pageId="null" pageNumber="239">Verbreitung</pageBreakToken>
. 
<normalizedToken id="EEDA7C92950C4F867E7C6E698B6402C4" originalValue="Ursprünglich" pageId="null" pageNumber="239">Urspruenglich</normalizedToken>
<normalizedToken id="B3D635FB4CEE0CBA1EB814B24482CF7B" originalValue="ostafrikanisch-südwestasiatische" pageId="null" pageNumber="239">ostafrikanisch-suedwestasiatische</normalizedToken>
Pflanze
</emphasis>
(nach Garber 1950); heute in vielen Kultursorten 
<normalizedToken id="7CF8B63F4388DCC0CF05B3F8574E9B97" originalValue="über" pageId="null" pageNumber="239">ueber</normalizedToken>
die warmen Gebiete der ganzen Erde verbreitet. - Im Gebiet: Im 
<normalizedToken id="C81E8957BD0D1B4447BDCBA39CA010F5" originalValue="Süden" pageId="null" pageNumber="239">Sueden</normalizedToken>
selten verwildert oder adventiv.
</paragraph>
<paragraph id="E66D2D34EAE9AEFD6AB893A92EC842EB" pageId="null" pageNumber="239">
<emphasis id="9E997AB65BF028385A1890D69EA377B3" italics="true" pageId="null" pageNumber="239">Bemerkungen.</emphasis>
Neuerdings wird auch der Name 
<taxonomicName id="3F84225CB0360C7420B1989216F29E5D" authority="(L.) Moench" authorityName="Moench" baseAuthorityName="L." class="Liliopsida" family="Poaceae" genus="Sorghum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="239" phylum="Tracheophyta" rank="species" species="bicolor">
<emphasis id="0D9447D6DA0C3413D31F9F6795177363" italics="true" pageId="null" pageNumber="239">S. bicolor</emphasis>
(
<authorityName id="1877C9C02AEA0B3D27C413C8677CC621" pageId="null" pageNumber="239">L.</authorityName>
) Moench
</taxonomicName>
gebraucht.
</paragraph>
</subSubSection>
