<bibRefCitation id="2E4D4B02FFF5FFB4FBCA9AE26DF27BDC" author="AUBERT" box="[1120,1279,1701,1726]" pageId="24" pageNumber="38" pagination="379 - 469" refId="ref20604" refString="AUBERT, J. &amp; W. A. BERGGREN (1976) - Paleocene benthic foraminifera biostratigraphy and paleoecology of Tunisia. Bulletin Centre Recherch Pau-SNI'A, 19 (2): 379 - 469." type="journal article" year="1976">AUBERT, 1976</bibRefCitation>
