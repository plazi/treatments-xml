<subSubSection id="D65EE9EB603D228AA3FF368639E96961" pageId="null" pageNumber="823" type="description">
<paragraph id="F32F207472959744A69DE4B1BE7EA0CD" pageId="null" pageNumber="823">
4-10 cm hoch. 
<emphasis id="CEC18BD81E3BABB299491CB7C85F6B58" italics="true" pageId="null" pageNumber="823">
<normalizedToken id="9CD900CFD0150E75E020F2B19707B876" originalValue="Blätter" pageId="null" pageNumber="823">Blaetter</normalizedToken>
2-3mal so lang wie breit. 
<normalizedToken id="2027E1DB6E0A38A59A0BB3A86776218C" originalValue="Blüten" pageId="null" pageNumber="823">Blueten</normalizedToken>
zu 2-7 je Zweig.
</emphasis>
<normalizedToken id="BB884FCFDD9C987352A37E453812C033" originalValue="Kronblätter" pageId="null" pageNumber="823">Kronblaetter</normalizedToken>
<normalizedToken id="0B0E6F43099AD7539E8B6228468D5855" originalValue="1¼-1½" pageId="null" pageNumber="823">11/4-11/2</normalizedToken>
mal so lang wie die 
<normalizedToken id="27F877DE771840608E02E6D1E1BB33F1" originalValue="Kelchblätter" pageId="null" pageNumber="823">Kelchblaetter</normalizedToken>
. - 
<normalizedToken id="36093C9B873D6FE9D0C63971CA58369D" originalValue="Blüte" pageId="null" pageNumber="823">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="7BE5DE65F881E158FD86271EE72D9F11" pageId="null" pageNumber="823">
<emphasis id="135A64AD177CA4EAAE7077288224A557" italics="true" pageId="null" pageNumber="823">Zytologische Angaben. 2n = 40:</emphasis>
Material von 16 verschiedenen Orten aus den West-, Nord- und 
<normalizedToken id="31C609E1545682E20BA62F929D29A466" originalValue="Südalpen" pageId="null" pageNumber="823">Suedalpen</normalizedToken>
(Favarger 1960Favarger 1963).
</paragraph>
<paragraph id="240123E39F7C1638EBA6CC012EEBC641" pageId="null" pageNumber="823">
<emphasis id="5C72B2DC052EF4E2E8ED758340E639F2" italics="true" pageId="null" pageNumber="823">Standort.</emphasis>
Alpin, seltener subalpin. Lockere, steinige, kalkreiche 
<normalizedToken id="5D40CB167CFDD036AB59D810F93CD2E0" originalValue="Böden" pageId="null" pageNumber="823">Boeden</normalizedToken>
. Felsschutt, 
<normalizedToken id="DBBF40C2C76094182B2348B59447916B" originalValue="Geröll" pageId="null" pageNumber="823">Geroell</normalizedToken>
.
</paragraph>
<paragraph id="359236B680E7EFDCE2698DAF32F9FCC8" pageId="null" pageNumber="823">
<emphasis id="331573A547BC6019B9A0BFFA2C5F6680" italics="true" pageId="null" pageNumber="823">
Verbreitung. Mittel- und 
<normalizedToken id="1E16AB5AED71C4D9FA736C1541E8281F" originalValue="südeuropäische" pageId="null" pageNumber="823">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="66EE3BE03458CBD4BBD64DF8AF49ABE1" italics="true" pageId="null" pageNumber="823">westlich</emphasis>
): Nordspanische Gebirge, 
<normalizedToken id="6D7038BD84D6FAB8095BC28B90149971" originalValue="Pyrenäen" pageId="null" pageNumber="823">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="8657009D5C74F1967F114F0D7E5ED012" originalValue="Corbières" pageId="null" pageNumber="823">Corbieres</normalizedToken>
, Jura, Alpen (
<normalizedToken id="011A040FF5A29205327E6D449F0EEFBA" originalValue="ostwärts" pageId="null" pageNumber="823">ostwaerts</normalizedToken>
bis Vorarlberg und Dolomiten), Nordapennin. - Im Gebiet: Jura (
<normalizedToken id="C556D63DCC6B1392886B215E89B212FB" originalValue="nordostwärts" pageId="null" pageNumber="823">nordostwaerts</normalizedToken>
bis zum Chasseral), Nordalpen, Zentralalpen (sehr selten, z. B. Bellalui ob 
<taxonomicName id="1A2C1AB43191B27C06A4BCDF9AF003C1" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="823" phylum="Tracheophyta" rank="species" species="montana">Montana</taxonomicName>
), Bergamasker Alpen; nicht 
<normalizedToken id="4D4F65AC12C491F147EB980849EDA541" originalValue="häufig" pageId="null" pageNumber="823">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
