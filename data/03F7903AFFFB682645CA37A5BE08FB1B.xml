<bibRefCitation id="EFCF5CDDFFFB682644183177B87FFB1A" author="Cartwright, D. I." box="[325,516,1148,1175]" pageId="14" pageNumber="297" pagination="1 - 48" refId="ref14543" refString="Cartwright, D. I. (1990) The Australian species of Ecnomus McLachlan (Trichoptera: Ecnomidae). Memoirs of the Museum of Victoria, 51, 1 - 48. https: // doi. org / 10.24199 / j / mmv. 1990.51.01" type="journal article" year="1990">Cartwright 1990</bibRefCitation>
