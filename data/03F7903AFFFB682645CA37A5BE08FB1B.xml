<taxonomicName id="4C5E5AAFFFFB6826441E3152B840FBFF" authorityName="Cartwright" authorityYear="1990" box="[323,571,1112,1138]" class="Insecta" family="Ecnomidae" genus="Ecnomus" kingdom="Animalia" order="Trichoptera" pageId="14" pageNumber="297" phylum="Arthropoda" rank="species" species="walajandari">
