<taxonomicName id="4C5E5AAFFFF0682D447E31C0B8CDFB6E" authority="Cartwright 2011" authorityName="Cartwright" authorityYear="2011" box="[291,694,1227,1251]" class="Insecta" family="Ecnomidae" genus="Neboissomina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trichoptera" pageId="5" pageNumber="288" phylum="Arthropoda" rank="species" species="jardinei">
