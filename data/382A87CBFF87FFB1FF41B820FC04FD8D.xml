<td id="4D625DE3FF85004CFC48BD0DFA54FECB" box="[926,1410,308,332]" gridcol="2" gridrow="2" pageId="2" pageNumber="99">Both posterior projections narrow at apex</td>
</tr>
<tr id="0EB3349FFF85004CFF70BD65FA54FE1E" box="[166,1410,348,409]" gridrow="3" pageId="2" pageNumber="99">
<th id="4D625DE3FF85004CFF70BD65FE59FE1E" box="[166,399,348,409]" gridcol="0" gridrow="3" pageId="2" pageNumber="99">Tegmina of female</th>
<td id="4D625DE3FF85004CFE64BD65FCA8FE1E" box="[434,894,348,409]" gridcol="1" gridrow="3" pageId="2" pageNumber="99">Longer, extending over the middle of 2nd abdominal tergum</td>
<td id="4D625DE3FF85004CFC48BD65FA54FE1E" box="[926,1410,348,409]" gridcol="2" gridrow="3" pageId="2" pageNumber="99">Shorter, extending over the hind margin of first abdominal tergum slightly</td>
</tr>
<tr id="0EB3349FFF85004CFF70BD90FA54FE46" box="[166,1410,425,449]" gridrow="4" pageId="2" pageNumber="99">
<th id="4D625DE3FF85004CFF70BD90FE59FE46" box="[166,399,425,449]" gridcol="0" gridrow="4" pageId="2" pageNumber="99">Upper ovipositor valve</th>
<td id="4D625DE3FF85004CFE64BD90FCA8FE46" box="[434,894,425,449]" gridcol="1" gridrow="4" pageId="2" pageNumber="99">Slender, length 3.5 times its maximum width</td>
<td id="4D625DE3FF85004CFC48BD90FA54FE46" box="[926,1410,425,449]" gridcol="2" gridrow="4" pageId="2" pageNumber="99">Shorter, length 2.8 times its maximum width</td>
</tr>
