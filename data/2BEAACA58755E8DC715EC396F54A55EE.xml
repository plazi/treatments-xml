<taxonomicName id="1F9553A0C56BDF93C94AC720B6E2CFF2" class="Magnoliopsida" family="Asteraceae" genus="Petasites" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="472" phylum="Tracheophyta" rank="genus">Petasites</taxonomicName>
