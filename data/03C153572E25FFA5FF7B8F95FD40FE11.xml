<heading id="D09F552D2E25FFA7FF7B8F95FD10FA96" box="[166,668,1266,1293]" fontSize="36" level="2" pageId="4" pageNumber="185" reason="3">
<taxonomicName id="4C6899C22E25FFA7FF7B8F95FD10FA96" authority="(Rudolphi, 1802)" baseAuthorityName="Rudolphi" baseAuthorityYear="1802" box="[166,668,1266,1293]" class="Palaeacanthocephala" family="Polymorphidae" genus="Corynosoma" kingdom="Animalia" order="Polymorphida" pageId="4" pageNumber="185" phylum="Acanthocephala" rank="species" species="strumosum">
<emphasis id="B91C3E532E25FFA7FF7B8F95FE41FA96" bold="true" box="[166,461,1266,1293]" italics="true" pageId="4" pageNumber="185">Corynosoma strumosum</emphasis>
(
<bibRefCitation id="EFF99FB02E25FFA7FE068F95FD1FFA96" author="Rudolphi, C. A." box="[475,659,1266,1293]" pageId="4" pageNumber="185" pagination="1 - 67" refId="ref8322" refString="Rudolphi, C. A. 1802. Fortsetzung der Beobachtungen uber die Eingeweidewurmer. Archiv fur Zoologie und Zootomie von Wiedemanns, 2, 1 - 67." type="journal article" year="1802">Rudolphi, 1802</bibRefCitation>
