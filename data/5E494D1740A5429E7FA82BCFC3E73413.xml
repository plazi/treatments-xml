<subSubSection id="0C5DB586C6C43188D035AD8FCE1812FD" pageId="null" pageNumber="321" type="description">
<paragraph id="01EE2067C6DCB996A5416CCE05D9F1FC" pageId="null" pageNumber="321">
<normalizedToken id="C34240D034593843AD250ADA2EFE5E74" originalValue="Sommergrüne" pageId="null" pageNumber="321">Sommergruene</normalizedToken>
<normalizedToken id="2B1CBCB2194B6BBF84202D161DB58143" originalValue="Sträucher" pageId="null" pageNumber="321">Straeucher</normalizedToken>
. 
<normalizedToken id="9A808EE2D4F2DC8EB6B2FE2B475C634B" originalValue="Blätter" pageId="null" pageNumber="321">Blaetter</normalizedToken>
meist ganzrandig, seltener wenig tief geteilt, kurz gestielt. 
<emphasis id="F9151EBE2E697B19B39B2A9EE356CC97" italics="true" pageId="null" pageNumber="321">
<normalizedToken id="38A6B42AF09B35868C5F4529C6E5E3C7" originalValue="Blüten" pageId="null" pageNumber="321">Blueten</normalizedToken>
in 
<normalizedToken id="1C500C41B927E5F76588FB4847457F2E" originalValue="endständigen" pageId="null" pageNumber="321">endstaendigen</normalizedToken>
oder 
<normalizedToken id="AF683D5261450DBE974A50C2BEB73120" originalValue="blattachselständigen" pageId="null" pageNumber="321">blattachselstaendigen</normalizedToken>
<normalizedToken id="AB2A8B178CCB2E2146426F368A4EF947" originalValue="Ähren" pageId="null" pageNumber="321">Aehren</normalizedToken>
</emphasis>
, meist 5-, selten 4 
<normalizedToken id="05A5464578E833A7AB5674E4779E2D19" originalValue="zählig" pageId="null" pageNumber="321">zaehlig</normalizedToken>
, aktinomorph. Kelchzipfel kurz. Krone meist 
<normalizedToken id="078E54CF193655285915143AA29699B9" originalValue="glockenförmig" pageId="null" pageNumber="321">glockenfoermig</normalizedToken>
, 
<emphasis id="91E38A8DEF34FC028C0AC3E4B53B19D5" italics="true" pageId="null" pageNumber="321">
<normalizedToken id="AF868C1ACD47C735FAD8B5685404DA55" originalValue="±" pageId="null" pageNumber="321">+/-</normalizedToken>
</emphasis>
weit hinauf verwachsen, 
<normalizedToken id="2A3D9016E3DB7F4FAA29C68142FA50F2" originalValue="weiß" pageId="null" pageNumber="321">weiss</normalizedToken>
bis rosa, innerseits 
<pageBreakToken id="9DC3F5270C46DD5CFFB727D0790177FD" pageId="null" pageNumber="321">oft</pageBreakToken>
behaart. Narbe 2teilig, auf kurzem Griffel. Frucht eine 2samige, kugelige, meist 
<normalizedToken id="6EC94D5C426D5B4AAEF78190E7D33AEF" originalValue="weiße" pageId="null" pageNumber="321">weisse</normalizedToken>
, seltener rote oder schwarze Beere.
</paragraph>
<paragraph id="1F2031DBA36FE0792138F55B388E1F91" pageId="null" pageNumber="321">
Die Gattung 
<taxonomicName id="B36BEBF314C50163AA367A471DF21FCE" class="Magnoliopsida" family="Caprifoliaceae" genus="Symphoricarpos" kingdom="Plantae" order="Dipsacales" pageId="null" pageNumber="321" phylum="Tracheophyta" rank="genus">
<emphasis id="420CC2F4EC8DB58D3173B6C826A55889" italics="true" pageId="null" pageNumber="321">Symphoricarpos</emphasis>
</taxonomicName>
<normalizedToken id="4E26887B9110DB3FF7D9AA342B1CA9F9" originalValue="umfaßt" pageId="null" pageNumber="321">umfasst</normalizedToken>
<emphasis id="44F6CF050AA19C9FC8782DD28BF7A66B" italics="true" pageId="null" pageNumber="321">17 Arten</emphasis>
und 
<emphasis id="4ED510F4F063CE3B326393CE76FD3474" italics="true" pageId="null" pageNumber="321">ist in Nordamerika verbreitet; 1 Art in China.</emphasis>
</paragraph>
