Subgenus 
<taxonomicName id="4C1FA387FFB10462FE46FC1FFCD7FC2F" authority="Amyot &amp; Serville, 1843" authorityName="Amyot &amp; Serville" authorityYear="1843" box="[463,855,985,1010]" class="Insecta" family="Largidae" genus="Physopelta" kingdom="Animalia" order="Hemiptera" pageId="7" pageNumber="512" phylum="Arthropoda" rank="genus">
