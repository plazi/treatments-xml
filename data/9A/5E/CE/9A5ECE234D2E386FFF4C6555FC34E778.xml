<subSubSection pageId="5" pageNumber="524" type="discussion">
<paragraph blockId="5.[786,1381,726,1149]" pageId="5" pageNumber="524">
This species previously included 
<taxonomicName class="Mammalia" family="Pseudocheiridae" genus="Pseudochirulus" kingdom="Animalia" order="Diprotodontia" pageId="5" pageNumber="524" phylum="Chordata" rank="species" species="larvatus">P. larvatus</taxonomicName>
but this taxon is currently recognized a distinct species. Monotypic.
</paragraph>
</subSubSection>
<subSubSection box="[787,1198,1041,1070]" pageId="5" pageNumber="524" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6670488" ID-Zenodo-Dep="6670488" box="[787,1198,1041,1070]" httpUri="https://zenodo.org/record/6670488/files/figure.png" inLine="true" pageId="5" pageNumber="524" targetBox="[172,763,731,1145]" targetPageId="5">
<paragraph blockId="5.[786,1381,726,1149]" box="[787,1198,1041,1070]" pageId="5" pageNumber="524">
<emphasis bold="true" box="[787,962,1041,1070]" pageId="5" pageNumber="524">Distribution.</emphasis>
