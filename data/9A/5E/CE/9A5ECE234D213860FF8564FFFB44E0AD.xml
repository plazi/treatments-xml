<taxonomicName box="[251,397,1899,1932]" class="Magnoliopsida" family="Lauraceae" kingdom="Plantae" order="Laurales" pageId="10" pageNumber="529" phylum="Tracheophyta" rank="family">Lauraceae</taxonomicName>
) and strangler fig (
<taxonomicName box="[671,739,1899,1932]" class="Magnoliopsida" family="Moraceae" genus="Ficus" kingdom="Plantae" order="Rosales" pageId="10" pageNumber="529" phylum="Tracheophyta" rank="genus">Ficus</taxonomicName>
