<figureCitation id="C5FF10EEFF9CEF5FFEACF9D5FEEDF9C2" box="[297,344,1632,1658]" captionStart="FIGURE 28" captionStartId="53.[151,250,1373,1397]" captionTargetBox="[154,1433,306,1335]" captionTargetId="figure-45@53.[154,1433,306,1346]" captionTargetPageId="53" captionText="FIGURE 28. Live specimens of Scudderiini, Steirodontini and Entephippion olivaceum (Phaneropterinae) from the ParNa Iguaçu. A: Ceraia cornutoides; B: Theudoria melanocnemis; C: Vellea cruenta; D: Steirodon dentiferum; E: Stilpnochlora marginoides; F: E. olivaceum; A: photo by Leanna C. Macarini; B–F: photos by Marcos Fianco." figureDoi="http://doi.org/10.5281/zenodo.6550129" httpUri="https://zenodo.org/record/6550129/files/figure.png" pageId="52" pageNumber="53">28D</figureCitation>
