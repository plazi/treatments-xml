<subSubSection id="1AB49D71A8DB9F8E296A354FE2B0836E" pageId="null" pageNumber="456" type="description">
<paragraph id="F33B760C6FE6A717F405EC73B4B7B0B6" pageId="null" pageNumber="456">
<emphasis id="B9D153F63130799E6B37C5FD8D3E5919" italics="true" pageId="null" pageNumber="456">30-100 cm hoch;</emphasis>
lange, unterirdische 
<normalizedToken id="2F8C3E8CCB9F08756EA6B27CFA9592A8" originalValue="Ausläufer" pageId="null" pageNumber="456">Auslaeufer</normalizedToken>
treibend. 
<normalizedToken id="821919EF2528444DA11B90F06E697C06" originalValue="Grundständige" pageId="null" pageNumber="456">Grundstaendige</normalizedToken>
, blattlose Scheiden gelbbraun bis dunkelbraun, ohne Gitternerven; 
<normalizedToken id="4E48A9C4B6739BFB129AC70C9887C332" originalValue="beblätterte" pageId="null" pageNumber="456">beblaetterte</normalizedToken>
Scheiden mit deutlichen Gitternerven. 
<pageBreakToken id="C6217998F73EB58B6CA07CE2395ECAE8" pageId="null" pageNumber="456">
<normalizedToken id="D5B3B7EB33E07E4BC46F34E8FE34646F" originalValue="Blätter" pageId="null" pageNumber="456">Blaetter</normalizedToken>
</pageBreakToken>
1-1,5 mm breit, 
<emphasis id="9CEF0ADF6147D2B72654D7999A093BDD" italics="true" pageId="null" pageNumber="456">steif, hohlrinnig</emphasis>
(
<emphasis id="38586810FA446B8C84503041D79A052D" italics="true" pageId="null" pageNumber="456">binsenartig</emphasis>
), 
<normalizedToken id="9D570320CE067167F18C46A8D21530AD" originalValue="dunkelgrün" pageId="null" pageNumber="456">dunkelgruen</normalizedToken>
, den 
<normalizedToken id="427578E5ED1A149BFB82F7A4DB536DA6" originalValue="Blütenstand" pageId="null" pageNumber="456">Bluetenstand</normalizedToken>
nicht erreichend. Stengel rundlich, steif aufrecht, oben rauh. 
<normalizedToken id="66CB774F8F50CB4480D3ACD7D7BF8A3F" originalValue="Blütenstand" pageId="null" pageNumber="456">Bluetenstand</normalizedToken>
8-20 cm lang, aus 1-3 seitlichen, zylindrischen oder 
<normalizedToken id="0F6B447BE24F63BC9D111A1301364FFD" originalValue="eiförmigen" pageId="null" pageNumber="456">eifoermigen</normalizedToken>
, 1-3 cm langen, 
<emphasis id="3C9DB17E2DCEEDDE2019752E1383D461" italics="true" pageId="null" pageNumber="456">
<normalizedToken id="6C1A37DC9FA699DC8EB2B341DE4E5585" originalValue="vielblütigen" pageId="null" pageNumber="456">vielbluetigen</normalizedToken>
</emphasis>
(
<emphasis id="38B93AC95F470F87D98AF49F199622C6" italics="true" pageId="null" pageNumber="456">
<normalizedToken id="CB2EA7893D316D47CED96EF2231941C3" originalValue="über" pageId="null" pageNumber="456">ueber</normalizedToken>
10 
<normalizedToken id="DACB7AAA70871231CA23D35CFC367854" originalValue="blütigen" pageId="null" pageNumber="456">bluetigen</normalizedToken>
</emphasis>
), aufrechten, sitzenden oder kurz gestielten, entfernt stehenden ♀ 
<normalizedToken id="306A01DE59E092EC4D046480792C243B" originalValue="Ähren" pageId="null" pageNumber="456">Aehren</normalizedToken>
und an der Spitze mit 1-3 ♂ 
<normalizedToken id="F8E60CAE2FD7BD58FAF0AECD13D2D1AE" originalValue="Ähren" pageId="null" pageNumber="456">Aehren</normalizedToken>
. 
<normalizedToken id="B7DEA059CF215B26E93C1B803D1AD1FF" originalValue="Hochblätter" pageId="null" pageNumber="456">Hochblaetter</normalizedToken>
<normalizedToken id="56902D8BA50777E1540A65265A002C04" originalValue="blattähnlich" pageId="null" pageNumber="456">blattaehnlich</normalizedToken>
, das unterste den 
<normalizedToken id="9E14B8C5D09A4B008FC24A94D1BA1FFF" originalValue="Blütenstand" pageId="null" pageNumber="456">Bluetenstand</normalizedToken>
meist weit 
<normalizedToken id="674CE0A1240D8B0D7E41BBAAB4492129" originalValue="überragend" pageId="null" pageNumber="456">ueberragend</normalizedToken>
. 
<normalizedToken id="EE362F49A4EDDB05E5F7215489BE9722" originalValue="Tragblätter" pageId="null" pageNumber="456">Tragblaetter</normalizedToken>
<normalizedToken id="0198AED5873D3765C87E508BCBCFF1EA" originalValue="¾" pageId="null" pageNumber="456">3/4</normalizedToken>
bis so lang wie die reifen 
<normalizedToken id="3B1C4A5A649CC4943D7B2E67649E9B20" originalValue="Fruchtschläuche" pageId="null" pageNumber="456">Fruchtschlaeuche</normalizedToken>
, spitz, braun, mit hellem Mittelnerv. 
<normalizedToken id="07581FE09E0D24AB65D3096E4EBC17AD" originalValue="Fruchtschläuche" pageId="null" pageNumber="456">Fruchtschlaeuche</normalizedToken>
4-6 mm lang, etwa in der Mitte am breitesten (2-2,5 mm), im Querschnitt rundlich oder undeutlich 3eckig, ohne Nerven, 
<normalizedToken id="085C89956BF686B1C27432B91BD53D1F" originalValue="überall" pageId="null" pageNumber="456">ueberall</normalizedToken>
sehr dicht behaart, graubraun, 
<normalizedToken id="48BC4EED1D72F5D999486F99B88DB64E" originalValue="allmählich" pageId="null" pageNumber="456">allmaehlich</normalizedToken>
in den aus 0,5-2 mm langen, geraden oder gespreizten 
<normalizedToken id="C84120776D1D0B621A1572D83D763318" originalValue="Zähnen" pageId="null" pageNumber="456">Zaehnen</normalizedToken>
bestehenden Schnabel 
<normalizedToken id="26973BAD9ED20A15A455AABEFE308749" originalValue="verschmälert" pageId="null" pageNumber="456">verschmaelert</normalizedToken>
. Narben 3.
</paragraph>
<paragraph id="93C3D5FD4F24968BE65457735112ACFD" pageId="null" pageNumber="456">
<emphasis id="B92AB8C77A82B3B58D150B6EBAF4171B" italics="true" pageId="null" pageNumber="456">Zytologische Angaben. 2n = 56:</emphasis>
Material aus Schleswig-Holstein (Reese 1951).
</paragraph>
<paragraph id="01684A2747396750E3D36DFF43F300A1" pageId="null" pageNumber="456">
<emphasis id="806018AC8AE46E4011245630BB4C6DF5" italics="true" pageId="null" pageNumber="456">Standort.</emphasis>
Kollin und montan, selten subalpin. Nasse, schwach saure 
<normalizedToken id="C01EE261D8E8B4FB96FF1A7F99A9656B" originalValue="Torfböden" pageId="null" pageNumber="456">Torfboeden</normalizedToken>
in Flach- und Hochmooren. Im Verlandungsgebiet von 
<normalizedToken id="E28AF9CF2510DC795A3E403A026C7CAB" originalValue="Tümpeln" pageId="null" pageNumber="456">Tuempeln</normalizedToken>
und Schlenken: 
<emphasis id="DB09DDCBAA70F063BD608B701DEF38C3" italics="true" pageId="null" pageNumber="456">Caricetum lasiocarpae</emphasis>
W. Koch 1926 (Schwingmoorgesellschaft).
</paragraph>
<paragraph id="FE7DD345D4149766498ACECFA7B1E6E7" pageId="null" pageNumber="456">
<emphasis id="CB44526A5A2F72E0F826C0D914E2844E" italics="true" pageId="null" pageNumber="456">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
In 
<taxonomicName id="963122C5A3C817636E978A4328E403A2" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="456" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
<normalizedToken id="BC95143BC21D03B364DAB77C268ABEE7" originalValue="nordwärts" pageId="null" pageNumber="456">nordwaerts</normalizedToken>
bis 71° NB (kommt auf Island nicht vor); 
<normalizedToken id="16D35D0A08364034FF12B59C0E502CE2" originalValue="Südgrenze" pageId="null" pageNumber="456">Suedgrenze</normalizedToken>
durch 
<normalizedToken id="AA1AC7285660DD041953093682BB0159" originalValue="Pyrenäen" pageId="null" pageNumber="456">Pyrenaeen</normalizedToken>
, Nordapennin, 
<normalizedToken id="034301A2AE94591F6431FBE3FDA9B7B8" originalValue="nördliche" pageId="null" pageNumber="456">noerdliche</normalizedToken>
Balkanhalbinsel, Kaukasus; in Asien vor allem zwischen 50 und 65° NB; in Nordamerika zwischen 40 und 60° NB (
<taxonomicName id="37E39CE68BF11958B7D89372FA4427EA" authority="Fern." authorityName="Fern." pageId="null" pageNumber="456" rank="variety" variety="americana">
var. 
<emphasis id="46117314C4D77A0332CB440D98CA2D87" italics="true" pageId="null" pageNumber="456">americana</emphasis>
Fern.
</taxonomicName>
). Verbreitungskarte von 
<normalizedToken id="6E827FB37455B28E9072F4CF0A7B9999" originalValue="Hultén" pageId="null" pageNumber="456">Hulten</normalizedToken>
(1962). - Im Gebiet: Kommt in Basel, Uri und Tessin nicht vor; sonst zerstreut und nicht 
<normalizedToken id="2FE2747884D6B67BA32B9C8FC5469F8D" originalValue="häufig" pageId="null" pageNumber="456">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
