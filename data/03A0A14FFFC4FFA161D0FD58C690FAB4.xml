<bibRefCitation id="EF986DA8FFC4FFA160EEFB25C709FA88" author="Bartsch, I." box="[425,594,1267,1293]" pageId="8" pageNumber="309" pagination="27 - 38" refId="ref9403" refString="Bartsch, I. (2009 c) Rhombognathus (Halacaridae: Rhombognathinae) from Mauritius, new records from the western Indian Ocean. Mitteilungen aus dem Hamburgischen Zoologische Museum und Institut, 106, 27 - 38." type="journal article" year="2009">Bartsch 2009c</bibRefCitation>
; 
<bibRefCitation id="EF986DA8FFC4FFA16318FB25C601FA88" author="Abe, H. &amp; Etemadi, I." box="[607,858,1267,1293]" pageId="8" pageNumber="309" pagination="107 - 119" refId="ref8146" refString="Abe, H. &amp; Etemadi, I. (2014) Two rhombognathine mites (Acari: Halacaridae) from the Gulf of Oman, Iran. Persian Journal of Acarology, 3 (2), 107 - 119." type="journal article" year="2014">Abé &amp; Etemadi 2014</bibRefCitation>
; 
<bibRefCitation id="EF986DA8FFC4FFA1622FFB25C1E9FA88" author="Chatterjee, T. &amp; Nanajkar, M." box="[872,1202,1267,1293]" pageId="8" pageNumber="309" pagination="127 - 132" refId="ref11467" refString="Chatterjee, T. &amp; Nanajkar, M. (2019) Report of Rhombognathus scutulatus (Acari: Halacaridae) from Goa, India. Acta Biologica, 26, 127 - 132. https: // doi. org / 10.18276 / ab. 2019.26 - 11" type="journal article" year="2019">Chatterjee &amp; Nanajkar 2019</bibRefCitation>
