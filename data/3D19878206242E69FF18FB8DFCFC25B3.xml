<bibRefCitation id="D1214B6506242E68FD0FFBC8FCE623B5" author="Alcock, A." box="[640,780,1767,1791]" pageId="14" pageNumber="315" pagination="123 - 169" refId="ref24584" refString="Alcock, A. (1900) Materials for a carcinological Fauna of India. No. 5. Brachyura Primigenia or Dromiacea. Journal of the Asiatic Society Bengal, 1899, 68 (2), 123 - 169. [1900]" type="journal article" year="1900">Alcock, 1900</bibRefCitation>
