<paragraph id="C401369CFF91FFCEFC87DD2F27396CA9" blockId="3.[811,1456,535,657]" pageId="3" pageNumber="44">
<bibRefCitation id="A02F4B6DFF91FFCEFC87DD2F21F76C69" author="CABRERA A. L." box="[813,971,566,593]" pageId="3" pageNumber="44" pagination="285 - 308" refId="ref912" refString="CABRERA A. L. 1966. - The genus Lagenophora (Compositae). Blumea 14: 285 - 308." type="journal article" year="1966">Cabrera (1966)</bibRefCitation>
included this name in synonymy with 
<taxonomicName id="03BE4D1FFF91FFCEFAE5DD2E21516C48" authority="Steetz" authorityName="Steetz" class="Magnoliopsida" family="Asteraceae" genus="Lagenophora" kingdom="Plantae" order="Asterales" pageId="3" pageNumber="44" phylum="Tracheophyta" rank="species" species="gracilis">
