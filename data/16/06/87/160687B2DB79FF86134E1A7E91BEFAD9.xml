<paragraph blockId="0.[1225,2108,777,1366]" box="[1228,1417,930,963]" pageId="0" pageNumber="400">• 65-80 cm.</paragraph>
</caption>
<caption ID-DOI="http://doi.org/10.5281/zenodo.6657604" ID-Zenodo-Dep="6657604" box="[1227,1574,1167,1200]" httpUri="https://zenodo.org/record/6657604/files/figure.png" inLine="true" pageId="0" pageNumber="400" targetBox="[212,1159,777,1402]" targetPageId="0">
