<quantity id="4C8753A8FFB2FFDE47E0FE73FDB557C2" box="[475,548,392,414]" metricMagnitude="3" metricUnit="m" metricValue="1.6669999999999998" pageId="2" pageNumber="403" unit="m" value="1667.0">1667 m</quantity>
