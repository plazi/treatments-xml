<paragraph id="CEE4D8F544200615FF3BA788C5F10A41" pageId="null" pageNumber="538">
<taxonomicName id="F9D9C9FCE23DAC17B3AB8A0D16B325A5" authority="Vili." class="Magnoliopsida" family="Fabaceae" genus="Dorycnium" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="538" phylum="Tracheophyta" rank="species" species="herbaceum">
<pageBreakToken id="FA4701C8C93CEC8EE5C38F58673A6601" pageId="null" pageNumber="538">Dorycnium</pageBreakToken>
<normalizedToken id="0BB5667C9E1CBFAEE6F012BE42608875" originalValue="herbáceum" pageId="null" pageNumber="538">herbaceum</normalizedToken>
Vili.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="0AAF5F12443CF841220526F57D152634" pageId="null" pageNumber="538" type="vernacular_names">
<paragraph id="68938CA2BC4D5A46A773CDDC65F3DCCE" pageId="null" pageNumber="538">Krautiger Backenklee</paragraph>
</subSubSection>
</title>
<subSubSection id="F392F77827810EE2892F6D20C7DEA27A" pageId="null" pageNumber="538" type="description">
<paragraph id="75CF299344DBAD060DF4B1713B3D42EF" pageId="null" pageNumber="538">
Halbstrauch, am Grunde verholzt; 30-65 cm hoch. Stengel und Kelch zerstreut bis dicht anliegend behaart. 
<emphasis id="E1CC8272C3F1CA8B6A95C84F5AB74199" italics="true" pageId="null" pageNumber="538">
<normalizedToken id="9D8AEA5235850DADFF7116AE717F664B" originalValue="Blätter" pageId="null" pageNumber="538">Blaetter</normalizedToken>
zerstreut abstehend behaart
</emphasis>
(
<emphasis id="8100ED3937BB031B0F5158F8229109A9" italics="true" pageId="null" pageNumber="538">
<normalizedToken id="47E33078B8E99112843E6726597FCEF8" originalValue="längere" pageId="null" pageNumber="538">laengere</normalizedToken>
Haare 0,5-1 mm lang
</emphasis>
). 
<normalizedToken id="89DB2788D12BBC249E13ADFD8E93D908" originalValue="Teilblätter" pageId="null" pageNumber="538">Teilblaetter</normalizedToken>
lanzettlich, bis 2 cm lang, 
<emphasis id="C797E750C04796B755D6CCAA097CB067" italics="true" pageId="null" pageNumber="538">3-5mal so lang wie breit.</emphasis>
<normalizedToken id="BE61F9531294A055D829AC3D56CD0112" originalValue="Blütenstände" pageId="null" pageNumber="538">Bluetenstaende</normalizedToken>
lang gestielt (
<emphasis id="FF251A56CCD38E52B855D4CE95EA0E58" italics="true" pageId="null" pageNumber="538">Stiel 1-5 cm lang</emphasis>
), 
<emphasis id="B917E259C44E736D64B9BA459E473B99" italics="true" pageId="null" pageNumber="538">
15-15 
<normalizedToken id="C3546E22F59B8065F4B0390C3C07511B" originalValue="blütig" pageId="null" pageNumber="538">bluetig</normalizedToken>
.
</emphasis>
<normalizedToken id="34354497C1CC23B39F2E812BED5C3425" originalValue="Blütenstiele" pageId="null" pageNumber="538">Bluetenstiele</normalizedToken>
1-1,5 mm lang. 
<emphasis id="403CDCAC770722D5089F3C919B44A20D" italics="true" pageId="null" pageNumber="538">Kelch 1,5-2 mm lang; Kelchzipfel</emphasis>
<normalizedToken id="ADBF5AA76EB963EA1DDDD38AC1711DF7" originalValue="½" pageId="null" pageNumber="538">1/2</normalizedToken>
- ⅔ 
<emphasis id="E5BE55FB58E38281613550A85A86A960" italics="true" pageId="null" pageNumber="538">
so lang wie die 
<normalizedToken id="8D96BAFE0139F6D565D88B9FAEF70FCD" originalValue="Kelchröhre" pageId="null" pageNumber="538">Kelchroehre</normalizedToken>
. Krone 3-5 mm lang
</emphasis>
, 
<normalizedToken id="A06B2636F80A8AEAB532F0CFD62F8620" originalValue="weiß" pageId="null" pageNumber="538">weiss</normalizedToken>
, mit dunkelpurpurner Schiffchenspitze; 
<emphasis id="3280690D0E35153580FC719052C91E72" italics="true" pageId="null" pageNumber="538">
Fahne 
<normalizedToken id="63E642188098F4CD5409E76BB40A1982" originalValue="geigenförmig" pageId="null" pageNumber="538">geigenfoermig</normalizedToken>
; 
<normalizedToken id="8B21B54C04BC974C6B2A7AD48FDB6F05" originalValue="Flügel" pageId="null" pageNumber="538">Fluegel</normalizedToken>
an der Spitze miteinander verwachsen;
</emphasis>
Schiffchen etwas 
<normalizedToken id="4BB9DACAA5B864D37E976C2279FFFE73" originalValue="aufwärts" pageId="null" pageNumber="538">aufwaerts</normalizedToken>
gebogen. - 
<normalizedToken id="1FE36D21857ACAED8BC1F3BFD63ABA13" originalValue="Blüte" pageId="null" pageNumber="538">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="D799DA222403C3379E8DCCDC84A3C66F" pageId="null" pageNumber="538">
<emphasis id="B2E01BB4C33F1F05B03C642E7065F869" italics="true" pageId="null" pageNumber="538">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0821283FDB77157871959261FA975496" italics="true" pageId="null" pageNumber="538">14:</emphasis>
Material aus botanischen 
<normalizedToken id="DAB15C9B59A10DAE3D13406213FA32AD" originalValue="Gärten" pageId="null" pageNumber="538">Gaerten</normalizedToken>
(Tschechow und Kartashova 1932, Gilot 1965).
</paragraph>
<paragraph id="6106DB948DF9630C7D2451A299BF700D" pageId="null" pageNumber="538">
<emphasis id="3D37817846AAEDC389C5B6F332AEACC4" italics="true" pageId="null" pageNumber="538">Standort.</emphasis>
Kollin, seltener montan. Trockene, lockere, kalkhaltige 
<normalizedToken id="15B5B44A8F766E1660009AA27B46E699" originalValue="Böden" pageId="null" pageNumber="538">Boeden</normalizedToken>
in warmen Lagen. Lichte 
<normalizedToken id="4F5F0B71F4A194FD9D1C2CEDC8A8E5EC" originalValue="Wälder" pageId="null" pageNumber="538">Waelder</normalizedToken>
, felsige 
<normalizedToken id="E56D8416F4904926D681B6022B7FD888" originalValue="Hänge" pageId="null" pageNumber="538">Haenge</normalizedToken>
, buschige Stellen.
</paragraph>
<paragraph id="BECAB98D80E1F38BBEA33912A52126AA" pageId="null" pageNumber="538">
<emphasis id="6BCC63620CE512F4867C2238B29806DA" italics="true" pageId="null" pageNumber="538">
Verbreitung. 
<normalizedToken id="EA7B2CFCACC9123B92532F3C6A64956C" originalValue="Südosteuropäische" pageId="null" pageNumber="538">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="EAC9D4E735E06125E7EE01626B173CA9" originalValue="Westwärts" pageId="null" pageNumber="538">Westwaerts</normalizedToken>
bis zur Rhone; 
<normalizedToken id="0F69643A25BE1C19B36B8CE5C2180B02" originalValue="nordwärts" pageId="null" pageNumber="538">nordwaerts</normalizedToken>
bis Jura, 
<normalizedToken id="D32C38A4532E2313DF4EE8BEC33A2CDD" originalValue="Südalpen" pageId="null" pageNumber="538">Suedalpen</normalizedToken>
, Donaubecken, Krim; Kleinasien (wenige Fundstellen), Kaukasus. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: 
<normalizedToken id="0E128E1B113C5C9B0389D7D582E81FC7" originalValue="Dép" pageId="null" pageNumber="538">Dep</normalizedToken>
. Doubs (
<normalizedToken id="90752F3A79B70599DE9BC2CC46205D21" originalValue="Besançon" pageId="null" pageNumber="538">Besancon</normalizedToken>
), Savoyen (Mont Corsuet im 
<normalizedToken id="EDF9F5BB0A075B5122ECBFF0C4752A9E" originalValue="südlichen" pageId="null" pageNumber="538">suedlichen</normalizedToken>
Jura; Massif des Bauges und 
<normalizedToken id="5D33CEB09A34A0E2A21EB50E89CDF71A" originalValue="südlich" pageId="null" pageNumber="538">suedlich</normalizedToken>
<normalizedToken id="841D0852FB657E11C6F0952C1EA52AA9" originalValue="anschließende" pageId="null" pageNumber="538">anschliessende</normalizedToken>
Gebiete), Gebiet der Seen von Varese, Lugano und Como, Gegend von Bergamo, Val Camonica, Vintschgau (Tisens), Vaduz (wohl adventiv).
</paragraph>
</subSubSection>
