<subSubSection id="5F6FB9DC57815D3C2F68F7407C3256C4" pageId="null" pageNumber="416" type="description">
<paragraph id="2859702A10DE51BE860D663F7EA339F8" pageId="null" pageNumber="416">
Ausdauernd. Stengel 
<normalizedToken id="4E466B411939AA56F7ED6DFA9F5C12B8" originalValue="beblättert" pageId="null" pageNumber="416">beblaettert</normalizedToken>
. 
<emphasis id="C2F1E44FCDA8882410671DEBFFB1A560" italics="true" pageId="null" pageNumber="416">
<normalizedToken id="50BCBB504706FDA2A69EB8CE95648A9A" originalValue="Gesamtblütenstand" pageId="null" pageNumber="416">Gesamtbluetenstand</normalizedToken>
aus einer 
<normalizedToken id="5BC5C6471B8D6EC1E04EF9E56AD71D56" originalValue="endständigen" pageId="null" pageNumber="416">endstaendigen</normalizedToken>
und mehreren 
<normalizedToken id="A0D7A76B2905FE595AED0575BE877F1A" originalValue="seitenständigen" pageId="null" pageNumber="416">seitenstaendigen</normalizedToken>
Spirren bestehend;
</emphasis>
<normalizedToken id="3CEAB087AB3CFB1B86654F1987205617" originalValue="Ähren" pageId="null" pageNumber="416">Aehren</normalizedToken>
am Ende der 
<normalizedToken id="33210444DFC6927E9BFACE9D72CE4076" originalValue="Äste" pageId="null" pageNumber="416">Aeste</normalizedToken>
kopfig angeordnet; 
<emphasis id="BA62D83CDD33AC4EA3157269F1A418C9" italics="true" pageId="null" pageNumber="416">
am Grunde jeder 
<normalizedToken id="D6FF74E91144B5DAA50EDCBC3C2A0FA1" originalValue="Ähre" pageId="null" pageNumber="416">Aehre</normalizedToken>
mehrere, kleinere, keine 
<normalizedToken id="281252EB0ED34FED883D1F3590754EA3" originalValue="Blüten" pageId="null" pageNumber="416">Blueten</normalizedToken>
tragende 
<normalizedToken id="5B7A7F33F162470009CA567D116451AB" originalValue="Tragblätter" pageId="null" pageNumber="416">Tragblaetter</normalizedToken>
vorhanden; 
<normalizedToken id="6EA541F7A194F964F523BDF7CCD262D5" originalValue="Ähren" pageId="null" pageNumber="416">Aehren</normalizedToken>
1-6 
<normalizedToken id="BD83DEA0B306534A070B11D96EE2AE70" originalValue="blütig" pageId="null" pageNumber="416">bluetig</normalizedToken>
;
</emphasis>
<normalizedToken id="E46725026942D4DDE191DC1111BB343C" originalValue="Blüten" pageId="null" pageNumber="416">Blueten</normalizedToken>
zwitterig, schraubig angeordnet. Meist 
<emphasis id="A4A17688AEC5AAE5158596D16A437382" italics="true" pageId="null" pageNumber="416">keine Perigonborsten</emphasis>
vorhanden. An den unreifen 
<normalizedToken id="4F12D43C6E56BEA68D2465B54BD10FCE" originalValue="Früchten" pageId="null" pageNumber="416">Fruechten</normalizedToken>
die verdickte Griffelbasis durch eine 
<emphasis id="B31C84BDCC22C5DC930E84CA1DC7D467" italics="true" pageId="null" pageNumber="416">
<normalizedToken id="3390E395315EC82447D572F867916CD5" originalValue="Einschnürung" pageId="null" pageNumber="416">Einschnuerung</normalizedToken>
</emphasis>
mit der Frucht verbunden. Narben 3 oder 2. 
<normalizedToken id="6E97F589FA624326979D4B910892E107" originalValue="Staubblätter" pageId="null" pageNumber="416">Staubblaetter</normalizedToken>
3 oder 2.
</paragraph>
<paragraph id="D8AC6FC7DC7C1343A8B2B9050AD963E7" pageId="null" pageNumber="416">
Die Gattung 
<taxonomicName id="C61FFA14C5F38ABA4B00690140C14B73" class="Liliopsida" family="Cyperaceae" genus="Cladium" kingdom="Plantae" order="Poales" pageId="null" pageNumber="416" phylum="Tracheophyta" rank="genus">
<emphasis id="A1C296570FF6AD6927D0F07506CC19A9" italics="true" pageId="null" pageNumber="416">Cladium</emphasis>
</taxonomicName>
<normalizedToken id="7AB1422F576A5BA950449C4C945555DE" originalValue="umfaßt" pageId="null" pageNumber="416">umfasst</normalizedToken>
nach der 
<emphasis id="A657196A36DD52F25067C1CB3F00964A" italics="true" pageId="null" pageNumber="416">Monographie</emphasis>
von 
<normalizedToken id="EF2B7A81690F4F361BD0BFE9F5EA81E3" originalValue="Kükenthal" pageId="null" pageNumber="416">Kuekenthal</normalizedToken>
(1942) (
<normalizedToken id="ABADF08590C9442C002D0913030AC2D1" originalValue="sorgfältige" pageId="null" pageNumber="416">sorgfaeltige</normalizedToken>
Diagnosen und 
<normalizedToken id="24BEF012000699F749373B28D24DDA12" originalValue="Schlüssel" pageId="null" pageNumber="416">Schluessel</normalizedToken>
, Verbreitungsangaben, keine experimentellen Untersuchungen, keine Abbildungen) 
<emphasis id="E548C7325DA294DC68DF81AA17548523" italics="true" pageId="null" pageNumber="416">48 Arten;</emphasis>
die Gattung kommt in der Arktis und Antarktis nicht vor; 
<emphasis id="E8CB7A4BF60393FB45BC3C662BDFEEB7" italics="true" pageId="null" pageNumber="416">
in 
<taxonomicName id="2164AA86D8859F3EC9002B1FEA5033D4" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="416" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
nur 1 Art.
</emphasis>
Alle Arten sind 
<emphasis id="79360C44A095D0ECE4892CE798CFDEEC" italics="true" pageId="null" pageNumber="416">Sumpfpflanzen.</emphasis>
</paragraph>
</subSubSection>
</treatment>
