<emphasis id="B919EACFED673803FF4DF8BDFEEBF84F" bold="true" box="[136,302,1907,1934]" pageId="566" pageNumber="567">FIGURE 379.</emphasis>
<taxonomicName id="4C6D4D5EED673803FEF3F8BAFDC6F84F" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[310,515,1908,1934]" class="Maxillopoda" family="Notodelphyidae" genus="Contoura" kingdom="Animalia" order="Cyclopoida" pageId="566" pageNumber="567" phylum="Arthropoda" rank="species" species="globosa" status="gen. et sp. nov.">
<emphasis id="B919EACFED673803FEF3F8BAFDC6F84F" box="[310,515,1908,1934]" italics="true" pageId="566" pageNumber="567">Contoura globosa</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A22A57B4ED673803FDCFF8BAFD78F84F" box="[522,701,1908,1934]" pageId="566" pageNumber="567" rank="species">
<emphasis id="B919EACFED673803FDCFF8BAFD72F84F" bold="true" box="[522,695,1908,1934]" pageId="566" pageNumber="567">gen. et sp. nov</emphasis>
.
</taxonomicNameLabel>
, female. A, habitus, dorsal; B, habitus, right; C, urosome, ventral; D, cephalic region, ventral; E, rostrum; F, antennule; G, antenna; H, labrum, dorsal; I, mandible. Scale bars: A, B, 0.5 mm; C–E, H, 0.05 mm; F. G, I, 0.02 mm.
</paragraph>
</caption>
<caption id="DF126655ED663802FF4DFB05FB89FAC9" ID-DOI="http://doi.org/10.5281/zenodo.4592074" ID-Zenodo-Dep="4592074" httpUri="https://zenodo.org/record/4592074/files/figure.png" pageId="567" pageNumber="568" startId="567.[136,245,1227,1253]" targetBox="[168,1430,228,1172]" targetPageId="567">
