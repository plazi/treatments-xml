<emphasis id="B919EACFED663802FF4DFB05FEE8FB24" bold="true" box="[136,301,1227,1253]" pageId="567" pageNumber="568">FIGURE 380.</emphasis>
<taxonomicName id="4C6D4D5EED663802FEF0FB02FDC4FB24" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[309,513,1227,1254]" class="Maxillopoda" family="Notodelphyidae" genus="Contoura" kingdom="Animalia" order="Cyclopoida" pageId="567" pageNumber="568" phylum="Arthropoda" rank="species" species="globosa" status="gen. et sp. nov.">
<emphasis id="B919EACFED663802FEF0FB02FDC4FB24" box="[309,513,1227,1254]" italics="true" pageId="567" pageNumber="568">Contoura globosa</emphasis>
</taxonomicName>
