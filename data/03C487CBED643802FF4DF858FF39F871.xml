<subSubSection id="C3776556ED663802FF78F8C0FF39F871" pageId="567" pageNumber="568" type="discussion">
<paragraph id="8BD236DDED663802FF78F8C0FF39F871" blockId="567.[136,778,1363,1968]" pageId="567" pageNumber="568">
<emphasis id="B919EACFED663802FF78F8C0FEEFF8E9" bold="true" box="[189,298,1806,1832]" pageId="567" pageNumber="568">Remarks</emphasis>
. The host of the new species, 
<taxonomicName id="4C6D4D5EED663802FD66F8C3FF30F88B" class="Ascidiacea" family="Polyclinidae" genus="Aplidium" kingdom="Animalia" order="Enterogona" pageId="567" pageNumber="568" phylum="Chordata" rank="species" species="antillense">
<emphasis id="B919EACFED663802FD66F8C3FF30F88B" italics="true" pageId="567" pageNumber="568">Aplidium antillense</emphasis>
</taxonomicName>
, is distributed in the western Atlantic from 
<collectingCountry id="F37A764DED663802FF4DF89CFF27F8AD" box="[136,226,1874,1900]" name="Georgia" pageId="567" pageNumber="568">Georgia</collectingCountry>
(
<collectingCountry id="F37A764DED663802FF34F89CFDD5F8AC" box="[241,528,1874,1901]" name="United States of America" pageId="567" pageNumber="568">United States of America</collectingCountry>
) in the north to 
<collectingCountry id="F37A764DED663802FD00F89CFCCCF8AD" box="[709,777,1874,1900]" name="Brazil" pageId="567" pageNumber="568">Brazil</collectingCountry>
in the south (
<bibRefCitation id="EFFC4B2CED663802FEDAF8BAFDAAF84F" author="Sanamyan, K. &amp; Gleason, D. F." box="[287,623,1908,1934]" journalOrPublisher="Zootaxa" pageId="567" pageNumber="568" pagination="50 - 58" part="2066" refId="ref330564" refString="Sanamyan, K. &amp; Gleason, D. F. (2009) Ascidians of the genus Aplidium collected on shallow hard-bottom reefs of coastal Georgia (Atlantic coast of N America, U. S. A.). Zootaxa, 2066, 50 - 58. https: // doi. org / 10.11646 / zootaxa. 2066.1.2" title="Ascidians of the genus Aplidium collected on shallow hard-bottom reefs of coastal Georgia (Atlantic coast of N America, U. S. A.)" type="journal article" year="2009">Sanamyan &amp; Gleason, 2009</bibRefCitation>
; 
<bibRefCitation id="EFFC4B2CED663802FDB9F8BAFF35F871" author="Da Rocha, R. M. &amp; Gamba, G. A. &amp; Zanata, T. B." journalOrPublisher="Zootaxa" pageId="567" pageNumber="568" pagination="18 - 30" part="3565" refId="ref327798" refString="Da Rocha, R. M., Gamba, G. A. &amp; Zanata, T. B. (2012) Aplidium (Ascidiacea, Polyclinidae) in central coast, Brazil. Zootaxa, 3565, 18 - 30. https: // doi. org / 10.11646 / zootaxa. 3565.1.2" title="Aplidium (Ascidiacea, Polyclinidae) in central coast, Brazil" type="journal article" year="2012">
Da Rocha 
<emphasis id="B919EACFED663802FD30F8BAFF5BF871" italics="true" pageId="567" pageNumber="568">et al</emphasis>
., 2012
</bibRefCitation>
).
</paragraph>
