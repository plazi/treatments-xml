<bibRefCitation DOI="https://doi.org/10.1093/ae/tmx033" author="Miller, KB" journalOrPublisher="Johns Hopkins University Press, Baltimore" pageId="0" pageNumber="301" refId="B64" refString="Miller, KB, Bergsten, J, 2016. Diving beetles of the world. Johns Hopkins University Press, Baltimore, DOI: https://doi.org/10.1093/ae/tmx033" title="Diving beetles of the world." url="https://doi.org/10.1093/ae/tmx033" year="2016">Miller and Bergsten 2016</bibRefCitation>
) and comprises 40 species (
<bibRefCitation author="Nilsson, AN" journalOrPublisher="Dugesiana" pageId="0" pageNumber="301" publicationUrl="http://www.waterbeetles.eu" refId="B75" refString="Nilsson, AN, Hajek, J, 2020. A World Catalogue of the Family Dytiscidae, or the Diving Beetles (Coleoptera, Adephaga). Version 1.I.2020. National Museum, Prague. http://www.waterbeetles.eu" title="A World Catalogue of the Family Dytiscidae, or the Diving Beetles (Coleoptera, Adephaga). Version 1. I. 2020. National Museum, Prague." url="http://www.waterbeetles.eu" year="2020">
Nilsson and 
<normalizedToken originalValue="Hájek">Hajek</normalizedToken>
2020
</bibRefCitation>
), with four species recorded from Mexico (
<bibRefCitation DOI="https://doi.org/10.32870/dugesiana.v6i2.3914" author="Arce-Perez, A" journalOrPublisher="Dugesiana" pageId="0" pageNumber="301" pagination="69 - 104" refId="B6" refString="Arce-Perez, A, Roughley, RE, 1999. Lista anotada y claves para los Hydradephaga (Coleoptera: Adephaga: Dytiscidae, Noteridae, Haliplidae, Gyrinidae) de Mexico. Dugesiana 6 (2): 69 - 104, DOI: https://doi.org/10.32870/dugesiana.v6i2.3914" title="Lista anotada y claves para los Hydradephaga (Coleoptera: Adephaga: Dytiscidae, Noteridae, Haliplidae, Gyrinidae) de Mexico." url="https://doi.org/10.32870/dugesiana.v6i2.3914" volume="6" year="1999">
<normalizedToken originalValue="Arce-Pérez">Arce-Perez</normalizedToken>
