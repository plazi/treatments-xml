<subSubSection id="DA21D6DD81EEE9931229F256FC31193F" pageId="0" pageNumber="77507" type="ecology">
<paragraph id="C1B750564D850A35058845E5FB353C30" pageId="0" pageNumber="77507">Ecology</paragraph>
<paragraph id="C189ED70C073F739114A613DCA8B6B03" pageId="0" pageNumber="77507">
At the ASDIA Wild Game Farm (
<geoCoordinate id="EDF01C30B4AB9FEB00AB2F98E21FA234" degrees="24" direction="south" minutes="26" orientation="latitude" precision="925" value="-24.433332">24°26'S</geoCoordinate>
