<subSubSection id="030264AC29E3E7D4A76FA5A8A359507E" pageId="null" pageNumber="190" type="description">
<paragraph id="7657A2975517A1BD2D6FED4EE294FB87" lastPageNumber="189" pageId="null" pageNumber="190">
Ausdauernd, mit Pfahlwurzel und verzweigtem Rhizom, das noch von Blattresten 
<normalizedToken id="BE30E4122EA35A494D32FAC1C1308C45" originalValue="vorjähriger" pageId="null" pageNumber="190">vorjaehriger</normalizedToken>
<normalizedToken id="37C01B6692E9BECB80209A85572F9243" originalValue="Blätter" pageId="null" pageNumber="190">Blaetter</normalizedToken>
bedeckt ist; 
<emphasis id="BD59CEA59428004A45BADCFBD636D351" italics="true" pageId="null" pageNumber="190">3-15 cm hoch. Stengel aufrecht, unverzweigt, blattlos</emphasis>
(bei den andern Arten des Gebiets 
<normalizedToken id="B797D14E540CF7E4290B9325C4E40C98" originalValue="beblättert" pageId="null" pageNumber="190">beblaettert</normalizedToken>
), kahl. Alle 
<normalizedToken id="40E6D893A7B18BB2D7C7555A0A5C003A" originalValue="Blätter" pageId="null" pageNumber="190">Blaetter</normalizedToken>
<normalizedToken id="C406368417EA7C65548884747D6308E5" originalValue="grundständig" pageId="null" pageNumber="190">grundstaendig</normalizedToken>
gestielt, 
<emphasis id="296E72D38CB8D8016C908442FB9E84CC" italics="true" pageId="null" pageNumber="190">bis ca. 4 cm lang</emphasis>
(mit Stiel, bei den andern Arten des Gebiets meist bedeutend 
<normalizedToken id="7ACFEA0C1832AA7760F5C43046E249F4" originalValue="größer" pageId="null" pageNumber="190">groesser</normalizedToken>
), ungeteilt, mit jederseits 0-5 nach vorn gerichteten 
<normalizedToken id="DF031665E2522906222F0974078FFDDC" originalValue="Zähnen" pageId="null" pageNumber="190">Zaehnen</normalizedToken>
, 
<normalizedToken id="F42DA7852C678197945CD43E5C749AC9" originalValue="spatelförmig" pageId="null" pageNumber="190">spatelfoermig</normalizedToken>
bis lanzettlich, kahl, fleischig. 
<normalizedToken id="D8E818EDC023AB8D11BFA7AC51B8A561" originalValue="Blütenstiele" pageId="null" pageNumber="190">Bluetenstiele</normalizedToken>
⅔-1⅓mal so lang wie die
<pageBreakToken id="A8A708D9E37C13ADC84B728271B69542" pageId="null" pageNumber="189" start="start">,</pageBreakToken>
5-6 mm lang, kahl. 
<normalizedToken id="CAC52BC117E3C11A9E3454ED63D4BBD1" originalValue="Kronblätter" pageId="null" pageNumber="189">Kronblaetter</normalizedToken>
9-12 mm lang, lang gestielt, gelb. Fruchtstiele 4-12 mm lang. 
<normalizedToken id="36D85ADB80849D9D00E785D236CA8470" originalValue="Früchte" pageId="null" pageNumber="189">Fruechte</normalizedToken>
aufrecht abstehend, 2-4 cm lang und 3-3,5 mm dick, 10-20samig, kahl; Schnabel 2,5-3 mm lang, ohne Samen, 
<normalizedToken id="BC46E648C880DF9760DE286584D141C2" originalValue="dünn" pageId="null" pageNumber="189">duenn</normalizedToken>
und zylindrisch. Samen 2 mm lang. - 
<normalizedToken id="6E3205BBC77A3065242A791619B0DBC1" originalValue="Blüte" pageId="null" pageNumber="189">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="9039FCD0EFC70E1788ADD70123B19ACB" pageId="null" pageNumber="189">
<emphasis id="C3A84A6AC71D13B8465ED58541E4FBE0" italics="true" pageId="null" pageNumber="189">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="C00F04BA47AA4791C119AF9BF33AF2B3" italics="true" pageId="null" pageNumber="189">20:</emphasis>
Material vom Col du Galibier (Favarger und Huynh in 
<normalizedToken id="955A55DA0CD64B1E40C22D0E03613E61" originalValue="Löve" pageId="null" pageNumber="189">Loeve</normalizedToken>
und Solbrig 1964a, Favarger 1965).
</paragraph>
<paragraph id="50E6E7109C1C4CA6F5CC47D093797DD5" pageId="null" pageNumber="189">
<emphasis id="E22AEB28EFC5E69F876AA5DA45EC8133" italics="true" pageId="null" pageNumber="189">Standort.</emphasis>
Subalpin und alpin. Felsschutt, steinige 
<normalizedToken id="46F4627FA676AD6787F74A7CE61FEDDA" originalValue="Hänge" pageId="null" pageNumber="189">Haenge</normalizedToken>
, auf kalkhaltiger Unterlage. 
<emphasis id="5A4B25A4DFCB07E67356B7FB9DB7AACF" italics="true" pageId="null" pageNumber="189">Leontodontetum montani</emphasis>
Jenny-Lips 1930.
</paragraph>
<paragraph id="1C753DB3DB7B1423CA6318D86AA8B3A6" pageId="null" pageNumber="190">
<emphasis id="EDC213C3E5BDC4F375B1EE3C1256E030" italics="true" pageId="null" pageNumber="190">
<pageBreakToken id="01020B18F8EC1A34D9292F3C3F63E793" pageId="null" pageNumber="190">Verbreitung</pageBreakToken>
. 
<normalizedToken id="3DDB2BEEC19E514AE94FBB16D111658B" originalValue="Südwestalpen-Pflanze" pageId="null" pageNumber="190">Suedwestalpen-Pflanze</normalizedToken>
:
</emphasis>
Valle di Susa und 
<normalizedToken id="E65F9F015FAE2FD222317E83A440F0F1" originalValue="Südsavoyen" pageId="null" pageNumber="190">Suedsavoyen</normalizedToken>
bis Alpes Maritimes. Im Gebiet: Savoyen (Gegend zwischen St-Jean de Maurienne und Col du Galibier).
</paragraph>
<paragraph id="9692DC3E53F016AD775DB2C5477862D4" pageId="null" pageNumber="190">
<emphasis id="9FC5992F87875FEF33512B161C7C45C0" italics="true" pageId="null" pageNumber="190">
Bemerkungen. 
<taxonomicName id="54F3B6143F1CA64E4440BB89636004F8" class="Insecta" family="Melolonthidae" genus="Diplotaxis" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="190" phylum="Arthropoda" rank="species" species="repanda">B. repanda</taxonomicName>
</emphasis>
vermittelt morphologisch zur Gattung 
<emphasis id="9891A2BE196CF90DA32E629D8C1FDBBC" italics="true" pageId="null" pageNumber="190">
<taxonomicName id="DF68F698EDEAAB9359AD0501F523B4EC" class="Insecta" family="Melolonthidae" genus="Diplotaxis" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="190" phylum="Arthropoda" rank="genus">Diplotaxis</taxonomicName>
.
</emphasis>
</paragraph>
</subSubSection>
