<taxonomicName id="4C6C6AE4FFDDFFE9FC0C523E5F4DF5C0" box="[944,1324,2615,2644]" class="Mammalia" family="Echimyidae" genus="Echimys" kingdom="Animalia" order="Rodentia" pageId="48" pageNumber="600" phylum="Chordata" rank="species" species="kerri" subGenus="Phyllomys">Echimys (Phyllomys) kerri</taxonomicName>
