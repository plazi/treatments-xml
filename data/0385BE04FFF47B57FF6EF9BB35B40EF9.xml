<taxonomicName id="4C2C7491FFF47B57FD0EF96537260E73" authorityName="Fabricius" authorityYear="1775" box="[712,776,1770,1794]" class="Insecta" family="Noctuidae" genus="Thyas" kingdom="Animalia" order="Lepidoptera" pageId="15" pageNumber="1116" phylum="Arthropoda" rank="genus">
