<subSubSection id="C851D954165F8F8636BC330DCFDEFBF3" pageId="null" pageNumber="242" type="description">
<paragraph id="534E67575C359F1A0DEC7A8AFB653F27" pageId="null" pageNumber="242">
40-100 cm hoch. 
<emphasis id="16164B5588572CA32BE508C9622346B0" italics="true" pageId="null" pageNumber="242">
<normalizedToken id="F9A06A97F93AD0D7481D21D6FEB4D0DE" originalValue="Blätter" pageId="null" pageNumber="242">Blaetter</normalizedToken>
5-7mal so lang wie breit
</emphasis>
, die untern jederseits mit 2-5 
<emphasis id="DC2C7F647F0AED099E6191362E6CCF98" italics="true" pageId="null" pageNumber="242">
meist weniger als 1 mm langen 
<normalizedToken id="D3F1747E694E8F9096032D8908C6310A" originalValue="Zähnen" pageId="null" pageNumber="242">Zaehnen</normalizedToken>
. 
<normalizedToken id="804381B21D05E4C0D7107A4EF211B7A0" originalValue="Kelchblätter" pageId="null" pageNumber="242">Kelchblaetter</normalizedToken>
5-6 mm lang. 
<normalizedToken id="740EEB15D12F13DD5D0B816DACFC05C5" originalValue="Kronblätter" pageId="null" pageNumber="242">Kronblaetter</normalizedToken>
8-11 mm lang
</emphasis>
, gelb. Staubbeutel 1,2-1,8 mm lang. - 
<normalizedToken id="77ED16C614FA23BFBE05B49D47E34243" originalValue="Blüte" pageId="null" pageNumber="242">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="3D228769301287182C0FE4E743F3C25D" pageId="null" pageNumber="242">
<emphasis id="1E392BAC42C63C91AE5F24BF3D73F6E9" italics="true" pageId="null" pageNumber="242">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B52D5D83490B0325AEA4B7762DE47200" italics="true" pageId="null" pageNumber="242">32:</emphasis>
Material unbekannter Herkunft (Jaretzky 1928a), aus Island (
<normalizedToken id="623FDDFAC883FF7F3E5D071319B83B1E" originalValue="Löve" pageId="null" pageNumber="242">Loeve</normalizedToken>
und 
<normalizedToken id="59E914BFFF11533B6731F7C99CCECFB2" originalValue="Löve" pageId="null" pageNumber="242">Loeve</normalizedToken>
1956b), aus Polen (Jankun 1966a), aus 
<normalizedToken id="739DDCC3DCB3934070A5D68A52041E88" originalValue="Österreich" pageId="null" pageNumber="242">Oesterreich</normalizedToken>
(Polatschek 1966). Mulligan (1959) 
<normalizedToken id="BE273196F08FBEB444A78E8983778486" originalValue="zählte" pageId="null" pageNumber="242">zaehlte</normalizedToken>
an Material aus Kanada 2n = 48.
</paragraph>
<paragraph id="D1F62367B680542503BFC798EA5251A2" pageId="null" pageNumber="242">
<emphasis id="F49D91BB5F8D66E568F90DB88640A519" italics="true" pageId="null" pageNumber="242">Standort.</emphasis>
Kollin und montan, selten subalpin. 
<normalizedToken id="64504F4D450C22D2D4C0284EBDE18039" originalValue="Nährstoff-" pageId="null" pageNumber="242">Naehrstoff-</normalizedToken>
und kalkreiche 
<normalizedToken id="8D297BABB36B00EEB54455C30AD0C755" originalValue="Böden" pageId="null" pageNumber="242">Boeden</normalizedToken>
in halbschattigen Lagen. 
<normalizedToken id="7D7B117D9ED60B7B8A2E36976D2988AF" originalValue="Gebüsche" pageId="null" pageNumber="242">Gebuesche</normalizedToken>
, Alluvionen, 
<normalizedToken id="A98BE2932133F49CF0ABD126C38E4972" originalValue="Wegränder" pageId="null" pageNumber="242">Wegraender</normalizedToken>
, Schuttstellen.
</paragraph>
<paragraph id="F25D7D1D56366E9AFC193D97EE214902" pageId="null" pageNumber="242">
<emphasis id="EE8CBFA8477A29469EE737C953F4A342" italics="true" pageId="null" pageNumber="242">Verbreitung. Eurasiatische Pflanze:</emphasis>
<normalizedToken id="A73833D61FE814350E620B2FFBDCFA97" originalValue="Nordwärts" pageId="null" pageNumber="242">Nordwaerts</normalizedToken>
bis Island, Nordkap, Nordsibirien; 
<normalizedToken id="56A1A1D7CAD809B0DB8C0AEDEAB4DABD" originalValue="ostwärts" pageId="null" pageNumber="242">ostwaerts</normalizedToken>
bis Kamtschatka; west- und 
<normalizedToken id="38E5B11D78B0D2A5F2390EA6E27455C8" originalValue="südwärts" pageId="null" pageNumber="242">suedwaerts</normalizedToken>
bis Mosel, Rhone, Alpen, Herzegowina, Dobrudscha, Kaukasus. - Im Gebiet vielleicht nicht 
<normalizedToken id="2AFDD4E13FF787F4CF013ACCEEAE74D0" originalValue="ursprünglich" pageId="null" pageNumber="242">urspruenglich</normalizedToken>
: Gegend von Beifort, Oberrheinische Tiefebene, Neuenburgerseegebiet, Creux du Van, Moron oberhalb Saut du Doubs, 
<normalizedToken id="A6FE355A3712B1DB03D2B1726450F635" originalValue="Château" pageId="null" pageNumber="242">Chateau</normalizedToken>
<normalizedToken id="A819C0D5F02F2A6B922CA6D31BC17B72" originalValue="d’Œx" pageId="null" pageNumber="242">d'Oex</normalizedToken>
, Wallis (Salvaln, Saxon); auch adventiv.
</paragraph>
<paragraph id="240311F93614B434B94BBB2CB5B9B8E0" pageId="null" pageNumber="242">
<emphasis id="12AC62F545BE6AA295D36988AC6771FD" italics="true" pageId="null" pageNumber="242">Bemerkungen.</emphasis>
Siehe unter 
<taxonomicName id="706F575F8625ADC157C3D1A3CBC50CFF" class="Magnoliopsida" family="Brassicaceae" genus="Erysimum" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="242" phylum="Tracheophyta" rank="species" species="virgatum">
<emphasis id="422100F9EC89EF47E2B0210C6D2E50CB" italics="true" pageId="null" pageNumber="242">E. virgatum</emphasis>
</taxonomicName>
(Nr. 4c).
</paragraph>
</subSubSection>
