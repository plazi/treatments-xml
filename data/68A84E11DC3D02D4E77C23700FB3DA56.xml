<paragraph id="E7F4B5A4A11B1B6D83BB3274D4C17B25" pageId="null" pageNumber="151">
Glattes 
<normalizedToken id="10026DE0F0761C1D0F3C22D6E3D767E5" originalValue="Brillenschötchen" pageId="null" pageNumber="151">Brillenschoetchen</normalizedToken>
</paragraph>
