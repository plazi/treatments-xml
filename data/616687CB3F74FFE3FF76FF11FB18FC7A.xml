</taxonomicName>
, 
<taxonomicName id="2ECF4D5E3F74FFE3FDAEFD77FCF0FCEB" authorityName="Kovacic &amp; Miller" authorityYear="2000" box="[591,784,752,779]" class="Actinopterygii" family="Gobiidae" genus="Gobius" kingdom="Animalia" order="Perciformes" pageId="65" pageNumber="66" phylum="Chordata" rank="species" species="kolombatovici">
<emphasis id="DBBBEACF3F74FFE3FDAEFD77FD83FCEA" box="[591,611,753,779]" italics="true" pageId="65" pageNumber="66">G</emphasis>
