<taxonomicName id="2ECF4D5E3F74FFE3FCFFFD76FBC4FCEB" authorityName="Brownell" authorityYear="1978" box="[798,1060,752,778]" class="Actinopterygii" family="Gobiidae" genus="Vanneaugobius" kingdom="Animalia" order="Perciformes" pageId="65" pageNumber="66" phylum="Chordata" rank="species" species="dollfusi">
