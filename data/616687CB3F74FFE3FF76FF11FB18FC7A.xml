<taxonomicName id="2ECF4D5E3F74FFE3FE9EFD76FDA1FCEB" authorityName="Miller" authorityYear="1974" box="[383,577,752,778]" class="Actinopterygii" family="Gobiidae" genus="Gobius" kingdom="Animalia" order="Perciformes" pageId="65" pageNumber="66" phylum="Chordata" rank="species" species="gasteveni">
