<taxonomicName id="57E14D7CFFFBBD511CACACF893D104C0" authority="Assing, 2014" authorityName="Assing" authorityYear="2014" box="[898,1012,1420,1440]" class="Insecta" family="Staphylinidae" genus="Orsunius" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="465" phylum="Arthropoda" rank="species" species="gladiator" status="nov.sp.">
