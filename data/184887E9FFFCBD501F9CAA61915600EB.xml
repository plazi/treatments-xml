<taxonomicNameLabel id="B9A65796FFFBBD511CD5ACF8941B04C0" box="[1019,1086,1420,1440]" pageId="4" pageNumber="465" rank="species">nov.sp.</taxonomicNameLabel>
(
<emphasis id="A295EAEDFFFBBD511F94ACD790E004D7" bold="true" box="[186,197,1443,1463]" pageId="4" pageNumber="465">9</emphasis>
): (
<emphasis id="A295EAEDFFFBBD511FCEACD790CE04D7" bold="true" box="[224,235,1443,1463]" pageId="4" pageNumber="465">1</emphasis>
) habitus; (
<emphasis id="A295EAEDFFFBBD511E60ACD7917C04D7" bold="true" box="[334,345,1443,1463]" pageId="4" pageNumber="465">2</emphasis>
