<paragraph id="905E36FFFFFBBD511F9CAC8692A50746" blockId="4.[178,1085,1522,1574]" pageId="4" pageNumber="465">
aedeagus (
<figureCitation id="08DA2A7AFFFBBD511E30AC8691530768" box="[286,374,1522,1544]" captionStart="Figs 1-9" captionStartId="4.[178,218,1420,1440]" captionTargetBox="[186,1058,212,1392]" captionTargetId="figure-2@4.[178,1063,212,1409]" captionTargetPageId="4" captionText="Figs 1-9: Orsunius spathulatus nov.sp. (1-6), O. stimulans nov.sp. (7-8), and O. gladiator nov.sp. (9): (1) habitus; (2) forebody; (3, 8, 9) male sternite VIII; (4) posterior portion of male sternite VIII; (5) aedeagus in lateral view; (6) ventral process in ventral view; (7) male sternite VII. Scale bars: 1- 2: 1.0 mm; 3-9: 0.2 mm." figureDoi="http://doi.org/10.5281/zenodo.5305063" httpUri="https://zenodo.org/record/5305063/files/figure.png" pageId="4" pageNumber="465">Figs 5-6</figureCitation>
) 
<quantity id="57199B1AFFFBBD511EA8AC8691C40768" box="[390,481,1522,1544]" metricMagnitude="-4" metricUnit="m" metricValue="4.5" pageId="4" pageNumber="465" unit="mm" value="0.45">0.45 mm</quantity>
