<taxonomicNameLabel id="B9A65796FFFBBD511DF9ACF8933F04C0" box="[727,794,1420,1440]" pageId="4" pageNumber="465" rank="species">nov.sp.</taxonomicNameLabel>
(
<emphasis id="A295EAEDFFFBBD511C09ACF8936304C0" bold="true" box="[807,838,1420,1440]" pageId="4" pageNumber="465">7-8</emphasis>
