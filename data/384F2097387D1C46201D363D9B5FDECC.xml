<taxonomicName id="717EBCF73684236E464A38959EB7CD31" class="Magnoliopsida" family="Asteraceae" genus="Cirsium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="417" phylum="Tracheophyta" rank="species" species="pannonicum">
