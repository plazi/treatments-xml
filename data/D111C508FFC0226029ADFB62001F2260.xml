<paragraph id="5907741EFFC022602998FA0A001F2260" blockId="2.[136,1451,1352,1595]" pageId="2" pageNumber="109">
<emphasis id="6BCCA80CFFC022602998FA0A07F2224C" bold="true" box="[189,756,1532,1559]" pageId="2" pageNumber="109">
Distribution of genus 
<taxonomicName id="9EB80F9DFFC0226028E7FA0A0733224D" box="[450,565,1532,1559]" class="Liliopsida" family="Poaceae" genus="Louisiella" kingdom="Plantae" order="Poales" pageId="2" pageNumber="109" phylum="Tracheophyta" rank="genus">
<emphasis id="6BCCA80CFFC0226028E7FA0A0733224D" bold="true" box="[450,565,1532,1559]" italics="true" pageId="2" pageNumber="109">Louisiella</emphasis>
</taxonomicName>
in the world: 
<emphasis id="6BCCA80CFFC022602BFDFA0A07F2224C" bold="true" box="[728,756,1532,1558]" italics="true" pageId="2" pageNumber="109">—</emphasis>
</emphasis>
