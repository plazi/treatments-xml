<paragraph id="902B555AFFCAFFBCAFF9FECAFCB2C65F" blockId="74.[192,791,315,345]" box="[192,791,315,345]" pageId="74" pageNumber="73">
<heading id="CB63E236FFCAFFBCAFF9FECAFCB2C65F" box="[192,791,315,345]" fontSize="12" level="2" pageId="74" pageNumber="73" reason="2">
<emphasis id="A2E08948FFCAFFBCAFF9FECAFCB2C65F" bold="true" box="[192,791,315,345]" pageId="74" pageNumber="73">
<taxonomicName id="57942ED9FFCAFFBCAFF9FECAFD9CC65E" authority="(Plotz, 1882)" baseAuthorityName="Plotz" baseAuthorityYear="1882" box="[192,569,315,345]" class="Insecta" family="Hesperiidae" genus="Cymaenes" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="edata">
<emphasis id="A2E08948FFCAFFBCAFF9FECAFE29C65F" bold="true" box="[192,396,315,344]" italics="true" pageId="74" pageNumber="73">Cymaenes edata</emphasis>
(Plötz, 1882)
</taxonomicName>
, reinstated status
</emphasis>
</heading>
</paragraph>
</subSubSection>
<subSubSection id="D88E06D1FFCAFFBCAFF9FE9FFC03C556" pageId="74" pageNumber="73" type="reference_group">
<paragraph id="902B555AFFCAFFBCAFF9FE9FFC03C556" blockId="74.[192,1440,360,593]" pageId="74" pageNumber="73">
<taxonomicName id="57942ED9FFCAFFBCAFF9FE9FFE4EC685" authority="Plotz, 1882" authorityName="Plotz" authorityYear="1882" box="[192,491,360,386]" class="Insecta" family="Hesperiidae" genus="Hesperia" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="edata">
<emphasis id="A2E08948FFCAFFBCAFF9FE9FFEC0C685" box="[192,357,360,386]" italics="true" pageId="74" pageNumber="73">Hesperia edata</emphasis>
Plötz, 1882
</taxonomicName>
(
<typeStatus id="4F2FEBF8FFCAFFBCAEC2FE9EFD88C685" box="[507,557,360,386]" pageId="74" pageNumber="73">type</typeStatus>
locality 
<collectingCountry id="E88315CAFFCAFFBCADB6FE9EFCA1C685" box="[655,772,360,386]" name="Venezuela" pageId="74" pageNumber="73">Venezuela</collectingCountry>
: La Guaira) was treated by 
<bibRefCitation id="F40528ABFFCAFFBCAB04FE9FFB75C684" author="Evans WH" box="[1085,1232,360,387]" pageId="74" pageNumber="73" pagination="54 - 88" refId="ref85135" refString="Evans WH. 1955. A catalogue of the American Hesperiidae indicating the classification and nomenclature adopted in the British Museum (Natural History). Part IV. Hesperiinae and Megathyminae. British Museum (Natural History); London. v + 499 p., pl. 54 - 88." type="book chapter" year="1955">Evans (1955)</bibRefCitation>
as a subspecies of 
<taxonomicName id="57942ED9FFCAFFBCAFFBFE7DFDF3C6A2" authority="(Burmeister, 1878)" authorityName="" baseAuthorityName="Burmeister" baseAuthorityYear="1878" box="[194,598,395,421]" class="Insecta" family="Hesperiidae" genus="Cymaenes" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="odilia">
<emphasis id="A2E08948FFCAFFBCAFFBFE7DFEDCC6A2" box="[194,377,395,421]" italics="true" pageId="74" pageNumber="73">Cymaenes odilia</emphasis>
(Burmeister, 1878)
</taxonomicName>
(
<typeStatus id="4F2FEBF8FFCAFFBCAD5EFE7DFD3CC6A2" box="[615,665,395,421]" pageId="74" pageNumber="73">type</typeStatus>
locality 
<collectingCountry id="E88315CAFFCAFFBCADC6FE7DFCD1C6A1" box="[767,884,395,422]" name="Argentina" pageId="74" pageNumber="73">Argentina</collectingCountry>
), but it is not monophyletic with it. As we have shown above, 
<taxonomicName id="57942ED9FFCAFFBCAE5BFE58FE64C6C0" authorityName="" baseAuthorityName="Burmeister" baseAuthorityYear="1878" box="[354,449,429,456]" class="Insecta" family="Hesperiidae" genus="Cymaenes" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="odilia">
<emphasis id="A2E08948FFCAFFBCAE5BFE58FE64C6C0" box="[354,449,429,456]" italics="true" pageId="74" pageNumber="73">C. odilia</emphasis>
</taxonomicName>
is a junior subjective synonym of 
<taxonomicName id="57942ED9FFCAFFBCAC77FE58FA95C6CF" authority="(Herrich-Schaffer, 1869)" authorityName="Zhang &amp; Cong &amp; Shen &amp; Grishin" authorityYear="2022" baseAuthorityName="Herrich-Schaffer" baseAuthorityYear="1869" box="[846,1328,429,456]" class="Insecta" family="Hesperiidae" genus="Cymaenes" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="lumina">
<emphasis id="A2E08948FFCAFFBCAC77FE58FBB1C6C0" box="[846,1044,429,456]" italics="true" pageId="74" pageNumber="73">Cymaenes lumina</emphasis>
(
<bibRefCitation id="F40528ABFFCAFFBCAB1CFE5BFA8DC6CF" author="Herrich-Schaffer GAW" box="[1061,1320,429,456]" pageId="74" pageNumber="73" pagination="184 - 204" refId="ref85514" refString="Herrich-Schaffer GAW. 1869. Prodromus systematis lepidopterorum. Versuch einer systematischen Anordnung der Schmetterlinge. Correspondenz-Blatt des zoologisch-mineralogischen Vereines in Regensburg 23 (12): 184 - 204." type="journal article" year="1869">Herrich-Schäffer, 1869</bibRefCitation>
)
</taxonomicName>
(
<figureCitation id="08AF49DFFFCAFFBCAA78FE5BFA36C6C0" box="[1345,1427,429,455]" captionStart="Figure 14" captionStartId="67.[192,268,1900,1926]" captionTargetBox="[194,1437,361,1873]" captionTargetId="figure-11@67.[192,1440,361,1878]" captionTargetPageId="67" captionText="Figure 14. Genomic tree of Moncina, part 2. See Fig. 1 legend for notations." figureDoi="http://doi.org/10.5281/zenodo.6392088" httpUri="https://zenodo.org/record/6392088/files/figure.png" pageId="74" pageNumber="73">Fig. 14</figureCitation>
). Instead, in the genomic tree, 
<emphasis id="A2E08948FFCAFFBCAD31FE26FDD8C6EE" box="[520,637,463,490]" italics="true" pageId="74" pageNumber="73">
C. o. 
<taxonomicName id="57942ED9FFCAFFBCAD78FE39FDD8C6EE" authorityName="Plotz" authorityYear="1882" box="[577,637,463,489]" class="Insecta" family="Hesperiidae" genus="Hesperia" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="edata">edata</taxonomicName>
</emphasis>
is sister to 
<taxonomicName id="57942ED9FFCAFFBCADC5FE26FBF8C6ED" authority="(Godman, 1900)" baseAuthorityName="Godman" baseAuthorityYear="1900" box="[764,1117,463,490]" class="Insecta" family="Hesperiidae" genus="Cymaenes" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="isus">
<emphasis id="A2E08948FFCAFFBCADC5FE26FC3EC6EE" box="[764,923,464,490]" italics="true" pageId="74" pageNumber="73">Cymaenes isus</emphasis>
(Godman, 1900)
</taxonomicName>
(
<typeStatus id="4F2FEBF8FFCAFFBCAB52FE26FB38C6ED" box="[1131,1181,464,490]" pageId="74" pageNumber="73">type</typeStatus>
locality 
<collectingCountry id="E88315CAFFCAFFBCABC7FE39FAF1C6EE" box="[1278,1364,463,489]" name="Mexico" pageId="74" pageNumber="73">Mexico</collectingCountry>
: 
<collectingRegion id="52509BB8FFCAFFBCAA67FE26FF56C50A" country="Mexico" name="Guerrero" pageId="74" pageNumber="73">Guerrero</collectingRegion>
). Therefore, we reinstate 
<taxonomicName id="57942ED9FFCAFFBCAD29FE04FCFEC50B" authority="(Plotz, 1882)" baseAuthorityName="Plotz" baseAuthorityYear="1882" box="[528,859,498,524]" class="Insecta" family="Hesperiidae" genus="Cymaenes" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="edata">
<emphasis id="A2E08948FFCAFFBCAD29FE04FD61C50B" box="[528,708,498,524]" italics="true" pageId="74" pageNumber="73">Cymaenes edata</emphasis>
(Plötz, 1882)
</taxonomicName>
as a species. With this action, and pending further studies, we follow 
<bibRefCitation id="F40528ABFFCAFFBCAEADFDE2FD27C528" author="Llorente JE &amp; Luis MA &amp; Vargas A." box="[404,642,532,559]" pageId="74" pageNumber="73" pagination="1 - 70" refId="ref86288" refString="Llorente JE, Luis MA, Vargas A. 1990. Catalogo sistematico de los Hesperioidea de Mexico. Publicaciones especiales del Museo de Zoologia. Facultad de Ciencias. Universidad nacional autonoma de Mexico 1: 1 - 70." type="journal article" year="1990">Llorente et al. (1990)</bibRefCitation>
in considering North American 
<taxonomicName id="57942ED9FFCAFFBCACC2FDE3FBE0C529" baseAuthorityName="Godman" baseAuthorityYear="1900" box="[1019,1093,533,559]" class="Insecta" family="Hesperiidae" genus="Cymaenes" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="isus">
<emphasis id="A2E08948FFCAFFBCACC2FDE3FBE0C529" box="[1019,1093,533,559]" italics="true" pageId="74" pageNumber="73">C. isus</emphasis>
</taxonomicName>
(formerly 
<taxonomicName id="57942ED9FFCAFFBCABFBFDE3FA8EC529" authorityName="" baseAuthorityName="Mabille" baseAuthorityYear="1891" box="[1218,1323,532,559]" class="Insecta" family="Hesperiidae" genus="Cymaenes" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="trebius">
<emphasis id="A2E08948FFCAFFBCABFBFDE3FA8EC529" box="[1218,1323,532,559]" italics="true" pageId="74" pageNumber="73">C. trebius</emphasis>
</taxonomicName>
) a species distinct from South American 
<taxonomicName id="57942ED9FFCAFFBCAD2FFDC1FDD4C556" baseAuthorityName="Plotz" baseAuthorityYear="1882" box="[534,625,567,593]" class="Insecta" family="Hesperiidae" genus="Cymaenes" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="edata">
<emphasis id="A2E08948FFCAFFBCAD2FFDC1FDD4C556" box="[534,625,567,593]" italics="true" pageId="74" pageNumber="73">C. edata</emphasis>
</taxonomicName>
(formerly within 
<taxonomicName id="57942ED9FFCAFFBCAC01FDC1FC30C556" authorityName="" baseAuthorityName="Burmeister" baseAuthorityYear="1878" box="[824,917,567,593]" class="Insecta" family="Hesperiidae" genus="Cymaenes" kingdom="Animalia" order="Lepidoptera" pageId="74" pageNumber="73" phylum="Arthropoda" rank="species" species="odilia">
<emphasis id="A2E08948FFCAFFBCAC01FDC1FC30C556" box="[824,917,567,593]" italics="true" pageId="74" pageNumber="73">C. odilia</emphasis>
</taxonomicName>
).
</paragraph>
