</subSubSection>
<subSubSection box="[199,1033,1195,1221]" pageId="6" pageNumber="363" type="etymology">
<paragraph blockId="6.[151,1437,150,1221]" box="[199,1033,1195,1221]" pageId="6" pageNumber="363">
<emphasis bold="true" box="[199,334,1195,1221]" pageId="6" pageNumber="363">Etymology.</emphasis>
The specific name is derived from 
<emphasis box="[731,817,1195,1221]" italics="true" pageId="6" pageNumber="363">pulcher</emphasis>
(= beautiful, nice).
</paragraph>
</subSubSection>
