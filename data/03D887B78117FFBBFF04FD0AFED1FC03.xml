<subSubSection id="C36B652A8117FFBBFF31FCFAFED1FC03" pageId="56" pageNumber="57" type="distribution">
<paragraph id="8BCE36A18117FFBBFF31FCFAFAA2FCB6" blockId="56.[136,1452,770,977]" box="[189,1297,842,869]" pageId="56" pageNumber="57">
<emphasis id="B905EAB38117FFBBFF31FCFAFEC6FCB6" bold="true" box="[189,373,842,868]" pageId="56" pageNumber="57">Distribution:—</emphasis>
Northeastern 
<collectingCountry id="F36676318117FFBBFD81FCFAFDFAFCB6" box="[525,585,842,868]" name="India" pageId="56" pageNumber="57">India</collectingCountry>
, western 
<collectingCountry id="F36676318117FFBBFD3EFCFBFC92FCB7" box="[690,801,843,869]" name="Myanmar" pageId="56" pageNumber="57">Myanmar</collectingCountry>
, northern 
<collectingCountry id="F36676318117FFBBFC1DFCFAFC46FCB6" box="[913,1013,842,868]" name="Thailand" pageId="56" pageNumber="57">Thailand</collectingCountry>
and southwestern 
<collectingCountry id="F36676318117FFBBFB4AFCFAFABEFCB6" box="[1222,1293,842,868]" name="China" pageId="56" pageNumber="57">China</collectingCountry>
.
</paragraph>
<paragraph id="8BCE36A18117FFBBFF31FCDEFED1FC03" blockId="56.[136,1452,770,977]" pageId="56" pageNumber="57">
<emphasis id="B905EAB38117FFBBFF31FCDEFEA8FC5A" bold="true" box="[189,283,878,904]" pageId="56" pageNumber="57">Note:—</emphasis>
<bibRefCitation id="EFE04B508117FFBBFE97FCDEFDD4FC5B" author="Seidenfaden, G." box="[283,615,878,905]" pageId="56" pageNumber="57" pagination="1 - 50" refId="ref227910" refString="Seidenfaden, G. (1975 a) Orchid genera in Thailand I. Calanthe R. Br. Dansk Botanisk Arkiv 29 (2): 1 - 50." type="journal article" year="1975">Seidenfaden (1975a: 42−45)</bibRefCitation>
pointed out similarities between this species and 
<taxonomicName id="4C714D228117FFBBFB49FCDFFA1FFC5A" authority="W. W. Sm." authorityName="W. W. Sm." box="[1221,1452,878,905]" class="Liliopsida" family="Orchidaceae" genus="Calanthe" kingdom="Plantae" order="Asparagales" pageId="56" pageNumber="57" phylum="Tracheophyta" rank="species" species="wardii">
<emphasis id="B905EAB38117FFBBFB49FCDFFA87FC5A" box="[1221,1332,878,905]" italics="true" pageId="56" pageNumber="57">C. wardii</emphasis>
W.W.Sm.
</taxonomicName>
(currently accepted name, 
<taxonomicName id="4C714D228117FFBBFE34FC23FD5EFC7F" authority="King &amp; Pantl." authorityName="King &amp; Pantl." box="[440,749,914,941]" class="Liliopsida" family="Orchidaceae" genus="Calanthe" kingdom="Plantae" order="Asparagales" pageId="56" pageNumber="57" phylum="Tracheophyta" rank="species" species="whiteana">
<emphasis id="B905EAB38117FFBBFE34FC23FDF1FC7E" box="[440,578,914,941]" italics="true" pageId="56" pageNumber="57">C. whiteana</emphasis>
King &amp; Pantl.
</taxonomicName>
) but decided to keep the two separate. See also 
<bibRefCitation id="EFE04B508117FFBBFAA8FC22FEEDFC03" author="Kurzweil, H. &amp; Ormerod, P." pageId="56" pageNumber="57" pagination="1 - 15" refId="ref224386" refString="Kurzweil, H. &amp; Ormerod, P. (2018) Precursory studies on the orchid flora of Myanmar with one new species and thirty-eight new distribution records. Rheedea 28: 1 - 15. https: // doi. org / 10.22244 / rheedea. 2018.28.1.01" type="journal article" year="2018">Kurzweil &amp; Ormerod (2018: 5)</bibRefCitation>
.
</paragraph>
