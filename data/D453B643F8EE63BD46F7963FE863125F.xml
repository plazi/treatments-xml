<paragraph id="B5AB4BFFF1261DEF35200942C84C2232" pageId="null" pageNumber="592">
<taxonomicName id="5511E28B355E0A4484B92427D03F99BB" authority="Thuill." class="Magnoliopsida" family="Fabaceae" genus="Vicia" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="592" phylum="Tracheophyta" rank="species" species="segetalis">
Vicia 
<normalizedToken id="6BAAC3CA7D43B71B24966445E6228CF2" originalValue="segetális" pageId="null" pageNumber="592">segetalis</normalizedToken>
Thuill.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="335A068903EDCF51D500BDCFAD7CFC03" pageId="null" pageNumber="592" type="vernacular_names">
<paragraph id="CA999ED32C1082645B04DC20A9EB4AEB" pageId="null" pageNumber="592">Saat-Wicke</paragraph>
</subSubSection>
</title>
<subSubSection id="1740AD8A92355A197F9EBD8BEF958F9C" pageId="null" pageNumber="592" type="description">
<paragraph id="41D7866D94A7544D9F86512788B47982" pageId="null" pageNumber="592">
Unterscheidet sich von 
<taxonomicName id="0D4A933E50156D7623F9C55C44C413FF" class="Magnoliopsida" family="Fabaceae" genus="Vicia" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="592" phylum="Tracheophyta" rank="species" species="angustifolia">
<emphasis id="2230ACD2352C247104748C25DF3785B3" italics="true" pageId="null" pageNumber="592">V. angustifolia</emphasis>
</taxonomicName>
(Nr. 13e) durch folgende Merkmale: 
<normalizedToken id="600DFD3CE88B24A2E04FF85D8CC4969C" originalValue="Teilblätter" pageId="null" pageNumber="592">Teilblaetter</normalizedToken>
der obern 
<normalizedToken id="6A3C007713E12F8E5688BD8807B23764" originalValue="Blätter" pageId="null" pageNumber="592">Blaetter</normalizedToken>
3-6mal so lang wie breit; 
<emphasis id="F166C3212C299363015689E424AE7C71" italics="true" pageId="null" pageNumber="592">Kelch 10-12 mm lang, etwa</emphasis>
<normalizedToken id="ADB5113DF638F81DE23668BDD3117F81" originalValue="¾" pageId="null" pageNumber="592">3/4</normalizedToken>
<emphasis id="992BE112C01E11421A93994B2CAC62EB" italics="true" pageId="null" pageNumber="592">so lang wie die Fahne</emphasis>
, fast kahl; Fahne 
<normalizedToken id="BCC4E888DB0ECE5F84400C9FE26D41DA" originalValue="schräg" pageId="null" pageNumber="592">schraeg</normalizedToken>
nach oben gebogen, 
<emphasis id="CE51F5ACDED1F8BE1C5FCB56E4863103" italics="true" pageId="null" pageNumber="592">
<normalizedToken id="F0385539A4EEC8FE3A721A1C9DE093C5" originalValue="außen" pageId="null" pageNumber="592">aussen</normalizedToken>
<normalizedToken id="1F7D4C4AB712E38C3CA552447BFEF1A3" originalValue="grünlich" pageId="null" pageNumber="592">gruenlich</normalizedToken>
<normalizedToken id="3FBE6C9121685725A99D09EEC5A92887" originalValue="überlaufen" pageId="null" pageNumber="592">ueberlaufen</normalizedToken>
;
</emphasis>
Samen 2,5-3,5 mm lang. - 
<normalizedToken id="401654BC36DBACD4C7515581F3FC5050" originalValue="Blüte" pageId="null" pageNumber="592">Bluete</normalizedToken>
: 
<normalizedToken id="870140EDDA83D5264DBEA281DAABE47D" originalValue="Später" pageId="null" pageNumber="592">Spaeter</normalizedToken>
<normalizedToken id="AEBEA9584EABC2762B76E9F8ED9CD115" originalValue="Frühling" pageId="null" pageNumber="592">Fruehling</normalizedToken>
und 
<normalizedToken id="9EC50F765F3BCC9B495FBEFDDB37D009" originalValue="früher" pageId="null" pageNumber="592">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="3A4C0473FA6F8E4FDA240C1583FC1CB5" pageId="null" pageNumber="592">
<emphasis id="2EF765A5F01BC915092828721135E347" italics="true" pageId="null" pageNumber="592">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="EA2DC6429D030088CBF94C5A8DF2FA1F" italics="true" pageId="null" pageNumber="592">12:</emphasis>
Ohne Herkunftsangabe (Sveshnikova aus Mettin und Hanelt 1964, Mettin und Hanelt 1964), aus Ungarn (Baksay 1954), aus Island (
<normalizedToken id="5EA9FFB3BCE4EA4430A45225EE936383" originalValue="Löve" pageId="null" pageNumber="592">Loeve</normalizedToken>
und 
<normalizedToken id="0F43EC187B4883E3C25A1FA8E487CE26" originalValue="Löve" pageId="null" pageNumber="592">Loeve</normalizedToken>
1956b), aus Japan (Huziwara und Kondo 1963).
</paragraph>
<paragraph id="C70D60F120499CAE85400A063516CB72" pageId="null" pageNumber="592">
<emphasis id="82359A0963C7E510996F04228B50BA7F" italics="true" pageId="null" pageNumber="592">Standort.</emphasis>
Kollin und montan. Lockere, trockene, eher 
<normalizedToken id="4E5966F986C621DFCC726E48E6787733" originalValue="nährstoffreiche" pageId="null" pageNumber="592">naehrstoffreiche</normalizedToken>
<normalizedToken id="542E97F9CFF3F6043FC4EBB7D791B4FE" originalValue="Böden" pageId="null" pageNumber="592">Boeden</normalizedToken>
in 
<normalizedToken id="CFAA58CEED83D127D222B91FB9D68D11" originalValue="wärmeren" pageId="null" pageNumber="592">waermeren</normalizedToken>
Lagen. Getreidefelder, 
<normalizedToken id="771963040BF1F65528AE9D51F3423020" originalValue="Wegränder" pageId="null" pageNumber="592">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="B4CF32D5264B39D50C3DB39C137EDC06" pageId="null" pageNumber="592">
<emphasis id="224BB451320509974E51FDA558D72DD0" italics="true" pageId="null" pageNumber="592">Verbreitung. Mediterrane Pflanze:</emphasis>
Nicht genau bekannt. In Europa 
<normalizedToken id="E71430BF4D9F8FFA9081E0B3BC05A90C" originalValue="nordwärts" pageId="null" pageNumber="592">nordwaerts</normalizedToken>
vereinzelt und zum Teil nur verschleppt bis 
<normalizedToken id="F89F9E46068144C6186D70AF24EDD572" originalValue="Großbritannien" pageId="null" pageNumber="592">Grossbritannien</normalizedToken>
und 
<normalizedToken id="BBF8D64C1FD60CAE5178B165D3B5A426" originalValue="Südskandinavien" pageId="null" pageNumber="592">Suedskandinavien</normalizedToken>
; in Island und Nordamerika eingeschleppt. - Im Gebiet ziemlich verbreitet, nicht 
<normalizedToken id="350EA12401581BA5BCD3C4C25ABBE639" originalValue="häufig" pageId="null" pageNumber="592">haeufig</normalizedToken>
(auch 
<normalizedToken id="C2DAF7F71A4F2AD9D7AE5309BF557E33" originalValue="angesät" pageId="null" pageNumber="592">angesaet</normalizedToken>
).
</paragraph>
</subSubSection>
