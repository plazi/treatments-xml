<taxonomicName id="4C0B4D4CFFA8FF82FCBC85A2FBA4F2EE" authority="Crispino &amp; Ghirotto &amp; Engelking, 2022" authorityName="Crispino &amp; Ghirotto &amp; Engelking" authorityYear="2022" box="[800,1124,1709,1733]" class="Insecta" family="Heteronemiidae" genus="Ceroys" kingdom="Animalia" order="Phasmida" pageId="13" pageNumber="47" phylum="Arthropoda" rank="species" species="cancelloae" status="sp. nov." subGenus="Miroceroys">
<emphasis id="B97FEADDFFA8FF82FCBC85A2FBA4F2EE" box="[800,1124,1709,1733]" italics="true" pageId="13" pageNumber="47">Ceroys (Miroceroys) cancelloae</emphasis>
</taxonomicName>
