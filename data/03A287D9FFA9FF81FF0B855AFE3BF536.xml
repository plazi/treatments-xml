<subSubSection id="C3116544FFA8FF81FF5B841BFE3BF536" lastPageId="14" lastPageNumber="48" pageId="13" pageNumber="47" type="diagnosis">
<paragraph id="8BB436CFFFA8FF81FF5B841BFE3BF536" blockId="13.[151,1437,1815,2022]" lastBlockId="14.[151,1437,151,285]" lastPageId="14" lastPageNumber="48" pageId="13" pageNumber="47">
<emphasis id="B97FEADDFFA8FF82FF5B841BFE82F31A" bold="true" box="[199,322,1815,1841]" pageId="13" pageNumber="47">Diagnosis.</emphasis>
<taxonomicName id="4C0B4D4CFFA8FF82FED18414FD69F31A" authority="Crispino &amp; Ghirotto &amp; Engelking, 2022" authorityName="Crispino &amp; Ghirotto &amp; Engelking" authorityYear="2022" box="[333,681,1815,1842]" class="Insecta" family="Heteronemiidae" genus="Ceroys" kingdom="Animalia" order="Phasmida" pageId="13" pageNumber="47" phylum="Arthropoda" rank="species" species="indicattii" status="sp. nov." subGenus="Miroceroys">
<emphasis id="B97FEADDFFA8FF82FED18414FD69F31A" box="[333,681,1815,1842]" italics="true" pageId="13" pageNumber="47">Ceroys (Miroceroys) indicattii</emphasis>
</taxonomicName>
<emphasis id="B97FEADDFFA8FF82FD288414FCD2F319" bold="true" box="[692,786,1816,1842]" pageId="13" pageNumber="47">
<taxonomicNameLabel id="A24C57A6FFA8FF82FD288414FCD2F319" box="[692,786,1816,1842]" pageId="13" pageNumber="47" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
resembles 
<taxonomicName id="4C0B4D4CFFA8FF82FC058414FAD4F31A" baseAuthorityName="Westwood" baseAuthorityYear="1859" box="[921,1300,1816,1842]" class="Insecta" family="Heteronemiidae" genus="Ceroys" kingdom="Animalia" order="Phasmida" pageId="13" pageNumber="47" phylum="Arthropoda" rank="species" species="saevissimus" subGenus="Miroceroys">
<emphasis id="B97FEADDFFA8FF82FC058414FAD4F31A" box="[921,1300,1816,1842]" italics="true" pageId="13" pageNumber="47">Ceroys (Miroceroys) saevissimus</emphasis>
</taxonomicName>
and differs from all remaining species of the genus by the conspicuous dorsolateral medial widening of the mesonotum (
<figureCitation id="13302A4AFFA8FF82FAF38437FF09F351" captionStart="FIGURE 10" captionStartId="15.[151,250,1898,1922]" captionTargetBox="[161,1436,610,1863]" captionTargetId="figure-211@15.[151,1436,597,1874]" captionTargetPageId="15" captionText="FIGURE 10. A–B. Recently deceased female holotype V0641 of Ceroys (Miroceroys) indicattii sp. nov., from Petrópolis, Rio de Janeiro, Brazil. A. Habitus in dorsal view. B. Body in dorsal, lateral and ventral view. Scale bar: 5 mm." figureDoi="http://doi.org/10.5281/zenodo.6531244" httpUri="https://zenodo.org/record/6531244/files/figure.png" pageId="13" pageNumber="47">Fig. 10B</figureCitation>
, 
<figureCitation id="13302A4AFFA8FF82FF49846CFEC4F351" box="[213,260,1888,1914]" captionStart="FIGURE 13" captionStartId="19.[151,250,1406,1430]" captionTargetBox="[163,1416,198,1382]" captionTargetId="figure-27@19.[151,1436,181,1382]" captionTargetPageId="19" captionText="FIGURE 13. A–B. Male paratype MZUSP 0529 of Ceroys (Miroceroys) indicattii sp. nov., from Teresópolis, Rio de Janeiro, Brazil. A. Habitus in dorsal view. B. Body in dorsal, lateral and ventral view. Scale bar: 5 mm." figureDoi="http://doi.org/10.5281/zenodo.6531250" httpUri="https://zenodo.org/record/6531250/files/figure.png" pageId="13" pageNumber="47">13B</figureCitation>
) and overall pattern of ornamentation, such as lateral and dorsal expansions in abdominal segments and several strong spines in the thorax (
<figureCitation id="13302A4AFFA8FF82FDB5848FFD4FF3B5" box="[553,655,1923,1950]" captionStart="FIGURE 10" captionStartId="15.[151,250,1898,1922]" captionTargetBox="[161,1436,610,1863]" captionTargetId="figure-211@15.[151,1436,597,1874]" captionTargetPageId="15" captionText="FIGURE 10. A–B. Recently deceased female holotype V0641 of Ceroys (Miroceroys) indicattii sp. nov., from Petrópolis, Rio de Janeiro, Brazil. A. Habitus in dorsal view. B. Body in dorsal, lateral and ventral view. Scale bar: 5 mm." figureDoi="http://doi.org/10.5281/zenodo.6531244" httpUri="https://zenodo.org/record/6531244/files/figure.png" pageId="13" pageNumber="47">Fig. 10B</figureCitation>
), less prominent in males (
<figureCitation id="13302A4AFFA8FF82FC5C848FFBD4F3B5" box="[960,1044,1923,1950]" captionStart="FIGURE 13" captionStartId="19.[151,250,1406,1430]" captionTargetBox="[163,1416,198,1382]" captionTargetId="figure-27@19.[151,1436,181,1382]" captionTargetPageId="19" captionText="FIGURE 13. A–B. Male paratype MZUSP 0529 of Ceroys (Miroceroys) indicattii sp. nov., from Teresópolis, Rio de Janeiro, Brazil. A. Habitus in dorsal view. B. Body in dorsal, lateral and ventral view. Scale bar: 5 mm." figureDoi="http://doi.org/10.5281/zenodo.6531250" httpUri="https://zenodo.org/record/6531250/files/figure.png" pageId="13" pageNumber="47">Fig. 13</figureCitation>
). It differs from females of 
<taxonomicName id="4C0B4D4CFFA8FF82FAD28488FE74F3EA" baseAuthorityName="Westwood" baseAuthorityYear="1859" class="Insecta" family="Heteronemiidae" genus="Ceroys" kingdom="Animalia" order="Phasmida" pageId="13" pageNumber="47" phylum="Arthropoda" rank="species" species="saevissimus" subGenus="Miroceroys">
<emphasis id="B97FEADDFFA8FF82FAD28488FE74F3EA" italics="true" pageId="13" pageNumber="47">Ceroys (Miroceroys) saevissimus</emphasis>
</taxonomicName>
by the shorter and less deflexed posterior margin of tergite X (anal segment) and shorter sternite VIII (subgenital plate), with both not forming a duck-bill shape (
<figureCitation id="13302A4AFFA8FF82FC5084C7FBF1F3CD" box="[972,1073,1995,2022]" captionStart="FIGURE 12" captionStartId="18.[151,250,1786,1810]" captionTargetBox="[151,1436,381,1756]" captionTargetId="figure-100@18.[151,1436,381,1763]" captionTargetPageId="18" captionText="FIGURE 12. A–F. Abdomen morphology of female Ceroys (Miroceroys) indicattii sp. nov., holotype V0641, end of the abdomen: A. Dorsal view; B. Lateral view; C. Ventral view; D. Terminalia, lateral view; E. Dorsal view, detail of apex; F. Ventral view, detail of praeopercular organ. Abbreviations. Ce, cercus; Ep, epiproct; Gap8-Gap9, gonapophysis 8 and 9; Gng, gonangulum; Gpl, gonoplac; Pre, praeopercular organ; Sp, subgenital plate; St, sternite; Tg, tergite. Scale bars: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6531248" httpUri="https://zenodo.org/record/6531248/files/figure.png" pageId="13" pageNumber="47">Fig. 12B</figureCitation>
) as in 
<taxonomicName id="4C0B4D4CFFA8FF82FBE184C0FAE3F3CE" baseAuthorityName="Westwood" baseAuthorityYear="1859" box="[1149,1315,1996,2022]" class="Insecta" family="Heteronemiidae" genus="Ceroys" kingdom="Animalia" order="Phasmida" pageId="13" pageNumber="47" phylum="Arthropoda" rank="species" species="saevissimus">
<emphasis id="B97FEADDFFA8FF82FBE184C0FAE3F3CE" box="[1149,1315,1996,2022]" italics="true" pageId="13" pageNumber="47">C. saevissimus</emphasis>
</taxonomicName>
, the larger dorsal expansions on tergites IV, V and IX (
<figureCitation id="13302A4AFFABFF81FD10839BFD37F49A" box="[652,759,151,177]" captionStart="FIGURE 10" captionStartId="15.[151,250,1898,1922]" captionTargetBox="[161,1436,610,1863]" captionTargetId="figure-211@15.[151,1436,597,1874]" captionTargetPageId="15" captionText="FIGURE 10. A–B. Recently deceased female holotype V0641 of Ceroys (Miroceroys) indicattii sp. nov., from Petrópolis, Rio de Janeiro, Brazil. A. Habitus in dorsal view. B. Body in dorsal, lateral and ventral view. Scale bar: 5 mm." figureDoi="http://doi.org/10.5281/zenodo.6531244" httpUri="https://zenodo.org/record/6531244/files/figure.png" pageId="14" pageNumber="48">Figs 10B</figureCitation>
, 
<figureCitation id="13302A4AFFABFF81FC98839BFCF4F49A" box="[772,820,151,177]" captionStart="FIGURE 12" captionStartId="18.[151,250,1786,1810]" captionTargetBox="[151,1436,381,1756]" captionTargetId="figure-100@18.[151,1436,381,1763]" captionTargetPageId="18" captionText="FIGURE 12. A–F. Abdomen morphology of female Ceroys (Miroceroys) indicattii sp. nov., holotype V0641, end of the abdomen: A. Dorsal view; B. Lateral view; C. Ventral view; D. Terminalia, lateral view; E. Dorsal view, detail of apex; F. Ventral view, detail of praeopercular organ. Abbreviations. Ce, cercus; Ep, epiproct; Gap8-Gap9, gonapophysis 8 and 9; Gng, gonangulum; Gpl, gonoplac; Pre, praeopercular organ; Sp, subgenital plate; St, sternite; Tg, tergite. Scale bars: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6531248" httpUri="https://zenodo.org/record/6531248/files/figure.png" pageId="14" pageNumber="48">12B</figureCitation>
) and by the tergite VIII slightly wider than IX and X, not constricted (
<figureCitation id="13302A4AFFABFF81FECD83B7FE7CF4FE" box="[337,444,187,213]" captionStart="FIGURE 10" captionStartId="15.[151,250,1898,1922]" captionTargetBox="[161,1436,610,1863]" captionTargetId="figure-211@15.[151,1436,597,1874]" captionTargetPageId="15" captionText="FIGURE 10. A–B. Recently deceased female holotype V0641 of Ceroys (Miroceroys) indicattii sp. nov., from Petrópolis, Rio de Janeiro, Brazil. A. Habitus in dorsal view. B. Body in dorsal, lateral and ventral view. Scale bar: 5 mm." figureDoi="http://doi.org/10.5281/zenodo.6531244" httpUri="https://zenodo.org/record/6531244/files/figure.png" pageId="14" pageNumber="48">Fig. 10A</figureCitation>
). Males are recognized by the straight mesonotum in lateral view, smaller, less jagged triangular thoracic projections and less spiny body with abdomen segments without lateral spines in both anterior and posterior margins (
<figureCitation id="13302A4AFFABFF81FE06820FFE2EF536" box="[410,494,259,285]" captionStart="FIGURE 13" captionStartId="19.[151,250,1406,1430]" captionTargetBox="[163,1416,198,1382]" captionTargetId="figure-27@19.[151,1436,181,1382]" captionTargetPageId="19" captionText="FIGURE 13. A–B. Male paratype MZUSP 0529 of Ceroys (Miroceroys) indicattii sp. nov., from Teresópolis, Rio de Janeiro, Brazil. A. Habitus in dorsal view. B. Body in dorsal, lateral and ventral view. Scale bar: 5 mm." figureDoi="http://doi.org/10.5281/zenodo.6531250" httpUri="https://zenodo.org/record/6531250/files/figure.png" pageId="14" pageNumber="48">Fig. 13</figureCitation>
).
</paragraph>
