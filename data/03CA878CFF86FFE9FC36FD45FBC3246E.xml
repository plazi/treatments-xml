<taxonomicName id="4C634D19FF86FFE9FC40FBD8FBAD25F5" authorityName="Simon" authorityYear="1879" box="[958,1034,1135,1156]" class="Arachnida" family="Cosmetidae" genus="Protus" kingdom="Animalia" order="Opiliones" pageId="51" pageNumber="636" phylum="Arthropoda" rank="genus">
