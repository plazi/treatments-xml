<figureCitation id="13582A1FFF86FFE9FBA8FB3AFB7125D3" box="[1110,1238,1165,1187]" captionStart="Figure 39" captionStartId="52.[145,225,1023,1045]" captionTargetBox="[305,1265,195,983]" captionTargetId="figure-47@52.[305,1265,195,983]" captionTargetPageId="52" captionText="Figure 39. Protus quadripunctatus, male syntype (SMF RII 1489/7a). A, dorsal view. B, ventral view. C, lateral view. D, detail of coxa IV in dorsal view. E, original label. Scale bars: 1 mm. Photos courtesy Abel Pérez." pageId="51" pageNumber="636">Fig. 39B–D</figureCitation>
