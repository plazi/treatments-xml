<figureCitation id="78F42A63A702D66E7A196DDFDC41413E" box="[809,881,754,780]" captionStart="Fig 9" captionStartId="16.[189,230,1913,1939]" captionTargetBox="[216,1331,819,1856]" captionTargetId="figure-188@16.[204,1383,799,1873]" captionTargetPageId="16" captionText="Fig 9. Carrhotus lobatus sp. nov., palp. A. Ventral view. B. Retrolateral view. Abbreviations: E = embolus; PLP = posterior lateral protrusion; RTA = retrolateral tibial apophysis; TE = tegulum. Scale bars = 0.2 mm." figureDoi="http://doi.org/10.5281/zenodo.6518329" httpUri="https://zenodo.org/record/6518329/files/figure.png" pageId="14" pageNumber="92">9A–B</figureCitation>
