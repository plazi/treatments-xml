<figureCitation id="78F42A63A702D66E7BA96DDFDC2D413E" box="[665,797,754,780]" captionStart="Fig 8" captionStartId="15.[189,230,1913,1939]" captionTargetBox="[287,1301,265,1861]" captionTargetId="figure-14@15.[287,1301,265,1861]" captionTargetPageId="15" captionText="Fig 8. Carrhotus lobatus sp. nov. A–B. Male habitus. A. Dorsal view. B. Ventral view. C–D. Palp, C. Ventral view. D. Retrolateral view. Abbreviations: E = embolus; PLP = posterior lateral protrusion; RTA = retrolateral tibial apophysis; TE = tegulum. Scale bars: A–B = 2 mm; C–D = 0.2 mm." figureDoi="http://doi.org/10.5281/zenodo.6518325" httpUri="https://zenodo.org/record/6518325/files/figure.png" pageId="14" pageNumber="92">Figs 8A–D</figureCitation>
