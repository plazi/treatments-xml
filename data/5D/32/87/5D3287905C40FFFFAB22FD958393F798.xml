<paragraph blockId="2.[1346,2554,1150,2167]" pageId="2" pageNumber="165">
<emphasis bold="true" box="[1347,2057,1740,1773]" pageId="2" pageNumber="165">Movements, Home range and Social organization.</emphasis>
