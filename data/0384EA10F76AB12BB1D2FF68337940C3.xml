<typeStatus id="5496E5A4F76AB12BB06FFCD833624075" box="[298,347,807,823]" pageId="31" pageNumber="552">TYPE</typeStatus>
LOCALITY: 
<location id="8EF20DDDF76AB12BB091FCE03016407B" LSID="urn:lsid:plazi:treatment:0384EA10F76AB12BB1D2FF68337940C3:8EF20DDDF76AB12BB091FCE03016407B" box="[468,559,799,825]" name="Durban" pageId="31" pageNumber="552" stateProvince="KwaZulu-Natal">Durban</location>
, 
<collectingRegion id="49E995E4F76AB12BB37EFCE030CE407B" box="[571,759,799,825]" country="South Africa" name="KwaZulu-Natal" pageId="31" pageNumber="552">KwaZulu-Natal</collectingRegion>
