<taxonomicName id="33A4D0F8FFC8FFF4E4D4AA75FBB6FAB3" authority="Mamaev, 1964" authorityName="Mamaev" authorityYear="1964" box="[735,1072,1281,1308]" class="Insecta" family="Cecidomyiidae" genus="Cryptoneurus" kingdom="Animalia" order="Diptera" pageId="1" pageNumber="24" phylum="Arthropoda" rank="genus">
<emphasis id="C6D07769FFC8FFF4E4D4AA75FCF8FAB4" box="[735,894,1281,1307]" italics="true" pageId="1" pageNumber="24">Cryptoneurus</emphasis>
