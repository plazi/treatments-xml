</taxonomicName>
(3); 
<emphasis id="C6D07769FFC8FFF4E26DAA75FB56FAB4" box="[1126,1232,1281,1307]" italics="true" pageId="1" pageNumber="24">Dalaiella</emphasis>
Mamaev, 1996 (1); 
<taxonomicName id="33A4D0F8FFC8FFF4E790AA55FD41FA93" authority="Kieffer, 1894" authorityName="Kieffer" authorityYear="1894" box="[411,711,1313,1340]" class="Insecta" family="Cecidomyiidae" genus="Holoneurus" kingdom="Animalia" order="Diptera" pageId="1" pageNumber="24" phylum="Arthropoda" rank="genus">
<emphasis id="C6D07769FFC8FFF4E790AA55FDA5FA94" box="[411,547,1313,1339]" italics="true" pageId="1" pageNumber="24">Holoneurus</emphasis>
