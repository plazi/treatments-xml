<subSubSection pageId="0" pageNumber="87597" type="etymology">
<paragraph pageId="0" pageNumber="87597">Etymology</paragraph>
<paragraph pageId="0" pageNumber="87597">The specific name refers to the type locality (Banna is a short name for Xishuangbanna) and is a noun in apposition.</paragraph>
</subSubSection>
