<taxonomicName id="84015EEFC909CA06E9130681BB90E8B4" authority="Hübner, 1825" authorityName="Chrétien" authorityYear="1915" class="Insecta" family="Galacticidae" genus="Psecadia" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Psecadia variinotella" order="Lepidoptera" pageId="0" pageNumber="169" phylum="Arthropoda" rank="species" species="variinotella">Psecadia variinotella</taxonomicName>
