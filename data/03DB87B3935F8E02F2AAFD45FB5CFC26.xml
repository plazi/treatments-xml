<materialsCitation id="3B1A3CF8935F8E02F2AAFC8DFC72FC96" ID-GBIF-Occurrence="3798147344" collectorName="J. Serrano" pageId="6" pageNumber="490" specimenCount="2" typeStatus="lectotype">
