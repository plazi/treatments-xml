<typeStatus id="54C98807935F8E02F76DFC8DFF16FC95" pageId="6" pageNumber="490">Lectotype</typeStatus>
of 
<taxonomicName id="4C724D26935F8E02F2D0FCD1FD61FC96" authority="Dejean, 1829" authorityName="Dejean" authorityYear="1829" box="[237,688,835,861]" class="Insecta" family="Carabidae" genus="Harpalus" kingdom="Animalia" order="Coleoptera" pageId="6" pageNumber="490" phylum="Arthropoda" rank="species" species="punctatostriatus">
