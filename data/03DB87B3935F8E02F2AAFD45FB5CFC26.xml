<typeStatus id="54C98807935F8E02F02FFC8DFDA8FCF2" box="[530,633,799,825]" pageId="6" pageNumber="490">lectotype</typeStatus>
is a male bearing labels “ 
<taxonomicName id="4C724D26935F8E02F1A0FCB2FB82FCF2" authorityName="Dejean" authorityYear="1829" box="[925,1107,800,825]" class="Insecta" family="Carabidae" genus="Harpalus" kingdom="Animalia" order="Coleoptera" pageId="6" pageNumber="490" phylum="Arthropoda" rank="species" species="punctatostriatus">
