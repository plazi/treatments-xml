<paragraph id="8BF5D959FFA53C5FFF6BB850FDC1820B" blockId="3.[151,599,1540,1565]" box="[151,599,1540,1565]" pageId="3" pageNumber="241">
<treatmentCitationGroup id="AB5AFE77FFA53C5FFF6BB850FDC1820B" box="[151,599,1540,1565]" pageId="3" pageNumber="241">
<treatmentCitation id="0AEBFF48FFA53C5FFF6BB850FDC5820B" author="Bianchi, F." box="[151,595,1540,1565]" page="385" pageId="3" pageNumber="241" year="1952">
