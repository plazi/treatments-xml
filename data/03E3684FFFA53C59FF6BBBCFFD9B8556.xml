<emphasis id="B93E054BFFA53C5FFF6BB850FE1E820A" box="[151,392,1540,1565]" italics="true" pageId="3" pageNumber="241">Arrhenothrips pacificus</emphasis>
<bibRefCitation id="EFDBA4A8FFA53C5FFE72B850FDC5820B" author="Bianchi" box="[398,595,1540,1564]" firstAuthor="Bianchi" page="385" pageId="3" pageNumber="241" pagination="385 - 390" refId="ref3104" refString="Bianchi, F. (1952) Additions to the Thysanoptera of New Caledonia. Proceedings of the Hawaiian entomological Society, 14, 385 - 390." type="journal article" year="1952">Bianchi, 1952: 385</bibRefCitation>
