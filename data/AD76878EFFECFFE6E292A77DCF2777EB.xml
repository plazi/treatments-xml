<emphasis id="17ABEA8AFFEDFFE1E292A7E9CF4D71CD" bold="true" box="[151,269,1423,1447]" pageId="3" pageNumber="304">FIGURE 1</emphasis>
. 
<taxonomicName id="E2DF4D1BFFEDFFE1E31CA7F6CCF671CD" authority="Adams, 1967" authorityName="Adams" authorityYear="1967" box="[281,694,1423,1448]" class="Insecta" family="Chrysopidae" genus="Archaeochrysa" kingdom="Animalia" order="Neuroptera" pageId="3" pageNumber="304" phylum="Arthropoda" rank="species" species="paranervis">
<emphasis id="17ABEA8AFFEDFFE1E31CA7F6CC6671CD" box="[281,550,1424,1448]" italics="true" pageId="3" pageNumber="304">Archaeochrysa paranervis</emphasis>
