<collectingCountry box="[1109,1191,1288,1314]" name="Taiwan" pageId="6" pageNumber="293">Taiwan</collectingCountry>
(
<bibRefCitation author="Ju, Y. M. &amp; Hsieh, H. M. &amp; Ho, M. C. &amp; Szu, D. H. &amp; Fang, M. J." box="[1206,1365,1288,1314]" pageId="6" pageNumber="293" pagination="621" refId="ref7455" refString="Ju, Y. M., Hsieh, H. M., Ho, M. C., Szu, D. H. &amp; Fang, M. J. (2007) Theissenia rogersii sp. nov. and phylogenetic position of Theissenia. Mycologia 99: 612 e 621. https: // doi. org / 10.1080 / 15572536.2007.11832555" type="journal article" year="2007">
Ju 
