<taxonomicName authority="(Petrini 2013)" baseAuthorityName="Petrini" baseAuthorityYear="2013" box="[680,1027,1252,1278]" class="Sordariomycetes" family="Xylariaceae" genus="Rosellinia" kingdom="Fungi" order="Xylariales" pageId="6" pageNumber="293" phylum="Ascomycota" rank="species" species="lamprostoma">
<emphasis box="[680,859,1252,1278]" italics="true" pageId="6" pageNumber="293">R. lamprostoma</emphasis>
