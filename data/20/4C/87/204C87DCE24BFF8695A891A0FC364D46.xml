<collectionCode box="[1300,1363,1252,1278]" pageId="6" pageNumber="293">GMB</collectionCode>
0086 as 
<taxonomicName baseAuthorityName="Petrini" baseAuthorityYear="2013" box="[136,315,1288,1314]" class="Sordariomycetes" family="Xylariaceae" genus="Rosellinia" kingdom="Fungi" order="Xylariales" pageId="6" pageNumber="293" phylum="Ascomycota" rank="species" species="lamprostoma">
<emphasis box="[136,315,1288,1314]" italics="true" pageId="6" pageNumber="293">R. lamprostoma</emphasis>
