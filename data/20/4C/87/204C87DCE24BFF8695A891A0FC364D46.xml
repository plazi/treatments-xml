<taxonomicName baseAuthorityName="Petrini" baseAuthorityYear="2013" box="[495,673,1324,1350]" class="Sordariomycetes" family="Xylariaceae" genus="Rosellinia" kingdom="Fungi" order="Xylariales" pageId="6" pageNumber="293" phylum="Ascomycota" rank="species" species="lamprostoma">
<emphasis box="[495,673,1324,1350]" italics="true" pageId="6" pageNumber="293">R. lamprostoma</emphasis>
