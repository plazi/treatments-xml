<bibRefCitation author="Petrini, L. E." pageId="6" pageNumber="293" refId="ref9079" refString="Petrini, L. E. (2013) Rosellinia: a world monograph. Bibliotheca Mycologica, J. Cramer: Stuttgart, 410 pp." type="book" year="2013">Petrini 2013</bibRefCitation>
