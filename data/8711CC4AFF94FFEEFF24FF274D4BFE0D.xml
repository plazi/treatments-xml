<taxonomicName id="C8B806DFFF94FFEEFEF5FEBD4E1CFEC6" baseAuthorityName="BERNHAUER" baseAuthorityYear="1928" box="[355,577,322,344]" class="Insecta" family="Staphylinidae" genus="Stiliderus" kingdom="Animalia" order="Coleoptera" pageId="14" pageNumber="1585" phylum="Arthropoda" rank="species" species="brevipennis">
