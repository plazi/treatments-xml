<quantity id="A30D9B28650E047D2BD46E31FDACDE5A" box="[453,522,595,616]" metricMagnitude="-3" metricUnit="m" metricValue="2.1" pageId="15" pageNumber="264" unit="mm" value="2.1">2.1mm</quantity>
