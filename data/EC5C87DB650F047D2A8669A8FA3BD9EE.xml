<quantity id="A30D9B28650E047D2BD46E57FDACDE78" box="[453,522,565,586]" metricMagnitude="-3" metricUnit="m" metricValue="2.1" pageId="15" pageNumber="264" unit="mm" value="2.1">2.1mm</quantity>
