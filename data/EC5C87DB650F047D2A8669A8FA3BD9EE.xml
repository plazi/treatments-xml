<taxonomicName id="A3F54D4E650E047D2F236DBCFA3BDDC0" authorityName="Richardson &amp; Zabka" authorityYear="2007" box="[1330,1437,477,499]" class="Arachnida" family="Salticidae" genus="Prostheclina" kingdom="Animalia" order="Araneae" pageId="15" pageNumber="264" phylum="Arthropoda" rank="species" species="eungella">
