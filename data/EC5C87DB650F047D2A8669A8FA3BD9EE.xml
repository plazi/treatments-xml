<taxonomicName id="A3F54D4E650E047D2F046D29FA3ADD52" box="[1301,1436,331,352]" class="Arachnida" family="Salticidae" genus="Prostheclina" kingdom="Animalia" order="Araneae" pageId="15" pageNumber="264" phylum="Arthropoda" rank="species" species="basilonessa">
