<paragraph id="8B8336A2FFBFFFAAFF5CF82ADB61F819" blockId="1.[151,800,1893,1948]" box="[151,800,1924,1948]" pageId="1" pageNumber="326">
<typeStatus id="54878800FFBFFFAAFF5CF82AD888F819" box="[151,201,1924,1948]" pageId="1" pageNumber="326">Type</typeStatus>
species: 
<taxonomicName id="4C3C4D21FFBFFFAAFEEDF82ADAF9F819" authority="Eggers, 1920: 36" authorityName="Eggers" authorityPageNumber="36" authorityYear="1920" box="[294,696,1924,1948]" class="Insecta" family="Curculionidae" genus="Pseudomicracis" kingdom="Animalia" order="Coleoptera" pageId="1" pageNumber="326" phylum="Arthropoda" rank="species" species="elsae">
<emphasis id="B948EAB0FFBFFFAAFEEDF82ADA43F819" box="[294,514,1924,1948]" italics="true" pageId="1" pageNumber="326">Pseudomicracis elsae</emphasis>
<bibRefCitation id="EFAD4B53FFBFFFAAFDC2F82ADAF9F819" author="Eggers, H." box="[521,696,1924,1948]" pageId="1" pageNumber="326" pagination="33 - 45" refId="ref9858" refString="Eggers, H. (1920) 60 Neue Borkenkafer (Ipidae) aus Afrika, nebst zehn neuen Gattungen, zwei Abarten. (Fortsetzung). Entomologische Blatter, 16, 33 - 45." type="journal article" year="1920">Eggers, 1920: 36</bibRefCitation>
</taxonomicName>
