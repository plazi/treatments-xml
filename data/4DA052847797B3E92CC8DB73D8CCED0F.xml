<subSubSection id="7727C9F3A8622AC7C1682E5DD1C0640A" pageId="null" pageNumber="361" type="description">
<paragraph id="EEDE99EDD75413310B7640FC459B6316" pageId="null" pageNumber="361">
Unterscheidet sich von 
<emphasis id="815A8EA3711230D12E7CF8FA943ECD71" italics="true" pageId="null" pageNumber="361">B. dioeca</emphasis>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="FE2EEB97D8F38773B21A650B3AA89EF2" italics="true" pageId="null" pageNumber="361">
Pflanzen 1 
<normalizedToken id="3582249446ABCD781BCCCD6A13F23FF6" originalValue="häusig" pageId="null" pageNumber="361">haeusig</normalizedToken>
;
</emphasis>
<normalizedToken id="3B10C67523BD4392141B4EEA0FFAF47F" originalValue="Blätter" pageId="null" pageNumber="361">Blaetter</normalizedToken>
stets mit scharfen 
<normalizedToken id="865ADBEF294CBD65365A575E2E2B2E42" originalValue="Zähnen" pageId="null" pageNumber="361">Zaehnen</normalizedToken>
; 
<emphasis id="D4B8E69BAC05AF3AD062FFDA0BA866FC" italics="true" pageId="null" pageNumber="361">
<normalizedToken id="DD326F04C120A93B76B78F98258CC0A2" originalValue="Kelchzähne" pageId="null" pageNumber="361">Kelchzaehne</normalizedToken>
so lang wie die Krone; Narben kahl; reife 
<normalizedToken id="394820798CA984E698EC4874A9070930" originalValue="Früchte" pageId="null" pageNumber="361">Fruechte</normalizedToken>
schwarz.
</emphasis>
- 
<normalizedToken id="61185FE8169CADA73156FC4C4C77E840" originalValue="Blüte" pageId="null" pageNumber="361">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="3C8B4F05797659D4424BD0C235E1ECA2" pageId="null" pageNumber="361">
<emphasis id="966E37751A523D7112840523644DE89A" italics="true" pageId="null" pageNumber="361">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B1AB6BD1DFAB3C75016284716AFF8B8F" italics="true" pageId="null" pageNumber="361">20:</emphasis>
Material aus botanischem Garten (Meurmann 1925, Brabec 1953; weitere Autoren in 
<normalizedToken id="5BFEC6AF095BE68A5B248BDD8E85703C" originalValue="Löve" pageId="null" pageNumber="361">Loeve</normalizedToken>
und 
<normalizedToken id="1CDF120361841261CC57B4247D0CE6B0" originalValue="Löve" pageId="null" pageNumber="361">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="8A7DCB8FFB52C32BF3113A9FEC9299C4" pageId="null" pageNumber="361">
<emphasis id="6201ED2E99E89ED113B07CF962C1CFB6" italics="true" pageId="null" pageNumber="361">
<pageBreakToken id="BB7D9A2E26E19FE9263E38E04BA26E24" pageId="null" pageNumber="361">Standort</pageBreakToken>
.
</emphasis>
Kollin. 
<normalizedToken id="9527D511551E5A9C48AC47204D711993" originalValue="Ähnlich" pageId="null" pageNumber="361">Aehnlich</normalizedToken>
wie 
<emphasis id="FCE1AB57A9E91FDC218637F97931C12D" italics="true" pageId="null" pageNumber="361">B. dioeca</emphasis>
, aber nur in den 
<normalizedToken id="5222973BAB9A86BBE5CF6CA590E2A784" originalValue="wärmsten" pageId="null" pageNumber="361">waermsten</normalizedToken>
Gebieten.
</paragraph>
<paragraph id="75B6317BE23967BA842E085E1D67815A" pageId="null" pageNumber="361">
<emphasis id="3FFAAF92ABE1224CEE9B5957777C93E1" italics="true" pageId="null" pageNumber="361">
Verbreitung. 
<normalizedToken id="4186150BA3D519079B2228773858D3E0" originalValue="Osteuropäische" pageId="null" pageNumber="361">Osteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Nord- und 
<normalizedToken id="A55D70BF8080AD1F1B89B4D1BFCCE7AF" originalValue="westwärts" pageId="null" pageNumber="361">westwaerts</normalizedToken>
bis 
<normalizedToken id="0725F937D9DFA63B1ADBFE1C9F0B9604" originalValue="Südfinnland" pageId="null" pageNumber="361">Suedfinnland</normalizedToken>
, 
<normalizedToken id="32FD5D7B3F11DFBD272867AEC05B9BF5" originalValue="Südskandinavien" pageId="null" pageNumber="361">Suedskandinavien</normalizedToken>
, Mainbecken, Wallis; 
<normalizedToken id="0FE62A0A5F0148F66D03ABBC15611CB2" originalValue="süd-" pageId="null" pageNumber="361">sued-</normalizedToken>
und 
<normalizedToken id="68E6B3C2CD60C201F1808CDD6ED7DDD8" originalValue="ostwärts" pageId="null" pageNumber="361">ostwaerts</normalizedToken>
bis 
<normalizedToken id="E44D94F31A7B232DE6CCB21CE1C34B5C" originalValue="Südalpen" pageId="null" pageNumber="361">Suedalpen</normalizedToken>
, Griechenland, 
<normalizedToken id="3BCA6AED8993C9296E98A013C794CE79" originalValue="nördliche" pageId="null" pageNumber="361">noerdliche</normalizedToken>
<normalizedToken id="B3342CB0AEBD54697CF1CFC9F7B05B18" originalValue="Türkei" pageId="null" pageNumber="361">Tuerkei</normalizedToken>
, Kaukasus, 
<normalizedToken id="DF3B25AAA27CE671953D7A6F525F379A" originalValue="Süd-" pageId="null" pageNumber="361">Sued-</normalizedToken>
und 
<normalizedToken id="085F599446970BFDCA79CF201618EB07" originalValue="Mittelrußland" pageId="null" pageNumber="361">Mittelrussland</normalizedToken>
. - Im Gebiet: Zentralalpine 
<normalizedToken id="D9E0D8DC4CE6AF31C2F7EE37C1A2EDFF" originalValue="Täler" pageId="null" pageNumber="361">Taeler</normalizedToken>
(zwischen Martigny und Visp im Wallis, Domleschg, Gegend von Chur und Ilanz, Landeck im Oberinntal, Vintschgau), ziemlich selten; sonst selten aus 
<normalizedToken id="978A573E4DFEE1497F263401768C32F9" originalValue="Gärten" pageId="null" pageNumber="361">Gaerten</normalizedToken>
(Heilpflanze) verwildert.
</paragraph>
</subSubSection>
