<subSubSection id="2214D7D17FF7353826CEEDC6CF9E5623" pageId="null" pageNumber="681" type="description">
<paragraph id="673D634D8B094030BD4DCB4A663C5BC1" pageId="null" pageNumber="681">
<normalizedToken id="791B1F292146807703E6E9E5BF75D91C" originalValue="Sträucher" pageId="null" pageNumber="681">Straeucher</normalizedToken>
oder 
<normalizedToken id="CBACD00FF8296FB5496AC35E4A884D6E" originalValue="Bäume" pageId="null" pageNumber="681">Baeume</normalizedToken>
. 
<normalizedToken id="DB7CAF8DD2FD82E31CD552394DC3EB9D" originalValue="Blüten" pageId="null" pageNumber="681">Blueten</normalizedToken>
an 
<normalizedToken id="DB8999C5E9F9DECF4CEF9ECF1DBD9052" originalValue="vorjährigen" pageId="null" pageNumber="681">vorjaehrigen</normalizedToken>
Zweigen. ♂ 
<normalizedToken id="46A679FB4BA7BB85391DABF60CD2664F" originalValue="Blüten" pageId="null" pageNumber="681">Blueten</normalizedToken>
einzeln in der Achsel eines Tragblattes in 
<normalizedToken id="3D84F8ED7EC97973850FD22B42AC74EC" originalValue="hängenden" pageId="null" pageNumber="681">haengenden</normalizedToken>
<normalizedToken id="D5B72A11782D4F14F07BB69B0D023CB0" originalValue="Ähren" pageId="null" pageNumber="681">Aehren</normalizedToken>
; kein Perigon, 2 ovale 
<normalizedToken id="E186B71E2D42A2736B0AB17983D13672" originalValue="Vorblätter" pageId="null" pageNumber="681">Vorblaetter</normalizedToken>
; Staubbeutel 8 je 
<normalizedToken id="4346D37FA95195EE7C1BA5628CC48182" originalValue="Blüte" pageId="null" pageNumber="681">Bluete</normalizedToken>
, an der Spitze mit Haarschopf, je 2 
<normalizedToken id="9290139190990BDCBD1AFFE5628D4DB7" originalValue="Staubfäden" pageId="null" pageNumber="681">Staubfaeden</normalizedToken>
am Grunde nahe beisammen oder verwachsen. ♀ 
<normalizedToken id="B4A21DD969D169227479D955C65A9671" originalValue="Blüten" pageId="null" pageNumber="681">Blueten</normalizedToken>
einzeln oder zu wenigen eine kleine, aufrechte oder abstehende 
<normalizedToken id="0C9B0E82DBC7AADA5690F083EAB493DC" originalValue="Ähre" pageId="null" pageNumber="681">Aehre</normalizedToken>
bildend, mit unscheinbarem Perigon, mit 1 Vorblatt oder 2 
<normalizedToken id="13894FD54A0AF77510F98D0AF86EE00C" originalValue="Vorblättern" pageId="null" pageNumber="681">Vorblaettern</normalizedToken>
; 
<emphasis id="7B5E9C82E0EAB0278C25293FC770ADC2" italics="true" pageId="null" pageNumber="681">
aus dem Vorblatt oder den 
<normalizedToken id="7B4BDAE42E3D2B6CBE382300068396F0" originalValue="Vorblättern" pageId="null" pageNumber="681">Vorblaettern</normalizedToken>
entsteht nach der 
<normalizedToken id="8715829FD9A6ADF5818198E796787941" originalValue="Blüte" pageId="null" pageNumber="681">Bluete</normalizedToken>
durch Verwachsen eine glocken- oder 
<normalizedToken id="7E684836EC5EEB5D200607A14E368F49" originalValue="röhrenförmige" pageId="null" pageNumber="681">roehrenfoermige</normalizedToken>
<normalizedToken id="5434DC7F5DA9545F2CF83168B69D7522" originalValue="Fruchthülle" pageId="null" pageNumber="681">Fruchthuelle</normalizedToken>
. Frucht eine hartschalige 
<normalizedToken id="499EA81C4683BC82D41F57EB8E4C0F8B" originalValue="Nuβ" pageId="null" pageNumber="681">Nuβ</normalizedToken>
.
</emphasis>
Narben 2, 
<normalizedToken id="1B108D4E34386D62FE75D71D0EA45CDE" originalValue="fadenförmig" pageId="null" pageNumber="681">fadenfoermig</normalizedToken>
, rot.
</paragraph>
<paragraph id="E96DE4D28ED992148A92BDB3FCA40F70" pageId="null" pageNumber="681">
Die Gattung 
<taxonomicName id="3C7E1CA0EDD801525E9C1650897D7120" class="Magnoliopsida" family="Betulaceae" genus="Corylus" kingdom="Plantae" order="Fagales" pageId="null" pageNumber="681" phylum="Tracheophyta" rank="genus">
<emphasis id="370F99B08237D16048DB329CE7EE7840" italics="true" pageId="null" pageNumber="681">Corylus</emphasis>
</taxonomicName>
<normalizedToken id="F862C02E7308CCDC7B246FDA44C9260C" originalValue="umfaßt" pageId="null" pageNumber="681">umfasst</normalizedToken>
<emphasis id="31E04FB42640D3ECECB89AA3823C3F5B" italics="true" pageId="null" pageNumber="681">15 Arten;</emphasis>
die meisten Arten 
<emphasis id="2B369377F50A7182155D4DE5AEB3304A" italics="true" pageId="null" pageNumber="681">
von Kleinasien 
<normalizedToken id="CA43407DB81D709943AA6755B16B7401" originalValue="ostwärts" pageId="null" pageNumber="681">ostwaerts</normalizedToken>
bis Japan, 3 Arten in Nordamerika;
</emphasis>
in 
<taxonomicName id="B7843E4BEDCD09A947F1F1D7101F29D3" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="681" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
nur 
<taxonomicName id="62EE00A2F8CA54C94C2CB4AE02559964" class="Magnoliopsida" family="Betulaceae" genus="Corylus" kingdom="Plantae" order="Fagales" pageId="null" pageNumber="681" phylum="Tracheophyta" rank="species" species="avellana">
C
<emphasis id="80508B331BDA091A78D6EC5B40314786" italics="true" pageId="null" pageNumber="681">. Avellana</emphasis>
</taxonomicName>
<normalizedToken id="8DB9B26D63EF368C75A390901BE6E600" originalValue="ursprünglich" pageId="null" pageNumber="681">urspruenglich</normalizedToken>
(Verbreitungskarte von Meusel 1964).
</paragraph>
<paragraph id="197DAEC0A7669314EC73F0937E1ED87B" pageId="null" pageNumber="681">
<emphasis id="C8D3A2001E5D28D1F3FD5DEE4EF54130" italics="true" pageId="null" pageNumber="681">Chromosomengrundzahlen</emphasis>
n = 11, 14.
</paragraph>
