<subSubSection id="0BD0E3FE376A772DC91CCE011AB808F7" pageId="null" pageNumber="171" type="description">
<paragraph id="DED7EE983A9E2AD70CCDA33D941140D0" pageId="null" pageNumber="171">
Dicht anliegende 2- oder wenigstrahlige Sternhaare und 1fache Haare vorhanden. 
<normalizedToken id="98317E4A339C6F08A452CA2A4756E183" originalValue="Kelchblätter" pageId="null" pageNumber="171">Kelchblaetter</normalizedToken>
aufrecht (nicht abstehend), 
<emphasis id="51E4A133C86F3418FA1571499F3762F3" italics="true" pageId="null" pageNumber="171">
die innern am Grunde 
<normalizedToken id="02D6203695C4B7204D555556B4884C41" originalValue="sackförmig" pageId="null" pageNumber="171">sackfoermig</normalizedToken>
ausgebuchtet.
</emphasis>
<normalizedToken id="590468E48EEAF90B949C3F80F5097BA0" originalValue="Kronblätter" pageId="null" pageNumber="171">Kronblaetter</normalizedToken>
vorn gerundet, lang gestielt, gelb. 
<normalizedToken id="5E39AB45A8DAF9933B5371866106D9AD" originalValue="Staubfäden" pageId="null" pageNumber="171">Staubfaeden</normalizedToken>
am Grunde ohne 
<normalizedToken id="6435971D30302F7FDBE6437D8569D6E5" originalValue="Zähne" pageId="null" pageNumber="171">Zaehne</normalizedToken>
. 
<emphasis id="A86D368F6F6AB3E3FF5F2D38B110920E" italics="true" pageId="null" pageNumber="171">
<normalizedToken id="3AD17E3BF7CBDA5B7A5FF3962596CEAA" originalValue="Früchte" pageId="null" pageNumber="171">Fruechte</normalizedToken>
<normalizedToken id="F6424D42F4AA7C6236E3B8442CCBF2B0" originalValue="groß" pageId="null" pageNumber="171">gross</normalizedToken>
, fast kugelig
</emphasis>
(&quot; 
<emphasis id="C494C1CC6E2E123C1942389F0D931B3A" italics="true" pageId="null" pageNumber="171">aufgeblasen</emphasis>
&quot;), vielsamig, undeutlich netznervig.
</paragraph>
<paragraph id="FB66F8F3459BD03536419ED4D3F2F7E6" pageId="null" pageNumber="171">
Die Gattung 
<taxonomicName id="5A108B3A02C4630BBF3AE65EC1648501" class="Magnoliopsida" family="Brassicaceae" genus="Alyssoides" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="171" phylum="Tracheophyta" rank="genus">
<emphasis id="147658E53F4592CDE0ABFB8803DFECD2" italics="true" pageId="null" pageNumber="171">Alyssoides</emphasis>
</taxonomicName>
<normalizedToken id="619783E39992079B4EAF6B99031AD095" originalValue="umfaßt" pageId="null" pageNumber="171">umfasst</normalizedToken>
<emphasis id="3802C7279F05A7EA622BB1B92CE6F9F1" italics="true" pageId="null" pageNumber="171">
4 nahe verwandte Arten in den 
<normalizedToken id="3DA1B58809718C5678C7EACFAAC2FE08" originalValue="Südwestalpen" pageId="null" pageNumber="171">Suedwestalpen</normalizedToken>
, im Apennin und auf der Balkanhalbinsel.
</emphasis>
</paragraph>
