<subSubSection id="C865129E8FA1969704C59947FD916685" pageId="null" pageNumber="678" type="description">
<paragraph id="5B04668F04550EE5C53E87358B3D225A" pageId="null" pageNumber="678">
<normalizedToken id="2EAB563A2833077D4CCACAB1E728B297" originalValue="Bäume" pageId="null" pageNumber="678">Baeume</normalizedToken>
oder 
<normalizedToken id="4F1270289A5397E410A1E745F3627252" originalValue="Sträucher" pageId="null" pageNumber="678">Straeucher</normalizedToken>
, 
<normalizedToken id="3875B38D3D8B85B49CE3D0D6AAA568CC" originalValue="immergrün" pageId="null" pageNumber="678">immergruen</normalizedToken>
oder 
<normalizedToken id="493C88454EA4C7CB205F20E03EDE9B05" originalValue="sommergrün" pageId="null" pageNumber="678">sommergruen</normalizedToken>
. 
<normalizedToken id="6758D40DCA3CEC3F9FA24A036E49E6CE" originalValue="Blätter" pageId="null" pageNumber="678">Blaetter</normalizedToken>
gefiedert (ohne oder mit Endteilblatt), 3teilig oder ungeteilt. Pflanze 1 
<normalizedToken id="4C3D56B2685BC89A46CAABA47AAB93F3" originalValue="häusig" pageId="null" pageNumber="678">haeusig</normalizedToken>
; 
<normalizedToken id="9DAE490A78EC97FBF8FC1DA54785083C" originalValue="Blüten" pageId="null" pageNumber="678">Blueten</normalizedToken>
1geschlechtig, in trauben-oder rispenartigen, 
<pageBreakToken id="D4B414DC5990AF1E8B6FCA79255F1366" pageId="null" pageNumber="678">
<normalizedToken id="F775DE1912983A7E1169F40CB9861862" originalValue="vielblütigen" pageId="null" pageNumber="678">vielbluetigen</normalizedToken>
</pageBreakToken>
, 1geschlechtigen 
<normalizedToken id="55D8800BE6070EF33DB18E4F42C9F164" originalValue="Blütenständen" pageId="null" pageNumber="678">Bluetenstaenden</normalizedToken>
, 
<emphasis id="CC16935940E9718B2539705B3521CCA6" italics="true" pageId="null" pageNumber="678">
nur mit 1facher 
<normalizedToken id="89A30C008C72DF939E183B7CC75767DF" originalValue="Blütenhülle" pageId="null" pageNumber="678">Bluetenhuelle</normalizedToken>
</emphasis>
(nicht Kelch und Krone!). ♂ 
<normalizedToken id="FE2900A8D19C4BF40D13FD9896FF00C4" originalValue="Blüten" pageId="null" pageNumber="678">Blueten</normalizedToken>
mit 
<emphasis id="596636F6FF46FB65B34902BDF8600932" italics="true" pageId="null" pageNumber="678">
2-5 
<normalizedToken id="FE2C22B4E804251674B83FDCE1312DC1" originalValue="Kronblättern" pageId="null" pageNumber="678">Kronblaettern</normalizedToken>
;
</emphasis>
<normalizedToken id="63E02004BA23C1D39FC23EDD9E3185DC" originalValue="Staubblätter" pageId="null" pageNumber="678">Staubblaetter</normalizedToken>
3-5. ♂ 
<normalizedToken id="252AD2EEC9977FC774E87AB0AD07D4B0" originalValue="Blüten" pageId="null" pageNumber="678">Blueten</normalizedToken>
mit 
<emphasis id="65BBC0ED00CCA55A0D42A7FD24F89A80" italics="true" pageId="null" pageNumber="678">
2-5 
<normalizedToken id="4C576B6D3296C9D2C58F7D88124A5633" originalValue="Kelchblättern" pageId="null" pageNumber="678">Kelchblaettern</normalizedToken>
;
</emphasis>
<normalizedToken id="09876C46D4BAAEAF82DE2D860983BF2C" originalValue="Fruchtblätter" pageId="null" pageNumber="678">Fruchtblaetter</normalizedToken>
3, verwachsen, 
<normalizedToken id="C6A657A65FC830F7FD12E76100BEEFC0" originalValue="oberständig" pageId="null" pageNumber="678">oberstaendig</normalizedToken>
, nur 1 Fruchtblatt mit sich entwickelnder Samenanlage. Griffel 3teilig, 
<normalizedToken id="E4267108AE413DD9BADA67B62ECF70DC" originalValue="endständig" pageId="null" pageNumber="678">endstaendig</normalizedToken>
. Frucht kugelig oder 
<normalizedToken id="214A93133A46F26891DDD28548FCD7AB" originalValue="eiförmig" pageId="null" pageNumber="678">eifoermig</normalizedToken>
, eine 1samige Steinfrucht.
</paragraph>
<paragraph id="A2A7048C064492544D28D1DAF96D2E4E" pageId="null" pageNumber="678">
Die Gattung 
<taxonomicName id="503056B8525DCDD493243975D1A8B0F9" class="Magnoliopsida" family="Anacardiaceae" genus="Pistacia" kingdom="Plantae" order="Sapindales" pageId="null" pageNumber="678" phylum="Tracheophyta" rank="genus">
<emphasis id="AE9ED3D9FD83E33C43A43E284DBB810C" italics="true" pageId="null" pageNumber="678">Pistacia</emphasis>
</taxonomicName>
<normalizedToken id="2B717690968584EA4DD0A5F6B5E9CFEE" originalValue="umfaßt" pageId="null" pageNumber="678">umfasst</normalizedToken>
<emphasis id="CDE9DD6BAE7D10786CFB3439CDF1ABC6" italics="true" pageId="null" pageNumber="678">9 Arten, die durch das Mediterrangebiet bis Ostasien und in Mexiko Vorkommen.</emphasis>
Aus der Gattung sind die 
<emphasis id="62AB2FDAF36A906E52A9FB3E4A4B0865" italics="true" pageId="null" pageNumber="678">Chromosomenzahlen</emphasis>
2n = 24, 28, 30 bekannt.
</paragraph>
</subSubSection>
