<paragraph id="25603698FFF3FFFFE292A3F2CF7475A0" blockId="29.[151,1436,219,458]" pageId="29" pageNumber="330">
<emphasis id="17ABEA8AFFF3FFFFE292A3F2CF5675C6" box="[151,278,404,428]" italics="true" pageId="29" pageNumber="330">Paleochrysa</emphasis>
[
<emphasis id="17ABEA8AFFF3FFFFE320A3F2CF0175C1" box="[293,321,404,427]" italics="true" pageId="29" pageNumber="330">sic</emphasis>
]: 
<bibRefCitation id="414E4B69FFF3FFFFE352A3F2CC4275C6" author="Adams, P. A." box="[343,514,403,428]" pageId="29" pageNumber="330" pagination="67 - 74" refId="ref21927" refString="Adams, P. A. (1957) A new genus and new species of Chrysopidae from the western United States, with remarks on the wing venation of the family (Neuroptera). Psyche, 63, 67 - 74. [for 1976] https: // doi. org / 10.1155 / 1956 / 47287" type="journal article" year="1957">Adams 1957: 71</bibRefCitation>
, 72; 
<bibRefCitation id="414E4B69FFF3FFFFE031A3F2CCAC75C6" author="Adams, P. A." box="[564,748,403,428]" pageId="29" pageNumber="330" pagination="215 - 238" refId="ref21987" refString="Adams, P. A. (1967) A review of the Mesochrysinae and Nothochrysinae (Neuroptera: Chrysopidae). Bulletin of the Museum of Comparative Zoology, 135, 215 - 238." type="journal article" year="1967">Adams 1967: 220</bibRefCitation>
, 231; 
<bibRefCitation id="414E4B69FFF3FFFFE12FA3F2CA5D75C6" author="Yang, C. K. &amp; Hong, Y. C." box="[810,1053,404,428]" pageId="29" pageNumber="330" pagination="15 - 26" refId="ref26487" refString="Yang, C. K. &amp; Hong, Y. C. (1990) Drakochrysa, an Early Cretaceous new genus of Chrysopidae (Insecta: Neuroptera) from Laiyang Basin, Shandong Province. Geoscience, 4 (4), 15 - 26, 1 pl." type="journal article" year="1990">Yang &amp; Hong 1990: 20</bibRefCitation>
; 
<bibRefCitation id="414E4B69FFF3FFFFE62CA3F2CABE75C6" author="Carpenter, F. M." box="[1065,1278,404,428]" pageId="29" pageNumber="330" pagination="1 - 655" refId="ref22887" refString="Carpenter, F. M. (1992) Superclass Hexapoda. In: Kaesler, R. L. (Ed.), Treatise on Invertebrate Paleontology. Part R. Arthropoda 4. Vols. 3 &amp; 4. Geological Society of America, Boulder, Colorado &amp; University of Kansas, Lawrence, Kansas, pp. 1 - 655." type="book chapter" year="1992">Carpenter 1992: 347</bibRefCitation>
; 
<bibRefCitation id="414E4B69FFF3FFFFE70CA3F2CF7075A0" author="Penalver, E. &amp; Nel, A. &amp; Martinex-Delclos, X." pageId="29" pageNumber="330" pagination="481 - 487" refId="ref25120" refString="Penalver, E., Nel, A. &amp; Martinex-Delclos, X. (1995) New Nothochrysinae from the spanish Miocene (Neuroptera, Chrysopidae). Bulletin de la Societe Entomologique de France, 100, 481 - 487. https: // doi. org / 10.3406 / bsef. 1995.17194" type="journal article" year="1995">
Peñalver 
<emphasis id="17ABEA8AFFF3FFFFE76CA3F2CBD675C6" box="[1385,1430,404,428]" italics="true" pageId="29" pageNumber="330">et al</emphasis>
. 1995: 486
</bibRefCitation>
