<subSubSection id="9F27BB97044076DEA8065B1D374F72A3" pageId="null" pageNumber="575" type="description">
<paragraph id="7A17799D3BBE21AC025F1C28D4A19230" pageId="null" pageNumber="575">
<emphasis id="365F5E08431C341916485C5187AAE364" italics="true" pageId="null" pageNumber="575">
1 
<normalizedToken id="FB035004737C1EC716AB7A958DCE52E8" originalValue="jährig" pageId="null" pageNumber="575">jaehrig</normalizedToken>
</emphasis>
, mit 
<normalizedToken id="CB1E2220CB22E85634BF96288B0A8B6D" originalValue="dünner" pageId="null" pageNumber="575">duenner</normalizedToken>
Wurzel; 10-60 cm hoch. Stengel aufrecht, kahl oder zerstreut behaart (Haare mehrzellig), meist verzweigt. 
<normalizedToken id="E2CD5610F9C29D9209B81DC7964516EF" originalValue="Blätter" pageId="null" pageNumber="575">Blaetter</normalizedToken>
kahl oder zerstreut behaart, 
<emphasis id="92631D5C59AB4B52C1E9A40F81FBFC7A" italics="true" pageId="null" pageNumber="575">
ungeteilt, 
<normalizedToken id="041760BFD6FD23B5CE3D3ED8FC0BA53E" originalValue="gezähnt" pageId="null" pageNumber="575">gezaehnt</normalizedToken>
</emphasis>
(
<normalizedToken id="F39E326EF37F34B0EFF5B5D6E0D79C08" originalValue="Zähne" pageId="null" pageNumber="575">Zaehne</normalizedToken>
nach vorn gerichtet, 
<emphasis id="2245B19DAAB122252A034B0EC6F34A6A" italics="true" pageId="null" pageNumber="575">
nicht 
<normalizedToken id="3D920FE8F72BA9EC8290F5CF5A192F34" originalValue="länger" pageId="null" pageNumber="575">laenger</normalizedToken>
als 3 mm
</emphasis>
), die untern 
<normalizedToken id="017B1B801F7B548386677F3A952D29FE" originalValue="Blätter" pageId="null" pageNumber="575">Blaetter</normalizedToken>
oval (
<normalizedToken id="9AAE6B47BDF4995C2F600DA24C6E5FE0" originalValue="größte" pageId="null" pageNumber="575">groesste</normalizedToken>
Breite im obersten Drittel), 
<normalizedToken id="B08F0C27AC34E9F4260E5236C22FEDA8" originalValue="allmählich" pageId="null" pageNumber="575">allmaehlich</normalizedToken>
in einen kurzen Stiel 
<normalizedToken id="09D4596698588B2B5633BAC231B0141B" originalValue="verschmälert" pageId="null" pageNumber="575">verschmaelert</normalizedToken>
, die obern lanzettlich, 
<emphasis id="71ED7BBA0F14E08674D4BF8954F3CB1E" italics="true" pageId="null" pageNumber="575">
mit 
<normalizedToken id="609DE5533329D15D65E5A379EBA5B0CC" originalValue="verschmälertem" pageId="null" pageNumber="575">verschmaelertem</normalizedToken>
oder wenig umfassendem
</emphasis>
Grunde sitzend. 
<normalizedToken id="E87403362FFC3C1466E7C332327E19D2" originalValue="Köpfe" pageId="null" pageNumber="575">Koepfe</normalizedToken>
einzeln am Ende der Zweige, im Durchmesser 2-3 cm. 
<normalizedToken id="9C0B4687B238FFDB82F6DDAE0B9AA0A6" originalValue="Hüllblätter" pageId="null" pageNumber="575">Huellblaetter</normalizedToken>
kahl oder zerstreut behaart, hell berandet. 
<emphasis id="6D3D9AB256C701B01C19978E51C9F162" italics="true" pageId="null" pageNumber="575">
<normalizedToken id="04AF57820D91B57944D9D83A71CEB85C" originalValue="Zungenförmige" pageId="null" pageNumber="575">Zungenfoermige</normalizedToken>
<normalizedToken id="B364C095E2B820903C698670EDF989CD" originalValue="Blüten" pageId="null" pageNumber="575">Blueten</normalizedToken>
goldgelb
</emphasis>
, 1-1,5 cm lang. 
<emphasis id="EB442DCF7E56FF099EF297EEE1B55115" italics="true" pageId="null" pageNumber="575">
<normalizedToken id="1EB60AA4EFF2B183C2BC5E4EF3E25671" originalValue="Früchte" pageId="null" pageNumber="575">Fruechte</normalizedToken>
etwas 
<normalizedToken id="02C2F4680820DD6C4A4D793A680C3230" originalValue="gekrümmt" pageId="null" pageNumber="575">gekruemmt</normalizedToken>
</emphasis>
, 2-3 mm lang (ohne Rand), 6-10rippig, 
<emphasis id="725F61FA980F35E12AC8DC9D27EE14C7" italics="true" pageId="null" pageNumber="575">oben mit 0,5</emphasis>
- 
<emphasis id="9CDC697C6BFEB7AD4504E772AFC1A33E" italics="true" pageId="null" pageNumber="575">
2 mm langem, einseitig 
<normalizedToken id="BC866AE5BAC5BF08373E9E4CC14B47E5" originalValue="verlängertem" pageId="null" pageNumber="575">verlaengertem</normalizedToken>
, 
<normalizedToken id="4DFDA0A31205C2193C5CBAC4A2B13F49" originalValue="gezähntem" pageId="null" pageNumber="575">gezaehntem</normalizedToken>
Rand.
</emphasis>
- 
<normalizedToken id="A3DED9A37B9D275AC51867657776D9C9" originalValue="Blüte" pageId="null" pageNumber="575">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="BDAEEA67B674A361F6942DC3F339625E" pageId="null" pageNumber="575">
<emphasis id="7C2CB506E1C3C5BB6128D2CF3F10DB5E" italics="true" pageId="null" pageNumber="575">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A879023EE769E0BE116D9BA06B974A58" italics="true" pageId="null" pageNumber="575">18:</emphasis>
Material aus botanischen 
<normalizedToken id="C6BEC7FA46E9449B94D6BB3733119C4F" originalValue="Gärten" pageId="null" pageNumber="575">Gaerten</normalizedToken>
(Harling 1951a, Dowrick 1952).
</paragraph>
<paragraph id="583AE3E3A02FDA13AA5E7803202A43F0" pageId="null" pageNumber="575">
<emphasis id="03DDC2F18238857E1F11EE1E674A9394" italics="true" pageId="null" pageNumber="575">Standort.</emphasis>
Kollin. Trockene, lockere 
<normalizedToken id="17E8E90F8F215F23C583318DE1797D13" originalValue="Böden" pageId="null" pageNumber="575">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="FA2ACE35FC60BA088E76FA05A13DD1D0" originalValue="Schuttplätze" pageId="null" pageNumber="575">Schuttplaetze</normalizedToken>
, Bahnareale.
</paragraph>
<paragraph id="67D110A1D31626B5883EEFF38B14557A" pageId="null" pageNumber="575">
<emphasis id="D8F48E1319B21B90F1AB28C63445F666" italics="true" pageId="null" pageNumber="575">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="F745901D3D6FB0D09C885ECA0C4C4686" originalValue="Südeuropa" pageId="null" pageNumber="575">Suedeuropa</normalizedToken>
; Kleinasien; Nordwestafrika. - Im Gebiet nicht einheimisch, gelegentlich adventiv.
</paragraph>
</subSubSection>
