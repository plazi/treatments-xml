<taxonomicName id="73AFA6EC3CFEEB5719C4EA9B9F61FEC6" authority="L." class="Magnoliopsida" family="Fabaceae" genus="Astragalus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="559" phylum="Tracheophyta" rank="species" species="alopecuroides">
Astragalus 
