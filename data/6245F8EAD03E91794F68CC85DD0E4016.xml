<paragraph id="CF7D176AE7D49B8894E5A888811DDD7C" pageId="null" pageNumber="537">
<taxonomicName id="F235F2EDF773D557E42A05A12B0306D8" authority="L." class="Magnoliopsida" family="Fabaceae" genus="Medicago" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="537" phylum="Tracheophyta" rank="species" species="falcata">
<pageBreakToken id="70E537778F266589C0EC771E338CB23E" pageId="null" pageNumber="537">Medicago</pageBreakToken>
<normalizedToken id="FBA364DFE5FBAF4EFD91A1AF5762616A" originalValue="falcáta" pageId="null" pageNumber="537">falcata</normalizedToken>
<authorityName id="4C011091801E3053BFE0E020C4703CFC" pageId="null" pageNumber="537">L.</authorityName>
