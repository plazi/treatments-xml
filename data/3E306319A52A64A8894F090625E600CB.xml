<subSubSection id="C437968BBD6BD5B439D0C573C378B7A9" pageId="null" pageNumber="103" type="nomenclature">
<paragraph id="808A4721C0E182D4B6C67F3DCEE0B810" pageId="null" pageNumber="103">
<taxonomicName id="D06AF6F7766128A04EDD64A0224D3E94" authority="Sw." class="Polypodiopsida" family="Pteridaceae" genus="Cheilanthes" kingdom="Plantae" order="Polypodiales" pageId="null" pageNumber="103" phylum="Tracheophyta" rank="species" species="fragrans">
Cheilanthes 
<normalizedToken id="75764C57A476D23E6584E1A5EB0A8742" originalValue="frágrans" pageId="null" pageNumber="103">fragrans</normalizedToken>
Sw.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="D7957863552C13CBA9E94DDDACAC41A1" pageId="null" pageNumber="103" type="vernacular_names">
<paragraph id="B8BA24E2FDF3B721E3D15D78BF78F5FD" pageId="null" pageNumber="103">Gefranster Duftfarn</paragraph>
</subSubSection>
</title>
<subSubSection id="70DB46AEB4929360425A33A705C290A7" pageId="null" pageNumber="103" type="description">
<paragraph id="7347CFAB4F4949CD96679D4E20218721" pageId="null" pageNumber="103">
Blattstiel 
<normalizedToken id="19D2F5601BB2871891C7193FC987F325" originalValue="kürzer" pageId="null" pageNumber="103">kuerzer</normalizedToken>
als die Spreite, dunkelbraun, 
<normalizedToken id="156783A00D1C942A7B5FF9944DB2AFF2" originalValue="glänzend" pageId="null" pageNumber="103">glaenzend</normalizedToken>
, mit zahlreichen, schmal lanzettlichen Spreuschuppen; Blattspreite im 
<normalizedToken id="6F0D7CD9E04275F2C7E317D43D69FE68" originalValue="Umriß" pageId="null" pageNumber="103">Umriss</normalizedToken>
oval bis 3eckig, bis 8 cm lang, 2-3mal so lang wie breit, 
<emphasis id="B7621BF5B7B797DEADDF4BF29D8774C1" italics="true" pageId="null" pageNumber="103">2-3fach gefiedert;</emphasis>
Abschnitte im 
<normalizedToken id="DE1B25E6216A00FD1B281462CED106FE" originalValue="Umriß" pageId="null" pageNumber="103">Umriss</normalizedToken>
oval, ganzrandig bis fiederteilig; 
<emphasis id="2E165B494B075FEE68F5A3CE55FCC55C" italics="true" pageId="null" pageNumber="103">
Rand nach unten umgebogen. Sori mit Schleier; Schleier am Blattrand angewachsen, meist 
<normalizedToken id="15FAC4B9682FCE1CCB2DD7237C80865E" originalValue="drüsig" pageId="null" pageNumber="103">druesig</normalizedToken>
bewimpert.
</emphasis>
- Sporenreife: Sommer.
</paragraph>
<paragraph id="B88786B6F2B606E9BEAF6CFD7C0C123F" pageId="null" pageNumber="103">
<emphasis id="BB00E4497A74F3D0A9AF35B587B78DE3" italics="true" pageId="null" pageNumber="103">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="6B5F19BD2F51DA967858D9908F4BD38F" pageId="null" pageNumber="103">
<emphasis id="2335C3132D8E2F0E3F5640D50A3D2004" italics="true" pageId="null" pageNumber="103">Standort.</emphasis>
Kollin. Sonnige Felsspalten.
</paragraph>
<paragraph id="BF639418D9880624D4FD9FC87132FACD" pageId="null" pageNumber="103">
<emphasis id="2020423945686C0CE128A6CB4E2E88CB" italics="true" pageId="null" pageNumber="103">Verbreitung. Mediterrane Pflanze:</emphasis>
Ganzes Mittelmeergebiet, 
<normalizedToken id="E7DDA274B07E6BE31B125D2FF4B9885B" originalValue="nordwärts" pageId="null" pageNumber="103">nordwaerts</normalizedToken>
bis in 
<normalizedToken id="1B102814AD436B1C4BB0BB7004A80E9D" originalValue="südliche" pageId="null" pageNumber="103">suedliche</normalizedToken>
<normalizedToken id="D5F7230C6032977A325B2FD7D34EBDBC" originalValue="Alpentäler" pageId="null" pageNumber="103">Alpentaeler</normalizedToken>
, 
<normalizedToken id="08CE571B97048A8498DAD6DEB846943A" originalValue="ostwärts" pageId="null" pageNumber="103">ostwaerts</normalizedToken>
bis Afghanistan und westlicher Himalaja; auch aus 
<normalizedToken id="0E12C7222CF6F1A5BAFF56B40419A59C" originalValue="Südamerika" pageId="null" pageNumber="103">Suedamerika</normalizedToken>
(Peru) angegeben. - Im Gebiet: Aostatal, Valsesia (Civiasco), Val 
<normalizedToken id="F9CCDA364E1BFE65A585FBC218710506" originalValue="d’Ossola" pageId="null" pageNumber="103">d'Ossola</normalizedToken>
; Angabe von Chiavenna bezieht sich auf 
<taxonomicName id="B403526DB0FC9E7956D2EA24B29AEA98" authority="Marantae" authorityName="Marantae" class="Polypodiopsida" family="Pteridaceae" genus="Notholaena" kingdom="Plantae" order="Polypodiales" pageId="null" pageNumber="103" phylum="Tracheophyta" rank="genus">
<emphasis id="4BC1E773CAF3FF953BC7F653FA86A498" italics="true" pageId="null" pageNumber="103">Notholaena Marantae</emphasis>
</taxonomicName>
(
<authorityName id="7355B95558FCAF2819D5FD96519535CD" pageId="null" pageNumber="103">L.</authorityName>
) R. Br. (Hauser und Reichstein 1960).
</paragraph>
<paragraph id="C1BF3A1D5406BA8E96E564E72DCE9A86" pageId="null" pageNumber="103">
<emphasis id="286F9F258CE6904A56E8BB5787578E2F" italics="true" pageId="null" pageNumber="103">Bemerkungen.</emphasis>
Becherer (in 
<emphasis id="07BA653EB97A075716005B387F4A537F" italics="true" pageId="null" pageNumber="103">Fortschritte</emphasis>
, 1962) verwendet den Namen 
<taxonomicName id="6FBBF517B1ADDDAB3DAF4B82F0487198" authority="(Reichhard) Christensen." authorityName="Christensen." baseAuthorityName="Reichhard" class="Polypodiopsida" family="Pteridaceae" genus="Cheilanthes" kingdom="Plantae" order="Polypodiales" pageId="null" pageNumber="103" phylum="Tracheophyta" rank="species" species="pteridioides">
<emphasis id="6681FF7BF8533371327391438A5490A0" italics="true" pageId="null" pageNumber="103">Ch. pteridioides</emphasis>
(Reichhard) Christensen.
</taxonomicName>
</paragraph>
</subSubSection>
</treatment>
