<subSubSection id="14D57A95A333588D3E54BA98FAEDCB3B" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="E11A92858CDB75F9B22EAE11B2AFB950" pageId="null" pageNumber="590">Gletscher-Habichtskraut</paragraph>
</subSubSection>
</title>
<subSubSection id="197BD6CBBF23391967DF8ECAED91C6D4" pageId="null" pageNumber="590" type="description">
<paragraph id="6F0B0F95AF4683E1B6A09AB98C9BBBE0" pageId="null" pageNumber="590">
<emphasis id="5D6BD0805DE05A967DACD597F9E3E9F0" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="FAD46472422C901B3DD4512969BBF397" originalValue="Ausläufer" pageId="null" pageNumber="590">Auslaeufer</normalizedToken>
nicht vorhanden oder seltener sehr kurz;
</emphasis>
Stengel behaart, neben Stern- und 
<normalizedToken id="0DDB80857ECE5FF555A93B7E44B32980" originalValue="Drüsenhaaren" pageId="null" pageNumber="590">Druesenhaaren</normalizedToken>
auch 
<emphasis id="E47C2157BCFD8D3EAC95AA9FE8B9150B" italics="true" pageId="null" pageNumber="590">mit 1,5</emphasis>
- 
<emphasis id="7372406527EE91F19851CB6CA106C11B" italics="true" pageId="null" pageNumber="590">
4 mm langen, einfachen Haaren; 
<normalizedToken id="77F0615687C6A64CEF9D4FBC4D9A11E3" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
<normalizedToken id="B12E51576895EC2F0C35B5ECB47804C9" originalValue="grün" pageId="null" pageNumber="590">gruen</normalizedToken>
, meist spitz, stets mit Sternhaaren
</emphasis>
(oft nur am Rand und auf dem Mittelnerv der Blattoberseite). 
<normalizedToken id="CA7CD4E18F06D6B3F54D4A6BDFEC01A9" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
fein zugespitzt, 
<emphasis id="39B26A9CB9BDFA650B2E92073E777F16" italics="true" pageId="null" pageNumber="590">mit zahlreichen, 1,5</emphasis>
- 
<emphasis id="2939BC32D3AFCED953A221EF724A1B5B" italics="true" pageId="null" pageNumber="590">4 mm langen, einfachen Haaren.</emphasis>
- 
<normalizedToken id="800FD03A48DB8E89F653C8C0DF4EF464" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="3D6D929E24284E2A8F5A520E103478C4" originalValue="früher" pageId="null" pageNumber="590">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="A902D31CFA5D98FCBD8E1C34FC072487" pageId="null" pageNumber="590">
<emphasis id="4BE16BC56B715BA8B9522E6B0F379C92" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="419DDB9930ABABC2CFFA7B659C1E639E" italics="true" pageId="null" pageNumber="590">18:</emphasis>
Material aus dem Val Queyras in den Westalpen (Favarger 1969).
</paragraph>
<paragraph id="342843AA434E0601570D82FA006EF438" pageId="null" pageNumber="590">
<emphasis id="40725F5CA4C6F1B609E5939E5E0E6336" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Alpin (selten subalpin). Oft kalkarme, tonige 
<normalizedToken id="14E3C2AFB6949428CB8082A03F54CE92" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
in sonnigen Lagen. Weiden, 
<normalizedToken id="D62563B0DD76A2C9758FD086DFA7C4AC" originalValue="Schutthänge" pageId="null" pageNumber="590">Schutthaenge</normalizedToken>
. 
<emphasis id="B9E83672607C4F77B500D4EE1AEA8047" italics="true" pageId="null" pageNumber="590">Festucetum Halleri</emphasis>
Br.-Bl. 1926, 
<emphasis id="D2796D34120F3E3EF39BBBCF37464DD9" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="3972C09356175048F571D408D634AEF8" originalValue="Aveno-Närdetum" pageId="null" pageNumber="590">Aveno-Naerdetum</normalizedToken>
</emphasis>
Oberd. 1950.
</paragraph>
<paragraph id="A2D0FDED85C913F02030ED8E5AD6D8FC" pageId="null" pageNumber="590">
<emphasis id="6532FC5786CBF62459A04BAFFD06FC29" italics="true" pageId="null" pageNumber="590">Verbreitung. Alpen-Pflanze:</emphasis>
Vom Col de Tende 
<normalizedToken id="2F1B02C2A8ACE59809D5FE3491A958EB" originalValue="ostwärts" pageId="null" pageNumber="590">ostwaerts</normalizedToken>
bis zur Krain. - Im Gebiet: Alpen (besonders Zentral- und 
<normalizedToken id="F4629C3880ECF46514DD4A67CA2888FB" originalValue="Südalpen" pageId="null" pageNumber="590">Suedalpen</normalizedToken>
); nicht 
<normalizedToken id="1A47D1558B0DA91A8EFC2B2D4E248A88" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
