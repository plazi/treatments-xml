Holotype of 
<taxonomicName id="B2E208832629E745DCD508C832DE3F4C" authorityName="M. Tang, G. J. Yan &amp; W. P. Li" authorityYear="2022" class="Magnoliopsida" family="Asteraceae" genus="Aster" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Aster quanzhouensis" order="Asterales" pageId="0" pageNumber="93" phylum="Tracheophyta" rank="species" species="quanzhouensis">
