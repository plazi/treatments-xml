<subSubSection id="5759DDD36250FFB4A9D96065673D142D" pageId="null" pageNumber="288" type="description">
<paragraph id="DE6DE0AF010938AF63AE354AC0148139" pageId="null" pageNumber="288">
Ausdauernd, locker- bis dichtrasig, mit Rhizom und kriechenden 
<normalizedToken id="EBD1B5712169FC3B747628660C2158D8" originalValue="Ausläufern" pageId="null" pageNumber="288">Auslaeufern</normalizedToken>
, 10-20 cm hoch. 
<normalizedToken id="83C1B636D65582DFB79D643D46B987FF" originalValue="Blühende" pageId="null" pageNumber="288">Bluehende</normalizedToken>
Stengel 
<normalizedToken id="F5210BEE3CA42F02E5C01DE27279671C" originalValue="dünn" pageId="null" pageNumber="288">duenn</normalizedToken>
, aufsteigend, meist unverzweigt, besonders an den Kanten mit einzelnen 0,3-0,5 mm langen, abstehenden Haaren oder meist 
<normalizedToken id="F109F854739B16ED6C0C1523B82258E6" originalValue="±" pageId="null" pageNumber="288">+/-</normalizedToken>
kahl. Mittlere 
<normalizedToken id="65E2F2C593162190DAA3DAF47CF2EC0A" originalValue="Blätter" pageId="null" pageNumber="288">Blaetter</normalizedToken>
zu 4 im Quirl, 
<emphasis id="6EC4AC3E593EE6435B499690CBC940F3" italics="true" pageId="null" pageNumber="288">0,5</emphasis>
- 
<emphasis id="52F5792E06A893E3C0E5D016BDB28D51" italics="true" pageId="null" pageNumber="288">2 cm lang, breit oval</emphasis>
, mit der 
<normalizedToken id="64C012070525800F87A91DAEC7BC771F" originalValue="größten" pageId="null" pageNumber="288">groessten</normalizedToken>
Breite etwa in der Mitte, 
<emphasis id="8A07159882BDA3688CD36E5EF522A951" italics="true" pageId="null" pageNumber="288">1</emphasis>
⅓/- 
<emphasis id="5C363AAF1F8834115C7414341E357465" italics="true" pageId="null" pageNumber="288">2</emphasis>
<normalizedToken id="188DA88B2A65C3DFB2A29D621D918577" originalValue="½" pageId="null" pageNumber="288">1/2</normalizedToken>
<emphasis id="0CDF8014ADC9C3E734FE0274DE83BEA4" italics="true" pageId="null" pageNumber="288">mal so lang wie breit</emphasis>
, 
<emphasis id="C83639ECBB1F13597883ADBDE0AA03D6" italics="true" pageId="null" pageNumber="288">3nervig</emphasis>
, mit kurzer, krautiger Spitze, beiderseits 
<normalizedToken id="1A031FC9F86C4BE91EF4669876485F3A" originalValue="grün" pageId="null" pageNumber="288">gruen</normalizedToken>
, am Rande und oft auf den Nerven und der Oberseite mit nach vorn gerichteten 0,3-0,5 mm langen Haaren. 
<normalizedToken id="D5CBD1A9713ED226366B393793B93909" originalValue="Blütenstand" pageId="null" pageNumber="288">Bluetenstand</normalizedToken>
locker, 
<emphasis id="647079D511174C7E0CDD09F8800F7E64" italics="true" pageId="null" pageNumber="288">
<normalizedToken id="67880CC4FAD107D8588FA19717CC7B5A" originalValue="wenigblütig" pageId="null" pageNumber="288">wenigbluetig</normalizedToken>
</emphasis>
, 
<emphasis id="166DB44D25B0FCFDEDD4A5A29C30DC6B" italics="true" pageId="null" pageNumber="288">
<normalizedToken id="87E64FC246299E3F39951F133A9FC424" originalValue="schirmförmig" pageId="null" pageNumber="288">schirmfoermig</normalizedToken>
.
</emphasis>
<normalizedToken id="CEA2C4D90D87510D5F71E6F5910B2189" originalValue="Blütenstiele" pageId="null" pageNumber="288">Bluetenstiele</normalizedToken>
5-15 mm lang, ohne 
<normalizedToken id="A9DDB78538F37B6D297A8F6675677C87" originalValue="Tragblätter" pageId="null" pageNumber="288">Tragblaetter</normalizedToken>
. Fruchtstiele gerade. Krone 
<normalizedToken id="8EED211EBD9B5989EEE525712F983D9A" originalValue="weiß" pageId="null" pageNumber="288">weiss</normalizedToken>
bis 
<normalizedToken id="FB9229819CE363BE3626768A26640E54" originalValue="grünlichweiß" pageId="null" pageNumber="288">gruenlichweiss</normalizedToken>
, 
<normalizedToken id="5435970390F0E9EC1E505A9FB94A508D" originalValue="±" pageId="null" pageNumber="288">+/-</normalizedToken>
flach, mit spitzen (aber nicht grannenartig zugespitzten) Zipfeln, ca. 3 mm im Durchmesser. 
<normalizedToken id="0C87245BCEF2ACE38ABCE216A255D244" originalValue="Früchte" pageId="null" pageNumber="288">Fruechte</normalizedToken>
ca. 2 mm hoch, mit zahlreichen abstehenden, 
<emphasis id="7C250DE691F6AB3DA3432D22C445D49D" italics="true" pageId="null" pageNumber="288">0,5</emphasis>
- 
<emphasis id="8C2D31E9FE330AF37A982042BAB1346F" italics="true" pageId="null" pageNumber="288">1 mm langen hakigen Haaren</emphasis>
(Widerhaken). - 
<normalizedToken id="5DE631AC3209058293801FE9DAE8034B" originalValue="Blüte" pageId="null" pageNumber="288">Bluete</normalizedToken>
: 
<normalizedToken id="25F91B98073A007B8D077B8A95C32807" originalValue="Später" pageId="null" pageNumber="288">Spaeter</normalizedToken>
<normalizedToken id="BAC648B71C0288B574E3368D53ADAE19" originalValue="Frühling" pageId="null" pageNumber="288">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="BFE54235391BBA9B1EA96BF9F58E435D" pageId="null" pageNumber="288">
<emphasis id="EBD5B5C60EDCBE3D65869FC51E5D0413" italics="true" pageId="null" pageNumber="288">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A069BA1890F5621D6D95EF1A4A8C1D24" italics="true" pageId="null" pageNumber="288">22:</emphasis>
Material von verschiedenen Stellen aus Polen (Piotrowicz 1958, Skalinska et al. 1964), aus botanischem Garten (Kliphuis 1962a), aus dem Himalaja (verwandte Art; Khoshoo und Bhatia 1963a), aus Taiwan (verwandte Art; Hsu 1968).
</paragraph>
<paragraph id="F179E6ACED728BEBD119370C8393FD0D" pageId="null" pageNumber="288">
<emphasis id="40E50CB939192A962522F7852F3EC3F4" italics="true" pageId="null" pageNumber="288">Standort.</emphasis>
Montan, seltener subalpin und kollin. Ziemlich feuchte, kalkarme, 
<normalizedToken id="C9F1B0FD7045917D6869EE64139B63B9" originalValue="mäßig" pageId="null" pageNumber="288">maessig</normalizedToken>
saure, humose, tonige 
<normalizedToken id="D181C0A158C2A88CBE70251929936921" originalValue="Böden" pageId="null" pageNumber="288">Boeden</normalizedToken>
in schattigen, luftfeuchten Lagen. 
<normalizedToken id="B3CD5D8C266629A35024713B419EB768" originalValue="Nadelwälder" pageId="null" pageNumber="288">Nadelwaelder</normalizedToken>
(seltener 
<normalizedToken id="B37F08C7815E37974A9F36D6CF1B97C2" originalValue="Buchen-Tannenwälder" pageId="null" pageNumber="288">Buchen-Tannenwaelder</normalizedToken>
), 
<normalizedToken id="4160E3DBB267F78ABBC3917B68275EA9" originalValue="Waldschläge" pageId="null" pageNumber="288">Waldschlaege</normalizedToken>
.
</paragraph>
<paragraph id="6F053C48467179957BBCE756A91A910A" pageId="null" pageNumber="288">
<emphasis id="621E166B706629E669B94FB933F7E397" italics="true" pageId="null" pageNumber="288">
Verbreitung. 
<normalizedToken id="E955F78DCD0837D3016024F77569A6E1" originalValue="Europäisch-südwestasiatische" pageId="null" pageNumber="288">Europaeisch-suedwestasiatische</normalizedToken>
Gebirgspflanze:
</emphasis>
Mittel- und 
<normalizedToken id="C6EFC0E9F22BDC87B5C78F85B23332F9" originalValue="südeuropäische" pageId="null" pageNumber="288">suedeuropaeische</normalizedToken>
Gebirge mit vorgelagerten Gebieten (
<normalizedToken id="E07F07CE5FBD2F458E03D69CA123ADBF" originalValue="nordwärts" pageId="null" pageNumber="288">nordwaerts</normalizedToken>
vereinzelt bis 
<normalizedToken id="467EF94CFE5A416D368CC8EA7EE0171D" originalValue="Öland" pageId="null" pageNumber="288">Oeland</normalizedToken>
, Gotland und Litauen); Kleinasien, Kaukasus; oft mit Fichtenwaldanbau in die tieferen Lagen verschleppt. - Im Gebiet verbreitet (in den Zentral- und 
<normalizedToken id="F18381FB545B90B91A099E151A38DECE" originalValue="Südalpen" pageId="null" pageNumber="288">Suedalpen</normalizedToken>
nur zerstreut), ziemlich 
<normalizedToken id="267224CDFFB77A611B4B4802D0B9677B" originalValue="häufig" pageId="null" pageNumber="288">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
