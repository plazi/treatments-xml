Saussure, 1869
</taxonomicName>
[
<taxonomicName id="AFA64D61FFD5297973E8E33C39CCFBC4" box="[437,511,1092,1115]" class="Insecta" family="Mantidae" genus="Mantis" kingdom="Animalia" order="Mantodea" pageId="2" pageNumber="263" phylum="Arthropoda" rank="genus">
