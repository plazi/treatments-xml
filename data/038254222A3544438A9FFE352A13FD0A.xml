<taxonomicName id="4C2B9EB72A3544428B20F96C2D9AF94F" authority="(Smitt, 1868)" baseAuthorityName="Smitt" baseAuthorityYear="1868" box="[296,716,1748,1772]" class="Gymnolaemata" family="Doryporellidae" genus="Doryporella" kingdom="Animalia" order="Cheilostomatida" pageId="2" pageNumber="159" phylum="Bryozoa" rank="species" species="spathulifera">
<emphasis id="B95F39262A3544428B20F96C2D7AF94F" box="[296,556,1748,1772]" italics="true" pageId="2" pageNumber="159">Doryporella spathulifera</emphasis>
(
<bibRefCitation id="EFBA98C52A354442884AF96C2D92F94F" author="Smitt, F. A." box="[578,708,1748,1772]" pageId="2" pageNumber="159" pagination="2 - 230" refId="ref15126" refString="Smitt, F. A. (1868) Kritisk forteckning ofver Skandinaviens hafs-Bryozoer. Part 4. Ofversigt af Kongliga Vetenskaps-Akademiens Forhandlingar, 25, 2 - 230." type="journal article" year="1868">Smitt, 1868</bibRefCitation>
