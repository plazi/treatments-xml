<taxonomicName id="DE3279D882BA73762AC9F4D848C74DA8" authority="Balbis" class="Gymnolaemata" family="Cymuloporidae" genus="Crepis" kingdom="Animalia" order="Cheilostomatida" pageId="null" pageNumber="590" phylum="Bryozoa" rank="species" species="nicaeensis">
