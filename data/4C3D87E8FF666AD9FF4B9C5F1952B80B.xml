<quantity id="036C9B1BFF666AD9F71A97EC173EBAE4" box="[2278,2366,437,470]" metricMagnitude="2" metricUnit="m" metricValue="6.859999999999999" pageId="157" pageNumber="918" unit="m" value="686.0">686 m</quantity>
.
</paragraph>
</subSubSection>
