<paragraph id="21B9DBA15F4EB8BEA4BAAF19F0FD34CA" pageId="null" pageNumber="425">
<normalizedToken id="5D5D77A95EB3397F90E59B7657D4D026" originalValue="Blätter" pageId="null" pageNumber="425">Blaetter</normalizedToken>
mit 3-6 mm langen, 
<normalizedToken id="32D7B38E5A7CA0A2781F69FB9806BCE9" originalValue="kräftigen" pageId="null" pageNumber="425">kraeftigen</normalizedToken>
Stacheln. 
<emphasis id="86C9B72D8AED96BC636D9827A347B11A" italics="true" pageId="null" pageNumber="425">
<normalizedToken id="A99B0D722A1390C9DF96A730E8922BD3" originalValue="Blühende" pageId="null" pageNumber="425">Bluehende</normalizedToken>
<normalizedToken id="4B0D8F38CD5142F78339C511D56C5251" originalValue="Köpfe" pageId="null" pageNumber="425">Koepfe</normalizedToken>
5
</emphasis>
- 
<emphasis id="B8379B3BE3580BF8DEDEDFA0EE710848" italics="true" pageId="null" pageNumber="425">8 cm dick</emphasis>
, nickend oder aufrecht; 
<emphasis id="EEEFFCAC748FB85DE68FBB8142CBE807" italics="true" pageId="null" pageNumber="425">
<normalizedToken id="C4B0B45F4924B9928BD65EED1755FF39" originalValue="äußere" pageId="null" pageNumber="425">aeussere</normalizedToken>
<normalizedToken id="3A84B29C0539F08D8E0B5E90A7A13D5B" originalValue="Hüllblätter" pageId="null" pageNumber="425">Huellblaetter</normalizedToken>
mit 3
</emphasis>
- 
<emphasis id="1A76720AA0EB78407E5C6102C4235138" italics="true" pageId="null" pageNumber="425">
5 mm breitem Grund und durch eine 
<normalizedToken id="26A54E47DF34706093FB7B9EE6314AFC" originalValue="Verschmälerung" pageId="null" pageNumber="425">Verschmaelerung</normalizedToken>
abgesetztem, 5
</emphasis>
- 
<emphasis id="74F2631F0BD0A518345CE1B70B96B8AB" italics="true" pageId="null" pageNumber="425">
8 mm breitem, schmal 3eckig zugespitztem und meist 
<normalizedToken id="0DD7BB7155B614B1026ABD6E4CF51B1D" originalValue="zurückgebogenem" pageId="null" pageNumber="425">zurueckgebogenem</normalizedToken>
Endteil.
</emphasis>
- 
<normalizedToken id="8805993190CDC04BDF1CEFA7AB3481BF" originalValue="Blüte" pageId="null" pageNumber="425">Bluete</normalizedToken>
: 
<normalizedToken id="25A4AA2806DBE93084DFE2EA01A1D3B4" originalValue="Später" pageId="null" pageNumber="425">Spaeter</normalizedToken>
<normalizedToken id="EB810F4E44F3D8594EAE9322639CCD29" originalValue="Frühling" pageId="null" pageNumber="425">Fruehling</normalizedToken>
, Sommer.
</paragraph>
<paragraph id="456C36E77FCA92354AD36A896DF0FFED" pageId="null" pageNumber="425">
<emphasis id="0E92ABBD3EBB64C4F0A79A433D1F369D" italics="true" pageId="null" pageNumber="425">
<pageBreakToken id="3FA726217A731296AFD92359CB5471F3" pageId="null" pageNumber="425">Zytologische</pageBreakToken>
Angaben
</emphasis>
. Keine Untersuchungen.
</paragraph>
<paragraph id="18175D93416E794916FCDB3171BB5816" pageId="null" pageNumber="425">
<emphasis id="529E542C41DEF6857E7854AB2A7255F0" italics="true" pageId="null" pageNumber="425">Standort</emphasis>
. Kollin (in den 
<normalizedToken id="D8F817364D997AA1FC18BD79F95BE2DD" originalValue="Südwestalpen" pageId="null" pageNumber="425">Suedwestalpen</normalizedToken>
auch montan und subalpin). Warme, trockene Orte. 
<normalizedToken id="75943A900A122C6DE2C16D66936F4F56" originalValue="Wegränder" pageId="null" pageNumber="425">Wegraender</normalizedToken>
, 
<normalizedToken id="3569A6BE83A2BDC0392B1B98F573474E" originalValue="Schuttplätze" pageId="null" pageNumber="425">Schuttplaetze</normalizedToken>
, Bahnareale.
</paragraph>
<paragraph id="8768ABC4488714D7618E6C021C18B96D" pageId="null" pageNumber="425">
<emphasis id="AA24AD3D0564BA9AA3A3CD9E78F3246B" italics="true" pageId="null" pageNumber="425">
Verbreitung. 
<normalizedToken id="A3A8263E5A3592516979701810DA6423" originalValue="Südeuropäische" pageId="null" pageNumber="425">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Westalpen, Italien, Balkanhalbinsel. - Im Gebiet nur gelegentlich adventiv.
</paragraph>
