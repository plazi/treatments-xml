<subSubSection id="BC3870861F4E1B7742D5792B27A93B3F" pageId="null" pageNumber="287" type="description">
<paragraph id="98A3A7325840798B750A2A4C80A00DA0" pageId="null" pageNumber="287">
15-60 cm hoch, Rasen bildend. Stengel aufrecht. 
<normalizedToken id="53DCFC365938318CA94C6C8BD7179EC7" originalValue="Blätter" pageId="null" pageNumber="287">Blaetter</normalizedToken>
eingerollt, fast 
<normalizedToken id="23E33E136B5D8F1FCD9D858BE820F3E1" originalValue="borstenförmig" pageId="null" pageNumber="287">borstenfoermig</normalizedToken>
; 
<normalizedToken id="96242AAC26CAA5297383A87BA02AEF6D" originalValue="Blatthäutchen" pageId="null" pageNumber="287">Blatthaeutchen</normalizedToken>
ca. 3 mm lang, stumpf, zerschlitzt, am Rande herablaufend und scheinbar bis 10 mm lang. Obere 
<normalizedToken id="87A143E4F112D96D3EC51D35E16E01C2" originalValue="Hüllspelze" pageId="null" pageNumber="287">Huellspelze</normalizedToken>
7-9 mm lang, untere 1-2 mm 
<normalizedToken id="01A81D3B5BF20C9D2B1A06D0DB385114" originalValue="kürzer" pageId="null" pageNumber="287">kuerzer</normalizedToken>
. Deckspelzen 4-6 mm lang (ohne Grannen). - 
<normalizedToken id="79AECCCEFBF2150E281278170B720056" originalValue="Blüte" pageId="null" pageNumber="287">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="5E465458CBDF168469C512AC150E147B" pageId="null" pageNumber="287">
<emphasis id="6E5C091717745DC6541083E08F1D17F6" italics="true" pageId="null" pageNumber="287">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="13183BC2348BCAE8156BD070D1B30483" pageId="null" pageNumber="287">
<emphasis id="D816A3DB07AC8187DDA286C28EF72B89" italics="true" pageId="null" pageNumber="287">Standort.</emphasis>
Kollin. Trockene 
<normalizedToken id="28E15C186DE28A5E1BF99D4CB7F1CDB5" originalValue="Böden" pageId="null" pageNumber="287">Boeden</normalizedToken>
. 
<normalizedToken id="ADDB8FB22B194DEF5789F936C5F6D28B" originalValue="Äcker" pageId="null" pageNumber="287">Aecker</normalizedToken>
, lichte 
<normalizedToken id="FDEC52C9E97A542903E1577502C29912" originalValue="Wälder" pageId="null" pageNumber="287">Waelder</normalizedToken>
.
</paragraph>
<paragraph id="DDC182372B85814B2B2598E1D2AE2AE0" pageId="null" pageNumber="287">
<emphasis id="F05FF174CFDD1C62E656400255833320" italics="true" pageId="null" pageNumber="287">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="905C9F74EAFE4827636445A4EBD6FB63" originalValue="Nordwärts" pageId="null" pageNumber="287">Nordwaerts</normalizedToken>
bis ins Gebiet der Loire, Mitteldeutschland, Donaubecken, 
<normalizedToken id="8402259C48683B25A837476650025844" originalValue="Südrußland" pageId="null" pageNumber="287">Suedrussland</normalizedToken>
, 
<normalizedToken id="6223162FD9DD705758E979CAFB19E041" originalValue="südwärts" pageId="null" pageNumber="287">suedwaerts</normalizedToken>
vereinzelt bis Nordafrika, 
<normalizedToken id="C87A89D3B8C43DBE86B1B5937F62FF52" originalValue="ostwärts" pageId="null" pageNumber="287">ostwaerts</normalizedToken>
bis nach Kleinasien und in den Kaukasus. Verbreitungskarte von Meusel (1964). - Im Gebiet: 
<normalizedToken id="F7C2AE1E22E4BA8AF4696E5D5B477A0D" originalValue="Dép" pageId="null" pageNumber="287">Dep</normalizedToken>
. Ain; selten adventiv.
</paragraph>
</subSubSection>
