<subSubSection id="7CF6CE9D31E9CD6226F680C93C086B13" pageId="null" pageNumber="110" type="vernacular_names">
<paragraph id="2892A08A07EB40B8591145F91983150F" pageId="null" pageNumber="110">Sendtners Alpen-Mohn</paragraph>
</subSubSection>
</title>
<subSubSection id="5FFB6C4995C0CE21AEB3FB9FBB609835" pageId="null" pageNumber="110" type="description">
<paragraph id="4753033CDA02DC7C55641B30E45E217F" pageId="null" pageNumber="110">
<normalizedToken id="77E3756E1525987197C2F6AB847EDFF6" originalValue="Blätter" pageId="null" pageNumber="110">Blaetter</normalizedToken>
1-2fach gefiedert, 
<emphasis id="DDF05A042C5E2B6EDF50E594743F4D03" italics="true" pageId="null" pageNumber="110">beiderseits zerstreut bis dicht behaart;</emphasis>
die 
<normalizedToken id="273833BB8761257AA0EC937F1C0446C3" originalValue="späteren" pageId="null" pageNumber="110">spaeteren</normalizedToken>
<normalizedToken id="E9EB2C1CEBF97A4DB07D73048044B1EC" originalValue="Blätter" pageId="null" pageNumber="110">Blaetter</normalizedToken>
jederseits mit 3-5 Fiedern 1. Ordnung, 
<emphasis id="FF5C52477FA84E5FBFA42E08E463B928" italics="true" pageId="null" pageNumber="110">
auch die untersten mit 
<normalizedToken id="08CF847024D8F4E7BA6B4AAED73EE7DC" originalValue="höchstens" pageId="null" pageNumber="110">hoechstens</normalizedToken>
3 mm langem Stiel;
</emphasis>
Zipfel der 
<normalizedToken id="B8052D7FDE43EBEC4C51226105D74EC9" originalValue="späteren" pageId="null" pageNumber="110">spaeteren</normalizedToken>
<normalizedToken id="40870A61C0A157EC1731B6D1A1B09901" originalValue="Blätter" pageId="null" pageNumber="110">Blaetter</normalizedToken>
meist spitz, meist unsymmetrisch, 0,7-2,5 mm breit, 
<emphasis id="49B53CFE3FCA7CC30CC7E6C681AE7817" italics="true" pageId="null" pageNumber="110">meist 3-5mal so lang wie breit</emphasis>
, oft wenig nach 
<normalizedToken id="D5310CEA51C4F5BDEAF5032765A7168D" originalValue="außen" pageId="null" pageNumber="110">aussen</normalizedToken>
gebogen. 
<normalizedToken id="D022D83CF77EFB1711F4CAAAEDE84FD5" originalValue="Kronblätter" pageId="null" pageNumber="110">Kronblaetter</normalizedToken>
<normalizedToken id="7160E1273834D748CB1460EBE95F457D" originalValue="weiß" pageId="null" pageNumber="110">weiss</normalizedToken>
. 
<emphasis id="1995D73281A7CAE39DC4EBF8962A8954" italics="true" pageId="null" pageNumber="110">Narbenstrahlen meist 5</emphasis>
, weniger als ⅕ der 
<normalizedToken id="25D23545ACBA01E17FFA218A51C17C98" originalValue="Fruchtknotenlänge" pageId="null" pageNumber="110">Fruchtknotenlaenge</normalizedToken>
herablaufend. - 
<normalizedToken id="0838CFD29B12E9A78636336FFF02B481" originalValue="Blüte" pageId="null" pageNumber="110">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="059D38D37FD52B2136B738F019B72CBC" pageId="null" pageNumber="110">
<emphasis id="2A61F16E6A9CC8ADCAA869260887D0A7" italics="true" pageId="null" pageNumber="110">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="63CEBB73993663CD77433887BF4C6C64" italics="true" pageId="null" pageNumber="110">14:</emphasis>
Material vom Karwendel bei Innsbruck (
<normalizedToken id="2EC4BEFE69D87AC95053B2362D446706" originalValue="Fabergé" pageId="null" pageNumber="110">Faberge</normalizedToken>
1943).
</paragraph>
<paragraph id="F77BA2F884CA82B9747333C743A6BF81" pageId="null" pageNumber="110">
<emphasis id="19A72949F9C01EA7FB0008869A7BA61E" italics="true" pageId="null" pageNumber="110">Standort.</emphasis>
Alpin. Beweglicher Kalkschutt, Schutthalden, 
<normalizedToken id="6B4C59E09A5858B88AA73F7CDAD5B489" originalValue="Geröll" pageId="null" pageNumber="110">Geroell</normalizedToken>
. 
<emphasis id="5FFFC9F9D081AE9796ED7DB91EBE36CC" italics="true" pageId="null" pageNumber="110">Thlaspeetum rotundifolii normale</emphasis>
Jenny-Lips 1930.
</paragraph>
<paragraph id="1D7517378CB7F688022C7CA368742FD0" pageId="null" pageNumber="110">
<emphasis id="4D894088AD5B9EDF48E55A462BD8C421" italics="true" pageId="null" pageNumber="110">Verbreitung. Nordalpenpflanze:</emphasis>
Zentralschweiz bis Raxalpe (
<normalizedToken id="152820D96D978DC76A4FDFF4A61A7E26" originalValue="Niederösterreich" pageId="null" pageNumber="110">Niederoesterreich</normalizedToken>
). - Im Gebiet: Pilatus, Urner Alpen (Schwalmis bis Urirotstock), Glarner Alpen (Gebiet der Sandalp), westliches 
<normalizedToken id="5ACEF21CFF8FF38F799469AB690C6F00" originalValue="Rätikon" pageId="null" pageNumber="110">Raetikon</normalizedToken>
(Gebiet der Scesaplana).
</paragraph>
</subSubSection>
