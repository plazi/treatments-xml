(
<bibRefCitation id="17629A1DBB572C8F603595B688A50634" author="Roedl-Linder, G" journalOrPublisher="Blumea" pageId="0" pageNumber="141" pagination="351 - 364" refId="B23" refString="Roedl-Linder, G, 1994. A monograph of the fern genus Thylacopteris (Polypodiaceae). Blumea 39: 351 - 364" title="A monograph of the fern genus Thylacopteris (Polypodiaceae)." volume="39" year="1994">
<normalizedToken id="744AE42C7F8B316D7D44F57C7B42B7A0" originalValue="Rödl-Linder">Roedl-Linder</normalizedToken>
