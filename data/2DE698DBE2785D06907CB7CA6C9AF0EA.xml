<bibRefCitation id="F54D9C001C2F15A288B0F938484D5D17" author="Fraser-Jenkins, CR" journalOrPublisher="Bishen Singh Mahendra Pal Singh, Uttarakhand" pageId="0" pageNumber="141" refId="B11" refString="Fraser-Jenkins, CR, 2020. An Annotated Checklist of Indian Pteridophytes, Part 3: Lomariopsidaceae to Salviniaceae. Bishen Singh Mahendra Pal Singh, Uttarakhand" title="An Annotated Checklist of Indian Pteridophytes, Part 3: Lomariopsidaceae to Salviniaceae." year="2020">Fraser-Jenkins 2020</bibRefCitation>
