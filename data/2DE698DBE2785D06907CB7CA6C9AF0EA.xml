<taxonomicName id="F958476B1A4A4D4B14D39D76A4720C56" class="Polypodiopsida" family="Polypodiaceae" genus="Thylacopteris" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Thylacopteris" order="Polypodiales" pageId="0" pageNumber="141" phylum="Tracheophyta" rank="genus">
<emphasis id="2A4CC462E6B61D1E80E7D5B2CE027CD7" italics="true" pageId="0" pageNumber="141">Thylacopteris</emphasis>
