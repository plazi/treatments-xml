<subSubSection id="364BFD630875455EDDA7A684921E21C5" pageId="0" pageNumber="141" type="notes">
<paragraph id="CC1D7ED612B38F4B793A9FF2740D18CC" pageId="0" pageNumber="141">Notes.</paragraph>
<paragraph id="CD5BBAA83282083FE3C01B1EEADB5633" pageId="0" pageNumber="141">
The genus 
<taxonomicName id="4001A96DE827591EADD461EAA48E1DF3" class="Polypodiopsida" family="Polypodiaceae" genus="Thylacopteris" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Thylacopteris" order="Polypodiales" pageId="0" pageNumber="141" phylum="Tracheophyta" rank="genus">
<emphasis id="C17A252278260D1B6BEEFD61E48CA110" italics="true" pageId="0" pageNumber="141">Thylacopteris</emphasis>
</taxonomicName>
is sometimes confused with 
<taxonomicName id="8625E1EAF47CE62BD191110599BDBDFD" class="Polypodiopsida" family="Polypodiaceae" genus="Goniophlebium" kingdom="Plantae" lsidName="Goniophlebium" order="Polypodiales" pageId="0" pageNumber="141" phylum="Tracheophyta" rank="genus">
<emphasis id="EED7FECC789150F0E618DC1BD8F4AC2C" italics="true" pageId="0" pageNumber="141">Goniophlebium</emphasis>
</taxonomicName>
and 
<taxonomicName id="444F326844F40F59BFD631D744FDEC27" class="Polypodiopsida" family="Polypodiaceae" genus="Polypodium" kingdom="Plantae" lsidName="Polypodium" order="Polypodiales" pageId="0" pageNumber="141" phylum="Tracheophyta" rank="genus">
<emphasis id="0E0E5E6C7907B0969A0B69CC65353AE1" italics="true" pageId="0" pageNumber="141">Polypodium</emphasis>
</taxonomicName>
(
<bibRefCitation id="5B867A1085DCE48A3BC9EEDBB7CE155D" author="Roedl-Linder, G" journalOrPublisher="Blumea" pageId="0" pageNumber="141" pagination="351 - 364" refId="B23" refString="Roedl-Linder, G, 1994. A monograph of the fern genus Thylacopteris (Polypodiaceae). Blumea 39: 351 - 364" title="A monograph of the fern genus Thylacopteris (Polypodiaceae)." volume="39" year="1994">
<normalizedToken id="4E9BF42B079686D538751747A51B470B" originalValue="Rödl-Linder">Roedl-Linder</normalizedToken>
1994
</bibRefCitation>
