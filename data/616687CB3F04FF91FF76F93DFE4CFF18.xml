<bibRefCitation id="8D5E4B2C3F07FF90FCACF82CFC38F824" author="Miller, P. J." box="[845,984,1962,1989]" pageId="50" pageNumber="51" pagination="1413 - 1419" refId="ref61672" refString="Miller, P. J. (1993) A new species of Didogobius (Teleostei: Gobiidae) from the Adriatic Sea. Journal of Natural History, 26, 1413 - 1419. https: // doi. org / 10.1080 / 00222939200770791" type="journal article" year="1993">Miller 1993</bibRefCitation>
