<subSubSection id="8A6EF3E790FED5566B11823211FF84FB" pageId="null" pageNumber="479" type="description">
<paragraph id="8CFE746945B76D4E284862B8EBE2C3D3" pageId="null" pageNumber="479">
10-40 cm hoch; lockere Horste bildend (keine 
<normalizedToken id="53AF44DEB7D8E67379CA4857803F0561" originalValue="Ausläufer" pageId="null" pageNumber="479">Auslaeufer</normalizedToken>
), jedoch 
<emphasis id="80F9C55509C5A9BAF83E48821AC7F153" italics="true" pageId="null" pageNumber="479">
alle Triebe die 
<normalizedToken id="A9D829C581C85B9546736458B2282DB6" originalValue="grundständigen" pageId="null" pageNumber="479">grundstaendigen</normalizedToken>
Scheiden durchbrechend
</emphasis>
(extravaginal). 
<emphasis id="2BC694E1DFDD2952C6E5C4D6F46FF8A0" italics="true" pageId="null" pageNumber="479">
<normalizedToken id="A0D541DE0B26FA7D9A0A51FF20E32F82" originalValue="Grundständige" pageId="null" pageNumber="479">Grundstaendige</normalizedToken>
, blattlose Scheiden zahlreich, rotbraun. 
<normalizedToken id="42DE6CD86AF7E3A81ACD6CD608F746B7" originalValue="Blätter" pageId="null" pageNumber="479">Blaetter</normalizedToken>
sehr schmal
</emphasis>
(
<emphasis id="01E23BB904B9B45876140A126B1FB427" italics="true" pageId="null" pageNumber="479">weniger als 1 mm breit</emphasis>
), oft eingerollt, schlaff, den 
<normalizedToken id="AD1B83B3A51F3E02095C69E79BAE1810" originalValue="Blütenstand" pageId="null" pageNumber="479">Bluetenstand</normalizedToken>
nicht erreichend. Stengel und 
<normalizedToken id="514FE9CBF067FE4EEBA82F4D1914FF3C" originalValue="Blütenstand" pageId="null" pageNumber="479">Bluetenstand</normalizedToken>
wie bei 
<taxonomicName id="DA6186FD32972B0E6359A79D3A157245" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="479" phylum="Tracheophyta" rank="species" species="ferruginea">
<emphasis id="1941EAE92E01BAA012B5A97A9DD3A5B1" italics="true" pageId="null" pageNumber="479">C. ferruginea</emphasis>
</taxonomicName>
(Nr. 84). 
<normalizedToken id="8AAC1228F37FE7A45425904866C306F3" originalValue="Hochblätter" pageId="null" pageNumber="479">Hochblaetter</normalizedToken>
<normalizedToken id="9E5FA7A90518DB4596777FB792EF92B5" originalValue="blattähnlich" pageId="null" pageNumber="479">blattaehnlich</normalizedToken>
, 
<normalizedToken id="C9A7B2BAA11E9D7E88AD4925F512D8E2" originalValue="schmäler" pageId="null" pageNumber="479">schmaeler</normalizedToken>
als bei 
<emphasis id="637EA5A018EB270B8C2202D46B765361" italics="true" pageId="null" pageNumber="479">
<taxonomicName id="23A09ADF83BB750233109F37F2A3BC74" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="479" phylum="Tracheophyta" rank="species" species="ferruginea">
<pageBreakToken id="2133718FF36BCA3C88C098DE1B40E228" pageId="null" pageNumber="479">C</pageBreakToken>
. ferruginea
</taxonomicName>
.
</emphasis>
<normalizedToken id="590363698E02DF057FF315BD3BBA0C54" originalValue="Tragblätter" pageId="null" pageNumber="479">Tragblaetter</normalizedToken>
wie bei 
<taxonomicName id="1665A16A94509BC72B42BACD6F936B06" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="479" phylum="Tracheophyta" rank="species" species="ferruginea">
<emphasis id="153F7E286B0C1F995291C75517692B6A" italics="true" pageId="null" pageNumber="479">C. ferruginea</emphasis>
</taxonomicName>
, oft mit grannenartiger Spitze, vor der Fruchtreife abfallend. 
<normalizedToken id="D6CEAF4931423FF18FC9F54F161AC17A" originalValue="Fruchtschläuche" pageId="null" pageNumber="479">Fruchtschlaeuche</normalizedToken>
3-4mm lang, unterhalb der Mitte am breitesten (0,8-1 mm), 3kantig, mit zahlreichen deutlichen Nerven, braun, seidig 
<normalizedToken id="6E2139AD4BED62DC5C7A0AB97892AD15" originalValue="glänzend" pageId="null" pageNumber="479">glaenzend</normalizedToken>
, 
<normalizedToken id="FC6CAE3B94179182611CFDC18F2D813F" originalValue="allmählich" pageId="null" pageNumber="479">allmaehlich</normalizedToken>
in den 
<normalizedToken id="30A2776D81DDE4CCE6070C28C0B73CA8" originalValue="vollständig" pageId="null" pageNumber="479">vollstaendig</normalizedToken>
kahlen Schnabel 
<normalizedToken id="60F219FCC426FA7E7D5D2C44887212CA" originalValue="verschmälert" pageId="null" pageNumber="479">verschmaelert</normalizedToken>
. Narben 3.
</paragraph>
<paragraph id="402D754F31F7F51DDC83CC7221AD9D29" pageId="null" pageNumber="479">
<emphasis id="C41E4291E7ACA55E62E3EBFA5CD30C8F" italics="true" pageId="null" pageNumber="479">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="8D564B91AF85E015FB0836A0FB0B5A55" pageId="null" pageNumber="479">
<emphasis id="040D14C68A45AFCADA59F267B6BCAA04" italics="true" pageId="null" pageNumber="479">Standort.</emphasis>
Montan und subalpin. Ritzen und Spalten schattiger, von kalkhaltigem Wasser 
<normalizedToken id="6902002249E4056F230C3D4CD08A03EB" originalValue="überrieselter" pageId="null" pageNumber="479">ueberrieselter</normalizedToken>
Felsen (meist Kalkfelsen). 
<emphasis id="4C834093B57CC7E193014EF391BE516F" italics="true" pageId="null" pageNumber="479">Caricetum brachystachidis</emphasis>
<normalizedToken id="390B50519AFFA63839AA3093B61B0C36" originalValue="Lüdi" pageId="null" pageNumber="479">Luedi</normalizedToken>
1921.
</paragraph>
<paragraph id="E21FFE618869DCFAA636A395187D6172" pageId="null" pageNumber="479">
<emphasis id="D35091E7A35932BE1E96BDB34EECA2E1" italics="true" pageId="null" pageNumber="479">
Verbreitung. Mittel- und 
<normalizedToken id="6E8EF4353B6BCCEC371E179B1BEDBF5F" originalValue="südeuropäische" pageId="null" pageNumber="479">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
<normalizedToken id="043C4CA740AB217691CE4945BC2D2507" originalValue="Pyrenäen" pageId="null" pageNumber="479">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="F2A6FBC3BCF136E1A390D59D20EEDF4E" originalValue="zentralfranzösische" pageId="null" pageNumber="479">zentralfranzoesische</normalizedToken>
Gebirge, Alpen, Jura, Schwarzwald, Karpaten, Apennin, Gebirge der Balkanhalbinsel. - Im Gebiet: Alpen, 
<normalizedToken id="05C56D2CCC1B97EC1CF4952218B6FB8F" originalValue="nördliches" pageId="null" pageNumber="479">noerdliches</normalizedToken>
Alpenvorland, Jura, 
<normalizedToken id="C382CA5A5455DCA4FB2E259341373EF7" originalValue="Südschwarzwald" pageId="null" pageNumber="479">Suedschwarzwald</normalizedToken>
(Wehratal); zerstreut, ziemlich selten.
</paragraph>
</subSubSection>
