<figureCitation id="398E07DCBF4AFF8A1DBBFCD8990BFCE9" box="[233,317,860,887]" captionStart="FIGURE 83" captionStartId="44.[151,250,2008,2032]" captionTargetBox="[273,1315,1132,1980]" captionTargetId="figure-39@44.[267,1320,1127,1984]" captionTargetPageId="44" captionText="FIGURE 83. Map of distribution of Copelatus in China Mainland." figureDoi="http://doi.org/10.5281/zenodo.6410823" httpUri="https://zenodo.org/record/6410823/files/figure.png" pageId="23" pageNumber="274">Fig. 83</figureCitation>
