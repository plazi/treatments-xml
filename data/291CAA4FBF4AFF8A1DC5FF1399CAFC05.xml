<collectingRegion id="6371D5BBBF4AFF8A1F55FCBC9A7BFCCC" box="[519,589,824,850]" country="China" name="Hebei" pageId="23" pageNumber="274">Hebei</collectingRegion>
, 
<collectingRegion id="6371D5BBBF4AFF8A1F05FCBC9A89FCCC" box="[599,703,824,850]" country="China" name="Shanghai" pageId="23" pageNumber="274">Shanghai</collectingRegion>
