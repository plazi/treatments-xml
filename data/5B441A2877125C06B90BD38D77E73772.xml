<taxonomicName id="BF4B476BECCDBC5A9B83AAB598D86495" LSID="5B441A28-7712-5C06-B90B-D38D77E73772" authority="Baker, 1915" authorityName="Baker" authorityYear="1915" class="Insecta" family="Cicadellidae" genus="Idioscopus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Idioscopus" order="Hemiptera" pageId="0" pageNumber="97" phylum="Arthropoda" rank="genus">Idioscopus Baker, 1915</taxonomicName>
