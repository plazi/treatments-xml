<taxonomicName id="03944D7DFF2C6A93FC6992FD1DEABFF7" authority="Kaup, 1829" box="[917,1002,1188,1221]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="215" pageNumber="977" phylum="Chordata" rank="genus">Myotis</taxonomicName>
