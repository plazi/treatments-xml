<taxonomicName id="03944D7DFF2C6A93FBE492FD1AB0BFF7" authorityName="Kuhl" authorityYear="1817" box="[1048,1200,1188,1221]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="215" pageNumber="977" phylum="Chordata" rank="species" species="daubentonii">daubentonii</taxonomicName>
