<subSubSection id="8FF0518A27ABD5BF0EDCFE4FF219F4D3" pageId="null" pageNumber="785" type="description">
<paragraph id="538A0831BCDF2F4A214DF02284DDD78D" pageId="null" pageNumber="785">
Unterscheidet sich durch folgende Merkmale von 
<taxonomicName id="BC52798D4B05739E1BFF82488543F9E5" class="Magnoliopsida" family="Haloragaceae" genus="Myriophyllum" kingdom="Plantae" order="Saxifragales" pageId="null" pageNumber="785" phylum="Tracheophyta" rank="species" species="verticillatum">
<emphasis id="B9205621637ACC0E77C8563585412205" italics="true" pageId="null" pageNumber="785">M. verticillatum</emphasis>
</taxonomicName>
(Nr. 1): Pflanze selten 
<normalizedToken id="915C1CC470BE59B1D397E5B73DD7A5D7" originalValue="über" pageId="null" pageNumber="785">ueber</normalizedToken>
1 m hoch; 
<emphasis id="50E67C98D82D14A17CB430DCE6F813B5" italics="true" pageId="null" pageNumber="785">
untergetauchte Blattquirle mit meist 4 
<normalizedToken id="15C2EAC599A0F229999CE4F5236066F2" originalValue="Blättern" pageId="null" pageNumber="785">Blaettern</normalizedToken>
</emphasis>
(vereinzelt mit 3 oder 5). 
<normalizedToken id="E0FD622CC56D99D70570F2EEA68C5D5E" originalValue="Blätter" pageId="null" pageNumber="785">Blaetter</normalizedToken>
0,5-2,5 cm lang, 
<emphasis id="8F6C2569F6813D9BE1605183A41A530A" italics="true" pageId="null" pageNumber="785">
mit 8-18 
<normalizedToken id="CA3345CC3B90BD788080F60FE932A1E3" originalValue="haarförmigen" pageId="null" pageNumber="785">haarfoermigen</normalizedToken>
, 0,3-1,5 cm langen Abschnitten; 
<normalizedToken id="1242A41E7F951B6399DEE4FA39D8E2F7" originalValue="Tragblätter" pageId="null" pageNumber="785">Tragblaetter</normalizedToken>
im obern Teil des 
<normalizedToken id="85291A688F1168509BE3990B2D369777" originalValue="Blütenstandes" pageId="null" pageNumber="785">Bluetenstandes</normalizedToken>
ganzrandig, 
<normalizedToken id="9CF2800F4CDBBF9A9341E7164D3CAFC5" originalValue="kürzer" pageId="null" pageNumber="785">kuerzer</normalizedToken>
als die 
<normalizedToken id="F7F043EC865E9A3A5708F1D8AF3B1F1C" originalValue="Blüten" pageId="null" pageNumber="785">Blueten</normalizedToken>
; 
<normalizedToken id="28A16A3E1C99BF7E929AB7EF943D2AB2" originalValue="Blütenstand" pageId="null" pageNumber="785">Bluetenstand</normalizedToken>
0,5-3 cm lang, zuerst 
<normalizedToken id="A918D6A6E4445D35D58F4442E1526B58" originalValue="überhängend" pageId="null" pageNumber="785">ueberhaengend</normalizedToken>
; nicht alle 
<normalizedToken id="5094EC75B4ED5D7308D78F4F690C88EC" originalValue="Blüten" pageId="null" pageNumber="785">Blueten</normalizedToken>
in Quirlen
</emphasis>
(auch einzeln stehende vorhanden); 
<emphasis id="1531BA109BEAE47D87A5AE2B10E28F3C" italics="true" pageId="null" pageNumber="785">
<normalizedToken id="76D216260D76FD70A1DE022BD6405C14" originalValue="Kronblätter" pageId="null" pageNumber="785">Kronblaetter</normalizedToken>
gelb
</emphasis>
. - 
<normalizedToken id="ABC54FFD3B5FE0A67D2ABA8298640EA5" originalValue="Blüte" pageId="null" pageNumber="785">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="8AB056246E0AEB0720E51F4B55639082" pageId="null" pageNumber="785">
<emphasis id="38C3812B59C051BBF87BCBD139F348C8" italics="true" pageId="null" pageNumber="785">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D658824FEF86D9E23EFD34057CC9CA52" italics="true" pageId="null" pageNumber="785">14:</emphasis>
Material aus Norddeutschland (Scheerer 1939), aus 
<normalizedToken id="BF5E503415F0606095F98F737FB4D5F9" originalValue="Dänemark" pageId="null" pageNumber="785">Daenemark</normalizedToken>
(Larsen in 
<normalizedToken id="78464E100BB1C9C880D38A2C19C15A35" originalValue="Löve" pageId="null" pageNumber="785">Loeve</normalizedToken>
und Solbrig 1965a), aus Polen (Skalinska et al. 1966), aus Island (
<normalizedToken id="0B5D53EBF2E106FE9D42EA713F0D31C0" originalValue="Löve" pageId="null" pageNumber="785">Loeve</normalizedToken>
und 
<normalizedToken id="6DAFB0CF292E3728389DB018741642FB" originalValue="Löve" pageId="null" pageNumber="785">Loeve</normalizedToken>
1956b), aus 
<normalizedToken id="7DE9BA199E7893EB511C10FA9BAF4A2E" originalValue="Grönland" pageId="null" pageNumber="785">Groenland</normalizedToken>
(
<normalizedToken id="52E6FD3B508AC12629441BD8B7E708F5" originalValue="Jörgensen" pageId="null" pageNumber="785">Joergensen</normalizedToken>
et al. 1958), aus Kanada (
<normalizedToken id="DAC3B39D6FFB4D985315B98C277ECD72" originalValue="Löve" pageId="null" pageNumber="785">Loeve</normalizedToken>
1961, 
<normalizedToken id="3EB2AA7E7756AE2C7FBC3A83C2D04406" originalValue="irrtümlich" pageId="null" pageNumber="785">irrtuemlich</normalizedToken>
als 
<taxonomicName id="1AF46AEFAB1FC1CB6FD79CB7FC3C4EB8" authority="Hulten" authorityName="Hulten" class="Magnoliopsida" family="Haloragaceae" genus="Myriophyllum" kingdom="Plantae" order="Saxifragales" pageId="null" pageNumber="785" phylum="Tracheophyta" rank="species" species="exalbescens">
<emphasis id="5D9710560E5CF80217953CB7D16D2D87" italics="true" pageId="null" pageNumber="785">M. exalbescens</emphasis>
<normalizedToken id="89F4E60ED4A188D06935B284EC1C9B49" originalValue="Hultén" pageId="null" pageNumber="785">Hulten</normalizedToken>
</taxonomicName>
bezeichnet).
</paragraph>
<paragraph id="320F9710BFE3C8653FBB312DCA28A2E5" pageId="null" pageNumber="785">
<emphasis id="B23C74C7A57585B792DEDE892617D8F1" italics="true" pageId="null" pageNumber="785">Standort</emphasis>
. Kollin und montan. Stehende, kalkfreie, 
<normalizedToken id="9EC11C658B098F24746F3E7E2263560F" originalValue="nährstoffarme" pageId="null" pageNumber="785">naehrstoffarme</normalizedToken>
<normalizedToken id="DE548C6C698BEC9456D8FB98EB2146A3" originalValue="Gewässer" pageId="null" pageNumber="785">Gewaesser</normalizedToken>
<normalizedToken id="1FA48E3EA9321AC6C36C0D049AF02499" originalValue="über" pageId="null" pageNumber="785">ueber</normalizedToken>
schlammigem Grund. Strandlingsgesellschaften (
<emphasis id="335531E4D72697C4F69B7814312CB86D" italics="true" pageId="null" pageNumber="785">Litorelletalia</emphasis>
W. Koch 1926).
</paragraph>
<paragraph id="D719FC5EEA885CAACF4CB1E750E3CEAE" pageId="null" pageNumber="785">
<emphasis id="A9D6532AABC975311DF1F3ED510327A0" italics="true" pageId="null" pageNumber="785">
Verbreitung. 
<normalizedToken id="53F5A1E67693C1B3A717AC43DFB486C1" originalValue="Europäisch-nordamerikanische" pageId="null" pageNumber="785">Europaeisch-nordamerikanische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="6A58B1229BB7149E1C7D913C1BF2F04C" originalValue="Nordwärts" pageId="null" pageNumber="785">Nordwaerts</normalizedToken>
bis Island, Nordkap; 
<normalizedToken id="3589A7CD1DE04878E706C57D91B41308" originalValue="ostwärts" pageId="null" pageNumber="785">ostwaerts</normalizedToken>
bis Finnland, Polen, 
<normalizedToken id="52223AE261039FFCDAFCE889F64D94F5" originalValue="Rumänien" pageId="null" pageNumber="785">Rumaenien</normalizedToken>
; 
<normalizedToken id="128EA12CA9C2BDF1D784E5B1DBD779AF" originalValue="südwärts" pageId="null" pageNumber="785">suedwaerts</normalizedToken>
bis Nordwestafrika, Sizilien, 
<normalizedToken id="A58CFB51F73FC6B5E13DD1ACD3C1218E" originalValue="Südostalpen" pageId="null" pageNumber="785">Suedostalpen</normalizedToken>
, Karpaten; Alaska, arktisches und 
<normalizedToken id="481A0278D720C9AF7F5A2D53A1DA70DE" originalValue="östliches" pageId="null" pageNumber="785">oestliches</normalizedToken>
Nordamerika (35-50° NB); 
<normalizedToken id="34C5FA3550AF650C01C4725A327D86BE" originalValue="Grönland" pageId="null" pageNumber="785">Groenland</normalizedToken>
. Verbreitungskarte von 
<normalizedToken id="9571149CE95FB296DE0CE4E4FFAA0B77" originalValue="Hultén" pageId="null" pageNumber="785">Hulten</normalizedToken>
(1958). - Im Gebiet: Gegend von Belfort, Seen der Hochvogesen, Oberrheinische Tiefebene, Schwarzwald (Feldsee, Titisee, 
<normalizedToken id="780CB19B1221F072802C435572308660" originalValue="Schlüchtsee" pageId="null" pageNumber="785">Schluechtsee</normalizedToken>
, Tiengen bei Waldshut), 
<normalizedToken id="A9E024FB02580519C37813D295385B9E" originalValue="südliches" pageId="null" pageNumber="785">suedliches</normalizedToken>
Tessin (Magadinoebene, Langensee, Luganersee), 
<normalizedToken id="6858F8AE224CF1E8C731FD3723DA0A50" originalValue="dürfte" pageId="null" pageNumber="785">duerfte</normalizedToken>
am 
<normalizedToken id="097CF34EAC6B83FFF999CF8291870404" originalValue="Alpensüdfuß" pageId="null" pageNumber="785">Alpensuedfuss</normalizedToken>
weiter verbreitet sein.
</paragraph>
</subSubSection>
