<emphasis id="B926D14F0974B22AEE73FC2B22DB4E38" box="[625,720,1015,1041]" italics="true" pageId="32" pageNumber="483">favonius</emphasis>
= gentle, 
<emphasis id="B926D14F0974B22AEF3AFC2B23B84E38" box="[824,947,1015,1041]" italics="true" pageId="32" pageNumber="483">favonianus</emphasis>
