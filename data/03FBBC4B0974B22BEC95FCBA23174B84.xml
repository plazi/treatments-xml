<emphasis id="B926D14F0974B22AECC5FC2B21594E38" bold="true" box="[199,338,1015,1041]" pageId="32" pageNumber="483">Etymology:</emphasis>
<taxonomicName id="4C5276DE0974B22AED5AFC2B21F94E38" authorityName="Whitley" authorityYear="1930" box="[344,498,1015,1041]" class="Actinopterygii" family="Gobiidae" genus="Favonigobius" kingdom="Animalia" order="Perciformes" pageId="32" pageNumber="483" phylum="Chordata" rank="genus">
<emphasis id="B926D14F0974B22AED5AFC2B21F94E38" box="[344,498,1015,1041]" italics="true" pageId="32" pageNumber="483">Favonigobius</emphasis>
</taxonomicName>
