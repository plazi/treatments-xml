<subSubSection id="4E6A260645330ED1DDD4FABF825FF9AA" pageId="null" pageNumber="590" type="nomenclature">
<paragraph id="EABE422AD1B37CC84ED121A970ABA9B1" pageId="null" pageNumber="590">
<taxonomicName id="3935B6A4CE941437197C4FC9A5B5749C" authority="Ramond" class="Magnoliopsida" family="Asteraceae" genus="Scorzonera" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="aristata">
<pageBreakToken id="E8318A3804BF8ABF37A75DDAC3BAA44E" pageId="null" pageNumber="590">Scorzonera</pageBreakToken>
<normalizedToken id="6D3ACC1B0629E03A7E20163A574FAD67" originalValue="aristáta" pageId="null" pageNumber="590">aristata</normalizedToken>
Ramond
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="EEB6DF57D2973D04F6C0101FF2316375" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="1C0780A3A64E20974E04877271933A42" pageId="null" pageNumber="590">Grannen-Schwarzwurzel</paragraph>
</subSubSection>
</title>
<subSubSection id="4440649D7804B6293D1FCB52CEAED31B" pageId="null" pageNumber="590" type="description">
<paragraph id="16E666865883693268715B7919BD5D0E" pageId="null" pageNumber="590">
Ausdauernd; 10-40 cm hoch; am Grunde mit einzelnen schwarzen Blattschuppen, ohne Fasern 
<normalizedToken id="BD5B61DAFBAF602461BAD31468B35F88" originalValue="vorjähriger" pageId="null" pageNumber="590">vorjaehriger</normalizedToken>
<normalizedToken id="66DDFB6D2FF157AD5C9B4DC3944C5ED5" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
. Stengel aufrecht, 
<emphasis id="F44DD0F5EE4A7547AB1A09C597546A57" italics="true" pageId="null" pageNumber="590">
blattlos. 
<normalizedToken id="2C21C00CFA710C024743A89D45370C90" originalValue="Grundständige" pageId="null" pageNumber="590">Grundstaendige</normalizedToken>
<normalizedToken id="C227382DBFCCFABA863295A2D63F453F" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
grasartig.
</emphasis>
<normalizedToken id="8A0BD53135333F278FFFC84679072E32" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
2-2,5 cm lang. 
<normalizedToken id="5EC8D23C16BA95825F6C4E11B218AB9B" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
auf der Innenseite kahl; 
<emphasis id="A46C3F3DB1F980ACDB46C69DD3B210F0" italics="true" pageId="null" pageNumber="590">
die 
<normalizedToken id="CCD9455BD68EE30412E342014127F3BB" originalValue="äußern" pageId="null" pageNumber="590">aeussern</normalizedToken>
mindestens halb so lang wie die innern.
</emphasis>
Kronen 2,5-3,5 cm lang, hellgelb. 
<emphasis id="F36B30FA39DB6467C623C081825E7DD5" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="76B96A30C2283E0C28DBE87A655B70F6" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
7
</emphasis>
- 
<emphasis id="72C5FED8BAB1A91D40A465CD8CE5B595" italics="true" pageId="null" pageNumber="590">
9 mm lang, kahl, gerippt, auf den Rippen 
<normalizedToken id="215DE39AE75B195F5360CC4ED49FBF7E" originalValue="höckerig" pageId="null" pageNumber="590">hoeckerig</normalizedToken>
.
</emphasis>
<taxonomicName id="71899B90CBFEA1349BF8C4F8E43A4AA5" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
<normalizedToken id="9A2A8868408A58CCE226C3E82489F301" originalValue="gelblichweiß" pageId="null" pageNumber="590">gelblichweiss</normalizedToken>
, 
<emphasis id="074CBF28987C6662A149835F0AA1F29A" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="C4B8DFEE395A51BE2198064C5655E0FE" originalValue="länger" pageId="null" pageNumber="590">laenger</normalizedToken>
als die Frucht, am Grunde kahl.
</emphasis>
- 
<normalizedToken id="73C8195C7938A16B463BF32B72AFA7C7" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="ED94328003765C59DA13AE2AA037FFF2" pageId="null" pageNumber="590">
<emphasis id="EDF4306BCF3FEED6D432B7E2F22EB425" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="86EFEED0E86D1E1564647C2571089434" italics="true" pageId="null" pageNumber="590">14:</emphasis>
Material von der Grigna (Favarger 1965).
</paragraph>
<paragraph id="A791CD49E8E629B1973AEA9AE5CE7E75" pageId="null" pageNumber="590">
<emphasis id="B44565340599F6E30870E935EB3A23AB" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Montan und subalpin. Kalkhaltige, 
<normalizedToken id="0A281633FF9D255569B3EEC9E2A532B4" originalValue="nährstoffreiche" pageId="null" pageNumber="590">naehrstoffreiche</normalizedToken>
<normalizedToken id="49F519CA1F2939D09B11DA2E542A6930" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
. Fettwiesen.
</paragraph>
<paragraph id="727CB8A89B609F29B1A268C9128B9EC7" pageId="null" pageNumber="590">
<emphasis id="25CD2E8677301A2D9029856E34C240CD" italics="true" pageId="null" pageNumber="590">
Verbreitung. Mittel- und 
<normalizedToken id="EF75C3C5E8B37171A4C406EA9846DC72" originalValue="südeuropäische" pageId="null" pageNumber="590">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="058FA61ED5D47642F5E95BA9287045AB" italics="true" pageId="null" pageNumber="590">westlich</emphasis>
)
<emphasis id="C978140CCE36501FE8470E40988CA18D" italics="true" pageId="null" pageNumber="590">:</emphasis>
<normalizedToken id="406480DE2F87E8790E4904E297731ACE" originalValue="Pyrenäen" pageId="null" pageNumber="590">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="D7377180CECF98A1E147DBFFC4D64F87" originalValue="Südostalpen" pageId="null" pageNumber="590">Suedostalpen</normalizedToken>
(Lombardei bis Krain), Seealpen, Nordapennin (
<normalizedToken id="0845F463965DC8197BBAC282D9769797" originalValue="südwärts" pageId="null" pageNumber="590">suedwaerts</normalizedToken>
bis Toskana). - Im Gebiet: Comerseegebiet (Corni di Canzo, Grigna), Bergamasker Alpen (Monte Campione), Vintschgau (Zielalpe bei Meran).
</paragraph>
<paragraph id="E4F5C1340564FDBF4AEECC8C85091B1F" pageId="null" pageNumber="590">
<emphasis id="185A3F2E636E027D3606C7917D845103" italics="true" pageId="null" pageNumber="590">Bemerkungen.</emphasis>
Die Verbreitung von 
<taxonomicName id="B33FEB38C72C1873E757392A1CF6E56D" class="Magnoliopsida" family="Asteraceae" genus="Scorzonera" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="aristata">
<emphasis id="F549D92BC554F5D0BC675819B45038B4" italics="true" pageId="null" pageNumber="590">S. aristata</emphasis>
</taxonomicName>
ist nur 
<normalizedToken id="521355E7B99126C760197D466AA59F2B" originalValue="ungenügend" pageId="null" pageNumber="590">ungenuegend</normalizedToken>
bekannt. Es ist zu untersuchen, ob die 
<normalizedToken id="247C021020B4B65339CFC0A919D04AB9" originalValue="pyrenäischen" pageId="null" pageNumber="590">pyrenaeischen</normalizedToken>
Pflanzen mit den alpinen 
<normalizedToken id="DD8217A068AA81BFAB8E34761A814F3E" originalValue="übereinstimmen" pageId="null" pageNumber="590">uebereinstimmen</normalizedToken>
.
</paragraph>
</subSubSection>
