<subSubSection id="62ECB5120C282F68CAACCEDE7A4B7041" pageId="null" pageNumber="177" type="description">
<paragraph id="7237A68A124FB6EB25CCCC50A290D8E5" pageId="null" pageNumber="177">
<emphasis id="7770CAE3081C59A79E00C11A960BF59F" italics="true" pageId="null" pageNumber="177">
Behaarung gelblich bis rostbraun. 
<normalizedToken id="28164779ADD4D4D95BA177C9CB98E184" originalValue="Grundständige" pageId="null" pageNumber="177">Grundstaendige</normalizedToken>
<normalizedToken id="4331AF8B20539C8D2910E6461D0032C6" originalValue="Blätter" pageId="null" pageNumber="177">Blaetter</normalizedToken>
lang gestielt
</emphasis>
, breit lanzettlich, 
<emphasis id="919DA97B9A072C7D18FBDEBAAF347F6A" italics="true" pageId="null" pageNumber="177">2</emphasis>
- 
<emphasis id="0FC3D413CF68FC8365A74D8058D2782D" italics="true" pageId="null" pageNumber="177">4mal so lang wie breit</emphasis>
(oline Stiel), untere 
<normalizedToken id="ABB2AD76E4D9D80178C6FDED2A919E41" originalValue="Stengelblätter" pageId="null" pageNumber="177">Stengelblaetter</normalizedToken>
gestielt, 
<emphasis id="B5C80F9E012913FEB2A795EFD663D8A7" italics="true" pageId="null" pageNumber="177">die obern sitzend, am Stengel nicht oder nur wenig herablaufend</emphasis>
(
<emphasis id="FD46B08CED3F23E8D6C1B6C5B36B363F" italics="true" pageId="null" pageNumber="177">
nicht bis zum 
<normalizedToken id="9589F68806975922FAEEF74D0627F9D7" originalValue="nächst" pageId="null" pageNumber="177">naechst</normalizedToken>
untern Blatt
</emphasis>
), nur undeutlich 
<normalizedToken id="6BC95B14079B2DDE75D8BAB60562A5D9" originalValue="gezähnt" pageId="null" pageNumber="177">gezaehnt</normalizedToken>
oder fast ganzrandig. Krone 1,5-3 cm im Durchmesser, mit 
<normalizedToken id="28858978CE0157EE9065BC8ECDC31D5D" originalValue="länglichen" pageId="null" pageNumber="177">laenglichen</normalizedToken>
Abschnitten (
<emphasis id="53135FFC54BC047CAD2F8968172718B5" italics="true" pageId="null" pageNumber="177">
<normalizedToken id="50EFFD4B8C2709E6304A01B408031BCE" originalValue="länger" pageId="null" pageNumber="177">laenger</normalizedToken>
als die 
<normalizedToken id="A5BE0D839872911DB0E67270F481D4E3" originalValue="Kronröhre" pageId="null" pageNumber="177">Kronroehre</normalizedToken>
</emphasis>
). 
<emphasis id="CC279CEB437EB44BE5A4C5C330274A70" italics="true" pageId="null" pageNumber="177">
<normalizedToken id="1AF4D0641CB5D4AE4B88CBC15A1E875B" originalValue="Staubfäden" pageId="null" pageNumber="177">Staubfaeden</normalizedToken>
der 2 
<normalizedToken id="6D200601D67FF5CBBEF7A1D7B57F84BA" originalValue="längeren" pageId="null" pageNumber="177">laengeren</normalizedToken>
<normalizedToken id="AEB60A5BEE6340881D34CDAB3039E8BC" originalValue="Staubblätter" pageId="null" pageNumber="177">Staubblaetter</normalizedToken>
nur im obern Teil kahl
</emphasis>
, sonst 
<normalizedToken id="03C04194920AECBC8C26B661B463D290" originalValue="weiß" pageId="null" pageNumber="177">weiss</normalizedToken>
und wollig behaart. Sonst wie 
<taxonomicName id="F990DD15008E344A357FC59441215351" class="Magnoliopsida" family="Scrophulariaceae" genus="Verbascum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="177" phylum="Tracheophyta" rank="species" species="thapsus">
<emphasis id="163079855CE79EDA19859F8711726452" italics="true" pageId="null" pageNumber="177">V. Thapsus</emphasis>
</taxonomicName>
(Nr.3a). - 
<normalizedToken id="24C5CA7E035EE9BA1CFF9041C87D2359" originalValue="Blüte" pageId="null" pageNumber="177">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="D1224BF7F94C0B899D2681A83435DD9F" originalValue="früher" pageId="null" pageNumber="177">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="7FEF4B7AFB8F57A8A38E8CD0B87BFA97" pageId="null" pageNumber="177">
<emphasis id="D409FD900586919A4B5A7F05DE0827EA" italics="true" pageId="null" pageNumber="177">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="FD12BDFAE776D4D308487953D1C3401C" italics="true" pageId="null" pageNumber="177">32:</emphasis>
Material aus der Schweiz (Schmid 1906).
</paragraph>
<paragraph id="BE480BA8A8A79194475D278CDA5E45C7" pageId="null" pageNumber="177">
<emphasis id="18234B7DFEA483D95034EA0EEB487563" italics="true" pageId="null" pageNumber="177">Standort.</emphasis>
Montan und subalpin. Lockere, steinige 
<normalizedToken id="A252DF57185975826544B3C9855CE007" originalValue="Böden" pageId="null" pageNumber="177">Boeden</normalizedToken>
in 
<normalizedToken id="EF06A8EC5919D125E0A44C5406E339A3" originalValue="wärmeren" pageId="null" pageNumber="177">waermeren</normalizedToken>
Lagen. Sonnige 
<normalizedToken id="C3BFA26864B2874672101BF865BD858D" originalValue="Felshänge" pageId="null" pageNumber="177">Felshaenge</normalizedToken>
, 
<normalizedToken id="8EF7D0E60B0F8BDFB248A6140FCF1470" originalValue="Gebüsche" pageId="null" pageNumber="177">Gebuesche</normalizedToken>
. 
<emphasis id="45587730372E3E6CF7015C3F5716D6F1" italics="true" pageId="null" pageNumber="177">Galiopsido-Rumicetum</emphasis>
Br.-Bl. 1948.
</paragraph>
<paragraph id="BC731961025062EAB1FC83005FEC609A" pageId="null" pageNumber="177">
<emphasis id="AC11944971B0EE85AD15770B016616E0" italics="true" pageId="null" pageNumber="177">Verbreitung. Westalpin-apenninische Pflanze:</emphasis>
Alpen (
<normalizedToken id="BA9045BE322ACED9243EC05968DEF051" originalValue="ostwärts" pageId="null" pageNumber="177">ostwaerts</normalizedToken>
bis ins Tirol), 
<normalizedToken id="5BFC0531DA9EFF0515C4068C9AFFD844" originalValue="südlicher" pageId="null" pageNumber="177">suedlicher</normalizedToken>
Jura, Apuanische Alpen, mittlerer Apennin. - Im Gebiet: Alpen und 
<normalizedToken id="D6C27636DAF3B1F5206128661DFE438F" originalValue="südlicher" pageId="null" pageNumber="177">suedlicher</normalizedToken>
Jura; nicht 
<normalizedToken id="742E10CF430D15A3EDE36E5E31C0C32D" originalValue="häufig" pageId="null" pageNumber="177">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
