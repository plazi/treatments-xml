<subSubSection id="1491992A0AF9BE7261645DCF022F5D0D" pageId="null" pageNumber="203" type="description">
<paragraph id="9DD490E4ED23374033A7ED671D495E17" pageId="null" pageNumber="203">
Unterscheidet sich von 
<taxonomicName id="2E181973220E55F7BB72A254F8C1AB46" class="Liliopsida" family="Potamogetonaceae" genus="Potamogeton" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="203" phylum="Tracheophyta" rank="species" species="compressus">
<emphasis id="015D5BD7DFE1B3556DB2F4F57549A6F1" italics="true" pageId="null" pageNumber="203">P. compressus</emphasis>
</taxonomicName>
(Nr. 12) durch folgende Merkmale: 
<emphasis id="2FB6DCC17B73A5D412325085F3C16DA9" italics="true" pageId="null" pageNumber="203">
Stengel 2kantig, die Kanten jedoch nicht 
<normalizedToken id="B01488D567BA38589361C5BF12D4E49C" originalValue="geflügelt" pageId="null" pageNumber="203">gefluegelt</normalizedToken>
; Stiele der 
<normalizedToken id="8BD56459C6E41D28B71E07B697BE06BD" originalValue="Blütenstände" pageId="null" pageNumber="203">Bluetenstaende</normalizedToken>
nur 0,5-1,5 cm lang, nicht oder nur wenig 
<normalizedToken id="CB792F68A480381E25A5B420576E88A9" originalValue="länger" pageId="null" pageNumber="203">laenger</normalizedToken>
als der 3-6 
<normalizedToken id="8830920DA5820741FADC0E8DBE421BB9" originalValue="blütige" pageId="null" pageNumber="203">bluetige</normalizedToken>
<normalizedToken id="992CADED180425469D8A0458460D90B3" originalValue="Blütenstand" pageId="null" pageNumber="203">Bluetenstand</normalizedToken>
</emphasis>
. - 
<normalizedToken id="86D4455CD2235D98BF4B854AC333DB0C" originalValue="Blüte" pageId="null" pageNumber="203">Bluete</normalizedToken>
: 
<normalizedToken id="C95202033C474DE5373EFB3BF2FE7DAD" originalValue="Früher" pageId="null" pageNumber="203">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="DB1BC77938B55D5EE0C2F12B1E7E3AAE" pageId="null" pageNumber="203">
<emphasis id="5362686A574AE623C6C8C893F69AF775" italics="true" pageId="null" pageNumber="203">
<pageBreakToken id="0F998739E9B0C97EAB81B1FC071AA731" pageId="null" pageNumber="203">Zytologische</pageBreakToken>
Angaben. 2n = 26:
</emphasis>
Material aus Skandinavien (
<normalizedToken id="6E71E539196D4BEF6B78FC153FD8B5A3" originalValue="Löve" pageId="null" pageNumber="203">Loeve</normalizedToken>
und 
<normalizedToken id="C1FFE5DE16A30230D25A32C61C60DC99" originalValue="Löve" pageId="null" pageNumber="203">Loeve</normalizedToken>
1942b).
</paragraph>
<paragraph id="69ED9587D361CCAB3702760CE3AA86A7" pageId="null" pageNumber="203">
<emphasis id="79EC15CC84D15B099B86E6A052B7E1F4" italics="true" pageId="null" pageNumber="203">Standort.</emphasis>
Kollin. Stehende oder langsam 
<normalizedToken id="6BC7EB6950B375DE1D560499C6368E24" originalValue="fließende" pageId="null" pageNumber="203">fliessende</normalizedToken>
<normalizedToken id="1FBD4C2322E3588F38B962ABA08E60BD" originalValue="Gewässer" pageId="null" pageNumber="203">Gewaesser</normalizedToken>
.
</paragraph>
<paragraph id="591E355FA3E5B9F2C2281EA03AD9138F" pageId="null" pageNumber="203">
<emphasis id="F842C634AEADBE557F61262D28B6D0F9" italics="true" pageId="null" pageNumber="203">
Verbreitung. 
<normalizedToken id="6E5012227120F1E5F9296D53F8097A15" originalValue="Europäische" pageId="null" pageNumber="203">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="4A7763E398089696761DE1D0DF023323" originalValue="Nordwärts" pageId="null" pageNumber="203">Nordwaerts</normalizedToken>
bis England, 
<normalizedToken id="4B8BB1D1847505140DFE1568FC043AC3" originalValue="Südskandinavien" pageId="null" pageNumber="203">Suedskandinavien</normalizedToken>
, 
<normalizedToken id="1425D7ED8DC19C5A6C674F06E44650D1" originalValue="ostwärts" pageId="null" pageNumber="203">ostwaerts</normalizedToken>
bis zum Ural, 
<normalizedToken id="7AC5058AC0B8BFF628DBF0EE3F52F9F2" originalValue="südwärts" pageId="null" pageNumber="203">suedwaerts</normalizedToken>
bis 
<normalizedToken id="727DAF0B6198B1189176E89316A4BD28" originalValue="Südfrankreich" pageId="null" pageNumber="203">Suedfrankreich</normalizedToken>
, Norditalien, Donaugebiet. - Im Gebiet: Savoyen, 
<normalizedToken id="B4363E5FB3E9A2E964E42AC4522310FB" originalValue="Dép" pageId="null" pageNumber="203">Dep</normalizedToken>
. Jura (Bresse und am Doubs), Bonfol, Gebiet von Belfort, 
<normalizedToken id="A3A2AEFE305B46E13F48153893300E0C" originalValue="Elsaß" pageId="null" pageNumber="203">Elsass</normalizedToken>
, Bodenseegebiet, (Lindau? Baar?), 
<normalizedToken id="663E3CB75E3731FA6D35ECBB41792525" originalValue="Zürich" pageId="null" pageNumber="203">Zuerich</normalizedToken>
(Seen von Ossingen und Andelfingen; 
<normalizedToken id="C6304E7FFB0AE80E6EF2958125E40714" originalValue="Allgäu" pageId="null" pageNumber="203">Allgaeu</normalizedToken>
(Hammerweiher bei Wangen?); Seen von Varese, sehr selten.
</paragraph>
</subSubSection>
