<taxonomicName id="56EB4D5CFFB0BA1CB002FB88B69FF2C7" baseAuthorityName="Wagner" baseAuthorityYear="1843" box="[1040,1209,3304,3337]" class="Mammalia" family="Molossidae" genus="Eumops" kingdom="Animalia" order="Chiroptera" pageId="12" pageNumber="631" phylum="Chordata" rank="species" species="glaucinus">E. glaucinus</taxonomicName>
