C o m m e n t: 
<taxonomicName id="4C6500B7C21E2812FEA1BDD27C5765E9" baseAuthorityName="MOTSCHULSKY" baseAuthorityYear="1858" box="[358,569,1208,1229]" class="Magnoliopsida" family="Acanthaceae" genus="Sclerochiton" kingdom="Plantae" order="Lamiales" pageId="1" pageNumber="1198" phylum="Tracheophyta" rank="species" species="indicus">
