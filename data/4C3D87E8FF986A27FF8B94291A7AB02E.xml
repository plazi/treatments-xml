, from 
<collectingRegion id="0650F81CFF986A27FD2592AE1D79BE2A" box="[729,889,1271,1304]" country="Mexico" name="Tamaulipas" pageId="99" pageNumber="857">Tamaulipas</collectingRegion>
S to C 
<collectingRegion id="0650F81CFF986A27FC2792AE1A4ABE2A" box="[987,1098,1271,1304]" country="Mexico" name="Tabasco" pageId="99" pageNumber="857">Tabasco</collectingRegion>
and N 
<collectingRegion id="0650F81CFF986A27FB4D92AE1B22BE2A" box="[1201,1314,1271,1304]" country="Mexico" name="Chiapas" pageId="99" pageNumber="857">Chiapas</collectingRegion>
