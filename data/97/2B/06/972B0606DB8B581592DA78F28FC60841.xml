, 
<geoCoordinate degrees="101" direction="east" minutes="22" orientation="longitude" precision="1" seconds="20.02" value="101.37223">101°22'20.02&quot;E</geoCoordinate>
, on spider (Non-web builder, 
<taxonomicName authorityName="Mongkolsamrit, Noisripoom &amp; Tasanathai" authorityYear="2022" class="Arachnida" family="Cordycipitaceae" genus="Jenniferia" kingdom="Fungi" lsidName="" order="Araneae" pageId="0" pageNumber="113" rank="order">Araneae</taxonomicName>
