<normalizedToken id="690E8749C3EA30BA30E9141ED6465C7F" originalValue="vorjähriger" pageId="null" pageNumber="754">vorjaehriger</normalizedToken>
(abgefallener) 
<normalizedToken id="498740ABC6172B3C436B1A2AB27EC984" originalValue="Blätter" pageId="null" pageNumber="754">Blaetter</normalizedToken>
