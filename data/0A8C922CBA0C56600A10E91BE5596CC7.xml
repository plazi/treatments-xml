<subSubSection id="A78B0FC69C71B2DFAB68396547FB2241" pageId="null" pageNumber="557" type="description">
<paragraph id="467CE88C1CCDCAF536A2559A6920A164" pageId="null" pageNumber="557">
Unterscheidet sich durch folgende Merkmale von 
<taxonomicName id="5A62AAC91AFEABF16D5D4C20A34008CD" class="Liliopsida" family="Asparagaceae" genus="Ornithogalum" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="557" phylum="Tracheophyta" rank="species" species="nutans">
<emphasis id="D510F77F1723A59F4D4FBAA8D92DE452" italics="true" pageId="null" pageNumber="557">O. nutans</emphasis>
</taxonomicName>
(Nr. 3): 
<emphasis id="95D19407D5ED619DE931CDB284E6EBAB" italics="true" pageId="null" pageNumber="557">
<normalizedToken id="DCE79B1CCF7975EBA05B772FBF258294" originalValue="Blätter" pageId="null" pageNumber="557">Blaetter</normalizedToken>
zur 
<normalizedToken id="6A841485384F5F5538E52A3EF7708105" originalValue="Blütezeit" pageId="null" pageNumber="557">Bluetezeit</normalizedToken>
abgestorben; Leiste auf der Innenseite der 
<normalizedToken id="FB0AEFFBC182D63D82C400D80F40AB11" originalValue="Staubblätter" pageId="null" pageNumber="557">Staubblaetter</normalizedToken>
unterhalb der Staubbeutel einen Zahn bildend. -
</emphasis>
<normalizedToken id="65DD924212348C60B1BA46768419E03E" originalValue="Blüte" pageId="null" pageNumber="557">Bluete</normalizedToken>
: 
<normalizedToken id="5F115D7C49F2C6A7CB1E00D535B67268" originalValue="Frühling" pageId="null" pageNumber="557">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="BFC0E031909FF2135BC6367D1E98447D" pageId="null" pageNumber="557">
<emphasis id="43CDA09AD5EC474F29A060B3069249B4" italics="true" pageId="null" pageNumber="557">Zytologische Angaben. 2n = 28:</emphasis>
Material aus botanischem Garten (Holzer 1952).
</paragraph>
<paragraph id="DF5ECC1F6798CC95BBC0ACE7D03DBDF5" pageId="null" pageNumber="557">
<emphasis id="29676D21F2F189CC62EC6FD58352F89F" italics="true" pageId="null" pageNumber="557">Standort.</emphasis>
Kollin. 
<normalizedToken id="DBEC2B77DB4C8F24E3FB72E69F600AF3" originalValue="Äcker" pageId="null" pageNumber="557">Aecker</normalizedToken>
, Weinberge, 
<normalizedToken id="15F606438C73829104819289936273AC" originalValue="Gebüsch" pageId="null" pageNumber="557">Gebuesch</normalizedToken>
; gelegentlich in 
<normalizedToken id="DE4FE7F29543C4E0019E7A90702011B1" originalValue="Gärten" pageId="null" pageNumber="557">Gaerten</normalizedToken>
kultiviert.
</paragraph>
<paragraph id="61826F9CE3F0E35767F02BC70C6927D0" pageId="null" pageNumber="557">
<emphasis id="88BECD1F72ACF714DB035C54DB80B3F1" italics="true" pageId="null" pageNumber="557">
Verbreitung. 
<normalizedToken id="D284178C10A8C79019B4B296A7699447" originalValue="Südosteuropäische" pageId="null" pageNumber="557">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="C95917DDB8B5020EF45A508E39CDF54F" originalValue="Westwärts" pageId="null" pageNumber="557">Westwaerts</normalizedToken>
bis Vintschgau, 
<normalizedToken id="0FD21C0013E49BD4F8CA240FBFB54BB3" originalValue="nordwärts" pageId="null" pageNumber="557">nordwaerts</normalizedToken>
bis Wiener Becken, 
<normalizedToken id="BCB108AD5C04816E4F6EF63A5D5CAD66" originalValue="südostwärts" pageId="null" pageNumber="557">suedostwaerts</normalizedToken>
bis Kleinasien (
<normalizedToken id="AD018A9ACED30961A3FD4307F8BAB57F" originalValue="außerhalb" pageId="null" pageNumber="557">ausserhalb</normalizedToken>
dieses Gebiets gelegentlich verwilderte Gartenpflanze). - Im Gebiet einzig im Vintschgau 
<normalizedToken id="8546F9F348393D07FBAE77D7BAA43EB4" originalValue="ursprünglich" pageId="null" pageNumber="557">urspruenglich</normalizedToken>
(mehrfache Angaben); sonst selten verwildert.
</paragraph>
</subSubSection>
