(1995), Barquez &amp; Diaz (
<quantity id="036C9B1BFF516AEEF7689A3316D5B7B1" box="[2196,2261,3178,3203]" metricMagnitude="0" metricUnit="kg" metricValue="2.016" pageId="170" pageNumber="932" unit="g" value="2016.0">2016g</quantity>
