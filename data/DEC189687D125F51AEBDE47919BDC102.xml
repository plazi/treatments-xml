<subSubSection id="6BFB8B249932A082CCB8CC703AD24CC5" pageId="null" pageNumber="387" type="description">
<paragraph id="8CF2177E6EEB121742F717B9415FA874" pageId="null" pageNumber="387">
Unterscheidet sich von der Gattung 
<taxonomicName id="B191C75DCAE5A78BD9F12A416883525E" class="Liliopsida" family="Poaceae" genus="Hordeum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="387" phylum="Tracheophyta" rank="genus">
<emphasis id="99F992F2AFFFD6630E91879E9FD2D08D" italics="true" pageId="null" pageNumber="387">Hordeum</emphasis>
</taxonomicName>
(S. 383) durch folgende Merkmale: Stets ausdauernd; 
<normalizedToken id="5AF7FE4BBC26271CA3BE5D7F4D2793BF" originalValue="Ährchen" pageId="null" pageNumber="387">Aehrchen</normalizedToken>
1- oder 
<normalizedToken id="DA82528833589B41B4D95EC7C53F2E7D" originalValue="mehrblütig" pageId="null" pageNumber="387">mehrbluetig</normalizedToken>
, alle 
<normalizedToken id="D96DDC62BC91183AE877EE9248967D09" originalValue="Ährchen" pageId="null" pageNumber="387">Aehrchen</normalizedToken>
<emphasis id="B42D44C025A0A12061E017F2EF1B7DB4" italics="true" pageId="null" pageNumber="387">
zwitterig und fertil oder das mittlere der 3 benachbarten 
<normalizedToken id="97E04A32680F4661971BE54AE69C396A" originalValue="Ährchen" pageId="null" pageNumber="387">Aehrchen</normalizedToken>
steril
</emphasis>
, sitzend, und 2 oder 3 beisammen. 
<emphasis id="A4015C6C76B61620609448A748F9848D" italics="true" pageId="null" pageNumber="387">
<normalizedToken id="5476DD31108C047C6EA7EC8398849068" originalValue="Hüllspelzen" pageId="null" pageNumber="387">Huellspelzen</normalizedToken>
</emphasis>
(die wie bei 
<taxonomicName id="9AD41447F2D4B737D090F2C2A21D3DD5" class="Liliopsida" family="Poaceae" genus="Hordeum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="387" phylum="Tracheophyta" rank="genus">
<emphasis id="4119365649C65C6D5F9DDDE41DEEE1E5" italics="true" pageId="null" pageNumber="387">Hordeum</emphasis>
</taxonomicName>
gestellt sind) 
<emphasis id="8B2D38E22C42384FB09A9EAEE8DDB596" italics="true" pageId="null" pageNumber="387">und unterste Deckspelze an der Achse ca.1 mm voneinander entfernt.</emphasis>
</paragraph>
<paragraph id="8FED8FA44432620EA4C606CE1A0379F3" pageId="null" pageNumber="387">
Die Gattung 
<taxonomicName id="6D955A0782A83C72D2E4AF3E88DDF229" class="Liliopsida" family="Poaceae" genus="Elymus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="387" phylum="Tracheophyta" rank="genus">
<emphasis id="50BFF993E3EC92C0C822B76291F1B565" italics="true" pageId="null" pageNumber="387">Elymus</emphasis>
</taxonomicName>
<normalizedToken id="4060846ED4E9E6F48FF3A02A091B828B" originalValue="umfaßt" pageId="null" pageNumber="387">umfasst</normalizedToken>
etwa 
<emphasis id="C464095FC0C76A72090FECB451C9B022" italics="true" pageId="null" pageNumber="387">30 Arten, die in Eurasien und Nordamerika verbreitet sind.</emphasis>
In 
<taxonomicName id="C7E624E2AA994EA24D3F203386CF8AF5" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="387" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
nur 2 Arten. 
<emphasis id="8B12F93F7C679736D8A3271F74A37648" italics="true" pageId="null" pageNumber="387">Chromosomengrundzahl</emphasis>
n = 7; 
<emphasis id="143735C4E2035BF62C8C37E8EA2068B6" italics="true" pageId="null" pageNumber="387">polyploide Reihe</emphasis>
von 2n = 14-56.
</paragraph>
</subSubSection>
