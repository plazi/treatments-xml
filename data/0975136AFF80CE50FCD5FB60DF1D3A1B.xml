Group 
<taxonomicName id="46DCD9FFFF80CE50FC7BFB60D88F38E2" authority="Perty, 1833" authorityName="Perty" authorityYear="1833" box="[900,988,1201,1228]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="13" pageNumber="14" phylum="Arthropoda" rank="genus">
<emphasis id="B3A87E6EFF80CE50FC7BFB60D88F38E2" bold="true" box="[900,988,1201,1228]" italics="true" pageId="13" pageNumber="14">tarsalis</emphasis>
