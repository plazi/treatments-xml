<paragraph blockId="6.[227,1436,1205,1269]" pageId="6" pageNumber="7">
<taxonomicName authority="Wichard &amp; Espeland, 2022" authorityName="Wichard &amp; Espeland" authorityYear="2022" box="[227,503,1205,1231]" class="Insecta" family="Dysoneuridae" genus="Cretapsyche" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trichoptera" pageId="6" pageNumber="7" phylum="Arthropoda" rank="species" species="myanmari" status="sp. nov.">
<emphasis box="[227,503,1205,1231]" italics="true" pageId="6" pageNumber="7">Cretapsyche myanmari</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[515,610,1206,1232]" pageId="6" pageNumber="7" rank="species">sp. nov.</taxonomicNameLabel>
is named after 
<collectingCountry box="[808,924,1206,1232]" name="Myanmar" pageId="6" pageNumber="7">Myanmar</collectingCountry>
, where the amber inclusion was found in 
<collectingRegion box="[227,381,1243,1269]" country="Myanmar" name="Kachin" pageId="6" pageNumber="7">Kachin State</collectingRegion>
.
</paragraph>
