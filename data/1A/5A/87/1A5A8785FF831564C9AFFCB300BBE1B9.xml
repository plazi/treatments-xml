<emphasis bold="true" box="[227,304,1962,1988]" pageId="7" pageNumber="8">Fig. 4.</emphasis>
<taxonomicName authority="Wichard &amp; Espeland, 2022" authorityName="Wichard &amp; Espeland" authorityYear="2022" box="[311,583,1963,1989]" class="Insecta" family="Dysoneuridae" genus="Cretapsyche" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trichoptera" pageId="7" pageNumber="8" phylum="Arthropoda" rank="species" species="myanmari" status="sp. nov.">
