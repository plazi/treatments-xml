<taxonomicName id="A2EA84A9FFFBFFC4FF71FC00FDB1FC42" authority="(Butler, 1895)" baseAuthorityName="Butler" baseAuthorityYear="1895" box="[151,588,978,1005]" class="Insecta" family="Noctuidae" genus="Eudocima" kingdom="Animalia" order="Lepidoptera" pageId="19" pageNumber="20" phylum="Arthropoda" rank="species" species="sikhimensis">
<emphasis id="579E2338FFFBFFC4FF71FC00FDB1FC42" bold="true" box="[151,588,978,1005]" pageId="19" pageNumber="20">
<emphasis id="579E2338FFFBFFC4FF71FC00FE66FC43" bold="true" box="[151,411,978,1005]" italics="true" pageId="19" pageNumber="20">Eudocima sikhimensis</emphasis>
(
<bibRefCitation id="017B82DBFFFBFFC4FE4CFC00FDC1FC42" author="Butler, A. G." box="[426,572,978,1004]" pageId="19" pageNumber="20" pagination="126" refId="ref36376" refString="Butler, A. G. (1895) Adris sikhimensis, a new form of the Ophideroid group of noctuid moths. Annals and Magazine of Natural History, Series 6, 15 (85), 126. https: // doi. org / 10.1080 / 00222939508677853" type="journal article" year="1895">Butler, 1895</bibRefCitation>
)
</emphasis>
</taxonomicName>
</heading>
</paragraph>
