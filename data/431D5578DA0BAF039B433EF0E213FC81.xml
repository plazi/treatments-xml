<subSubSection id="29071CEAF5D39993EA9CAAB649BF2AAE" pageId="null" pageNumber="291" type="description">
<paragraph id="257B4FC6FA84E102A93171A08780994B" pageId="null" pageNumber="291">
Einziger wesentlicher Unterschied zur Gattung 
<taxonomicName id="2E164E4B6C58FA540C8D0D2BD146859A" class="Liliopsida" family="Poaceae" genus="Danthonia" kingdom="Plantae" order="Poales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="genus">
<emphasis id="F99051B3DCB250D89755D67A67E85051" italics="true" pageId="null" pageNumber="291">Danthonia</emphasis>
</taxonomicName>
(S.291): 
<emphasis id="613DDF2D53D065CB7736F549D13EEA5F" italics="true" pageId="null" pageNumber="291">
Deckspelze an der Spitze mit 3 gleichen, stumpfen 
<normalizedToken id="615F586A47C9FDA75856A60CD7B9EBC3" originalValue="Zähnen" pageId="null" pageNumber="291">Zaehnen</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="6C567779CC6C996AFC9D6E3A560C41EC" pageId="null" pageNumber="291">
Die Gattung 
<taxonomicName id="F471614700A95B06CB1DFE4F253815F9" class="Liliopsida" family="Poaceae" genus="Sieglingia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Poales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="genus">
<emphasis id="1B364470DB8968750B2C2F4234A3836B" italics="true" pageId="null" pageNumber="291">Sieglingia</emphasis>
</taxonomicName>
<normalizedToken id="A859CC3BFFF31D1AA5F3BF6F6CFF7812" originalValue="umfaßt" pageId="null" pageNumber="291">umfasst</normalizedToken>
<emphasis id="C5C909E52BA5DD631879313B802D9E53" italics="true" pageId="null" pageNumber="291">
2 Arten, 
<taxonomicName id="816FD89B2B312CE1B78073F43170830D" class="Liliopsida" family="Poaceae" genus="Sieglingia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Poales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="species" species="decumbens">S. decumbens</taxonomicName>
</emphasis>
in 
<taxonomicName id="C0A82AD2F9EBBB4585B5CDAAF28240B8" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="291" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
und 
<taxonomicName id="247B21C5DA0578F8A3FCD30CEB77D992" authority="Aschers" authorityName="Aschers" class="Liliopsida" family="Poaceae" genus="Sieglingia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Poales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="species" species="irritans">
<emphasis id="591F4A58BE546835D2E5187FA47312DD" italics="true" pageId="null" pageNumber="291">S. irritans</emphasis>
Aschers
</taxonomicName>
, in Australien. Zwischen 
<taxonomicName id="6E58DCB05478CBEA9396ADFD91A01391" class="Liliopsida" family="Poaceae" genus="Danthonia" kingdom="Plantae" order="Poales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="species" species="provincialis">
<emphasis id="21AA66205B5C89C135B66576B2ED410E" italics="true" pageId="null" pageNumber="291">Danthonia provincialis</emphasis>
</taxonomicName>
und 
<taxonomicName id="7688D761B7551105870F59B85283D497" class="Liliopsida" family="Poaceae" genus="Sieglingia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Poales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="species" species="decumbens">
<emphasis id="93E18B1DE247DC63E9192A1FADF06CBB" italics="true" pageId="null" pageNumber="291">Sieglingia decumbens</emphasis>
</taxonomicName>
ist ein Bastard bekannt (z. B. aus dem Wienerwald); deshalb 
<normalizedToken id="A1BF7B43EB9CB0A74787E593FF826DED" originalValue="dürfte" pageId="null" pageNumber="291">duerfte</normalizedToken>
wohl 
<taxonomicName id="4CDD85B938FD0EF5CA8AAD89EE505DDE" class="Liliopsida" family="Poaceae" genus="Sieglingia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Poales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="genus">
<emphasis id="A95F535C9E07ED22267FB021E4DC857E" italics="true" pageId="null" pageNumber="291">Sieglingia</emphasis>
</taxonomicName>
(wie 
<taxonomicName id="69132E5F2E7DAB301A0C36892F5D0D99" class="Liliopsida" family="Poaceae" genus="Danthonia" kingdom="Plantae" order="Poales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="genus">
<emphasis id="BCEBD77563A6691003112B370C157A7B" italics="true" pageId="null" pageNumber="291">Danthonia</emphasis>
</taxonomicName>
) in die Verwandtschaft von 
<taxonomicName id="C497336DCADE542771D6A9B70949E320" class="Liliopsida" family="Poaceae" genus="Avena" kingdom="Plantae" order="Poales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="genus">
<emphasis id="22697D137888403D495AE00D25AE80C5" italics="true" pageId="null" pageNumber="291">Avena</emphasis>
</taxonomicName>
und nicht von 
<taxonomicName id="24E5818AE7E6E3D14ABCC7F929743BEA" class="Liliopsida" family="Poaceae" genus="Festuca" kingdom="Plantae" order="Poales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="genus">
<emphasis id="FABE4F69C5835C05E11704879737AC1D" italics="true" pageId="null" pageNumber="291">Festuca</emphasis>
</taxonomicName>
gestellt werden (vgl. dazu Schwarz und 
<normalizedToken id="910BAB5F5F3A3089A2467EC66581981B" originalValue="Bässler" pageId="null" pageNumber="291">Baessler</normalizedToken>
1964).
</paragraph>
</subSubSection>
