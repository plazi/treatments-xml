</caption>
<paragraph id="8BAE36CF6B2CFFBBFB3B7AC3F7D28D05" blockId="0.[1258,2137,996,1304]" box="[1259,2057,996,1029]" pageId="0" pageNumber="528">
<caption id="DF6E66476B2CFFBBFB3B7AC3F7DD8D05" ID-DOI="http://doi.org/10.5281/zenodo.6607325" ID-Zenodo-Dep="6607325" box="[1259,2054,996,1029]" httpUri="https://zenodo.org/record/6607325/files/figure.png" inLine="true" pageId="0" pageNumber="528" startId="0.[1259,1272,996,1029]" targetBox="[249,1194,689,1314]" targetPageId="0">• All oceans and some rivers in East and South Asia</caption>
