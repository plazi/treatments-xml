<subSubSection id="F4C03594F788A5FA792E99698411466A" lastPageNumber="121" pageId="null" pageNumber="124" type="description">
<paragraph id="715CADDF5A212D18359FF4700E46AEFE" pageId="null" pageNumber="124">
Unterscheidet sich von der Gattung 
<taxonomicName id="00C81C127CF6E1D95E9C29D7F75D1527" class="Magnoliopsida" family="Papaveraceae" genus="Corydalis" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="124" phylum="Tracheophyta" rank="genus">
<emphasis id="1B33451AF1DE293F61BECCCF83C41377" italics="true" pageId="null" pageNumber="124">Corydalis</emphasis>
</taxonomicName>
(S. 117) durch folgende Merkmale: 
<emphasis id="605EFCC9020BA518217FE1AB503A7D78" italics="true" pageId="null" pageNumber="124">
1 
<normalizedToken id="253CB3480848A1DEDE0B55D9C5874003" originalValue="jährig" pageId="null" pageNumber="124">jaehrig</normalizedToken>
;
</emphasis>
<normalizedToken id="7DFECC6CF4BF9EA56543C907E5D3B2A5" originalValue="Blütentrauben" pageId="null" pageNumber="124">Bluetentrauben</normalizedToken>
von Seitentrieben 
<normalizedToken id="19F35B2526B97B0C8C0281C4ADA6730D" originalValue="überragt" pageId="null" pageNumber="124">ueberragt</normalizedToken>
, 
<emphasis id="C9E73D551E28A36369EBAE20AC0633E0" italics="true" pageId="null" pageNumber="124">
<normalizedToken id="34E5FEBF43D2A778F051DF05C632008A" originalValue="Blüten" pageId="null" pageNumber="124">Blueten</normalizedToken>
0,5-1,5 cm lang; Frucht eine 1samige, kugelige 
<normalizedToken id="12905BEE2C7604B63BF9034B54E757D4" originalValue="Nuß" pageId="null" pageNumber="124">Nuss</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="3D74B82E485A909870C605D5EA422752" pageId="null" pageNumber="124">
Die Gattung 
<taxonomicName id="13025C04E5F6DC8F059B982818952204" class="Magnoliopsida" family="Papaveraceae" genus="Fumaria" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="124" phylum="Tracheophyta" rank="genus">
<emphasis id="E214DBBBCBBA20D925F1A15083D324B3" italics="true" pageId="null" pageNumber="124">Fumaria</emphasis>
</taxonomicName>
<normalizedToken id="9C3297F77233B7FC36023EFE60645ADE" originalValue="umfaßt" pageId="null" pageNumber="124">umfasst</normalizedToken>
etwa 
<emphasis id="98F9E46014FAF8CD9575453D437E9F4E" italics="true" pageId="null" pageNumber="124">50 Arten</emphasis>
und hat ihre 
<emphasis id="FE4B02D3662A494073F3AF29D25F239C" italics="true" pageId="null" pageNumber="124">Hauptverbreitung im Mittelmeergebiet.</emphasis>
</paragraph>
<paragraph id="4B3ECBB5AD64986BEA1581766F00C23C" pageId="null" pageNumber="121">
<table id="96E78E49808B0A6E908835C07A197EE8" frame="void" pageId="null" pageNumber="121" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="4F776E3811B485427E6AE3F72396A16E" pageId="null" pageNumber="121">
