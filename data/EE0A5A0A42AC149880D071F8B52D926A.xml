<td id="78BFDD054ED7B6C0CF59DA922931C057" align="left" pageId="null" pageNumber="121" valign="top">
<pageBreakToken id="E5671E28D609D70517A235BD7EF64C26" pageId="null" pageNumber="121" start="start">1</pageBreakToken>
. 
<normalizedToken id="3F38BDE49745D1722B35A5413375D3D9" originalValue="Blüten" pageId="null" pageNumber="121">Blueten</normalizedToken>
9-15 mm lang, 
<normalizedToken id="4337BF7EE2A0903467AFC5537CE98F04" originalValue="Kelchblätter" pageId="null" pageNumber="121">Kelchblaetter</normalizedToken>
4-6 mm lang; Fruchtstiele nach 
<normalizedToken id="46FF1AC91DF1FA48B297CA23AD9A1875" originalValue="rückwärts" pageId="null" pageNumber="121">rueckwaerts</normalizedToken>
<normalizedToken id="168AC27B51ACBDA7185F2BE96129D8EA" originalValue="gekrümmt" pageId="null" pageNumber="121">gekruemmt</normalizedToken>
; Frucht glatt
</td>
<td id="CA8E41ABC3C14AE97FECBC1A6E11D5C1" align="left" pageId="null" pageNumber="121" valign="bottom">
<taxonomicName id="812529F31B3D5F7F0CF35137C7C7A1FE" class="Magnoliopsida" family="Papaveraceae" genus="Fumaria" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="121" phylum="Tracheophyta" rank="species" species="capreolata">
<italic id="AD9F95C764A92FFB0AB2A50BEF08E820" pageId="null" pageNumber="121">F. capreolata</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="A7B314F2945F401A1FD1F747E73183B8" pageId="null" pageNumber="121">
<td id="3D757348D14E3A7C1B7084C8E8C069BA" align="left" pageId="null" pageNumber="121" valign="top">
1*. 
<normalizedToken id="4EAFEBFEE7ECA645E2B5EA0D3251AEE2" originalValue="Blüten" pageId="null" pageNumber="121">Blueten</normalizedToken>
5-9 mm lang; 
<normalizedToken id="E3A2864AC2452D13E55C15946AB5D3C6" originalValue="Kelchblätter" pageId="null" pageNumber="121">Kelchblaetter</normalizedToken>
0,5-3,5 mm lang; Fruchtstiele aufrecht-abstehend; Frucht etwas runzelig
</td>
<td id="C43C8A25A7723FF907148526FFFF1E59" align="left" pageId="null" pageNumber="121" valign="bottom">
<italic id="5040364F51DF4E751AB92757D09A3104" pageId="null" pageNumber="121">
Artengruppe der 
<taxonomicName id="3BFF2308A12C6E96E3AE60B634C93F92" class="Magnoliopsida" family="Papaveraceae" genus="Fumaria" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="121" phylum="Tracheophyta" rank="species" species="officinalis">F. officinalis</taxonomicName>
</italic>
(Nr. 2)
</td>
</tr>
