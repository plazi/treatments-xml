<emphasis id="3592EA9F0B7E164F78E8FC882797FCCD" box="[189,205,842,868]" italics="true" pageId="14" pageNumber="119">=</emphasis>
<taxonomicName id="C0E64D0E0B7E164F7898FC882559FCCD" authority="Linnaeus" authorityName="Linnaeus" box="[205,515,842,868]" class="Magnoliopsida" family="Malvaceae" genus="Sida" kingdom="Plantae" order="Malvales" pageId="14" pageNumber="119" phylum="Tracheophyta" rank="species" species="carpinifolia">
