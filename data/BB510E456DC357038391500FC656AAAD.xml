3.2.1. 
<taxonomicName id="877AC039DDA882ABC457AB02FF436122" LSID="http://zoobank.org/27CE7BA1-F2D6-46EF-9E29-302E54844D84" authority="Moreira &amp; Dumas &amp; Rozo &amp; Desidério &amp; Takiya, 2022" authorityName="Moreira &amp; Dumas &amp; Rozo &amp; Desidério &amp; Takiya" authorityYear="2022" class="Insecta" family="Philopotamidae" genus="Chimarra" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Chimarra (Chimarrita) truncata" order="Trichoptera" pageId="0" pageNumber="169" phylum="Arthropoda" rank="species" species="truncata" status="sp. nov." subGenus="Chimarrita">Chimarra (Chimarrita) truncata</taxonomicName>
