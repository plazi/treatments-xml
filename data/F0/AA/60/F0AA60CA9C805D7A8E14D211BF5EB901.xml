<bibRefCitation DOI="https://doi.org/10.11646/zootaxa.3895.1.3" author="Maier, CA" journalOrPublisher="Zootaxa" pageId="0" pageNumber="301" pagination="58 - 72" refId="B55" refString="Maier, CA, Short, AEZ, 2014. Review of the Lutrochidae (Coleoptera) of the Guianas and Lesser Antilles, with description of four new species. Zootaxa 3895 (1): 58 - 72, DOI: https://doi.org/10.11646/zootaxa.3895.1.3" title="Review of the Lutrochidae (Coleoptera) of the Guianas and Lesser Antilles, with description of four new species." url="https://doi.org/10.11646/zootaxa.3895.1.3" volume="3895" year="2014">2014</bibRefCitation>
