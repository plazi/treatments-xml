<subSubSection id="E05EC3F17DFC3AB69644D12C4DA56AFC" pageId="null" pageNumber="62" type="description">
<paragraph id="EA9C89BB1EB982C7023045DA1CA45245" pageId="null" pageNumber="62">
<emphasis id="8ECAC2FCC9817E789E7191963B672E5F" italics="true" pageId="null" pageNumber="62">
1 
<normalizedToken id="23B6F71516DA8247F081A4423F2CF4E2" originalValue="jährig" pageId="null" pageNumber="62">jaehrig</normalizedToken>
</emphasis>
(sommer- oder winterannuell), mit Pfahlwurzel; ganze Pflanze dicht mit kurzen flaumigen und 
<normalizedToken id="4E6C7B01DEDA75A487C5605670B38B95" originalValue="drüsigen" pageId="null" pageNumber="62">druesigen</normalizedToken>
und zerstreut mit langen, weichen Borstenhaaren besetzt. Stengel 10-40 cm hoch, stets mehrere und 
<emphasis id="061953389C229BE28DD82C43DCAF8801" italics="true" pageId="null" pageNumber="62">nicht verzweigt.</emphasis>
<normalizedToken id="2D9F20073BAF008FC1F65BB49CCAEC72" originalValue="Blätter" pageId="null" pageNumber="62">Blaetter</normalizedToken>
lanzettlich, 4-6mal so lang wie breit, ganzrandig oder 
<normalizedToken id="378B7CB3D7472B57B4D3BD21B89D57C4" originalValue="unregelmäßig" pageId="null" pageNumber="62">unregelmaessig</normalizedToken>
<normalizedToken id="74522416158253F6B969E687CF2EB57D" originalValue="gezähnt" pageId="null" pageNumber="62">gezaehnt</normalizedToken>
, nach oben 
<normalizedToken id="FDFD1F8A8F972ADF4682B23772D5DC1E" originalValue="allmählich" pageId="null" pageNumber="62">allmaehlich</normalizedToken>
in die 
<normalizedToken id="AFB33F55AA756F897407BB0FC296AFA0" originalValue="Tragblätter" pageId="null" pageNumber="62">Tragblaetter</normalizedToken>
<normalizedToken id="3ACC1DE3C5E3F9A0D66F8D89555F4E8B" originalValue="übergehend" pageId="null" pageNumber="62">uebergehend</normalizedToken>
. 
<normalizedToken id="364BF98981968E7B39B7B17AFCA98822" originalValue="Blütenstand" pageId="null" pageNumber="62">Bluetenstand</normalizedToken>
traubenartig. 
<emphasis id="F8FAC29A1D80D89BA4D7A6743D725A8A" italics="true" pageId="null" pageNumber="62">Kelch bis in die Mitte geteilt</emphasis>
, 
<normalizedToken id="2988D5FFA7CD1B159D946B0B9F937FE6" originalValue="glockenförmig" pageId="null" pageNumber="62">glockenfoermig</normalizedToken>
, zur 
<normalizedToken id="3351FEB7C053C724DC1A2D8D1CD821DB" originalValue="Blütezeit" pageId="null" pageNumber="62">Bluetezeit</normalizedToken>
6-8 mm lang, 
<emphasis id="39C582CE3656EE4F7CD652E00A73A2E8" italics="true" pageId="null" pageNumber="62">zur Fruchtzeit 12</emphasis>
- 
<emphasis id="B78832C9AAFCA7D9465D1696D09F0D85" italics="true" pageId="null" pageNumber="62">18 mm lang und schief abstehend. Krone gelb</emphasis>
, 7-12 mm lang, im Durchmesser 5-7 mm; Schlundschuppen behaart. - 
<normalizedToken id="B1C2AC8AAFCFE46AC86FA566A5932104" originalValue="Blüte" pageId="null" pageNumber="62">Bluete</normalizedToken>
: 
<normalizedToken id="4B4B45288E0FD722F05EB9A34A1C2497" originalValue="Später" pageId="null" pageNumber="62">Spaeter</normalizedToken>
<normalizedToken id="8E8B575100DD0F8F2E5A6F64777AA0FD" originalValue="Frühling" pageId="null" pageNumber="62">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="784B0615B15D9C306E803C5C474EE1B6" pageId="null" pageNumber="62">
<emphasis id="A8DBDE4431651176F79FB5B65FD1A6CA" italics="true" pageId="null" pageNumber="62">
<pageBreakToken id="A42F22BF865C1D85B90B14631785C06D" pageId="null" pageNumber="62">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="34ECFA5B1357650BB00B36A7151D6628" italics="true" pageId="null" pageNumber="62">14:</emphasis>
Material aus botanischen 
<normalizedToken id="59832835D69BC1FDD49B33E62967FB3B" originalValue="Gärten" pageId="null" pageNumber="62">Gaerten</normalizedToken>
(Strey 1931, Britton 1951, Speta 1971), aus Persien (Grau 1971).
</paragraph>
<paragraph id="1DC471A77C0DA1176CA075ED424A9A6C" pageId="null" pageNumber="62">
<emphasis id="E69E572FBB47275ABBCAB1475F4A336F" italics="true" pageId="null" pageNumber="62">Standort.</emphasis>
Kollin. Trockene 
<normalizedToken id="00EA4FF2D540FCF6C5B2044C610D3C9E" originalValue="Böden" pageId="null" pageNumber="62">Boeden</normalizedToken>
in warmen Lagen. Weinberge, Ruderalstellen.
</paragraph>
<paragraph id="B77149C2CAD217583F05FAF966DBFBBC" pageId="null" pageNumber="62">
<emphasis id="CF97C9C0128FA046D9B933DB2E1730D5" italics="true" pageId="null" pageNumber="62">Verbreitung.</emphasis>
<normalizedToken id="0F53ABFB299C2440CFA0E871911F7E9F" originalValue="Ursprünglich" pageId="null" pageNumber="62">Urspruenglich</normalizedToken>
<emphasis id="5A5E2ABD589A869DEDDFA9F0D42143D6" italics="true" pageId="null" pageNumber="62">
<normalizedToken id="07C188546ABFD6046B163944E7C5B97B" originalValue="südosteuropäisch-westasiatische" pageId="null" pageNumber="62">suedosteuropaeisch-westasiatische</normalizedToken>
Pflanze;
</emphasis>
heute in den 
<normalizedToken id="4C3B7089E2B5004B813A7FAD2AC511F8" originalValue="wärmeren" pageId="null" pageNumber="62">waermeren</normalizedToken>
Zonen verwilderte Gartenpflanze. - Im Gebiet in den warmen Gegenden, aber selten.
</paragraph>
</subSubSection>
