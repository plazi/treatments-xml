<taxonomicName id="A7E14D6CFFC7D6490960FC1512F13203" baseAuthorityName="Kuhl" baseAuthorityYear="1817" box="[810,990,1017,1050]" class="Mammalia" family="Miniopteridae" genus="Miniopteres" kingdom="Animalia" order="Chiroptera" pageId="17" pageNumber="708" phylum="Chordata" rank="species" species="schreibersii">M. schreibersii</taxonomicName>
