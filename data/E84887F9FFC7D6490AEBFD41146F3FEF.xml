, 
<materialsCitation id="D0893CB2FFC7D6490914FC67127335D2" ID-GBIF-Occurrence="3747914316" pageId="17" pageNumber="708">
“Imasindrary, N.E. Betsileo,” 
<collectingCountry id="18F6767FFFC7D6490F4AFC67127635D2" name="Madagascar" pageId="17" pageNumber="708">Madagascar</collectingCountry>
.
</materialsCitation>
</paragraph>
<paragraph id="605E36EFFFC7D649094FFC3D15A53203" blockId="17.[772,1364,859,1287]" pageId="17" pageNumber="708">
<taxonomicName id="A7E14D6CFFC7D649094FFC3D12D135EB" authorityName="Bonaparte" authorityYear="1837" box="[773,1022,977,1010]" class="Mammalia" family="Miniopteridae" genus="Miniopterus" kingdom="Animalia" order="Chiroptera" pageId="17" pageNumber="708" phylum="Chordata" rank="species" species="major">Miniopterus major</taxonomicName>
