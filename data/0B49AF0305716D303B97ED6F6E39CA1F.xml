<subSubSection id="B3144383AE63C00A1D0ADFBE2429A2CE" pageId="null" pageNumber="302" type="description">
<paragraph id="FD793CDFF6DC4872CD3A4873BC4C1543" pageId="null" pageNumber="302">
0,3-1 m hoch, horstbildend. Stengel aufrecht, kahl. 
<emphasis id="7AE2B348448FAC3DAF186E562C62FC51" italics="true" pageId="null" pageNumber="302">
Alle 
<normalizedToken id="9F04569AE0C3E03D1273206164507F79" originalValue="Blätter" pageId="null" pageNumber="302">Blaetter</normalizedToken>
<normalizedToken id="913281FEF3599E6915B3E2BEA3C7F9B4" originalValue="borstenförmig" pageId="null" pageNumber="302">borstenfoermig</normalizedToken>
</emphasis>
, mit feiner Spitze, 
<emphasis id="FD19DF7276FB0076FDE520513EB5A38A" italics="true" pageId="null" pageNumber="302">
<normalizedToken id="B1CDBE7BC082214F2409B04DCE2B5D8E" originalValue="blaugrün" pageId="null" pageNumber="302">blaugruen</normalizedToken>
, kahl; 
<normalizedToken id="FEC5E55F8A49609477E14B59D00B77A4" originalValue="Blatthäutchen" pageId="null" pageNumber="302">Blatthaeutchen</normalizedToken>
bis 1 mm lang
</emphasis>
, stumpf, bewimpert; 
<emphasis id="49BB6E891176579F97C8BA0AE90BC98C" italics="true" pageId="null" pageNumber="302">Blattscheiden kahl.</emphasis>
<normalizedToken id="0B9515FBD8634BB124673CBE1606B18E" originalValue="Blütenstand" pageId="null" pageNumber="302">Bluetenstand</normalizedToken>
im Habitus wie bei 
<taxonomicName id="3DC134F60EA7ED444645EAFC1A929663" class="Liliopsida" family="Poaceae" genus="Avenochloa" higherTaxonomySource="GBIF" kingdom="Plantae" order="Poales" pageId="null" pageNumber="302" phylum="Tracheophyta" rank="species" species="pubescens">
<emphasis id="44AF8C27747A80B352838F02644C5995" italics="true" pageId="null" pageNumber="302">H. pubescens</emphasis>
</taxonomicName>
(Nr. 1), die 
<normalizedToken id="8F56E714CC7320A51B52D0256B71C001" originalValue="Ährchen" pageId="null" pageNumber="302">Aehrchen</normalizedToken>
jedoch kleiner: obere (
<normalizedToken id="76E3959793CAA6F3BFDF55105293363E" originalValue="längere" pageId="null" pageNumber="302">laengere</normalizedToken>
) 
<normalizedToken id="650BB291C6A9ECF4BECEE52528907EFF" originalValue="Hüllspelze" pageId="null" pageNumber="302">Huellspelze</normalizedToken>
10-12 mm lang; Spelzen rotviolett gescheckt. - 
<normalizedToken id="EAA4313EEB43806CA5887685B91EC9C0" originalValue="Blüte" pageId="null" pageNumber="302">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="3B64B4B87B9C9E7FF5E18474498B6859" pageId="null" pageNumber="302">
<emphasis id="770547A60B4F426EC2EB002CF884DA39" italics="true" pageId="null" pageNumber="302">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="4328241A33C659FF14F5AC51B9072C6D" italics="true" pageId="null" pageNumber="302">14, 42:</emphasis>
Material aus Frankreich (
<normalizedToken id="7CA1DE246699BDCF5C04B99409CEBDB3" originalValue="Drôme" pageId="null" pageNumber="302">Drome</normalizedToken>
), 2 verschiedene Unterarten mit verschiedenen Chromosomenzahlen (
<normalizedToken id="32266D94430C5FF3175809439BDC4E3C" originalValue="Litardière" pageId="null" pageNumber="302">Litardiere</normalizedToken>
1950). 
<emphasis id="AD74C5F3F0FA3FA85FBA90C713EFE2E2" italics="true" pageId="null" pageNumber="302">2n = 42:</emphasis>
Material aus den Westalpen (Gervais 1966).
</paragraph>
<paragraph id="0B6BE5BB508714FA31A0F74FF4116BEB" pageId="null" pageNumber="302">
<emphasis id="C6B28835837253942B7DAD3383844FAA" italics="true" pageId="null" pageNumber="302">Standort.</emphasis>
Montan und subalpin. Kalkhaltige Unterlage. Felsen, 
<normalizedToken id="A3EBEFB071EB1834F3B46AC63CB0F18E" originalValue="Hänge" pageId="null" pageNumber="302">Haenge</normalizedToken>
.
</paragraph>
<paragraph id="A1868FD47233D06DA10C3AA5E1F50E70" pageId="null" pageNumber="302">
<emphasis id="E8A7BA55277CF0A54F97F1BADB654F36" italics="true" pageId="null" pageNumber="302">Verbreitung. Westalpen-Pflanze:</emphasis>
Von den Seealpen bis in die Gegend des Mont Cenis (Savoyen). - Im Gebiet nur am Mont Cenis.
</paragraph>
</subSubSection>
