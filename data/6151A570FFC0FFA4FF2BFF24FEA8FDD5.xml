<taxonomicName id="2EF86FE5FFC0FFA4FD2DFE49FCBFFDFC" authorityName="Wassilieff" authorityYear="1908" box="[657,862,506,531]" class="Anthozoa" family="Actiniidae" genus="Dofleinia" kingdom="Animalia" order="Actiniaria" pageId="16" pageNumber="101" phylum="Cnidaria" rank="species" species="armata">
