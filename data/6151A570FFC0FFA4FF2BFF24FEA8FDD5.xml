<subSubSection id="A1E247EDFFC0FFA4FF7AFE49FEA8FDD5" pageId="16" pageNumber="101" type="biology_ecology">
<paragraph id="E9471466FFC0FFA4FF7AFE49FEA8FDD5" blockId="16.[151,1436,357,570]" pageId="16" pageNumber="101">
<emphasis id="DB8CC874FFC0FFA4FF7AFE49FEE0FDFB" bold="true" box="[198,257,506,532]" pageId="16" pageNumber="101">Host</emphasis>
