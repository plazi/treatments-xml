<subSubSection id="C32F656CFFBD6272FF065850401CF97D" pageId="1" pageNumber="231" type="discussion">
<paragraph id="8B8A36E7FFBD6272FF065850401CF97D" blockId="1.[136,1452,1627,2088]" pageId="1" pageNumber="231">
<emphasis id="B941EAF5FFBD6272FF065850454CF991" bold="true" box="[189,294,1627,1653]" pageId="1" pageNumber="231">Notes:—</emphasis>
<taxonomicName id="4C354D64FFBD6272FE9D585745F0F991" box="[294,410,1627,1653]" class="Magnoliopsida" family="Linderniaceae" genus="Torenia" kingdom="Plantae" order="Lamiales" pageId="1" pageNumber="231" phylum="Tracheophyta" rank="species" species="hookeri">
<emphasis id="B941EAF5FFBD6272FE9D585745F0F991" box="[294,410,1627,1653]" italics="true" pageId="1" pageNumber="231">T. hookeri</emphasis>
</taxonomicName>
can be easily distinguished from other 
<taxonomicName id="4C354D64FFBD6272FCDD585747D1F991" authorityName="Linnaeus" authorityYear="1753" box="[870,955,1628,1653]" class="Magnoliopsida" family="Linderniaceae" genus="Torenia" kingdom="Plantae" order="Lamiales" pageId="1" pageNumber="231" phylum="Tracheophyta" rank="genus">
<emphasis id="B941EAF5FFBD6272FCDD585747D1F991" box="[870,955,1628,1653]" italics="true" pageId="1" pageNumber="231">Torenia</emphasis>
</taxonomicName>
by the size of the densely hairy calyx and purple or violet corolla with a yellow spot surrounded by a whitish patch on the lower lip.
</paragraph>
</subSubSection>
<subSubSection id="C32F656CFFBD6272FF0658A847F6F959" box="[189,924,1699,1725]" pageId="1" pageNumber="231" type="biology_ecology">
<paragraph id="8B8A36E7FFBD6272FF0658A847F6F959" blockId="1.[136,1452,1627,2088]" box="[189,924,1699,1725]" pageId="1" pageNumber="231">
<emphasis id="B941EAF5FFBD6272FF0658A84535F959" bold="true" box="[189,351,1699,1725]" pageId="1" pageNumber="231">Phenology:—</emphasis>
Flowers and fruits recorded in October–November.
</paragraph>
</subSubSection>
