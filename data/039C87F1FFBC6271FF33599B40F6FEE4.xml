<collectingCountry id="F3227677FFBD6272FD7B58E74745F8E2" box="[704,815,1772,1798]" name="Myanmar" pageId="1" pageNumber="231">Myanmar</collectingCountry>
, 
<collectingCountry id="F3227677FFBD6272FC8058E047EBF8E1" box="[827,897,1771,1797]" name="Nepal" pageId="1" pageNumber="231">Nepal</collectingCountry>
