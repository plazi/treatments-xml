<taxonomicName id="FC0E87E90EA7E4BB8F015BCE5B1738DF" authority="(L.) Lam." class="Magnoliopsida" family="Fabaceae" genus="Onobrychis" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="574" phylum="Tracheophyta" rank="species" species="saxatilis">
