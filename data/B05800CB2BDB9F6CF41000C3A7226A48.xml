<subSubSection id="E939FF1744E3234AE2C8539AA6FAAD47" pageId="null" pageNumber="574" type="vernacular_names">
<paragraph id="E51B166149E30C63C560D08700E2FEB3" pageId="null" pageNumber="574">Felsen-Esparsette</paragraph>
</subSubSection>
</title>
<subSubSection id="8C038B6ED440FD436878A27ADBA7CDF0" pageId="null" pageNumber="574" type="description">
<paragraph id="0445C9CFE66B868DA319371671F85158" pageId="null" pageNumber="574">
Ausdauernd, ohne 
<normalizedToken id="FA0560EA59EA40FDD5B21771E947C791" originalValue="Ausläufer" pageId="null" pageNumber="574">Auslaeufer</normalizedToken>
; 15-40 cm hoch. Stengel aufrecht oder bogig aufsteigend, zerstreut behaart. 
<emphasis id="A9D74F34762BDC7212A83CD881FEF8FA" italics="true" pageId="null" pageNumber="574">
Alle 
<normalizedToken id="7680DECDD57307B8122FB8272A6665A2" originalValue="Blätter" pageId="null" pageNumber="574">Blaetter</normalizedToken>
in 
<normalizedToken id="3FFEDF6E733BA4C7204313AE88F8DCA0" originalValue="grundständiger" pageId="null" pageNumber="574">grundstaendiger</normalizedToken>
Rosette.
</emphasis>
<normalizedToken id="8D4BE3C62C70C15882B615FE944F41E0" originalValue="Blätter" pageId="null" pageNumber="574">Blaetter</normalizedToken>
mit 13-31 
<normalizedToken id="9D770AA7CF46181BCCB55205B80917B4" originalValue="Teilblättern" pageId="null" pageNumber="574">Teilblaettern</normalizedToken>
; 
<normalizedToken id="A00AC6A915A872EB34363F4A5727F9BC" originalValue="Teilblätter" pageId="null" pageNumber="574">Teilblaetter</normalizedToken>
kurz gestielt, sehr schmal lanzettlich, spitz, besonders unterseits 
<emphasis id="A7DF09208A6A22BE45306B4835DC96F7" italics="true" pageId="null" pageNumber="574">ziemlich dicht und seidig behaart.</emphasis>
<normalizedToken id="66D02F8D66D1E6393D91B32CF5D4E110" originalValue="Nebenblätter" pageId="null" pageNumber="574">Nebenblaetter</normalizedToken>
verwachsen. Stiel des 
<normalizedToken id="63F414E3EB17042CF4525B6E59541737" originalValue="Blütenstandes" pageId="null" pageNumber="574">Bluetenstandes</normalizedToken>
<normalizedToken id="293FB24D91E7134E6D1D491772C80B18" originalValue="kürzer" pageId="null" pageNumber="574">kuerzer</normalizedToken>
oder wenig 
<normalizedToken id="D8CBCD50C417E504216396AB3F9E7EC8" originalValue="länger" pageId="null" pageNumber="574">laenger</normalizedToken>
als die 
<normalizedToken id="B5154B6B5F0F4D1296DA3CF76E8AC2AE" originalValue="Blätter" pageId="null" pageNumber="574">Blaetter</normalizedToken>
. 
<normalizedToken id="6AF8E59B75990C7912BF8E503A86CAC5" originalValue="Blüten" pageId="null" pageNumber="574">Blueten</normalizedToken>
aufrecht abstehend, in allseitswendigen, 
<normalizedToken id="5730205D3017F9E01856D0F85529CAC8" originalValue="vielblütigen" pageId="null" pageNumber="574">vielbluetigen</normalizedToken>
, lockeren, 
<normalizedToken id="94AC9F2096599E4FE87C5BBDD4360910" originalValue="ährenähnlichen" pageId="null" pageNumber="574">aehrenaehnlichen</normalizedToken>
Trauben. 
<normalizedToken id="5C0424345A85E11F675035F6F7730043" originalValue="Blütenstiele" pageId="null" pageNumber="574">Bluetenstiele</normalizedToken>
und Kelch zerstreut behaart; 
<normalizedToken id="1FC7D0A971DB0A56A43F62896530181B" originalValue="Kelchzähne" pageId="null" pageNumber="574">Kelchzaehne</normalizedToken>
<normalizedToken id="DC8981B5653A56E4C000AB8F2D0635E4" originalValue="1½" pageId="null" pageNumber="574">11/2</normalizedToken>
-2mal so lang wie die 
<normalizedToken id="46DB7B8CC8B6966C1343FAC379B52572" originalValue="Kelchröhre" pageId="null" pageNumber="574">Kelchroehre</normalizedToken>
. Krone 1-1,3 cm lang, 
<emphasis id="DC97EBC636A8CE94482208D85C3863AC" italics="true" pageId="null" pageNumber="574">
gelblich, 
<normalizedToken id="62282FB57FF8AC048F9E7459836A2406" originalValue="rötlich" pageId="null" pageNumber="574">roetlich</normalizedToken>
gestreift;
</emphasis>
<normalizedToken id="FFBC354E80A29D8E3BAD1EB804CD8263" originalValue="Flügel" pageId="null" pageNumber="574">Fluegel</normalizedToken>
0,7-0,8 cm lang, bedeutend 
<normalizedToken id="0588BF8E2C9DD22DCDAD04A79460B347" originalValue="kürzer" pageId="null" pageNumber="574">kuerzer</normalizedToken>
als Fahne und Schiffchen, etwa 
<normalizedToken id="5983D16EF6B9F6D2F83BA4E7AA85AC6C" originalValue="1½" pageId="null" pageNumber="574">11/2</normalizedToken>
mal so lang wie der Kelch. Frucht 5-7 mm lang, mit netzartig hervortretenden Leisten und 
<normalizedToken id="B45004D3A8147D232ABE6F23206B2FF4" originalValue="flügelförmigem" pageId="null" pageNumber="574">fluegelfoermigem</normalizedToken>
unterem Rand, 
<emphasis id="1E2E1D211C3168B6FC30A28CBC7D5CE5" italics="true" pageId="null" pageNumber="574">
ohne deutliche 
<normalizedToken id="9027B73F1AE31C5E31EA7A3701C9E7B5" originalValue="Zähne" pageId="null" pageNumber="574">Zaehne</normalizedToken>
</emphasis>
, kurz behaart. - 
<normalizedToken id="38E49346B68865962E88838A5661E5F9" originalValue="Blüte" pageId="null" pageNumber="574">Bluete</normalizedToken>
: 
<normalizedToken id="A7CC96282A5210284C2181313E24A882" originalValue="Später" pageId="null" pageNumber="574">Spaeter</normalizedToken>
<normalizedToken id="0C5A4C043191A08D04654B62F87A778B" originalValue="Frühling" pageId="null" pageNumber="574">Fruehling</normalizedToken>
und 
<normalizedToken id="CAD865F736386FB7D06EB46848E724BB" originalValue="früher" pageId="null" pageNumber="574">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="E2E3689A8225472F594696C893874F12" pageId="null" pageNumber="574">
<emphasis id="076A8289D3CFC8C9E96FD874BFDDE516" italics="true" pageId="null" pageNumber="574">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D3024C915469614B0EFC5CD1856FE9C8" italics="true" pageId="null" pageNumber="574">28:</emphasis>
Material aus Spanien (Sacristan 1966).
</paragraph>
<paragraph id="36D10771F2A641CB04FC9598DF34C145" pageId="null" pageNumber="574">
<emphasis id="1D64C54B92A2DFACCA4AA0CB63C55211" italics="true" pageId="null" pageNumber="574">Standort.</emphasis>
Kollin und montan, seltener subalpin. Steinige, trockene 
<normalizedToken id="3E24CF20589FC775C306A84729C81869" originalValue="Hänge" pageId="null" pageNumber="574">Haenge</normalizedToken>
. Trockenwiesen, Felsensteppen.
</paragraph>
<paragraph id="4956810591A122E4614185B4B121E130" pageId="null" pageNumber="574">
<emphasis id="E7CCC9EE62092EFE98AC83D002C54241" italics="true" pageId="null" pageNumber="574">
Verbreitung. 
<normalizedToken id="84AD762D6FC60311D04B745DDA4E0E3A" originalValue="Südwesteuropäische" pageId="null" pageNumber="574">Suedwesteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Nordwestspanien, 
<normalizedToken id="7B0A6E0C32C475C29C7F383135A1F220" originalValue="Ostpyrenäen" pageId="null" pageNumber="574">Ostpyrenaeen</normalizedToken>
, 
<normalizedToken id="0C1E1C267392A1B6CAEA4529184B234E" originalValue="Südfrankreich" pageId="null" pageNumber="574">Suedfrankreich</normalizedToken>
, 
<normalizedToken id="76694155C586877730FCAC06A96484AB" originalValue="Südwestalpen" pageId="null" pageNumber="574">Suedwestalpen</normalizedToken>
, Apennin (Monte Cajo). - Im Gebiet: Aostatal (nach Fiori 1923-1925).
</paragraph>
</subSubSection>
