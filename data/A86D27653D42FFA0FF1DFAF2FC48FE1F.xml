<figureCitation id="B8FF8AF63D47FFA0FBB8FEEEFB68FED4" box="[1074,1155,295,322]" captionStart="FIGURE 26" captionStartId="50.[151,250,1943,1967]" captionTargetBox="[170,1405,181,1914]" captionTargetId="figure-27@50.[164,1424,181,1920]" captionTargetPageId="50" captionText="FIGURE 26A–D. Patrera dentata n. sp. Male (ICN-Ar-10636):A habitus, dorsal view; B chelicerae, dorsal view; C chelicerae, ventral view; D left palp, retroventral view; E palp, ventral view; F palp, retrolateral view. Abbreviations: Cavp, cheliceral anteroventral projection; VTP, ventral tegular process. Scale bars: A: 2mm; B–C: 1mm; D: 0.5mm; E–F: 0.2mm." figureDoi="http://doi.org/10.5281/zenodo.4468441" httpUri="https://zenodo.org/record/4468441/files/figure.png" pageId="52" pageNumber="53">Fig. 26</figureCitation>
