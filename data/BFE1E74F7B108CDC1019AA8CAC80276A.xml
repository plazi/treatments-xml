<subSubSection id="E61C819C8E83EF81D5B75766B039824C" pageId="null" pageNumber="435" type="vernacular_names">
<paragraph id="2AED8C940D51BCBBAB9487FB46598067" pageId="null" pageNumber="435">Nacktstenglige Scharte</paragraph>
</subSubSection>
</title>
<subSubSection id="ACE52900283B46BD171B7F21F50C1909" pageId="null" pageNumber="435" type="description">
<paragraph id="136E461C4F11AC5F419B596CDE2B431A" pageId="null" pageNumber="435">
Ausdauernd, mit Rhizom; 20-50 cm hoch. Stengel aufrecht, einfach, 
<emphasis id="E0B11E7CAF7CDB1A7ADE8C2E0B3F9068" italics="true" pageId="null" pageNumber="435">
1 
<normalizedToken id="C0ADBA2A42EC239FACBC690A12AAF2BD" originalValue="köpfig" pageId="null" pageNumber="435">koepfig</normalizedToken>
</emphasis>
, kahl, 
<emphasis id="50F7887A3AC2DDF9D0768F67207E0159" italics="true" pageId="null" pageNumber="435">
nur in der untern 
<normalizedToken id="B957577F97F19AF2D6C8CDCA89E825A2" originalValue="Hälfte" pageId="null" pageNumber="435">Haelfte</normalizedToken>
<normalizedToken id="88A3093D6891A4AB02A5735C53385E10" originalValue="beblättert" pageId="null" pageNumber="435">beblaettert</normalizedToken>
.
</emphasis>
<normalizedToken id="8C9188FF3B161C99EDEB181839EB56AE" originalValue="Blätter" pageId="null" pageNumber="435">Blaetter</normalizedToken>
kahl, nur am Rande mit einigen mehrzelligen Haaren, 
<emphasis id="C655AD6CD433D9504EA37063E54F6EC9" italics="true" pageId="null" pageNumber="435">
<normalizedToken id="314FE649199642E21A8CD718D99BE392" originalValue="blaugrün" pageId="null" pageNumber="435">blaugruen</normalizedToken>
</emphasis>
, die untern oval bis lanzettlich, 
<emphasis id="CC17CEFC7103D0ADD5FCD740AA92BFCE" italics="true" pageId="null" pageNumber="435">ganzrandig</emphasis>
, seltener am Grunde mit 
<normalizedToken id="37AA013B887577DDB2692501B40E60DC" originalValue="Zähnen" pageId="null" pageNumber="435">Zaehnen</normalizedToken>
, gestielt, die obern lanzettlich, am Grunde mit einzelnen langen 
<normalizedToken id="4B8DCD8599584E0BA01D237B500E59BB" originalValue="Zähnen" pageId="null" pageNumber="435">Zaehnen</normalizedToken>
oder jederseits bis zur Mitte fiederteilig, sitzend. 
<emphasis id="3123D14EBE04DFA59DDD4BA31B1E3CBA" italics="true" pageId="null" pageNumber="435">
<normalizedToken id="F390BCF2DDF73E216098865359345D0F" originalValue="Hülle" pageId="null" pageNumber="435">Huelle</normalizedToken>
der 
<normalizedToken id="F4DDFDE30A8B961FE45DD212F65BE989" originalValue="blühenden" pageId="null" pageNumber="435">bluehenden</normalizedToken>
<normalizedToken id="64446B9FE32031F497215B5DEFCFD9FB" originalValue="Köpfe" pageId="null" pageNumber="435">Koepfe</normalizedToken>
fast kugelig, 1,2
</emphasis>
- 
<emphasis id="A4CA886BBCF82948952F846D2B4E092F" italics="true" pageId="null" pageNumber="435">1,5 cm lang und 1,5</emphasis>
- 
<emphasis id="8E9D60D3D832A2C7DE3637BCE3D47D76" italics="true" pageId="null" pageNumber="435">2 cm dick.</emphasis>
<normalizedToken id="98CD9777E0B07902814E46D0DC0B5226" originalValue="Hüllblätter" pageId="null" pageNumber="435">Huellblaetter</normalizedToken>
lanzettlich, 
<normalizedToken id="445DB4A356D848097D7F85077803EC94" originalValue="grün" pageId="null" pageNumber="435">gruen</normalizedToken>
, 
<emphasis id="94CD63AD416665627B84C46AB9242761" italics="true" pageId="null" pageNumber="435">im obern Teil dunkel berandet</emphasis>
, besonders am Rand zerstreut und filzig behaart, 
<emphasis id="FD82E234B6D6084B94E7D8CDD858E728" italics="true" pageId="null" pageNumber="435">
die innern mit 
<normalizedToken id="EEC3879B6210F48A13B74BB2E3E01BE5" originalValue="trockenhäutigem" pageId="null" pageNumber="435">trockenhaeutigem</normalizedToken>
, lanzettlichem 
<normalizedToken id="1829F56923624E31755E79C157578A9F" originalValue="Anhängsel" pageId="null" pageNumber="435">Anhaengsel</normalizedToken>
.
</emphasis>
Kronen purpurn. 
<normalizedToken id="89B3337453EED903026E68C61DD2DB2D" originalValue="Früchte" pageId="null" pageNumber="435">Fruechte</normalizedToken>
4-5 mm lang, dunkelbraun. 
<emphasis id="17E4B4EBFF16CA78FC5BC388CF274E26" italics="true" pageId="null" pageNumber="435">
<taxonomicName id="CA9D05B09A9F8193B9870EE942BF2F4F" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="435" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
fast doppelt so lang wie die Frucht.
</emphasis>
- 
<normalizedToken id="A98AA99C6373EBEB07095A28C3869115" originalValue="Blüte" pageId="null" pageNumber="435">Bluete</normalizedToken>
: 
<normalizedToken id="EC66898F8A561BAACF1F622849DA1DEB" originalValue="Frühsommer" pageId="null" pageNumber="435">Fruehsommer</normalizedToken>
.
</paragraph>
<paragraph id="706F246FC8F7966D522C5E21218BD499" pageId="null" pageNumber="435">
<emphasis id="57B19C7DCD16313C37B3721F4B4F54D3" italics="true" pageId="null" pageNumber="435">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E220A39B24CAE1FF5BBA1227BA3DF9A4" italics="true" pageId="null" pageNumber="435">30:</emphasis>
Material aus den 
<normalizedToken id="E3A63B63FC0ACB35847176ED472A5F84" originalValue="Südwestalpen" pageId="null" pageNumber="435">Suedwestalpen</normalizedToken>
(Caussols) (Guinochet und Logeois 1962). 
<emphasis id="B583383E0902EACC1B25A37ED5051C26" italics="true" pageId="null" pageNumber="435">2n</emphasis>
= 
<emphasis id="24BC78CF79EE415E9ABD613BAA8B5E58" italics="true" pageId="null" pageNumber="435">32:</emphasis>
Material aus Nordafrika (
<normalizedToken id="AA76CD5B946EFB35A55F060076EAE47E" originalValue="Quézel" pageId="null" pageNumber="435">Quezel</normalizedToken>
1957).
</paragraph>
<paragraph id="2E6A9D0DFB8E20D399EFCE74D0333882" pageId="null" pageNumber="435">
<emphasis id="AEDD713E3F0598EB118C14BD3BAB6840" italics="true" pageId="null" pageNumber="435">Standort.</emphasis>
Montan, selten subalpin. Trockenwiesen, 
<normalizedToken id="6CCDB11A6B58D1FAE43DB21FF96281CE" originalValue="Felsbänder" pageId="null" pageNumber="435">Felsbaender</normalizedToken>
; auf Kalkunterlage.
</paragraph>
<paragraph id="A6270249CFE13E00336A684BDDA0F32C" pageId="null" pageNumber="435">
<emphasis id="7B4EF58114FFE6F87FE145587C088D23" italics="true" pageId="null" pageNumber="435">
Verbreitung. Mittel- und 
<normalizedToken id="5842E01C09CCC709007093B1C980517A" originalValue="südeuropäische" pageId="null" pageNumber="435">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="1D2A061A46383BB0456C0D71234E64C6" italics="true" pageId="null" pageNumber="435">westlich</emphasis>
)
<emphasis id="4D0B822CDB63DF38B49AB8F95AEB745F" italics="true" pageId="null" pageNumber="435">:</emphasis>
Sierra de Guadarrama, 
<normalizedToken id="BCFEABAED186504990540AB6FF72A169" originalValue="Pyrenäen" pageId="null" pageNumber="435">Pyrenaeen</normalizedToken>
, Plateau Central, Westalpen, 
<normalizedToken id="992814B21FD5F3800BF0A6679ED089DB" originalValue="südlicher" pageId="null" pageNumber="435">suedlicher</normalizedToken>
Jura, mittlerer und 
<normalizedToken id="183C9C7A201E872E66AE605621F258FA" originalValue="nördlicher" pageId="null" pageNumber="435">noerdlicher</normalizedToken>
Apennin; Atlas (?). - Im Gebiet: Savoyen (
<normalizedToken id="E15F7D083D2475C325BFED53B8A9E0C6" originalValue="Salève" pageId="null" pageNumber="435">Saleve</normalizedToken>
, Monte Vuache).
</paragraph>
</subSubSection>
