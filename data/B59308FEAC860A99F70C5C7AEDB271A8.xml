<subSubSection id="0EE28CC4C608BDADFF47C0612B315A56" pageId="null" pageNumber="544" type="description">
<paragraph id="785263A633DE71818F3EE9F66D5348F5" pageId="null" pageNumber="544">
<emphasis id="1CC504B5D66A5CAD0E2E12C0FDF2D833" italics="true" pageId="null" pageNumber="544">
<normalizedToken id="A52669477FB066BAE2EE2A4FF6C7654F" originalValue="Immergrüne" pageId="null" pageNumber="544">Immergruene</normalizedToken>
, 0,2-1,5 m hohe 
<normalizedToken id="83FCBD1D2E4C065929F05F591DE490AF" originalValue="Sträucher" pageId="null" pageNumber="544">Straeucher</normalizedToken>
.
</emphasis>
Rhizom horizontal, dick. 
<emphasis id="258675B8B5BD0BBDC0836E26D42DD516" italics="true" pageId="null" pageNumber="544">
Stengel holzig, mit 
<normalizedToken id="A3ADFE40FD1C8739A5B205E2A94D8507" originalValue="früh" pageId="null" pageNumber="544">frueh</normalizedToken>
abfallenden, 
<normalizedToken id="D13B3830AEC16E1010DB251C5D60BD6A" originalValue="wechselständig" pageId="null" pageNumber="544">wechselstaendig</normalizedToken>
angeordneten, 
<normalizedToken id="B3003321489C2BA3D53F53E74191ECC6" originalValue="häutigen" pageId="null" pageNumber="544">haeutigen</normalizedToken>
, gelblichen, schmal lanzettlichen, kleinen 
<normalizedToken id="E8D0A860FA27218089143072FA5766AB" originalValue="Blättern" pageId="null" pageNumber="544">Blaettern</normalizedToken>
, in deren Achseln Seitensprosse stehen
</emphasis>
, die 2zeilig angeordnete, 
<emphasis id="1B7DF91BA24034EE6DEAD9049F241B04" italics="true" pageId="null" pageNumber="544">
breit lanzettliche, 
<normalizedToken id="4046A8678C58ECFC47695CB414A1F184" originalValue="immergrüne" pageId="null" pageNumber="544">immergruene</normalizedToken>
, ledrige 
<normalizedToken id="65568C6141AF503424AA824847D2796A" originalValue="Blätter" pageId="null" pageNumber="544">Blaetter</normalizedToken>
</emphasis>
(Phyllokladien) 
<emphasis id="C6433C22E0A6A5759FC6E30FA1BA9630" italics="true" pageId="null" pageNumber="544">
tragen. Phyllokladien viel 
<normalizedToken id="1AB8925FF14D77933E5A8DB4A45A9203" originalValue="größer" pageId="null" pageNumber="544">groesser</normalizedToken>
als die oben 
<normalizedToken id="6CB076DC9BBBBFC36D082342232A8707" originalValue="erwähnten" pageId="null" pageNumber="544">erwaehnten</normalizedToken>
<normalizedToken id="46F8830779DAE6F20743A6EAF25A60C5" originalValue="Stengelblätter" pageId="null" pageNumber="544">Stengelblaetter</normalizedToken>
, oberseits
</emphasis>
(wenig unterhalb der Mitte) 
<emphasis id="B7CB8070FBAB628B7BF7073D3983CF4E" italics="true" pageId="null" pageNumber="544">
auf kurzen Stielen 1 bis mehrere kleine 
<normalizedToken id="76CA31F37A310D4A66C5BDF2CF9565E6" originalValue="Blüten" pageId="null" pageNumber="544">Blueten</normalizedToken>
tragend
</emphasis>
(da sich die Phyllokladien oft drehen, sind die 
<normalizedToken id="78AF52BCA2910128E4F2C15B272AC74E" originalValue="Blüten" pageId="null" pageNumber="544">Blueten</normalizedToken>
und 
<normalizedToken id="5E5D387DD807A3740442692F5B8931F4" originalValue="Früchte" pageId="null" pageNumber="544">Fruechte</normalizedToken>
dann scheinbar auf der Unterseite der Phyllokladien). Am Grunde des 
<normalizedToken id="7850108A88C3C8A36951D647DFFDF6AA" originalValue="Blütenstiels" pageId="null" pageNumber="544">Bluetenstiels</normalizedToken>
(oder der 
<normalizedToken id="8A7341AB36D2517CB237E3712C5A64AB" originalValue="Blütenstiele" pageId="null" pageNumber="544">Bluetenstiele</normalizedToken>
) ein kleines Hochblatt vorhanden. 
<emphasis id="17EB16D1239C679B2977A38182C17DFD" italics="true" pageId="null" pageNumber="544">
<normalizedToken id="C166790C21B28B73148CF72F940D5797" originalValue="Blüten" pageId="null" pageNumber="544">Blueten</normalizedToken>
sehr klein, 1geschlechtig
</emphasis>
(in der ♂ 
<normalizedToken id="2BE729600DD4FA47489BD387596E60BA" originalValue="Blüte" pageId="null" pageNumber="544">Bluete</normalizedToken>
oft 
<normalizedToken id="F92D9D6DD5808ECDB71367DFF322ED76" originalValue="rudimentäre" pageId="null" pageNumber="544">rudimentaere</normalizedToken>
♀ 
<normalizedToken id="962E5BEABE73236B534570A5BD4F484F" originalValue="Blütenteile" pageId="null" pageNumber="544">Bluetenteile</normalizedToken>
vorhanden). 
<normalizedToken id="0744787ED7E0A93C0941AA7A15743F60" originalValue="Perigonblätter" pageId="null" pageNumber="544">Perigonblaetter</normalizedToken>
6, frei, die innern kleiner als die 
<normalizedToken id="64F898761B539B5A7D7D87667BED9992" originalValue="äußern" pageId="null" pageNumber="544">aeussern</normalizedToken>
. 
<normalizedToken id="6F9ABC50C8753211F417FE1FD67920AE" originalValue="Staubblätter" pageId="null" pageNumber="544">Staubblaetter</normalizedToken>
3; 
<normalizedToken id="7B0BE436F439BDF90DB289AB99D7F568" originalValue="Staubfäden" pageId="null" pageNumber="544">Staubfaeden</normalizedToken>
zu einer 
<normalizedToken id="F76487C1191DDF22FF4235DA89CDB2AB" originalValue="Röhre" pageId="null" pageNumber="544">Roehre</normalizedToken>
verwachsen. Frucht eine kugelige, 1 
<normalizedToken id="066BC3C0B381E0C8894EE362903C7DBB" originalValue="fächrige" pageId="null" pageNumber="544">faechrige</normalizedToken>
, 1-2 Samen enthaltende Beere; Griffel 1, kurz, mit kopfiger Narbe.
</paragraph>
<paragraph id="E0EE12C29A4C5E373A6BC491E5178106" pageId="null" pageNumber="544">
Die Gattung 
<taxonomicName id="4A865FAAD15C79EA780671E8625577AA" class="Liliopsida" family="Asparagaceae" genus="Ruscus" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="544" phylum="Tracheophyta" rank="genus">
<emphasis id="F55A438A08725BF25FBEDC14683FE009" italics="true" pageId="null" pageNumber="544">Ruscus</emphasis>
</taxonomicName>
<normalizedToken id="82CE4A8BD6A5613AD2DACF0B27A72403" originalValue="umfaßt" pageId="null" pageNumber="544">umfasst</normalizedToken>
<emphasis id="C1562DA6077D6144E4A6B05180F78594" italics="true" pageId="null" pageNumber="544">
5 Arten, die im Mittelmeergebiet und 
<normalizedToken id="E2C40963FC4AB45A73C6A0AAE818E702" originalValue="Südwestasien" pageId="null" pageNumber="544">Suedwestasien</normalizedToken>
vorkommen
</emphasis>
.
</paragraph>
<paragraph id="A9C7BBF439633062EDBB2FACE6A095D9" pageId="null" pageNumber="544">
Alle 3 im Mediterrangebiet vorkommenden Arten, 
<taxonomicName id="F881BF5DB44526CB1B305E08E6D8184E" authority="L., R. Hypophyllum L. und R. Hypoglossum L." authorityName="L., R. Hypophyllum L. und R. Hypoglossum L." class="Liliopsida" family="Asparagaceae" genus="Ruscus" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="544" phylum="Tracheophyta" rank="species" species="aculeatus">
<emphasis id="BD6306785CD38A3D5AE0C17BEB749CE1" italics="true" pageId="null" pageNumber="544">R. aculeatus</emphasis>
<authorityName id="F6AD9E05A92FC70ADFFF3BB3B91C1440" pageId="null" pageNumber="544">L.</authorityName>
, 
<emphasis id="68471523A0E58583609FDBA6C0162DD2" italics="true" pageId="null" pageNumber="544">R. Hypophyllum</emphasis>
<authorityName id="AAE3FAD4016181B21F6D2F1AC5B4676A" pageId="null" pageNumber="544">L.</authorityName>
und 
<emphasis id="6E78106F9AEDE01E63B1806BE66320FB" italics="true" pageId="null" pageNumber="544">R. Hypoglossum</emphasis>
<authorityName id="259C2B23F2AEEB98418B3AC00A672D65" pageId="null" pageNumber="544">L.</authorityName>
</taxonomicName>
haben 
<emphasis id="D25C20E98B5BF4380BBCF54650AAA99F" italics="true" pageId="null" pageNumber="544">2n = 40 Chromosomen</emphasis>
(Chiarugi 1950).
</paragraph>
</subSubSection>
