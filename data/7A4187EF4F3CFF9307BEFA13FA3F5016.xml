<subSubSection id="BAF265724F3FFF9304BBF915FE375108" pageId="18" pageNumber="1286" type="distribution">
<paragraph id="F25736F94F3FFF9304BBF915FE375108" blockId="18.[163,778,1664,1901]" pageId="18" pageNumber="1286">
<emphasis id="C09CEAEB4F3FFF9304BBF915FD8350F2" box="[163,541,1664,1686]" italics="true" pageId="18" pageNumber="1286">
Distribution: 
<taxonomicName id="35E84D7A4F3FFF930541F914FD8350F2" authorityName="Cumberlidge &amp; Daniels" authorityYear="2022" box="[345,541,1665,1686]" class="Malacostraca" family="Potamonautidae" genus="Maritimonautes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="18" pageNumber="1286" phylum="Arthropoda" rank="genus">Maritimonautes</taxonomicName>
</emphasis>
is found mainly in the low-lying eastern coastal region of Africa (an area of about 
<quantity id="35109B1C4F3FFF930540F92BFE6C50B0" box="[344,498,1726,1748]" metricMagnitude="5" metricUnit="m" metricValue="2.5" metricValueMax="3.0" metricValueMin="2.0" pageId="18" pageNumber="1286" unit="km" value="250.0" valueMax="300.0" valueMin="200.0">200–300 km</quantity>
wide inland from the coast as far as the Rift Valley) including 
<collectingCountry id="8AFF76694F3FFF9306B9F949FC9B5096" box="[673,773,1756,1778]" name="Somalia" pageId="18" pageNumber="1286">Somalia</collectingCountry>
, 
<collectingCountry id="8AFF76694F3FFF9304BBF96EFF6A5174" box="[163,244,1787,1808]" name="Kenya" pageId="18" pageNumber="1286">Kenya</collectingCountry>
, 
<collectingCountry id="8AFF76694F3FFF930519F96EFEED5175" box="[257,371,1787,1809]" name="Tanzania" pageId="18" pageNumber="1286">Tanzania</collectingCountry>
(from the east coast of Africa to the north coast of Lake 
<collectingCountry id="8AFF76694F3FFF9305A7F88FFD875154" box="[447,537,1818,1840]" name="Malawi" pageId="18" pageNumber="1286">Malawi</collectingCountry>
, including 
<collectingCountry id="8AFF76694F3FFF930685F88FFC945154" box="[669,778,1818,1840]" name="Tanzania" pageId="18" pageNumber="1286">Tanzania</collectingCountry>
plus 
<collectingCountry id="8AFF76694F3FFF9304C4F8ADFEDA512A" box="[220,324,1848,1870]" name="Tanzania" pageId="18" pageNumber="1286">Zanzibar</collectingCountry>
and 
<collectingRegion id="302CF81B4F3FFF930567F8ADFE50512A" box="[383,462,1848,1870]" country="Tanzania" name="Kusini Pemba" pageId="18" pageNumber="1286">Pemba</collectingRegion>
Islands), 
<collectingCountry id="8AFF76694F3FFF93065AF8ADFD49512A" box="[578,727,1848,1870]" name="Mozambique" pageId="18" pageNumber="1286">Mozambique</collectingCountry>
and 
<collectingCountry id="8AFF76694F3FFF9304BBF8C2FEAB5109" box="[163,309,1879,1901]" name="South Africa" pageId="18" pageNumber="1286">South Africa</collectingCountry>
(
<figureCitation id="6AD32A7C4F3FFF93055EF8C2FE075108" box="[326,409,1879,1901]" captionStart="Figure 8" captionStartId="17.[145,224,1267,1289]" captionTargetBox="[225,1345,195,1227]" captionTargetId="figure-288@17.[225,1345,195,1227]" captionTargetPageId="17" captionText="Figure 8. Maps showing the distributional ranges of (A) Potamonautinae, (B) Maritimonautini, (C) Erimetopini and (D) Potamonautini." figureDoi="http://doi.org/10.5281/zenodo.6461497" httpUri="https://zenodo.org/record/6461497/files/figure.png" pageId="18" pageNumber="1286">Fig. 8C</figureCitation>
