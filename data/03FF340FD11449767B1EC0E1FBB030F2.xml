<taxonomicName id="4C56FE9AD11649767C7BC57BFE1E3017" authority="(Buhl 2002)" baseAuthorityName="Buhl" baseAuthorityYear="2002" class="Insecta" family="Diapriidae" genus="Pantolyta" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="15" pageNumber="72" phylum="Arthropoda" rank="species" species="augustinusii">
<emphasis id="B922590BD11649767C7BC57BFEB73017" italics="true" pageId="15" pageNumber="72">Pantolyta augustinusii</emphasis>
(
<bibRefCitation id="EFC7F8E8D11649767825C518FE263017" author="Buhl P. N." box="[347,477,1111,1137]" pageId="15" pageNumber="72" pagination="57 - 61" refId="ref14115" refString="Buhl P. N. 2002. On a Baltic amber collection of Platygastridae and Diapriidae (Hymenoptera). Entomologiske Meddelelser 70: 57 - 61." type="journal article" year="2002">Buhl 2002</bibRefCitation>
)
</taxonomicName>
; 
<taxonomicName id="4C56FE9AD1164976788EC517FD793017" authorityName="Brazidec &amp; Vilhelmsen" authorityYear="2022" baseAuthorityName="Jouault &amp; Nel" baseAuthorityYear="2020" box="[496,642,1111,1137]" class="Insecta" family="Diapriidae" genus="Pantolyta" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="15" pageNumber="72" phylum="Arthropoda" rank="species" species="perrichoti">
