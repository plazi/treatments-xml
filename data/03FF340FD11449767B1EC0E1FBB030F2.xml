<bibRefCitation id="EFC7F8E8D11649767AEEC535FBC530F2" author="Maneval H." box="[912,1086,1146,1172]" pageId="15" pageNumber="72" pagination="107 - 116" refId="ref15502" refString="Maneval H. 1938. Trois serphoides de l'ambre de la Baltique. Revue francaise d'Entomologie 5 (2): 107 - 116." type="journal article" year="1938">Maneval 1938</bibRefCitation>
