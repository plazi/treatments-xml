<figureCitation id="C0905FBF2D00B842FC53FF0F6EC9FF78" box="[954,1018,175,202]" captionStart="Fig" captionStartId="2.[166,199,1720,1742]" captionTargetBox="[167,1226,975,1693]" captionTargetId="figure-368@2.[167,1226,967,1693]" captionTargetPageId="2" captionText="Fig. 1. Sandpit de Kuilen, location of Mill-Langenboom, in the eastern Noord-Brabant, The Netherlands(Late Miocene)." figureDoi="http://doi.org/10.5281/zenodo.6452221" httpUri="https://zenodo.org/record/6452221/files/figure.png" pageId="2" pageNumber="59">fig. 1.</figureCitation>
