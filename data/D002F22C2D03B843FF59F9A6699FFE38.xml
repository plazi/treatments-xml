Toula, 1897
</taxonomicName>
from the early Sarmatian of 
<collectingCountry id="20BC03AA2D00B842FC9BFEAF6EFAFE98" box="[882,969,271,298]" name="Austria" pageId="2" pageNumber="59">Austria</collectingCountry>
(Nussdorf) and from the middle Sarmatian of the 
<collectingCountry id="20BC03AA2D00B842FE1AFE8F6F60FEF8" box="[499,595,303,330]" name="Ukraine" pageId="2" pageNumber="59">Ukraine</collectingCountry>
and 
<collectingCountry id="20BC03AA2D00B842FD64FE8F6FCAFEF8" box="[653,761,303,330]" name="Moldova" pageId="2" pageNumber="59">Moldova</collectingCountry>
; 
<taxonomicName id="9FAB38B92D00B842FCEDFE90695AFEF8" authority="Koretsky, 2003" authorityName="Koretsky" authorityYear="2003" box="[772,1129,303,330]" class="Mammalia" family="Phocidae" genus="Praepusa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Carnivora" pageId="2" pageNumber="59" phylum="Chordata" rank="species" species="magyaricus">
<emphasis id="6ADF9F282D00B842FCEDFE906E82FEFB" box="[772,945,304,329]" italics="true" pageId="2" pageNumber="59">Pr. magyaricus</emphasis>
<bibRefCitation id="3C3A3ECB2D00B842FC5EFE8F695AFEF8" author="Koretsky, I. A." box="[951,1129,303,330]" pageId="2" pageNumber="59" pagination="63 - 70" refId="ref6865" refString="Koretsky, I. A. New finds of Sarmatian seals (Mammalia: Carnivora: Phocinae) from southern Hungary // Advances in Vertebrate Paleontology / Eds A. Petrulescu, E. Stiuca. - Bucharest, 2003. - P. 63 - 70." type="book chapter" year="2003">Koretsky, 2003</bibRefCitation>
</taxonomicName>
, Sarmatian age of the Vienna Basin. 
<taxonomicName id="9FAB38B92D00B842FE1FFEF06F86FEDB" authority="Koretsky &amp; Peters &amp; Rahmat, 2015" authorityName="Koretsky &amp; Peters &amp; Rahmat" authorityYear="2015" box="[502,693,335,361]" class="Mammalia" family="Phocidae" genus="Praepusa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Carnivora" pageId="2" pageNumber="59" phylum="Chordata" rank="species" species="boeska" status="sp.n.">
<emphasis id="6ADF9F282D00B842FE1FFEF06F86FEDB" box="[502,693,335,361]" italics="true" pageId="2" pageNumber="59">Praepusa boeska</emphasis>
</taxonomicName>
<taxonomicNameLabel id="71EC22532D00B842FD53FEEF6FC0FED8" box="[698,755,335,362]" pageId="2" pageNumber="59" rank="species">sp.n.</taxonomicNameLabel>
, from the Late Miocene — Late Pliocene (Tortonian–Piacenzian Stages, 11.5–3.5 Ma) sandpit de Kuilen, Mill-Langenboom, Noord- 
<collectingRegion id="9A6F8DD82D00B842FF4FFE2F6C35FE18" box="[166,262,399,426]" country="Netherlands" name="Noord-Brabant" pageId="2" pageNumber="59">Brabant</collectingRegion>
, S. E. 
<collectingCountry id="20BC03AA2D00B842FEA2FE2F6CEDFE18" box="[331,478,399,426]" name="Netherlands" pageId="2" pageNumber="59">Netherlands</collectingCountry>
