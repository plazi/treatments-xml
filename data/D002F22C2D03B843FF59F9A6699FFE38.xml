<taxonomicName id="9FAB38B92D00B842FB63FF506F28FE98" authority="Toula, 1897" authorityName="Toula" authorityYear="1897" class="Mammalia" family="Phocidae" genus="Praepusa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Carnivora" pageId="2" pageNumber="59" phylum="Chordata" rank="species" species="vindobonensis">
