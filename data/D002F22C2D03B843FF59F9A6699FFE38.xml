<bibRefCitation id="3C3A3ECB2D01B843FE8BFEAF6F26FE98" author="Koretsky, I. A." box="[354,533,271,298]" pageId="3" pageNumber="60" pagination="63 - 70" refId="ref6865" refString="Koretsky, I. A. New finds of Sarmatian seals (Mammalia: Carnivora: Phocinae) from southern Hungary // Advances in Vertebrate Paleontology / Eds A. Petrulescu, E. Stiuca. - Bucharest, 2003. - P. 63 - 70." type="book chapter" year="2003">Koretsky, 2003</bibRefCitation>
