<taxonomicName id="9FAB38B92D01B843FF47FEB06F26FE98" authority="Koretsky, 2003" authorityName="Koretsky" authorityYear="2003" box="[174,533,271,298]" class="Mammalia" family="Phocidae" genus="Praepusa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Carnivora" pageId="3" pageNumber="60" phylum="Chordata" rank="species" species="magyaricus">
