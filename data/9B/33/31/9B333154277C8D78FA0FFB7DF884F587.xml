<subSubSection box="[1422,2345,2316,2349]" pageId="11" pageNumber="172" type="activity">
<paragraph blockId="11.[1422,2632,1845,2663]" box="[1422,2345,2316,2349]" pageId="11" pageNumber="172">
<emphasis bold="true" box="[1422,1657,2316,2349]" pageId="11" pageNumber="172">Activity patterns.</emphasis>
Jenkins’s Shrew 
<taxonomicName box="[1895,1991,2316,2349]" class="Mammalia" family="Tenrecidae" genus="Tenrec" kingdom="Animalia" order="Afrosoricida" pageId="11" pageNumber="172" phylum="Chordata" rank="genus">Tenrec</taxonomicName>
