<taxonomicName authorityName="Jenkins, Goodman &amp; Raxworthy" authorityYear="1996" class="Mammalia" family="Tenrecidae" genus="Microgale" kingdom="Animalia" order="Afrosoricida" pageId="6" pageNumber="167" phylum="Chordata" rank="species" species="gymnorhyncha">gymnorhyncha</taxonomicName>
