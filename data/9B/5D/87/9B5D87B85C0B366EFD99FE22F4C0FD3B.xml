<collectingCountry box="[841,906,945,966]" name="Kenya" pageId="14" pageNumber="23">Kenya</collectingCountry>
, 
<collectingCountry box="[915,992,945,966]" name="Uganda" pageId="14" pageNumber="23">Uganda</collectingCountry>
