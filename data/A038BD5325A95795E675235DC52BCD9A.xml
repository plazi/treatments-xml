<taxonomicName id="A517F0FBC64BC368262AC01B76846F6E" authority="L." class="Magnoliopsida" family="Apiaceae" genus="Coriandrum" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="868" phylum="Tracheophyta" rank="species" species="sativum">
Coriandrum 
<normalizedToken id="059017377D897B013A50F94458AD74DD" originalValue="satívum" pageId="null" pageNumber="868">sativum</normalizedToken>
<authorityName id="00D912FF56162E8F5963A2555EA40310" pageId="null" pageNumber="868">L.</authorityName>
