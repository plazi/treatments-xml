<subSubSection id="1F27144779900A54C125A26DDABB942A" pageId="null" pageNumber="485" type="vernacular_names">
<paragraph id="91B412A3CB94B36B04AEE348C121667C" pageId="null" pageNumber="485">Punktierte Segge</paragraph>
</subSubSection>
</title>
<subSubSection id="8D9B0FA4A3281E38EF0B69D75524E5F5" pageId="null" pageNumber="485" type="description">
<paragraph id="072206A7D2DB332E6A71C43759AB57B9" pageId="null" pageNumber="485">
20-50 cm hoch; horstbildend. 
<normalizedToken id="F852E8179738949F16457F38C0A15E67" originalValue="Grundständige" pageId="null" pageNumber="485">Grundstaendige</normalizedToken>
Scheiden braun, kahl. 
<normalizedToken id="7502DDCEE8737A3FA9F303C795F92DDE" originalValue="Blätter" pageId="null" pageNumber="485">Blaetter</normalizedToken>
2-4 mm breit, flach, schlaff, kahl, 
<normalizedToken id="B50F16EF0BDF06CCE5CCCC246F9E811F" originalValue="gelbgrün" pageId="null" pageNumber="485">gelbgruen</normalizedToken>
, den 
<normalizedToken id="D441D75E0BBB95BC1DF70D1AB6697D43" originalValue="Blütenstand" pageId="null" pageNumber="485">Bluetenstand</normalizedToken>
nicht erreichend. Stengel stumpf 3kantig, steif aufrecht, undeutlich rauh. 
<normalizedToken id="CA79293D510B8B3E22B975C3C57A3CF2" originalValue="Blütenstand" pageId="null" pageNumber="485">Bluetenstand</normalizedToken>
wie bei 
<taxonomicName id="0A1C390E986E84E7A8A9B69C6E7E17DB" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="485" phylum="Tracheophyta" rank="species" species="distans">
<emphasis id="45D61750E03B65C85A8816E6EADBDA08" italics="true" pageId="null" pageNumber="485">C. distans</emphasis>
</taxonomicName>
(Nr.95). 
<normalizedToken id="1A3854D4BB539CE56DDD7D93A2B7071A" originalValue="Hochblätter" pageId="null" pageNumber="485">Hochblaetter</normalizedToken>
<normalizedToken id="BABCB10EA95F312EEA8DF94D7C53F5C5" originalValue="blattähnlich" pageId="null" pageNumber="485">blattaehnlich</normalizedToken>
, das unterste den 
<normalizedToken id="4D32DC18B286927FD501014C9743081A" originalValue="Blütenstand" pageId="null" pageNumber="485">Bluetenstand</normalizedToken>
oft 
<normalizedToken id="51B7203F89BFEB4811A25F07705E8572" originalValue="überragend" pageId="null" pageNumber="485">ueberragend</normalizedToken>
. 
<normalizedToken id="509AA145E64BB2DF27BBEEF86C88A30B" originalValue="Tragblätter" pageId="null" pageNumber="485">Tragblaetter</normalizedToken>
etwa 
<normalizedToken id="0AE4C1AF9A018CA300FF2CFEB1AB18AE" originalValue="¾" pageId="null" pageNumber="485">3/4</normalizedToken>
so lang wie die reifen 
<normalizedToken id="956628C7277A14606249CF1E067636E4" originalValue="Fruchtschläuche" pageId="null" pageNumber="485">Fruchtschlaeuche</normalizedToken>
, spitz, 
<emphasis id="197BD63A403F14B22154879E2AC5D49F" italics="true" pageId="null" pageNumber="485">hellbraun bis gelb</emphasis>
, mit 
<normalizedToken id="71DEAA64A084C8520A8765C1BBBB9253" originalValue="grünem" pageId="null" pageNumber="485">gruenem</normalizedToken>
Mittelnerv. 
<normalizedToken id="7D52CCBC332C3377010932AA4005E0E6" originalValue="Fruchtschläuche" pageId="null" pageNumber="485">Fruchtschlaeuche</normalizedToken>
3-3,5 mm lang, wenig unterhalb der Mitte am breitesten (1,5-1,8 mm), im Querschnitt 2eckig (
<normalizedToken id="CBF163FD45FF56CF22B6961D69BDF2F9" originalValue="Seitenflächen" pageId="null" pageNumber="485">Seitenflaechen</normalizedToken>
bikonvex), mit 2 
<emphasis id="3F5525E4DB5AF9B3A0BCC52DF4E23F61" italics="true" pageId="null" pageNumber="485">deutlichen Randnerven</emphasis>
(
<normalizedToken id="51095EB8D3D30D8C8CE8FB0ECA7383E8" originalValue="übrige" pageId="null" pageNumber="485">uebrige</normalizedToken>
Nerven undeutlich), 
<emphasis id="F5E832EABF8338A012ED0293398A47A0" italics="true" pageId="null" pageNumber="485">
gelb, 
<normalizedToken id="804D0782A3F6EAB1742FA51B290DB45F" originalValue="glänzend" pageId="null" pageNumber="485">glaenzend</normalizedToken>
</emphasis>
, kahl, 
<normalizedToken id="764D302AE8F67A27A3E2E9E61DD83F30" originalValue="allmählich" pageId="null" pageNumber="485">allmaehlich</normalizedToken>
in den 2 
<normalizedToken id="0C573C03EBB82CB39078AF23D26FFFD3" originalValue="zähnigen" pageId="null" pageNumber="485">zaehnigen</normalizedToken>
Schnabel 
<normalizedToken id="D7EF7CA66D0DBA9FFEBD4C2BE69BC79A" originalValue="verschmälert" pageId="null" pageNumber="485">verschmaelert</normalizedToken>
. Narben 3.
</paragraph>
<paragraph id="5962ACEA2CACD0395A189AB1DE850034" pageId="null" pageNumber="485">
<emphasis id="2EABEF6388BA4D1004C5FAEA42311B36" italics="true" pageId="null" pageNumber="485">Zytologische Angaben. 2n = 68:</emphasis>
Material aus botanischen 
<normalizedToken id="1CE6B6A4E61A84F78213A4F02F66E37E" originalValue="Gärten" pageId="null" pageNumber="485">Gaerten</normalizedToken>
(Heilborn 1924), aus England (Davies 1956a).
</paragraph>
<paragraph id="A1058BB8FB2D92F54BE7DFD5197351B2" pageId="null" pageNumber="485">
<emphasis id="63AD1174D410E29F44178545C34C9D83" italics="true" pageId="null" pageNumber="485">Standort.</emphasis>
Kollin und montan. Quellfluren auf kalkfreien 
<normalizedToken id="BF5D15738C84708979648E91B9FB2569" originalValue="Böden" pageId="null" pageNumber="485">Boeden</normalizedToken>
.
</paragraph>
<paragraph id="835CF9F348FFE6C36720468EB6616F07" pageId="null" pageNumber="485">
<emphasis id="410645E8ED9CA692EDBD21AA56BAF276" italics="true" pageId="null" pageNumber="485">
Verbreitung. 
<normalizedToken id="BC6BB2ED6EEF04CF01E32C0691649B12" originalValue="Westeuropäisch-mediterrane" pageId="null" pageNumber="485">Westeuropaeisch-mediterrane</normalizedToken>
Pflanze:
</emphasis>
Mediterrangebiet (auch Nordafrika und Westasien) 
<normalizedToken id="8C66A2EB5DE87AB476C873A41BE1E894" originalValue="nordwärts" pageId="null" pageNumber="485">nordwaerts</normalizedToken>
bis in die 
<normalizedToken id="919881AA7D4950F157DAD2C7C2156393" originalValue="südlichen" pageId="null" pageNumber="485">suedlichen</normalizedToken>
<normalizedToken id="AEF5389DC4675748FD0105365324A8B7" originalValue="Alpentäler" pageId="null" pageNumber="485">Alpentaeler</normalizedToken>
(
<normalizedToken id="19C58593302E8F1C640E00F65A89A638" originalValue="für" pageId="null" pageNumber="485">fuer</normalizedToken>
die Ostalpen viele Angaben von Widder 1958); Westfrankreich, 
<normalizedToken id="AA44B72F28A74BB1610D21A35546C771" originalValue="Südengland" pageId="null" pageNumber="485">Suedengland</normalizedToken>
, 
<normalizedToken id="D1560C430E6D2EFAE699D391743CB29D" originalValue="Südskandinavien" pageId="null" pageNumber="485">Suedskandinavien</normalizedToken>
, 
<normalizedToken id="3AE7B57DB8E2963EFE6E123E4608ED19" originalValue="Ostpreußen" pageId="null" pageNumber="485">Ostpreussen</normalizedToken>
. - Im Gebiet: Wallis (Lalden 
<normalizedToken id="AFF642F64B027DF209CD3BE2D40932AC" originalValue="nordöstlich" pageId="null" pageNumber="485">nordoestlich</normalizedToken>
Visp, Gondo), Piemont, Tessin und 
<normalizedToken id="7E5E1994CA2AA08A886E720AD75D8CB5" originalValue="östlich" pageId="null" pageNumber="485">oestlich</normalizedToken>
angrenzende Gebiete, 
<normalizedToken id="87DB665D4F309828F41FFD94ABEE3E4D" originalValue="Graubünden" pageId="null" pageNumber="485">Graubuenden</normalizedToken>
, (isoliert bei Disentis, Bergell, Puschlav, 
<normalizedToken id="1CECE8157FA917613640F28390FC6AA9" originalValue="Münstertal" pageId="null" pageNumber="485">Muenstertal</normalizedToken>
), Veltlin, Vintschgau.
</paragraph>
</subSubSection>
