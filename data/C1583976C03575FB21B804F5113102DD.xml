<subSubSection id="31E42BAC05001EE5207456480B4297E2" pageId="null" pageNumber="306" type="description">
<paragraph id="860D21806439938EBE38937BCCAAC28D" pageId="null" pageNumber="306">
Unterscheidet sich durch folgende Merkmale von 
<taxonomicName id="518B785104512B268C3F8697E88C993A" class="Magnoliopsida" family="Grossulariaceae" genus="Ribes" kingdom="Plantae" order="Saxifragales" pageId="null" pageNumber="306" phylum="Tracheophyta" rank="species" species="nigrum">
<emphasis id="7C83EB8B15A8C33353FEDF2C6DDF4001" italics="true" pageId="null" pageNumber="306">R. nigrum</emphasis>
</taxonomicName>
(Nr. 2): 
<emphasis id="98E75141069099BF3A3161CEC698EDB2" italics="true" pageId="null" pageNumber="306">
<normalizedToken id="6284D45C71A1F9592E6E136284788507" originalValue="Blätter" pageId="null" pageNumber="306">Blaetter</normalizedToken>
ohne sitzende 
<normalizedToken id="467E5B188BD86BC9D588D676FA3C2DFE" originalValue="Drüsen" pageId="null" pageNumber="306">Druesen</normalizedToken>
; 
<normalizedToken id="A0A898FAC003EC74D9AF8A0E6C53C56E" originalValue="Kelchblätter" pageId="null" pageNumber="306">Kelchblaetter</normalizedToken>
<normalizedToken id="00674DA19A2FFF9422A49F462D5DE926" originalValue="vollständig" pageId="null" pageNumber="306">vollstaendig</normalizedToken>
kahl; 
<normalizedToken id="92033C12030947C5B792899A6C2A1F2E" originalValue="Kronblätter" pageId="null" pageNumber="306">Kronblaetter</normalizedToken>
etwa
</emphasis>
⅓ 
<emphasis id="BC89786210852F90F34163DBD1FA16FA" italics="true" pageId="null" pageNumber="306">
so lang wie die 
<normalizedToken id="1FBEC3DE5E2880E842C4A20751264B9D" originalValue="Kelchblätter" pageId="null" pageNumber="306">Kelchblaetter</normalizedToken>
; Beeren rot.
</emphasis>
- 
<normalizedToken id="60B9D217F4C550C9DDE2AE8DAD8B5E55" originalValue="Blüte" pageId="null" pageNumber="306">Bluete</normalizedToken>
: 
<normalizedToken id="9F137B6E46977970C7B9DFBE594858F7" originalValue="Frühling" pageId="null" pageNumber="306">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="FFE0140AA9FDF9DDED7B486C39B4A81E" pageId="null" pageNumber="306">
<emphasis id="76CA58540A52F584684184FBC9A3051D" italics="true" pageId="null" pageNumber="306">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D909A2563B92BB7BBE3ECC61D74CB811" italics="true" pageId="null" pageNumber="306">16</emphasis>
(s. unter Gattung).
</paragraph>
<paragraph id="511D65B57ACA30797EE23AE0CD7392A1" pageId="null" pageNumber="306">
<emphasis id="7D6642062A953367BCAF827110B4C444" italics="true" pageId="null" pageNumber="306">Standort.</emphasis>
Kollin und montan, selten subalpin. Feuchte 
<normalizedToken id="DF2055C1C813187AB6D6EB2A7AFA3110" originalValue="Wälder" pageId="null" pageNumber="306">Waelder</normalizedToken>
, 
<normalizedToken id="C24BDE1F6A1E22FA7BD9D423688C447B" originalValue="Gebüsche" pageId="null" pageNumber="306">Gebuesche</normalizedToken>
.
</paragraph>
<paragraph id="728D9A89D9B5FA2F6DC4B38D1B405185" pageId="null" pageNumber="306">
<emphasis id="6417DC8877CA722F57C6EB1271B27238" italics="true" pageId="null" pageNumber="306">Verbreitung.</emphasis>
<normalizedToken id="F310A73CB20BA5673430A3B0119B807B" originalValue="Ursprünglich" pageId="null" pageNumber="306">Urspruenglich</normalizedToken>
wahrscheinlich 
<emphasis id="7F1CC3DDBD3C4831D9264A972D9A3294" italics="true" pageId="null" pageNumber="306">
<normalizedToken id="F4003ACAA93753C9819436CF00139DE9" originalValue="westeuropäische" pageId="null" pageNumber="306">westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="43703320A7C0A26C8F23759FEDF862D5" originalValue="Häufig" pageId="null" pageNumber="306">Haeufig</normalizedToken>
kultiviert, aus dem Mediterrangebiet nicht angegeben. - Im Gebiet verbreitet in 
<normalizedToken id="EF90D4E88CA8DA86F13FBA0305958C9B" originalValue="Gärten" pageId="null" pageNumber="306">Gaerten</normalizedToken>
, gelegentlich verwildert.
</paragraph>
</subSubSection>
