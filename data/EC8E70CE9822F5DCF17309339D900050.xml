<subSubSection id="559A8D4FD5E552F9D8280D834AD8DDE8" pageId="null" pageNumber="590" type="description">
<paragraph id="E4F4F3604009C059FB96F47D2ACDB3CF" pageId="null" pageNumber="590">
<emphasis id="A089AB9D32455C4AD55E9D7A2F6A1BC1" italics="true" pageId="null" pageNumber="590">Pflanze distelartig</emphasis>
. 
<normalizedToken id="46441A3C2690F89FDB93212C55D40E78" originalValue="Köpfe" pageId="null" pageNumber="590">Koepfe</normalizedToken>
<normalizedToken id="2991CC35DA6977CF533EFE9BBF36B978" originalValue="vielblütig" pageId="null" pageNumber="590">vielbluetig</normalizedToken>
. 
<emphasis id="D9D218850F1D991370C2A530E5B217A5" italics="true" pageId="null" pageNumber="590">
Boden des 
<normalizedToken id="E9245ED5E763746C36265F448F83927F" originalValue="Blütenkopfes" pageId="null" pageNumber="590">Bluetenkopfes</normalizedToken>
mit 
<normalizedToken id="3A6FF1303C409210BACCA2D73FD79C81" originalValue="Spreublättern" pageId="null" pageNumber="590">Spreublaettern</normalizedToken>
</emphasis>
. 
<normalizedToken id="70D508A2C877C4DBAF5B04837E4FF58A" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
gelb; 
<normalizedToken id="75FB7EEDF6F673CBBFEDC6E2CF29D255" originalValue="Kronröhre" pageId="null" pageNumber="590">Kronroehre</normalizedToken>
<normalizedToken id="8FD169AA75FECAAEEDC646FA9F807059" originalValue="außen" pageId="null" pageNumber="590">aussen</normalizedToken>
im obern Teil und innen behaart. 
<normalizedToken id="29B91D7F6DFD5E7319245456BA37B79C" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
abgeflacht, 
<emphasis id="484D924F605B2DDBBAE8D9EE13626C4F" italics="true" pageId="null" pageNumber="590">
die 
<normalizedToken id="9A169B7A3FAC8B653D2A1B00D94E1A50" originalValue="äußern" pageId="null" pageNumber="590">aeussern</normalizedToken>
von den 
<normalizedToken id="3AEBE99B480669CA79022D77C38254C5" originalValue="Spreublättern" pageId="null" pageNumber="590">Spreublaettern</normalizedToken>
eingeschlossen und deshalb 
<normalizedToken id="8AE455647B6EB8549F0A499289521C8A" originalValue="geflügelt" pageId="null" pageNumber="590">gefluegelt</normalizedToken>
erscheinend. 
<taxonomicName id="ED06856F6BA7F8E5376AFCD342D94024" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
nicht vorhanden oder nur aus 2
</emphasis>
- 
<emphasis id="DD0C9B3A27C4FD82F5764C71387A505B" italics="true" pageId="null" pageNumber="590">4 rauhen, kurzen Borsten</emphasis>
bestehend.
</paragraph>
<paragraph id="8F06359BB94CC7AED21F59DE4E4654C8" pageId="null" pageNumber="590">
Die Gattung 
<taxonomicName id="36ADC15B99E3D7F53FD42A14C9D2C3EB" class="Magnoliopsida" family="Asteraceae" genus="Scolymus" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="genus">
<emphasis id="2797C2D8EFABD85B5188C6AFAA67629D" italics="true" pageId="null" pageNumber="590">Scolymus</emphasis>
</taxonomicName>
<normalizedToken id="3AB87DD02BE470B25DF70E1D2C9C96E4" originalValue="umfaßt" pageId="null" pageNumber="590">umfasst</normalizedToken>
<emphasis id="48DA22ABDC7C3FEEFF6B2E585BBA6A8C" italics="true" pageId="null" pageNumber="590">4 mediterrane Arten</emphasis>
.
</paragraph>
