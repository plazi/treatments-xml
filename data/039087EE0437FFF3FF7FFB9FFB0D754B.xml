<subSubSection id="C32365730434FFF3FF2FFCBEFCC7724F" box="[199,780,835,861]" pageId="6" pageNumber="327" type="etymology">
<paragraph id="8B8636F80434FFF3FF2FFCBEFCC7724F" blockId="6.[151,1437,150,1113]" box="[199,780,835,861]" pageId="6" pageNumber="327">
<emphasis id="B94DEAEA0434FFF3FF2FFCBEFE83724F" bold="true" box="[199,328,835,861]" pageId="6" pageNumber="327">Etymology</emphasis>
. Named for the costulae on propodeum.
</paragraph>
