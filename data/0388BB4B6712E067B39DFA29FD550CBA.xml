(
<bibRefCitation id="EFB077AC6712E064B2ABF98EFDD609DC" author="Semeria, Y." box="[417,569,1651,1676]" pageId="17" pageNumber="78" pagination="199 - 202" refId="ref20304" refString="Semeria, Y. (1976) Contribution a la connaissance des Chrysopides de France (Planipennia, Chrysopidae). Troisieme serie: Les Alpes-Maritimes, 1974. Entomops, Nice, 38, 199 - 202." type="journal article" year="1976">Séméria, 1976</bibRefCitation>
