<paragraph id="8B9E0A5D6712E064B39DF968FB80099E" blockId="17.[151,1436,1559,1737]" pageId="17" pageNumber="78">
<taxonomicName id="4C2171DE6712E064B39DF968FE5109FD" authority="(Séméria, 1976)" box="[151,446,1682,1706]" class="Insecta" family="Chrysopidae" genus="Mallada" kingdom="Animalia" order="Neuroptera" pageId="17" pageNumber="78" phylum="Arthropoda" rank="subSpecies" species="ventralis" subSpecies="benedictus">
<emphasis id="B955D64F6712E064B39DF968FE5109FD" box="[151,446,1682,1706]" italics="true" pageId="17" pageNumber="78">Mallada ventralis benedictus</emphasis>
</taxonomicName>
[sic] (
<bibRefCitation id="EFB077AC6712E064B2F5F968FD7B09FD" author="Semeria, Y." box="[511,660,1682,1706]" pageId="17" pageNumber="78" pagination="199 - 202" refId="ref20304" refString="Semeria, Y. (1976) Contribution a la connaissance des Chrysopides de France (Planipennia, Chrysopidae). Troisieme serie: Les Alpes-Maritimes, 1974. Entomops, Nice, 38, 199 - 202." type="journal article" year="1976">Séméria, 1976</bibRefCitation>
) was synonymized with 
<taxonomicName id="4C2171DE6712E064B09AF968FAFE09FD" authority="(Schneider, 1851)" baseAuthorityName="Schneider" baseAuthorityYear="1851" box="[912,1297,1682,1706]" class="Insecta" family="Chrysopidae" genus="Dichochrysa" kingdom="Animalia" order="Neuroptera" pageId="17" pageNumber="78" phylum="Arthropoda" rank="species" species="zelleri">
<emphasis id="B955D64F6712E064B09AF968FBB809FD" box="[912,1111,1682,1706]" italics="true" pageId="17" pageNumber="78">Dichochrysa zelleri</emphasis>
(
<bibRefCitation id="EFB077AC6712E064B76EF968FAE409FD" author="Schneider, W. G." box="[1124,1291,1682,1706]" pageId="17" pageNumber="78" refId="ref20212" refString="Schneider, W. G. (1851) Symbolae ad Monographiam generis Chrysopae, Leach. Sexaginta picturarum tabulis, in lapide acu delineatis, quarum quinquaginta quatuor coloribus impressae sunt, illustratae. Ferdinandum Hirt, Vratislaviae, 178 pp. https: // doi. org / 10.5962 / bhl. title. 8500" type="book" year="1851">Schneider, 1851</bibRefCitation>
)
</taxonomicName>
by 
<bibRefCitation id="EFB077AC6712E064B63CF968FECC099E" author="Aspock, H. &amp; Holzel, H. &amp; Aspock, U." pageId="17" pageNumber="78" pagination="1 - 606" refId="ref17990" refString="Aspock, H., Holzel, H. &amp; Aspock, U. (2001) Kommentierter Katalog der Neuropterida (Insecta: Raphidioptera, Megaloptera, Neuroptera) der Westpalaarktis. Denisia, 2, 1 - 606." type="journal article" year="2001">
Aspöck 
<emphasis id="B955D64F6712E064B680F969FF0D099E" italics="true" pageId="17" pageNumber="78">et al.</emphasis>
, 2001
</bibRefCitation>
, but the two species look different in almost every morphological trait treated here.
</paragraph>
