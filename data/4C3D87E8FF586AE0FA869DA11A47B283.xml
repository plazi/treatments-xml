<subSubSection id="8C8E6575FF586AE7FA859A9417A9B627" pageId="163" pageNumber="925" type="discussion">
<paragraph id="C42B36FEFF586AE7FA859A9417A9B627" blockId="163.[1399,2607,3198,3470]" pageId="163" pageNumber="925">
Subgenus Pyzonux; 
<taxonomicName id="03944D7DFF586AE7F9749A9418FDB7DC" baseAuthorityName="Le Conte" baseAuthorityYear="1831" box="[1672,1789,3277,3310]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="163" pageNumber="925" phylum="Chordata" rank="species" species="lucifugus">lucifugus</taxonomicName>
species group. Populations of 
<taxonomicName id="03944D7DFF586AE7F73F9A941784B7DC" authorityName="Merriam" authorityYear="1886" box="[2243,2436,3277,3310]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="163" pageNumber="927" phylum="Chordata" rank="species" species="ciliolabrum">M. ciliolabrum</taxonomicName>
