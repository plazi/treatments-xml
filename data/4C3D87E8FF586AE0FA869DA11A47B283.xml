<taxonomicName id="03944D7DFF586AE7F9D99AAD189CB627" baseAuthorityName="Merriam" baseAuthorityYear="1895" box="[1573,1692,3316,3349]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="163" pageNumber="925" phylum="Chordata" rank="species" species="keenii">M. keenii</taxonomicName>
, M. leibir, M. 
<taxonomicName id="03944D7DFF586AE7F8A99AAD19D1B627" box="[1877,2001,3316,3349]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="163" pageNumber="925" phylum="Chordata" rank="species" species="subulatus">subulatus</taxonomicName>
, and 
<taxonomicName id="03944D7DFF586AE7F7DC9AAD16FDB627" baseAuthorityName="Merriam" baseAuthorityYear="1890" box="[2080,2301,3316,3349]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="163" pageNumber="926" phylum="Chordata" rank="species" species="melanorhinus">M. melanorhinus</taxonomicName>
. Monotypic.
</paragraph>
</subSubSection>
