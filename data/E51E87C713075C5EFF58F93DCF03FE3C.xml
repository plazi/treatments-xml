<subSubSection id="25AD655A13005C5EFF2DFF2DCF03FE3C" pageId="4" pageNumber="457" type="description">
<paragraph id="6D0836D113005C5EFF2DFF2DC988FEBF" blockId="4.[166,1225,175,394]" pageId="4" pageNumber="457">
D i s t r i b u t i o n. British Isles, Czech Republic, France, Germany, Hungary, Lithuania, Slovakia, Switzerland (
<bibRefCitation id="09264B2013005C5EFE47FF52CFBDFF5F" author="Papp, L. &amp; Cerny, M." box="[433,680,207,234]" pageId="4" pageNumber="457" refId="ref19613" refString="Papp, L. &amp; Cerny, M. 2015. Agromyzidae (Diptera) of Hungary. Volume 1. Agromyzinae. Nagykovacsi, Pars Ltd., 1 - 416. DOI: http: // doi. org / 10.18655 / Agromyzidae. Vol. 1." type="book" year="2015">Papp &amp; Černý, 2015</bibRefCitation>
). 
<emphasis id="5FC3EAC313005C5EFD4AFF52CE5EFF5C" bold="true" box="[700,843,207,233]" pageId="4" pageNumber="457">
In 
<collectingCountry id="15A0764113005C5EFD29FF52CE50FF5C" box="[735,837,207,233]" name="Ukraine" pageId="4" pageNumber="457">Ukraine</collectingCountry>
.
</emphasis>
<collectingRegion id="AF73F83313005C5EFCA5FF52C907FF5C" box="[851,1042,207,233]" country="Ukraine" name="Dnipropetrovs'k" pageId="4" pageNumber="457">Dnipropetrovsk</collectingRegion>
, 
<collectingRegion id="AF73F83313005C5EFBEBFF52C96AFF5C" box="[1053,1151,207,233]" country="Ukraine" name="Kharkiv" pageId="4" pageNumber="457">Kharkiv</collectingRegion>
, 
<collectingRegion id="AF73F83313005C5EFB7DFF52C9D1FF5C" box="[1163,1220,207,233]" country="Ukraine" name="Kyiv" pageId="4" pageNumber="457">Kyiv</collectingRegion>
, 
<collectingRegion id="AF73F83313005C5EFF50FF72CDE8FEBC" box="[166,253,239,265]" country="Ukraine" name="Poltava" pageId="4" pageNumber="457">Poltava</collectingRegion>
and 
<collectingRegion id="AF73F83313005C5EFEC1FF72CC6FFEBC" box="[311,378,239,265]" country="Ukraine" name="Sumy" pageId="4" pageNumber="457">Sumy</collectingRegion>
Regions (
<bibRefCitation id="09264B2013005C5EFE18FF72CF99FEBF" author="Guglya, Yu." box="[494,652,239,266]" pageId="4" pageNumber="457" pagination="29 - 38" refId="ref19304" refString="Guglya, Yu. 2015. A study of the fauna of leaf-miner flies of the subfamily Agromyzinae (Diptera: Agromyzidae) of Ukraine. Report 3. Eleven new species for the fauna of Ukraine. The Kharkov Entomological Society Gazette, 23 (2), 29 - 38." type="journal article" year="2015">Guglya, 2015</bibRefCitation>
, 
<bibRefCitation id="09264B2013005C5EFD61FF72CFF0FEBF" author="Guglya, Yu." box="[663,741,239,266]" pageId="4" pageNumber="457" pagination="17 - 24" refId="ref19357" refString="Guglya, Yu. 2016 a. A study of the fauna of leaf-miner flies of the subfamily Agromyzinae (Diptera: Agromyzidae) of Ukraine. Report 4. Thirteen new species for the fauna of Ukraine. The Kharkov Entomological Society Gazette, 24 (2), 17 - 24. URL: http: // nbuv. gov. ua / UJRN / Vkhet _ 2016 _ 24 _ 2 _ 7" type="journal article" year="2016">2016 a</bibRefCitation>
, 
<bibRefCitation id="09264B2013005C5EFD06FF72CE38FEBF" author="Guglya, Yu." box="[752,813,239,266]" pageId="4" pageNumber="457" pagination="48 - 56" refId="ref19484" refString="Guglya, Yu. 2017. A study of the fauna of leaf-miner flies of the subfamily Agromyzinae (Diptera: Agromyzidae) of Ukraine. Report 5. Seven new species for the fauna of Ukraine. The Kharkov Entomological Society Gazette, 25 (1), 48 - 56." type="journal article" year="2017">2017</bibRefCitation>
); 
<collectingRegion id="AF73F83313005C5EFCB6FF72CEE7FEBC" box="[832,1010,239,265]" country="Ukraine" name="Zakarpattya" pageId="4" pageNumber="457">Transcarpathia</collectingRegion>
(
<emphasis id="5FC3EAC313005C5EFBF5FF72C99EFEBC" bold="true" box="[1027,1163,239,265]" pageId="4" pageNumber="457">first record</emphasis>
).
</paragraph>
<paragraph id="6D0836D113005C5EFF2DFE92CF03FE3C" blockId="4.[166,1225,175,394]" pageId="4" pageNumber="457">
Bionomics. This species is common in most of 
<collectingCountry id="15A0764113005C5EFCC6FE92CE86FE9C" box="[816,915,271,297]" name="Ukraine" pageId="4" pageNumber="457">Ukraine</collectingCountry>
. Ukrainian material dates from 4 May to 11 August and occurs on various localities, where its host plant 
<taxonomicName id="AAB74D5213005C5EFBB8FEB2CDD9FEDC" class="Magnoliopsida" family="Fabaceae" genus="Astragalus" kingdom="Plantae" order="Fabales" pageId="4" pageNumber="457" phylum="Tracheophyta" rank="species" species="spp">
<emphasis id="5FC3EAC313005C5EFBB8FEB2CDD9FEDC" italics="true" pageId="4" pageNumber="457">Astragalus spp</emphasis>
</taxonomicName>
. (
<taxonomicName id="AAB74D5213005C5EFF15FED2CC47FEDF" box="[227,338,335,362]" class="Magnoliopsida" family="Fabaceae" kingdom="Plantae" order="Fabales" pageId="4" pageNumber="457" phylum="Tracheophyta" rank="family">Fabaceae</taxonomicName>
) grows, but 
<specimenCount id="7BB1FD5813005C5EFE10FECDCF9DFEDC" box="[486,648,335,362]" pageId="4" pageNumber="457" type="generic">one specimen</specimenCount>
was caught in a small desert where only 
<taxonomicName id="AAB74D5213005C5EFB86FECDCC1FFE3C" class="Magnoliopsida" family="Fabaceae" genus="Genista" kingdom="Plantae" order="Fabales" pageId="4" pageNumber="457" phylum="Tracheophyta" rank="species" species="tinctoria">
<emphasis id="5FC3EAC313005C5EFB86FECDCC1FFE3C" italics="true" pageId="4" pageNumber="457">Genista tinctoria</emphasis>
</taxonomicName>
(
<taxonomicName id="AAB74D5213005C5EFEEEFEF2CC92FE3F" box="[280,391,367,394]" class="Magnoliopsida" family="Fabaceae" kingdom="Plantae" order="Fabales" pageId="4" pageNumber="457" phylum="Tracheophyta" rank="family">Fabaceae</taxonomicName>
) was found.
</paragraph>
