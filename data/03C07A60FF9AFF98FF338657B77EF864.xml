<paragraph id="8BD6CB76FF9AFF98FF33816DB07CFBC4" blockId="3.[151,1437,1060,1987]" pageId="3" pageNumber="526">
<emphasis id="B91D1764FF9AFF98FF33816DB5E2FB98" bold="true" box="[151,412,1060,1086]" pageId="3" pageNumber="526">Specimens examined.</emphasis>
Two females on 
<taxonomicName id="4C69B0F5FF9AFF98FDD4816DB7DAFB98" box="[624,932,1060,1086]" class="Liliopsida" family="Poaceae" genus="Andropogon" kingdom="Plantae" order="Poales" pageId="3" pageNumber="526" phylum="Tracheophyta" rank="species" species="leucostachyus">
<emphasis id="B91D1764FF9AFF98FDD4816DB7DAFB98" box="[624,932,1060,1086]" italics="true" pageId="3" pageNumber="526">Andropogon leucostachyus</emphasis>
</taxonomicName>
(
<taxonomicName id="4C69B0F5FF9AFF98FC1C816DB064FB98" authorityName="Barnhart" authorityYear="1895" baseAuthorityName="R.Br." box="[952,1050,1060,1086]" class="Liliopsida" family="Poaceae" kingdom="Plantae" order="Poales" pageId="3" pageNumber="526" phylum="Tracheophyta" rank="family">Poaceae</taxonomicName>
); pedestrian grasslands, Mucugê, Chapada Diamantina, 
<geoCoordinate id="EE5DADB1FF9AFF98FE358101B66BFBC5" box="[401,533,1096,1123]" degrees="12" direction="south" minutes="53" orientation="latitude" pageId="3" pageNumber="526" precision="15" seconds="49" value="-12.896944">12º53’49”S</geoCoordinate>
, 
<geoCoordinate id="EE5DADB1FF9AFF98FD858101B6D3FBC5" box="[545,685,1096,1123]" degrees="41" direction="west" minutes="18" orientation="longitude" pageId="3" pageNumber="526" precision="15" seconds="58" value="-41.31611">41º18’58”W</geoCoordinate>
, 
<quantity id="4C916693FF9AFF98FD1D8101B773FBC5" box="[697,781,1096,1123]" metricMagnitude="3" metricUnit="m" metricValue="1.125" pageId="3" pageNumber="526" unit="m" value="1125.0">1125 m</quantity>
asl; 
<date id="FFD7EDB6FF9AFF98FCE68101B781FBC4" box="[834,1023,1096,1123]" pageId="3" pageNumber="526" value="2012-01-19">19 January 2012</date>
.
</paragraph>
