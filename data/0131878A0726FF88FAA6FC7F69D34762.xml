<taxonomicName id="4E984D1F0726FF89F7A6FAE563E2433F" authorityName="Merriam" authorityYear="1895" box="[2133,2285,1308,1341]" class="Mammalia" family="Geomyidae" genus="Geomys" kingdom="Animalia" order="Rodentia" pageId="10" pageNumber="243" phylum="Chordata" rank="species" species="attwateri">G. attwateri</taxonomicName>
. Six subspecies recognized.
</paragraph>
</subSubSection>
