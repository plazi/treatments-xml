<subSubSection id="C18265170726FF89F845FB856322436A" pageId="10" pageNumber="243" type="reference_group">
<paragraph id="8927369C0726FF89F845FB856CF342F3" blockId="10.[1974,2568,1148,1576]" pageId="10" pageNumber="243">
<emphasis id="BBECEA8E0726FF89F845FB85635E429F" bold="true" box="[1974,2129,1148,1181]" pageId="10" pageNumber="243">Taxonomy.</emphasis>
<taxonomicName id="4E984D1F0726FF89F795FB85610F429F" authority="True, 1889" authorityName="True" authorityYear="1889" box="[2150,2560,1148,1181]" class="Mammalia" family="Geomyidae" genus="Geomys" kingdom="Animalia" order="Rodentia" pageId="10" pageNumber="243" phylum="Chordata" rank="species" species="personatus">Geomys personatus True, 1889</taxonomicName>
