azorica
</emphasis>
(Seub.) J. Franco
</taxonomicName>
(
<taxonomicName id="04440A272E46A84889B72FF8C913B892" authority="Webb" authorityName="Webb" class="Magnoliopsida" family="Lauraceae" genus="Laurus" kingdom="Plantae" order="Laurales" phylum="Tracheophyta" rank="species" species="canariensis">
<emphasis id="0BFCD699D40BFDA6725D2B0981C4E765" italics="true">
<authorityName id="71B3B69598B35B7211C6181457A49BD2">L.</authorityName>
