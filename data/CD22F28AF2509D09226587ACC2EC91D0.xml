</emphasis>
Webb
</taxonomicName>
). 
<taxonomicName id="F916C1E99A8C72E0B418DA12A4F6827A" class="Magnoliopsida" family="Lauraceae" genus="Laurus" kingdom="Plantae" order="Laurales" phylum="Tracheophyta" rank="species" species="azorica">
