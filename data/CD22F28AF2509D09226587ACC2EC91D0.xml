<taxonomicName id="D6B8E79F31F537D105096047FF75C5A8" authority="(Seub.) J. Franco" authorityName="J. Franco" baseAuthorityName="Seub." class="Magnoliopsida" family="Lauraceae" genus="Laurus" kingdom="Plantae" order="Laurales" phylum="Tracheophyta" rank="species" species="azorica">
