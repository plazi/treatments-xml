</taxonomicName>
<normalizedToken id="55B0791E3C929AFBF6C002779504BCF7" originalValue="umfaßt">umfasst</normalizedToken>
<emphasis id="9304C2BDF59BCB7B481A487BB2B4B816" italics="true">
2 Arten, 
<taxonomicName id="84752F38FEF468E8C09F2E051B517AF0" class="Magnoliopsida" family="Lauraceae" genus="Laurus" kingdom="Plantae" order="Laurales" phylum="Tracheophyta" rank="species" species="nobilis">
<authorityName id="2F30B43E002810BABE1B030F89C10D72">L.</authorityName>
nobilis
</taxonomicName>
</emphasis>
