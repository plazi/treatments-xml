<subSubSection id="88F2B53C4971A3CB6369BD1FF6CB322A" pageId="null" pageNumber="49" type="description">
<paragraph id="B92BBF8A884B0536A0BB31AA827AEC31" pageId="null" pageNumber="49">
Ausdauernde 
<normalizedToken id="885AD1280313943B7E9C8D7A12F0D226" originalValue="Kräuter" pageId="null" pageNumber="49">Kraeuter</normalizedToken>
. 
<emphasis id="A8FDB9C6E387BFFD736FF58BF2144A2E" italics="true" pageId="null" pageNumber="49">
<normalizedToken id="E4CE58ADDB5FAF4FE5A5AE3FE7835904" originalValue="Blätter" pageId="null" pageNumber="49">Blaetter</normalizedToken>
gefiedert, mit Endteilblatt
</emphasis>
(unpaarig gefiedert), 
<normalizedToken id="C4C781E62B3618D1EE7D74D14C930126" originalValue="wechselständig" pageId="null" pageNumber="49">wechselstaendig</normalizedToken>
. 
<normalizedToken id="63425AF819DCD558B8E18DDFDA0AF382" originalValue="Blüten" pageId="null" pageNumber="49">Blueten</normalizedToken>
in wenig- bis 
<normalizedToken id="402859D78EF6FD27A9067BDBD816B73C" originalValue="vielblütigen" pageId="null" pageNumber="49">vielbluetigen</normalizedToken>
, traubigen oder rispigen 
<normalizedToken id="424602EA292E3C9BC08026511274CE5E" originalValue="Blütenständen" pageId="null" pageNumber="49">Bluetenstaenden</normalizedToken>
. Kelch 
<normalizedToken id="8C4C7D47356A3141A1E7994B93C58581" originalValue="grün" pageId="null" pageNumber="49">gruen</normalizedToken>
, 
<emphasis id="6F05168B61C60C862E4A6A68B48D0CC7" italics="true" pageId="null" pageNumber="49">an der Frucht mit aufrechten Zipfeln.</emphasis>
Krone blau, 
<normalizedToken id="8DC6D9E9E44C6D7EF5FF3F417B5030AF" originalValue="weiß" pageId="null" pageNumber="49">weiss</normalizedToken>
oder rot, 
<emphasis id="3D39705C129D5F5D9D9BE748A4CB899C" italics="true" pageId="null" pageNumber="49">
weit 
<normalizedToken id="3FE29A161514AEB0E71DF943EC464123" originalValue="trichterförmig" pageId="null" pageNumber="49">trichterfoermig</normalizedToken>
. 
<normalizedToken id="471BB38D75065371468EEAFA556C9C68" originalValue="Staubblätter" pageId="null" pageNumber="49">Staubblaetter</normalizedToken>
alle auf
</emphasis>
<emphasis id="0A64E2D6C3358272C8AE27C94A3C5323" italics="true" pageId="null" pageNumber="49">
<pageBreakToken id="5A38BC18789314D89965C12A58E85B25" pageId="null" pageNumber="49">derselben</pageBreakToken>
<normalizedToken id="4EC5665280EB5882A717F2683ECA385D" originalValue="Höhe" pageId="null" pageNumber="49">Hoehe</normalizedToken>
, am obern Rande der sehr kurzen 
<normalizedToken id="96488BC2941108ADB717D708B6B711C4" originalValue="Kronröhre" pageId="null" pageNumber="49">Kronroehre</normalizedToken>
angewachsen, am Grunde innerseits mit krausem Haarschopf.
</emphasis>
Kapsel wenig- bis vielsamig.
</paragraph>
<paragraph id="F1DBAB9F9FA42225BEC461A7325DC3B1" pageId="null" pageNumber="49">
Die Gattung 
<taxonomicName id="22F3B4FB089482D27C22D74C3F70E875" class="Magnoliopsida" family="Polemoniaceae" genus="Polemonium" kingdom="Plantae" order="Ericales" pageId="null" pageNumber="49" phylum="Tracheophyta" rank="genus">
<emphasis id="E6F62CF778EFC88417EFD174DADB5841" italics="true" pageId="null" pageNumber="49">Polemonium</emphasis>
</taxonomicName>
<normalizedToken id="218684A8439AAF3112860F5B5D32F1B9" originalValue="umfaßt" pageId="null" pageNumber="49">umfasst</normalizedToken>
wahrscheinlich etwa 
<emphasis id="0179AD512510431ADC162D3CFD1B94BC" italics="true" pageId="null" pageNumber="49">40 Arten</emphasis>
(Davidson 1950 
<normalizedToken id="BFA46BCE4D40978B3FF7AE961D6D1932" originalValue="erwähnt" pageId="null" pageNumber="49">erwaehnt</normalizedToken>
in der Monographie 19 Arten; in Flora URSS Band 19, 1953, werden aber allein 14 Arten genannt); 
<emphasis id="91DD665E2C1D571D3A29A6ACBE36B3F7" italics="true" pageId="null" pageNumber="49">sie hat eurasiatisch-nordamerikanische Verbreitung</emphasis>
, einige Arten auch in den Gebirgen 
<normalizedToken id="8FE86A1F6F8C6EC1E545B0CB70F3AC38" originalValue="Südamerikas" pageId="null" pageNumber="49">Suedamerikas</normalizedToken>
. 
<emphasis id="932EEFEAFEAF48EBEE6AD812219F7BC4" italics="true" pageId="null" pageNumber="49">Chromosomengrundzahl</emphasis>
n = 9.
</paragraph>
</subSubSection>
