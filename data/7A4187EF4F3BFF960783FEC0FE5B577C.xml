, 4A–C, 9A; 
<tableCitation id="BF6A03424F3BFF9700BBFEEEFAB257F0" box="[1187,1324,379,404]" captionStart-0="Table 1" captionStart-1="Table 2" captionStart-2="Table 3" captionStartId-0="4.[163,227,196,217]" captionStartId-1="4.[827,891,196,217]" captionStartId-2="5.[145,209,196,217]" captionTargetBox-0="[163,678,312,900]" captionTargetBox-1="[827,1442,371,1530]" captionTargetBox-2="[145,1400,312,1930]" captionText-0="Table 1. List of new and revised higher taxa and genera of Afrotropical freshwater crabs (Potamoidea Ortmann, 1896)" captionText-1="Table 2. Updated classification of the freshwater" captionText-2="Table 3. List of all the species of Afrotropical freshwater crabs of the families Potamonautidae and Deckeniidae together with the countries where they have been recorded in the specialized literature from the mid-19th century to March 2021. The list comprises a total of two families, four subfamilies, three tribes, 28 genera and 185 species" httpUri-0="http://table.plazi.org/id/A69766714F29FF8504BBFF51FF435770" httpUri-1="http://table.plazi.org/id/A69766714F29FF850723FF51FAC4572B" httpUri-2="http://table.plazi.org/id/A69766714F28FF840489FF51FB115770" pageId="22" pageNumber="1290" tableUuid-0="A69766714F29FF8504BBFF51FF435770" tableUuid-1="A69766714F29FF850723FF51FAC4572B" tableUuid-2="A69766714F28FF840489FF51FB115770">TABLES 1–3</tableCitation>
