<taxonomicName id="FAC46D88DE6EFF9BD7C7FD86FD619C56" authorityName="Menge" authorityYear="1866" box="[504,651,553,575]" class="Arachnida" family="Tetragnathidae" kingdom="Animalia" order="Araneae" pageId="11" pageNumber="214" phylum="Arthropoda" rank="family">Tetragnathidae</taxonomicName>
female:
</paragraph>
</caption>
