</taxonomicName>
, 
<taxonomicName id="2ECF4D5E3F01FF96FDBBF883FD5CF8FF" authorityName="Sarato" authorityYear="1889" box="[602,700,1796,1823]" class="Actinopterygii" family="Gobiidae" genus="Gobius" kingdom="Animalia" order="Perciformes" pageId="52" pageNumber="53" phylum="Chordata" rank="species" species="fallax">
