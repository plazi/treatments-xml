Size. Known adult size about 
<quantity id="2E379B383F01FF96FE07FBFBFDFDFB76" box="[486,541,1149,1175]" metricMagnitude="-2" metricUnit="m" metricValue="9.0" pageId="52" pageNumber="53" unit="cm" value="9.0">9 cm</quantity>
