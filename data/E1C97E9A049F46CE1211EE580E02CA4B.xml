<subSubSection id="83D28297015E8F0FB3A9F10BFA2CD444" pageId="null" pageNumber="48" type="description">
<paragraph id="0BCAEB5B8F92EC23B2D33C9DE1F8C91A" pageId="null" pageNumber="48">
10-30 cm hoch. Rhizom horizontal, kriechend. Stengel aufrecht, 
<normalizedToken id="D263122A5FDB4C34F7B1DA0A5F01325C" originalValue="±" pageId="null" pageNumber="48">+/-</normalizedToken>
kahl. 
<normalizedToken id="B91A3B83279552E5719D31DBFDF7C583" originalValue="Grundständige" pageId="null" pageNumber="48">Grundstaendige</normalizedToken>
<normalizedToken id="BE3C7D75ACD05C2229217F0B75DD63C8" originalValue="Blätter" pageId="null" pageNumber="48">Blaetter</normalizedToken>
zur 
<normalizedToken id="EEA8FECA923DDB5557FA9B618BC24793" originalValue="Blütezeit" pageId="null" pageNumber="48">Bluetezeit</normalizedToken>
in der Regel keine; 
<normalizedToken id="C94486028D784DBD4DD78E233B4A193F" originalValue="Stengelblätter" pageId="null" pageNumber="48">Stengelblaetter</normalizedToken>
3, 
<emphasis id="4E053CDCECC3DA5DD05C2A041E80FAC0" italics="true" pageId="null" pageNumber="48">im obersten Viertel der Pflanze, weniger als 1 cm lang gestielt oder sitzend</emphasis>
, im 
<normalizedToken id="85BEBF44365AD6362C2E1D3B08EA3A05" originalValue="Umriß" pageId="null" pageNumber="48">Umriss</normalizedToken>
meist rhombisch, 4-8 cm lang, bis zum Grunde 3teilig: 
<emphasis id="0B19C6C4F8D9C7B45C237507AADBC224" italics="true" pageId="null" pageNumber="48">Abschnitte 3-5mal so lang wie breit</emphasis>
, 
<normalizedToken id="005F05DE9984308D82CBBC2FDB7D93A9" originalValue="unregelmäßig" pageId="null" pageNumber="48">unregelmaessig</normalizedToken>
und grob 
<normalizedToken id="E90E10FA0A4A597D71EC8A2ED90D8486" originalValue="gezähnt" pageId="null" pageNumber="48">gezaehnt</normalizedToken>
, gelegentlich mit einzelnen tiefen Einschnitten. 
<emphasis id="114A84BAD6D9978F22AF8F17683D4896" italics="true" pageId="null" pageNumber="48">
<normalizedToken id="88AFF3DFE53306EDD095E6763CC54BA3" originalValue="Blüten" pageId="null" pageNumber="48">Blueten</normalizedToken>
meist 2;
</emphasis>
Durchmesser 2-2,5 cm. 
<normalizedToken id="3914891D9B73835DE071C1A87E8A365E" originalValue="Blütenstiele" pageId="null" pageNumber="48">Bluetenstiele</normalizedToken>
kraus behaart. 
<normalizedToken id="4D3FB38ED9D3BAF0DBF8486E8FE40FC3" originalValue="Perigonblätter" pageId="null" pageNumber="48">Perigonblaetter</normalizedToken>
5, 
<emphasis id="EEA8A6885D17937791B2E4C372F1CCCE" italics="true" pageId="null" pageNumber="48">
gelb, 
<normalizedToken id="5CB9F01FAAE5BFD7D8520D324D03C888" originalValue="außerseits" pageId="null" pageNumber="48">ausserseits</normalizedToken>
behaart.
</emphasis>
<normalizedToken id="8330EB8D9EC04E478BC3072790800EC3" originalValue="Früchtchen" pageId="null" pageNumber="48">Fruechtchen</normalizedToken>
dicht mit kurzen, geraden, borstigen Haaren besetzt. - 
<normalizedToken id="80935F460B982D07196A091346DB9C0F" originalValue="Blüte" pageId="null" pageNumber="48">Bluete</normalizedToken>
: 
<normalizedToken id="00E3287EAB3D1F33587E9A44CD71B5C8" originalValue="Frühling" pageId="null" pageNumber="48">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="EBE97057C2155FAA7A600CD819744543" pageId="null" pageNumber="48">
<emphasis id="A9D7890972E53C3596597430402AB170" italics="true" pageId="null" pageNumber="48">Zylologische Angaben. 2n</emphasis>
= 
<emphasis id="2C203BB2BB9B4769B33888AD92310A85" italics="true" pageId="null" pageNumber="48">32:</emphasis>
Ohne Herkunftsangabe (
<normalizedToken id="FBB401AE79575BF138A17FC7118D7B7D" originalValue="Böcher" pageId="null" pageNumber="48">Boecher</normalizedToken>
1932, Langlet 1932), Material aus Schweden (
<normalizedToken id="C9015E8D9F2D902A6114FDA96BABDD8B" originalValue="Bernström" pageId="null" pageNumber="48">Bernstroem</normalizedToken>
1946), von vielen Fundstellen in Polen (Trela 1959). Nach Lamprecht (1962) 
<normalizedToken id="5D705220005965579CF6EBE9E9A4F9C1" originalValue="läuft" pageId="null" pageNumber="48">laeuft</normalizedToken>
die Meiose im Herbst oder 
<normalizedToken id="5940A425ABDCF1C9D6282F0BFA667D8D" originalValue="Frühjahr" pageId="null" pageNumber="48">Fruehjahr</normalizedToken>
ab; sie ist normal, selten bleiben 
<normalizedToken id="DBEA9D89DCC581BF2AF3EAE11397E6D0" originalValue="während" pageId="null" pageNumber="48">waehrend</normalizedToken>
der Anaphase einzelne Chromosomen liegen.
</paragraph>
<paragraph id="107C9D56EF962EE0065A4406A74EB4B0" pageId="null" pageNumber="48">
<emphasis id="9A8CD9B2A2873A93730E52E8D5FBFA68" italics="true" pageId="null" pageNumber="48">Standort.</emphasis>
Kollin und montan, selten subalpin. Feuchte, lehmige oder humose 
<normalizedToken id="0BB8879323998B90259F4B40551809B5" originalValue="Böden" pageId="null" pageNumber="48">Boeden</normalizedToken>
. 
<normalizedToken id="DCD4960A14BA8B7701A8B0D5BC7A4AA7" originalValue="Laubmischwälder" pageId="null" pageNumber="48">Laubmischwaelder</normalizedToken>
(besonders 
<normalizedToken id="E1392441BB70C548CD03D0F10D697EF1" originalValue="Auenwälder" pageId="null" pageNumber="48">Auenwaelder</normalizedToken>
), Hecken, 
<normalizedToken id="CDD5DB9806C911F75B539DEBCFC39F01" originalValue="Obstgärten" pageId="null" pageNumber="48">Obstgaerten</normalizedToken>
, selten in Wiesen.
</paragraph>
<paragraph id="38EA6179F385D497BB6A78A192DB377F" pageId="null" pageNumber="48">
<emphasis id="6AAD26CE1BB5C3B8D75269CFF8DAADF8" italics="true" pageId="null" pageNumber="48">
Verbreitung. 
<normalizedToken id="7223F530EC4D02028709CB94B4CE1BC7" originalValue="Europäische" pageId="null" pageNumber="48">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="34F0BC3F1061D42D4D3E699F0CB27EA0" originalValue="Westwärts" pageId="null" pageNumber="48">Westwaerts</normalizedToken>
bis Ardennen, Gebiet der Seine, Vogesen, Burgund, Gironde, Kastilien; 
<normalizedToken id="9BF64BBB1F0116D5D488ACCC8213D634" originalValue="nordwärts" pageId="null" pageNumber="48">nordwaerts</normalizedToken>
in Skandinavien bis 69° NB (in England nur eingeschleppt), 
<normalizedToken id="9203D93C7DFBB2D1CAF17D2D3D2666DC" originalValue="Südfinnland" pageId="null" pageNumber="48">Suedfinnland</normalizedToken>
, zerstreut in 
<normalizedToken id="44DE6AC0B8EEB307E8E023C0B76BC13F" originalValue="Nordrußland" pageId="null" pageNumber="48">Nordrussland</normalizedToken>
; 
<normalizedToken id="FC6F815141754AE8C7989B60EC3A5F67" originalValue="ostwärts" pageId="null" pageNumber="48">ostwaerts</normalizedToken>
bis in den Ural; 
<normalizedToken id="E6ECA986AA591111AAF06EA606D19FB6" originalValue="südwärts" pageId="null" pageNumber="48">suedwaerts</normalizedToken>
bis Nordspanien, Mittelitalien, Albanien, Mazedonien, 
<normalizedToken id="6C25E9A8F511EDB988FC76BB1EB9A6A1" originalValue="Südrußland" pageId="null" pageNumber="48">Suedrussland</normalizedToken>
, Kaukasus. Verbreitungskarte von Meusel (1965). - Im Gebiet 
<normalizedToken id="F56C5FA975F8C0DA69BA8D6E14A63846" originalValue="fällt" pageId="null" pageNumber="48">faellt</normalizedToken>
Hauptverbreitung mit der Verbreitung der 
<normalizedToken id="9AB7C3512907905BB0068AFE0B23EB18" originalValue="Eichenwälder" pageId="null" pageNumber="48">Eichenwaelder</normalizedToken>
zusammen; 
<normalizedToken id="D0F0EB360DFC2296FC62B65D47A72D51" originalValue="häufig" pageId="null" pageNumber="48">haeufig</normalizedToken>
am 
<normalizedToken id="0889E56F483545FB216924FA81F076DF" originalValue="Alpensüdfuß" pageId="null" pageNumber="48">Alpensuedfuss</normalizedToken>
und in der Nordschweiz, sonst ziemlich selten.
</paragraph>
</subSubSection>
