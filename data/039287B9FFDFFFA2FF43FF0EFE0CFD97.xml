<taxonomicName id="4C3B4D2CFFDFFFA2FC06FDB9FB2DFDB0" box="[973,1254,551,578]" class="Magnoliopsida" family="Malvaceae" genus="Luehea" kingdom="Plantae" order="Malvales" pageId="6" pageNumber="186" phylum="Tracheophyta" rank="variety" species="candicans" variety="gracilis">
