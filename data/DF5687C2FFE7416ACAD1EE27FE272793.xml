<tableCitation id="1A7D036FFFE7416ACB74EEB0FE3A2793" box="[306,392,2012,2038]" captionStart="TABLE 2" captionStartId="7.[151,236,476,501]" captionTargetPageId="7" captionText="TABLE 2. Song characteristics of Hetrodini species (for song type see Fig. 5 and text)" httpUri="http://table.plazi.org/id/0380665CFFF1417CCAD1E8B0FBBD2190" pageId="17" pageNumber="468" tableUuid="0380665CFFF1417CCAD1E8B0FBBD2190">Table 2</tableCitation>
