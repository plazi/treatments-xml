<emphasis id="D3EA22357775FFBE1B5B4935FC46ED62" bold="true" box="[831,940,546,570]" pageId="13" pageNumber="50">Material:</emphasis>
<specimenCount id="F79835AE7775FFBE1BD14934FC18ED62" box="[949,1010,547,571]" pageId="13" pageNumber="50" type="generic">5 Ex.</specimenCount>
