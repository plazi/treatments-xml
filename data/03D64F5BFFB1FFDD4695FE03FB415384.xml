<figureCitation id="1344E2C8FFB1FFDD4491FD09FD485554" box="[682,729,754,776]" captionStart="Fig" captionStartId="2.[166,199,1778,1800]" captionTargetBox="[314,1085,630,1758]" captionTargetId="figure-192@2.[301,1091,627,1758]" captionTargetPageId="2" captionText="Fig. 1. Nemotelus argentifer: female dorsal view (a); Nemotelus nigrinus, female, lateral (b); Nemotelus notatus: female, dorsal view (c), male, lateral view (d); Nemotelus pantherinus: male, lateral view (e), lateral view of the head (f); Nemotelus rudifranci: lateral view of a female (g), lateral view of a male (h)." figureDoi="http://doi.org/10.5281/zenodo.6449249" httpUri="https://zenodo.org/record/6449249/files/figure.png" pageId="1" pageNumber="402">fig. 1</figureCitation>
