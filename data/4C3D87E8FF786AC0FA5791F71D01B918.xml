<collectingCountry id="BC83766EFF786AC7F7AF9B1316A8B659" box="[2131,2216,3402,3435]" name="Kenya" pageId="131" pageNumber="890">Kenya</collectingCountry>
from sea level up to elevations of ¢. 
<quantity id="036C9B1BFF786AC7FA219B361839B6A2" box="[1501,1593,3439,3472]" metricMagnitude="2" metricUnit="m" metricValue="7.6" pageId="131" pageNumber="890" unit="m" value="760.0">760 m</quantity>
.
</paragraph>
</subSubSection>
