, holotype habitus; C) 
<taxonomicName id="4C2E81F1F713CA74BA82F866C1797FE7" authorityName="Perkins" authorityYear="1997" box="[457,556,1967,1991]" class="Insecta" family="Hydraenidae" genus="Protozantaena" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="94" phylum="Arthropoda" rank="species" species="labrata">
