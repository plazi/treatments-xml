<quantity id="4CD65797F710CA77B8D8FCB0C76C7BA1" box="[915,1081,870,897]" metricMagnitude="-4" metricUnit="m" metricValue="8.75" metricValueMax="9.5" metricValueMin="8.0" pageId="1" pageNumber="93" unit="mm" value="0.875" valueMax="0.95" valueMin="0.8">0.80–0.95 mm</quantity>
