<subSubSection id="2B830B446F158F4E076EB12DB9448342" pageId="null" pageNumber="180" type="description">
<paragraph id="9ABE57CED2FA67D186ECA7CA50B8AB09" pageId="null" pageNumber="180">
Unterscheidet sich von 
<taxonomicName id="1CEC4FDEE7468AB0D488EFBF255F675F" class="Gnetopsida" family="Ephedraceae" genus="Ephedra" kingdom="Plantae" order="Ephedrales" pageId="null" pageNumber="180" phylum="Tracheophyta" rank="species" species="helvetica">
<emphasis id="E8601D692D4B7A9BB51C3327D1183107" italics="true" pageId="null" pageNumber="180">E. helvetica</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: Strauch bis 1 m hoch; 
<emphasis id="B098B53F5038356546BAC1A49AB7D091" italics="true" pageId="null" pageNumber="180">
narbenartig 
<normalizedToken id="D82675AFF290E285A259BAFCA01A20A9" originalValue="verlängerte" pageId="null" pageNumber="180">verlaengerte</normalizedToken>
Mikropyle gerade, ca. 0,5 mm lang.
</emphasis>
- 
<normalizedToken id="DC8ED80A203EFAE29FD730FE3B7D12D1" originalValue="Blüte" pageId="null" pageNumber="180">Bluete</normalizedToken>
: 
<normalizedToken id="C69D3B6A28E95C2947990B34A97519CC" originalValue="Frühling" pageId="null" pageNumber="180">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="554A795DA3920E16DC4B8519861E7554" pageId="null" pageNumber="180">
<emphasis id="AC30A750C1B11C676E8BB5E8315FFAE6" italics="true" pageId="null" pageNumber="180">Zytologische Angaben. 2n = 28:</emphasis>
Material aus botanischen 
<normalizedToken id="8A1221E6E546CC689B9CAF348B5DDFB8" originalValue="Gärten" pageId="null" pageNumber="180">Gaerten</normalizedToken>
; Zusammenstellung der Untersuchungen von 
<normalizedToken id="6F1EC19BA29DA1496F4665D7C373B830" originalValue="Löve" pageId="null" pageNumber="180">Loeve</normalizedToken>
und 
<normalizedToken id="A5C3E24EF3C416B76099C6F525495965" originalValue="Löve" pageId="null" pageNumber="180">Loeve</normalizedToken>
(1961).
</paragraph>
<paragraph id="D45EB99568E1B55E08341111E8ED898A" pageId="null" pageNumber="180">
<emphasis id="990E52108DEB29597E3DC7800BFC743F" italics="true" pageId="null" pageNumber="180">Standort.</emphasis>
Wie 
<taxonomicName id="B47463F8937B4EA545355CB72339A832" class="Gnetopsida" family="Ephedraceae" genus="Ephedra" kingdom="Plantae" order="Ephedrales" pageId="null" pageNumber="180" phylum="Tracheophyta" rank="species" species="helvetica">
<emphasis id="732C2DB485B7BC29464CFE30E536FB92" italics="true" pageId="null" pageNumber="180">E. helvetica</emphasis>
</taxonomicName>
(Nr. 1).
</paragraph>
<paragraph id="5944613A018331F1AAECC2F2E7D4152E" pageId="null" pageNumber="180">
<emphasis id="8E0635696583738F4E96DBF6ABCC804B" italics="true" pageId="null" pageNumber="180">
Verbreitung. 
<normalizedToken id="29D0ACC0F19783DD1B474BF79A86218A" originalValue="Südeuropäisch-westasiatische" pageId="null" pageNumber="180">Suedeuropaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="52D32D0924DBEB8DE2021A5A0BE79B6D" originalValue="Südeuropa" pageId="null" pageNumber="180">Suedeuropa</normalizedToken>
(atlantische 
<normalizedToken id="08F095EDEF58B037283CEB45C2E9B14C" originalValue="Küste" pageId="null" pageNumber="180">Kueste</normalizedToken>
<normalizedToken id="9C201E7CF9E6E5D9F23C651F9117FFCF" originalValue="nordwärts" pageId="null" pageNumber="180">nordwaerts</normalizedToken>
bis auf die Bretagne, durch das Etschtal vereinzelt 
<normalizedToken id="0BF8641C5BFC50FCC9B3D1F7FA4B723A" originalValue="nordwärts" pageId="null" pageNumber="180">nordwaerts</normalizedToken>
bis Vintschgau), 
<normalizedToken id="FA5A3F80946063EF1F1CF995C340B41F" originalValue="Schwarzmeerküsten" pageId="null" pageNumber="180">Schwarzmeerkuesten</normalizedToken>
, 
<normalizedToken id="6E5726797EF5FDCBABAA47424EDF7F53" originalValue="Südrußland" pageId="null" pageNumber="180">Suedrussland</normalizedToken>
, 
<normalizedToken id="5FC51BDA4F29B630A8CAEC7C8F520E21" originalValue="ostwärts" pageId="null" pageNumber="180">ostwaerts</normalizedToken>
bis Zentralasien. Verbreitungskarte von Meusel (1964). - Im Gebiet: Bei Schlanders im Vintschgau (immer noch vorhanden, Handel-Mazzetti 1960).
</paragraph>
</subSubSection>
