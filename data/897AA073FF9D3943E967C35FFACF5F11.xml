<quantity id="C62BBC80FF9A3942E853C0C7FC565338" box="[866,937,2036,2062]" metricMagnitude="-3" metricUnit="m" metricValue="1.0" pageId="52" pageNumber="53" unit="mm" value="1.0">1 mm</quantity>
