<taxonomicName id="C6D36AE6FF9A3942EAF3C0B9FD8D5C92" authorityName="Alcock" authorityYear="1889" box="[450,626,1930,1956]" class="Actinopterygii" family="Ophidiidae" genus="Glyptophidium" kingdom="Animalia" order="Ophidiiformes" pageId="52" pageNumber="53" phylum="Chordata" rank="genus">
