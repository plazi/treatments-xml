<subSubSection id="6D67DAC31A2A69915A65764574847BC2" pageId="null" pageNumber="493" type="vernacular_names">
<paragraph id="0D78D7E3C943AA46693AEC472AA742DB" pageId="null" pageNumber="493">Skorpion-Ginster</paragraph>
</subSubSection>
</title>
<subSubSection id="1B6630E8C2A01A57163771A9F3DD6C90" pageId="null" pageNumber="493" type="description">
<paragraph id="01835C5DCA82E52B5753FE959A55176E" pageId="null" pageNumber="493">
60-200 cm hoch; mit aufrechten, 
<emphasis id="94136E4B38091B8CCF778208AFB78D10" italics="true" pageId="null" pageNumber="493">dornigen</emphasis>
<normalizedToken id="54E1B3435FD303E0F6B58C523840A014" originalValue="älteren" pageId="null" pageNumber="493">aelteren</normalizedToken>
Zweigen und dornigen, 
<normalizedToken id="23CB7C619CCAED126F8F9E1E3B7049F5" originalValue="beblätterten" pageId="null" pageNumber="493">beblaetterten</normalizedToken>
und 
<normalizedToken id="B04012DD863100A0F1CD9AAC7ED81A5D" originalValue="blühenden" pageId="null" pageNumber="493">bluehenden</normalizedToken>
jungen Zweigen. Zweige gerillt, die jungen anliegend kurz behaart (Haare etwa 0,2 mm lang). Dornen verzweigt oder unverzweigt. 
<emphasis id="D2C83C120718EC81FAB6324AE8F6E9BF" italics="true" pageId="null" pageNumber="493">
<normalizedToken id="F10C312298BAE1DBE1B1F8562B2AE94C" originalValue="Blätter" pageId="null" pageNumber="493">Blaetter</normalizedToken>
am Grunde mit 2 zu Dornen umgeformten 
<normalizedToken id="B2046F8AD68251AD07983E395B1D9A94" originalValue="Nebenblättern" pageId="null" pageNumber="493">Nebenblaettern</normalizedToken>
</emphasis>
, ungeteilt, lanzettlich, 0,3-1,1 cm lang und etwa 
<normalizedToken id="932E525BFFA404EB9645BB2B1544716C" originalValue="¼" pageId="null" pageNumber="493">1/4</normalizedToken>
-⅓ so breit, anliegend behaart bis fast kahl, 
<normalizedToken id="630DF5EBBF91A9BBAD2D7EBE9B46E2DA" originalValue="graugrün" pageId="null" pageNumber="493">graugruen</normalizedToken>
. 
<normalizedToken id="403A8225C3C0B3C3E708AA6F226A6C30" originalValue="Blüten" pageId="null" pageNumber="493">Blueten</normalizedToken>
zu 1-3 in den Achseln von 
<normalizedToken id="7FD199E23A7579B9DBCEF4C62F65AD93" originalValue="Blättern" pageId="null" pageNumber="493">Blaettern</normalizedToken>
. 
<normalizedToken id="C91057DB539BCEABA1A406BD6E1F0B91" originalValue="Tragblätter" pageId="null" pageNumber="493">Tragblaetter</normalizedToken>
<normalizedToken id="C757F42841D0F1B1566E5A79ED4E6B86" originalValue="kürzer" pageId="null" pageNumber="493">kuerzer</normalizedToken>
als der 
<normalizedToken id="0EF7E763072D92F66B23609506FF86F6" originalValue="Blütenstiel" pageId="null" pageNumber="493">Bluetenstiel</normalizedToken>
. Kelch 3-5 mm lang, am Rande etwas bewimpert, sonst 
<normalizedToken id="347522D98E8AD94CC1185778885F021D" originalValue="±" pageId="null" pageNumber="493">+/-</normalizedToken>
kahl, mit bis etwa zur 
<normalizedToken id="A129BF602F1AC7C6A8E66E8CDC72EA56" originalValue="Hälfte" pageId="null" pageNumber="493">Haelfte</normalizedToken>
2teiliger Oberlippe und bis auf etwa ⅔ 3teiliger Unterlippe. Krone 1-1,3 cm lang, gelb; Schiffchen kahl; 
<emphasis id="637256BFBDC51EF47997853E16798117" italics="true" pageId="null" pageNumber="493">
Fahne und 
<normalizedToken id="13CE15C6BC8CD9D0C6431423BA3340AD" originalValue="Flügel" pageId="null" pageNumber="493">Fluegel</normalizedToken>
etwa so lang wie das Schiffchen
</emphasis>
, ausgerandet, kahl. 
<emphasis id="EB9F77730DDBB2742F5094AD0950D7F3" italics="true" pageId="null" pageNumber="493">Frucht 2-4 cm lang</emphasis>
und 0,3-0,5 cm breit, 
<emphasis id="557083D3CE9FAF1F6BE40A436EA572A6" italics="true" pageId="null" pageNumber="493">kahl.</emphasis>
- 
<normalizedToken id="91E95F6C9F7594286F5D25B7590C0421" originalValue="Blüte" pageId="null" pageNumber="493">Bluete</normalizedToken>
: 
<normalizedToken id="87E7F26CB25E3BE47DCEDA5878FF7292" originalValue="Später" pageId="null" pageNumber="493">Spaeter</normalizedToken>
<normalizedToken id="795370EA67B341A599CC222EDD4370FD" originalValue="Frühling" pageId="null" pageNumber="493">Fruehling</normalizedToken>
und 
<normalizedToken id="21AF97E1225B2144F5211D15DC528EA1" originalValue="früher" pageId="null" pageNumber="493">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="B67384CF406FE8F0F51BACBC11418287" pageId="null" pageNumber="493">
<emphasis id="5CBB280DD2D5DF2AEA922DD8F45A025E" italics="true" pageId="null" pageNumber="493">
<pageBreakToken id="EAD6744FC3860B2ED4E8F4F4C0A883E1" pageId="null" pageNumber="493">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="37B697E297726222668DC3B76927206E" italics="true" pageId="null" pageNumber="493">40:</emphasis>
Material aus Spanien (Lorenzo-Andreu und Garcia-Sanz aus Darlington und Wylie 1955). 
<emphasis id="CD5DBE92DE4877E208D3819459627292" italics="true" pageId="null" pageNumber="493">2n</emphasis>
= 
<emphasis id="8EBA1557AF92F632CC17212D9E9CAD9A" italics="true" pageId="null" pageNumber="493">48:</emphasis>
Material aus 
<normalizedToken id="C4940B2D49E9C9A90893C1E5DFE95F8E" originalValue="Südfrankreich" pageId="null" pageNumber="493">Suedfrankreich</normalizedToken>
(Favarger und Contandriopoulos 1961).
</paragraph>
<paragraph id="107E14B60630E7B8F358CB6A3CBD460F" pageId="null" pageNumber="493">
<emphasis id="F7F08A8A5615CD7B9241F738C2E15EFF" italics="true" pageId="null" pageNumber="493">Standort.</emphasis>
Kollin, selten montan. Trockene, steinige 
<normalizedToken id="14F39455725A5B5348E5FA4CADD5E5F2" originalValue="Böden" pageId="null" pageNumber="493">Boeden</normalizedToken>
in warmen Lagen. Felsige 
<normalizedToken id="7D0F752BB28F7D71AFD6C79A0B073FD3" originalValue="Hänge" pageId="null" pageNumber="493">Haenge</normalizedToken>
, 
<normalizedToken id="9A59F7AB454225C686B431F8AF6FEE2E" originalValue="Gebüsche" pageId="null" pageNumber="493">Gebuesche</normalizedToken>
, lichte 
<normalizedToken id="85DF2AD824E6780F58DE0A93A4738413" originalValue="Wälder" pageId="null" pageNumber="493">Waelder</normalizedToken>
.
</paragraph>
<paragraph id="EDC41ACFB2D5ACE5DBCCB71653233E87" pageId="null" pageNumber="493">
<emphasis id="B4C6B2AD57411D10255EA120BE3252F1" italics="true" pageId="null" pageNumber="493">
Verbreitung. 
<normalizedToken id="C4187F5AE1F61A8397A4CEB70C383DF5" originalValue="Südwesteuropäische" pageId="null" pageNumber="493">Suedwesteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Nord- und 
<normalizedToken id="FBB19D0C2D3DB8B9C6EF69C37D2B5DAC" originalValue="ostwärts" pageId="null" pageNumber="493">ostwaerts</normalizedToken>
bis 
<normalizedToken id="C87CB3ABB1436A68AE34FAD7A714EA3E" originalValue="Südfrankreich" pageId="null" pageNumber="493">Suedfrankreich</normalizedToken>
, Westalpen, Korsika. - Im Gebiet: Savoyen (Montagne de St-Romain).
</paragraph>
</subSubSection>
