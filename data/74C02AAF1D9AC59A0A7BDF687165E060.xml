<subSubSection id="D0D0D8367878B57E84663A6D58F96302" pageId="null" pageNumber="520" type="description">
<paragraph id="5C31EE8E285FCAC864572BFCBFE16374" pageId="null" pageNumber="520">
1-2 
<normalizedToken id="4CD5029CBAC963E31D04118F7F42CD77" originalValue="jährig" pageId="null" pageNumber="520">jaehrig</normalizedToken>
; 7-30 cm hoch. Stengel aufrecht oder aufsteigend, besonders am Grunde verzweigt, dicht behaart. 
<emphasis id="319B3B65CB6EDFE51F5B1CFD5988747F" italics="true" pageId="null" pageNumber="520">
<normalizedToken id="14088F3DC7E83E2203530C3E176FD026" originalValue="Teilblätter" pageId="null" pageNumber="520">Teilblaetter</normalizedToken>
1-2
</emphasis>
<normalizedToken id="A8EE6062693975EC739875F0E511AEDB" originalValue="½" pageId="null" pageNumber="520">1/2</normalizedToken>
<emphasis id="41C63F94E9FEB30F66CE2ACA7AB3E4DC" italics="true" pageId="null" pageNumber="520">mal so lang wie breit, bis 2 cm lang</emphasis>
, abgerundet oder ausgerandet, oft mit kurzer, aufgesetzter Spitze, mit geraden Seitennerven, fein 
<normalizedToken id="5A521826B5DEEE4052BD83829FCB6FC9" originalValue="gezähnt" pageId="null" pageNumber="520">gezaehnt</normalizedToken>
, mit der 
<normalizedToken id="A98E530F6C5D4CDD84E720EB47BC7F6B" originalValue="größten" pageId="null" pageNumber="520">groessten</normalizedToken>
Breite oberhalb der Mitte, beidseits behaart. 
<normalizedToken id="CFFFD0E9961EEFCBF351DA40212E9479" originalValue="Nebenblätter" pageId="null" pageNumber="520">Nebenblaetter</normalizedToken>
der untern 
<normalizedToken id="18DDF50859385D49A79353F6F21F6E72" originalValue="Stengelblätter" pageId="null" pageNumber="520">Stengelblaetter</normalizedToken>
meist 
<normalizedToken id="46B85DFACE3B7E025D70FF7A8405D1D9" originalValue="kürzer" pageId="null" pageNumber="520">kuerzer</normalizedToken>
als der halbe Blattstiel, behaart; der freie Teil in eine Spitze ausgezogen, etwa 2mal so lang wie breit. 
<normalizedToken id="0F84521D54EF39BC0D7E12B8348E486D" originalValue="Blütenstände" pageId="null" pageNumber="520">Bluetenstaende</normalizedToken>
kugelig bis 
<normalizedToken id="BF39592F6CF71C6AE3BB5C5578F5DD26" originalValue="eiförmig" pageId="null" pageNumber="520">eifoermig</normalizedToken>
, 
<normalizedToken id="736DF5EE23EE107A90F8B7F3C2E37E0E" originalValue="vielblütig" pageId="null" pageNumber="520">vielbluetig</normalizedToken>
, etwa 1 cm lang und fast so dick, einzeln in den Achseln von 
<normalizedToken id="8596F5361F9327ADFD864BF63F531E47" originalValue="Stengelblättern" pageId="null" pageNumber="520">Stengelblaettern</normalizedToken>
oder am Ende der Zweige, 
<emphasis id="04D9523BA8229FD12296A884D903EAD1" italics="true" pageId="null" pageNumber="520">ungestielt</emphasis>
, von den 
<normalizedToken id="939541C0DBF5CD25372855DAC14FE4E2" originalValue="Nebenblättern" pageId="null" pageNumber="520">Nebenblaettern</normalizedToken>
<normalizedToken id="980F906D630158496C845E228394FCDC" originalValue="umhüllt" pageId="null" pageNumber="520">umhuellt</normalizedToken>
. 
<normalizedToken id="72F022A28DD649F52D92E54E5071593F" originalValue="Blüten" pageId="null" pageNumber="520">Blueten</normalizedToken>
ungestielt. 
<normalizedToken id="597A0E7BC924B2E33393EFCEBF81CD1D" originalValue="Kelchröhre" pageId="null" pageNumber="520">Kelchroehre</normalizedToken>
10nervig, 
<emphasis id="849A7AC8B4065AA4CA0D0F06BF6DA1E9" italics="true" pageId="null" pageNumber="520">
<normalizedToken id="A14A283BF478C44D4AEEC8DECD5EC0B0" originalValue="außen" pageId="null" pageNumber="520">aussen</normalizedToken>
dicht behaart
</emphasis>
(
<emphasis id="D1EA4C171ACC0434333035E2D64AF713" italics="true" pageId="null" pageNumber="520">auch auf den Nerven</emphasis>
), innen am Rande mit schmalem Haarring; Kelchzipfel kurz 
<normalizedToken id="1B752E10820256252F8F7FB355918C87" originalValue="fadenförmig" pageId="null" pageNumber="520">fadenfoermig</normalizedToken>
, 
<emphasis id="CCC4CD33204D1FCC280E9FD35DDF9CC5" italics="true" pageId="null" pageNumber="520">zerstreut behaart</emphasis>
(Haare 0,1-1 mm lang). 
<emphasis id="493FAA02A8360F3DA063FD083A5EB458" italics="true" pageId="null" pageNumber="520">Krone 4-5 mm lang</emphasis>
, etwa 2mal so lang wie die 
<normalizedToken id="A3B3B621301551D7BA8F4BDD3F9CFCC9" originalValue="Kelchröhre" pageId="null" pageNumber="520">Kelchroehre</normalizedToken>
und 
<emphasis id="A1285434D2E473E3C82164F434B8DDCA" italics="true" pageId="null" pageNumber="520">etwa so lang wie der Kelch</emphasis>
, hellrosa. - 
<normalizedToken id="0EF144D662A355B29E079A4976B2595F" originalValue="Blüte" pageId="null" pageNumber="520">Bluete</normalizedToken>
: 
<normalizedToken id="D25357C351B8C727CDD6728298F790EE" originalValue="Später" pageId="null" pageNumber="520">Spaeter</normalizedToken>
<normalizedToken id="BB70BAA26E1EC6D67EF997F3CF89D1B1" originalValue="Frühling" pageId="null" pageNumber="520">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="F067C905E64A1634E12836F7E0523EF4" pageId="null" pageNumber="520">
<emphasis id="B8C953895509D08C1915FDBDB288B112" italics="true" pageId="null" pageNumber="520">
<pageBreakToken id="8CD76E333ECCF69C17456DB5D434A82A" pageId="null" pageNumber="520">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="8F28F873801D6D2100613529773841F6" italics="true" pageId="null" pageNumber="520">14:</emphasis>
Material aus Schleswig-Holstein (Wulff 1939b), aus Holland (Kliphuis 1962, Gadella und Kliphuis 1963).
</paragraph>
<paragraph id="02AB3B6AAA41C0B2AD92D5C7786BFA3B" pageId="null" pageNumber="520">
<emphasis id="E2292D4F30291DA252A2F313FCB19DBC" italics="true" pageId="null" pageNumber="520">Standort.</emphasis>
Kollin, seltener montan. Trockene, meist kalkarme, sandige oder lehmige 
<normalizedToken id="79B32322934E4EE68702420E111B3FB4" originalValue="Böden" pageId="null" pageNumber="520">Boeden</normalizedToken>
in warmen Lagen. Felder, 
<normalizedToken id="C5A9FC09750D4317C5EB39928469322E" originalValue="Wegränder" pageId="null" pageNumber="520">Wegraender</normalizedToken>
, Trockenwiesen.
</paragraph>
<paragraph id="66371BF48E9F8B24F92B5117E199F9CD" pageId="null" pageNumber="520">
<emphasis id="298CDD7416CA8244C96DD1FE0C47F5D1" italics="true" pageId="null" pageNumber="520">
Verbreitung. 
<normalizedToken id="8A127CDA09DE53383E04FD898109FD75" originalValue="Westeuropäisch-mediterrane" pageId="null" pageNumber="520">Westeuropaeisch-mediterrane</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="0175E1101DA2DAF3AD749013A51683EF" originalValue="Nordwärts" pageId="null" pageNumber="520">Nordwaerts</normalizedToken>
vereinzelt bis Irland, England, Gotland, Polen, 
<normalizedToken id="BC4610C0E83F7D351F637846E1DAECA4" originalValue="Südrußland" pageId="null" pageNumber="520">Suedrussland</normalizedToken>
; Kaukasus; Kleinasien; Nordwestafrika; Madeira. - Im Gebiet: Oberrheinische Tiefebene, Gegend von Beifort, Jura (
<normalizedToken id="0D7694B3E64F5BB70797EF458247996C" originalValue="nordostwärts" pageId="null" pageNumber="520">nordostwaerts</normalizedToken>
bis Basel), Savoyen, Genferseegebiet, Wallis (
<normalizedToken id="FC078285999F04E1B128FD27690FE4EC" originalValue="Brançon" pageId="null" pageNumber="520">Brancon</normalizedToken>
, Champlan, 
<normalizedToken id="68AD6D17EF4B9B40C821DB27C007AB5E" originalValue="Valère" pageId="null" pageNumber="520">Valere</normalizedToken>
?), unteres Aostatal, 
<normalizedToken id="943202597939AB252F1B935EB2663C57" originalValue="südliches" pageId="null" pageNumber="520">suedliches</normalizedToken>
Tessin, Comerseegebiet, 
<normalizedToken id="42DEB052CC2E6029B5A8B4051CAA9063" originalValue="südliche" pageId="null" pageNumber="520">suedliche</normalizedToken>
Bergamasker Alpen, Veltlin, Puschlav, Vintschgau; selten, auch adventiv.
</paragraph>
</subSubSection>
