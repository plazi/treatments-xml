<subSubSection id="5F328E3773E38B1BCC4710447C7E91A1" pageId="null" pageNumber="483" type="description">
<paragraph id="16A50078774BC466E39720C605567142" pageId="null" pageNumber="483">
10-30 cm hoch; lange unterirdische 
<normalizedToken id="CC1369AB155F2BE1EB53AA99B254A0A6" originalValue="Ausläufer" pageId="null" pageNumber="483">Auslaeufer</normalizedToken>
treibend. 
<normalizedToken id="EF97DFFFADE4576DCBC4C8B6F25817CD" originalValue="Grundständige" pageId="null" pageNumber="483">Grundstaendige</normalizedToken>
Scheiden braun bis rotbraun. 
<normalizedToken id="EC043AB1A467F77DACC3F18DC8849BC7" originalValue="Blätter" pageId="null" pageNumber="483">Blaetter</normalizedToken>
1-2 mm breit, steif, 
<normalizedToken id="F5DDFBA11431751DE2D1D197C4745019" originalValue="gelbgrün" pageId="null" pageNumber="483">gelbgruen</normalizedToken>
, den 
<normalizedToken id="9F587B80641D5D855D77C35817F02C16" originalValue="Blütenstand" pageId="null" pageNumber="483">Bluetenstand</normalizedToken>
nicht erreichend. Stengel 3kantig, aufrecht, im obern Teil rauh. 
<normalizedToken id="01C451D859C91E21C4050E11A726D44B" originalValue="Blütenstand" pageId="null" pageNumber="483">Bluetenstand</normalizedToken>
1,5-4 cm lang, aus 1-3 seitlichen, 
<normalizedToken id="300F342700D4404D44EE3AA4B9D0883B" originalValue="eiförmigen" pageId="null" pageNumber="483">eifoermigen</normalizedToken>
bis zylindrischen, meist mehr als 6 
<normalizedToken id="B13ED1DCD82948259B577C6CA4D5CD1A" originalValue="blütigen" pageId="null" pageNumber="483">bluetigen</normalizedToken>
, 0,5-1 cm langen, aufrechten, sitzenden, oder kurz gestielten 
<normalizedToken id="F51F84EF3C99962FF594620F5D4D3E3B" originalValue="dichtfrüchtigen" pageId="null" pageNumber="483">dichtfruechtigen</normalizedToken>
♀ 
<normalizedToken id="10800956F5272FBE36B1C08566F5745A" originalValue="Ähren" pageId="null" pageNumber="483">Aehren</normalizedToken>
und 1 
<normalizedToken id="91ACCFA31ADC1E4F843B10D7F9724508" originalValue="endständigen" pageId="null" pageNumber="483">endstaendigen</normalizedToken>
♂ 
<normalizedToken id="E912E97A53042A4B30E747668904B3CE" originalValue="Ähre" pageId="null" pageNumber="483">Aehre</normalizedToken>
. 
<normalizedToken id="B53500BC782111E1DBCF81A0186FCED6" originalValue="Hochblätter" pageId="null" pageNumber="483">Hochblaetter</normalizedToken>
<normalizedToken id="3C5D44865B0600E60B63C587DB545938" originalValue="tragblattähnlich" pageId="null" pageNumber="483">tragblattaehnlich</normalizedToken>
oder, wenn 
<normalizedToken id="81B4B96F3ACCFAFAA240746AB92E952C" originalValue="blattähnlich" pageId="null" pageNumber="483">blattaehnlich</normalizedToken>
, den 
<normalizedToken id="AEA2E49DEFAF1D514B8B00AF32ADB8BA" originalValue="Blütenstand" pageId="null" pageNumber="483">Bluetenstand</normalizedToken>
nicht 
<normalizedToken id="FCB75B9E89FB19E36395EC9F043C97C3" originalValue="überragend" pageId="null" pageNumber="483">ueberragend</normalizedToken>
, 
<emphasis id="E7685D14538611EAF0CC167AA1C2D668" italics="true" pageId="null" pageNumber="483">stets mit 3-8 mm langer Scheide.</emphasis>
<normalizedToken id="306638B3B77D01E8F843DC53510E8724" originalValue="Tragblätter" pageId="null" pageNumber="483">Tragblaetter</normalizedToken>
⅔ bis fast so lang wie der reife Fruchtschlauch, spitz oder stumpf, rotbraun, meist mit 
<normalizedToken id="2C63F714916F45A1D869B08239767033" originalValue="weißem" pageId="null" pageNumber="483">weissem</normalizedToken>
Rand und hellem Mittelnerv. 
<normalizedToken id="E1816459C9D656BA5BA74D98388D540A" originalValue="Fruchtschläuche" pageId="null" pageNumber="483">Fruchtschlaeuche</normalizedToken>
3-4 mm lang, in der Mitte oder wenig 
<normalizedToken id="BBC95AADF39ECCF8E3F7D72FAD008104" originalValue="darüber" pageId="null" pageNumber="483">darueber</normalizedToken>
am breitesten (2-2,5 mm), im Querschnitt rundlich, mit 
<emphasis id="FF54EC1AD357D34667C3DB03B2029C86" italics="true" pageId="null" pageNumber="483">wulstigen Nerven</emphasis>
, kahl, oft zerstreut bewimpert, 
<emphasis id="AB1DD542561AB8FDF78A542876D5162E" italics="true" pageId="null" pageNumber="483">
braun, auffallend 
<normalizedToken id="329674E5834E031A2B24884F774EEFEE" originalValue="glänzend" pageId="null" pageNumber="483">glaenzend</normalizedToken>
</emphasis>
, 
<normalizedToken id="4F715E6161D36553249CD5695B719011" originalValue="plötzlich" pageId="null" pageNumber="483">ploetzlich</normalizedToken>
in den kleinen Schnabel 
<normalizedToken id="304A7F739E455748CE024C242D79228A" originalValue="verschmälert" pageId="null" pageNumber="483">verschmaelert</normalizedToken>
. Narben 3.
</paragraph>
<paragraph id="7417BBFCFD518E3396A441FE66EEA714" pageId="null" pageNumber="483">
<emphasis id="B588D4904A5C7FD23B93DC030E972A04" italics="true" pageId="null" pageNumber="483">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="E4C767057FF1377E1664F15FC271CDD0" pageId="null" pageNumber="483">
<emphasis id="513DDA505CB03298048F8B5A11F93BA3" italics="true" pageId="null" pageNumber="483">Standort.</emphasis>
Kollin, montan, selten subalpin (bei Zermatt bis 2900 m). Trockene, sandige, humus- und kalkarme 
<normalizedToken id="1040116F74BBADCB38E5B675FE6BC992" originalValue="Böden" pageId="null" pageNumber="483">Boeden</normalizedToken>
; meist Alluvionen in den 
<normalizedToken id="60E4D31D14D8C8C72FED4EB2CFC22542" originalValue="wärmsten" pageId="null" pageNumber="483">waermsten</normalizedToken>
<normalizedToken id="C84EEE95F9C72A768F32EF3DAEAE9A10" originalValue="Tälern" pageId="null" pageNumber="483">Taelern</normalizedToken>
des Gebiets. Extreme Trockenheit und 
<normalizedToken id="E52E47AEF37B5BCEEECF340A9CBA1A0F" originalValue="Wärme" pageId="null" pageNumber="483">Waerme</normalizedToken>
ertragende, 
<normalizedToken id="64581F00093EE3BE6BBB0A157556096D" originalValue="steppenähnliche" pageId="null" pageNumber="483">steppenaehnliche</normalizedToken>
Wiesen.
</paragraph>
<paragraph id="139D1CE798F04ADD68A7E1569B8B6C10" pageId="null" pageNumber="483">
<emphasis id="CB4FE09738E291DC127331A7D9857D7F" italics="true" pageId="null" pageNumber="483">
Verbreitung. 
<normalizedToken id="CA1A1692D8FC51DC148AEA18C040EB67" originalValue="Südosteuropäische" pageId="null" pageNumber="483">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Mittel- und 
<normalizedToken id="2A1D642EBD39B22568A1107D86F5E353" originalValue="Südfrankreich" pageId="null" pageNumber="483">Suedfrankreich</normalizedToken>
, durch das Rhonetal 
<normalizedToken id="4974C806709F9AF054BC0D2B0326E45E" originalValue="aufwärts" pageId="null" pageNumber="483">aufwaerts</normalizedToken>
bis in die Westschweiz und das Wallis, dem 
<normalizedToken id="5B85697CBD41112D7963DD37D35CCDFF" originalValue="südlichen" pageId="null" pageNumber="483">suedlichen</normalizedToken>
Alpengebiet entlang bis auf die Balkanhalbinsel, ganzes Donaugebiet bis 
<normalizedToken id="DBE033AC0AF573824970ABA83FF6F534" originalValue="Südrußland" pageId="null" pageNumber="483">Suedrussland</normalizedToken>
(Krim). (Die asiatischen Sippen werden neuerdings als eigene Arten 
<normalizedToken id="4674027343BF64ED63E82066A6A321AC" originalValue="aufgefaßt" pageId="null" pageNumber="483">aufgefasst</normalizedToken>
.) - Im Gebiet: Savoyen, Genf, Waadt, Wallis, Rheintal bei Ragaz, 
<normalizedToken id="4C629A6C822C8DC30FB709F17E5A34B1" originalValue="Graubünden" pageId="null" pageNumber="483">Graubuenden</normalizedToken>
(Vorder- und Hinterrheingebiet, Unterengadin, 
<normalizedToken id="B7C71F015B18FFF18859E50822F6E3F3" originalValue="Münstertal" pageId="null" pageNumber="483">Muenstertal</normalizedToken>
, Puschlav), Vintschgau, Veltlin, 
<taxonomicName id="542F3BFB898FF7C1E1A92BE3A0C5627E" authority="Val Seriana, Grigna, Tessin" authorityName="Val Seriana, Grigna, Tessin" genus="Val" pageId="null" pageNumber="483" rank="species" species="brembana">Val Brembana, Val Seriana, Grigna, Tessin</taxonomicName>
, Piemont.
</paragraph>
<paragraph id="7C8EC22A20CFE686087D44A9A9A60A6E" pageId="null" pageNumber="483">
<emphasis id="6303090C2DA230F1CCBD5D2BB69B1A3A" italics="true" pageId="null" pageNumber="483">Bemerkungen.</emphasis>
Neuerdings ist der Name C. 
<taxonomicName id="C1B10193DD84CEEEF10E802D19D86098" authority="Gaud" authorityName="Gaud" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="483" phylum="Tracheophyta" rank="species" species="liparocarpos">
<emphasis id="676B886CD755074CF35AB6B96EB34260" italics="true" pageId="null" pageNumber="483">liparocarpos</emphasis>
Gaud
</taxonomicName>
, als 
<normalizedToken id="FE1A306A6E92D598A0BB16396611DDED" originalValue="gültig" pageId="null" pageNumber="483">gueltig</normalizedToken>
<normalizedToken id="7C016FF8BF4924E28E96326467252FE3" originalValue="erklärt" pageId="null" pageNumber="483">erklaert</normalizedToken>
worden; da der Name 
<taxonomicName id="EC4CD6B08E44EE5A41EC883DDD960550" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="483" phylum="Tracheophyta" rank="species" species="nitida">
<emphasis id="9E9CB27FFE2B76FB25311DA157773799" italics="true" pageId="null" pageNumber="483">C. nitida</emphasis>
</taxonomicName>
schon lange verwendet wurde und nie zu Verwechslungen 
<normalizedToken id="586B55EFC7905BB36C2EBF2CC69826B0" originalValue="Anlaß" pageId="null" pageNumber="483">Anlass</normalizedToken>
gegeben hat, behalten wir diesen Namen bei.
</paragraph>
</subSubSection>
