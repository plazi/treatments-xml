<taxonomicName id="8FF444F2A6AE105927A6D02E4640888F" authority="Lindbg." authorityName="Lindbg." class="Liliopsida" family="Cyperaceae" genus="Heleocharis" kingdom="Plantae" order="Poales" pageId="null" pageNumber="398" phylum="Tracheophyta" rank="species" species="mamillata">
