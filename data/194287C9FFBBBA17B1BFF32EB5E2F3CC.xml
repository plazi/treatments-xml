</subSubSection>
<subSubSection id="D9F16554FFBBBA17BC1FF2F2BB56F983" pageId="7" pageNumber="626" type="distribution">
<caption id="C5946657FFBBBA17BC1FF2F2BB56F983" inLine="true" pageId="7" pageNumber="626" targetBox="[1984,1988,3049,3074]" targetPageId="7">
<paragraph id="915436DFFFBBBA17BC1FF2F2BB56F983" blockId="7.[2061,2654,1264,1692]" pageId="7" pageNumber="626">
<emphasis id="A39FEACDFFBBBA17BC1FF2F2BA98FA61" bold="true" box="[2061,2238,1426,1455]" pageId="7" pageNumber="626">Distribution.</emphasis>
Known from scattered localities in S 
<collectingCountry id="E9FC764FFFBBBA17BC9EF2DABAD4FA19" box="[2188,2290,1466,1495]" name="Mexico" pageId="7" pageNumber="626">Mexico</collectingCountry>
(
<collectingRegion id="532FF83DFFBBBA17BD1EF2DABBB6FA19" box="[2316,2448,1466,1495]" country="Mexico" name="Guerrero" pageId="7" pageNumber="626">Guerrero</collectingRegion>
and 
<taxonomicName id="56EB4D5CFFBBBA17BDCDF2DAB86BFA19" authorityName="Fontana, Buzzetti &amp; Marino-Perez" authorityYear="2011" box="[2527,2637,1466,1495]" class="Insecta" family="Acrididae" genus="Oaxaca" kingdom="Animalia" order="Orthoptera" pageId="7" pageNumber="626" phylum="Arthropoda" rank="genus">
<collectingRegion id="532FF83DFFBBBA17BDCDF2DAB86BFA19" box="[2527,2637,1466,1495]" country="Mexico" name="Oaxaca" pageId="7" pageNumber="626">Oaxaca</collectingRegion>
</taxonomicName>
), E 
<collectingCountry id="E9FC764FFFBBBA17BC23F286BAE6FA31" box="[2097,2240,1510,1535]" name="Honduras" pageId="7" pageNumber="626">Honduras</collectingCountry>
, 
<collectingCountry id="E9FC764FFFBBBA17BCC4F286BB41FA31" box="[2262,2407,1510,1535]" name="Nicaragua" pageId="7" pageNumber="626">Nicaragua</collectingCountry>
, 
<collectingCountry id="E9FC764FFFBBBA17BD6CF286B831FA31" box="[2430,2583,1510,1535]" name="Costa Rica" pageId="7" pageNumber="626">Costa Rica</collectingCountry>
, 
<collectingCountry id="E9FC764FFFBBBA17BE3DF286BA57F9E8" name="Colombia" pageId="7" pageNumber="626">Colombia</collectingCountry>
, 
<collectingCountry id="E9FC764FFFBBBA17BC90F16DBB33F9E8" box="[2178,2325,1549,1574]" name="Venezuela" pageId="7" pageNumber="626">Venezuela</collectingCountry>
, 
<collectingCountry id="E9FC764FFFBBBA17BD3AF16DBBB2F9E8" box="[2344,2452,1549,1574]" name="Guyana" pageId="7" pageNumber="626">Guyana</collectingCountry>
, and CW &amp; E 
<collectingCountry id="E9FC764FFFBBBA17BC1CF154BA46F983" box="[2062,2144,1588,1613]" name="Brazil" pageId="7" pageNumber="626">Brazil</collectingCountry>
; also on 
<collectingCountry id="E9FC764FFFBBBA17BCCEF154BB73F983" box="[2268,2389,1588,1613]" name="Trinidad and Tobago" pageId="7" pageNumber="626">Trinidad</collectingCountry>
I.
