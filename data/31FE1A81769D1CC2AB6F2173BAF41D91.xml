<subSubSection id="2A8D9CA204D8A482BAEB2B26F2AD1C35" pageId="null" pageNumber="290" type="description">
<paragraph id="86EDE1607173B7C05B81415C74565C27" pageId="null" pageNumber="290">
1 
<normalizedToken id="C217FB8599A453B519D34CA5489BBA85" originalValue="jährig" pageId="null" pageNumber="290">jaehrig</normalizedToken>
, behaart. 
<emphasis id="144A2743CEB03DE5F39F200DE8863A4E" italics="true" pageId="null" pageNumber="290">
<normalizedToken id="F21EAA89050CA0780B5549F42CE82C0F" originalValue="Blütenstand" pageId="null" pageNumber="290">Bluetenstand</normalizedToken>
eine mehrere Zentimeter lange 
<normalizedToken id="DFEC9BEFC9DCB276FF399DAE237CFE00" originalValue="Ähre" pageId="null" pageNumber="290">Aehre</normalizedToken>
.
</emphasis>
<normalizedToken id="96EEF32CAC896614697CE07FA8AA3F89" originalValue="Ährchen" pageId="null" pageNumber="290">Aehrchen</normalizedToken>
<normalizedToken id="3280CA4511DC3DD5FC6391375909D63A" originalValue="mehrblütig" pageId="null" pageNumber="290">mehrbluetig</normalizedToken>
(bis 10 
<normalizedToken id="BF1DB8DCDB5ED5D444BDA7F5F6F7529C" originalValue="blütig" pageId="null" pageNumber="290">bluetig</normalizedToken>
). 
<normalizedToken id="50113D302AEF629A5C3E99C9D1E50B59" originalValue="Hüllspelzen" pageId="null" pageNumber="290">Huellspelzen</normalizedToken>
2, 
<emphasis id="B40638C8CFD96331BC73E23F162D2597" italics="true" pageId="null" pageNumber="290">
die obere so lang wie die Deckspelzen, etwa 3mal so lang wie die untere 
<normalizedToken id="FBD0A0CF97D3086AF274D3162D8BF999" originalValue="Hüllspelze" pageId="null" pageNumber="290">Huellspelze</normalizedToken>
. Deckspelzen auf dem 
<normalizedToken id="4A2FA49CD3A65F8B2A8A7098819752EF" originalValue="Rücken" pageId="null" pageNumber="290">Ruecken</normalizedToken>
etwas 
<normalizedToken id="CE5EB6F9DC8422CD6A5CAF6A02DCE3D5" originalValue="über" pageId="null" pageNumber="290">ueber</normalizedToken>
der Mitte mit langer
</emphasis>
(an trockenem Material gedrehter und geknieter) 
<emphasis id="5EAB19144C312E64D7667EC5D05AE384" italics="true" pageId="null" pageNumber="290">
Granne. 
<normalizedToken id="E37DC030E78BFD0896D5A85C3CA0378F" originalValue="Ährenachse" pageId="null" pageNumber="290">Aehrenachse</normalizedToken>
</emphasis>
(Spindel) 
<emphasis id="A666B185F0223B1CAAF5B57C36C1B8A4" italics="true" pageId="null" pageNumber="290">
zur Reifezeit zerfallend; jedes 
<normalizedToken id="A44039ECAEDE7401B1DBB71BCED61B32" originalValue="Ährchen" pageId="null" pageNumber="290">Aehrchen</normalizedToken>
als Ganzes mit einem Teil der 
<normalizedToken id="346CB9368EEB19318FFB04E226D3C4D9" originalValue="Ährenachse" pageId="null" pageNumber="290">Aehrenachse</normalizedToken>
abfallend.
</emphasis>
</paragraph>
<paragraph id="B2A813530D60A71DE0C7C568A1D75FA5" pageId="null" pageNumber="290">
Die Gattung 
<taxonomicName id="5C243BAE176A78057E9158348D454C75" class="Liliopsida" family="Poaceae" genus="Gaudinia" kingdom="Plantae" order="Poales" pageId="null" pageNumber="290" phylum="Tracheophyta" rank="genus">
<emphasis id="3BB9B9542DE3E92C924A882ED04F2E17" italics="true" pageId="null" pageNumber="290">Gaudinia</emphasis>
</taxonomicName>
<normalizedToken id="D47C74DECA9DD32D62D7C39867BBA6E8" originalValue="umfaßt" pageId="null" pageNumber="290">umfasst</normalizedToken>
<emphasis id="35019B2110D0FA538B1774C2950D0B17" italics="true" pageId="null" pageNumber="290">
2 Arten; 
<taxonomicName id="410BE22CC76E083554D7FD05B16239D0" authority="Gay" authorityName="Gay" class="Liliopsida" family="Poaceae" genus="Gaudinia" kingdom="Plantae" order="Poales" pageId="null" pageNumber="290" phylum="Tracheophyta" rank="species" species="geminifolia">G. geminifolia Gay</taxonomicName>
</emphasis>
wird nur von den Azoren angegeben.
</paragraph>
