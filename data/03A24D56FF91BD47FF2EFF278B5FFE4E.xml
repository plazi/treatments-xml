<figureCitation id="1330E0C5FF91BD47FD89FE368B5BFE4E" box="[533,601,453,475]" captionStart="Map 3" captionStartId="5.[178,223,1463,1483]" captionTargetBox="[178,1085,643,1450]" captionTargetId="figure-250@5.[178,1085,642,1450]" captionTargetPageId="5" captionText="Map 3: Distributions of Neosclerus dupleseriatus ASSING (circles), N. brevipennis (CAMERON) (filled triangles: male-based records; open triangle: female-based record), N. assamensis (CAMERON) (diamonds), and N. obscurus nov.sp. (star)." figureDoi="http://doi.org/10.5281/zenodo.5302508" httpUri="https://zenodo.org/record/5302508/files/figure.png" pageId="6" pageNumber="1555">Map 3</figureCitation>
