<collectingCountry id="F31E79D57320FFAA9445FC02F69BFC04" name="Argentina" pageId="13" pageNumber="12">Argentina</collectingCountry>
(Misiones). 
<bibRefCitation id="EF9844B47320FFAA906AFC24F45EFC04" author="Martins UR" box="[382,553,995,1022]" pageId="13" pageNumber="12" pagination="319 - 359" refId="ref14830" refString="Martins UR. 1975. A taxonomic revision of the world Smodicini (Coleoptera, Cerambycidae). Arquivos de Zoologia 26 (4): 319 - 359." type="journal article" year="1975">Martins (1975)</bibRefCitation>
