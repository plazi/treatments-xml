<collectingCountry id="F31E79D57320FFAA91D4FBC6F776FBDA" box="[192,257,1030,1056]" name="Brazil" pageId="13" pageNumber="12">Brazil</collectingCountry>
(
<collectingRegion id="49CDF7A77320FFAA9006FBC6F721FBDA" box="[274,342,1030,1056]" country="Brazil" name="Bahia" pageId="13" pageNumber="12">Bahia</collectingRegion>
