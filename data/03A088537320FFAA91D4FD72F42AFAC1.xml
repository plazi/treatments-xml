, 
<collectingRegion id="49CDF7A77320FFAA9273FBC6F5AFFBDA" box="[871,984,1030,1056]" country="Brazil" name="Sao Paulo" pageId="13" pageNumber="12">São Paulo</collectingRegion>
, 
<collectingRegion id="49CDF7A77320FFAA92F1FBC6F243FBDA" box="[997,1076,1030,1056]" country="Brazil" name="Parana" pageId="13" pageNumber="12">Paraná</collectingRegion>
, 
<collectingRegion id="49CDF7A77320FFAA9555FBC6F29EFBDA" box="[1089,1257,1030,1056]" country="Brazil" name="Santa Catarina" pageId="13" pageNumber="12">Santa Catarina</collectingRegion>
