<collectingCountry id="F31E79D57320FFAA908DFBE8F47DFBB8" box="[409,522,1064,1090]" name="Argentina" pageId="13" pageNumber="12">Argentina</collectingCountry>
(
<collectingRegion id="49CDF7A77320FFAA930CFBE8F425FBB8" box="[536,594,1064,1090]" country="Argentina" name="Salta" pageId="13" pageNumber="12">Salta</collectingRegion>
