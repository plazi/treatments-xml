<taxonomicName id="4C0942C67320FFAA956EFC02F37BFC21" authorityName="Bruch" authorityYear="1911" box="[1146,1292,962,988]" class="Insecta" family="Cerambycidae" genus="Smodicum" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="12" phylum="Arthropoda" rank="species" species="missionum">
