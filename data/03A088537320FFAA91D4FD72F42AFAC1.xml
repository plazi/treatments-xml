<emphasis id="B97DE5577320FFAA90FDFC02F443FC26" box="[489,564,962,988]" italics="true" pageId="13" pageNumber="12">dinellii</emphasis>
</taxonomicName>
from 
<collectingCountry id="F31E79D57320FFAA936DFC02F49DFC26" box="[633,746,962,988]" name="Argentina" pageId="13" pageNumber="12">Argentina</collectingCountry>
