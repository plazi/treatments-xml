<bibRefCitation id="EF9844B47320FFAA91D4FC02F723FC26" author="Bruch C." box="[192,340,962,988]" pageId="13" pageNumber="12" pagination="164 - 178" refId="ref14289" refString="Bruch C. 1911. Longicornios argentinos nuevos o poco conocidos. II. Revista del Museo de La Plata 18: 164 - 178." type="journal article" year="1911">Bruch (1911)</bibRefCitation>
