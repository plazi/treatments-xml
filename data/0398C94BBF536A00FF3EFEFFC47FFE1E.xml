<emphasis id="B945A44FBF536A07FB5DFDD7C325FDE8" box="[1259,1351,532,558]" italics="true" pageId="3" pageNumber="69">
Anzar 
<collectionCode id="ED20E098BF536A07FA80FDD7C325FDE8" box="[1334,1351,532,558]" country="USA" lsid="urn:lsid:biocol.org:col:15406" name="Harvard University - Arnold Arboretum" pageId="3" pageNumber="69" type="Herbarium">A</collectionCode>
</emphasis>
. 
<emphasis id="B945A44FBF536A07FAE1FDD7C3CEFDE8" box="[1367,1452,532,558]" italics="true" pageId="3" pageNumber="69">
