46321 (
<collectionCode id="ED20E098BF536A07FF68FDFBC757FD94" box="[222,309,568,594]" country="India" httpUri="http://biocol.org/urn:lsid:biocol.org:col:14536" lsid="urn:lsid:biocol.org:col:14536" name="University of Kashmir" pageId="3" pageNumber="69" type="Herbarium">KASH</collectionCode>
