<subSubSection id="8C8E6575FF2F6A90FCEF945C1C2BB8EA" pageId="212" pageNumber="974" type="discussion">
<paragraph id="C42B36FEFF2F6A90FCEF945C1C2BB8EA" blockId="212.[784,1379,438,866]" lastBlockId="212.[166,1378,872,2327]" pageId="212" pageNumber="974">
Subgenus 
<taxonomicName id="03944D7DFF2F6A90FC45945C1A0DB914" authority="Kaup, 1829" box="[953,1037,517,550]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="212" pageNumber="974" phylum="Chordata" rank="genus">Myotis</taxonomicName>
; 
<taxonomicName id="03944D7DFF2F6A90FBCF945C1AE3B914" baseAuthorityName="Temminck" baseAuthorityYear="1840" box="[1075,1251,517,550]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="212" pageNumber="974" phylum="Chordata" rank="species" species="macrodactylus">macrodactylus</taxonomicName>
species group. 
<collectingRegion id="0650F81CFF2F6A90FC7494751DB7B97F" box="[904,951,556,589]" country="South Sudan" name="Lakes" pageId="212" pageNumber="974">See</collectingRegion>
<taxonomicName id="03944D7DFF2F6A90FC2C94751A50B97F" authorityName="Hollister" authorityYear="1912" box="[976,1104,556,589]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="212" pageNumber="974" phylum="Chordata" rank="species" species="petax">M. petax</taxonomicName>
. Specimens from 
<collectingRegion id="0650F81CFF2F6A90FCEC940D1D7DB947" box="[784,893,596,629]" country="China" name="Yunnan" pageId="212" pageNumber="974">Yunnan</collectingRegion>
did not cluster with the rest of 
<taxonomicName id="03944D7DFF2F6A90FCEF94251DC1B9AF" authorityName="Peters" authorityYear="1871" box="[787,961,636,669]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="212" pageNumber="974" phylum="Chordata" rank="species" species="fimbriatus">M. fimbriatus</taxonomicName>
(being sister to 
<taxonomicName id="03944D7DFF2F6A90FB5D94251B25B9AF" baseAuthorityName="Peters" baseAuthorityYear="1869" box="[1185,1317,636,669]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="212" pageNumber="974" phylum="Chordata" rank="species" species="pilosus">M. pilosus</taxonomicName>
and true 
<taxonomicName id="03944D7DFF2F6A90FCA494FA1A0AB9F6" authorityName="Peters" authorityYear="1871" box="[856,1034,675,708]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="212" pageNumber="974" phylum="Chordata" rank="species" species="fimbriatus">M. fimbriatus</taxonomicName>
) but are similar in general morphology, except for their larger size. These specimens likely represent an undescribed species (M. 
<taxonomicName id="03944D7DFF2F6A90FB6595431B51B809" authorityName="Peters" authorityYear="1871" box="[1177,1361,794,827]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" isUncertain="true" kingdom="Animalia" order="Chiroptera" pageId="212" pageNumber="974" phylum="Chordata" rank="species" species="fimbriatus">cf. fimbriatus</taxonomicName>
), although further studies are needed, and these populations are tentatively included here. 
<taxonomicName id="03944D7DFF2F6A90FCA795311A4EB8BB" authorityName="Arnback-Christie Linde" authorityYear="1908" box="[859,1102,872,905]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="212" pageNumber="974" phylum="Chordata" rank="species" species="taiwanensis">Myotis taiwanensis</taxonomicName>
was recently recognized as a distinct species, but later studies found it to be a subspecies of 
<taxonomicName id="03944D7DFF2F6A90FB5795D61B5BB882" authorityName="Peters" authorityYear="1871" box="[1195,1371,911,944]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="212" pageNumber="974" phylum="Chordata" rank="species" species="fimbriatus">M. fimbriatus</taxonomicName>
. ‘Two subspecies recognized.
</paragraph>
</subSubSection>
