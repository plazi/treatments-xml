<emphasis id="B92E275D101FFFAAFEF5FEE67A445531" box="[300,522,266,292]" italics="true" pageId="8" pageNumber="45">Beauveria bassiana</emphasis>
</taxonomicName>
(Bals.-Criv.) 
<bibCitation id="5E70F323101FFFAAFD7AFEE77C815530" author="Vuill." box="[675,1231,266,293]" journal="Bulletin de la Societe Botanique de France" page="40" pageId="8" pageNumber="45" score="165.90273174218356" volume="59" year="1912">
