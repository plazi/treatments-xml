<subSubSection id="5897F4F83C1F4B31FFFFB733FB014497" lastPageId="21" lastPageNumber="472" pageId="20" pageNumber="471" type="etymology">
<paragraph id="1032A7733C1F4B31FFFFB733FB014497" blockId="20.[127,141,2098,2117]" lastBlockId="21.[151,1437,151,213]" lastPageId="21" lastPageNumber="472" pageId="20" pageNumber="471">
A 
<emphasis id="22F97B613C1E4B31FF47BF96FEBD44F3" bold="true" box="[199,334,151,177]" pageId="21" pageNumber="472">Etymology.</emphasis>
<taxonomicName id="D78DDCF03C1E4B31FED5BF96FD4B44F3" authority="Pearson &amp; Rouse, 2022" authorityName="Pearson &amp; Rouse" authorityYear="2022" box="[341,696,151,177]" class="Polychaeta" family="Phyllodocidae" genus="Galapagomystides" kingdom="Animalia" order="Phyllodocida" pageId="21" pageNumber="472" phylum="Annelida" rank="species" species="bobpearsoni" status="n. sp.">
<emphasis id="22F97B613C1E4B31FED5BF96FD4B44F3" box="[341,696,151,177]" italics="true" pageId="21" pageNumber="472">Galapagomystides bobpearsoni</emphasis>
</taxonomicName>
<taxonomicNameLabel id="39CAC61A3C1E4B31FD3FBF96FD0844F3" box="[703,763,151,177]" pageId="21" pageNumber="472" rank="species">n. sp.</taxonomicNameLabel>
