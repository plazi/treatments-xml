— N 
<collectingCountry id="F31E7642FFCBFFCAFD9FF900E495F92D" box="[596,680,1719,1748]" name="Japan" pageId="14" pageNumber="421">Japan</collectingCountry>
(
<collectingRegion id="49CDF830FFCBFFCAFD0BF900E56EF92D" box="[704,851,1719,1748]" country="Japan" name="Hokkaido" pageId="14" pageNumber="421">Hokkaido</collectingRegion>
