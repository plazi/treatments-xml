<subSubSection id="BBEF2C1140C1F3D6837904786933779B" pageId="null" pageNumber="590" type="nomenclature">
<paragraph id="91E0284F662A3C0DC9B92F8C8D82351E" pageId="null" pageNumber="590">
<taxonomicName id="102BCD10AB970DB19251E1EEAEC0D4FF" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Lactuca" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="virosa">
Lactuca 
<normalizedToken id="D057349F2A38934B9B464CB571EE6AE6" originalValue="virósa" pageId="null" pageNumber="590">virosa</normalizedToken>
<authorityName id="F977D007C51A7EA9250DE58F6D300ABC" pageId="null" pageNumber="590">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="99F3DE6BFE9EE435EDCF6553BA48E766" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="26D80A2BEF17F8AD9DEE6091C345DFD5" pageId="null" pageNumber="590">Gift-Lattich</paragraph>
</subSubSection>
</title>
<subSubSection id="87FE6FD8EAE9F727D9E39E70056FED72" pageId="null" pageNumber="590" type="description">
<paragraph id="DBC4F579FBFE819DE4B0D8542FD87744" pageId="null" pageNumber="590">
1- oder 2 
<normalizedToken id="084282A64F7822731D7A9B149427E55B" originalValue="jährig" pageId="null" pageNumber="590">jaehrig</normalizedToken>
, mit verzweigten Wurzeln; 60-150 cm hoch; 
<emphasis id="431C5C751DE7319BAA1098BB596FF056" italics="true" pageId="null" pageNumber="590">nach Mohn riechend.</emphasis>
Stengel und 
<normalizedToken id="F461A2406170445E4F6ED81B423B1112" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
wie 
<taxonomicName id="BC1FAAC5E2AD7AEAD07FD5B2201E24D6" class="Magnoliopsida" family="Asteraceae" genus="Lactuca" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="serriola">
<emphasis id="ED9CCB27C23973212AB0D7A44068D291" italics="true" pageId="null" pageNumber="590">
<authorityName id="8650E3BAAA1B6454AF136CCC36CB7DF6" pageId="null" pageNumber="590">L.</authorityName>
Serriola
</emphasis>
</taxonomicName>
(Nr. 6), aber 
<emphasis id="8219E8CC3F9CEBEA462A4D266C269D8A" italics="true" pageId="null" pageNumber="590">
die 
<normalizedToken id="714C7FB0432E5F0B239C9810C0B318FD" originalValue="Stengelblätter" pageId="null" pageNumber="590">Stengelblaetter</normalizedToken>
mit horizontaler Spreite
</emphasis>
, ungeteilt, sitzend, mit 2 breiten, 
<normalizedToken id="608EB2C7096C09E5CE57BB2C6240ED53" originalValue="gezähnten" pageId="null" pageNumber="590">gezaehnten</normalizedToken>
Zipfeln den Stengel umfassend. 
<normalizedToken id="759DB15C9D6AA114A8FD22E0B053B4BB" originalValue="Blütenköpfe" pageId="null" pageNumber="590">Bluetenkoepfe</normalizedToken>
in einer breiten, 
<normalizedToken id="1F728A75E9C64E47159033B3A93FD81D" originalValue="kegelförmigen" pageId="null" pageNumber="590">kegelfoermigen</normalizedToken>
Rispe, mehr als 5 
<normalizedToken id="5B74D400BB442D35E6B2F20FE49E20BC" originalValue="blütig" pageId="null" pageNumber="590">bluetig</normalizedToken>
. 
<normalizedToken id="5C8E39F94CE3C260100B2C2A90AD186E" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
10-12 mm lang. Krone hellgelb (auch getrocknet), 1-2 cm lang. 
<normalizedToken id="D466037452A3F1656E87F0114185274A" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
(mit Schnabel) 6-8 mm lang, 
<emphasis id="3A15B59E25853CAB1092961BA228A5DA" italics="true" pageId="null" pageNumber="590">
schwarz, 
<normalizedToken id="AD101F25C86DA4C59D87AE5140DA2B22" originalValue="höckerig" pageId="null" pageNumber="590">hoeckerig</normalizedToken>
, meist ohne Haare
</emphasis>
, beiderseits mit je 5-9 
<normalizedToken id="7E2340A5FAEE51E55AE9AD73C14C3607" originalValue="Längsrippen" pageId="null" pageNumber="590">Laengsrippen</normalizedToken>
; 
<emphasis id="FBB5B8F074304E16D5234CB5B87FF1FD" italics="true" pageId="null" pageNumber="590">
Schnabel 
<normalizedToken id="D9B4966EAD71FB2F60EB2D6E576F3EF0" originalValue="weiß" pageId="null" pageNumber="590">weiss</normalizedToken>
, deutlich 
<normalizedToken id="70D3B0DA58D99BB781807835D2EE54D7" originalValue="kürzer" pageId="null" pageNumber="590">kuerzer</normalizedToken>
als der Rest der Frucht.
</emphasis>
- 
<normalizedToken id="1C11F90EBE973A25BF5ADD312834536D" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="2EA27EBCBF87762AA20A91A57716CEF4" originalValue="früher" pageId="null" pageNumber="590">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="57AF463D29D644084F64A4F5ABECF301" pageId="null" pageNumber="590">
<emphasis id="CC936AC461657614C92C4D9C9C8724B4" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="3D8173B41ADCFCE3E1DC9CEB0CD325E8" italics="true" pageId="null" pageNumber="590">18:</emphasis>
Material aus botanischen 
<normalizedToken id="6BBB35E10DA926CCC8475E7E48F69B25" originalValue="Gärten" pageId="null" pageNumber="590">Gaerten</normalizedToken>
(Babcock et al. 1937, Lindqvist 1960), aus England (Thompson et al. 1941), aus dem Aostatal (Gadella und Kliphuis 1970).
</paragraph>
<paragraph id="33C313EB0E70CBB77924C6B424187E71" pageId="null" pageNumber="590">
<emphasis id="0134F315F8953E667CD2F9AD34137954" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Kollin, selten montan. Trockene, 
<normalizedToken id="ED2FC4352AE610AA16CE628613C2588F" originalValue="nährstoffreiche" pageId="null" pageNumber="590">naehrstoffreiche</normalizedToken>
, steinige, lehmige 
<normalizedToken id="3B7412A5209B344273BC48DF4EB4CC6F" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="85B2A54BDD26C63B71F310EE5A6570BC" originalValue="Schuttplätze" pageId="null" pageNumber="590">Schuttplaetze</normalizedToken>
, 
<normalizedToken id="A793E030768CDF2757F41893AA57A7A1" originalValue="Wegränder" pageId="null" pageNumber="590">Wegraender</normalizedToken>
, 
<normalizedToken id="698E3F2F0747167A2B3732417DA62B17" originalValue="Dämme" pageId="null" pageNumber="590">Daemme</normalizedToken>
, Unkrautgesellschaften.
</paragraph>
<paragraph id="FB8DF4AEB5E003D9613054B07DEE58B0" pageId="null" pageNumber="590">
<emphasis id="8BEE717E4DC3ED42538934A3A89E23C7" italics="true" pageId="null" pageNumber="590">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="AA6D5D491A0BFD3837E02442450F4A6B" originalValue="Nordwärts" pageId="null" pageNumber="590">Nordwaerts</normalizedToken>
vereinzelt und zum Teil nur verschleppt (als Arzneipflanze angepflanzt und verwildert) bis Nordfrankreich, Mitteldeutschland, Alpen; 
<normalizedToken id="B1F651215034D07B5A92C1BFDB05E1A6" originalValue="südwärts" pageId="null" pageNumber="590">suedwaerts</normalizedToken>
bis Nordafrika, 
<normalizedToken id="277B78265DF2E6E0035AB56036648DD0" originalValue="Südwestasien" pageId="null" pageNumber="590">Suedwestasien</normalizedToken>
.- Im Gebiet: Oberrheinische Tiefebene, 
<normalizedToken id="D741145CDAB1875BB9D7FD17863BC42D" originalValue="Jurasüdfuß" pageId="null" pageNumber="590">Jurasuedfuss</normalizedToken>
, 
<normalizedToken id="7D4CC808B266F34F97370A368E8442FA" originalValue="Dép" pageId="null" pageNumber="590">Dep</normalizedToken>
. Jura (Salins), Savoyen (Tarentaise, Maurienne), Genferseegebiet, Wallis (Martigny bis Brig), Aostatal (
<normalizedToken id="F0D06E4E5CB959B0F1964404B52185A4" originalValue="Châtillon" pageId="null" pageNumber="590">Chatillon</normalizedToken>
bis Valgrisenche), Val 
<normalizedToken id="1DD63FDC98BED692F4E6582C6C0E5AD8" originalValue="d’Ossola" pageId="null" pageNumber="590">d'Ossola</normalizedToken>
, Comerseegebiet (Colico), Vintschgau (Fragsbourg, 
<normalizedToken id="9378FACD32B2F02AAC4F204F1BC1EA98" originalValue="Schloß" pageId="null" pageNumber="590">Schloss</normalizedToken>
Brandis); ziemlich selten und 
<normalizedToken id="106EC72ACE7F6E6B9674CA3A3A276A9D" originalValue="unbeständig" pageId="null" pageNumber="590">unbestaendig</normalizedToken>
; gelegentlich adventiv (z. B. 
<normalizedToken id="42B99BA38EFB1EAB1E055E78ABD47791" originalValue="südliches" pageId="null" pageNumber="590">suedliches</normalizedToken>
Tessin).
</paragraph>
</subSubSection>
