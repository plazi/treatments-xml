<taxonomicName id="4C7424938D20FFC7FB6BFA73FF1DA844" class="Magnoliopsida" family="Fabaceae" genus="Medicago" kingdom="Plantae" order="Fabales" pageId="1" pageNumber="296" phylum="Tracheophyta" rank="genus">
