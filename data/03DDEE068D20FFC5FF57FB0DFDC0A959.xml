<taxonomicName id="4C7424938D20FFC7FE73F993FDEDA844" box="[394,538,1547,1573]" class="Magnoliopsida" family="Convolvulaceae" genus="Convolvulus" kingdom="Plantae" order="Solanales" pageId="1" pageNumber="296" phylum="Tracheophyta" rank="genus">
<emphasis id="B90083028D20FFC7FE73F993FDEDA844" box="[394,538,1547,1573]" italics="true" pageId="1" pageNumber="296">Convolvulus</emphasis>
</taxonomicName>
