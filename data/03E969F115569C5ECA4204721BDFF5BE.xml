<subSubSection id="32CAFC0853C7F50E6EC00151B52C30F9" pageId="null" pageNumber="87" type="description">
<paragraph id="0A76AF6E7597CBF3A2D2D8EDF7882D7D" pageId="null" pageNumber="87">
<emphasis id="9231BD73CAC66076BA932B09F42EB440" italics="true" pageId="null" pageNumber="87">
1-2 
<normalizedToken id="2D3FAE7F4B4EBC425EC42D14652BB62E" originalValue="jährig" pageId="null" pageNumber="87">jaehrig</normalizedToken>
; 10-100 cm hoch, kahl
</emphasis>
, aufrecht. Kein Rhizom. 
<normalizedToken id="EB5CFAC51C7AA4D88E1181BCD4CD1797" originalValue="Grundständige" pageId="null" pageNumber="87">Grundstaendige</normalizedToken>
<normalizedToken id="EF47F25CC4BFE8E3E55CB71C241F82E1" originalValue="Blätter" pageId="null" pageNumber="87">Blaetter</normalizedToken>
lang gestielt, 
<normalizedToken id="EE7CAD842417F979455374A6413B985E" originalValue="über" pageId="null" pageNumber="87">ueber</normalizedToken>
die Mitte hinaus, oft bis zum Grunde 3teilig; die 
<normalizedToken id="6627A3CB47C433C305D8FF8A59FB74D2" originalValue="keilförmigen" pageId="null" pageNumber="87">keilfoermigen</normalizedToken>
Abschnitte nochmals bis auf 
<normalizedToken id="F45EFAD555CD9BC3AF0F129E10F5688B" originalValue="¾" pageId="null" pageNumber="87">3/4</normalizedToken>
2-3teilig; Zipfel grob 
<normalizedToken id="401A1810599F6D1B9F0EE5015BCF6111" originalValue="gezähnt" pageId="null" pageNumber="87">gezaehnt</normalizedToken>
. Stengel gefurcht, meist reich verzweigt. Untere 
<normalizedToken id="FD94828EB08ED3161A82A109BB53F7BE" originalValue="Stengelblätter" pageId="null" pageNumber="87">Stengelblaetter</normalizedToken>
lang gestielt, 
<emphasis id="E7F6ACCB32354D6005D17B296EC54FDE" italics="true" pageId="null" pageNumber="87">von gleicher Form wie</emphasis>
die 
<normalizedToken id="FC82D027F5EDC317EB850EED1D78EF19" originalValue="grundständigen" pageId="null" pageNumber="87">grundstaendigen</normalizedToken>
<normalizedToken id="DE9E9E40C3D00A370403A63132958344" originalValue="Blätter" pageId="null" pageNumber="87">Blaetter</normalizedToken>
; obere sitzend, bis zum Grunde 3teilig, Abschnitte schmal lanzettlich, grob 
<normalizedToken id="0F6E2E93D50FB585A9E2952BD09018E4" originalValue="gezähnt" pageId="null" pageNumber="87">gezaehnt</normalizedToken>
oder ganzrandig. 
<normalizedToken id="8EE538FC847F4F6F0560E3FDD2CE9DFB" originalValue="Blüten" pageId="null" pageNumber="87">Blueten</normalizedToken>
hellgelb, im Durchmesser 0,5-1 cm; 
<normalizedToken id="8F785FFBF5B3C497C0D014D8CD62ACEC" originalValue="Kelchblätter" pageId="null" pageNumber="87">Kelchblaetter</normalizedToken>
2-4 mm lang, 
<emphasis id="20E207E58602A4F746F6F3F05BF4838C" italics="true" pageId="null" pageNumber="87">
<normalizedToken id="1990FA5A10490ED263AE04C05A35BAAB" originalValue="rückwärts" pageId="null" pageNumber="87">rueckwaerts</normalizedToken>
gerichtet
</emphasis>
, 
<normalizedToken id="11C0DFA9A9518AE21E5A4E63D16ECAB7" originalValue="früh" pageId="null" pageNumber="87">frueh</normalizedToken>
abfallend. 
<normalizedToken id="F6576A038022DD734CEBFF07800EAA31" originalValue="Kronblätter" pageId="null" pageNumber="87">Kronblaetter</normalizedToken>
etwas 
<normalizedToken id="94FBE898FAB2D469AD899CB4E14EDB24" originalValue="kürzer" pageId="null" pageNumber="87">kuerzer</normalizedToken>
. 
<emphasis id="85FCDB09FCB0664F4C253FF3843F0CD4" italics="true" pageId="null" pageNumber="87">
Reife 
<normalizedToken id="041307D483650AF49882A30952E80F50" originalValue="Früchtchen" pageId="null" pageNumber="87">Fruechtchen</normalizedToken>
einen zylindrischen oder 
<normalizedToken id="95068A8766DE123DD87AA6DA234536A2" originalValue="eiförmigen" pageId="null" pageNumber="87">eifoermigen</normalizedToken>
Kopf bildend
</emphasis>
(
<emphasis id="E1B448F91DE5E22291914CA68D4073C4" italics="true" pageId="null" pageNumber="87">
bis 100 
<normalizedToken id="BF1940D1D77671061C120A2D8A055998" originalValue="Früchtchen" pageId="null" pageNumber="87">Fruechtchen</normalizedToken>
je Kopf
</emphasis>
). 
<normalizedToken id="3551291319B905DDD151CBF3D248FC8A" originalValue="Früchtchen" pageId="null" pageNumber="87">Fruechtchen</normalizedToken>
rundlich, flach, im Durchmesser 0,8-1 mm; Rand etwas 
<normalizedToken id="44A7F5855BA543D52DD3EFB14A521B9B" originalValue="eingestülpt" pageId="null" pageNumber="87">eingestuelpt</normalizedToken>
; Seiten glatt oder schwach querrunzelig, kahl; Schnabel bis 0,2 mm lang, gerade. 
<normalizedToken id="4434E40EBBE1CB6BCF60FF240BF849F0" originalValue="Blütenboden" pageId="null" pageNumber="87">Bluetenboden</normalizedToken>
zerstreut behaart. - 
<normalizedToken id="F89EDE860C87472C6E57F9D3C7CFE03A" originalValue="Blüte" pageId="null" pageNumber="87">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="ED002576E8CD8E85D0C58A7C48385581" pageId="null" pageNumber="87">
<emphasis id="2B016AD36ECEA55F3D089B29DA213F2C" italics="true" pageId="null" pageNumber="87">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="2AA9BDA984ECC375210E59434096A04F" italics="true" pageId="null" pageNumber="87">16, 32:</emphasis>
Material aus Holland (Gadella und Kliphuis 1967Gadella und Kliphuis 1968). 
<emphasis id="B57CEA4847803A917A78E10CA173609A" italics="true" pageId="null" pageNumber="87">2n</emphasis>
= 
<emphasis id="83E13C6758D707330B2376548ADEBB78" italics="true" pageId="null" pageNumber="87">32:</emphasis>
Material aus Schweden (Langlet 1936), Wisconsin, USA (Coonen 1939) und Portugal, keine 
<normalizedToken id="8EE9E34252BE13368CEE6662CA563829" originalValue="Störungen" pageId="null" pageNumber="87">Stoerungen</normalizedToken>
in der Meiose des Pollens (Neves 1944). 
<emphasis id="6BF391C48600B68AE6C46D544F7C43F7" italics="true" pageId="null" pageNumber="87">2n</emphasis>
= 
<emphasis id="8AC8572389ACCE16DC22BF80BDEBD7C8" italics="true" pageId="null" pageNumber="87">64:</emphasis>
Material aus Kanada (Mulligan und Porsild 1969).
</paragraph>
<paragraph id="DA1C1689D904D541CFC7A58AA2B5AAAF" pageId="null" pageNumber="87">
<emphasis id="29AD76C0E463CADAF92FF03C7B695340" italics="true" pageId="null" pageNumber="87">
<pageBreakToken id="9C4E9CE886874E42DC046760DDB261C4" pageId="null" pageNumber="87">Polygono-Bidentetum</pageBreakToken>
</emphasis>
Lohm. 1950 und 
<emphasis id="9FA387AFC4FD4E18E7BABD1A17F2ED92" italics="true" pageId="null" pageNumber="87">Rumici-Ranunculetum scelerati</emphasis>
Oberdorfer 1957.
</paragraph>
<paragraph id="2A6B6AA21FABD5CEE4EF7D8594664831" pageId="null" pageNumber="87">
<emphasis id="757EFB7978B103E53D4BE89E21BF8907" italics="true" pageId="null" pageNumber="87">Verbreitung. Eurasiatische Pflanze:</emphasis>
Heute fast 
<normalizedToken id="FEF83D8BCB16F6B039F5A2B0053B6CA7" originalValue="über" pageId="null" pageNumber="87">ueber</normalizedToken>
die ganze Erde verschleppt. - Im Gebiet zerstreut, ziemlich selten und 
<normalizedToken id="6A28F9B57C0689EA0BE0ADCB639D931A" originalValue="unbeständig" pageId="null" pageNumber="87">unbestaendig</normalizedToken>
.
</paragraph>
</subSubSection>
