<taxonomicName id="79495CAE413E22A6F608F4EC397CF358" authorityName="Framenau &amp; Castanheira" authorityYear="2022" baseAuthorityName="L. Koch" baseAuthorityYear="1871" family="Araneidae" genus="Mangrovia" kingdom="Animalia" lsidName="Mangrovia albida" order="Araneae" pageId="0" pageNumber="137" rank="species" species="albida">
