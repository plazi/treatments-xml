<subSubSection id="D184298C9B75C31DE93767D55D68B124" pageId="null" pageNumber="137" type="description">
<paragraph id="42264C0B365E040DA59990087A44E203" pageId="null" pageNumber="137">
Unterscheidet sich von 
<taxonomicName id="CA0586EA1B7F5AADCE945865D36C521E" class="Magnoliopsida" family="Brassicaceae" genus="Iberis" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="137" phylum="Tracheophyta" rank="species" species="umbellata">
<emphasis id="D9843CC33D4D7B4B1C20640A1F6E622A" italics="true" pageId="null" pageNumber="137">I. umbellata</emphasis>
</taxonomicName>
(Nr. 3) durch folgende Merkmale: 
<normalizedToken id="89D39A34CF7D69D5ACBFFEAE35460902" originalValue="Blätter" pageId="null" pageNumber="137">Blaetter</normalizedToken>
bis 5 mm breit; 
<normalizedToken id="DC1EB0DD27928AC2CF32F4460B124318" originalValue="Kelchblätter" pageId="null" pageNumber="137">Kelchblaetter</normalizedToken>
2-2,5 mm lang; 
<emphasis id="EDA9775BE01CDAEB9B6B6E878325F54B" italics="true" pageId="null" pageNumber="137">
<normalizedToken id="0D2A93735A369D3363A7AD73207E4F1B" originalValue="Kronblätter" pageId="null" pageNumber="137">Kronblaetter</normalizedToken>
<normalizedToken id="012995C5EDFAF9465E1A1674050B68A1" originalValue="weiß" pageId="null" pageNumber="137">weiss</normalizedToken>
bis purpurn, 6-8 mm lang; Fruchtstand 
<normalizedToken id="5A2C18A8B7D87ACFE6A143D4CD5150D7" originalValue="verlängert" pageId="null" pageNumber="137">verlaengert</normalizedToken>
, deutlich 
<normalizedToken id="5F010617F6191CDE5F477485F64600FC" originalValue="länger" pageId="null" pageNumber="137">laenger</normalizedToken>
als breit;
</emphasis>
Fruchtstiele fast horizontal abstehend; 
<normalizedToken id="FC6F22C75704917805B7FA877B89B232" originalValue="Früchte" pageId="null" pageNumber="137">Fruechte</normalizedToken>
6-8 mm lang; 
<emphasis id="2505DED96D5AC1710AC70C624543E299" italics="true" pageId="null" pageNumber="137">Griffel an der Frucht 1-1,5 mm lang.</emphasis>
- 
<normalizedToken id="38FD56B5BE26150FD8CAAC84CE55EF87" originalValue="Blüte" pageId="null" pageNumber="137">Bluete</normalizedToken>
: 
<normalizedToken id="613C6101801CF22BBC562F7524AB8AA9" originalValue="Später" pageId="null" pageNumber="137">Spaeter</normalizedToken>
Sommer und 
<normalizedToken id="440580D0320200B71292483806C57819" originalValue="früher" pageId="null" pageNumber="137">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="1CDF9563A2DC32DAB761683D6AE0F3C9" pageId="null" pageNumber="137">
<emphasis id="0CB62B32E3CC422BACDEAECA2D4AD4C9" italics="true" pageId="null" pageNumber="137">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="6A516403E0F94F98DD0399BDFCC5053D" pageId="null" pageNumber="137">
<emphasis id="F68E86530BCF9810658627FEDD0B2E17" italics="true" pageId="null" pageNumber="137">Standort.</emphasis>
Kollin und montan. Offene, steinige, trockene 
<normalizedToken id="1B0A664D9684BC05152B2418C0DA85EC" originalValue="Kalkböden" pageId="null" pageNumber="137">Kalkboeden</normalizedToken>
in warmen Lagen. Trockenrasen, Schuttstellen.
</paragraph>
<paragraph id="C51F05163DA8EC4CA11ADBC2CE0E8A61" pageId="null" pageNumber="137">
<emphasis id="026EF53082276AFEA0089F4ED7B50C26" italics="true" pageId="null" pageNumber="137">
Verbreitung. 
<normalizedToken id="3F444D308317335F883702597B325D66" originalValue="Südeuropäische" pageId="null" pageNumber="137">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Nordostspanien, 
<normalizedToken id="EAA5341A5C1D47DEC499FD1816C2A328" originalValue="Südfrankreich" pageId="null" pageNumber="137">Suedfrankreich</normalizedToken>
(Cevennen, Westalpen, Jura), Nordostitalien, westliches Jugoslawien. - Im Gebiet: 
<normalizedToken id="4ECD5D020A6019C8749CBC2F8106420F" originalValue="Südlicher" pageId="null" pageNumber="137">Suedlicher</normalizedToken>
Jura (Bugey im 
<normalizedToken id="A05D19E25F40BA3C917622EF02641F68" originalValue="Dép" pageId="null" pageNumber="137">Dep</normalizedToken>
. Ain und Mandeur im 
<normalizedToken id="A1A007C37549086602EAC2519267F77F" originalValue="Dép" pageId="null" pageNumber="137">Dep</normalizedToken>
. Jura); sonst gelegentlich als Zierpflanze 
<normalizedToken id="BA84B889712CDD31A4D74D32C4605AA3" originalValue="angesät" pageId="null" pageNumber="137">angesaet</normalizedToken>
und verwildert.
</paragraph>
</subSubSection>
