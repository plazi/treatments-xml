<quantity id="2E379B383F05FF92FE65FEA4FE5BFEDD" box="[388,443,290,316]" metricMagnitude="-2" metricUnit="m" metricValue="7.0" pageId="48" pageNumber="49" unit="cm" value="7.0">7 cm</quantity>
