<subSubSection id="A7D318CF20FB8650945382C24E4D1328" pageId="null" pageNumber="230" type="vernacular_names">
<paragraph id="C04C72D81FDE54FF280A525D95A58BB6" pageId="null" pageNumber="230">
Schopfiges 
<normalizedToken id="2FC5717D60DEA51ECF1C17FF847C38BE" originalValue="Läusekraut" pageId="null" pageNumber="230">Laeusekraut</normalizedToken>
</paragraph>
</subSubSection>
</title>
<subSubSection id="EE7717CFD665765A261DE83A3FA9A9B3" pageId="null" pageNumber="230" type="description">
<paragraph id="CFBC374E91544498689B8A9D9EC28D19" pageId="null" pageNumber="230">
Ausdauernd; 10-40 cm hoch. Stengel aufrecht, zerstreut behaart. 
<normalizedToken id="6FC16C3032187485FF8711D695DC9D63" originalValue="Blätter" pageId="null" pageNumber="230">Blaetter</normalizedToken>
kahl oder zerstreut behaart, bis auf den Mittelnerv fiederteilig, die 
<normalizedToken id="5845E68D63B3D6B2D994BDA52E74FA06" originalValue="größeren" pageId="null" pageNumber="230">groesseren</normalizedToken>
8-25 cm lang; Abschnitte nochmals bis fast auf den Mittelnerv fiederteilig, mit 
<normalizedToken id="A40E3FDB697B148B65DCBA20A9DC8104" originalValue="gezähnten" pageId="null" pageNumber="230">gezaehnten</normalizedToken>
Zipfeln; Blattstiel behaart. 
<emphasis id="F3FF664D65844E8308507E1198D0358A" italics="true" pageId="null" pageNumber="230">
<normalizedToken id="3BF47A0802F2EF2D86BE4062CD01006B" originalValue="Blätter" pageId="null" pageNumber="230">Blaetter</normalizedToken>
im 
<normalizedToken id="C8D952409CA4BB473C7E3AE70ABB1F90" originalValue="Blütenstand" pageId="null" pageNumber="230">Bluetenstand</normalizedToken>
<normalizedToken id="E49542ADCE0472C3D9FF370649F069B1" originalValue="kürzer" pageId="null" pageNumber="230">kuerzer</normalizedToken>
als die 
<normalizedToken id="A7C7A3EE98E5EB6A14D32EEF275C23DB" originalValue="Blüten" pageId="null" pageNumber="230">Blueten</normalizedToken>
</emphasis>
, behaart. 
<emphasis id="DC6C93C8F0AF69A9F3F3A483DF7C86A9" italics="true" pageId="null" pageNumber="230">
<normalizedToken id="4FE95C5588572091534FAD10CE8C3935" originalValue="Blüten" pageId="null" pageNumber="230">Blueten</normalizedToken>
in einem 
<normalizedToken id="9611F39335D32E2CD0F29772F9DCF813" originalValue="längeren" pageId="null" pageNumber="230">laengeren</normalizedToken>
, ziemlich dichten 
<normalizedToken id="0A270EE81B151DA895408059981156EF" originalValue="Blütenstand" pageId="null" pageNumber="230">Bluetenstand</normalizedToken>
</emphasis>
, kaum abgedreht. 
<emphasis id="CDEC588F09B0F4FA4F1A1EB9E7380B99" italics="true" pageId="null" pageNumber="230">Kelch 10</emphasis>
- 
<emphasis id="A23E6EF443B317F94BF8909DE0B87998" italics="true" pageId="null" pageNumber="230">12 mm lang</emphasis>
, am Grunde abgerundet, nur bis auf etwa 
<normalizedToken id="B7DC7882D174D719CB36F6EB8487458E" originalValue="¾" pageId="null" pageNumber="230">3/4</normalizedToken>
5teilig, mit breiten, 
<emphasis id="0245406A213454418B323CC9863A9002" italics="true" pageId="null" pageNumber="230">ganzrandigen, stumpfen Zipfeln</emphasis>
(bei den andern Arten Zipfel spitz), am Rand und auf der Innenseite der Zipfel kurz behaart. Krone 18-25 mm lang, hellgelb; 
<emphasis id="29D903518AE9846315E67DC01FC1176C" italics="true" pageId="null" pageNumber="230">
Oberlippe vorn in einen kurzen, etwa 1 mm langen Schnabel 
<normalizedToken id="F5A54D0C9F9D78D082311BC5AEFBE980" originalValue="verschmälert" pageId="null" pageNumber="230">verschmaelert</normalizedToken>
und am Schnabel jederseits mit einem kurzen, schmalen Zahn, kahl;
</emphasis>
Unterlippe nur wenig abstehend, etwas 
<normalizedToken id="E8848ABCE125C77D35EFBCB68C677C21" originalValue="kürzer" pageId="null" pageNumber="230">kuerzer</normalizedToken>
als die Oberlippe, 
<emphasis id="D8833EFD9C19DD9FB48F15113A9CFE77" italics="true" pageId="null" pageNumber="230">am Rande bewimpert. Frucht fast doppelt so lang wie der Kelch</emphasis>
. Samen 2,5-3,5 mm lang. - 
<normalizedToken id="7AAA18022360445EACCE9BD7A75C7315" originalValue="Blüte" pageId="null" pageNumber="230">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="389F81B899B0638047C201F5B85BAC24" pageId="null" pageNumber="230">
<emphasis id="28BFB06ACAD01A55326B8D9DC71692FC" italics="true" pageId="null" pageNumber="230">Zytologische Angaben</emphasis>
. Keine Untersuchungen.
</paragraph>
<paragraph id="ACA88A6753909B3CFA54485E00523CAF" pageId="null" pageNumber="230">
<emphasis id="0D4C49AD7CA4528D1D184501D5202D63" italics="true" pageId="null" pageNumber="230">Standort</emphasis>
. Subalpin. Weiden.
</paragraph>
<paragraph id="670528A1B9F445C299CF205ACC7ED47F" pageId="null" pageNumber="230">
<emphasis id="5B4FEF45B5084421EAAD46AA0DF0BC0D" italics="true" pageId="null" pageNumber="230">
Verbreitung. Mittel- und 
<normalizedToken id="490DC08B269176570C5E753AEEA51DD4" originalValue="südeuropäische" pageId="null" pageNumber="230">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="3F9119A0884856AA9FE86642A412910A" italics="true" pageId="null" pageNumber="230">
<normalizedToken id="7BB98F5ED5A0DFC94320935A00074BA2" originalValue="südlich" pageId="null" pageNumber="230">suedlich</normalizedToken>
</emphasis>
)
<emphasis id="01EE783726FECC54F2F780EFC3A90296" italics="true" pageId="null" pageNumber="230">:</emphasis>
Gebirge der 
<normalizedToken id="D2C55B4DF07B15A6AA31138BA7E7CCB3" originalValue="Pyrenäenhalbinsel" pageId="null" pageNumber="230">Pyrenaeenhalbinsel</normalizedToken>
(
<normalizedToken id="4B95AF88125C7C7A764105EAB33E8BBD" originalValue="südwestwärts" pageId="null" pageNumber="230">suedwestwaerts</normalizedToken>
bis Sierra Nevada), 
<normalizedToken id="7F492FD7B6CCCA78EB69B51ED5EB4808" originalValue="Pyrenäen" pageId="null" pageNumber="230">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="B737CBF92D81A7C338551E450EEA9ABE" originalValue="Corbières" pageId="null" pageNumber="230">Corbieres</normalizedToken>
, Plateau Central, Cevennen, Korsika, West- und 
<normalizedToken id="D6C607739350540718C617998D4BBB86" originalValue="Südalpen" pageId="null" pageNumber="230">Suedalpen</normalizedToken>
(
<normalizedToken id="102D6A9518E94EC18E1784CD5AD0063B" originalValue="ostwärts" pageId="null" pageNumber="230">ostwaerts</normalizedToken>
bis Savoyen und 
<normalizedToken id="339F83A92930FE979399850D1DD4D5E2" originalValue="Südtirol" pageId="null" pageNumber="230">Suedtirol</normalizedToken>
), Apennin (
<normalizedToken id="E592D8B984F2B419FC235F1069EB6222" originalValue="südwärts" pageId="null" pageNumber="230">suedwaerts</normalizedToken>
bis Kalabrien), Gebirge der Balkanhalbinsel (
<normalizedToken id="34141487A6EDF83545543E0EE7C3E4CE" originalValue="südwärts" pageId="null" pageNumber="230">suedwaerts</normalizedToken>
bis Albanien und Bulgarien). - Im Gebiet: Savoyen (vom Massif des Bauges und von der Tarentaise 
<normalizedToken id="564EAB9B686AF32F7456A88D5631AD62" originalValue="südwärts" pageId="null" pageNumber="230">suedwaerts</normalizedToken>
), Grajische Alpen, Valle 
<normalizedToken id="DCA43084EBDDDCFFFF21F8540772F071" originalValue="d’Ossola" pageId="null" pageNumber="230">d'Ossola</normalizedToken>
(Val Vigezzo), Bergamasker Alpen (Valle di Scalve); Veltlin (Alpi di Mara, Zana, Arcoglio, Monte Canale); nicht 
<normalizedToken id="3B1B90BA4842D44D5C9D0100070B1165" originalValue="häufig" pageId="null" pageNumber="230">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
