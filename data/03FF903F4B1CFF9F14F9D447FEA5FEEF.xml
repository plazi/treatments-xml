<bibRefCitation id="EFC75CD84B1CFF92153AD447FDD1FAD7" author="Trabaud, L." box="[331,561,1310,1337]" pageId="7" pageNumber="38" pagination="154 - 155" refId="ref11773" refString="Trabaud, L. (1906) Sur la presence d'un Abies nouveau au Maroc (Abies marocana). Bulletin de la Societe botanique de France 53: 154 - 155. https: // doi. org / 10.1080 / 00378941.1906.10831158" type="journal article" year="1906">Trabaud (1906: 154)</bibRefCitation>
