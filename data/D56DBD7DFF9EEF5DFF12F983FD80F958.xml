<taxonomicName id="9AC477E8FF9EEF5DFF4EF983FD55F9E8" authority="Brunner von Wattenwyl, 1895" authorityName="Brunner von Wattenwyl" authorityYear="1895" box="[203,736,1590,1616]" class="Insecta" family="Tettigoniidae" kingdom="Animalia" order="Orthoptera" pageId="54" pageNumber="55" phylum="Arthropoda" rank="tribe" tribe="Cocconotini">Cocconotini Brunner von Wattenwyl, 1895</taxonomicName>
