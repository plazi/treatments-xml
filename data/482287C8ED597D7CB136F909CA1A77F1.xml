<subSubSection id="88916555ED597D7DB398F812CC9679F0" pageId="4" pageNumber="1" type="multiple">
<caption id="94F46656ED597D7DB398F812CC9679F0" ID-DOI="http://doi.org/10.5281/zenodo.6591962" ID-Zenodo-Dep="6591962" httpUri="https://zenodo.org/record/6591962/files/figure.png" inLine="true" pageId="4" pageNumber="1" startId="4.[2009,2163,1999,2032]" targetBox="[1394,1984,1888,2301]" targetPageId="4">
<paragraph id="C03436DEED597D7DB398F812C24077C6" blockId="4.[2008,2601,1881,2308]" box="[2009,2409,1999,2032]" pageId="4" pageNumber="1">
