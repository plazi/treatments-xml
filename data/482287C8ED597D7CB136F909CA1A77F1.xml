</paragraph>
<paragraph id="C03436DEED597D7DB399F761CD1D7979" blockId="4.[2008,2601,1881,2308]" lastBlockId="4.[1391,2599,2313,3488]" pageId="4" pageNumber="1">
<taxonomicName id="078B4D5DED597D7DB399F761C28978EB" authority="Shenbrot, 1991" authorityName="Shenbrot" authorityYear="1991" box="[2008,2464,2236,2269]" class="Mammalia" family="Dipodidae" genus="Allactaga" kingdom="Animalia" order="Rodentia" pageId="4" pageNumber="1" phylum="Chordata" rank="subSpecies" species="major" subSpecies="djetysuensis">A.m.djetysuensisShenbrot,1991—SEKazakhstan(Almaty,SJambylandSouthKazakhstanregions),NKyrgyzstan(ChuyandTalasregions),andUzbekistan(NTashkentRegion).</taxonomicName>
