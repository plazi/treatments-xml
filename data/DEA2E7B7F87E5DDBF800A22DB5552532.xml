<tr id="8590E8C34C703B4F02EE35B3D30C2164" pageId="null" pageNumber="538">
<td id="19E1CBEC2F2807E5AE47C6D40C772E92" align="left" pageId="null" pageNumber="538" valign="top">
1. Kelch 8-12 mm lang; Krone 12-20 mm lang; 
<normalizedToken id="48875C662C2AB901D30749D985DA2085" originalValue="Flügel" pageId="null" pageNumber="538">Fluegel</normalizedToken>
vorn nicht verwachsen
</td>
<td id="6F4C836B46BD034F46AEB9233BE35A0F" align="left" pageId="null" pageNumber="538" valign="bottom">
<taxonomicName id="07BB46EC589460AC5039C1750EE058C2" class="Magnoliopsida" family="Fabaceae" genus="Dorycnium" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="538" phylum="Tracheophyta" rank="species" species="hirsutum">
<italic id="B71704AC0B38AA30991DDB3C9DB436EE" pageId="null" pageNumber="538">D. hirsutum</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="81A6920D11E2302CC5DBFDB159BE937A" pageId="null" pageNumber="538">
<td id="1F97346786F82BE42CE1FBCC706E8450" align="left" pageId="null" pageNumber="538" valign="top">
1*. Kelch 1,5-3,5 mm lang; Krone 3-7 mm lang; 
<normalizedToken id="4CC9400BBDA86AE371D4D95A28BB4087" originalValue="Flügel" pageId="null" pageNumber="538">Fluegel</normalizedToken>
an der Spitze miteinander verwachsen.
</td>
</tr>
<tr id="F0430E60AD6A6026C27E2C9D3BBFFF8D" pageId="null" pageNumber="538">
<td id="2322E5AA5A415B8911F4EF5B812222EB" align="left" pageId="null" pageNumber="538" valign="top">
2. Kelch 1,5-2 mm lang; Krone 3-5 mm lang; 
<normalizedToken id="72455F7042238435F5BEF8400123206B" originalValue="Teilblätter" pageId="null" pageNumber="538">Teilblaetter</normalizedToken>
zerstreut abstehend behaart, 3-5mal so lang wie breit
</td>
<td id="3110D48FE4D256EEB7FFB3DE1F68CAC6" align="left" pageId="null" pageNumber="538" valign="bottom">
<taxonomicName id="56F65871F10AD584C8FB9ADF1AD88710" class="Magnoliopsida" family="Fabaceae" genus="Dorycnium" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="538" phylum="Tracheophyta" rank="species" species="herbaceum">
<italic id="2CB2D6FC7EDD48CFF96E51099034B58F" pageId="null" pageNumber="538">D. herbaceum</italic>
</taxonomicName>
(Nr. 2)
</td>
</tr>
<tr id="0158FB17049172ECCE974F34062E14BE" pageId="null" pageNumber="538">
<td id="3AB29DFC606853AACFE57866CB312D90" align="left" pageId="null" pageNumber="538" valign="top">
2*. Kelch 2,5-3,5 mm lang; Krone 5-7 mm lang; 
<normalizedToken id="577EA1A0670F2D60E5AC009A9621E851" originalValue="Teilblätter" pageId="null" pageNumber="538">Teilblaetter</normalizedToken>
dicht anliegend behaart, 4-8mal so lang wie breit
</td>
<td id="E58E42E7E3BA4C92BF5799EF6CB541A6" align="left" pageId="null" pageNumber="538" valign="bottom">
<taxonomicName id="00E72275DC1B3127BEECF34F4B4CB786" class="Magnoliopsida" family="Fabaceae" genus="Dorycnium" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="538" phylum="Tracheophyta" rank="species" species="germanicum">
<italic id="AC4A7D5137AC1C0F16E731BBEB426E46" pageId="null" pageNumber="538">D. germanicum</italic>
</taxonomicName>
(Nr. 3)
</td>
</tr>
