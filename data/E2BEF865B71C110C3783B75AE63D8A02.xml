<subSubSection id="834D71F2210DC11D6CFE0A94C5709C84" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="9DF240F1A2658BE1CEF447CDF3A77308" pageId="null" pageNumber="590">Mauerlattich</paragraph>
</subSubSection>
</title>
<subSubSection id="5AA5A51042271B8572E71EEE02CC3D08" pageId="null" pageNumber="590" type="description">
<paragraph id="AAB421D96E0203606FBA38D9028DEE8D" pageId="null" pageNumber="590">
Stengel hohl. 
<emphasis id="7CC725F278985BB61448FE140BA7D251" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="83F09530D8E6735F97899A33941441F3" originalValue="Blütenköpfe" pageId="null" pageNumber="590">Bluetenkoepfe</normalizedToken>
meist nur 5 
<normalizedToken id="F3F53A0D555ACFF403D39A7F9F1A914E" originalValue="blütig" pageId="null" pageNumber="590">bluetig</normalizedToken>
.
</emphasis>
<normalizedToken id="10893BC6A94B5DB92B95796A4985AF37" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
zylindrisch, 
<emphasis id="B84840E690CDE4BE350D567A23C3363F" italics="true" pageId="null" pageNumber="590">mit 2 Reihen</emphasis>
von 
<emphasis id="87B57801EC1854D0B1C890C4A49DA840" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="CB9D5AD7D9043E4945E9F82DC0BA57D2" originalValue="Hüllblättern" pageId="null" pageNumber="590">Huellblaettern</normalizedToken>
:
</emphasis>
ganz kurze 
<normalizedToken id="3D80A233364FD9E29A97CFF15C4912F7" originalValue="äußere" pageId="null" pageNumber="590">aeussere</normalizedToken>
und lange innere. Boden des 
<normalizedToken id="6FFC8B3501A055F2B609EB42DD56FA83" originalValue="Blütenkopfes" pageId="null" pageNumber="590">Bluetenkopfes</normalizedToken>
ohne 
<normalizedToken id="E44F40D76694BBE4DAFFC2E89EBE122E" originalValue="Spreublätter" pageId="null" pageNumber="590">Spreublaetter</normalizedToken>
, kahl. 
<normalizedToken id="FD6EF6E2223CA4BBC0BE813A64CCFD41" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
<normalizedToken id="684C05AB13CA1FE34BBEA7E93DDC0C48" originalValue="spindelförmig" pageId="null" pageNumber="590">spindelfoermig</normalizedToken>
, 
<emphasis id="1C4620397076A3C9EEB821596AA13855" italics="true" pageId="null" pageNumber="590">
abgeflacht, mit 
<normalizedToken id="C9D190B915BC9BDC82BC459E02E8E89D" originalValue="Längsrippen" pageId="null" pageNumber="590">Laengsrippen</normalizedToken>
, mit kurzem, 
<normalizedToken id="68E44166E2852BEDB46C993F0CED6790" originalValue="dünnem" pageId="null" pageNumber="590">duennem</normalizedToken>
Schnabel.
</emphasis>
<taxonomicName id="9BBC3A3AD4E10D2D1BA9D265A69FBCAE" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
<normalizedToken id="C5E7261EE761FD25B229FF1FB17438BC" originalValue="weiß" pageId="null" pageNumber="590">weiss</normalizedToken>
, 
<emphasis id="0AC064634E331375A4D27DBF2A956218" italics="true" pageId="null" pageNumber="590">
1reihig, von einem Kranz sehr kurzer, nur mit 10facher 
<normalizedToken id="E1D025BEC18B772B6AE4D6A2FA941750" originalValue="Vergrößerung" pageId="null" pageNumber="590">Vergroesserung</normalizedToken>
sichtbarer Haare umgeben.
</emphasis>
Pappusborsten sehr 
<normalizedToken id="92A51613F8155908A5256CD890EEAE45" originalValue="dünn" pageId="null" pageNumber="590">duenn</normalizedToken>
, rauh.
</paragraph>
<paragraph id="B5261EC85158CC0486BC696611058E67" pageId="null" pageNumber="590">
Die aus etwa 
<emphasis id="C67CDF67F55611DE706A3B422F6644ED" italics="true" pageId="null" pageNumber="590">35 Arten</emphasis>
bestehende Gattung 
<taxonomicName id="FDFE94CD5BDE3594F62E84241F6D5A01" class="Magnoliopsida" family="Asteraceae" genus="Mycelis" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="genus">
<emphasis id="D0CB493043405A08BEB450CE1AB33E51" italics="true" pageId="null" pageNumber="590">Mycelis</emphasis>
</taxonomicName>
ist in 
<taxonomicName id="FE0051B29B6FF7348AF9097A1CCB807D" authority="Asien und Afrika" authorityName="Asien und Afrika" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">
<emphasis id="90A85050CFBC5CAB3C059D7F67371A3F" italics="true" pageId="null" pageNumber="590">Europa, Asien und Afrika</emphasis>
</taxonomicName>
verbreitet. Im Gebiet ist sie nur mit 1 Art vertreten. 
<emphasis id="FFE02B5F26A9344FDBBD0B5A42B00D62" italics="true" pageId="null" pageNumber="590">Chromosomengrundzahl</emphasis>
n = 9. 
<normalizedToken id="78CCADF5A4906C7C851C8CB53C07B8D6" originalValue="Über" pageId="null" pageNumber="590">Ueber</normalizedToken>
die verwandtschaftliche Stellung der Gattung s. unter 
<taxonomicName id="694ACED1FB17E502874E5C1CCC56466A" class="Magnoliopsida" family="Asteraceae" genus="Lactuca" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="genus">
<emphasis id="9596EDC294A876C3468C406BF5435214" italics="true" pageId="null" pageNumber="590">Lactuca</emphasis>
</taxonomicName>
(S. 627).
</paragraph>
</subSubSection>
