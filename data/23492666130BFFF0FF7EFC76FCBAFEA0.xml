and 
<taxonomicName id="6CE0ECF31305FFF0FDB2FE9FFD47FEA1" authorityName="Assing" authorityYear="2013" box="[623,764,299,321]" class="Insecta" family="Staphylinidae" genus="Lathrobium" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="163" phylum="Arthropoda" rank="species" species="hamulatum">
<emphasis id="99944B621305FFF0FDB2FE9FFD47FEA1" box="[623,764,299,321]" italics="true" pageId="8" pageNumber="163">L. hamulatum</emphasis>
</taxonomicName>
.
</paragraph>
