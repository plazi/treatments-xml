<taxonomicName id="6CE0ECF31305FFF0FE1AFE9FFD86FEA1" authorityName="Assing" authorityYear="2013" box="[455,573,299,321]" class="Insecta" family="Staphylinidae" genus="Lathrobium" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="163" phylum="Arthropoda" rank="species" species="diffissum">
