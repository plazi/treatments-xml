<subSubSection id="C374652CFFE7FF8DD4CCF8A50854FF6A" lastPageId="27" lastPageNumber="28" pageId="26" pageNumber="27" type="diagnosis">
<paragraph id="8BD136A7FFE7FF8DD4CCF8A50854FF6A" blockId="26.[151,1437,1662,2013]" lastBlockId="27.[151,1436,151,249]" lastPageId="27" lastPageNumber="28" pageId="26" pageNumber="27">
<emphasis id="B91AEAB5FFE7FF8CD4CCF8A50C1AF8BB" bold="true" box="[199,322,1806,1832]" pageId="26" pageNumber="27">Diagnosis.</emphasis>
<taxonomicName id="4C6E4D24FFE7FF8CD543F8A40C8AF8BB" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" box="[328,466,1807,1833]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="26" pageNumber="27" phylum="Arthropoda" rank="species" species="ayo" status="sp. n.">
<emphasis id="B91AEAB5FFE7FF8CD543F8A40C8AF8BB" box="[328,466,1807,1833]" italics="true" pageId="26" pageNumber="27">Tenedos ayo</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFE7FF8CD5D2F8A40F40F8BA" bold="true" box="[473,536,1807,1833]" pageId="26" pageNumber="27">
<taxonomicNameLabel id="A22957CEFFE7FF8CD5D2F8A40F40F8BA" box="[473,536,1807,1833]" pageId="26" pageNumber="27" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
resembles 
<taxonomicName id="4C6E4D24FFE7FF8CD69DF8A40EA2F8BA" authority="(Chamberlin, 1925)" baseAuthorityName="Chamberlin" baseAuthorityYear="1925" box="[662,1018,1806,1833]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="26" pageNumber="27" phylum="Arthropoda" rank="species" species="barronus">
<emphasis id="B91AEAB5FFE7FF8CD69DF8A40E4FF8BA" box="[662,791,1807,1833]" italics="true" pageId="26" pageNumber="27">T. barronus</emphasis>
(
<bibRefCitation id="EFFF4B56FFE7FF8CD72EF8A40EAAF8BA" author="Chamberlin, R. V." box="[805,1010,1806,1833]" pageId="26" pageNumber="27" pagination="105 - 142" refId="ref78375" refString="Chamberlin, R. V. (1925) New North American spiders. Proceedings of the California Academy of Sciences, Series 4, 14, 105 - 142." type="journal article" year="1925">Chamberlin, 1925</bibRefCitation>
)
</taxonomicName>
and 
<taxonomicName id="4C6E4D24FFE7FF8CD03BF8A408C0F8BA" authority="Jocque &amp; Baert, 2002" authorityName="Jocque &amp; Baert" authorityYear="2002" box="[1072,1432,1807,1833]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="26" pageNumber="27" phylum="Arthropoda" rank="species" species="hoeferi">
<emphasis id="B91AEAB5FFE7FF8CD03BF8A409C2F8BA" box="[1072,1178,1807,1833]" italics="true" pageId="26" pageNumber="27">T. hoeferi</emphasis>
<bibRefCitation id="EFFF4B56FFE7FF8CD0A9F8A408C0F8BA" author="Jocque, R. &amp; Baert, L." box="[1186,1432,1807,1833]" pageId="26" pageNumber="27" pagination="67 - 173" refId="ref79332" refString="Jocque, R. &amp; Baert, L. (2002) A revision of the Neotropical spider genera Tenedos O. P. - Cambridge and Ishania Chamberlin (Araneae, Zodariidae). Bulletin de l'Institut Royal des Sciences Naturelles de Belgique, Entomologie, 72, 67 - 173." type="journal article" year="2002">Jocqué &amp; Baert, 2002</bibRefCitation>
</taxonomicName>
, by having similar structural organization of male palp: developed conductor (C): curved at prolateral side, short, conical retrolateral tibial apophysis (RTA) (see 
<bibRefCitation id="EFFF4B56FFE7FF8CD6BAF8FC0E8FF8E2" author="Jocque, R. &amp; Baert, L." box="[689,983,1879,1905]" pageId="26" pageNumber="27" pagination="67 - 173" refId="ref79332" refString="Jocque, R. &amp; Baert, L. (2002) A revision of the Neotropical spider genera Tenedos O. P. - Cambridge and Ishania Chamberlin (Araneae, Zodariidae). Bulletin de l'Institut Royal des Sciences Naturelles de Belgique, Entomologie, 72, 67 - 173." type="journal article" year="2002">Jocqué &amp; Baert, 2002: 87</bibRefCitation>
, 100, figs 10A–B; 18B–C; figs 12A–D; 13A–B; 14A–F), but can be recognized by laminar, long median apophysis (MA), thinner, apically sharp retrolateral tibial apophysis (RTA) (
<figureCitation id="13552A22FFE7FF8CD5AFF8340F6BF82A" box="[420,563,1951,1977]" captionStart="FIGURE 16" captionStartId="28.[151,250,1943,1967]" captionTargetBox="[349,1239,189,1920]" captionTargetId="figure-27@28.[349,1239,181,1920]" captionTargetPageId="28" captionText="FIGURE 16. Tenedos ayo sp. n. A–D. Male palp (IAvH-I-2974): A. Prolateral view. B. Retroventral view. C. Ventral view. D. Retrolateral view. E–F. Female epigyne (IAvH-I-2975): E. Ventral view. F. Dorsal view. Scale bars:A–B: 200µm; C–D: 500µm; E–F: 100µm." figureDoi="http://doi.org/10.5281/zenodo.6520780" httpUri="https://zenodo.org/record/6520780/files/figure.png" pageId="26" pageNumber="27">Figs 16A–D</figureCitation>
; 
<figureCitation id="13552A22FFE7FF8CD634F8340FCCF82A" box="[575,660,1951,1977]" captionStart="FIGURE 17" captionStartId="29.[151,250,1689,1713]" captionTargetBox="[167,1425,186,1651]" captionTargetId="figure-19@29.[151,1436,181,1666]" captionTargetPageId="29" captionText="FIGURE 17. Tenedos ayo sp. n. A–B. Male palp (IAvH-I-2974): A. Ventral view. B. Retrolateral view. C–D. Female epigyne (IAvH-I-2975): C. Ventral view. D. Dorsal view. Scale bars: A–B: 200µm; C–D: 500µm. Abbreviations: ApC, appendix of the conductor; C, conductor; E, embolus; FD, fertilization ducts; MA, median apophysis; MFP, median field plate; RPC, retrolateral process of the cymbium; S, spermathecae; St, subtegulum; SR, seminal receptacles." figureDoi="http://doi.org/10.5281/zenodo.6520782" httpUri="https://zenodo.org/record/6520782/files/figure.png" pageId="26" pageNumber="27">17A–B</figureCitation>
). Females are similar to those of 
<taxonomicName id="4C6E4D24FFE7FF8CD00CF8340835F82A" authority="Jocque &amp; Baert, 2002" authorityName="Jocque &amp; Baert" authorityYear="2002" box="[1031,1389,1951,1977]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="26" pageNumber="27" phylum="Arthropoda" rank="species" species="hoeferi">
<emphasis id="B91AEAB5FFE7FF8CD00CF8340929F82A" box="[1031,1137,1951,1977]" italics="true" pageId="26" pageNumber="27">T. hoeferi</emphasis>
<bibRefCitation id="EFFF4B56FFE7FF8CD073F8340835F82A" author="Jocque, R. &amp; Baert, L." box="[1144,1389,1951,1977]" pageId="26" pageNumber="27" pagination="67 - 173" refId="ref79332" refString="Jocque, R. &amp; Baert, L. (2002) A revision of the Neotropical spider genera Tenedos O. P. - Cambridge and Ishania Chamberlin (Araneae, Zodariidae). Bulletin de l'Institut Royal des Sciences Naturelles de Belgique, Entomologie, 72, 67 - 173." type="journal article" year="2002">Jocqué &amp; Baert, 2002</bibRefCitation>
</taxonomicName>
and 
<taxonomicName id="4C6E4D24FFE7FF8CD49CF8680F05F84E" authority="Jocque &amp; Baert, 2002" authorityName="Jocque &amp; Baert" authorityYear="2002" box="[151,605,1987,2013]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="26" pageNumber="27" phylum="Arthropoda" rank="species" species="quadrangulatus">
<emphasis id="B91AEAB5FFE7FF8CD49CF8680C3BF84E" box="[151,355,1987,2013]" italics="true" pageId="26" pageNumber="27">T. quadrangulatus</emphasis>
<bibRefCitation id="EFFF4B56FFE7FF8CD562F8680F05F84E" author="Jocque, R. &amp; Baert, L." box="[361,605,1987,2013]" pageId="26" pageNumber="27" pagination="67 - 173" refId="ref79332" refString="Jocque, R. &amp; Baert, L. (2002) A revision of the Neotropical spider genera Tenedos O. P. - Cambridge and Ishania Chamberlin (Araneae, Zodariidae). Bulletin de l'Institut Royal des Sciences Naturelles de Belgique, Entomologie, 72, 67 - 173." type="journal article" year="2002">Jocqué &amp; Baert, 2002</bibRefCitation>
</taxonomicName>
, by long seminal receptacles (RTA), curved towards median septum of epigyne; knob-shaped median field plate (MFP) (see 
<bibRefCitation id="EFFF4B56FFE6FF8DD6C8FF3C0EB9FF22" author="Jocque, R. &amp; Baert, L." box="[707,993,151,177]" pageId="27" pageNumber="28" pagination="67 - 173" refId="ref79332" refString="Jocque, R. &amp; Baert, L. (2002) A revision of the Neotropical spider genera Tenedos O. P. - Cambridge and Ishania Chamberlin (Araneae, Zodariidae). Bulletin de l'Institut Royal des Sciences Naturelles de Belgique, Entomologie, 72, 67 - 173." type="journal article" year="2002">Jocqué &amp; Baert, 2002: 87</bibRefCitation>
, 100, 116, figs 10C–D, 18D–E, 33A–B; figs 16E–F; 17C–D), but can be distinguished by thinner seminal receptacles (SR); smaller, basally rounded median field plate; rounded spermathecae (S), closely related to copulatory ducts (CD) (
<figureCitation id="13552A22FFE6FF8DD012FF7409F8FF6A" box="[1049,1184,223,249]" captionStart="FIGURE 16" captionStartId="28.[151,250,1943,1967]" captionTargetBox="[349,1239,189,1920]" captionTargetId="figure-27@28.[349,1239,181,1920]" captionTargetPageId="28" captionText="FIGURE 16. Tenedos ayo sp. n. A–D. Male palp (IAvH-I-2974): A. Prolateral view. B. Retroventral view. C. Ventral view. D. Retrolateral view. E–F. Female epigyne (IAvH-I-2975): E. Ventral view. F. Dorsal view. Scale bars:A–B: 200µm; C–D: 500µm; E–F: 100µm." figureDoi="http://doi.org/10.5281/zenodo.6520780" httpUri="https://zenodo.org/record/6520780/files/figure.png" pageId="27" pageNumber="28">Figs 16E–F</figureCitation>
; 
<figureCitation id="13552A22FFE6FF8DD0A0FF740858FF6A" box="[1195,1280,223,249]" captionStart="FIGURE 17" captionStartId="29.[151,250,1689,1713]" captionTargetBox="[167,1425,186,1651]" captionTargetId="figure-19@29.[151,1436,181,1666]" captionTargetPageId="29" captionText="FIGURE 17. Tenedos ayo sp. n. A–B. Male palp (IAvH-I-2974): A. Ventral view. B. Retrolateral view. C–D. Female epigyne (IAvH-I-2975): C. Ventral view. D. Dorsal view. Scale bars: A–B: 200µm; C–D: 500µm. Abbreviations: ApC, appendix of the conductor; C, conductor; E, embolus; FD, fertilization ducts; MA, median apophysis; MFP, median field plate; RPC, retrolateral process of the cymbium; S, spermathecae; St, subtegulum; SR, seminal receptacles." figureDoi="http://doi.org/10.5281/zenodo.6520782" httpUri="https://zenodo.org/record/6520782/files/figure.png" pageId="27" pageNumber="28">17C–D</figureCitation>
).
</paragraph>
</subSubSection>
