<subSubSection id="9308595E9D674ECA32DE8A79C515553C" pageId="null" pageNumber="291" type="description">
<paragraph id="37F7C4310D37FDC6E5A131D4746BE828" pageId="null" pageNumber="291">
Ausdauernd, mit 
<normalizedToken id="AC83710C0727E6C7B1A869063A418806" originalValue="dünnem" pageId="null" pageNumber="291">duennem</normalizedToken>
, verzweigtem, kriechendem Rhizom; 20-50 cm hoch, nach Kumarin duftend; Stengel niederliegend, aufsteigend oder aufrecht, meist unverzweigt, kahl oder mit einzelnen nach 
<normalizedToken id="EE6329CB72D9B1C8839D5BC0ADAB671E" originalValue="rückwärts" pageId="null" pageNumber="291">rueckwaerts</normalizedToken>
gerichteten Haaren. Mittlere 
<normalizedToken id="C5E2C1217B917DDAA21EE7F9004F6F1A" originalValue="Blätter" pageId="null" pageNumber="291">Blaetter</normalizedToken>
zu 6-8 im Quirl, lanzettlich, 1-3 cm lang, 
<normalizedToken id="D0DD34F5E7FDFEB3DE2514AD909BAAAC" originalValue="2½" pageId="null" pageNumber="291">21/2</normalizedToken>
-4mal so lang wie breit, mit der 
<normalizedToken id="0A1D33E5F4F068FF198AD60556086FE7" originalValue="größten" pageId="null" pageNumber="291">groessten</normalizedToken>
Breite etwa in der Mitte, 1nervig und netzaderig, 
<emphasis id="307096029D929F6413BE4F27FF80AA58" italics="true" pageId="null" pageNumber="291">
<pageBreakToken id="B4317B3550B19E67A3FEC82CC545B434" pageId="null" pageNumber="291">mit</pageBreakToken>
0,5
</emphasis>
- 
<emphasis id="3D2BEBDF9047F9A9678E1D1000F10633" italics="true" pageId="null" pageNumber="291">1,5 mm langer, krautiger Spitze</emphasis>
(nur zuvorderst hyalin), beiderseits 
<normalizedToken id="6DFA0AA4DD49593071BB807B9764A5DC" originalValue="dunkelgrün" pageId="null" pageNumber="291">dunkelgruen</normalizedToken>
, kahl oder am Rande mit einzelnen nach vorn gerichteten Haaren. 
<emphasis id="4558207D9F61499EBABE0BD321CDA261" italics="true" pageId="null" pageNumber="291">
<normalizedToken id="61040E736D2F5EA4E1C0BBEB8C092058" originalValue="Blütenstände" pageId="null" pageNumber="291">Bluetenstaende</normalizedToken>
schmal 
<normalizedToken id="7124FAA5371A9B075586283590116CE1" originalValue="eiförmig" pageId="null" pageNumber="291">eifoermig</normalizedToken>
bis 
<normalizedToken id="5E53607B5BE84DFC1E9A78630F3D510C" originalValue="pyramidenförmig" pageId="null" pageNumber="291">pyramidenfoermig</normalizedToken>
;
</emphasis>
<normalizedToken id="FFC2062B9B9819BD54F1DAC5CB7D6699" originalValue="Teilblütenstände" pageId="null" pageNumber="291">Teilbluetenstaende</normalizedToken>
2-5 
<normalizedToken id="C21ABBEF322EA3A2C25F03E16BDF7F52" originalValue="blütig" pageId="null" pageNumber="291">bluetig</normalizedToken>
(meist 3 
<normalizedToken id="4AFE338A217D820E525A0E01090648A6" originalValue="blütig" pageId="null" pageNumber="291">bluetig</normalizedToken>
), 1-2mal so lang wie die obersten 
<normalizedToken id="F86AB10AD61E58FFB6E365C8B75F354B" originalValue="Blätter" pageId="null" pageNumber="291">Blaetter</normalizedToken>
. 
<normalizedToken id="1643CFDCE105BA2919934F07A62D5EF4" originalValue="Blütenstiele" pageId="null" pageNumber="291">Bluetenstiele</normalizedToken>
1-5 mm lang, mit oder ohne 
<normalizedToken id="C7D2199C748849C5C71DF34E73DD827C" originalValue="Tragblätter" pageId="null" pageNumber="291">Tragblaetter</normalizedToken>
. Fruchtstiele gerade. 
<emphasis id="EE14B640B0B7DD9382C9DA0449187110" italics="true" pageId="null" pageNumber="291">
Krone 
<normalizedToken id="C6F50F7F904DC7BF96BF200E25905122" originalValue="grünlich" pageId="null" pageNumber="291">gruenlich</normalizedToken>
, 
<normalizedToken id="9D01DB9C74B34394C516C3308A88D24B" originalValue="±" pageId="null" pageNumber="291">+/-</normalizedToken>
flach
</emphasis>
, mit spitzen Zipfeln, 
<emphasis id="A213A5ECE4CB062FF509DBC658840755" italics="true" pageId="null" pageNumber="291">1,5</emphasis>
- 
<emphasis id="FB0695C80F8549B3D6CBAD7E46A7F219" italics="true" pageId="null" pageNumber="291">
2,5 mm im Durchmesser. 
<normalizedToken id="1585E6B90869459CBFC90E2DD3AFECE9" originalValue="Früchte" pageId="null" pageNumber="291">Fruechte</normalizedToken>
ca. 1,5 mm hoch, mit ca. 0,5 mm langen
</emphasis>
, 
<emphasis id="9C643F19819FEB30B06ABFE8F19C05B1" italics="true" pageId="null" pageNumber="291">
<normalizedToken id="C233D474FC2CE93ACB8E01F7F6580F11" originalValue="hakenförmigen" pageId="null" pageNumber="291">hakenfoermigen</normalizedToken>
Haaren.
</emphasis>
- 
<normalizedToken id="24EC175504556E84875ACA5F8D06A3FE" originalValue="Blüte" pageId="null" pageNumber="291">Bluete</normalizedToken>
: 
<normalizedToken id="40F27269156ADEC38619CFF77CCD9AD2" originalValue="Später" pageId="null" pageNumber="291">Spaeter</normalizedToken>
Sommer.
</paragraph>
<paragraph id="44BD83052D77B1E35547CB651B376CC3" pageId="null" pageNumber="291">
<emphasis id="19E61389EE8701E447F71B68297AE728" italics="true" pageId="null" pageNumber="291">Zytologische Angaben. 2n ca. 44:</emphasis>
Material aus Finnland (Sorsa 1963). Khoshoo und Bhatia (1963a) 
<normalizedToken id="A37B0A2F6880DFC5413E4747AD551410" originalValue="zählten" pageId="null" pageNumber="291">zaehlten</normalizedToken>
an Material aus dem Himalaja 
<emphasis id="84C671344BCD64218A53B0590F45A801" italics="true" pageId="null" pageNumber="291">2n</emphasis>
= 
<emphasis id="3EF0B77652509474BF7821F569416AF7" italics="true" pageId="null" pageNumber="291">22.</emphasis>
</paragraph>
<paragraph id="17254AEA2156A24575FDD53D7A4702EC" pageId="null" pageNumber="291">
<emphasis id="022FB894C485BD957CD9EC8D245B3E83" italics="true" pageId="null" pageNumber="291">Standort.</emphasis>
Montan und subalpin. Feuchte, humose 
<normalizedToken id="C5A48FD92708B05380A8609DB3D77E9B" originalValue="Böden" pageId="null" pageNumber="291">Boeden</normalizedToken>
in schattigen Lagen. Fichtenwald, 
<normalizedToken id="9A1D61499D61BCC16B25D779701625F4" originalValue="Weißerlenwald" pageId="null" pageNumber="291">Weisserlenwald</normalizedToken>
.
</paragraph>
<paragraph id="DD1A535AA7ABC4FD0D51E3F41EE9061A" pageId="null" pageNumber="291">
<emphasis id="CC79F19A9143961D82EABA3E355F9942" italics="true" pageId="null" pageNumber="291">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
Skandinavien (
<normalizedToken id="D8B40D4B78094D9B44E87CAA69C178D9" originalValue="südwärts" pageId="null" pageNumber="291">suedwaerts</normalizedToken>
bis 
<normalizedToken id="D64DC08692BD33F1101AE1E83BDEE8E0" originalValue="Südschweden" pageId="null" pageNumber="291">Suedschweden</normalizedToken>
, Estland, 
<normalizedToken id="3A06E74A432D13AB9C231C30D1F9806B" originalValue="Nordrußland" pageId="null" pageNumber="291">Nordrussland</normalizedToken>
); Alpen; Sibirien, Kleinasien (Lyzien), Ostasien (dort zum Teil auch eine eigene Art, 
<taxonomicName id="96E3AC119E32084C9E5E971E3A02EFC4" authority="Kom." authorityName="Kom." class="Magnoliopsida" family="Rubiaceae" genus="Galium" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="291" phylum="Tracheophyta" rank="species" species="trifloriforme">
<emphasis id="C80F17DB98ADFCD0BB88584AB7DDA518" italics="true" pageId="null" pageNumber="291">G. trifloriforme</emphasis>
Kom.
</taxonomicName>
, abgetrennt); Himalaja; Nordamerika (
<normalizedToken id="8C19EFBEF60F95A4DA178CD64AEA98B3" originalValue="südwärts" pageId="null" pageNumber="291">suedwaerts</normalizedToken>
bis Mexiko); 
<normalizedToken id="DA318C716A0E0E5ABEAE1473FE17DA25" originalValue="Südgrönland" pageId="null" pageNumber="291">Suedgroenland</normalizedToken>
. Verbreitungskarte von 
<normalizedToken id="E53FC2651C9BA780FB19A8AEE71A8FD7" originalValue="Hultén" pageId="null" pageNumber="291">Hulten</normalizedToken>
(1958). - Im Gebiet: Wallis (im Val 
<normalizedToken id="94226355E43B9D4EFFAD956AF2B5FAED" originalValue="d’Hérémence" pageId="null" pageNumber="291">d'Heremence</normalizedToken>
bei Pralong), Unterengadin (mehrere Fundstellen zwischen Tarasp und Ramosch).
</paragraph>
</subSubSection>
