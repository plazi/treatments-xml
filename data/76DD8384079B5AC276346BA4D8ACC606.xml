<subSubSection id="10D165DF696A279E82F71B5F421EEC91" pageId="null" pageNumber="538" type="description">
<paragraph id="5025511BCA414F30380EACE914754D4F" pageId="null" pageNumber="538">
Halbstrauch, am Grunde verholzt; 20-50 cm hoch. Stengel, 
<normalizedToken id="CC7199ED24D5835C1F75457F6F7ADE60" originalValue="Blätter" pageId="null" pageNumber="538">Blaetter</normalizedToken>
und Kelch 
<emphasis id="B1D6D9B0230617742BA821BC46B5DF45" italics="true" pageId="null" pageNumber="538">dicht abstehend behaart</emphasis>
(
<emphasis id="5F3C33CE64AD85B8D2BFBC37EA595916" italics="true" pageId="null" pageNumber="538">
<normalizedToken id="263B4A5B7E130DF2A74B9DDC3D5CDD07" originalValue="längere" pageId="null" pageNumber="538">laengere</normalizedToken>
Haare 1,5-2 mm lang
</emphasis>
). 
<normalizedToken id="FE08A4C875DA0B5A46194034D72DAADA" originalValue="Teilblätter" pageId="null" pageNumber="538">Teilblaetter</normalizedToken>
breit lanzettlich, bis 2,5 cm lang, 2-4mal so lang wie breit. 
<normalizedToken id="FF073E1208FB3AF9DF2E6B3CC9689971" originalValue="Blütenstände" pageId="null" pageNumber="538">Bluetenstaende</normalizedToken>
kurz gestielt (
<emphasis id="C7E97A0958ED5FF95F75667EB3175426" italics="true" pageId="null" pageNumber="538">
Stiel 
<normalizedToken id="6086539A6D192F94A7FDCB6CA45B7FAE" originalValue="höchstens" pageId="null" pageNumber="538">hoechstens</normalizedToken>
0,6 cm lang
</emphasis>
), 5-10 
<normalizedToken id="C9DF30301E2632944EC5C54816A321A5" originalValue="blütig" pageId="null" pageNumber="538">bluetig</normalizedToken>
. 
<normalizedToken id="2DE266A096C6569C1C601115E6B8360C" originalValue="Blütenstiele" pageId="null" pageNumber="538">Bluetenstiele</normalizedToken>
<normalizedToken id="8CF9323393123DA3D9041E53CF4BB651" originalValue="±" pageId="null" pageNumber="538">+/-</normalizedToken>
2 mm lang. 
<emphasis id="DA637CB4EC9CF65702C1478F5BD375A9" italics="true" pageId="null" pageNumber="538">Kelch 8-12 mm lang;</emphasis>
Kelchzipfel etwa so lang wie die 
<normalizedToken id="B3F0A4ADCEBBAC5AB5F437FDACD61EDD" originalValue="Kelchröhre" pageId="null" pageNumber="538">Kelchroehre</normalizedToken>
. 
<emphasis id="44A0272623CF0B8F683F39A7AFFE4FD0" italics="true" pageId="null" pageNumber="538">Krone 12-20 mm lang</emphasis>
, rosa, mit dunkelpurpurner Schiffchenspitze; 
<emphasis id="6D2FDE91696985E0158A55F49F8A4757" italics="true" pageId="null" pageNumber="538">
Fahne fast 
<normalizedToken id="00A35AC91E9E673925DDE881B5FFDA2B" originalValue="kreisförmig" pageId="null" pageNumber="538">kreisfoermig</normalizedToken>
; 
<normalizedToken id="BE53B03B6CFBA79CA2198290042E6C19" originalValue="Flügel" pageId="null" pageNumber="538">Fluegel</normalizedToken>
vorn nicht verwachsen;
</emphasis>
Schiffchen gerade. - 
<normalizedToken id="B605FE9F81D1B79844DEC39E40E37AAD" originalValue="Blüte" pageId="null" pageNumber="538">Bluete</normalizedToken>
: 
<normalizedToken id="EE1ED9ED4AD61776942319C53AE6DEF9" originalValue="Später" pageId="null" pageNumber="538">Spaeter</normalizedToken>
<normalizedToken id="76F8B25DEE5365E87754330B4F1B4C46" originalValue="Frühling" pageId="null" pageNumber="538">Fruehling</normalizedToken>
und 
<normalizedToken id="91E052A9645FB722ACEB46C7E5DDB9BD" originalValue="früher" pageId="null" pageNumber="538">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="354C8DDF0BD7718819ED44AF83F8555C" pageId="null" pageNumber="538">
<emphasis id="03504076F315A1752CB2654A6CC856D1" italics="true" pageId="null" pageNumber="538">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="BA60DA7AD19BB1B273E78DC22C7488FF" italics="true" pageId="null" pageNumber="538">14:</emphasis>
Material aus Italien (Tschechow und Kartashova 1932), aus Italien und Jugoslawien (Larsen 1955), aus botanischen 
<normalizedToken id="43DEC3005D33BAB419AD7769A23AA948" originalValue="Gärten" pageId="null" pageNumber="538">Gaerten</normalizedToken>
(Gilot 1965). An einer Pflanze aus Jugoslawien wurde 
<emphasis id="C70F0731BA3526AA2A4391614C4FCBEF" italics="true" pageId="null" pageNumber="538">2n</emphasis>
= 
<emphasis id="9272F1A443F13CEE6CAC2130A7CBCD1C" italics="true" pageId="null" pageNumber="538">28</emphasis>
<normalizedToken id="408C58D4CF7B437A1B253D4C7087765B" originalValue="gezählt" pageId="null" pageNumber="538">gezaehlt</normalizedToken>
(Larsen 1956b).
</paragraph>
<paragraph id="38AAADDFD84F4956F878DAC86E1768AD" pageId="null" pageNumber="538">
<emphasis id="8F3316F9BB805933166A4DC644190B68" italics="true" pageId="null" pageNumber="538">Standort.</emphasis>
Kollin und montan. Trockene, steinige, kalkhaltige 
<normalizedToken id="547D2B1A437DC7A420E14A4C6D91B892" originalValue="Böden" pageId="null" pageNumber="538">Boeden</normalizedToken>
in warmen Lagen. Felsige 
<normalizedToken id="944D36E74B9A8CA82874A99C241D1F79" originalValue="Hänge" pageId="null" pageNumber="538">Haenge</normalizedToken>
, buschige Stellen.
</paragraph>
<paragraph id="A3634CE32FD11C75B685F63E75205E9E" pageId="null" pageNumber="538">
<emphasis id="DBCDC556128BFFB86C2507473039A643" italics="true" pageId="null" pageNumber="538">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="93E03C85BF527FB98C46C19EABA34D35" originalValue="Nordwärts" pageId="null" pageNumber="538">Nordwaerts</normalizedToken>
bis Mittelfrankreich, 
<normalizedToken id="EEFC901F16B5171999166C3C945E219C" originalValue="Südalpen" pageId="null" pageNumber="538">Suedalpen</normalizedToken>
, Kroatien; Kleinasien, Syrien, Israel; Nordwestafrika. - Im Gebiet: Comersee (Pliniana), Veltlin (zwischen Calvario und Tresivio), Vintschgau (Ulten).
</paragraph>
</subSubSection>
