<subSubSection id="B75C3B03FFB1E7C1319297BE78D08F0A" pageId="null" pageNumber="301" type="description">
<paragraph id="87EFE5C999CCAD58F41DE96ABE0ED145" pageId="null" pageNumber="301">
0,2-0,5 m hoch, horstbildend. Stengel aufrecht, kahl. 
<normalizedToken id="0514B4E812F9DEAAE3E16FCBB963536A" originalValue="Blätter" pageId="null" pageNumber="301">Blaetter</normalizedToken>
wie bei 
<taxonomicName id="886597EE787A10F01E5B49C6708C1FD3" class="Liliopsida" family="Poaceae" genus="Helictotrichon" kingdom="Plantae" order="Poales" pageId="null" pageNumber="301" phylum="Tracheophyta" rank="species" species="pratense">
<emphasis id="4885AA83E8200A27C51460A0EFEB8512" italics="true" pageId="null" pageNumber="301">H. pratense</emphasis>
</taxonomicName>
(Nr. 2), jedoch 
<emphasis id="B6307FD0887CFFA9F332B29497949BE5" italics="true" pageId="null" pageNumber="301">
oberseits glatt, mit auffallendem 
<normalizedToken id="F64F285010C92B3B55ADB0718E0F1AED" originalValue="weiβem" pageId="null" pageNumber="301">weiβem</normalizedToken>
, rauhem Rand;
</emphasis>
<normalizedToken id="1224E4E156E2294027F6AD48B8B223FE" originalValue="Blatthäutchen" pageId="null" pageNumber="301">Blatthaeutchen</normalizedToken>
bis 5 mm lang, spitz; Blattscheiden meist glatt. 
<normalizedToken id="B208343D26A57710060F7D6AFAA69F1B" originalValue="Blütenstand" pageId="null" pageNumber="301">Bluetenstand</normalizedToken>
wie bei 
<taxonomicName id="9A57AA3EDB8D948B5C71083DC4F36771" class="Liliopsida" family="Poaceae" genus="Helictotrichon" kingdom="Plantae" order="Poales" pageId="null" pageNumber="301" phylum="Tracheophyta" rank="species" species="pratense">
<emphasis id="AD86CA92D27BC07A3D32BE9E332C06DD" italics="true" pageId="null" pageNumber="301">H. pratense</emphasis>
</taxonomicName>
(Nr. 2). 
<emphasis id="E97BF2B2CEDE0358094C9DE1099DFCD3" italics="true" pageId="null" pageNumber="301">
<normalizedToken id="B19D3951DBC0407CAC02A5A2EB0495BE" originalValue="Ährchen" pageId="null" pageNumber="301">Aehrchen</normalizedToken>
bunt 
<normalizedToken id="BA3F0B9A067251D91DAC6CF805422820" originalValue="gefärbt" pageId="null" pageNumber="301">gefaerbt</normalizedToken>
</emphasis>
(
<emphasis id="15553AE48DC0C6C8827ED1C145912507" italics="true" pageId="null" pageNumber="301">gelbbraun und rot</emphasis>
), kleiner als bei 
<emphasis id="33991FB5C5FFBA848106930BDE1FC9B4" italics="true" pageId="null" pageNumber="301">
<taxonomicName id="288E7143FF5E5B525B7E05E188246872" class="Liliopsida" family="Poaceae" genus="Helictotrichon" kingdom="Plantae" order="Poales" pageId="null" pageNumber="301" phylum="Tracheophyta" rank="species" species="pratense">H. pratense</taxonomicName>
:
</emphasis>
obere, 
<normalizedToken id="230772CE313A2789EE23F9F776D32F01" originalValue="längere" pageId="null" pageNumber="301">laengere</normalizedToken>
<normalizedToken id="D71F22710A6C99DEF43751FE60BB0920" originalValue="Hüllspelze" pageId="null" pageNumber="301">Huellspelze</normalizedToken>
9-12 mm lang. - 
<normalizedToken id="89C727554BD4FABEDC5DC99F5E6EBE05" originalValue="Blüte" pageId="null" pageNumber="301">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="89615760FF8C50900470E1569E97AFDA" pageId="null" pageNumber="301">
<emphasis id="21FECECE348EF51A6C0CEEC818C8B48E" italics="true" pageId="null" pageNumber="301">Zytologische Angaben. 2n = 14 +</emphasis>
1-2 B-Chromosomen: Material von verschiedenen Fundstellen in der Hohen Tatra (Skalinska 1956), aus den West- und Ostalpen (Gervais 1966). 
<emphasis id="8738BE3D63B32A86CC65DE3079A5578F" italics="true" pageId="null" pageNumber="301">2n</emphasis>
= 
<emphasis id="C0D44634885E26A78B2748127C3E743B" italics="true" pageId="null" pageNumber="301">120-124:</emphasis>
Ohne Herkunftsangabe (Kattermann aus Tischler 1950); diese Angabe ist schwer zu deuten und beruht wahrscheinlich auf einem Irrtum.
</paragraph>
<paragraph id="6285F11C44346F772D6B1C49C5BC811B" pageId="null" pageNumber="301">
<emphasis id="BA8B9F341AAA1007C71D4A1A21B01440" italics="true" pageId="null" pageNumber="301">Standort.</emphasis>
Subalpin und alpin, selten montan. Ziemlich saure, trockene, humose 
<normalizedToken id="2E130207EE64214B623B7AEAAEA9214A" originalValue="Böden" pageId="null" pageNumber="301">Boeden</normalizedToken>
. Krummseggen- und Borstgraswiesen (besonders 
<normalizedToken id="AD7E17516F925E7380DD2BBC23DF31F2" originalValue="Gräte" pageId="null" pageNumber="301">Graete</normalizedToken>
und Gipfel), 
<normalizedToken id="85F96D7717D400C6ABF52F99DA19622A" originalValue="Zwergstrauchbestände" pageId="null" pageNumber="301">Zwergstrauchbestaende</normalizedToken>
.
</paragraph>
<paragraph id="591C5DEAA556EB3C7818EB7DAB1E391A" pageId="null" pageNumber="301">
<emphasis id="AE68D428C41E422B88DF6A790C51909C" italics="true" pageId="null" pageNumber="301">
Verbreitung. Mittel- und 
<normalizedToken id="65D9AA27B9CBE7DDE2ACBF1702529CFF" originalValue="südeuropäische" pageId="null" pageNumber="301">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
<normalizedToken id="4DF71D5D753FFAE749CC0542ACB8CF23" originalValue="Pyrenäen" pageId="null" pageNumber="301">Pyrenaeen</normalizedToken>
, Auvergne, Alpen, Tatra, Karpaten; Apuanische Alpen, Apennin, Gebirge der Balkanhalbinsel, Kaukasus. - Im Gebiet: Alpen, verbreitet und ziemlich 
<normalizedToken id="430A61C558E35F818554BE273248BB43" originalValue="häufig" pageId="null" pageNumber="301">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="885EE279739091461B3B2DE7C73A6701" pageId="null" pageNumber="301">
<emphasis id="7FBF51CEA14B771A8279D9036065617D" italics="true" pageId="null" pageNumber="301">Bemerkungen.</emphasis>
Nach den Untersuchungen von Holub (1961) ist 
<taxonomicName id="7EA0450B3A4EB720D7323DDB677BD094" class="Liliopsida" family="Poaceae" genus="Avenochloa" higherTaxonomySource="GBIF" kingdom="Plantae" order="Poales" pageId="null" pageNumber="301" phylum="Tracheophyta" rank="species" species="versicolor">
<emphasis id="4387BA2A8C2014F3D4476CB16D9D2E94" italics="true" pageId="null" pageNumber="301">H. versicolor</emphasis>
</taxonomicName>
wenig variabel.
</paragraph>
</subSubSection>
