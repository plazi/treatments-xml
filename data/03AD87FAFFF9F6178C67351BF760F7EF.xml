, 
<materialsCitation id="3B6C3CB1FFF9F617812935C1F58CFE61" box="[2103,2601,477,506]" pageId="61" pageNumber="119">
“Bivak-island, Lorentz 
<collectingRegion id="49C0F80EFFF9F617809F35C1F66DFE61" box="[2433,2504,477,506]" country="Nigeria" name="Rivers" pageId="61" pageNumber="119">River</collectingRegion>
