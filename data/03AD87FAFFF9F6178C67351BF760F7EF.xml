1s in the 
<taxonomicName id="4C044D6FFFF9F61780B33630F58AFDD2" baseAuthorityName="Gray" baseAuthorityYear="1863" box="[2477,2607,556,585]" class="Mammalia" family="Pteropodidae" genus="Nyctimene" kingdom="Animalia" order="Chiroptera" pageId="61" pageNumber="119" phylum="Chordata" rank="species" species="albiventer">albiventer</taxonomicName>
