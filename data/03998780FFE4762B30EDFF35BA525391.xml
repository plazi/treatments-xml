<paragraph id="8B8F3696FFE4762B30EDFF35B94150A1" blockId="2.[166,621,175,202]" box="[166,621,175,202]" pageId="2" pageNumber="13">
<heading id="D0C781FAFFE4762B30EDFF35B94150A1" box="[166,621,175,202]" fontSize="36" level="2" pageId="2" pageNumber="13" reason="3">
<taxonomicName id="4C304D15FFE4762B30EDFF35B94150A1" authority="(Dahlbom, 1843)" baseAuthorityName="Dahlbom" baseAuthorityYear="1843" box="[166,621,175,202]" class="Insecta" family="Crabronidae" genus="Psenulus" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="13" phylum="Arthropoda" rank="species" species="fuscipennis">
<emphasis id="B944EA84FFE4762B30EDFF35BA8250A1" bold="true" box="[166,430,175,202]" pageId="2" pageNumber="13">
<emphasis id="B944EA84FFE4762B30EDFF35BAB150A1" bold="true" box="[166,413,175,202]" italics="true" pageId="2" pageNumber="13">Psenulus fuscipennis</emphasis>
(
</emphasis>
Dahlbom, 1843
<emphasis id="B944EA84FFE4762B3228FF35B94150A1" bold="true" box="[611,621,175,201]" pageId="2" pageNumber="13">)</emphasis>
</taxonomicName>
</heading>
