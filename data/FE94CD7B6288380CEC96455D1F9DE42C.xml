<subSubSection id="9C5B70AE58D624D7317862F30991D9DB" pageId="null" pageNumber="584" type="nomenclature">
<paragraph id="12D017AF97EFF47E8270A570597A63B3" pageId="null" pageNumber="584">
<taxonomicName id="AAD495ADE2CA3471DD4F57D81B55DBC2" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Artemisia" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="584" phylum="Tracheophyta" rank="species" species="absinthium">
Artemisia 
<normalizedToken id="D13AFD714D6F2686002A1136664226CF" originalValue="Absínthium" pageId="null" pageNumber="584">Absinthium</normalizedToken>
<authorityName id="0A96077ADD19BABAA36CE26AAF4C8D70" pageId="null" pageNumber="584">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="1A8A54099C2545017595EFFC7AEEFF99" pageId="null" pageNumber="584" type="vernacular_names">
<paragraph id="877E0A3EA2B823C7800F3CA2F849B313" pageId="null" pageNumber="584">Wermut, Absinth</paragraph>
</subSubSection>
</title>
<subSubSection id="91E36D2C3850DFC014E0A98673D03EC5" pageId="null" pageNumber="584" type="description">
<paragraph id="B1787A07BFBEF208D44C0F92B09EFCD4" pageId="null" pageNumber="584">
Ausdauernd, mit holzigem, 
<normalizedToken id="CE3424C6144749BB709DBB3A40BCEDF1" originalValue="mehrköpfigem" pageId="null" pageNumber="584">mehrkoepfigem</normalizedToken>
Rhizom; 30-75 cm hoch; aromatisch riechend und bitter schmeckend. 
<emphasis id="B5BB52E85BD6DE7D95B4828AE5FC9069" italics="true" pageId="null" pageNumber="584">Stengel graufilzig behaart</emphasis>
(
<emphasis id="C1924630179619A1C11A237DDE381DC0" italics="true" pageId="null" pageNumber="584">
Haare 
<normalizedToken id="3D75C3826947A3E5E6A296DBBF2569F6" originalValue="kompaßnadelartig" pageId="null" pageNumber="584">kompassnadelartig</normalizedToken>
</emphasis>
), meist aufrecht, verzweigt, am Grunde holzig. 
<emphasis id="E07BE445193231ED74EE8A232EF52FBB" italics="true" pageId="null" pageNumber="584">
<normalizedToken id="96F22AE6E5903DF9AC484140587BED2D" originalValue="Blätter" pageId="null" pageNumber="584">Blaetter</normalizedToken>
beiderseits
</emphasis>
(besonders unterseits), locker und 
<emphasis id="EE19256009BC397F41BEB70F72A394F1" italics="true" pageId="null" pageNumber="584">graufilzig behaart</emphasis>
, die untern lang gestielt (
<emphasis id="AE2FA2EBB897A5A4F767F1F214553FB1" italics="true" pageId="null" pageNumber="584">Stiel am Grunde verbreitert, aber nicht umfassend</emphasis>
), 
<emphasis id="926F44387ADEADBB2A3427F6571BBA5D" italics="true" pageId="null" pageNumber="584">3fach fiederteilig, 6</emphasis>
- 
<emphasis id="99ECF7D5FF70534754C67C52FC3545BC" italics="true" pageId="null" pageNumber="584">15 cm lang; Zipfel 1</emphasis>
- 
<emphasis id="1F7FC6A4F0B6F72A2E24D63AE0D81C15" italics="true" pageId="null" pageNumber="584">3 mm breit</emphasis>
, schmal lanzettlich, spitz; obere 
<normalizedToken id="C2222E75CFB00FF95A4D8F470FCE5A15" originalValue="Blätter" pageId="null" pageNumber="584">Blaetter</normalizedToken>
sitzend, einfacher geteilt oder ungeteilt. 
<normalizedToken id="2A682B42AA5929A199F17DFDA7C2B833" originalValue="Köpfe" pageId="null" pageNumber="584">Koepfe</normalizedToken>
im Durchmesser 3-4 mm, kurz gestielt (
<emphasis id="E500F996C05FDED105E62F319ED71A34" italics="true" pageId="null" pageNumber="584">Stiele graufilzig behaart</emphasis>
), nickend, meist allseitswendig, in einer dichten, verzweigten Rispe. Innere 
<normalizedToken id="DD6C8F06CE6A58E52A19F74625595A8B" originalValue="Hüllblätter" pageId="null" pageNumber="584">Huellblaetter</normalizedToken>
mit gelbbraunem, durchsichtigem, 
<normalizedToken id="7F4CBFE7C56F072FC306E28D0ABCDFC1" originalValue="trockenhäutigem" pageId="null" pageNumber="584">trockenhaeutigem</normalizedToken>
Rand, etwas graufilzig behaart. 
<emphasis id="27F70BA028BFAAE17803725011247A21" italics="true" pageId="null" pageNumber="584">
Boden des 
<normalizedToken id="5D4013302AD9890C2BEB82338D21C047" originalValue="Blütenkopfes" pageId="null" pageNumber="584">Bluetenkopfes</normalizedToken>
behaart
</emphasis>
(
<emphasis id="3192CFD9E628905164EFA806087FA162" italics="true" pageId="null" pageNumber="584">Haare etwa 1 mm lang</emphasis>
). 
<normalizedToken id="58D9BA01BC3F8451DB93DE3EE0302C32" originalValue="Blüten" pageId="null" pageNumber="584">Blueten</normalizedToken>
gelb, die innern ⚥, die 
<normalizedToken id="B4CD32C2FB35CCFA782E4F93FEBC9A25" originalValue="äußern" pageId="null" pageNumber="584">aeussern</normalizedToken>
♀. Kronen kahl. - 
<normalizedToken id="8A9DACB3662A5C2CE565A894E5C88610" originalValue="Blüte" pageId="null" pageNumber="584">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="271942D72327386465806A213291D66C" originalValue="früher" pageId="null" pageNumber="584">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="71CCA6DADDDA9F69C78B5618AA764B14" pageId="null" pageNumber="584">
<emphasis id="D2A191F5A3E2601630A935B9A5E3CEEA" italics="true" pageId="null" pageNumber="584">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D9142E171CA9FED5ED04E7786148A5E2" italics="true" pageId="null" pageNumber="584">18:</emphasis>
Material aus botanischen 
<normalizedToken id="47073F4543FF7459A33FD84954DF5051" originalValue="Gärten" pageId="null" pageNumber="584">Gaerten</normalizedToken>
(Weinedel 1928, Suzuka 1952, Kawatani und Ohno 1964), aus Ungarn (
<normalizedToken id="7CAA2F47BC01DAA41465CAA535728496" originalValue="Pólya" pageId="null" pageNumber="584">Polya</normalizedToken>
1950), aus Indien (Khoshoo und Sobti 1958), aus Polen (Skalinska et al. 1959), aus Indien (Koul 1964a), aus Jugoslawien (Kawatani und Ohno 1964), aus der Slowakei (Hindakova und 
<normalizedToken id="C62280001FEC287D09A413C8A968F05C" originalValue="Činčura" pageId="null" pageNumber="584">Cincura</normalizedToken>
1967), auf Afghanistan (Podlech und Dieterle 1969).
</paragraph>
<paragraph id="B6DD93227EED2FD0305945ED0EC48B1B" pageId="null" pageNumber="584">
<emphasis id="91AA28174B206FA26C3E9487E7DC23A2" italics="true" pageId="null" pageNumber="584">Standort.</emphasis>
Kollin, montan und subalpin. 
<normalizedToken id="B8216B379633EE8F96C31DBAA5FA7ABA" originalValue="Mäßig" pageId="null" pageNumber="584">Maessig</normalizedToken>
trockene, lockere, 
<normalizedToken id="3EDAF3C76A6C3F07B9D6AA9B922AAD33" originalValue="nährstoffreiche" pageId="null" pageNumber="584">naehrstoffreiche</normalizedToken>
, neutrale 
<normalizedToken id="0F8998496C0D02B993A765F085DCE7F7" originalValue="Böden" pageId="null" pageNumber="584">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="7504930BB44FBEDB98387F77FE3960E8" originalValue="Gebüsche" pageId="null" pageNumber="584">Gebuesche</normalizedToken>
, beweidete 
<normalizedToken id="88B60B1A046C9744B4BAAFF8D63157A9" originalValue="Felshänge" pageId="null" pageNumber="584">Felshaenge</normalizedToken>
, 
<normalizedToken id="BC1CB7F004709290D00218A19CB0718D" originalValue="Ödland" pageId="null" pageNumber="584">Oedland</normalizedToken>
, 
<normalizedToken id="A43A008F3ED65DB362AB06690D8A1C5F" originalValue="Wegränder" pageId="null" pageNumber="584">Wegraender</normalizedToken>
, Balmen.
</paragraph>
<paragraph id="4033A8D4EF1E21B9889FB88DACFDC3B8" pageId="null" pageNumber="584">
<emphasis id="2F6EDA4086D9E29B9D1F6752E6DD8D02" italics="true" pageId="null" pageNumber="584">Verbreitung. Eurasiatische Pflanze:</emphasis>
Europa und Asien (nur 
<normalizedToken id="AEEC178101EE0A65C9866EA15BC7FE7B" originalValue="gemäßigte" pageId="null" pageNumber="584">gemaessigte</normalizedToken>
Zonen); Nordwestafrika. - Im Gebiet: Savoyen, zentral- und 
<normalizedToken id="C0C27469C008381AEE63AE3237F96DBF" originalValue="südalpine" pageId="null" pageNumber="584">suedalpine</normalizedToken>
<normalizedToken id="93DC3E349E672601F59FE75588A152C4" originalValue="Täler" pageId="null" pageNumber="584">Taeler</normalizedToken>
, Gegend des Walensees, Rheintal; sonst oft als Arzneipflanze kultiviert und verwildert (z. B. 
<normalizedToken id="1D761A3D7A987F60EBCE1E8A85C5A432" originalValue="Elsaß" pageId="null" pageNumber="584">Elsass</normalizedToken>
, Hegau).
</paragraph>
</subSubSection>
