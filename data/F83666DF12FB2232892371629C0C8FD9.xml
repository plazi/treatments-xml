<taxonomicName id="FF1B7F02C46F024F8C0F765A988BD625" authority="L." class="Liliopsida" family="Potamogetonaceae" genus="Potamogeton" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="200" phylum="Tracheophyta" rank="species" species="lucens">
