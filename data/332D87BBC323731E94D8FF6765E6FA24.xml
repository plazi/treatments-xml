</taxonomicName>
(
<figureCitation id="23BF2A28C323731E9167FE3065ECFE5A" box="[1320,1430,448,470]" captionStart="FIGURES 32–39" captionStartId="11.[151,264,1789,1813]" captionTargetBox="[180,1416,273,1763]" captionTargetId="figure-65@11.[170,1416,273,1766]" captionTargetPageId="11" captionText="FIGURES 32–39. Papuaneon ewingar n. sp. Female holotype (KS 42181): 32 dorsal, 33 ventral, 34 lateral, 35 anterior views; epigyne: 36 external, semi-diagrammatic views of dissected and cleared specimen (37 ventral, 38 dorsal views); 39 map showing the known distribution. Scale: 0.2 mm." figureDoi="http://doi.org/10.5281/zenodo.6610178" httpUri="https://zenodo.org/record/6610178/files/figure.png" pageId="3" pageNumber="132">Figs 32–39</figureCitation>
