<bibRefCitation id="40709FAD8F70FFEF353AB00B55968B02" author="Roesler, R. U." box="[298,492,291,316]" pageId="1" pageNumber="294" pagination="273 - 282" refId="ref5027" refString="Roesler, R. U. (1967) Phycitinen-Studien (Lepidoptera) II. Entomologische Zeitschrift, 77, 273 - 282." type="journal article" year="1967">Roesler, 1967: 274</bibRefCitation>
