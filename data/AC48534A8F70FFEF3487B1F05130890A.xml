<emphasis id="16953E4E8F70FFEF3695B00B57C58B02" box="[645,959,292,316]" italics="true" pageId="1" pageNumber="294">Pempelia (Salebria) cingillella</emphasis>
<bibRefCitation id="40709FAD8F70FFEF37D5B00B50388B05" author="Zeller, P. C." box="[965,1090,291,316]" pageId="1" pageNumber="294" pagination="729 - 788" refId="ref5181" refString="Zeller, P. C. (1846) Die knotenhornigen Phyciden nach ihren Arten beschrieben. Isis von Oken, Leipzig, 1846 (10), 729 - 788." type="journal article" year="1846">Zeller, 1846</bibRefCitation>
