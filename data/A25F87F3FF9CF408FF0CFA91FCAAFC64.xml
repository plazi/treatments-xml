<bibRefCitation id="4E674B14FF9CF40BFA8EFA17FEE2FA11" author="Penny, N. D." pageId="1" pageNumber="156" pagination="207 - 212" refId="ref15869" refString="Penny, N. D. (1980) A revision of American Bennini (Hemiptera: Fulgoroidea: Cixiidae). Acta Amazonica, 10 (1), 207 - 212. https: // doi. org / 10.1590 / 1809 - 43921980101207" type="journal article" year="1980">Penny, 1980: 207–208</bibRefCitation>
</treatmentCitation>
, 
<figureCitation id="B2CD2A60FF9CF40BFEB7FA76FE4BFA11" box="[300,394,1500,1524]" captionStart-0="FIGURES 1–5" captionStart-1="FIGURES 6–12" captionStartId-0="4.[151,264,1821,1845]" captionStartId-1="5.[151,264,1848,1872]" captionTargetBox-0="[151,1435,179,1795]" captionTargetBox-1="[151,1435,181,1811]" captionTargetId-0="figure-24@4.[151,1435,179,1795]" captionTargetId-1="figure-17@5.[151,1435,181,1824]" captionTargetPageId-0="4" captionTargetPageId-1="5" captionText-0="FIGURES 1–5. Bennarella bicoloripennis Muir: 1. Male, habitus, lateral view; 2. Female, habitus, lateral view; 3. Male head, anterior view; 4. Male head and thorax, dorsal view; 5. Male abdominal process, lateral view. Scale bars: 1–2 = 1 mm; 3–5 = 0.2 mm." captionText-1="FIGURES 6–12. Bennarella bicoloripennis Muir, male genitalia: 6. Genital capsule, lateral view; 7. Anal tube and pygofer, dorsal view; 8. Anal tube, pygofer and gonostyli, posterior view; 9. Gonostylus left lateral view; 10. Gonostyli, dorsal view; 11. Phallic complex, left lateral view; 12. Phallic complex, right lateral view. Abbreviations: ae: aedeagus; at, anal tube; cp, phallic complex; go, gonostylus; pe, periandrium; py, pygofer; s, spines. Scale bars: 6, 8 = 0.2 mm; 7, 9–12 = 0.1 mm." figureDoi-0="http://doi.org/10.5281/zenodo.6405013" figureDoi-1="http://doi.org/10.5281/zenodo.6405015" httpUri-0="https://zenodo.org/record/6405013/files/figure.png" httpUri-1="https://zenodo.org/record/6405015/files/figure.png" pageId="1" pageNumber="156">Figs. 2–7</figureCitation>
(head, abdomen, sensory pit of lateral abdominal process, habitus) (revision); 
<treatmentCitation id="AB5710F4FF9CF40BFB3AFA76FF23F9F7" author="Holzinger, W. E. &amp; Kunz, G." page="53" pageId="1" pageNumber="156" year="2006">
<bibRefCitation id="4E674B14FF9CF40BFB3AFA76FF23F9F7" author="Holzinger, W. E. &amp; Kunz, G." pageId="1" pageNumber="156" pagination="53 - 61" refId="ref15471" refString="Holzinger, W. E. &amp; Kunz, G. (2006) A new genus and species of Bennarellini form Costa Rica (Hemiptera: Fulgoromorpha: Cixiidae). Zootaxa, 1353, 53 - 61." type="journal article" year="2006">Holzinger &amp; Kunz 2006: 53</bibRefCitation>
</treatmentCitation>
, 56, 
<figureCitation id="B2CD2A60FF9CF40BFE88FA50FE9AF9F7" box="[275,347,1530,1554]" captionStart="FIGURES 13–18" captionStartId="6.[151,264,1366,1390]" captionTargetBox="[151,1435,181,1341]" captionTargetId="figure-24@6.[151,1435,181,1341]" captionTargetPageId="6" captionText="FIGURES 13–18. Bennarella bicoloripennis Muir, female genitalia: 13. Ventral view; 14. Gonoplac (third valvula), lateral view; 15. Gonapophysis IX (second valvula); 16. Gonapophysis VIII, lateral view (first valvula); 17. Apex of the gonapophysis IX (second valvula); 18. Apex of the gonapophysis VIII, lateral view (first valvula).Abbreviations: br, branch; de, denticles; dsa, dorsal sculpted area; vsa, ventral sculpted area. Scale bars: 13 = 0.3 mm; 14–18 = 0.1 mm." figureDoi="http://doi.org/10.5281/zenodo.6405017" httpUri="https://zenodo.org/record/6405017/files/figure.png" pageId="1" pageNumber="156">Fig. 15</figureCitation>
(head, thorax); 
<bibRefCitation id="4E674B14FF9CF40BFE66FA50FD19F9F7" author="Holzinger, W. E. &amp; Holzinger, I. &amp; Egger, J." box="[509,728,1530,1554]" pageId="1" pageNumber="156" pagination="143 - 153" refId="ref15511" refString="Holzinger, W. E., Holzinger, I. &amp; Egger, J. (2013) A new genus, Loisirella, and two new species of Bennarellini from Ecuador (Hemiptera: Auchenorrhyncha: Fulgoromorpha: Cixiidae). Aca Musei Moraviae, Scientiae biologicae, Brno, 98 (2), 143 - 153." type="journal article" year="2013">
Holzinger 
<emphasis id="1882EAF7FF9CF40BFDF3FA51FD54F9F7" box="[616,661,1530,1554]" italics="true" pageId="1" pageNumber="156">et al</emphasis>
. 2013
</bibRefCitation>
: 143,148,152, 
<figureCitation id="B2CD2A60FF9CF40BFCF6FA50FC7FF9F7" box="[877,958,1530,1554]" captionStart="FIGURES 24–30" captionStartId="9.[151,264,1760,1784]" captionTargetBox="[157,1435,182,1728]" captionTargetId="figure-17@9.[151,1435,181,1736]" captionTargetPageId="9" captionText="FIGURES 24–30. Bennarella fusca Muir, male genitalia: 24. Genital capsule, lateral view; 25. Anal tube and pygofer, dorsal view; 26. Anal tube, pygofer and gonostyli, posterior view; 27. Gonostylus left lateral view; 28. Gonostyli, dorsal view; 29. Phallic complex, left lateral view; 30. Phallic complex, right lateral view. Scale bars: 24, 26 = 0.2 mm; 25, 27–30 = 0.1 mm." figureDoi="http://doi.org/10.5281/zenodo.6405021" httpUri="https://zenodo.org/record/6405021/files/figure.png" pageId="1" pageNumber="156">Figs. 27</figureCitation>
(head, thorax) (key).
