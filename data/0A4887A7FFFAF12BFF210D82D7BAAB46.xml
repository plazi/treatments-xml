<taxonomicName id="45E14D32FFFAF12BFE200D82D730AA86" authorityName="Burmeister" authorityYear="1840" box="[389,528,1682,1708]" class="Insecta" family="Pamphagidae" kingdom="Animalia" order="Orthoptera" pageId="14" pageNumber="239" phylum="Arthropoda" rank="family">Pamphagidae</taxonomicName>
