<taxonomicName id="03944D7DFF316A8EF73D9E56177AB302" baseAuthorityName="Peters" baseAuthorityYear="1871" box="[2241,2426,2063,2096]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="202" pageNumber="964" phylum="Chordata" rank="species" species="laniger">Myotis laniger</taxonomicName>
