Subgenus 
<taxonomicName id="03944D7DFF316A8EF75491B116FDB33B" authority="Kaup, 1829" box="[2216,2301,2024,2057]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="202" pageNumber="964" phylum="Chordata" rank="genus">Myotis</taxonomicName>
