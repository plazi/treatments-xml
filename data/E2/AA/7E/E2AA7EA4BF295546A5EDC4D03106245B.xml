<emphasis bold="true" pageId="0" pageNumber="1">A</emphasis>
); 0.05 mm (
<emphasis bold="true" pageId="0" pageNumber="1">B- D, F, G</emphasis>
); 0.02 mm (
<emphasis bold="true" pageId="0" pageNumber="1">E, H-J</emphasis>
