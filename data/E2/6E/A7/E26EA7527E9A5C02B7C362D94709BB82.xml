<subSubSection pageId="0" pageNumber="41" type="diagnosis">
<paragraph pageId="0" pageNumber="41">Diagnosis.</paragraph>
<paragraph pageId="0" pageNumber="41">
<taxonomicName authorityName="Kang &amp; Whitfield &amp; Owens &amp; Chen" authorityYear="2022" baseAuthorityName="Dabek &amp; Whitfield" baseAuthorityYear="2020" class="Insecta" family="Braconidae" genus="Neocardiochiles" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Neocardiochiles hasegawai" order="Hymenoptera" pageId="0" pageNumber="41" phylum="Arthropoda" rank="species" species="hasegawai">
<emphasis italics="true" pageId="0" pageNumber="41">Neocardiochiles hasegawai</emphasis>
</taxonomicName>
is most similar to 
<taxonomicName class="Insecta" genus="N." kingdom="Animalia" lsidName="N. alexeyi" order="Hymenoptera" pageId="0" pageNumber="41" phylum="Arthropoda" rank="species" species="alexeyi">
<emphasis italics="true" pageId="0" pageNumber="41">N. alexeyi</emphasis>
</taxonomicName>
sp. nov. and 
<taxonomicName class="Insecta" genus="N." kingdom="Animalia" lsidName="N. franki" order="Hymenoptera" pageId="0" pageNumber="41" phylum="Arthropoda" rank="species" species="franki">
<emphasis italics="true" pageId="0" pageNumber="41">N. franki</emphasis>
</taxonomicName>
sp. nov., but the members of 
<taxonomicName class="Insecta" genus="N." kingdom="Animalia" lsidName="N. hasegawai" order="Hymenoptera" pageId="0" pageNumber="41" phylum="Arthropoda" rank="species" species="hasegawai">
<emphasis italics="true" pageId="0" pageNumber="41">N. hasegawai</emphasis>
</taxonomicName>
differ from other 
<taxonomicName authorityName="Szepligeti" authorityYear="1908" class="Insecta" family="Braconidae" genus="Neocardiochiles" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Neocardiochiles" order="Hymenoptera" pageId="0" pageNumber="41" phylum="Arthropoda" rank="genus">
<emphasis italics="true" pageId="0" pageNumber="41">Neocardiochiles</emphasis>
</taxonomicName>
species by possession of the two following characters: mesoscutum entirely pale; hind femur entirely pale.
</paragraph>
</subSubSection>
