<subSubSection id="7A9974EC5286EE5EF961870F0168C9C2" pageId="null" pageNumber="505" type="description">
<paragraph id="13C48FB052569F31DEE0D9D75C35AB56" pageId="null" pageNumber="505">
5-20 cm hoch. 
<normalizedToken id="503314F2B9012F818277DECA6583B503" originalValue="Grundständige" pageId="null" pageNumber="505">Grundstaendige</normalizedToken>
Blattscheiden gelb oder braun. 
<emphasis id="13D952A2B46D638683B21834BB2B1C69" italics="true" pageId="null" pageNumber="505">
Reife Frucht kugelig. 
<normalizedToken id="0D5574923D7DDEA150F8A5AEDAC8FB8C" originalValue="Perigonblätter" pageId="null" pageNumber="505">Perigonblaetter</normalizedToken>
abstehend. Alle 
<normalizedToken id="7651E0A67A2F1209159C92249A5ED1CE" originalValue="Perigonblätter" pageId="null" pageNumber="505">Perigonblaetter</normalizedToken>
spitz, viel 
<normalizedToken id="8E6690950461B221EF5340B547BC0C89" originalValue="länger" pageId="null" pageNumber="505">laenger</normalizedToken>
als der Durchmesser der reifen Frucht
</emphasis>
, gelblich. - 
<normalizedToken id="C9F2D75885BA327E50FAE6AB2CB8E461" originalValue="Blüte" pageId="null" pageNumber="505">Bluete</normalizedToken>
: 
<normalizedToken id="B192E2A5EE6814B37014C70B1F94AC91" originalValue="Früher" pageId="null" pageNumber="505">Frueher</normalizedToken>
bis 
<normalizedToken id="9A20332BC9B86A6E39753283982C49DD" originalValue="später" pageId="null" pageNumber="505">spaeter</normalizedToken>
Sommer.
</paragraph>
<paragraph id="B05E3853D8B7C78490F024B87BD3E6DC" pageId="null" pageNumber="505">
<emphasis id="4EC836C6286104F18F0DB63272DC23CE" italics="true" pageId="null" pageNumber="505">Zytologische Angaben. 2n = 36:</emphasis>
Material aus botanischen 
<normalizedToken id="3721A3064E09A1E90710806F2447F035" originalValue="Gärten" pageId="null" pageNumber="505">Gaerten</normalizedToken>
(Snogerup 1958).
</paragraph>
<paragraph id="14B823C3520C4480DEDE7FD4251DF4CC" pageId="null" pageNumber="505">
<emphasis id="9F7F81D115EAD78FA989F588C251F4B9" italics="true" pageId="null" pageNumber="505">Standort.</emphasis>
Kollin. Wie 
<emphasis id="D36FE5D7B05C07C8848F497A0D4ED4F5" italics="true" pageId="null" pageNumber="505">J. tenageja</emphasis>
(Nr. 6).
</paragraph>
<paragraph id="F2D1E6294F0B6E346F0DF30FBC810954" pageId="null" pageNumber="505">
<emphasis id="7562115AAAF58A80317EFD3A827DFEAE" italics="true" pageId="null" pageNumber="505">Verbreitung. Mediterran-asiatische Pflanze:</emphasis>
<normalizedToken id="9980D47F01A6CBDB73C7D109778FBA02" originalValue="Nordwärts" pageId="null" pageNumber="505">Nordwaerts</normalizedToken>
bis Westalpen, Maingebiet, 
<normalizedToken id="07B2D632D2D24B45CE9A8FDB12E64CA8" originalValue="Thüringen" pageId="null" pageNumber="505">Thueringen</normalizedToken>
, Wiener Becken, Nordwestkarpaten, 
<normalizedToken id="DC5A21C156FA86907C7B6CCFF99CEDD9" originalValue="Südrußland" pageId="null" pageNumber="505">Suedrussland</normalizedToken>
, 
<normalizedToken id="7656C827C1255F7CCDF623249B43822B" originalValue="südwärts" pageId="null" pageNumber="505">suedwaerts</normalizedToken>
bis Nordwestafrika, Balkanhalbinsel, durch 
<normalizedToken id="9CD5EEB8E2D8DEA5ABC7DD922CCF19CF" originalValue="Südwest-" pageId="null" pageNumber="505">Suedwest-</normalizedToken>
und Zentralasien 
<normalizedToken id="E9BD9D96B6D2BE334109A0D713F2769D" originalValue="ostwärts" pageId="null" pageNumber="505">ostwaerts</normalizedToken>
bis in die Mongolei; in Nordamerika kaum 
<normalizedToken id="E94A0258AC428C795EA892053E47FB4C" originalValue="ursprünglich" pageId="null" pageNumber="505">urspruenglich</normalizedToken>
. - Im Gebiet: Savoyen, Oberrheinische Tiefebene (Gegend von 
<normalizedToken id="0ADF458B49754B0748AD3F4830EB7D59" originalValue="Straßburg" pageId="null" pageNumber="505">Strassburg</normalizedToken>
).
</paragraph>
</subSubSection>
