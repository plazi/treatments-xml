<emphasis id="B9626913FFDFFF1FFF1A8805E647F8F1" bold="true" box="[151,269,1847,1872]" pageId="14" pageNumber="15">FIGURE 5</emphasis>
. 
<taxonomicName id="4C16CE82FFDFFF1FFE95880AE6F5F8F1" authority="Just, 2022" authorityName="Just" authorityYear="2022" box="[280,447,1848,1872]" class="Malacostraca" family="Synopiidae" genus="Tiron" kingdom="Animalia" order="Amphipoda" pageId="14" pageNumber="15" phylum="Arthropoda" rank="species" species="canadense" status="sp. nov.">
<emphasis id="B9626913FFDFFF1FFE95880AE6F5F8F1" box="[280,447,1848,1872]" italics="true" pageId="14" pageNumber="15">Tiron canadense</emphasis>
</taxonomicName>
<emphasis id="B9626913FFDFFF1FFE48880AE55FF8F1" bold="true" box="[453,533,1848,1872]" pageId="14" pageNumber="15">
<taxonomicNameLabel id="A251D468FFDFFF1FFE48880AE55FF8F1" box="[453,533,1848,1872]" pageId="14" pageNumber="15" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
Holotype, ♀. 
<emphasis id="B9626913FFDFFF1FFD28880AE44AF8F1" bold="true" box="[677,768,1848,1872]" pageId="14" pageNumber="15">gp1–gp2</emphasis>
, gnathopods 1 and 2; 
<emphasis id="B9626913FFDFFF1FFC53880AE360F8F1" bold="true" box="[990,1066,1848,1872]" pageId="14" pageNumber="15">p3, 5, 7</emphasis>
, pereopods 3, 5, and 7; 
<emphasis id="B9626913FFDFFF1FFA97880AE216F8F1" bold="true" box="[1306,1372,1848,1872]" pageId="14" pageNumber="15">p7 mv</emphasis>
