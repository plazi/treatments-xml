<taxonomicName id="4C16CE82FFDCFF1CFE96886EE688F8D2" authority="Just, 2022" authorityName="Just" authorityYear="2022" box="[283,450,1883,1907]" class="Malacostraca" family="Synopiidae" genus="Tiron" kingdom="Animalia" order="Amphipoda" pageId="13" pageNumber="14" phylum="Arthropoda" rank="species" species="canadense" status="sp. nov.">
<emphasis id="B9626913FFDCFF1CFE96886EE688F8D2" box="[283,450,1883,1907]" italics="true" pageId="13" pageNumber="14">Tiron canadense</emphasis>
</taxonomicName>
<emphasis id="B9626913FFDCFF1CFE448869E550F8D2" bold="true" box="[457,538,1883,1907]" pageId="13" pageNumber="14">
<taxonomicNameLabel id="A251D468FFDCFF1CFE448869E550F8D2" box="[457,538,1883,1907]" pageId="13" pageNumber="14" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
Holotype, ♀, except 
<emphasis id="B9626913FFDCFF1CFD7B8869E44EF8D2" bold="true" box="[758,772,1883,1907]" pageId="13" pageNumber="14">S</emphasis>
<taxonomicName id="4C16CE82FFDCFF1CFC86886EE4E6F8D2" baseAuthorityName="Stimpson" baseAuthorityYear="1853" box="[779,940,1883,1907]" class="Malacostraca" family="Synopiidae" genus="Tiron" kingdom="Animalia" order="Amphipoda" pageId="13" pageNumber="14" phylum="Arthropoda" rank="species" species="spiniferus">
<emphasis id="B9626913FFDCFF1CFC86886EE4E6F8D2" box="[779,940,1883,1907]" italics="true" pageId="13" pageNumber="14">Tiron spiniferus</emphasis>
</taxonomicName>
from Western Greenland. 
<emphasis id="B9626913FFDCFF1CFB368869E390F8D2" bold="true" box="[1211,1242,1883,1907]" pageId="13" pageNumber="14">clv</emphasis>
, head lateral view; 
<emphasis id="B9626913FFDCFF1CFF1A884DE7AEF836" bold="true" box="[151,228,1919,1943]" pageId="13" pageNumber="14">md plp</emphasis>
, mandible palp; 
<emphasis id="B9626913FFDCFF1CFE1C884DE6F5F836" bold="true" box="[401,447,1919,1943]" pageId="13" pageNumber="14">mx1</emphasis>
, maxilla 1 (medial view); 
<emphasis id="B9626913FFDCFF1CFD42884DE5B6F836" bold="true" box="[719,764,1919,1943]" pageId="13" pageNumber="14">pleo</emphasis>
, pleonites (1–3); 
<emphasis id="B9626913FFDCFF1CFC3C884DE486F836" bold="true" box="[945,972,1919,1943]" pageId="13" pageNumber="14">tel</emphasis>
, telson; 
<emphasis id="B9626913FFDCFF1CFBAE884DE375F836" bold="true" box="[1059,1087,1919,1943]" pageId="13" pageNumber="14">up</emphasis>
, uropods; 
<emphasis id="B9626913FFDCFF1CFB21884DE391F836" bold="true" box="[1196,1243,1919,1943]" pageId="13" pageNumber="14">uros</emphasis>
, urosomites. Scale for holotype clv, 1 mm.
</paragraph>
</caption>
<caption id="DF69E589FFDFFF1FFF1A8805E6D4F8D5" ID-DOI="http://doi.org/10.5281/zenodo.6572033" ID-Zenodo-Dep="6572033" httpUri="https://zenodo.org/record/6572033/files/figure.png" pageId="14" pageNumber="15" startId="14.[151,250,1847,1871]" targetBox="[157,1427,194,1819]" targetPageId="14">
