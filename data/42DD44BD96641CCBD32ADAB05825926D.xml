<subSubSection id="8BEC2EBB46A105E8FE22EB9CDF086774" pageId="null" pageNumber="820" type="description">
<paragraph id="B219D6DF6CE949F6B97C0F95BF7D2388" pageId="null" pageNumber="820">
1 
<normalizedToken id="50B2318D15054C7F5DEB7813AD760BD7" originalValue="jährig" pageId="null" pageNumber="820">jaehrig</normalizedToken>
; 
<emphasis id="BA7B9C45B10953A014A97E37A5BEC1C4" italics="true" pageId="null" pageNumber="820">10-40 cm hoch;</emphasis>
<normalizedToken id="56FD6111E123187BD502927E6CEC8C3D" originalValue="bläulichgrün" pageId="null" pageNumber="820">blaeulichgruen</normalizedToken>
, kahl. Stengel aufrecht, einfach oder selten am Grunde verzweigt. 
<normalizedToken id="CF9DC6A092CFAF4E738FB26827102549" originalValue="Blätter" pageId="null" pageNumber="820">Blaetter</normalizedToken>
schmal lanzettlich, bis 3 cm lang, 4-15mal so lang wie breit. 
<normalizedToken id="37159050F78A9F8D56B2354ED6EE6E95" originalValue="Blüten" pageId="null" pageNumber="820">Blueten</normalizedToken>
am Ende des Stengels locker rispenartig angeordnet. Fruchtstiele 4-10mal so lang wie der Kelch. 
<emphasis id="40C5484B3F89780692418AB4BEFEE618" italics="true" pageId="null" pageNumber="820">
<normalizedToken id="208210105A26F735A3D0CA9A076A0414" originalValue="Kelchblätter" pageId="null" pageNumber="820">Kelchblaetter</normalizedToken>
5, 6-10 mm lang. 
<normalizedToken id="56C41E0EBB07F44027FDC67F5DC5C418" originalValue="Kronblätter" pageId="null" pageNumber="820">Kronblaetter</normalizedToken>
5, 1
</emphasis>
<normalizedToken id="80778141482E914BA8ACA0317C3A7AC2" originalValue="½" pageId="null" pageNumber="820">1/2</normalizedToken>
<emphasis id="3CB63DD42276E413131CC98BA75FC264" italics="true" pageId="null" pageNumber="820">
-2mal so lang wie die 
<normalizedToken id="5E37584EEF302E0B7C3AB6C83AFDB8D1" originalValue="Kelchblätter" pageId="null" pageNumber="820">Kelchblaetter</normalizedToken>
</emphasis>
, 
<normalizedToken id="E942EECEA6DBF16298AD7B124F6700E9" originalValue="weiß" pageId="null" pageNumber="820">weiss</normalizedToken>
. 
<emphasis id="D265124CB234ACAAB567FD515A41FABA" italics="true" pageId="null" pageNumber="820">
<normalizedToken id="0D48ABF74C17CB120CCD71926EC86D40" originalValue="Staubblätter" pageId="null" pageNumber="820">Staubblaetter</normalizedToken>
10.
</emphasis>
Kapsel wenig 
<normalizedToken id="3E525D14B3E763660BAE496C6AFF6D1B" originalValue="kürzer" pageId="null" pageNumber="820">kuerzer</normalizedToken>
als der Kelch. Samen 0,6-0, 8 mm lang, fein gerippt, am Rande gefurcht. - 
<normalizedToken id="4D05F201B980B44178AEDC35F04BA3CE" originalValue="Blüte" pageId="null" pageNumber="820">Bluete</normalizedToken>
: 
<normalizedToken id="2838B33D90E3E82777D39E0A7F713B56" originalValue="Später" pageId="null" pageNumber="820">Spaeter</normalizedToken>
<normalizedToken id="48A6999CA918907F1354DAE070F39A2B" originalValue="Frühling" pageId="null" pageNumber="820">Fruehling</normalizedToken>
und 
<normalizedToken id="E16A2CFB770A729449E1912CCC3ACBFF" originalValue="früher" pageId="null" pageNumber="820">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="395C9F2CC249B613A20435E23129EBCA" pageId="null" pageNumber="820">
<emphasis id="5B7E86E306F440BCE94EE1C320DC23FD" italics="true" pageId="null" pageNumber="820">Zytologische Angaben. 2n = 38:</emphasis>
Material unbekannter Herkunft (Blackburn aus Tischler 1950).
</paragraph>
<paragraph id="27D378DCED440F37156BA64CF3C9E1E2" pageId="null" pageNumber="820">
<emphasis id="D1619F90AC6FA737345D8EBCB48AA982" italics="true" pageId="null" pageNumber="820">Standort.</emphasis>
Kollin, selten montan. Eher feuchte, 
<normalizedToken id="012A5C186BE65368F8711FEFE7F48FA3" originalValue="nährstoffreiche" pageId="null" pageNumber="820">naehrstoffreiche</normalizedToken>
<normalizedToken id="2967ED305B16B5D2B3AE002A044CBFB4" originalValue="Böden" pageId="null" pageNumber="820">Boeden</normalizedToken>
in warmen Lagen. Fettwiesen.
</paragraph>
<paragraph id="0F561368453D61AA85CDCDF3FABF9BAA" pageId="null" pageNumber="820">
<emphasis id="354EABF4DBFA99BB17071399BF71F42F" italics="true" pageId="null" pageNumber="820">Verbreitung. Ostmediterrane Pflanze:</emphasis>
<normalizedToken id="9A0445B5D09B04DD793EB31C2DB68FB5" originalValue="Südosteuropa" pageId="null" pageNumber="820">Suedosteuropa</normalizedToken>
(west- und 
<normalizedToken id="352EC66019612633B04B1C7DFF60B733" originalValue="nordwärts" pageId="null" pageNumber="820">nordwaerts</normalizedToken>
bis Apennin, Alpen, Ungarn); Kleinasien, Armenien. Verbreitungskarte von Meusel (1964). - Im Gebiet: 
<normalizedToken id="B4E24FE86D3AAB0FF1831EB3CF2DC7A7" originalValue="Südalpine" pageId="null" pageNumber="820">Suedalpine</normalizedToken>
<normalizedToken id="4269B88315982CC5E1AC29CF47B3D7AD" originalValue="Täler" pageId="null" pageNumber="820">Taeler</normalizedToken>
(unterstes Aostatal, Valsesia [Borgosesia], Tessin [
<normalizedToken id="806611F9B37CD8D0F804670CB16A58C1" originalValue="nordwärts" pageId="null" pageNumber="820">nordwaerts</normalizedToken>
bis zum untern Maggia- und Bleniotal], Comerseegebiet, unteres Misox, Veltlin); selten auch adventiv.
</paragraph>
</subSubSection>
