<taxonomicName id="4C2C4D4D003EFFEEFC45FBC2FBC75B14" authorityName="Lane" authorityYear="1956" box="[958,1077,1087,1112]" class="Insecta" family="Cerambycidae" genus="Purusia" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="159" phylum="Arthropoda" rank="species" species="acreana">
<emphasis id="B958EADC003EFFEEFC45FBC2FBC75B14" box="[958,1077,1087,1112]" italics="true" pageId="8" pageNumber="159">P. acreana</emphasis>
</taxonomicName>
