<taxonomicName id="4C2C4D4D003EFFEEFDDDFC0AFD135B5C" authorityName="Lane" authorityYear="1956" box="[550,737,1015,1040]" class="Insecta" family="Cerambycidae" genus="Purusia" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="159" phylum="Arthropoda" rank="species" species="acreana">
