<taxonomicName id="4C2C4D4D003EFFEEFA73FC0AFF005B78" authorityName="Lane" authorityYear="1956" class="Insecta" family="Cerambycidae" genus="Purusia" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="159" phylum="Arthropoda" rank="species" species="acreana">
