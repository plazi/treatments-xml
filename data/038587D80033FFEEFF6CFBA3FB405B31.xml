<taxonomicName id="4C2C4D4D003EFFEEFBD7FB9EFB505B30" authorityName="Lane" authorityYear="1956" box="[1068,1186,1123,1148]" class="Insecta" family="Cerambycidae" genus="Purusia" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="159" phylum="Arthropoda" rank="species" species="acreana">
<emphasis id="B958EADC003EFFEEFBD7FB9EFB505B30" box="[1068,1186,1123,1148]" italics="true" pageId="8" pageNumber="159">P. acreana</emphasis>
