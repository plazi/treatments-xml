<subSubSection id="5437FAD7DF708BA1A41C28C398356551" pageId="null" pageNumber="713" type="description">
<paragraph id="6441D7D711F72EB81957F7557E1D8B6F" pageId="null" pageNumber="713">
<emphasis id="F0300342DB719FD4F32B242F4F8EBEE0" italics="true" pageId="null" pageNumber="713">
<normalizedToken id="FBC976D2748ACD1BE82986C623A921BC" originalValue="Immergrüne" pageId="null" pageNumber="713">Immergruene</normalizedToken>
<normalizedToken id="F6F27F78C70E236C990EEA64A2A8D3E7" originalValue="Bäume" pageId="null" pageNumber="713">Baeume</normalizedToken>
oder 
<normalizedToken id="32836D738D10096D4A21ACF68D384EA8" originalValue="Sträucher" pageId="null" pageNumber="713">Straeucher</normalizedToken>
.
</emphasis>
<normalizedToken id="5E01AD73E6CFA577BFB827A98624979A" originalValue="Blätter" pageId="null" pageNumber="713">Blaetter</normalizedToken>
schmal lanzettlich bis breit oval, lederig. Zwittrige und rein ♂ 
<normalizedToken id="7A9AAFE302D5BD6CC6FF3694B771D701" originalValue="Blüten" pageId="null" pageNumber="713">Blueten</normalizedToken>
auf derselben Pflanze oder auf verschiedenen Pflanzen. 
<normalizedToken id="131CC5B6A902AB8D4B3ADAFD35438DE7" originalValue="Blüten" pageId="null" pageNumber="713">Blueten</normalizedToken>
3- oder 4 
<normalizedToken id="13D2E46A168DD7D4D71D21E7321E207C" originalValue="zählig" pageId="null" pageNumber="713">zaehlig</normalizedToken>
. ♂ 
<emphasis id="505D150F9E23E17B08EF2F003167A9A0" italics="true" pageId="null" pageNumber="713">
<normalizedToken id="A10C2C84ECACA8A6CF998A246635149F" originalValue="Blüten" pageId="null" pageNumber="713">Blueten</normalizedToken>
in 
<normalizedToken id="84514D40A864B4633DD893F855DB4A6B" originalValue="achselständigen" pageId="null" pageNumber="713">achselstaendigen</normalizedToken>
Trauben; zwittrige oder
</emphasis>
♀ 
<emphasis id="5C369D575D51056D602A5468A6AFD7F6" italics="true" pageId="null" pageNumber="713">
<normalizedToken id="B30B8D8A4F3E4268C934ABFEBCFDD370" originalValue="Blüten" pageId="null" pageNumber="713">Blueten</normalizedToken>
einzeln oder zu 3 beisammen.
</emphasis>
Fruchtknoten 
<normalizedToken id="6DB00895D6C64E8977B14F5A6934EE82" originalValue="unterständig" pageId="null" pageNumber="713">unterstaendig</normalizedToken>
, mit 2-4 Samenanlagen; Griffel kurz; Narben 3 oder 4. Frucht steinfruchtartig, 1samig, kugelig oder 
<normalizedToken id="7520E41A641DC7D8503EDA4E73AE93D5" originalValue="eiförmig" pageId="null" pageNumber="713">eifoermig</normalizedToken>
, an der Spitze mit den Resten des Perigons.
</paragraph>
<paragraph id="2C2DF6BA1F959E82A473B66343A0A677" pageId="null" pageNumber="713">
Die Gattung 
<taxonomicName id="F99E495E651CF2E4282F86BA3821F9F5" class="Magnoliopsida" family="Santalaceae" genus="Osyris" kingdom="Plantae" order="Santalales" pageId="null" pageNumber="713" phylum="Tracheophyta" rank="genus">
<emphasis id="4A00F3B1052CAC58451049A08B51E234" italics="true" pageId="null" pageNumber="713">Osyris</emphasis>
</taxonomicName>
<normalizedToken id="AFF7563E4ADCC6D0F3686645C0FB4A61" originalValue="umfaßt" pageId="null" pageNumber="713">umfasst</normalizedToken>
<emphasis id="34DB8EDC441F29DC1F2F6B64B3579A87" italics="true" pageId="null" pageNumber="713">7 Arten</emphasis>
, die im 
<emphasis id="7EDC3632AE61F7AC26D459DA49BF53A0" italics="true" pageId="null" pageNumber="713">Mittelmeergebiet</emphasis>
, in 
<emphasis id="2D0EAF8736F3A70E30D4F468C66CB22F" italics="true" pageId="null" pageNumber="713">Afrika</emphasis>
, in 
<emphasis id="AD0F96437414E798EC83B431619ED7B8" italics="true" pageId="null" pageNumber="713">
<normalizedToken id="D92C1EB118824377D175AFA199C6F3A6" originalValue="Süd-" pageId="null" pageNumber="713">Sued-</normalizedToken>
und 
<normalizedToken id="E12B91F268CEAE7F186DF7D2398AA476" originalValue="Südostasien" pageId="null" pageNumber="713">Suedostasien</normalizedToken>
verbreitet sind
</emphasis>
(in den Tropen nur in Gebirgen).
</paragraph>
</subSubSection>
