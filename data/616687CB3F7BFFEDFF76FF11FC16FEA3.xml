<emphasis id="DBBBEACF3F7BFFECFF76FF5DFED7FF12" box="[151,311,219,243]" italics="true" pageId="78" pageNumber="79">Gobius minutus</emphasis>
<bibRefCitation id="8D5E4B2C3F7BFFECFEDCFF5DFE36FF15" author="Pallas, P. S." box="[317,470,219,244]" pageId="78" pageNumber="79" refId="ref62552" refString="Pallas, P. S. (1770) Spicilegia Zoologica quibus novae imprimis et obscurae animalium species iconibus, descriptionibus atque commentariis illustrantur. 1 (8). Gottl. August. Lange, Berolini, 56 pp., 5 pls." type="book" year="1770">Pallas, 1770: 4</bibRefCitation>
