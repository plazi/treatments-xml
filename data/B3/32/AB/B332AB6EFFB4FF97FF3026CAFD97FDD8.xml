<subSubSection pageId="13" pageNumber="14" type="etymology">
<paragraph blockId="13.[151,1437,151,609]" pageId="13" pageNumber="14">
<emphasis bold="true" box="[199,328,295,321]" pageId="13" pageNumber="14">Etymology</emphasis>
. The specific epithet “costalis” is used to denote the contrastingly pale brownish-orange embolium of this species.
</paragraph>
</subSubSection>
<subSubSection box="[199,387,367,393]" pageId="13" pageNumber="14" type="biology_ecology">
