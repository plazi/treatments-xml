<subSubSection pageId="9" pageNumber="10" type="etymology">
<paragraph blockId="9.[151,1437,289,2009]" pageId="9" pageNumber="10">
<emphasis bold="true" box="[199,334,1694,1720]" pageId="9" pageNumber="10">Etymology.</emphasis>
The specific epithet “ 
<taxonomicName box="[593,772,1694,1720]" class="Insecta" family="Miridae" genus="Cyrtocapsus" kingdom="Animalia" order="Hemiptera" pageId="9" pageNumber="10" phylum="Arthropoda" rank="species" species="atrametatibialis">
<emphasis box="[593,772,1694,1720]" italics="true" pageId="9" pageNumber="10">atrametatibialis</emphasis>
</taxonomicName>
” is used to denote the uniformly black hind tibiae in the males of this species.
</paragraph>
</subSubSection>
<subSubSection box="[199,909,1765,1792]" pageId="9" pageNumber="10" type="biology_ecology">
<paragraph blockId="9.[151,1437,289,2009]" box="[199,909,1765,1792]" pageId="9" pageNumber="10">
<emphasis bold="true" box="[199,262,1766,1792]" pageId="9" pageNumber="10">Host.</emphasis>
Beaten from pica-pica, 
<taxonomicName box="[532,709,1766,1792]" class="Magnoliopsida" family="Euphorbiaceae" genus="Cnidoscolus" kingdom="Plantae" order="Malpighiales" pageId="9" pageNumber="10" phylum="Tracheophyta" rank="species" species="undetermined">
<emphasis box="[532,670,1766,1792]" italics="true" pageId="9" pageNumber="10">Cnidoscolus</emphasis>
sp.
</taxonomicName>
[
<taxonomicName box="[723,899,1765,1792]" class="Magnoliopsida" family="Euphorbiaceae" kingdom="Plantae" order="Malpighiales" pageId="9" pageNumber="10" phylum="Tracheophyta" rank="family">Euphorbiaceae</taxonomicName>
].
</paragraph>
</subSubSection>
<subSubSection box="[199,934,1801,1828]" pageId="9" pageNumber="10" type="distribution">
<paragraph blockId="9.[151,1437,289,2009]" box="[199,934,1801,1828]" pageId="9" pageNumber="10">
<emphasis bold="true" box="[199,353,1801,1827]" pageId="9" pageNumber="10">Distribution.</emphasis>
Known only from 
<collectingRegion box="[567,833,1802,1828]" country="Bolivia" name="Santa Cruz" pageId="9" pageNumber="10">Santa Cruz Department</collectingRegion>
, 
<collectingCountry box="[844,930,1802,1828]" name="Bolivia" pageId="9" pageNumber="10">Bolivia</collectingCountry>
.
</paragraph>
</subSubSection>
