<taxonomicName authority="(Carvalho 1987)" baseAuthorityName="Carvalho" baseAuthorityYear="1987" box="[1083,1381,547,573]" class="Magnoliopsida" family="Fabaceae" kingdom="Plantae" order="Fabales" pageId="12" pageNumber="13" phylum="Tracheophyta" rank="family">
