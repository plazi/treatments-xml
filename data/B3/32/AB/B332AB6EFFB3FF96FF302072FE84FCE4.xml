<bibRefCitation author="Carvalho, J. C. M." box="[1202,1373,547,573]" pageId="12" pageNumber="13" pagination="235 - 239" refId="ref41922" refString="Carvalho, J. C. M. (1987) Mirideos neotropicais, CCLXXVIII: Descricoes de duas especies novas de Cyrtocapsus Reuter (Hemiptera). Boletim do Museum Paraense Emilio Goeldi, 3, 235 - 239." type="journal article" year="1987">Carvalho 1987</bibRefCitation>
