<subSubSection box="[199,1386,547,573]" pageId="12" pageNumber="13" type="biology_ecology">
<paragraph blockId="12.[151,1437,151,861]" box="[199,1386,547,573]" pageId="12" pageNumber="13">
<emphasis bold="true" box="[199,262,547,573]" pageId="12" pageNumber="13">Host.</emphasis>
The 
<typeStatus box="[319,417,547,573]" pageId="12" pageNumber="13">holotype</typeStatus>
and 
<specimenCount box="[472,614,547,573]" pageId="12" pageNumber="13" type="generic" typeStatus="paratypes">16 paratypes</specimenCount>
