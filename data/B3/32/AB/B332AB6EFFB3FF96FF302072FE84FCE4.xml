<subSubSection box="[199,1267,582,609]" pageId="12" pageNumber="13" type="distribution">
<paragraph blockId="12.[151,1437,151,861]" box="[199,1267,582,609]" pageId="12" pageNumber="13">
<emphasis bold="true" box="[199,353,582,608]" pageId="12" pageNumber="13">Distribution.</emphasis>
