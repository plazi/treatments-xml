<subSubSection pageId="28" pageNumber="29" type="etymology">
<paragraph blockId="28.[151,1437,289,2009]" pageId="28" pageNumber="29">
<emphasis bold="true" box="[199,328,1730,1756]" pageId="28" pageNumber="29">Etymology</emphasis>
. The specific epithet “ 
<taxonomicName box="[579,745,1730,1756]" class="Insecta" family="Miridae" genus="Cyrtocapsus" kingdom="Animalia" order="Hemiptera" pageId="28" pageNumber="29" phylum="Arthropoda" rank="species" species="metafemoratus">
<emphasis box="[579,745,1730,1756]" italics="true" pageId="28" pageNumber="29">metafemoratus</emphasis>
</taxonomicName>
” is used to denote the apically dark brown hind femora of this species.
</paragraph>
</subSubSection>
