<subSubSection box="[199,1366,1857,1884]" pageId="17" pageNumber="18" type="biology_ecology">
<paragraph blockId="17.[151,1437,669,2028]" box="[199,1366,1857,1884]" pageId="17" pageNumber="18">
<emphasis bold="true" box="[199,262,1857,1883]" pageId="17" pageNumber="18">Host.</emphasis>
