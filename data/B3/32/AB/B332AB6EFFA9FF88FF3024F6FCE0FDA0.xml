<taxonomicName authorityName="Bergroth" authorityYear="1910" box="[1102,1222,1857,1884]" class="Insecta" family="Miridae" genus="Miccus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hemiptera" pageId="17" pageNumber="18" phylum="Arthropoda" rank="species" species="elutipes">
