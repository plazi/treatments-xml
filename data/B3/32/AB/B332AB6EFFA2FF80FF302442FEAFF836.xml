<emphasis box="[708,819,866,891]" italics="true" pageId="26" pageNumber="27">Pronotum</emphasis>
: Median length 
<quantity box="[1005,1168,865,892]" metricMagnitude="-4" metricUnit="m" metricValue="9.45" metricValueMax="9.9" metricValueMin="9.0" pageId="26" pageNumber="27" unit="mm" value="0.945" valueMax="0.99" valueMin="0.9">0.90–0.99 mm</quantity>
(
<quantity box="[1182,1288,865,892]" metricMagnitude="-4" metricUnit="m" metricValue="9.6" pageId="26" pageNumber="27" unit="mm" value="0.96">0.96 mm</quantity>
), basal width 
<quantity box="[151,314,901,928]" metricMagnitude="-3" metricUnit="m" metricValue="1.4449999999999998" metricValueMax="1.5" metricValueMin="1.39" pageId="26" pageNumber="27" unit="mm" value="1.4449999999999998" valueMax="1.5" valueMin="1.39">1.39–1.50 mm</quantity>
(
<quantity box="[329,434,901,928]" metricMagnitude="-3" metricUnit="m" metricValue="1.41" pageId="26" pageNumber="27" unit="mm" value="1.41">1.41 mm</quantity>
