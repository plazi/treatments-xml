shore of 
<location LSID="urn:lsid:plazi:treatment:B30087960D3BB63AFF4BFBACFE1DFA41:3E76605B0D38B63AFB66F844FAAFFBFD" box="[1189,1321,1058,1084]" country="Mexico" latitude="16.10467" longLatPrecision="1" longitude="-91.68978" name="Montebello" pageId="34" pageNumber="175" stateProvince="Chiapas">Montebello</location>
