<bibRefCitation author="Small, J. K." box="[414,615,1387,1413]" pageId="2" pageNumber="143" pagination="84" refId="ref43991" refString="Small, J. K. (1907 h) Hesperolinon. North American Flora 25: 84." type="journal article" year="1907">Small, 1907h: 84</bibRefCitation>
