<subSubSection box="[136,1391,1057,1084]" pageId="8" pageNumber="149" type="description">
<paragraph blockId="8.[136,1452,1057,1912]" box="[136,1391,1057,1084]" pageId="8" pageNumber="149">
<emphasis bold="true" box="[136,274,1057,1083]" pageId="8" pageNumber="149">Description</emphasis>
:— 
<emphasis box="[310,378,1058,1084]" italics="true" pageId="8" pageNumber="149">Herbs</emphasis>
with black stipular glands, very prominent on nodes, base of all leaves, bracts, and sepals.
</paragraph>
</subSubSection>
