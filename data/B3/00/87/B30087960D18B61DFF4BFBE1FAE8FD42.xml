<elevation box="[1162,1297,1998,2025]" metricMagnitude="3" metricUnit="m" metricValue="1.025" metricValueMax="2.0" metricValueMin="0.05" pageId="3" pageNumber="144" unit="m" value="1025.0" valueMax="2000.0" valueMin="50.0">50–2000 m</elevation>
