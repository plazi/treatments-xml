Cardamine 
<normalizedToken id="0837E38EF97346ADC21502A28EE61A9E" originalValue="trifólia" pageId="null" pageNumber="204">trifolia</normalizedToken>
<authorityName id="89A613A98B4D31C701D413937544761F" pageId="null" pageNumber="204">L.</authorityName>
