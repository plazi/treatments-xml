<paragraph id="792FC7E03864535EFFBEEFC0FD257328" pageId="null" pageNumber="471">
Spitzdorniger 
<normalizedToken id="A6FA3FD479E02948E1AE6FA2C0711F4B" originalValue="Weißdorn" pageId="null" pageNumber="471">Weissdorn</normalizedToken>
</paragraph>
</subSubSection>
</title>
<subSubSection id="A419A802C627769A416EB14B667F39CF" pageId="null" pageNumber="471" type="description">
<paragraph id="0A972211581E6729FF393D99157EB8DC" pageId="null" pageNumber="471">
Bis 4 m hoch. 
<emphasis id="77045BB5A628829BCABDE387449B4C62" italics="true" pageId="null" pageNumber="471">
<normalizedToken id="85918A3A34E19D784F6BFC17F9E19005" originalValue="Blätter" pageId="null" pageNumber="471">Blaetter</normalizedToken>
wenig tief 3-5teilig, mit schmalen Einschnitten; Abschnitte breit abgerundet
</emphasis>
, 
<emphasis id="8B35D3FB00D5E9D7FFC1A90CF4504231" italics="true" pageId="null" pageNumber="471">
mit bespitzten, wenig 
<normalizedToken id="F28C872627E21AD5F7D5C1FAFC7034B6" originalValue="einwärts" pageId="null" pageNumber="471">einwaerts</normalizedToken>
gebogenen, bis etwa 1 mm langen 
<normalizedToken id="AF544761184B024B6EAC5168C70E2367" originalValue="Zähnen" pageId="null" pageNumber="471">Zaehnen</normalizedToken>
</emphasis>
, unterseits im Herbst meist kahl. 
<emphasis id="EEB22E4A90AFCC76D52B3A03EEF2DD9E" italics="true" pageId="null" pageNumber="471">
<normalizedToken id="05AFB4D82966017D10A9DA378BA437B8" originalValue="Blütenstiele" pageId="null" pageNumber="471">Bluetenstiele</normalizedToken>
kahl.
</emphasis>
Durchmesser der 
<normalizedToken id="A28F1E1CF4ECC10E36664A95D4AE09D0" originalValue="Kronblätter" pageId="null" pageNumber="471">Kronblaetter</normalizedToken>
0,5-0,8 cm. 
<emphasis id="70EF05EA02724083CC7C21DE11D71955" italics="true" pageId="null" pageNumber="471">Frucht mit 2-3 Kernen</emphasis>
, rot. 
<emphasis id="B3DBA86032A97039DC117FA6D24D2B41" italics="true" pageId="null" pageNumber="471">Griffel 2-3.</emphasis>
- 
<normalizedToken id="D439715CDC68D1150FC97CE305CCA51B" originalValue="Blüte" pageId="null" pageNumber="471">Bluete</normalizedToken>
: 
<normalizedToken id="853E655633CAEF67B0D507CF1C1212F4" originalValue="Später" pageId="null" pageNumber="471">Spaeter</normalizedToken>
<normalizedToken id="EBD0FF2C43C6AC9494179EF8C051A111" originalValue="Frühling" pageId="null" pageNumber="471">Fruehling</normalizedToken>
; reife 
<normalizedToken id="290530CF8F887D4CF030557B1F6317FC" originalValue="Früchte" pageId="null" pageNumber="471">Fruechte</normalizedToken>
im Herbst (Oktober).
</paragraph>
<paragraph id="C3204EF41DF00623A482089AE8E93220" pageId="null" pageNumber="471">
<emphasis id="ABC8D220C7000CDBB064B54964A73235" italics="true" pageId="null" pageNumber="471">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0D4401B9183188BD79266A5F06BB7A16" italics="true" pageId="null" pageNumber="471">32:</emphasis>
Material aus botanischen 
<normalizedToken id="9C0CD00209DCB8BB04996A7CE67F81CD" originalValue="Gärten" pageId="null" pageNumber="471">Gaerten</normalizedToken>
; Pollenmeiose normal (Longley 1924b). 
<emphasis id="E4FA68130D4A8A507D39AEDF5D4AF6EC" italics="true" pageId="null" pageNumber="471">2n</emphasis>
= 
<emphasis id="F3D2314CB00848462C3422A6DB45FC85" italics="true" pageId="null" pageNumber="471">34:</emphasis>
Moffett aus Tischler (1950), Material aus 
<normalizedToken id="B91155C12E947CDE94DE9C4FB20C7C4A" originalValue="Rußland" pageId="null" pageNumber="471">Russland</normalizedToken>
(Gladkova 1968).
</paragraph>
<paragraph id="C91D2B9DD5852F098461D1652DEB39BC" pageId="null" pageNumber="471">
<emphasis id="6A4B3B9AFDBB269FB7A63EADD7C8E058" italics="true" pageId="null" pageNumber="471">Standort.</emphasis>
Kollin und montan. Feuchte bis trockene, humose bis lehmige 
<normalizedToken id="6A6900DCC547AFCE30D1454C23289641" originalValue="Böden" pageId="null" pageNumber="471">Boeden</normalizedToken>
. 
<normalizedToken id="DFA8E8EC64066A2B74CB8BA21CD3B4CC" originalValue="Waldränder" pageId="null" pageNumber="471">Waldraender</normalizedToken>
, Waldlichtungen, Hecken.
</paragraph>
<paragraph id="CC1B8CA5202D0C1FB0AE06F2E7FF28E4" pageId="null" pageNumber="471">
<emphasis id="96359535743AA7A0361AF0FCF91BA540" italics="true" pageId="null" pageNumber="471">
Verbreitung. 
<normalizedToken id="6BE4429BED09E95BD4BE5321068F40CB" originalValue="Europäische" pageId="null" pageNumber="471">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="F1451343A40AFFDA5697BECF990A53C9" originalValue="Nordwärts" pageId="null" pageNumber="471">Nordwaerts</normalizedToken>
bis England, 
<normalizedToken id="0F109E99FEC15441CBC04128FE43668E" originalValue="Südskandinavien" pageId="null" pageNumber="471">Suedskandinavien</normalizedToken>
, Baltikum; Ostgrenze durch 
<normalizedToken id="50204EBF8A24029F61CB9E3F2238CCD5" originalValue="Westrußland" pageId="null" pageNumber="471">Westrussland</normalizedToken>
; 
<normalizedToken id="00D447C85D7C0C0839FA66557C501914" originalValue="südwärts" pageId="null" pageNumber="471">suedwaerts</normalizedToken>
bis 
<normalizedToken id="2E23750F6DC990DB10D585E8CEF6EB4C" originalValue="Pyrenäen" pageId="null" pageNumber="471">Pyrenaeen</normalizedToken>
, Sizilien, Peloponnes, Bulgarien. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet verbreitet und 
<normalizedToken id="B58D679B9FECFDFB90FB8790F185BF3A" originalValue="häufig" pageId="null" pageNumber="471">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
