<taxonomicName id="87E183FBF04DB098069BFDB2ACE75877" authority="L." class="Magnoliopsida" family="Convolvulaceae" genus="Convolvulus" kingdom="Plantae" order="Solanales" pageId="null" pageNumber="44" phylum="Tracheophyta" rank="species" species="arvensis">
