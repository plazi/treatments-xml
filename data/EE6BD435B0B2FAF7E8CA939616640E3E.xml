<subSubSection id="A0EF6C89ED94A19BB1340F2BCDD1B480" pageId="null" pageNumber="44" type="vernacular_names">
<paragraph id="0AFA261FF7D32EF7FFBDF0199EFB405B" pageId="null" pageNumber="44">Acker-Winde</paragraph>
</subSubSection>
</title>
<subSubSection id="ECF4E0B2B033D739C4F467A2C16370E5" pageId="null" pageNumber="44" type="description">
<paragraph id="413E03DA9D57FAC37574813A9A0636B1" pageId="null" pageNumber="44">
Ausdauernd, 
<emphasis id="C9433626169B398DC49F9E0E371515F3" italics="true" pageId="null" pageNumber="44">kurz und flaumig behaart oder kahl</emphasis>
, mit kriechendem Rhizom (bis 2 m tief). 
<emphasis id="7FEA70703221EA35504E6039DC37AF80" italics="true" pageId="null" pageNumber="44">
Stengel 
<normalizedToken id="82E8B709EE2CED3CAECF998C4EC0F772" originalValue="über" pageId="null" pageNumber="44">ueber</normalizedToken>
den Boden ausgebreitet, selten windend
</emphasis>
, bis 1 m lang. 
<emphasis id="917CA7DF334B85763A20FD409CD71F87" italics="true" pageId="null" pageNumber="44">
<normalizedToken id="E2250EF2C1FD4AD28AC03A0CA3FB2B91" originalValue="Blätter" pageId="null" pageNumber="44">Blaetter</normalizedToken>
<normalizedToken id="DC51BCD4FBD800F1D3A390540C78DE81" originalValue="pfeilförmig" pageId="null" pageNumber="44">pfeilfoermig</normalizedToken>
</emphasis>
, bis 4 cm lang, 3-6mal so lang wie der fast parallelrandige Mittelteil; Blattstiel 
<normalizedToken id="3621ECF8BD5F17393803EE8CC8A52EE3" originalValue="kürzer" pageId="null" pageNumber="44">kuerzer</normalizedToken>
als die Spreite. 
<normalizedToken id="11B3A40E2B14DC64C32C1BFA6809B9E1" originalValue="Blüten" pageId="null" pageNumber="44">Blueten</normalizedToken>
einzeln in den Blattachseln oder noch bis 2 weitere und kleinere 
<normalizedToken id="F89690B16969FBA7E1768069B7C1BC17" originalValue="Blüten" pageId="null" pageNumber="44">Blueten</normalizedToken>
in den Achseln von 
<normalizedToken id="FF5F2328B49AADF91912A5843ABDEFD1" originalValue="Vorblättern" pageId="null" pageNumber="44">Vorblaettern</normalizedToken>
. 
<normalizedToken id="EE6FC30532A4261D485CA4E0FDAF5080" originalValue="Blütenstiele" pageId="null" pageNumber="44">Bluetenstiele</normalizedToken>
meist 
<normalizedToken id="087A43C726D92264DECB53FC2BCC2B7A" originalValue="länger" pageId="null" pageNumber="44">laenger</normalizedToken>
als die 
<normalizedToken id="EA54FBF2E3BF3B625CBE25AB92AE165A" originalValue="Blüten" pageId="null" pageNumber="44">Blueten</normalizedToken>
, 
<emphasis id="0B002C27F5417AFDE5BD66B9F4FF5B8A" italics="true" pageId="null" pageNumber="44">
in oder wenig 
<normalizedToken id="9633B62E82630388D7ECB1C5A4B72DD4" originalValue="über" pageId="null" pageNumber="44">ueber</normalizedToken>
der Mitte mit 2 
<normalizedToken id="B69E7E14D2F612E82AC134935F187C01" originalValue="fadenförmigen" pageId="null" pageNumber="44">fadenfoermigen</normalizedToken>
<normalizedToken id="E8BC31AF3B0E79EBCE42A757CDAF8DE0" originalValue="Vorblättern" pageId="null" pageNumber="44">Vorblaettern</normalizedToken>
, die 
<normalizedToken id="9A099D436B1DB43D635CA4BF610AAC42" originalValue="kürzer" pageId="null" pageNumber="44">kuerzer</normalizedToken>
sind als die 
<normalizedToken id="2BC72612490E29C26D1567BC72E7F5C4" originalValue="Kelchblätter" pageId="null" pageNumber="44">Kelchblaetter</normalizedToken>
</emphasis>
. Kelch aus 3 
<normalizedToken id="6BC47E0C03BBC62F89ABD24ABF072A69" originalValue="längeren" pageId="null" pageNumber="44">laengeren</normalizedToken>
und 2 
<normalizedToken id="B8BD25F00789002759DF06B94AF3A870" originalValue="kürzeren" pageId="null" pageNumber="44">kuerzeren</normalizedToken>
, ovalen, bis 5 mm langen 
<normalizedToken id="535BDD8FD8289D407C05CB3EC65C0CDE" originalValue="Kelchblättern" pageId="null" pageNumber="44">Kelchblaettern</normalizedToken>
bestehend. Krone weit 
<normalizedToken id="CFE6B40C989CFCAC679465CA46D7EA9C" originalValue="trichterförmig" pageId="null" pageNumber="44">trichterfoermig</normalizedToken>
, 
<emphasis id="38160436381D7673054D9C67032DD339" italics="true" pageId="null" pageNumber="44">
<normalizedToken id="2FBA4B6DCF88696F97340CA15B827CA2" originalValue="weiß" pageId="null" pageNumber="44">weiss</normalizedToken>
bis rosa
</emphasis>
, 1,5-2,5 cm lang. 
<normalizedToken id="5A15739FB846E683E2FA1ABD0CF8275E" originalValue="Staubfäden" pageId="null" pageNumber="44">Staubfaeden</normalizedToken>
im untern Teil innerseits mit kopfigen 
<normalizedToken id="5119DB574AFF83B3988A4FBCE8A58925" originalValue="Drüsenhaaren" pageId="null" pageNumber="44">Druesenhaaren</normalizedToken>
. Griffel mit 2 
<normalizedToken id="BAEF20EA017AC61F9DD61B71C6F567E2" originalValue="fadenförmigen" pageId="null" pageNumber="44">fadenfoermigen</normalizedToken>
Narben. Fruchtkapsel 
<normalizedToken id="6D7C782EEC79BE0040259628B9D7C174" originalValue="eiförmig" pageId="null" pageNumber="44">eifoermig</normalizedToken>
, 5-8 mm lang. - 
<normalizedToken id="1AB81C670B7AE42B4A6D0BA2B146D4B6" originalValue="Blüte" pageId="null" pageNumber="44">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="B41E423319A404C2A783CF66DF11A0B6" pageId="null" pageNumber="44">
<emphasis id="8E83C7B1D04C0701863118AF27FA770F" italics="true" pageId="null" pageNumber="44">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5314C33174E3AE6EEC6D6A70D97D0ED9" italics="true" pageId="null" pageNumber="44">50:</emphasis>
Material aus Italien (Dolcher und Pignatti 1960), von den Kanarischen Inseln (
<normalizedToken id="F554FB20C52405BA46505A36ACE91D9C" originalValue="Sa’ad" pageId="null" pageNumber="44">Sa'ad</normalizedToken>
1967); weitere 
<normalizedToken id="39564403F9E7002FC4875EE8D996DC43" originalValue="übereinstimmende" pageId="null" pageNumber="44">uebereinstimmende</normalizedToken>
<normalizedToken id="D088BBACA5E702794D48AEAD995E05F6" originalValue="Zählungen" pageId="null" pageNumber="44">Zaehlungen</normalizedToken>
in 
<normalizedToken id="B6C9DB08AB5870135A1F19680BA5CF4D" originalValue="Löve" pageId="null" pageNumber="44">Loeve</normalizedToken>
und 
<normalizedToken id="44B1622960390EBD5C1D3BA7D49B0C5C" originalValue="Löve" pageId="null" pageNumber="44">Loeve</normalizedToken>
(1961).
</paragraph>
<paragraph id="5F2C34713E930DB7271E5BF12F853C76" pageId="null" pageNumber="44">
<emphasis id="47E254F12B2EC2AE7454C2BA6C2A7AAC" italics="true" pageId="null" pageNumber="44">Standort</emphasis>
. Kollin, montan, selten subalpin. Lehmige, 
<normalizedToken id="D505557C7277BA85C33B638BF8C56267" originalValue="nährstoffreiche" pageId="null" pageNumber="44">naehrstoffreiche</normalizedToken>
<normalizedToken id="4278B4EA187D907FBF9C3C092B09CFA7" originalValue="Böden" pageId="null" pageNumber="44">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="617EDB8FFE551A67DA5CE3FBF41C02B7" originalValue="Äcker" pageId="null" pageNumber="44">Aecker</normalizedToken>
, Weinberge, 
<normalizedToken id="A74C9EF2AC55DCBEF22467708CA31774" originalValue="Wegränder" pageId="null" pageNumber="44">Wegraender</normalizedToken>
, lockere Rasen, Ruderalstellen. Sehr 
<normalizedToken id="7E37783345DF6607C02DAAA6EF2DF06B" originalValue="lästiges" pageId="null" pageNumber="44">laestiges</normalizedToken>
Unkraut.
</paragraph>
<paragraph id="4861E2B448BD24BD3CB44559A8A6AE69" pageId="null" pageNumber="44">
<emphasis id="B60BAAFB3F3D879155EAF9931FA38D48" italics="true" pageId="null" pageNumber="44">Verbreitung</emphasis>
. 
<normalizedToken id="6D024FD97992BBF02368A82FF4A48716" originalValue="Ursprünglich" pageId="null" pageNumber="44">Urspruenglich</normalizedToken>
wahrscheinlich 
<emphasis id="81C6FA4A382C2AF8375EEB9686A36EDA" italics="true" pageId="null" pageNumber="44">
<normalizedToken id="EE58FAA46E0BE958CE2F4F7CF88D4C97" originalValue="südeuropäisch-westasiatische" pageId="null" pageNumber="44">suedeuropaeisch-westasiatische</normalizedToken>
Pflanze;
</emphasis>
heute mit Ausnahme der Arktis und Antarktis 
<normalizedToken id="05D92BFE6734AAC0641472994D87A450" originalValue="über" pageId="null" pageNumber="44">ueber</normalizedToken>
die ganze Erde verbreitet. - Im Gebiet verbreitet und 
<normalizedToken id="DF6C18EE2CDE6DE9A7F73DA452FDFA2B" originalValue="häufig" pageId="null" pageNumber="44">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
