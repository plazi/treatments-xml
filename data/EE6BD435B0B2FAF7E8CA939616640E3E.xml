<normalizedToken id="FA97F8C60AB0060971DFF451B90DA62A" originalValue="arvénsis" pageId="null" pageNumber="44">arvensis</normalizedToken>
<authorityName id="DCE5E8EB988D6ED9EE3CC688ABD4B741" pageId="null" pageNumber="44">L.</authorityName>
