<taxonomicName id="DAB3B725F84EB8BF6D3D8A41557889D8" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Rudbeckia" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="515" phylum="Tracheophyta" rank="species" species="hirta">
