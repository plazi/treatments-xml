<taxonomicName authority="Betrem, 1941" authorityName="Betrem" authorityYear="1941" class="Insecta" family="Scoliidae" genus="Sericocampsomeris" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Sericocampsomeris stygia" order="Hymenoptera" pageId="0" pageNumber="125" phylum="Arthropoda" rank="species" species="stygia">
