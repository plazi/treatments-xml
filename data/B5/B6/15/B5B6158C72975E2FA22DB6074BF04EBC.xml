<subSubSection pageId="0" pageNumber="201" type="nomenclature">
<paragraph pageId="0" pageNumber="201">
<taxonomicName LSID="B5B6158C-7297-5E2F-A22D-B6074BF04EBC" authority="Valenciennes, 1842" authorityName="Valenciennes" authorityYear="1842" class="Actinopterygii" family="Cyprinidae" genus="Capoeta" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Capoeta" order="Cypriniformes" pageId="0" pageNumber="201" phylum="Chordata" rank="genus">Capoeta Valenciennes, 1842</taxonomicName>
