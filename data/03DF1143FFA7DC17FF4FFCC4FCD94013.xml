<bibRefCitation id="EFE7DDA4FFA7DC17FED6FC54FE1B47EF" author="Kennel, J." box="[270,417,979,1005]" pageId="9" pageNumber="467" pagination="1 - 546" refId="ref6954" refString="Kennel, J. (1908 - 1921) Die Palaearctischen Tortriciden. Zoologica. Stuttgart, 21 (54), 1 - 546 + 729 - 742, taf. I - XXIV." type="journal article" year="1908">Kennel 1908</bibRefCitation>
