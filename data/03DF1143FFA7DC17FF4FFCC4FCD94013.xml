<taxonomicName id="4C76DBD6FFA7DC17FCDDFC70FCE64013" authorityName="Hubner" authorityYear="1825" box="[773,860,1015,1041]" class="Insecta" family="Tortricidae" genus="Thiodia" kingdom="Animalia" order="Lepidoptera" pageId="9" pageNumber="467" phylum="Arthropoda" rank="genus">
<emphasis id="B9027C47FFA7DC17FCDDFC70FCE64013" box="[773,860,1015,1041]" italics="true" pageId="9" pageNumber="467">Thiodia</emphasis>
