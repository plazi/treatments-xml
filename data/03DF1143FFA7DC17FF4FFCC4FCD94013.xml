<taxonomicName id="4C76DBD6FFA7DC17FEB2FC70FDC34013" authority="Hubner [1825]" authorityName="Hubner" authorityYear="1825" box="[362,633,1014,1041]" class="Insecta" family="Tortricidae" genus="Epinotia" kingdom="Animalia" order="Lepidoptera" pageId="9" pageNumber="467" phylum="Arthropoda" rank="genus">
