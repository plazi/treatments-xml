<bibRefCitation id="EFE7DDA4FFA7DC17FDF7FC54FCA247EF" author="Klimesch, J." box="[559,792,979,1005]" pageId="9" pageNumber="467" pagination="297 - 322" refId="ref7122" refString="Klimesch, J. (1987) Beitrage zur Kenntnis der Microlepidopteren-Fauna des Kanarischen Archipels. 9 Beitrag: Tortricidae, Cochylidae. Vieraea, 17, 297 - 322." type="journal article" year="1987">Klimesch 1987: 303</bibRefCitation>
, figs 26, 27, 28; 
<bibRefCitation id="EFE7DDA4FFA7DC17FC01FC54FB2947EF" author="Lepiforum" box="[985,1171,979,1005]" pageId="9" pageNumber="467" refId="ref7453" refString="Lepiforum (2022) Genus Thiodia Hubner [1825]. Available from: http // www. lepiforum. de (accessed 9 February 2022)" type="book" year="2022">Lepiforum 2022</bibRefCitation>
