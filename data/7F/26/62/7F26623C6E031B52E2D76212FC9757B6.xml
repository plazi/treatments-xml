<subSubSection box="[100,683,562,595]" pageId="8" pageNumber="74" type="activity">
<paragraph blockId="8.[99,1307,288,914]" box="[100,683,562,595]" pageId="8" pageNumber="74">
<emphasis bold="true" box="[100,334,562,595]" pageId="8" pageNumber="74">Activity patterns.</emphasis>
