</paragraph>
</subSubSection>
<subSubSection pageId="8" pageNumber="74" type="biology_ecology">
<paragraph blockId="8.[1362,2568,2416,3195]" pageId="8" pageNumber="74">
<emphasis bold="true" box="[1363,2071,2931,2960]" pageId="8" pageNumber="74">Movements, Home range and Social organization.</emphasis>
