</paragraph>
</subSubSection>
<subSubSection box="[1362,1945,2886,2919]" pageId="8" pageNumber="74" type="activity">
<paragraph blockId="8.[1362,2568,2416,3195]" box="[1362,1945,2886,2919]" pageId="8" pageNumber="74">
<emphasis bold="true" box="[1362,1596,2886,2919]" pageId="8" pageNumber="74">Activity patterns.</emphasis>
