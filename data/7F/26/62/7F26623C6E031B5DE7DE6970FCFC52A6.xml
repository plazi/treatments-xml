</paragraph>
</subSubSection>
<subSubSection box="[163,747,1266,1299]" pageId="7" pageNumber="73" type="activity">
<paragraph blockId="7.[163,1371,873,1693]" box="[163,747,1266,1299]" pageId="7" pageNumber="73">
<emphasis bold="true" box="[163,397,1266,1299]" pageId="7" pageNumber="73">Activity patterns.</emphasis>
