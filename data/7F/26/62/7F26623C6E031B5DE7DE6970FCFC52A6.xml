</paragraph>
</subSubSection>
<subSubSection pageId="7" pageNumber="73" type="biology_ecology">
<paragraph blockId="7.[163,1371,873,1693]" pageId="7" pageNumber="73">
<emphasis bold="true" box="[164,873,1306,1339]" pageId="7" pageNumber="73">Movements, Home range and Social organization.</emphasis>
