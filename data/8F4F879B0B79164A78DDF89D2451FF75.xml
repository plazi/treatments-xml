<taxonomicName id="C0E64D0E0B7A164B7963F84226A2F83C" authorityName="Krapovickas &amp; Bueno" authorityYear="2014" box="[310,504,1920,1941]" class="Magnoliopsida" family="Malvaceae" genus="Sida" kingdom="Plantae" order="Malvales" pageId="10" pageNumber="115" phylum="Tracheophyta" rank="species" species="farroupilhensis">
