<emphasis id="3592EA9F0B7A164B7B74F8662411F813" bold="true" box="[801,843,1956,1978]" pageId="10" pageNumber="115">G–J</emphasis>
<taxonomicName id="C0E64D0E0B7A164B7B07F866248AF810" box="[850,976,1956,1977]" class="Magnoliopsida" family="Malvaceae" genus="Sida" kingdom="Plantae" order="Malvales" pageId="10" pageNumber="115" phylum="Tracheophyta" rank="species" species="linifolia">
