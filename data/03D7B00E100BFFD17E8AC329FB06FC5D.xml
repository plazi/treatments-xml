Principal component analyses of morphometric data of 
<taxonomicName id="4C7E7A9B100AFFD77E64C6EEFC01FC42" box="[852,965,933,955]" class="Insecta" family="Formicidae" genus="Colobopsis" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="11" pageNumber="1435" phylum="Arthropoda" rank="genus">
