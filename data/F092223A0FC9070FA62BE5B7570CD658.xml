<subSubSection id="70ED7CE9793AD9896A5AF30B42F2E295" pageId="null" pageNumber="791" type="description">
<paragraph id="633F3061A1D6AEB790BA25204875FE66" pageId="null" pageNumber="791">
1 
<normalizedToken id="78841B9BEA0C4176C40FC5E85F104FD0" originalValue="jährig" pageId="null" pageNumber="791">jaehrig</normalizedToken>
, mit 
<normalizedToken id="6FB77214BEE46959D1200FF507B73E26" originalValue="dünner" pageId="null" pageNumber="791">duenner</normalizedToken>
Pfahlwurzel; 30-60 cm hoch; kahl, 
<normalizedToken id="7C57A64A03553B8F11520248E1B3B10D" originalValue="bläulich" pageId="null" pageNumber="791">blaeulich</normalizedToken>
bereift. Stengel aufrecht, im obern Teil verzweigt. 
<normalizedToken id="D61A9642B630BDC70C944907EB840CA8" originalValue="Blätter" pageId="null" pageNumber="791">Blaetter</normalizedToken>
lanzettlich (die obern am Grunde etwas 
<normalizedToken id="B8C5314979C6A6220C9A0DA462FE039C" originalValue="herzförmig" pageId="null" pageNumber="791">herzfoermig</normalizedToken>
), bis 10 cm lang, 
<emphasis id="9C6A8CD7BA85D5E18247E05D5B62D5CA" italics="true" pageId="null" pageNumber="791">2</emphasis>
<normalizedToken id="895C78A9DF0580CAAD466B7261ABDAC9" originalValue="½" pageId="null" pageNumber="791">1/2</normalizedToken>
<emphasis id="AE9DC488013F7F6D2D20A67BB0544773" italics="true" pageId="null" pageNumber="791">-6mal so lang wie breit.</emphasis>
<normalizedToken id="CC9B94462DEA1EC2024ECEB08534F620" originalValue="Blüten" pageId="null" pageNumber="791">Blueten</normalizedToken>
in lockeren, rispenartigen 
<normalizedToken id="997850EE0C33DBCE0D267F2125549950" originalValue="Blütenständen" pageId="null" pageNumber="791">Bluetenstaenden</normalizedToken>
. Kelch 12-17 mm lang, kahl; 
<normalizedToken id="FF2F00311D50DE424796E215FBCD28ED" originalValue="Kelchzähne" pageId="null" pageNumber="791">Kelchzaehne</normalizedToken>
<normalizedToken id="F7620D8378A7B144CE0D1B2A0A128A5C" originalValue="¼" pageId="null" pageNumber="791">1/4</normalizedToken>
-⅓ so lang wie der verwachsene Kelchteil. 
<normalizedToken id="D397DA81067AADDC4B04B7DD91376C08" originalValue="Kronblätter" pageId="null" pageNumber="791">Kronblaetter</normalizedToken>
16-20 mm lang, rosa, am stielartig 
<normalizedToken id="F429BE85C062C6AA80082A9075150D29" originalValue="verschmälerten" pageId="null" pageNumber="791">verschmaelerten</normalizedToken>
Teil (Nagel) mit 2 
<normalizedToken id="4B4877896C06E8E4764212465B6332DF" originalValue="häutigen" pageId="null" pageNumber="791">haeutigen</normalizedToken>
<normalizedToken id="8CB970BE99CBF2C257C55796F223DBF2" originalValue="Flügelleisten" pageId="null" pageNumber="791">Fluegelleisten</normalizedToken>
. Kapsel etwa 10 mm lang. Samen 1,8-2,5 mm lang. - 
<normalizedToken id="963EAD716E7D53D51238F5A419EE5CC9" originalValue="Blüte" pageId="null" pageNumber="791">Bluete</normalizedToken>
: 
<normalizedToken id="6FCE992FE420C7F7AA9B9C0FEA0C6D6B" originalValue="Früher" pageId="null" pageNumber="791">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="3E077834BB7241BD99353524A5695B99" pageId="null" pageNumber="791">
<emphasis id="A48EB5A04CC305AF9BF7C1D4C0BA0357" italics="true" pageId="null" pageNumber="791">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="6137D6FFC4352BAA2CD5EB2C0B7E6876" italics="true" pageId="null" pageNumber="791">30:</emphasis>
Material aus England (Blackburn 1928), ohne Herkunftsangabe (D. 
<normalizedToken id="5C286F111A90381E30F21F55E6A0CBE7" originalValue="Löve" pageId="null" pageNumber="791">Loeve</normalizedToken>
1942), aus Neuenburg (Favarger 1946). Favarger (1946) 
<normalizedToken id="046103F6491D4325848F0E5F34E4DFFA" originalValue="zählte" pageId="null" pageNumber="791">zaehlte</normalizedToken>
in Mitosen an den gleichen Pflanzen neben 2n = 30 auch 2n = 60.
</paragraph>
<paragraph id="93557F13CC582F97BF21E1505A754ED1" pageId="null" pageNumber="791">
<emphasis id="BD7367618660C89EEA02944A32271E91" italics="true" pageId="null" pageNumber="791">Standort.</emphasis>
Kollin und montan, selten subalpin (adventiv). Trockene, offene, kalkreiche 
<normalizedToken id="68D9D90077613868EB9772B1584D9F3A" originalValue="Böden" pageId="null" pageNumber="791">Boeden</normalizedToken>
in warmen Lagen. Getreidefelder, 
<normalizedToken id="3E8EE7338F842EF517EED2B28C43761C" originalValue="Schuttplätze" pageId="null" pageNumber="791">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="4DF3D82013013C37AF1BD38D32F80B57" pageId="null" pageNumber="791">
<emphasis id="85557401A66754EC10E71083361915DD" italics="true" pageId="null" pageNumber="791">
<pageBreakToken id="75C573A41E4B35E61492F04B94C242DD" pageId="null" pageNumber="791">Verbreitung</pageBreakToken>
. Mediterrane Pflanze:
</emphasis>
<normalizedToken id="B3AAF4529AD15DB742B8776BFBB1FDA0" originalValue="Südeuropa" pageId="null" pageNumber="791">Suedeuropa</normalizedToken>
(
<normalizedToken id="28AAB9944CD5A0F5A69F49E8A4812D2A" originalValue="nordwärts" pageId="null" pageNumber="791">nordwaerts</normalizedToken>
vereinzelt bis Belgien, Mitteldeutschland, 
<normalizedToken id="D6E1EF5D7FA4F17B8B7BD70F8C54552F" originalValue="Mittelrußland" pageId="null" pageNumber="791">Mittelrussland</normalizedToken>
); 
<normalizedToken id="E08511972788CD6CC1738065CBF7E83A" originalValue="Südwestasien" pageId="null" pageNumber="791">Suedwestasien</normalizedToken>
(
<normalizedToken id="226898204298EEDBF566EAED7C75C104" originalValue="ostwärts" pageId="null" pageNumber="791">ostwaerts</normalizedToken>
bis Nordindien); Nordwestafrika; in Nordamerika, Australien und Neuseeland eingeschleppt. - Im Gebiet sehr zerstreut (besonders im 
<normalizedToken id="530108A2CE8D414C3DD490591C89A960" originalValue="Süden" pageId="null" pageNumber="791">Sueden</normalizedToken>
), selten und oft 
<normalizedToken id="62E219E8F392D68C3E4C13DBDC7A8D42" originalValue="unbeständig" pageId="null" pageNumber="791">unbestaendig</normalizedToken>
; in neuerer Zeit seltener geworden.
</paragraph>
<paragraph id="CEC9A68C494C907E2A59D4A08F4A78BC" pageId="null" pageNumber="791">
<emphasis id="AEB74730C88D79E47FCEB62F4148C7F4" italics="true" pageId="null" pageNumber="791">Bemerkungen.</emphasis>
Rauschert (1966) verwendet den Namen 
<taxonomicName id="90AF8E86117A544687D71D389D5B007D" authority="(Mill.) Rauschert." authorityName="Rauschert." baseAuthorityName="Mill." class="Magnoliopsida" family="Caryophyllaceae" genus="Vaccaria" higherTaxonomySource="GBIF" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="791" phylum="Tracheophyta" rank="species" species="hispanica">
<emphasis id="99150BEE2B0FB5728D48AD895BB1A389" italics="true" pageId="null" pageNumber="791">V. hispanica</emphasis>
(Mill.) Rauschert.
</taxonomicName>
</paragraph>
</subSubSection>
