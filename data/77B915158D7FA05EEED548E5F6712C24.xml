<paragraph id="4957EFCF3A7E3B1D72947A9648A473DE" pageId="null" pageNumber="319">
Japanisches 
<normalizedToken id="3B395E599D9A6E331C6D60BC5FFCFCF3" originalValue="Geißblatt" pageId="null" pageNumber="319">Geissblatt</normalizedToken>
</paragraph>
