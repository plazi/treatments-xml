<subSubSection id="CA36AFD6EA06FEFD5963B2065D255D03" pageId="null" pageNumber="378" type="description">
<paragraph id="D6957C97C02D7E52A6A5043F9660B2F6" pageId="null" pageNumber="378">
<emphasis id="BECCE60AA6E82C5833006D7BD76622CD" italics="true" pageId="null" pageNumber="378">
Pflanze 20-40 cm hoch. 
<normalizedToken id="507C3C3D94F179D9F18A2EB2D6E3D71A" originalValue="Teilblätter" pageId="null" pageNumber="378">Teilblaetter</normalizedToken>
der 
<normalizedToken id="D58564ED903D09F60A0C2A5E74B4C781" originalValue="grundständigen" pageId="null" pageNumber="378">grundstaendigen</normalizedToken>
<normalizedToken id="A35DDAD42B24D360616D46B7D16D6BD0" originalValue="Blätter" pageId="null" pageNumber="378">Blaetter</normalizedToken>
4-10 cm lang
</emphasis>
, etwa 
<normalizedToken id="60A08DAF5AD730577F18E3E02B3640D3" originalValue="1½" pageId="null" pageNumber="378">11/2</normalizedToken>
mal so lang wie breit, beiderseits 
<normalizedToken id="CE2C55060B944176C957D85472268FF6" originalValue="grün" pageId="null" pageNumber="378">gruen</normalizedToken>
, locker behaart oder unterseits silberig 
<normalizedToken id="647C0A332C52D3708A0BAC01EF623B18" originalValue="glänzend" pageId="null" pageNumber="378">glaenzend</normalizedToken>
, anliegend und dicht behaart. Blattstiele und Stengel dicht und senkrecht bis 
<normalizedToken id="C128C834A8E80C2B4C2898EEABB06607" originalValue="rückwärts" pageId="null" pageNumber="378">rueckwaerts</normalizedToken>
abstehend behaart. 
<emphasis id="B3C04237EED47FFDE9DA2E577B43B792" italics="true" pageId="null" pageNumber="378">
<normalizedToken id="B4589BFB263FF3F2124B518AB5F0942F" originalValue="Blütenstand" pageId="null" pageNumber="378">Bluetenstand</normalizedToken>
8-15 
<normalizedToken id="B181B1683DCEFE472566BE06AC0F248C" originalValue="blütig" pageId="null" pageNumber="378">bluetig</normalizedToken>
. 
<normalizedToken id="6E8F450D4563EA9B030F14A7D9B332A6" originalValue="Blütenstiele" pageId="null" pageNumber="378">Bluetenstiele</normalizedToken>
senkrecht abstehend behaart; oft auch zahlreiche Haare 
<normalizedToken id="1E571F4E58E1C37BD2A1FFCBB30FE82E" originalValue="rückwärts" pageId="null" pageNumber="378">rueckwaerts</normalizedToken>
gerichtet.
</emphasis>
<normalizedToken id="81D6C27D89922741D6C2F0CCA61D414C" originalValue="Außenkelchblätter" pageId="null" pageNumber="378">Aussenkelchblaetter</normalizedToken>
schmal lanzettlich; 
<normalizedToken id="9562FA2AC9CB9A7B18D1813C96E49722" originalValue="Kelchblätter" pageId="null" pageNumber="378">Kelchblaetter</normalizedToken>
von der 
<normalizedToken id="C2533664DBD95E42167590B0ACF8FD89" originalValue="«Beere»" pageId="null" pageNumber="378">&quot;Beere&quot;</normalizedToken>
senkrecht abstehend oder 
<normalizedToken id="9E4F55AEAA6E6D3CA31CCE1EC2134FF2" originalValue="zurückgebogen" pageId="null" pageNumber="378">zurueckgebogen</normalizedToken>
. 
<emphasis id="7C9E3AEF3E02263ADE797A0422CDB16F" italics="true" pageId="null" pageNumber="378">
<normalizedToken id="793F4E9BB7EC579F7839D4E89BEFF433" originalValue="Blütendurchmesser" pageId="null" pageNumber="378">Bluetendurchmesser</normalizedToken>
1,5-2,5 cm.
</emphasis>
<normalizedToken id="308DD4D2591DD3057891DBEAFFD5D529" originalValue="Kronblätter" pageId="null" pageNumber="378">Kronblaetter</normalizedToken>
<normalizedToken id="09B8D4469FD16CD76C5AAB6968D7386A" originalValue="weiß" pageId="null" pageNumber="378">weiss</normalizedToken>
. 
<normalizedToken id="D5712418F4924FC322D31E097EC09BA2" originalValue="«Beeren»" pageId="null" pageNumber="378">&quot;Beeren&quot;</normalizedToken>
in 
<normalizedToken id="857318FE345AD84C224D048BEEBDC3C0" originalValue="Größe" pageId="null" pageNumber="378">Groesse</normalizedToken>
, Form und Farbe wie bei 
<taxonomicName id="ECCF3463A2CFC0DA9846A147164C4377" class="Magnoliopsida" family="Rosaceae" genus="Fragaria" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="378" phylum="Tracheophyta" rank="species" species="viridis">
<emphasis id="CC322A5874C54304D0CDE8439B11D870" italics="true" pageId="null" pageNumber="378">F. viridis</emphasis>
</taxonomicName>
(Nr. 1), jedoch 
<emphasis id="E8828D83308BF707302863284AB0C52C" italics="true" pageId="null" pageNumber="378">weich</emphasis>
, 
<normalizedToken id="8D7E725D96BEA694410A7E9F26F23E01" originalValue="Früchtchen" pageId="null" pageNumber="378">Fruechtchen</normalizedToken>
nicht in Gruben eingesenkt. - 
<normalizedToken id="A957657AA394FC6EA8F174CFF3E3B7A5" originalValue="Blüte" pageId="null" pageNumber="378">Bluete</normalizedToken>
: 
<normalizedToken id="A15A229E7DDEF68CBB5FFEFDF6BB663E" originalValue="Frühling" pageId="null" pageNumber="378">Fruehling</normalizedToken>
und 
<normalizedToken id="1B2194E1D63B44A8F40976A3D5AA83E2" originalValue="früher" pageId="null" pageNumber="378">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="38F1CA2A4E384973D744145FB1E305F9" pageId="null" pageNumber="378">
<emphasis id="3335AEB1FC4F48E1972E899EA68540FF" italics="true" pageId="null" pageNumber="378">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="CC30976A07066A3B637147EAD02E9A85" italics="true" pageId="null" pageNumber="378">42:</emphasis>
Zahlreiche 
<normalizedToken id="D667DC6F9EAC98EE78916734E269D179" originalValue="übereinstimmende" pageId="null" pageNumber="378">uebereinstimmende</normalizedToken>
<normalizedToken id="E95706DF525CFB42DB30428419349508" originalValue="Zählungen" pageId="null" pageNumber="378">Zaehlungen</normalizedToken>
(vgl. 
<normalizedToken id="6B735FBEDA5EAA722AA790EA06531AB7" originalValue="Löve" pageId="null" pageNumber="378">Loeve</normalizedToken>
und 
<normalizedToken id="4B82FFC7F6FA93D21DECF69B533C247A" originalValue="Löve" pageId="null" pageNumber="378">Loeve</normalizedToken>
1961); 22 Proben aus Europa (Staudt 1962). Einzige bisher bekannte Art mit dieser Chromosomenzahl; durch Autopolyploidie aus dem 
<taxonomicName id="1EDCDA53F05CEEFB0CABC88C11AE6FD7" class="Magnoliopsida" family="Rosaceae" genus="Fragaria" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="378" phylum="Tracheophyta" rank="species" species="vesca">
<emphasis id="DD1D9FA3992B81275DED03099E6BD77C" italics="true" pageId="null" pageNumber="378">F. vesca</emphasis>
</taxonomicName>
-Gcnom entstanden (Lilienfeld 1933, Schiemann 1944). Nach papierchromatographischen 
<pageBreakToken id="1D42BD5072D1FA32D4D842046A8888BD" pageId="null" pageNumber="378">Untersuchungen</pageBreakToken>
von Bringhurst et al. (1966) sollen an der Entstehung von 
<emphasis id="8B5735A1B7BD13F97B4AE02539498EE7" italics="true" pageId="null" pageNumber="378">F. moschetta F. virdis</emphasis>
und 
<taxonomicName id="492581019CFDC0FE59593FDB819F9E68" class="Magnoliopsida" family="Rosaceae" genus="Fragaria" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="378" phylum="Tracheophyta" rank="species" species="vesca">
<emphasis id="0F7F2EEC120BA3894010A7EEAB937A23" italics="true" pageId="null" pageNumber="378">F. vesca</emphasis>
</taxonomicName>
beteiligt sein.
</paragraph>
<paragraph id="312585F9A2A73AB9ACE00B58D347858B" pageId="null" pageNumber="378">
<emphasis id="135BF4DFE418AF33329D8A6294681643" italics="true" pageId="null" pageNumber="378">Standort.</emphasis>
Kollin, seltener montan. Frische, 
<normalizedToken id="4BACC09B0429ED62E405794B221AE06B" originalValue="nährstoffreiche" pageId="null" pageNumber="378">naehrstoffreiche</normalizedToken>
, humose, oft lehmige 
<normalizedToken id="5571FE1CA5C4C782F32C3EF798CC68E0" originalValue="Böden" pageId="null" pageNumber="378">Boeden</normalizedToken>
. 
<normalizedToken id="BD17900534052DD418456C710882C0FD" originalValue="Eichenmischwälder" pageId="null" pageNumber="378">Eichenmischwaelder</normalizedToken>
, 
<normalizedToken id="B24593883A1027CC599C04342F73EFBF" originalValue="Auenwälder" pageId="null" pageNumber="378">Auenwaelder</normalizedToken>
.
</paragraph>
<paragraph id="2D4961571B1E1D037DC606873E15544B" pageId="null" pageNumber="378">
<emphasis id="37880A29BB7A294EC85FFE7246EFFE37" italics="true" pageId="null" pageNumber="378">
Verbreitung. 
<normalizedToken id="71B900684872AB3AA0C278FA2DC9701F" originalValue="Europäische" pageId="null" pageNumber="378">Europaeische</normalizedToken>
Pflanze:
</emphasis>
Nordgrenze durch Schottland, 
<normalizedToken id="A64172E95265F8CE69AB06C20324815A" originalValue="Südskandinavien" pageId="null" pageNumber="378">Suedskandinavien</normalizedToken>
, Finnland, 
<normalizedToken id="10EFB6DAD9792A5F1FADA63CB9F51BEA" originalValue="ostwärts" pageId="null" pageNumber="378">ostwaerts</normalizedToken>
bis in den Ural; im 
<normalizedToken id="08E3013DC2A337C14BD73AF50F1E63E5" originalValue="Süden" pageId="null" pageNumber="378">Sueden</normalizedToken>
durch das Mediterrangebiet 
<normalizedToken id="E4799A96680E383B770E04C14B2B6DFE" originalValue="ostwärts" pageId="null" pageNumber="378">ostwaerts</normalizedToken>
bis zum Kaukasus. - Im Gebiet verbreitet, nicht 
<normalizedToken id="425EA9B19D0671F391E9DFC340300AF2" originalValue="häufig" pageId="null" pageNumber="378">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
