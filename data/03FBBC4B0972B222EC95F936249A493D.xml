<emphasis id="B926D14F0972B22CEC95F88D21294D42" bold="true" box="[151,290,1873,1899]" pageId="38" pageNumber="489">Etymology:</emphasis>
<taxonomicName id="4C5276DE0972B22CED28F88C22014D43" authority=": Latin" authorityName="Latin" box="[298,522,1872,1899]" class="Actinopterygii" family="Cichlidae" genus="Oreochromis" kingdom="Animalia" order="Perciformes" pageId="38" pageNumber="489" phylum="Chordata" rank="genus">
