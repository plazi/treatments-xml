<taxonomicName id="4C096BDAFFC5FFA0631AFE61C79DFE54" authorityName="Brtsch" authorityYear="1977" box="[605,710,439,465]" class="Arachnida" family="Halacaridae" genus="Rhombognathus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trombidiformes" pageId="9" pageNumber="310" phylum="Arthropoda" rank="species" species="similis">
