<taxonomicName id="4C096BDAFFC5FFA06374FE45C7A5FE29" box="[563,766,403,429]" class="Ulvophyceae" family="Halimedaceae" genus="Halimeda" kingdom="Plantae" order="Bryopsidales" pageId="9" pageNumber="310" phylum="Chlorophyta" rank="species" species="opuntia">
