<treatmentCitation id="EF1C4072F066FFCB075628E1FAF9CBD0" author="Forattini, O. P. &amp; Sallum, M. A. M." box="[1091,1404,1939,1963]" page="207" pageId="1" pageNumber="296" year="1989">
