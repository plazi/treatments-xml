<subSubSection id="3CB11296BF6A382DFDA0C38927ECC90A" pageId="null" pageNumber="163" type="vernacular_names">
<paragraph id="5AEF473A7B53F6F4C7EB75260E901966" pageId="null" pageNumber="163">Kartoffel</paragraph>
</subSubSection>
</title>
<subSubSection id="79FA721F9B14897C9B479C5B135A0650" pageId="null" pageNumber="163" type="description">
<paragraph id="6B95C3AFF333E0EC89792D22D0524FD1" pageId="null" pageNumber="163">
1 
<normalizedToken id="D0924D5B279B416D6E23D53425208882" originalValue="jährig" pageId="null" pageNumber="163">jaehrig</normalizedToken>
, aber mit 
<emphasis id="37FDF115F518893B1925AD01A49461F9" italics="true" pageId="null" pageNumber="163">zahlreichen unterirdischen Knollen</emphasis>
(die andern Arten im Gebiet ohne Knollen!); 40-80 cm hoch. Stengel aufrecht, oben kantig, verzweigt, zerstreut und anliegend behaart bis 
<pageBreakToken id="E725A6B3A6546C0EFA5E52EB347C6695" pageId="null" pageNumber="163">fast</pageBreakToken>
kahl. 
<normalizedToken id="F5357D86582F7508B9FD9B4BC50BA40B" originalValue="Blätter" pageId="null" pageNumber="163">Blaetter</normalizedToken>
im 
<normalizedToken id="504B6ADEAE52F59387FB0E0B96872228" originalValue="Umriß" pageId="null" pageNumber="163">Umriss</normalizedToken>
oval, 
<emphasis id="5526A851FE3FA3F0F48300BFFD0421BD" italics="true" pageId="null" pageNumber="163">
<normalizedToken id="DDE71EE9C4609056D2533AA0F34B07AA" originalValue="unregelmäßig" pageId="null" pageNumber="163">unregelmaessig</normalizedToken>
gefiedert
</emphasis>
, gestielt, besonders unterseits behaart; 
<emphasis id="0F871E9B6BC143E3FB5EB5CE174F8870" italics="true" pageId="null" pageNumber="163">
<normalizedToken id="B8EA6BAC0E7D50D0CF403FA9DBB920C6" originalValue="Teilblätter" pageId="null" pageNumber="163">Teilblaetter</normalizedToken>
oval bis breit lanzettlich, meist ganzrandig
</emphasis>
, 
<normalizedToken id="C9C07DE0DA0C5785EA437046D37A281C" originalValue="größere" pageId="null" pageNumber="163">groessere</normalizedToken>
und kleinere abwechselnd. Krone im Durchmesser 2-3 cm, 
<emphasis id="4297A79C2FF788A3E309AF30FD6AD20A" italics="true" pageId="null" pageNumber="163">
<normalizedToken id="02CABD58709CF812D41AC215DF5D4401" originalValue="weiß" pageId="null" pageNumber="163">weiss</normalizedToken>
, violett oder 
<normalizedToken id="0438C0069B16A99E15F3AFFF113B7CDB" originalValue="rötlich" pageId="null" pageNumber="163">roetlich</normalizedToken>
</emphasis>
, 
<normalizedToken id="E7F3FF4992621BC9D5489A3891FF2C12" originalValue="außen" pageId="null" pageNumber="163">aussen</normalizedToken>
und besonders am Rande kurz behaart. Frucht kugelig, etwa 2 cm im Durchmesser, 
<emphasis id="324022ABE55D39C920948A04E1B5BEAB" italics="true" pageId="null" pageNumber="163">
<normalizedToken id="37A78B2C6C3309DC9F3C18C964CCD837" originalValue="gelbgrün" pageId="null" pageNumber="163">gelbgruen</normalizedToken>
</emphasis>
. - 
<normalizedToken id="87EA88C3EB5C217563CE46500656266D" originalValue="Blüte" pageId="null" pageNumber="163">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="9720F1CA3141E4DE3227C735681FFE3B" pageId="null" pageNumber="163">
<emphasis id="8048C45ED119DC51218793BC309C7954" italics="true" pageId="null" pageNumber="163">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="00149C2CB2B0F4B8B9E885913023DB96" italics="true" pageId="null" pageNumber="163">48:</emphasis>
Material aus Kulturen (Gottschalk 1954, Baquar 1967, Wangenheim et al. 1957, dort auch eine 
<normalizedToken id="31C6F1322C0D567E8B0E613527F6DFD5" originalValue="Übersicht" pageId="null" pageNumber="163">Uebersicht</normalizedToken>
<normalizedToken id="2B4F46793F3D9928C331BE19F7052BE6" originalValue="über" pageId="null" pageNumber="163">ueber</normalizedToken>
die umfangreiche zytologische Literatur).
</paragraph>
<paragraph id="511FA9C5E3B17EAD7A3ADEABD17C93EA" pageId="null" pageNumber="163">
<emphasis id="1D4327B7F7F30DB73DDFAFD1F178053E" italics="true" pageId="null" pageNumber="163">Standort</emphasis>
. Kollin, montan, selten subalpin. Frische, lockere, 
<normalizedToken id="20CC21FD95A2D63FEA38D5A1E081E999" originalValue="nährstoffreiche" pageId="null" pageNumber="163">naehrstoffreiche</normalizedToken>
<normalizedToken id="3994C76906FC6840017FE14512969329" originalValue="Böden" pageId="null" pageNumber="163">Boeden</normalizedToken>
. 
<normalizedToken id="51E2481A8A5E886785148A620CF9CAC3" originalValue="Äcker" pageId="null" pageNumber="163">Aecker</normalizedToken>
, 
<normalizedToken id="8288C21965857AF6C9100C73BC07E97D" originalValue="Schuttplätze" pageId="null" pageNumber="163">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="1B654D098786D153DAEA96E0ECB1FF36" pageId="null" pageNumber="163">
<emphasis id="E97DFDC61DAE82E9DAF714D8178967EF" italics="true" pageId="null" pageNumber="163">Verbreitung</emphasis>
. 
<normalizedToken id="0D0E35260CCABE5617D9702BCC5BD9FC" originalValue="Ursprünglich" pageId="null" pageNumber="163">Urspruenglich</normalizedToken>
<emphasis id="D5450F2C3599CC16D21FD8A116C86764" italics="true" pageId="null" pageNumber="163">
<normalizedToken id="62895259C85190194D9F879B257024FA" originalValue="südamerikanische" pageId="null" pageNumber="163">suedamerikanische</normalizedToken>
Pflanze
</emphasis>
(Bolivien, nordwestliches Argentinien), heute auf der ganzen Welt kultiviert (ausgenommen kalte und 
<normalizedToken id="437DD0FDB084B3FB3D5BEDFA56842A10" originalValue="heiße" pageId="null" pageNumber="163">heisse</normalizedToken>
Zonen). - Im Gebiet 
<normalizedToken id="DC23C8A04FCB47CEA5F1388E8DE363C6" originalValue="häufig" pageId="null" pageNumber="163">haeufig</normalizedToken>
kultiviert und nur selten verwildert.
</paragraph>
<paragraph id="29D46DF65300B3A809ED9D8D62134753" pageId="null" pageNumber="163">
<emphasis id="61EB7DF26B032868127DF3DA3EAEC6CE" italics="true" pageId="null" pageNumber="163">Bemerkungen</emphasis>
. Die Kartoffel ist heute eine unserer wichtigsten Kulturpflanzen. Gegen Ende des 16. Jahrhunderts wurde sie aus Amerika in Europa 
<normalizedToken id="FC4F5EDB17315A5DEE50AB1814320C5C" originalValue="eingeführt" pageId="null" pageNumber="163">eingefuehrt</normalizedToken>
. In der Schweiz begann der 
<normalizedToken id="F64F16917D1934D44FB059D38E2A67BA" originalValue="großflächige" pageId="null" pageNumber="163">grossflaechige</normalizedToken>
Anbau erst gegen Ende des 18. Jahrhunderts.
</paragraph>
<paragraph id="7D711D547E2961A34A26BD31122E8A90" pageId="null" pageNumber="163">
<taxonomicName id="BD21DEB9D93EF43D4F1D3404FB41A811" class="Magnoliopsida" family="Solanaceae" genus="Solanum" kingdom="Plantae" order="Solanales" pageId="null" pageNumber="163" phylum="Tracheophyta" rank="species" species="tuberosum">
<emphasis id="3D688CB02B5B43F1306975289E5F4CB4" italics="true" pageId="null" pageNumber="163">S. tuberosum</emphasis>
</taxonomicName>
, heute in zahlreichen Kultursorten angebaut, ist wahrscheinlich ein polyploider Bastard einiger nahe verwandter Wildarten aus 
<normalizedToken id="1C1BC2B5100D054D5EA67F82A675CB2B" originalValue="Südamerika" pageId="null" pageNumber="163">Suedamerika</normalizedToken>
(Wangenheim et al. 1957, vgl. auch Maroon et al. 1962). 
<taxonomicName id="6D2359917716FED290C688103EF3EBD9" class="Magnoliopsida" family="Solanaceae" genus="Solanum" kingdom="Plantae" order="Solanales" pageId="null" pageNumber="163" phylum="Tracheophyta" rank="species" species="tuberosum">
<emphasis id="39D0B658827C4973A154F8E455B82460" italics="true" pageId="null" pageNumber="163">S. tuberosum</emphasis>
</taxonomicName>
bildet mit gegen 100 nahe verwandten 
<normalizedToken id="EA5ED170E51FE98AB53269ECF614FD15" originalValue="südamerikanischen" pageId="null" pageNumber="163">suedamerikanischen</normalizedToken>
Arten eine komplizierte Gruppe mit polyploiden Reihen und zahlreichen Bastarden. 
<normalizedToken id="60132CDBC756B133AEE3DAE76016727A" originalValue="Über" pageId="null" pageNumber="163">Ueber</normalizedToken>
die Abstammung vgl. 
<normalizedToken id="A9A6F312AC58C94988AA5BFA086010F3" originalValue="Brücher" pageId="null" pageNumber="163">Bruecher</normalizedToken>
(1958) und Correll (1962), 
<normalizedToken id="06D4821FB052F2706F01C0A81E3B4170" originalValue="über" pageId="null" pageNumber="163">ueber</normalizedToken>
die systematische Unterteilung vgl. Danert (1956).
</paragraph>
</subSubSection>
