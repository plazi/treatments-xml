<paragraph id="00DFD46E530BE99C3194A0C7F4A597CD" pageId="null" pageNumber="163">
<taxonomicName id="923081D5CBA28839458277BD7B660DD3" authority="L." class="Magnoliopsida" family="Solanaceae" genus="Solanum" kingdom="Plantae" order="Solanales" pageId="null" pageNumber="163" phylum="Tracheophyta" rank="species" species="tuberosum">
