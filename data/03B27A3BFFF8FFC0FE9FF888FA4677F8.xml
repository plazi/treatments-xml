<emphasis id="B96F173FFFF8FFC0FABAFDAAFA5A7738" box="[1340,1456,566,592]" italics="true" pageId="4" pageNumber="117">Béjaud s.n.</emphasis>
(
<collectionCode id="ED0A53E8FFF8FFC0FCB3FDCBFCAC7719" box="[821,838,599,625]" country="France" lsid="urn:lsid:biocol.org:col:15763" name="Museum National d' Histoire Naturelle, Paris (MNHN) - Vascular Plants" pageId="4" pageNumber="117" type="Herbarium">P</collectionCode>
[
<specimenCode id="DBBD6356FFF8FFC0FCCAFDCAFC2D7719" box="[844,967,598,625]" collectionCode="P" country="France" lsid="urn:lsid:biocol.org:col:15763" name="Museum National d' Histoire Naturelle, Paris (MNHN) - Vascular Plants" pageId="4" pageNumber="117" type="Herbarium">P00721450</specimenCode>
