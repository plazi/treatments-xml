<collectingMunicipality id="6BC05157FFF8FFC0FB73FE2BFAD674B9" box="[1269,1340,439,465]" pageId="4" pageNumber="117">Arabic</collectingMunicipality>
numerals. 
<collectingCounty id="62C5B3A1FFF8FFC0FCA8FE4BFCAC7499" box="[814,838,471,497]" pageId="4" pageNumber="117">In</collectingCounty>
