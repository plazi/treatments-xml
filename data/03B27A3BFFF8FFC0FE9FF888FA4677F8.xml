<date id="FFA5EDEDFFF8FFC0FC7AFE6BFB907779" box="[1020,1146,503,529]" pageId="4" pageNumber="117" value="1929-06-24">
<collectingDate id="EFE11405FFF8FFC0FC7AFE6BFB907779" box="[1020,1146,503,529]" pageId="4" pageNumber="117" value="1929-06-24">
24. 
<collectionCode id="ED0A53E8FFF8FFC0FB9BFE6BFBD77779" box="[1053,1085,503,529]" country="Norway" name="Mykotektet, National Veterinary Institute" pageId="4" pageNumber="117">VI</collectionCode>
