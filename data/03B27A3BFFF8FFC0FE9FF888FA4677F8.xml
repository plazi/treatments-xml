<emphasis id="B96F173FFFF8FFC0FCABFE2BFC9C74B9" box="[813,886,439,465]" italics="true" pageId="4" pageNumber="117">
<location id="8EC49DF6FFF8FFC0FCABFE2BFC9C74B9" LSID="urn:lsid:plazi:treatment:03B27A3BFFF8FFC0FE9FF888FA4677F8:8EC49DF6FFF8FFC0FCABFE2BFC9C74B9" box="[813,886,439,465]" country="Cambodia" county="In" municipality="Arabic" name="Bejaud" pageId="4" pageNumber="117">Béjaud</location>
</emphasis>
