<specimenCode id="DBBD6356FFF8FFC0FA98FEABFA74743A" box="[1310,1438,311,338]" collectionCode="P" country="France" lsid="urn:lsid:biocol.org:col:15763" name="Museum National d' Histoire Naturelle, Paris (MNHN) - Vascular Plants" pageId="4" pageNumber="117" type="Herbarium">P00721451</specimenCode>
