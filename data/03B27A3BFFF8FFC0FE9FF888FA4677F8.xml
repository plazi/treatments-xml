<specimenCode id="DBBD6356FFF8FFC0FCC9FE6BFC24777A" box="[847,974,503,530]" collectionCode="P" country="France" lsid="urn:lsid:biocol.org:col:15763" name="Museum National d' Histoire Naturelle, Paris (MNHN) - Vascular Plants" pageId="4" pageNumber="117" type="Herbarium">P00721450</specimenCode>
