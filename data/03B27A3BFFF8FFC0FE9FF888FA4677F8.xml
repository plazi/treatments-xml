<specimenCode id="DBBD6356FFF8FFC0FCA8FD8AFC447759" box="[814,942,534,561]" collectionCode="P" country="France" lsid="urn:lsid:biocol.org:col:15763" name="Museum National d' Histoire Naturelle, Paris (MNHN) - Vascular Plants" pageId="4" pageNumber="117" type="Herbarium">P00721451</specimenCode>
