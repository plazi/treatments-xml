<subSubSection id="CF2AA88A36728A05D37AF503DA52A962" pageId="null" pageNumber="572" type="vernacular_names">
<paragraph id="A52C09E38440AE6CDBBDB1E86C074E3F" pageId="null" pageNumber="572">Zottiger Spitzkiel</paragraph>
</subSubSection>
</title>
<subSubSection id="7B1FF75BEB55C2CE43C47E8141EEC195" pageId="null" pageNumber="572" type="description">
<paragraph id="08A5F994F71893B6A1035E000F76D75F" pageId="null" pageNumber="572">
15-30 cm hoch. Stengel deutlich ausgebildet und 
<normalizedToken id="B7D3137F4352157127870FB5CDBEDB2F" originalValue="beblättert" pageId="null" pageNumber="572">beblaettert</normalizedToken>
, dicht behaart (sehr kurze, krause und 0,5-1 mm lange, abstehende Haare). 
<normalizedToken id="D13066C2B6200AE6F95BE0D11512B836" originalValue="Blätter" pageId="null" pageNumber="572">Blaetter</normalizedToken>
mit 19-27 
<normalizedToken id="669D5892981A092374AE2494CEDC2477" originalValue="Teilblättern" pageId="null" pageNumber="572">Teilblaettern</normalizedToken>
; 
<normalizedToken id="6EB95873CD905CC22319E85DB47B3599" originalValue="Teilblätter" pageId="null" pageNumber="572">Teilblaetter</normalizedToken>
0,5-2 cm lang, 
<normalizedToken id="4DB9746750B70A982B70E759807E7DCB" originalValue="2½" pageId="null" pageNumber="572">21/2</normalizedToken>
-8mal so lang wie breit, spitz oder stumpf, oberseits kahl, unterseits anliegend behaart; 
<emphasis id="FBDAF881520F216A0F0FB7E011304F9D" italics="true" pageId="null" pageNumber="572">
<normalizedToken id="14D771F5117AD6940A84AAB1FC8C0FE0" originalValue="Nebenblätter" pageId="null" pageNumber="572">Nebenblaetter</normalizedToken>
frei
</emphasis>
, 
<normalizedToken id="5F08900C97C173CDA901DAA43EEA8CD5" originalValue="½" pageId="null" pageNumber="572">1/2</normalizedToken>
-⅔ 
<emphasis id="C41F879BF572F088F90A7980BF0B2A44" italics="true" pageId="null" pageNumber="572">
so lang wie die untern 
<normalizedToken id="48A8CFDA916F2D9E583E7D015B545252" originalValue="Teilblätter" pageId="null" pageNumber="572">Teilblaetter</normalizedToken>
.
</emphasis>
<normalizedToken id="4AA949CF5E7E2E2AFB276D531559031C" originalValue="Blüten" pageId="null" pageNumber="572">Blueten</normalizedToken>
zu 5-25, aufrecht. Stiel des 
<normalizedToken id="3329259384C254D82D803C7ABA0E816F" originalValue="Blütenstandes" pageId="null" pageNumber="572">Bluetenstandes</normalizedToken>
so lang oder wenig 
<normalizedToken id="D166232F28EFA113C656BC71163C3134" originalValue="länger" pageId="null" pageNumber="572">laenger</normalizedToken>
als das 
<normalizedToken id="CA031EE2809023BC72EF8002600A5457" originalValue="nächststehende" pageId="null" pageNumber="572">naechststehende</normalizedToken>
Stengelblatt, dicht behaart. Kelch mit zahlreichen, etwa 1 mm langen, 
<normalizedToken id="DF8132F54FC367684A6AB091FFC8F946" originalValue="weißen" pageId="null" pageNumber="572">weissen</normalizedToken>
und kurzen, schwarzen Haaren; 
<emphasis id="5CB61B83423C54559366A9664B3AB253" italics="true" pageId="null" pageNumber="572">
<normalizedToken id="9532F2D34E6D2C7CC449F732181AC78E" originalValue="Kelchzähne" pageId="null" pageNumber="572">Kelchzaehne</normalizedToken>
fast so lang wie die 
<normalizedToken id="42B1CF28772D98858DDDB0D4439274E4" originalValue="Kelchröhre" pageId="null" pageNumber="572">Kelchroehre</normalizedToken>
. Krone 1-1,2 cm lang, hellgelb. Frucht im Kelch ungestielt
</emphasis>
, aufrecht, 
<emphasis id="8207452BCD38627E2F58FC9C6DE06E9E" italics="true" pageId="null" pageNumber="572">kurz zylindrisch</emphasis>
, etwa 1,5 cm lang und 0,3 cm dick, an der obern Naht gefurcht, teilweise 2 
<normalizedToken id="5537544A875A67926A18FB913261568E" originalValue="fächerig" pageId="null" pageNumber="572">faecherig</normalizedToken>
, dicht und ziemlich kurz behaart. - 
<normalizedToken id="DB9ACCB665387E2A2A9A428115BE0474" originalValue="Blüte" pageId="null" pageNumber="572">Bluete</normalizedToken>
: 
<normalizedToken id="E437D0DC55E58A35637A7ECB3CF9847D" originalValue="Später" pageId="null" pageNumber="572">Spaeter</normalizedToken>
<normalizedToken id="19C8AE8388D5BD7AA683E342C18276DA" originalValue="Frühling" pageId="null" pageNumber="572">Fruehling</normalizedToken>
und 
<normalizedToken id="CB0DEDE3A4CD0E33BF197F8E1FAF0BDD" originalValue="früher" pageId="null" pageNumber="572">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="3D4E1F66DDE3425DF087B2DCCE2A3006" pageId="null" pageNumber="572">
<emphasis id="8A48A2EE08B58A7281FD80E486319C00" italics="true" pageId="null" pageNumber="572">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="45E25DC096578A77F14CAE7225C6647A" italics="true" pageId="null" pageNumber="572">16:</emphasis>
Material aus Ungarn (Baksay 1958).
</paragraph>
<paragraph id="8B58167A99BDDC9D7C9731135E265643" pageId="null" pageNumber="572">
<emphasis id="9CC2F8B494848CDCB2A3AB839222E333" italics="true" pageId="null" pageNumber="572">Standort.</emphasis>
Kollin und montan. Trockene, lockere, kalkhaltige, oft sandige 
<normalizedToken id="F3309430CE70C940606C6703612FA4B9" originalValue="Böden" pageId="null" pageNumber="572">Boeden</normalizedToken>
in warmen Lagen. Lichte 
<normalizedToken id="78AC85B867FA06D5822977BC5D528113" originalValue="Föhrenwälder" pageId="null" pageNumber="572">Foehrenwaelder</normalizedToken>
, Trockenwiesen.
</paragraph>
<paragraph id="A8E5DA0F2DC7276FD4F180C353345099" pageId="null" pageNumber="572">
<emphasis id="805825946FEBC0A9459EDA765D067891" italics="true" pageId="null" pageNumber="572">
Verbreitung. 
<normalizedToken id="75373D79C53D80F1C0A3B438B2045173" originalValue="Osteuropäisch-westasiatische" pageId="null" pageNumber="572">Osteuropaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
Alpen, Apennin, 
<normalizedToken id="305E79B8B031D367D5F528D1C5B756AC" originalValue="Südschweden" pageId="null" pageNumber="572">Suedschweden</normalizedToken>
, baltische Staaten, Balkanhalbinsel, 
<normalizedToken id="6017691A8FF94FEC3B4422ECD3500E23" originalValue="Südrußland" pageId="null" pageNumber="572">Suedrussland</normalizedToken>
, durch Asien 
<normalizedToken id="C98CEB0125DD38B476105D7A62AC4E28" originalValue="ostwärts" pageId="null" pageNumber="572">ostwaerts</normalizedToken>
bis Baikalsee. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: Savoyen (Maurienne, Tarentaise), Wallis (Trient bis Brig), Aostatal (Montjovet bis Courmayeur), Rheintal (Untervaz bis 
<normalizedToken id="B115B4C73C0D4319DE61C200ADF3088D" originalValue="Rhäzüns" pageId="null" pageNumber="572">Rhaezuens</normalizedToken>
und weiter 
<normalizedToken id="CCBF62E1A8622DA3BA37E50B0FCA0A06" originalValue="abwärts" pageId="null" pageNumber="572">abwaerts</normalizedToken>
<normalizedToken id="37D05828FAC8317568F46749CB932D1C" originalValue="vorübergehend" pageId="null" pageNumber="572">voruebergehend</normalizedToken>
auf Alluvionen und 
<normalizedToken id="491BD7E0A44F318A7541901B923E5848" originalValue="Dämmen" pageId="null" pageNumber="572">Daemmen</normalizedToken>
), Domleschg, Albulagebiet (
<normalizedToken id="C152F9604919A680EB508C871F913F05" originalValue="aufwärts" pageId="null" pageNumber="572">aufwaerts</normalizedToken>
bis Alvaneu), Unterengadin, Oberinntal, Veltlin, Bergamasker Alpen (Erve, Val Camonica), Vintschgau (
<normalizedToken id="81CC4E903CA0A9DB806D5BE82CFB45F3" originalValue="aufwärts" pageId="null" pageNumber="572">aufwaerts</normalizedToken>
bis Glurns), Hegau (Vulkanberge); ziemlich selten.
</paragraph>
</subSubSection>
