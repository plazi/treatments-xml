<typeStatus id="54C2882F8116F116FE552036FDF7F84A" box="[457,564,1896,1922]" pageId="15" pageNumber="48">holotype</typeStatus>
. Total length: 
<quantity id="4C819B688116F116FD462036FC86F84A" box="[730,837,1896,1922]" metricMagnitude="-3" metricUnit="m" metricValue="2.37" pageId="15" pageNumber="48" unit="mm" value="2.37">2.37 mm</quantity>
