<subSubSection id="906F100359BF1956E6B1F21F148BCAFD" pageId="null" pageNumber="679" type="description">
<paragraph id="14E666CEFC0C5257A1933F9F5CC053E7" pageId="null" pageNumber="679">
♂ 
<normalizedToken id="8D2146BA2F6103229A25344BE3BFAECB" originalValue="Blüten" pageId="null" pageNumber="679">Blueten</normalizedToken>
mit 3-5 freien, 
<normalizedToken id="2DF023A7B0228C4D7481637EFC4A3674" originalValue="grünen" pageId="null" pageNumber="679">gruenen</normalizedToken>
<normalizedToken id="C872D09DB292C6BCC1F2FB2A4D1DDBB7" originalValue="Perigonblättern" pageId="null" pageNumber="679">Perigonblaettern</normalizedToken>
, 
<normalizedToken id="1A887C9645AAC71E957DDF64A5FC0B3D" originalValue="Staubblätter" pageId="null" pageNumber="679">Staubblaetter</normalizedToken>
6-40. ♀ 
<normalizedToken id="D998AB482A050DBE17B4D6781D0DC5C9" originalValue="Blüten" pageId="null" pageNumber="679">Blueten</normalizedToken>
in 1-12 
<normalizedToken id="2581729395C740FE7C7AB64843433E80" originalValue="blütigen" pageId="null" pageNumber="679">bluetigen</normalizedToken>
<normalizedToken id="24F4F77AC3C82D3FC4711A02B7857309" originalValue="Blütenständen" pageId="null" pageNumber="679">Bluetenstaenden</normalizedToken>
, mit 4 
<normalizedToken id="C79EDFBAF975A929631D455EC1D319A1" originalValue="Perigonblättern" pageId="null" pageNumber="679">Perigonblaettern</normalizedToken>
.
</paragraph>
<paragraph id="0DBD2F76E421296F3A1280EEE8AEF15F" pageId="null" pageNumber="679">
Die Gattung 
<taxonomicName id="C01FD482CBC843A658A8694DA45AF955" class="Magnoliopsida" family="Juglandaceae" genus="Juglans" kingdom="Plantae" order="Fagales" pageId="null" pageNumber="679" phylum="Tracheophyta" rank="genus">
<emphasis id="36A7F3461E761BB8970A61176CE45343" italics="true" pageId="null" pageNumber="679">Juglans</emphasis>
</taxonomicName>
<normalizedToken id="A6C3E34D44C8BC0972A3940560FE9F0E" originalValue="umfaßt" pageId="null" pageNumber="679">umfasst</normalizedToken>
etwa 
<emphasis id="7682ABE18553A4658937BF9BAD006C29" italics="true" pageId="null" pageNumber="679">40 Arten;</emphasis>
sie ist in den 
<emphasis id="3C35BB64F9D6703BAF314438AABEF6AA" italics="true" pageId="null" pageNumber="679">
milden Gebieten von Eurasien, Nord- und 
<normalizedToken id="65BD86353E7F50CBE4F2D7836BFBC5B4" originalValue="Südamerika" pageId="null" pageNumber="679">Suedamerika</normalizedToken>
verbreitet.
</emphasis>
Verbreitungskarte von Meusel (1964). In Mitteleuropa nur kultivierte Arten.
</paragraph>
