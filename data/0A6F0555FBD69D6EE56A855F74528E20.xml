<subSubSection id="70043E6CE60A3E5137C137E333F20AA9" pageId="null" pageNumber="589" type="description">
<paragraph id="940944A34EA0509949DFA1C137A1E093" pageId="null" pageNumber="589">
<normalizedToken id="3E9752186E40ADA14D0047C915D5A259" originalValue="Teilblätter" pageId="null" pageNumber="589">Teilblaetter</normalizedToken>
<normalizedToken id="4B54C7FF17F0A7BFD3E831B3996BD22E" originalValue="2½" pageId="null" pageNumber="589">21/2</normalizedToken>
-5mal so lang wie breit, die obern vorn nicht ausgerandet; 
<emphasis id="0F2B7C37A8AA7874EE3D8BA975AA3F82" italics="true" pageId="null" pageNumber="589">
Haare kaum 
<normalizedToken id="4E45D25F5044BD87A421756ECE49A21E" originalValue="über" pageId="null" pageNumber="589">ueber</normalizedToken>
1 mm lang; 
<normalizedToken id="91DF493AE835731212A5D8B5307D0DD1" originalValue="Nebenblätter" pageId="null" pageNumber="589">Nebenblaetter</normalizedToken>
</emphasis>
1/10-⅙ 
<emphasis id="61C347B9FCE4A9BEFD562627F371FEF9" italics="true" pageId="null" pageNumber="589">
so lang wie die untern 
<normalizedToken id="F03D3F51CB8D2C9A288086E2A7C0B877" originalValue="Teilblätter" pageId="null" pageNumber="589">Teilblaetter</normalizedToken>
, in der Mitte mit 
<normalizedToken id="FAB38B7F7BEA8648F6E6466AD6C56BE9" originalValue="Nektardrüse" pageId="null" pageNumber="589">Nektardruese</normalizedToken>
, die mindestens
</emphasis>
<normalizedToken id="FC5DD09DCA14596394F3F75AD3EB2D34" originalValue="¼" pageId="null" pageNumber="589">1/4</normalizedToken>
<emphasis id="53B1FE67AA6CCC6472C21B43CB4102B4" italics="true" pageId="null" pageNumber="589">
der 
<normalizedToken id="A67984D02E6DDD63ED74E49889FC7BA6" originalValue="Nebenblattfläche" pageId="null" pageNumber="589">Nebenblattflaeche</normalizedToken>
bedeckt
</emphasis>
, auch die untern ganzrandig. 
<emphasis id="A3BEBC1616B1CE76CFA2FF89B6BF1693" italics="true" pageId="null" pageNumber="589">
<normalizedToken id="3DEFFB240B9E7F99BFFF2D2750BD69E1" originalValue="Blüten" pageId="null" pageNumber="589">Blueten</normalizedToken>
zu 2-4 in den Blattachseln. Kelch 0,8-1 cm lang. Krone 1,6-2,5 cm lang, violettrot. -
</emphasis>
<normalizedToken id="9AE459B06B757751CC67E24C561070C7" originalValue="Blüte" pageId="null" pageNumber="589">Bluete</normalizedToken>
: 
<normalizedToken id="42C1A5BCF9C08F80FEEE0A0262E89747" originalValue="Später" pageId="null" pageNumber="589">Spaeter</normalizedToken>
<normalizedToken id="89C6A648814FB81151B78170F4611FF4" originalValue="Frühling" pageId="null" pageNumber="589">Fruehling</normalizedToken>
und 
<normalizedToken id="CC845F6FA74D05816594E199BB1D46A1" originalValue="früher" pageId="null" pageNumber="589">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="D92CAE3CC31B4D6716CDB15C1300133E" pageId="null" pageNumber="589">
<emphasis id="CBC23CEA8BF4E76B6A80288246A62884" italics="true" pageId="null" pageNumber="589">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B6838269D287C577567842DEBE6AFA2F" italics="true" pageId="null" pageNumber="589">12:</emphasis>
Material aus Ungarn (Baksay 1954).
</paragraph>
<paragraph id="AACF3A434A11F9EE947B00BD9C1BBEF2" pageId="null" pageNumber="589">
<emphasis id="1A49845399A6EF39095658258DB62259" italics="true" pageId="null" pageNumber="589">Standort.</emphasis>
<normalizedToken id="1319A5E48BA90818473C88ADD2CB3345" originalValue="Ähnlich" pageId="null" pageNumber="589">Aehnlich</normalizedToken>
wie 
<taxonomicName id="8D77381F36A41C535A3939E9894C4BC5" class="Magnoliopsida" family="Fabaceae" genus="Vicia" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="589" phylum="Tracheophyta" rank="species" species="pannonica">
<emphasis id="DBE769E5680849DE5CC60AAE5806B75D" italics="true" pageId="null" pageNumber="589">V. pannonica</emphasis>
</taxonomicName>
(Nr. 11b).
</paragraph>
<paragraph id="52D8DD816E82DE8549C9FDB275F6AD1D" pageId="null" pageNumber="589">
<emphasis id="678794C59EE9B2A220867E4BDF36CB09" italics="true" pageId="null" pageNumber="589">
Verbreitung. 
<normalizedToken id="D955508493F2298EB6548E444143A0A5" originalValue="Südeuropäische" pageId="null" pageNumber="589">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="F3FAC282363730BA81190C1EC9C8FEC7" originalValue="Ursprüngliche" pageId="null" pageNumber="589">Urspruengliche</normalizedToken>
Verbreitung nicht genau bekannt. Durch Kulturen heute 
<normalizedToken id="9C3AF3390F3A029E3CD6E72D8C3BB2EB" originalValue="über" pageId="null" pageNumber="589">ueber</normalizedToken>
weite Gebiete der Erde verschleppt. - Im Gebiet nicht einheimisch, selten eingeschleppt oder adventiv.
</paragraph>
</subSubSection>
