<subSubSection id="90E38A20C3915A58A23ABCA6CE652A6D" pageId="null" pageNumber="402" type="description">
<paragraph id="E76B7F19EEB84FAD54BEBB4DEBFEB996" pageId="null" pageNumber="402">
Unterscheidet sich von 
<taxonomicName id="CE7781A475FA6C52363B31AE6FEB4423" class="Liliopsida" family="Cyperaceae" genus="Trichophorum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="402" phylum="Tracheophyta" rank="species" species="caespitosum">
<emphasis id="E7124D1EE011A7A924DDAD5DDAE26B2B" italics="true" pageId="null" pageNumber="402">T. caespitosum</emphasis>
</taxonomicName>
(Nr. 2) durch das folgende Merkmal: 
<emphasis id="A6FC8DC3C416F43084465E706D8C934F" italics="true" pageId="null" pageNumber="402">Ausschnitt an der obersten Blattscheide bis 10 mm tief.</emphasis>
- 
<normalizedToken id="238A40938919156D26CDEA5F391E4F0C" originalValue="Blüte" pageId="null" pageNumber="402">Bluete</normalizedToken>
: 
<normalizedToken id="7BC729BF484B2EEB30B55F0345831264" originalValue="Frühling" pageId="null" pageNumber="402">Fruehling</normalizedToken>
und 
<normalizedToken id="7511C657D1F940E2511AD6B056E4BDAC" originalValue="früher" pageId="null" pageNumber="402">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="5881187DE2CEEB939BB5BCAF7DB1B59D" pageId="null" pageNumber="402">
<emphasis id="C2EAAF6F0C143E7DE5A0879D257F2EEA" italics="true" pageId="null" pageNumber="402">Zytologische Angaben.</emphasis>
Siehe unter 
<taxonomicName id="E43E5705AEF90CDFC6C92D6DC85B0BF8" class="Liliopsida" family="Cyperaceae" genus="Trichophorum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="402" phylum="Tracheophyta" rank="species" species="caespitosum">
<emphasis id="9E8EEC9AB0023D3848C08B12C5622B8B" italics="true" pageId="null" pageNumber="402">T. caespitosum</emphasis>
</taxonomicName>
(Nr. 2).
</paragraph>
<paragraph id="1010F1673533CDC1DAFB780E1AC44F6F" pageId="null" pageNumber="402">
<emphasis id="56D394C8D6A2D3FF5BD34472EC84D27C" italics="true" pageId="null" pageNumber="402">Standort.</emphasis>
Montan. Wie 
<taxonomicName id="C8081B04266991FBE4C6EE03D2903D7D" class="Liliopsida" family="Cyperaceae" genus="Trichophorum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="402" phylum="Tracheophyta" rank="species" species="caespitosum">
<emphasis id="680EB7765A3FD7B08FCA6F95E2116AD2" italics="true" pageId="null" pageNumber="402">T. caespitosum</emphasis>
</taxonomicName>
(Nr. 2); in England nur auf sauren oder basenarmen 
<normalizedToken id="2BAE2B3F2E204BC09AB32BCE470450DD" originalValue="Böden" pageId="null" pageNumber="402">Boeden</normalizedToken>
(Clapham et al. 1952).
</paragraph>
<paragraph id="6E23BBE8CCCDE29225059AE60C79BB8E" pageId="null" pageNumber="402">
<emphasis id="12ED5F86A818BF4C43A7111263173598" italics="true" pageId="null" pageNumber="402">
Verbreitung. 
<normalizedToken id="FD874E53B033F65F4D5BA9AB4EBF222E" originalValue="Westeuropäische" pageId="null" pageNumber="402">Westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Gebirge Nordwestafrikas und Portugals, 
<normalizedToken id="E47183D046832D9111E9214A2557904F" originalValue="Pyrenäen" pageId="null" pageNumber="402">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="083D1BE09DADE1C2255EAF66B232A0F7" originalValue="südlicher" pageId="null" pageNumber="402">suedlicher</normalizedToken>
Jura, Vogesen, Schwarzwald, mitteldeutsche Gebirge, 
<normalizedToken id="027CE270F5D42ED387DABE23229D71CB" originalValue="Küstengebiete" pageId="null" pageNumber="402">Kuestengebiete</normalizedToken>
an der Nord- und Ostsee, 
<normalizedToken id="B3C4DE9849485265B9C6B569196B5E07" originalValue="Großbritannien" pageId="null" pageNumber="402">Grossbritannien</normalizedToken>
. Angaben 
<pageBreakToken id="532C1C538B1CC660BB62EC7968A20FD2" pageId="null" pageNumber="402">aus</pageBreakToken>
dem Himalaja, aus Nordamerika und 
<normalizedToken id="C4F37A328E61BC7C8E1C3B81F9A34C30" originalValue="Grönland" pageId="null" pageNumber="402">Groenland</normalizedToken>
sind zu 
<normalizedToken id="A935CAA409FCF8358D0F94FA5D5A9C42" originalValue="überprüfen" pageId="null" pageNumber="402">ueberpruefen</normalizedToken>
. - Im Gebiet: 
<normalizedToken id="06D52AC8F24E80DA599584CA5763F68D" originalValue="Südlicher" pageId="null" pageNumber="402">Suedlicher</normalizedToken>
Jura, Vogesen, Schwarzwald.
</paragraph>
<paragraph id="12140ACF8F3369B827E9716D782B536A" pageId="null" pageNumber="402">
<emphasis id="516E066D4A08FA81EF1C01AC837AA7E5" italics="true" pageId="null" pageNumber="402">
Bemerkungen. 
<taxonomicName id="4EB055E72CB4D66D5EFC179BF1F21AAB" class="Liliopsida" family="Cyperaceae" genus="Trichophorum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="402" phylum="Tracheophyta" rank="species" species="caespitosum">T. caespitosum</taxonomicName>
</emphasis>
und 
<taxonomicName id="157752A86FF35CC1859A67EF555B66CB" class="Liliopsida" family="Cyperaceae" genus="Trichophorum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="402" phylum="Tracheophyta" rank="species" species="germanicum">
<emphasis id="FB71447B445861B2BD95D2DBC8E74861" italics="true" pageId="null" pageNumber="402">T. germanicum</emphasis>
</taxonomicName>
sind zytogenetisch und 
<normalizedToken id="92166ED436BB8AD3D5654A04DFB97F85" originalValue="ökologisch" pageId="null" pageNumber="402">oekologisch</normalizedToken>
miteinander zu vergleichen und ihre Verbreitung ist genauer zu untersuchen.
</paragraph>
</subSubSection>
