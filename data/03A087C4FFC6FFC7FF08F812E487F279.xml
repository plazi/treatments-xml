<caption id="DF76665AFFC6FFC7FCE2F6D0E221F62B" ID-DOI="http://doi.org/10.5281/zenodo.6514399" ID-Zenodo-Dep="6514399" httpUri="https://zenodo.org/record/6514399/files/figure.png" inLine="true" pageId="3" pageNumber="410" targetBox="[192,785,2098,2513]" targetPageId="3">
<paragraph id="8BB636D2FFC6FFC7FCE2F6D0E221F62B" blockId="3.[809,1395,2092,2514]" pageId="3" pageNumber="410">
<emphasis id="B97DEAC0FFC6FFC7FCE2F6D0E5E4F67D" bold="true" box="[809,985,2407,2436]" pageId="3" pageNumber="410">Distribution.</emphasis>
