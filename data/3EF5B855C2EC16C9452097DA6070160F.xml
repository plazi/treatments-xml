<subSubSection id="7F9E18F5938F4A8220E10E1BA38AECEB" pageId="null" pageNumber="470" type="description">
<paragraph id="2F1D65BADDEDCA43309D995D90B8623E" pageId="null" pageNumber="470">
10-40 cm hoch; lange, 
<normalizedToken id="FB479009C5F44BD29B4E51F6DF5B02C4" originalValue="dünne" pageId="null" pageNumber="470">duenne</normalizedToken>
, unterirdische 
<normalizedToken id="533BD9ECA8E2EB87A67454CEC02814F7" originalValue="Ausläufer" pageId="null" pageNumber="470">Auslaeufer</normalizedToken>
treibend. 
<normalizedToken id="60F81628F42EDD5F73D58F0BD8E2DF24" originalValue="Grundständige" pageId="null" pageNumber="470">Grundstaendige</normalizedToken>
Blattscheiden braun. 
<normalizedToken id="896FCDB449D6F5699E437E9C288AD2C0" originalValue="Blätter" pageId="null" pageNumber="470">Blaetter</normalizedToken>
1-1,5 mm breit, flach, steif, kahl, den 
<normalizedToken id="1D7C3CD0C1EE5F50DBF2C5ED05B2B939" originalValue="Blütenstand" pageId="null" pageNumber="470">Bluetenstand</normalizedToken>
nicht erreichend. Stengel stumpf 3kantig, undeutlich rauh, steif aufrecht. 
<normalizedToken id="62F2908DFD945DC8D63167E9B4D25414" originalValue="Blütenstand" pageId="null" pageNumber="470">Bluetenstand</normalizedToken>
5-10 cm lang, aus 2-4 seitlichen, 
<emphasis id="182047EB4CCB8EBFD58B5F7235C08A60" italics="true" pageId="null" pageNumber="470">
<normalizedToken id="B77D1DF51E031D86F898ABE4F09AADD6" originalValue="lockerfrüchtigen" pageId="null" pageNumber="470">lockerfruechtigen</normalizedToken>
, 
<normalizedToken id="0C696C744B3180716B11DA56DBC39A3F" originalValue="wenigblütigen" pageId="null" pageNumber="470">wenigbluetigen</normalizedToken>
</emphasis>
(3-6 
<normalizedToken id="1D1E89229DC3DB9279E289A38DCD71E4" originalValue="Blüten" pageId="null" pageNumber="470">Blueten</normalizedToken>
), 0,5-1 cm langen, 0,5-3 cm lang gestielten, aufrechten ♀ 
<normalizedToken id="094C397B0FE7E685705565816F658224" originalValue="Ähren" pageId="null" pageNumber="470">Aehren</normalizedToken>
und 1 
<normalizedToken id="4000FB95E6DA3F83E1939B18EAA36B7E" originalValue="endständigen" pageId="null" pageNumber="470">endstaendigen</normalizedToken>
♂ 
<normalizedToken id="5AC78C8FBF346A2C610DD7F1064F00A3" originalValue="Ähre" pageId="null" pageNumber="470">Aehre</normalizedToken>
; 
<emphasis id="FF2BC797098054B1B3907A2D54F97063" italics="true" pageId="null" pageNumber="470">oberste</emphasis>
♀ 
<emphasis id="6303B289428322663215B74A8105367E" italics="true" pageId="null" pageNumber="470">
<normalizedToken id="73334F9B67F726D06E92250407F3FFBA" originalValue="Ähre" pageId="null" pageNumber="470">Aehre</normalizedToken>
zur Fruchtzeit die
</emphasis>
♂ 
<emphasis id="27D495BDC7B270C02A5A3E02E89625C7" italics="true" pageId="null" pageNumber="470">
<normalizedToken id="43DDC37B4C77011254D1325E20FAA7BD" originalValue="Ähre" pageId="null" pageNumber="470">Aehre</normalizedToken>
<normalizedToken id="99C41A94D8E1CD1818849240DA248C56" originalValue="überragend" pageId="null" pageNumber="470">ueberragend</normalizedToken>
. 
<normalizedToken id="F1BCF4A41630F8D0F3E5271E09076B25" originalValue="Hochblätter" pageId="null" pageNumber="470">Hochblaetter</normalizedToken>
<normalizedToken id="D97D0B7F59E249667A499E4D1D37726F" originalValue="tragblattähnlich" pageId="null" pageNumber="470">tragblattaehnlich</normalizedToken>
, mit 0,5
</emphasis>
- 
<emphasis id="F8B9C220EA62ACAEA0D47DFA0F4B9F5E" italics="true" pageId="null" pageNumber="470">
1,5 cm langer 
<normalizedToken id="00B33555F838D6866A7D3BB9C1F006BF" originalValue="häutiger" pageId="null" pageNumber="470">haeutiger</normalizedToken>
Scheide.
</emphasis>
<normalizedToken id="F098DD82168561505D5B32473222FC7F" originalValue="Tragblätter" pageId="null" pageNumber="470">Tragblaetter</normalizedToken>
<normalizedToken id="3384951ADAAD93066AD3A21A6406A091" originalValue="½" pageId="null" pageNumber="470">1/2</normalizedToken>
- ⅔ so lang wie die reifen 
<normalizedToken id="106CE9BE9088E482DB69DEF0535FD802" originalValue="Fruchtschläuche" pageId="null" pageNumber="470">Fruchtschlaeuche</normalizedToken>
, stumpf oder spitz, 
<emphasis id="FF40B81A9D76ACFE5E4B4A726F9C014B" italics="true" pageId="null" pageNumber="470">
<normalizedToken id="BA0234DE4222DFF793CAC28E54EBC344" originalValue="häutig" pageId="null" pageNumber="470">haeutig</normalizedToken>
. 
<normalizedToken id="4BB1AF7DE7F09FE44962B83A84E82E2E" originalValue="Fruchtschläuche" pageId="null" pageNumber="470">Fruchtschlaeuche</normalizedToken>
3,5-4 mm lang
</emphasis>
, in der Mitte am breitesten (1,5 
<emphasis id="F23B8D990C38847B250C39A1DAB806C8" italics="true" pageId="null" pageNumber="470">-</emphasis>
1,8 mm), stumpf 3kantig, mit zahlreichen, 
<emphasis id="63D2382A28F1D769ACEBD90E57B57B5C" italics="true" pageId="null" pageNumber="470">vortretenden Nerven</emphasis>
, gelblich, matt, 
<normalizedToken id="EB60F5DAAF56B6B86F967FF4AF06B33C" originalValue="allmählich" pageId="null" pageNumber="470">allmaehlich</normalizedToken>
in den Schnabel 
<normalizedToken id="DAF7F82146AC0057909DEC02A7AEA11F" originalValue="verschmälert" pageId="null" pageNumber="470">verschmaelert</normalizedToken>
. Narben 3.
</paragraph>
<paragraph id="0667331C063E266F23F0CA1D06004146" pageId="null" pageNumber="470">
<emphasis id="5371F2284F279077925C21982E84F476" italics="true" pageId="null" pageNumber="470">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="F02C7DB63F8BF945B84208281DAAF910" pageId="null" pageNumber="470">
<emphasis id="6B9D90EB764A4E788F2E6556A0EA1BE7" italics="true" pageId="null" pageNumber="470">Standort.</emphasis>
Kollin, montan und subalpin. Kalkreiche, trockene, humose, steinige, sandige oder lehmige 
<normalizedToken id="BF9CD0010362F208FA07E265F7249A9A" originalValue="Böden" pageId="null" pageNumber="470">Boeden</normalizedToken>
. Trockene, lichte Buchen- und 
<normalizedToken id="5671EA73EE78E2D7BAE902091F5FD990" originalValue="Föhrenwälder" pageId="null" pageNumber="470">Foehrenwaelder</normalizedToken>
, seltener in lichten Eichen-, Erlen- und 
<normalizedToken id="39DC966DB2423D7FB0F3C1512640FFD6" originalValue="Fichtenwäldern" pageId="null" pageNumber="470">Fichtenwaeldern</normalizedToken>
.
</paragraph>
<paragraph id="E46F1D0D68CDBAD33B9211A3B3D0C385" pageId="null" pageNumber="470">
<emphasis id="A158C16F29DD4DBB080DF1B2F46FB17A" italics="true" pageId="null" pageNumber="470">Verbreitung. Eurosibirische Pflanze:</emphasis>
In 
<taxonomicName id="021BE68B49DCC6619D70E9C6B90C0368" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="470" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
<normalizedToken id="B4D07A5CBD0E6CEBB1FE35C953FCA7A8" originalValue="nordwärts" pageId="null" pageNumber="470">nordwaerts</normalizedToken>
bis an die Maas, Mannheim und 
<normalizedToken id="F0DDD6ECE011DA1FB4DAF5E7490C764B" originalValue="Südbayern" pageId="null" pageNumber="470">Suedbayern</normalizedToken>
. Hauptverbreitung von den 
<normalizedToken id="C354FC1F4BD9F0B8FD9354B360A3AF48" originalValue="Ostpyrenäen" pageId="null" pageNumber="470">Ostpyrenaeen</normalizedToken>
durch die Alpen (
<normalizedToken id="BF57BF6E28A0BE51C2AEB0240F13C5D4" originalValue="Südgrenze" pageId="null" pageNumber="470">Suedgrenze</normalizedToken>
durch Piemont) und Gebirge der 
<normalizedToken id="FA3750E0A88C37204F7278E36A742D35" originalValue="nördlichen" pageId="null" pageNumber="470">noerdlichen</normalizedToken>
Balkanhalbinsel; Karpaten, Kaukasus, Wolgagebiet bis Ostsibirien (zwischen 50 und 70° NB), Zentralasien. Verbreitungskarte von Meusel (1964). - Im Gebiet verbreitet; ziemlich 
<normalizedToken id="C6313EFBF00433E6F081A9AF1A9B53A8" originalValue="häufig" pageId="null" pageNumber="470">haeufig</normalizedToken>
. Karte der zirkumalpinen Verbreitung von Bresinsky (1965).
</paragraph>
</subSubSection>
