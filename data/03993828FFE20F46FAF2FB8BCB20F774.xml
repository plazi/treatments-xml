<caption id="DF4FD9B6FFE20F46F854FAC2C45EFA4F" ID-DOI="http://doi.org/10.5281/zenodo.6600476" ID-Zenodo-Dep="6600476" httpUri="https://zenodo.org/record/6600476/files/figure.png" inLine="true" pageId="16" pageNumber="199" targetBox="[1373,1964,1220,1633]" targetPageId="16">
