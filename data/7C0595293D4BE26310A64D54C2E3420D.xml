<paragraph id="DFB94B1D54346E5A96E60AAF613AA884" pageId="null" pageNumber="619">Tauben-Storchschnabel</paragraph>
</subSubSection>
</title>
<subSubSection id="CDCF930FFDF6A12686AAAA02B7A95FD6" pageId="null" pageNumber="619" type="description">
<paragraph id="AC586A4BBAFFDD50344215EB50124F54" pageId="null" pageNumber="619">
1 
<normalizedToken id="B9CC0866E355284A672EBCF4E2D43E56" originalValue="jährig" pageId="null" pageNumber="619">jaehrig</normalizedToken>
, mit Pfahlwurzel; 15-40 cm hoch. Stengel aufsteigend oder aufrecht, nicht oder wenig verzweigt, 
<emphasis id="33F52516021A677E8DBFC8BBA852D7C8" italics="true" pageId="null" pageNumber="619">
kurz und 
<normalizedToken id="E66ABCA0B94A7E60DBE9ABE8FC68D0EE" originalValue="rückwärts" pageId="null" pageNumber="619">rueckwaerts</normalizedToken>
anliegend behaart
</emphasis>
(
<emphasis id="63B56969D8F3FBAFB67389F5475F62B6" italics="true" pageId="null" pageNumber="619">Haare 0,2-0,4 mm lang</emphasis>
). 
<normalizedToken id="7A62DD91D83720A0A4598FC0C4329959" originalValue="Blätter" pageId="null" pageNumber="619">Blaetter</normalizedToken>
am Stengel 
<normalizedToken id="B258C1B5AB82F0E9AF6C72301D40E66F" originalValue="gegenständig" pageId="null" pageNumber="619">gegenstaendig</normalizedToken>
, beiderseits kurz und anliegend behaart, die untern im 
<normalizedToken id="022C003428AD26CE7468EE7021CB11C1" originalValue="Umriß" pageId="null" pageNumber="619">Umriss</normalizedToken>
rundlich, 
<normalizedToken id="77484EA8C7165AB12225557707CD1D64" originalValue="nierenförmig" pageId="null" pageNumber="619">nierenfoermig</normalizedToken>
bis vieleckig, 2-5 cm breit, 
<emphasis id="3F2B99698ED969D84E93E2EBC716F1F7" italics="true" pageId="null" pageNumber="619">bis fast zum Grunde 5-7teilig</emphasis>
(nur die ersten 
<normalizedToken id="5B12CF3D77AA2C49D7A3DD9E1BB4B016" originalValue="Blätter" pageId="null" pageNumber="619">Blaetter</normalizedToken>
weniger tief geteilt und mit stumpfen Zipfeln); Abschnitte 1-2mal tief geteilt; 
<emphasis id="4AC36DA14D09D602FD4D4624A7105454" italics="true" pageId="null" pageNumber="619">Zipfel 3-8mal so lang wie breit, spitz</emphasis>
. 
<normalizedToken id="265F183A6ACDF3F9815626417854F345" originalValue="Nebenblätter" pageId="null" pageNumber="619">Nebenblaetter</normalizedToken>
lang zugespitzt. 
<normalizedToken id="F26678674A3DD18BE08F6A3FFDF03377" originalValue="Blütenstände" pageId="null" pageNumber="619">Bluetenstaende</normalizedToken>
2 
<normalizedToken id="74579C07E52A375EA89E8B5B0366D364" originalValue="blütig" pageId="null" pageNumber="619">bluetig</normalizedToken>
. 
<emphasis id="71950CD269D6E0DB849C38DCE7A0F9B3" italics="true" pageId="null" pageNumber="619">
<normalizedToken id="0D7FE3F69793B9B5DA0D9B8CA983C654" originalValue="Blüten" pageId="null" pageNumber="619">Blueten</normalizedToken>
die 
<normalizedToken id="EED92FD16151F135B700C591C1861B51" originalValue="nächststehenden" pageId="null" pageNumber="619">naechststehenden</normalizedToken>
<normalizedToken id="F0071BE320AD353261605EFE0073DC5F" originalValue="Blätter" pageId="null" pageNumber="619">Blaetter</normalizedToken>
weit 
<normalizedToken id="60A76D6AB918F2EE0EBDA57ED4A4F487" originalValue="überragend" pageId="null" pageNumber="619">ueberragend</normalizedToken>
</emphasis>
(
<emphasis id="4A8E113E882F50532B2163F3685A4976" italics="true" pageId="null" pageNumber="619">
mindestens um die 
<normalizedToken id="BF41A9D1E56AAC251CAA9D07050A6441" originalValue="Blattlänge" pageId="null" pageNumber="619">Blattlaenge</normalizedToken>
</emphasis>
). 
<normalizedToken id="EE5A467A40AAD841A10641EA08B4FFBB" originalValue="Blütenstiele" pageId="null" pageNumber="619">Bluetenstiele</normalizedToken>
und Kelch kurz anliegend behaart (Haare 0,2-0,4 mm lang), 
<emphasis id="A886AF67A452ECFFB90C74BD83A0DCA4" italics="true" pageId="null" pageNumber="619">
ohne 
<normalizedToken id="FE01FBDB7CF4892F9603847C46243446" originalValue="Drüsenhaare" pageId="null" pageNumber="619">Druesenhaare</normalizedToken>
</emphasis>
. 
<normalizedToken id="DAB97A9D0DBA8E6D23620657BF3BE259" originalValue="Kelchblätter" pageId="null" pageNumber="619">Kelchblaetter</normalizedToken>
mit 1-3 mm langer, aufgesetzter Spitze, 7-10 mm lang. 
<emphasis id="DD8A4EB0E61CEDB7970C2EC88E1BE731" italics="true" pageId="null" pageNumber="619">
<normalizedToken id="2B3684BF0287E46FE95FD2E11211339C" originalValue="Kronblätter" pageId="null" pageNumber="619">Kronblaetter</normalizedToken>
8-10 mm lang
</emphasis>
, vorn ausgerandet, 
<emphasis id="A901CFE5FEF81E4B358D48969550C7EC" italics="true" pageId="null" pageNumber="619">purpurn</emphasis>
, zuunterst an den 
<normalizedToken id="DE248E9AE7D18CDBCA1FB308E8791010" originalValue="Rändern" pageId="null" pageNumber="619">Raendern</normalizedToken>
bewimpert. 
<emphasis id="B67B3306C24369972099260F660B0ECC" italics="true" pageId="null" pageNumber="619">Frucht 2-2,5 cm lang</emphasis>
, im untern Teil glatt, zerstreut abstehend behaart bis fast kahl. Samen mit netzartiger 
<normalizedToken id="8415AC0BDB2EC3AF0A9072865E025A53" originalValue="Oberfläche" pageId="null" pageNumber="619">Oberflaeche</normalizedToken>
. - 
<normalizedToken id="E897F69F484F2EFB21C65B1FDB4A24EB" originalValue="Blüte" pageId="null" pageNumber="619">Bluete</normalizedToken>
: 
<normalizedToken id="C2999177CD0EA5E0F00467B98DE08C5A" originalValue="Später" pageId="null" pageNumber="619">Spaeter</normalizedToken>
<normalizedToken id="D66726FE815473F552C68B8065B3333D" originalValue="Frühling" pageId="null" pageNumber="619">Fruehling</normalizedToken>
, Sommer und Herbst.
</paragraph>
<paragraph id="ACCB641E2E300BB25608585B13A8B78F" pageId="null" pageNumber="619">
<emphasis id="0DD89C5F5143FD9D20AE8860375BF1F7" italics="true" pageId="null" pageNumber="619">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="90CC8E581D22E38F94633C5E796609B4" italics="true" pageId="null" pageNumber="619">18:</emphasis>
Material aus Schleswig-Holstein (Gauger 1937), aus England (Warburg 1938) und aus Skandinavien (
<normalizedToken id="F58755799A3CF721F1EF6CB03366512E" originalValue="Löve" pageId="null" pageNumber="619">Loeve</normalizedToken>
und 
<normalizedToken id="5F3258B140E236622A4CAFEA8FFE8F8A" originalValue="Löve" pageId="null" pageNumber="619">Loeve</normalizedToken>
1944b).
</paragraph>
<paragraph id="130CCF6C028F6E45840BA9153E79D3C5" pageId="null" pageNumber="619">
<emphasis id="117548F0BD853E82E3D22583EEEF2E3A" italics="true" pageId="null" pageNumber="619">Standort</emphasis>
. Kollin und montan. Trockene, lockere 
<normalizedToken id="BABC7C1B83542EE155F53080CCFAB593" originalValue="Böden" pageId="null" pageNumber="619">Boeden</normalizedToken>
. 
<normalizedToken id="B43F87FEEFFC3A0D6E7F2954185B0C85" originalValue="Äcker" pageId="null" pageNumber="619">Aecker</normalizedToken>
, 
<normalizedToken id="6DD9B7E10C9AC672B42D366ACC2B35DB" originalValue="Schuttplätze" pageId="null" pageNumber="619">Schuttplaetze</normalizedToken>
, seltener Trockenwiesen.
</paragraph>
<paragraph id="FAC0CFABDDEDE1D792294693FE6DE4B6" pageId="null" pageNumber="619">
<emphasis id="6C3CDFAFCC21B89C3B8C2FAA431A9EFB" italics="true" pageId="null" pageNumber="619">Verbreitung</emphasis>
. 
<normalizedToken id="7FECA1658697ADD882F56018E70FF859" originalValue="Ursprünglich" pageId="null" pageNumber="619">Urspruenglich</normalizedToken>
wahrscheinlich 
<emphasis id="3E6E688FE3B22DC2E7BF0701485DE466" italics="true" pageId="null" pageNumber="619">mediterrane Pflanze;</emphasis>
heute 
<normalizedToken id="1AB1C6C781D2501B01968D11EAF49EB4" originalValue="über" pageId="null" pageNumber="619">ueber</normalizedToken>
die ganze Erde verbreitet. - Im Gebiet verbreitet und 
<normalizedToken id="3D3A19869C06A4900284B63929A9EFE3" originalValue="häufig" pageId="null" pageNumber="619">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
