<emphasis box="[1265,1376,1089,1111]" italics="true" pageId="1" pageNumber="50">P. jadwigae</emphasis>
</taxonomicName>
<emphasis bold="true" box="[1382,1436,1090,1111]" pageId="1" pageNumber="50">
<taxonomicNameLabel box="[1382,1436,1090,1111]" pageId="1" pageNumber="50" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
</keyLead>
</paragraph>
</keyStep>
