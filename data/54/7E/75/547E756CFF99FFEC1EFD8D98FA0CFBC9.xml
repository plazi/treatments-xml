<heading bold="true" box="[151,1031,727,754]" fontSize="11" level="1" pageId="1" pageNumber="50" reason="1">
<emphasis bold="true" box="[151,1031,727,754]" pageId="1" pageNumber="50">
Key to the orange 
<taxonomicName authority="Johnson, 1990" authorityName="Johnson" authorityYear="1990" box="[381,546,727,754]" class="Insecta" family="Lycaenidae" genus="Penaincisalia" kingdom="Animalia" order="Lepidoptera" pageId="1" pageNumber="50" phylum="Arthropoda" rank="genus">
