<subSubSection id="D2826538FFFCFFA5FFBEFBDCFDB0344C" pageId="2" pageNumber="495" type="distribution">
<caption id="CEE7663BFFFCFFA5FFBEFBDCFDB0344C" ID-DOI="http://doi.org/10.5281/zenodo.6582023" ID-Zenodo-Dep="6582023" httpUri="https://zenodo.org/record/6582023/files/figure.png" inLine="true" pageId="2" pageNumber="495" targetBox="[109,699,609,1022]" targetPageId="2">
<paragraph id="9A2736B3FFFCFFA5FFBEFBDCFDB0344C" blockId="2.[107,1314,1038,2836]" pageId="2" pageNumber="495">
<emphasis id="A8ECEAA1FFFCFFA5FFBEFBDCFEBB3426" bold="true" box="[111,285,1038,1063]" pageId="2" pageNumber="495">Distribution.</emphasis>
