<paragraph id="302936A1C857537D9A8ECD09FE74226C" blockId="5.[160,1156,1321,1728]" box="[160,447,1321,1347]" pageId="5" pageNumber="40">
<emphasis id="02E2EAB3C857537D9A8ECD09FE74226C" bold="true" box="[160,447,1321,1347]" italics="true" pageId="5" pageNumber="40">
Female (
<specimenCount id="2690FD28C857537D9B29CD09FE7D226C" box="[263,438,1321,1347]" pageId="5" pageNumber="40" type="generic" typeStatus="paratypes">nine paratypes</specimenCount>
