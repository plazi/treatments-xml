<subSubSection id="62B651A086A45C511A14BAB4C5049453" pageId="null" pageNumber="150" type="description">
<paragraph id="4BB06E28CDDADB12E5AAE54899DB0EF6" pageId="null" pageNumber="150">
Unterscheidet sich von der Gattung 
<taxonomicName id="0A64D31DF78E99826C1306932634BD8A" class="Magnoliopsida" family="Lamiaceae" genus="Origanum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="150" phylum="Tracheophyta" rank="genus">
<emphasis id="22F4FDE5DD4121E6FE3783B9453179BA" italics="true" pageId="null" pageNumber="150">Origanum</emphasis>
</taxonomicName>
(S. 144) durch folgende Merkmale: Kelch 
<emphasis id="6AB2810041BE8D16FB6E525A92235BCE" italics="true" pageId="null" pageNumber="150">deutlich 2lippig;</emphasis>
Oberlippe mit 3 kurzen, 3eckigen 
<normalizedToken id="52690E58B6C1F544FA97523ACDED42DF" originalValue="Zähnen" pageId="null" pageNumber="150">Zaehnen</normalizedToken>
; Unterlippe mit 2 lang ausgezogenen, schmalen 
<normalizedToken id="CA850E6418EA03F2A86101890F47B9AF" originalValue="Zähnen" pageId="null" pageNumber="150">Zaehnen</normalizedToken>
; 
<emphasis id="3FAAD3439F80241515E62B08D9071E49" italics="true" pageId="null" pageNumber="150">
Staubbeutel mit fast parallelen 
<normalizedToken id="D1417930F2AD4D9DC9D41393BABAE2A0" originalValue="Hälften" pageId="null" pageNumber="150">Haelften</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="AEFE8FF3983B13BC25B31AD5912E74D5" pageId="null" pageNumber="150">
Die Gattung 
<emphasis id="7D7EBB2C4C069BB89815B912D5CEDDEE" italics="true" pageId="null" pageNumber="150">
<taxonomicName id="BD6691A386A3662CA3B34272ACD96E10" class="Insecta" family="Eulophidae" genus="Thymus" kingdom="Animalia" order="Hymenoptera" pageId="null" pageNumber="150" phylum="Arthropoda" rank="genus">Thymus</taxonomicName>
hat eurasiatisch-nordafrikanische Verbreitung
</emphasis>
und 
<normalizedToken id="73B225F589E860ECFAC7DE1D8BE5DD86" originalValue="umfaßt" pageId="null" pageNumber="150">umfasst</normalizedToken>
<emphasis id="BD1FCD46C8638C01CD2BAE186330223E" italics="true" pageId="null" pageNumber="150">30</emphasis>
- 
<emphasis id="89CEEADB61E3986BEF033AC42DA9D971" italics="true" pageId="null" pageNumber="150">60 Arten. Chromosomengrundzahl</emphasis>
n = 15 (14) (vgl. Jalas und Kaleva 1967).
</paragraph>
<paragraph id="799DC1B4BCA94B9CAD08D354ACC98D9D" pageId="null" pageNumber="150">
<table id="B4CF8F9DF7DB1EE7FAADBAB3DE8E511C" frame="void" pageId="null" pageNumber="150" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="A7F57F3A114E864025B6A69D6D3B1DEA" pageId="null" pageNumber="150">
<tr id="BD43510F1DD4861862024CF3F1B22B66" pageId="null" pageNumber="150">
<td id="88B9F590E08AC4354F9D79856281F332" align="left" pageId="null" pageNumber="150" valign="top">
1. 
<normalizedToken id="5FC5B4A162DB0BBF14536CD47305EE6A" originalValue="Blätter" pageId="null" pageNumber="150">Blaetter</normalizedToken>
unterseits dicht und 
<normalizedToken id="0051E932EC4350F4C1601297F7302CE1" originalValue="weißfilzig" pageId="null" pageNumber="150">weissfilzig</normalizedToken>
behaart, mit nach unten eingerolltem Rand
</td>
<td id="BE64C9C6DDF49D3284FAF4F799D3C816" align="left" pageId="null" pageNumber="150" valign="bottom">
<taxonomicName id="AABD311D83EBF04F96C6AFD4548ADC15" class="Magnoliopsida" family="Lamiaceae" genus="Satureja" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="150" phylum="Tracheophyta" rank="species" species="vulgaris">
<italic id="480EDC49E2281067E57E0D822198207B" pageId="null" pageNumber="150">Th. vulgaris</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="AFD31DF0E1F775A04B57E4D5515B743A" pageId="null" pageNumber="150">
<td id="7ADB987B08A2FB8675ED466EC628AEF0" align="left" pageId="null" pageNumber="150" valign="top">
1*. 
<normalizedToken id="5CF02B710DE0C600BDBA85911AACD2E3" originalValue="Blätter" pageId="null" pageNumber="150">Blaetter</normalizedToken>
unterseits kahl oder behaart, aber nicht filzig, mit flachem oder nur wenig nach unten umgebogenem Rand
</td>
<td id="265DE24C3DE0D402E06F2F0560314AEA" align="left" pageId="null" pageNumber="150" valign="bottom">
<italic id="C9175D768FC70E7BF0B10EC5B35237EB" pageId="null" pageNumber="150">
Artengruppe des 
<taxonomicName id="12DCE048BEFB3E2CD501FB7B5F0EF1A2" class="Insecta" family="Eulophidae" genus="Thymus" kingdom="Animalia" order="Hymenoptera" pageId="null" pageNumber="150" phylum="Arthropoda" rank="species" species="serpyllum">Th. Serpyllum</taxonomicName>
</italic>
(Nr. 2)
</td>
</tr>
</tbody>
</table>
</paragraph>
