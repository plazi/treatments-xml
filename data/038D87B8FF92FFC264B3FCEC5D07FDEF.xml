<collectingCountry id="F333763EFF92FFC364CBFF8B586AFA90" box="[239,331,1935,1961]" name="Rwanda" pageId="10" pageNumber="192">Rwanda</collectingCountry>
(
<bibRefCitation id="EFB54B5FFF92FFC3657DFF8B5B48FA90" author="Nyirakanani, C. &amp; Chibvongodze, R. &amp; Kariuki, L. &amp; Habtu, M. &amp; Masika, M. &amp; Mukoko, D. &amp; Njunwa, K. J." box="[345,617,1935,1962]" pageId="10" pageNumber="192" pagination="1 - 10" refId="ref10421" refString="Nyirakanani, C., Chibvongodze, R., Kariuki, L., Habtu, M., Masika, M., Mukoko, D. &amp; Njunwa, K. J. (2017) Characterization of malaria vectors in Huye District, southern Rwanda. Tanzania Journal of Health Research, 19 (3), 1 - 10. https: // doi. org / 10.4314 / thrb. v 19 i 3.8" type="journal article" year="2017">
Nyirakanani 
<emphasis id="B950EABCFF92FFC365C8FF945B3FFA90" box="[492,542,1935,1961]" italics="true" pageId="10" pageNumber="192">et al</emphasis>
. 2017
</bibRefCitation>
). 
<bibRefCitation id="EFB54B5FFF92FFC3665FFF8B5A5DFA93" author="Giaquinto-Mira, M." box="[635,892,1935,1962]" pageId="10" pageNumber="192" pagination="281 - 313" refId="ref8396" refString="Giaquinto-Mira, M. (1950) Notes on the geographical distribution and biology of &quot; Anophelinae &quot; and &quot; Culicinae &quot; in Etiopia [sic]. Rivista di Malariologia, 29 (5), 281 - 313." type="journal article" year="1950">Giaquinto-Mira (1950)</bibRefCitation>
