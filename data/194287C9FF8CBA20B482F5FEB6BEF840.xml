<subSubSection id="D9F16554FF8CBA20B6E3F369B631FB21" pageId="48" pageNumber="667" type="distribution">
<caption id="C5946657FF8CBA20B6E3F369B631FB21" ID-DOI="http://doi.org/10.5281/zenodo.6567934" ID-Zenodo-Dep="6567934" httpUri="https://zenodo.org/record/6567934/files/figure.png" inLine="true" pageId="48" pageNumber="667" targetBox="[138,730,806,1221]" targetPageId="48">
<paragraph id="915436DFFF8CBA20B6E3F369B631FB21" blockId="48.[753,1346,797,1223]" lastBlockId="48.[135,1346,1230,1934]" pageId="48" pageNumber="667">
<emphasis id="A39FEACDFF8CBA20B6E3F369B187FBE4" bold="true" box="[753,929,1033,1066]" pageId="48" pageNumber="667">Distribution.</emphasis>
Disjunct locations in NE 
<collectingCountry id="E9FC764FFF8CBA20B6E0F352B160FB9D" box="[754,838,1074,1107]" name="China" pageId="48" pageNumber="667">China</collectingCountry>
(
<collectingRegion id="532FF83DFF8CBA20B772F352B1C4FB9D" box="[864,994,1074,1107]" country="China" name="Liaoning" pageId="48" pageNumber="667">Liaoning</collectingRegion>
, 
<collectingRegion id="532FF83DFF8CBA20B7E4F352B6FEFB9D" box="[1014,1240,1074,1107]" country="China" name="Nei Mongol" pageId="48" pageNumber="667">Inner Mongolia</collectingRegion>
[= 
<collectingRegion id="532FF83DFF8CBA20B102F352B141FBB4" country="China" name="Nei Mongol" pageId="48" pageNumber="667">Nei Mongol</collectingRegion>
], 
<collectingRegion id="532FF83DFF8CBA20B792F339B1F1FBB4" box="[896,983,1113,1146]" country="China" name="Hebei" pageId="48" pageNumber="667">Hebei</collectingRegion>
, 
<collectingRegion id="532FF83DFF8CBA20B7F5F339B66AFBB4" box="[999,1100,1113,1146]" country="China" name="Beijing" pageId="48" pageNumber="667">Beijing</collectingRegion>
, and 
<collectingRegion id="532FF83DFF8CBA20B088F339B716FBB4" box="[1178,1328,1113,1146]" country="China" name="Shandong" pageId="48" pageNumber="667">Shandong</collectingRegion>
), N &amp; C 
