<taxonomicName id="4C424D5686076B21FF3A854FFDD4F6F9" authorityName="Knight" authorityYear="1930" box="[226,590,2363,2402]" class="Gastropoda" family="Pseudozygopleuridae" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coenogastropoda incertae sedis" pageId="21" pageNumber="84" phylum="Mollusca" rank="family">Pseudozygopleuridae</taxonomicName>
