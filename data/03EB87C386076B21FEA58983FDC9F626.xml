<taxonomicName id="4C424D5686076B21FF388579FE31F6A8" authorityName="Knight" authorityYear="1933" box="[224,427,2317,2355]" class="Gastropoda" family="Streptacididae" genus="Donaldina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Heterostropha" pageId="21" pageNumber="84" phylum="Mollusca" rank="genus">
<emphasis id="B936EAC786076B21FF388579FE31F6A8" box="[224,427,2317,2355]" italics="true" pageId="21" pageNumber="84">Donaldina</emphasis>
</taxonomicName>
