<taxonomicName id="87AF644AB5711A270D03E28246967768" class="Magnoliopsida" family="Brassicaceae" genus="Camelina" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="174" phylum="Tracheophyta" rank="species" species="microcarpa">
