<subSubSection pageId="1" pageNumber="178" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6656782" ID-Zenodo-Dep="6656782" httpUri="https://zenodo.org/record/6656782/files/figure.png" inLine="true" pageId="1" pageNumber="178" targetBox="[108,699,305,719]" targetPageId="2">
<paragraph blockId="1.[1446,2652,3091,3483]" pageId="1" pageNumber="178">
<emphasis bold="true" box="[1448,1619,3209,3238]" pageId="1" pageNumber="178">Distribution.</emphasis>
