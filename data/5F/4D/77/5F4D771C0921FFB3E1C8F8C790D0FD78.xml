24 (5+19), 
<emphasis box="[1233,1278,151,176]" italics="true" pageId="37" pageNumber="38">Vert</emphasis>
39 (24 + 15). Measurements (in % 
<emphasis box="[393,423,187,213]" italics="true" pageId="37" pageNumber="38">SL</emphasis>
): 
<emphasis box="[448,479,187,213]" italics="true" pageId="37" pageNumber="38">aA</emphasis>
79.2, 
<emphasis box="[551,585,187,212]" italics="true" pageId="37" pageNumber="38">aD</emphasis>
71.9, 
<emphasis box="[658,689,187,212]" italics="true" pageId="37" pageNumber="38">aV</emphasis>
58.1, 
<emphasis box="[761,791,187,212]" italics="true" pageId="37" pageNumber="38">cV</emphasis>
31.9, 
<emphasis box="[863,894,187,212]" italics="true" pageId="37" pageNumber="38">pV</emphasis>
37.7, 
<emphasis box="[966,978,187,212]" italics="true" pageId="37" pageNumber="38">c</emphasis>
25.9, 
<emphasis box="[1051,1079,187,212]" italics="true" pageId="37" pageNumber="38">po</emphasis>
12.1, 
<emphasis box="[1151,1165,187,212]" italics="true" pageId="37" pageNumber="38">o</emphasis>
7.8, 
<emphasis box="[1223,1251,187,212]" italics="true" pageId="37" pageNumber="38">ao</emphasis>
5.0, 
<emphasis box="[1310,1332,187,212]" italics="true" pageId="37" pageNumber="38">io</emphasis>
10.2, 
