<emphasis id="4BC380105966581358A3C5E5F86A5493" box="[206,322,1492,1518]" italics="true" pageId="5" pageNumber="322">T. hirsuta</emphasis>
(Wulfen) Pilát
</taxonomicName>
, 
<taxonomicName id="BEB72781596658135A69C5E5FBD55492" authority="(Pers.) Fr." authorityName="Fr." baseAuthorityName="Pers." box="[516,765,1492,1519]" class="Agaricomycetes" family="Polyporaceae" genus="Trametes" kingdom="Fungi" order="Polyporales" pageId="5" pageNumber="322" phylum="Basidiomycota" rank="species" species="gibbosa">
<emphasis id="4BC38010596658135A69C5E5FB545493" box="[516,636,1492,1518]" italics="true" pageId="5" pageNumber="322">T. gibbosa</emphasis>
(Pers.) Fr.
</taxonomicName>
, 
<taxonomicName id="BEB72781596658135B67C5E5FA8E5493" box="[778,934,1492,1518]" class="Agaricomycetes" family="Polyporaceae" genus="Trametes" kingdom="Fungi" order="Polyporales" pageId="5" pageNumber="322" phylum="Basidiomycota" rank="species" species="suaveolens">
<emphasis id="4BC38010596658135B67C5E5FA8E5493" box="[778,934,1492,1518]" italics="true" pageId="5" pageNumber="322">T. suaveolens</emphasis>
</taxonomicName>
(L.) Fr., furthermore exhibited with 
<taxonomicName id="BEB7278159665813592FC5C5FB385773" box="[322,528,1524,1550]" class="Agaricomycetes" family="Polyporaceae" genus="Lenzites" kingdom="Fungi" order="Polyporales" pageId="5" pageNumber="322" phylum="Basidiomycota" rank="species" species="betulinus">
<emphasis id="4BC3801059665813592FC5C5FB385773" box="[322,528,1524,1550]" italics="true" pageId="5" pageNumber="322">Lenzites betulinus</emphasis>
</taxonomicName>
(L.) Fr., sporadically develops in 
<taxonomicName id="BEB72781596658135BFEC5C4F8FF5752" authority="(Pers.) P. Karst. (Reibnitz, 1999)" authorityName="P. Karst. (Reibnitz" authorityYear="1999" class="Agaricomycetes" family="Meruliaceae" genus="Bjerkandera" kingdom="Fungi" order="Polyporales" pageId="5" pageNumber="322" phylum="Basidiomycota" rank="species" species="fumosa">
