<taxonomicName class="Magnoliopsida" family="Malvaceae" genus="Durio" kingdom="Plantae" lsidName="" order="Malvales" pageId="0" pageNumber="85" phylum="Tracheophyta" rank="order">Malvales</taxonomicName>
