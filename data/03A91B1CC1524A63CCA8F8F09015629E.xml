<subSubSection id="C31AF981C1524A63CCA1F3EB91726323" box="[1457,2395,3086,3119]" pageId="3" pageNumber="307" type="activity">
<paragraph id="8BBFAA0AC1524A63CCA1F3EB91726323" blockId="3.[1435,2665,2417,3474]" box="[1457,2395,3086,3119]" pageId="3" pageNumber="307">
<emphasis id="B9747618C1524A63CCA1F3EB9EB56323" bold="true" box="[1457,1692,3086,3119]" pageId="3" pageNumber="307">Activity patterns.</emphasis>
