<caption id="A4A966062C06FFBAFA53A58F944A6FCF" ID-DOI="http://doi.org/10.5281/zenodo.6609527" ID-Zenodo-Dep="6609527" httpUri="https://zenodo.org/record/6609527/files/figure.png" inLine="true" pageId="3" pageNumber="58" targetBox="[1456,2046,302,716]" targetPageId="3">
