</paragraph>
<paragraph id="394B36C8FFFBBE736F93FCF90D959CA8" blockId="17.[160,709,835,896]" box="[160,709,871,896]" pageId="17" pageNumber="461">
<location id="3C2B6013FFFBBE736F93FCF90FBE9CA8" LSID="urn:lsid:plazi:treatment:B15D87DEFFFABE736E94FA8A0E849B05:3C2B6013FFFBBE736F93FCF90FBE9CA8" box="[160,238,871,896]" country="Guam" name="Known" pageId="17" pageNumber="461">Known</location>
only from 
