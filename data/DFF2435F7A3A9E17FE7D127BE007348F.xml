<subSubSection id="96065326A8DDDAE1C7505AD5CFC2A4BA" pageId="null" pageNumber="100" type="description">
<paragraph id="452914E2B6820525D213CE900BB115CC" pageId="null" pageNumber="100">
<emphasis id="A1D40150BA69E202907D3AA0C00BA6DA" italics="true" pageId="null" pageNumber="100">Rhizom kurz</emphasis>
(bis 1 cm lang). 
<emphasis id="8081FA342319FD0098099E2F7E868EE6" italics="true" pageId="null" pageNumber="100">
<normalizedToken id="0EFB691418B482BFB272C5F58DF44E17" originalValue="Grundständige" pageId="null" pageNumber="100">Grundstaendige</normalizedToken>
<normalizedToken id="5AE11769F15ED4FBEF0FE31DBDAC18DA" originalValue="Blätter" pageId="null" pageNumber="100">Blaetter</normalizedToken>
bis zum Grunde 3-5teilig; Abschnitte noch mehrmals tief geteilt; Zipfel schmal, spreizend, sich 
<normalizedToken id="82B200EAA6F72F9CF30B6F2A0FE62279" originalValue="überdeckend" pageId="null" pageNumber="100">ueberdeckend</normalizedToken>
</emphasis>
, Untere 
<normalizedToken id="91C4892D9DBFD1B9E564F5FFC81F373E" originalValue="Stengelblätter" pageId="null" pageNumber="100">Stengelblaetter</normalizedToken>
von gleicher Form, obere mit schmal lanzettlichen Abschnitten. Schnabel etwa ⅛ so lang wie das 
<normalizedToken id="EAD1BFE1C07DC9CE2B1C85A433EC466F" originalValue="Früchtchen" pageId="null" pageNumber="100">Fruechtchen</normalizedToken>
, gerade oder wenig gebogen. - 
<normalizedToken id="3000A9651437788CA70C317635C874C5" originalValue="Blüte" pageId="null" pageNumber="100">Bluete</normalizedToken>
: 
<normalizedToken id="CA9ED37F6AB619FA58374CD932C41012" originalValue="Später" pageId="null" pageNumber="100">Spaeter</normalizedToken>
<normalizedToken id="8FE5D868C84128DA0094BF968525454D" originalValue="Frühling" pageId="null" pageNumber="100">Fruehling</normalizedToken>
und 
<normalizedToken id="8382D48A66593C7DF5AD1C7DFF57CA34" originalValue="früher" pageId="null" pageNumber="100">frueher</normalizedToken>
Sommer, oft nochmals im Herbst.
</paragraph>
<paragraph id="63CB3D93FA6615855B8AF1005BC4C430" pageId="null" pageNumber="100">
<emphasis id="7EB7FBB50C96EA35D1C01ACAAF751639" italics="true" pageId="null" pageNumber="100">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="4A21204BB85DA75509A9CE9F168BE7DA" italics="true" pageId="null" pageNumber="100">14:</emphasis>
Material aus England (Marsden-Jones und Turrill 1929Marsden-Jones und Turrill 1935 und Whyte 1929), aus Lappland (
<normalizedToken id="5CE8172B2562C6CCD40961F2DAF1A7A5" originalValue="Löve" pageId="null" pageNumber="100">Loeve</normalizedToken>
und 
<normalizedToken id="B1E3BA5C64BE9169F3BAD70B46DF039E" originalValue="Löve" pageId="null" pageNumber="100">Loeve</normalizedToken>
1944b), aus Island (
<normalizedToken id="90CA420423D71D8D6A12A1B02E08527E" originalValue="Löve" pageId="null" pageNumber="100">Loeve</normalizedToken>
und 
<normalizedToken id="148BA4BCD34B20A901271891F991B0D5" originalValue="Löve" pageId="null" pageNumber="100">Loeve</normalizedToken>
1956b), aus 
<normalizedToken id="09A39E9E75A2B5BA8F238E06AC22A565" originalValue="Grönland" pageId="null" pageNumber="100">Groenland</normalizedToken>
(
<normalizedToken id="CA753FB946CA8F41CD4518D8E4B0783E" originalValue="Böcher" pageId="null" pageNumber="100">Boecher</normalizedToken>
und 
<pageBreakToken id="D2C594D3D28BA760A449AC145FE3887B" pageId="null" pageNumber="100">Larsen</pageBreakToken>
1950, 
<normalizedToken id="FEB6B782DD7765167F503B34D91DD4A3" originalValue="Jörgensen" pageId="null" pageNumber="100">Joergensen</normalizedToken>
et al. 1958), aus Finnland (Sorsa 1962), aus der Schweiz (Hess 1953), von zahlreichen Fundstellen in Polen (Tomaszewski 1959), aus Nordnorwegen (Laane 1967), aus Holland (Gadella und Kliphuis 1968). 
<emphasis id="CD05551EB90E59BC8D874E1875939A0A" italics="true" pageId="null" pageNumber="100">2n</emphasis>
= 
<emphasis id="8764861839072E4EDA1A9696150167C2" italics="true" pageId="null" pageNumber="100">28:</emphasis>
Material aus Island (Nygren in 
<normalizedToken id="E71AA19B850A1418C942CF98FCDB41EA" originalValue="Löve" pageId="null" pageNumber="100">Loeve</normalizedToken>
und 
<normalizedToken id="A75B93A66F3E10CDD8706C2154127A76" originalValue="Löve" pageId="null" pageNumber="100">Loeve</normalizedToken>
1948), 7 Sippen aus Japan (Hara und Kurosawa 1956). 
<emphasis id="79FC1DEECD80CA2F76E262A0CECEB4B4" italics="true" pageId="null" pageNumber="100">2n</emphasis>
= 
<emphasis id="FE6D5638901E09BE6B33AF67BAA9212E" italics="true" pageId="null" pageNumber="100">56:</emphasis>
Material aus Island (Nygren in 
<normalizedToken id="AE2CA70CF66D0D1D81A1FF3955535FB2" originalValue="Löve" pageId="null" pageNumber="100">Loeve</normalizedToken>
und 
<normalizedToken id="2D0A91D84EA3DC222E235144F8B09D9A" originalValue="Löve" pageId="null" pageNumber="100">Loeve</normalizedToken>
1948). Weitere Angaben vgl. Harper (1957) und 
<normalizedToken id="0EFB73F123B049C5649145F130D47698" originalValue="Löve" pageId="null" pageNumber="100">Loeve</normalizedToken>
und 
<normalizedToken id="F05A9A0F991BF95A28623E624164D6AB" originalValue="Löve" pageId="null" pageNumber="100">Loeve</normalizedToken>
(1961).
</paragraph>
<paragraph id="B0BA002AFA0BBDC93CDA6692F9509BFD" pageId="null" pageNumber="100">
<emphasis id="BBCE35CD2E0BECC0EDA4425FF4E9FFCA" italics="true" pageId="null" pageNumber="100">Standort.</emphasis>
Kollin, montan, subalpin, seltener alpin. Nasse, feuchte bis trockene, humose 
<normalizedToken id="8EE70154DB31CBFC1F265BFC97B7DD98" originalValue="Böden" pageId="null" pageNumber="100">Boeden</normalizedToken>
. In den untern Lagen 
<normalizedToken id="152386AC7AAC133AB51B409518B0C85A" originalValue="düngerfliehend" pageId="null" pageNumber="100">duengerfliehend</normalizedToken>
. Spezielle 
<normalizedToken id="0747E87389EF995CE5410E1CF49A7D47" originalValue="Ansprüche" pageId="null" pageNumber="100">Ansprueche</normalizedToken>
, die die 
<normalizedToken id="37D994A54FF9A7D93B13738AFBBBAC7F" originalValue="merkwürdige" pageId="null" pageNumber="100">merkwuerdige</normalizedToken>
Verbreitung im Gebiet 
<normalizedToken id="96FCB03063661B8FE8F42B12F9363FD0" originalValue="erklären" pageId="null" pageNumber="100">erklaeren</normalizedToken>
, noch unbekannt. Mager- und 
<normalizedToken id="C51E5F183B566E77823EA404A3A54024" originalValue="Naßwiesen" pageId="null" pageNumber="100">Nasswiesen</normalizedToken>
; 
<normalizedToken id="3E85F8FF9A5501E7610CC8701FCE3A72" originalValue="Viehlägerstellen" pageId="null" pageNumber="100">Viehlaegerstellen</normalizedToken>
im Alpengebiet.
</paragraph>
<paragraph id="852F94498FC5855AC9C088B9DF8E8D47" pageId="null" pageNumber="100">
<emphasis id="31BBB426218021E6559A1DA61057582D" italics="true" pageId="null" pageNumber="100">Verbreitung. Eurasiatische Pflanze:</emphasis>
Ganz Europa, 
<normalizedToken id="7F2950366CB326DD4CDFBFAF1DCFDE8D" originalValue="nordwärts" pageId="null" pageNumber="100">nordwaerts</normalizedToken>
bis 71° NB, Asien (
<normalizedToken id="B8BDDEA4322250466064E88B067E0FD9" originalValue="nördlich" pageId="null" pageNumber="100">noerdlich</normalizedToken>
des Himalaja), in Nordamerika (zwischen 38 und 50° NB) wahrscheinlich eingeschleppt, 
<normalizedToken id="EC5083D34F58641AA1771239618B8F12" originalValue="Grönland" pageId="null" pageNumber="100">Groenland</normalizedToken>
; auch aus Nordafrika, Abessinien, dem Kapland und Neuseeland angegeben. Genauere Angaben 
<normalizedToken id="66D20D069B78CF89AE8B4D10FDFE03FB" originalValue="über" pageId="null" pageNumber="100">ueber</normalizedToken>
die Verbreitung nur nach monographischen Studien dieser polymorphen Artengruppe 
<normalizedToken id="CBCFE5ABFBAA219CCA13F494F50BB887" originalValue="möglich" pageId="null" pageNumber="100">moeglich</normalizedToken>
. Verbreitungskarte von Meusel (1965). - Im Gebiet: 
<normalizedToken id="0C3CC915485FBD0AF869410FE24A855F" originalValue="Föhntäler" pageId="null" pageNumber="100">Foehntaeler</normalizedToken>
, Zentral- und 
<normalizedToken id="1BE08CE7C9E5DF1050C77235B5F6D888" originalValue="Südalpen" pageId="null" pageNumber="100">Suedalpen</normalizedToken>
, 
<normalizedToken id="08070271A8062593649AD54B3E8B3179" originalValue="häufig" pageId="null" pageNumber="100">haeufig</normalizedToken>
; auch verschleppt.
</paragraph>
</subSubSection>
