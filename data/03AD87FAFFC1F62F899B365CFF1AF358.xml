<paragraph id="8BBB36ECFFC1F62F8BFB377DFBF5FC19" blockId="5.[740,1334,752,1176]" box="[741,1104,865,898]" pageId="5" pageNumber="63">This species is monotypic.</paragraph>
</subSubSection>
<subSubSection id="C31E6567FFC1F62F8BFB378EFB4FFC62" pageId="5" pageNumber="63" type="distribution">
<caption id="DF7B6664FFC1F62F8BFB378EFB4FFC62" inLine="true" pageId="5" pageNumber="63" targetBox="[187,191,3242,3267]" targetPageId="5">
<paragraph id="8BBB36ECFFC1F62F8BFB378EFB4FFC62" blockId="5.[740,1334,752,1176]" pageId="5" pageNumber="63">
<emphasis id="B970EAFEFFC1F62F8BFB378EFC30FC30" bold="true" box="[741,917,914,939]" pageId="5" pageNumber="63">Distribution.</emphasis>
Malay Peninsula, N &amp; W Sumatra, and Borneo; presence in NE 
<collectingCountry id="F313767CFFC1F62F8DF237A9FA93FC49" box="[1260,1334,949,978]" name="India" pageId="5" pageNumber="63">India</collectingCountry>
(
<collectingRegion id="49C0F80EFFC1F62F8BEC37C0FBA4FC62" box="[754,1025,988,1017]" country="India" name="Arunachal Pradesh" pageId="5" pageNumber="63">Arunachal Pradesh</collectingRegion>
