Hosts. 
<taxonomicName id="4C79DCC1FF89FF92F02BFBFAEC6BFB92" authorityName="Stroyan" authorityYear="1950" box="[317,603,1103,1129]" class="Insecta" family="Aphididae" genus="Metopeurum" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="399" phylum="Arthropoda" rank="species" species="fuscoviride">
