<collectingRegion id="7B57F7E02A01F325F93DFAFD6612FA30" box="[1742,1860,1394,1427]" country="Venezuela" name="Miranda" pageId="18" pageNumber="541">Miranda</collectingRegion>
and probably 
<collectingRegion id="7B57F7E02A01F325F7E6FAFD6925FA30" box="[2069,2163,1394,1427]" country="Venezuela" name="Vargas" pageId="18" pageNumber="541">Vargas</collectingRegion>
, and on both sides of the Venezuelan Andesin the states of 
<collectingRegion id="7B57F7E02A01F325F8EEFA156633FA18" box="[1821,1893,1434,1467]" country="Venezuela" name="Zulia" pageId="18" pageNumber="541">Zulia</collectingRegion>
, 
<collectingRegion id="7B57F7E02A01F325F887FA1566B7FA18" box="[1908,2017,1434,1467]" country="Venezuela" name="Tachira" pageId="18" pageNumber="541">Tachira</collectingRegion>
, 
<collectingRegion id="7B57F7E02A01F325F801FA156901FA18" box="[2034,2135,1434,1467]" country="Venezuela" name="Merida" pageId="18" pageNumber="541">Mérida</collectingRegion>
, 
<collectingRegion id="7B57F7E02A01F325F795FA156999FA18" box="[2150,2255,1434,1467]" country="Venezuela" name="Trujillo" pageId="18" pageNumber="541">Trujillo</collectingRegion>
, 
<collectingRegion id="7B57F7E02A01F325F72CFA15682BFA18" box="[2271,2429,1434,1467]" country="Venezuela" name="Portuguesa" pageId="18" pageNumber="541">Portuguesa</collectingRegion>
, 
<collectingRegion id="7B57F7E02A01F325F678FA1568B3FA18" box="[2443,2533,1434,1467]" country="Venezuela" name="Apure" pageId="18" pageNumber="541">Apure</collectingRegion>
, and 
<collectingRegion id="7B57F7E02A01F325FA8AFA4664B4FA41" box="[1401,1506,1481,1506]" country="Venezuela" name="Barinas" pageId="18" pageNumber="541">Barinas</collectingRegion>
, in the E in the piedmont and lowland forests of San Camilo and Ticoporo, and in the Win the piedmont forest around S Lake Maracaibo to the Sierra de Perija). A. h. brunneus Gray, 1871 — N 
<collectingCountry id="C18479922A01F325F8EBF99766F7F992" box="[1816,1953,1560,1585]" name="Colombia" pageId="18" pageNumber="541">Colombia</collectingCountry>
in the departments of 
<collectingRegion id="7B57F7E02A01F325F716F9976825F992" box="[2277,2419,1560,1585]" country="Colombia" name="Antioquia" pageId="18" pageNumber="541">Antioquia</collectingRegion>
, Bolivar, and 
<collectingRegion id="7B57F7E02A01F325FA8BF9B96483F9F4" box="[1400,1493,1590,1623]" country="Colombia" name="Caldas" pageId="18" pageNumber="541">Caldas</collectingRegion>
, between the lower rios 
<collectingRegion id="7B57F7E02A01F325F8DFF9B966D4F9F4" box="[1836,1922,1590,1623]" country="Colombia" name="Cauca" pageId="18" pageNumber="541">Cauca</collectingRegion>
and 
<collectingRegion id="7B57F7E02A01F325F83AF9B96933F9F4" box="[1993,2149,1590,1623]" country="Colombia" name="Magdalena" pageId="18" pageNumber="541">Magdalena</collectingRegion>
.
</paragraph>
</caption>
