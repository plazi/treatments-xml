(from the right bank of the Rio 
<collectingRegion id="7B57F7E02A01F325F771FBEF6848FB22" box="[2178,2334,1120,1153]" country="Colombia" name="Magdalena" pageId="18" pageNumber="541">Magdalena</collectingRegion>
