<subSubSection id="F1896A892A01F325F811FC65693CF9F4" pageId="18" pageNumber="541" type="multiple">
<caption id="EDEC698A2A01F325F811FC65693CF9F4" ID-DOI="http://doi.org/10.5281/zenodo.5727261" ID-Zenodo-Dep="5727261" httpUri="https://zenodo.org/record/5727261/files/figure.png" inLine="true" pageId="18" pageNumber="541" targetBox="[1405,1986,778,1184]" targetPageId="18">
<paragraph id="B92C39022A01F325F811FC65693CF9F4" blockId="18.[2018,2605,770,1192]" lastBlockId="18.[1392,2602,1198,3471]" pageId="18" pageNumber="541">
<emphasis id="8BE7E5102A01F325F811FC656824FBA8" box="[2018,2418,1002,1035]" pageId="18" pageNumber="541">Subspecies and Distribution.</emphasis>
A. h. 
<taxonomicName id="7E9342812A01F325F7B2FB9569FDFB90" box="[2113,2219,1050,1075]" class="Mammalia" family="Atelidae" genus="Ateles" kingdom="Animalia" order="Primates" pageId="18" pageNumber="541" phylum="Chordata" rank="species" species="hybridus">hybridus</taxonomicName>
