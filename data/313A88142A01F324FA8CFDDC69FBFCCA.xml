<collectingRegion id="7B57F7E02A01F325F966FB5A67A6FB55" box="[1685,1776,1237,1270]" country="Colombia" name="Caldas" pageId="18" pageNumber="541">Caldas</collectingRegion>
and 
<collectingRegion id="7B57F7E02A01F325F8CFFB5A6958FB55" box="[1852,2062,1237,1270]" country="Colombia" name="Cundinamarca" pageId="18" pageNumber="541">Cundinamarca</collectingRegion>
; two populations on the slopes of the Cordillera Oriental on the Venezuelan border (one in the Rio Catatumbo watershed in the 
<collectingRegion id="7B57F7E02A01F325FA2AFAAB66FDFAE6" box="[1497,1963,1316,1349]" country="Colombia" name="Norte de Santander" pageId="18" pageNumber="541">Norte de Santander Department</collectingRegion>
