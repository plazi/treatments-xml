<subSubSection id="76944B68CF820EB94AF2480C7AD7111A" pageId="null" pageNumber="806" type="description">
<paragraph id="22F2FEC96BDEDA876CCB9A2C000DEE56" pageId="null" pageNumber="806">
Unterscheidet sich von 
<taxonomicName id="6C4AF33076D03EB6ACB9CB67155E0192" class="Gastropoda" family="Xenophoridae" genus="Stellaria" kingdom="Animalia" order="Littorinimorpha" pageId="null" pageNumber="806" phylum="Mollusca" rank="species" species="graminea">
<emphasis id="3E79CA74564DB1223527808C93B0A232" italics="true" pageId="null" pageNumber="806">S. graminea</emphasis>
</taxonomicName>
(Nr. 7) durch folgende Merkmale: 
<normalizedToken id="55FD2DEDE248F9E263EB076CDA0A12D4" originalValue="Blätter" pageId="null" pageNumber="806">Blaetter</normalizedToken>
bis 3 cm lang, auch am Grunde kahl; 
<emphasis id="B30B5C7C1961F29FD67301BF4E57B471" italics="true" pageId="null" pageNumber="806">
<normalizedToken id="35BCF68E302770ECF99A8A0ADE935E24" originalValue="Blätter" pageId="null" pageNumber="806">Blaetter</normalizedToken>
im 
<normalizedToken id="145897B7AF009909B2C87A4A3C183C36" originalValue="Blütenstand" pageId="null" pageNumber="806">Bluetenstand</normalizedToken>
ganz kahl; 
<normalizedToken id="4FCF5FCE17E452C71F0BF26963C69939" originalValue="Kelchblätter" pageId="null" pageNumber="806">Kelchblaetter</normalizedToken>
5-7 mm lang;
</emphasis>
<normalizedToken id="E5E027A5BA6D5E7B74473AB3C742BC42" originalValue="Kronblätter" pageId="null" pageNumber="806">Kronblaetter</normalizedToken>
1- 
<normalizedToken id="4383BFC8F1E6943FC7C3A4E11484979E" originalValue="1½" pageId="null" pageNumber="806">11/2</normalizedToken>
-mal so lang wie die 
<normalizedToken id="659541D8066C2BD8DC971C682A685B8D" originalValue="Kelchblätter" pageId="null" pageNumber="806">Kelchblaetter</normalizedToken>
. - 
<normalizedToken id="28E02F744F45881623CAAD18421220D2" originalValue="Blüte" pageId="null" pageNumber="806">Bluete</normalizedToken>
: 
<normalizedToken id="85F1D3C101EFE482C7296550B63AC731" originalValue="Später" pageId="null" pageNumber="806">Spaeter</normalizedToken>
<normalizedToken id="D8631F054EA8709EEF219F3F1AC4D42E" originalValue="Frühling" pageId="null" pageNumber="806">Fruehling</normalizedToken>
und 
<normalizedToken id="DC86FDE20859D8207326EAFD88389690" originalValue="früher" pageId="null" pageNumber="806">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="C19B002C1B31F3DDCB6F897917F41393" pageId="null" pageNumber="806">
<emphasis id="89F7FD618256635C6A13A6808F364AC1" italics="true" pageId="null" pageNumber="806">Zytologische Angaben. 2n ca. 130:</emphasis>
Material aus Schweden (Peterson 1936) und England (Blackburn und Morton 1957).
</paragraph>
<paragraph id="F5CA473F427D1B3198D8466020532DD7" pageId="null" pageNumber="806">
<emphasis id="6070E5042C4988AE982A29E5FAB8423F" italics="true" pageId="null" pageNumber="806">Standort.</emphasis>
Kollin, montan und subalpin. Nasse, kalkarme, moorige 
<normalizedToken id="4B6D4447CEBFC77A0319C1B51B8D41F4" originalValue="Böden" pageId="null" pageNumber="806">Boeden</normalizedToken>
. Flachmoore, vor allem in 
<normalizedToken id="CD8CC68B0F478A256B63A850721939DF" originalValue="Braunseggensümpfen" pageId="null" pageNumber="806">Braunseggensuempfen</normalizedToken>
.
</paragraph>
<paragraph id="BFBF94E851E4C2C8B7C6002CF43B9404" pageId="null" pageNumber="806">
<emphasis id="4CB02D73F9B2CD3A0E3A81BFB092340B" italics="true" pageId="null" pageNumber="806">Verbreitung. Eurosibirische Pflanze:</emphasis>
<taxonomicName id="7B2E303D4ED5D88AFAC9FB6345344CFA" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="806" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
(
<normalizedToken id="66DA0C1A845A91A0131F8371630ADF38" originalValue="nordwärts" pageId="null" pageNumber="806">nordwaerts</normalizedToken>
bis Irland, 
<normalizedToken id="1DC54D87ADC59D4A8E10A2F92F27DE1E" originalValue="Südskandinavien" pageId="null" pageNumber="806">Suedskandinavien</normalizedToken>
; 
<normalizedToken id="84E47C4BF13D441E25A24DF064C0D4AF" originalValue="südwärts" pageId="null" pageNumber="806">suedwaerts</normalizedToken>
bis 
<normalizedToken id="3889A6CE289BCEDF216C93C913908151" originalValue="Pyrenäen" pageId="null" pageNumber="806">Pyrenaeen</normalizedToken>
, Korsika, Ligurien, Bulgarien); 
<normalizedToken id="193FF42670D37667964991BEB7CB4888" originalValue="gemäßigtes" pageId="null" pageNumber="806">gemaessigtes</normalizedToken>
Asien. - Im Gebiet: Seeland (erloschen?), 
<normalizedToken id="18CAD85CDC69762FBFAC564D31FE8F15" originalValue="Elsaß" pageId="null" pageNumber="806">Elsass</normalizedToken>
(Gebiet von Colmar), Schwarzwald, deutsches Bodenseegebiet (erloschen?), Aostatal (Champorcher?), Bergamasker Alpen (Schilpario); selten.
</paragraph>
</subSubSection>
