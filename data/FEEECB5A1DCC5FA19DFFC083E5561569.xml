</taxonomicName>
vs. 65-120 
<normalizedToken id="7EFA0B86AA3B8B2F822DACAE0405F17D" originalValue="μm">μm</normalizedToken>
in 
<taxonomicName id="F0FA500740940DFEBF3860BB16214E29" class="Entomophthoromycetes" family="Dalceridae" genus="Ca." higherTaxonomySource="CoL" kingdom="Fungi" lsidName="Ca. jiangsuense" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="jiangsuense">
<emphasis id="B822B43606B96495BD66C4509F0B28ED" italics="true" pageId="0" pageNumber="139">Ca. jiangsuense</emphasis>
