<taxonomicName id="A5E4CC193C3479030E70565008DBB2D4" authority="B.Huang &amp; Y.Nie, 2020" authorityName="B. Huang &amp; Y. Nie" authorityYear="2022" class="Entomophthoromycetes" family="Ancylistaceae" genus="Capillidium" higherTaxonomySource="GBIF" kingdom="Fungi" lsidName="Capillidium jiangsuense" order="Entomophthorales" pageId="0" pageNumber="139" phylum="Entomophthoromycota" rank="species" species="jiangsuense">
<emphasis id="83DCB01371F28219CC3B18368D8C34E5" italics="true" pageId="0" pageNumber="139">Capillidium jiangsuense</emphasis>
