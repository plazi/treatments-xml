<bibRefCitation id="A75D4B2AFFC0167B23D6E9A1FBFBFC32" author="ANLAS S" box="[898,1029,914,936]" pageId="2" pageNumber="193" pagination="83 - 91" refId="ref9604" refString="ANLAS S. (2013): A new species and additional records of the genus Lathrobium GRAVENHORST from Palaearctic region [sic] (Coleoptera: Staphylinidae: Paederinae). - Revue Suisse de Zoologie 120 (1): 83 - 91." type="journal article" year="2013">ANLAŞ 2013</bibRefCitation>
