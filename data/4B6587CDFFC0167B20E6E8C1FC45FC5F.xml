<taxonomicName id="04CC4D58FFC0167B2108E946FDDFFC11" authorityName="SCHULKE" authorityYear="1990" box="[348,545,885,907]" class="Insecta" family="Staphylinidae" genus="Lathrobium" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="193" phylum="Arthropoda" rank="species" species="wrasei">
