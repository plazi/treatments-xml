<taxonomicName id="C7C97DC28EE0FF6E493750B1FE35F843" box="[263,400,1949,1971]" class="Insecta" family="Dryinidae" genus="Anteon" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="174" pageNumber="175" phylum="Arthropoda" rank="species" species="sylvaticum">
