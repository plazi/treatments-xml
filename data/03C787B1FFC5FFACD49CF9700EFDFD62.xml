<subSubSection id="C374652CFFC5FFAFD4CCF8180F53FE8E" lastPageId="57" lastPageNumber="58" pageId="56" pageNumber="57" type="diagnosis">
<paragraph id="8BD136A7FFC5FFAED4CCF81808C4F862" blockId="56.[151,1437,1863,2034]" pageId="56" pageNumber="57">
<emphasis id="B91AEAB5FFC5FFAED4CCF8180C1AF85E" bold="true" box="[199,322,1971,1997]" pageId="56" pageNumber="57">Diagnosis.</emphasis>
Males of 
<taxonomicName id="4C6E4D24FFC5FFAED5BFF8180F08F85E" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" box="[436,592,1971,1997]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="56" pageNumber="57" phylum="Arthropoda" rank="species" species="mesa" status="sp. n.">
<emphasis id="B91AEAB5FFC5FFAED5BFF8180F08F85E" box="[436,592,1971,1997]" italics="true" pageId="56" pageNumber="57">Tenedos mesa</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFC5FFAED65CF8180FCFF85E" bold="true" box="[599,663,1971,1997]" pageId="56" pageNumber="57">
<taxonomicNameLabel id="A22957CEFFC5FFAED65CF8180FCFF85E" box="[599,663,1971,1997]" pageId="56" pageNumber="57" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
, resemble those of 
<taxonomicName id="4C6E4D24FFC5FFAED778F81F09A6F85E" authority="Jocque &amp; Baert, 2002" authorityName="Jocque &amp; Baert" authorityYear="2002" box="[883,1278,1971,1998]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="56" pageNumber="57" phylum="Arthropoda" rank="species" species="peckorum">
<emphasis id="B91AEAB5FFC5FFAED778F81F0EA5F85E" box="[883,1021,1971,1997]" italics="true" pageId="56" pageNumber="57">T. peckorum</emphasis>
<bibRefCitation id="EFFF4B56FFC5FFAED00EF81809A6F85E" author="Jocque, R. &amp; Baert, L." box="[1029,1278,1971,1998]" pageId="56" pageNumber="57" pagination="67 - 173" refId="ref79332" refString="Jocque, R. &amp; Baert, L. (2002) A revision of the Neotropical spider genera Tenedos O. P. - Cambridge and Ishania Chamberlin (Araneae, Zodariidae). Bulletin de l'Institut Royal des Sciences Naturelles de Belgique, Entomologie, 72, 67 - 173." type="journal article" year="2002">Jocqué &amp; Baert, 2002</bibRefCitation>
</taxonomicName>
, 
<taxonomicName id="4C6E4D24FFC5FFAED102F81F082BF85E" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" box="[1289,1395,1971,1997]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="56" pageNumber="57" phylum="Arthropoda" rank="species" species="quipile" status="sp. n.">
<emphasis id="B91AEAB5FFC5FFAED102F81F082BF85E" box="[1289,1395,1971,1997]" italics="true" pageId="56" pageNumber="57">T. quipile</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFC5FFAED170F8180DF6F862" bold="true" pageId="56" pageNumber="57">
<taxonomicNameLabel id="A22957CEFFC5FFAED170F8180DF6F862" pageId="56" pageNumber="57" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
, 
<taxonomicName id="4C6E4D24FFC5FFAED4B6F8730C17F862" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" box="[189,335,2007,2033]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="56" pageNumber="57" phylum="Arthropoda" rank="species" species="guacharos" status="sp. n.">
<emphasis id="B91AEAB5FFC5FFAED4B6F8730C17F862" box="[189,335,2007,2033]" italics="true" pageId="56" pageNumber="57">T. guacharos</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFC5FFAED55CF87C0CC0F862" bold="true" box="[343,408,2007,2033]" pageId="56" pageNumber="57">
<taxonomicNameLabel id="A22957CEFFC5FFAED55CF87C0CC0F862" box="[343,408,2007,2033]" pageId="56" pageNumber="57" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
, and 
<taxonomicName id="4C6E4D24FFC5FFAED5DCF8730F0DF862" authority="Martínez &amp; Brescovit &amp; Quijano, 2022" authorityName="Martínez &amp; Brescovit &amp; Quijano" authorityYear="2022" box="[471,597,2007,2033]" class="Arachnida" family="Zodariidae" genus="Tenedos" kingdom="Animalia" order="Araneae" pageId="56" pageNumber="57" phylum="Arthropoda" rank="species" species="henrardi" status="sp. n.">
<emphasis id="B91AEAB5FFC5FFAED5DCF8730F0DF862" box="[471,597,2007,2033]" italics="true" pageId="56" pageNumber="57">T. henrardi</emphasis>
</taxonomicName>
<emphasis id="B91AEAB5FFC5FFAED656F87C0FC5F862" bold="true" box="[605,669,2007,2033]" pageId="56" pageNumber="57">
<taxonomicNameLabel id="A22957CEFFC5FFAED656F87C0FC5F862" box="[605,669,2007,2033]" pageId="56" pageNumber="57" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
, by having complex retrolateral tibial apophysis (RTA) (see 
<bibRefCitation id="EFFF4B56FFC5FFAED145F87C08C4F862" author="Jocque, R. &amp; Baert, L." box="[1358,1436,2007,2033]" pageId="56" pageNumber="57" pagination="67 - 173" refId="ref79332" refString="Jocque, R. &amp; Baert, L. (2002) A revision of the Neotropical spider genera Tenedos O. P. - Cambridge and Ishania Chamberlin (Araneae, Zodariidae). Bulletin de l'Institut Royal des Sciences Naturelles de Belgique, Entomologie, 72, 67 - 173." type="journal article" year="2002">Jocqué</bibRefCitation>
</paragraph>
<paragraph id="8BD136A7FFC4FFAFD49CFF3C0F53FE8E" blockId="57.[151,1436,151,285]" pageId="57" pageNumber="58">
&amp; Baert, 2002: 111, fig. 29A–B; figs 34C–F; 36A–D; 37A–B; 38C–F; 39C–F; 40A–D; 42A–D; 43A–B; 44A–F; 46A–D; 47A–B), but can be distinguished by median apophysis (MA) with straight, short posterior branch (pMA); large retrolateral tibial apophysis, short, squared posterior branch (pRTA); small, rounded projection on embolus base (EB) (
<figureCitation id="13552A22FFC4FFAFD51EFEA80CC6FE8E" box="[277,414,259,285]" captionStart="FIGURE 38" captionStartId="57.[151,250,1606,1630]" captionTargetBox="[151,1420,309,1571]" captionTargetId="figure-70@57.[151,1435,309,1582]" captionTargetPageId="57" captionText="FIGURE 38. Tenedos mesa sp. n.A–B. Male habitus (ICN-Ar-12336):A. Dorsal view. B. Ventral view. C–F. Male palp: C. Ventral view. D. Prolateral view. E. Retroventral view. F. Retrolateral view. Scale bars: A–B: 2mm; C–D: 200µm; E–F: 500µm." figureDoi="http://doi.org/10.5281/zenodo.6520862" httpUri="https://zenodo.org/record/6520862/files/figure.png" pageId="57" pageNumber="58">Figs 38C–F</figureCitation>
; 
<figureCitation id="13552A22FFC4FFAFD5A2FEA80CA7FE8E" box="[425,511,259,285]" captionStart="FIGURE 40" captionStartId="60.[151,250,1853,1877]" captionTargetBox="[282,1315,187,1829]" captionTargetId="figure-27@60.[271,1316,181,1829]" captionTargetPageId="60" captionText="FIGURE 40. Tenedos mesa sp. n. A–B. Male palp (ICN-Ar-12336): A. Ventral view (arrow indicates the sclerotized process). B. Retrolateral view. Tenedos guacharos sp. n. C–D. Male palp (IAvH-I-2972): C. Ventral view. D. Retrolateral view. Scale bars: A–D: 200µm. Abbreviations: ApC, appendix of the conductor; aRTA, anterior branch of the retrolateral tibial apophysis; aMA, anterior branch of the median apophysis; BEP, basal embolar process; E, embolus; pRTA, posterior branch of the retrolateral tibial apophysis; pMA, posterior branch of the median apophysis; VTA, ventral tibial apophysis." figureDoi="http://doi.org/10.5281/zenodo.6520868" httpUri="https://zenodo.org/record/6520868/files/figure.png" pageId="57" pageNumber="58">40A–B</figureCitation>
).
</paragraph>
