<subSubSection id="C3136559FFC6FFC7F7EEFDB9EF42FD8C" pageId="3" pageNumber="410" type="discussion">
<paragraph id="8BB636D2FFC6FFC7F7EEFDB9EF42FD8C" blockId="3.[2084,2670,400,826]" pageId="3" pageNumber="410">Closely related to M. erinifrons, the divergence of these two species is a relatively recent event. Monotypic.</paragraph>
</subSubSection>
<subSubSection id="C3136559FFC6FFC7F7EFFD37EEF2FD12" pageId="3" pageNumber="410" type="distribution">
<caption id="DF76665AFFC6FFC7F7EFFD37EEF2FD12" ID-DOI="http://doi.org/10.5281/zenodo.6514401" ID-Zenodo-Dep="6514401" httpUri="https://zenodo.org/record/6514401/files/figure.png" inLine="true" pageId="3" pageNumber="410" targetBox="[1466,2060,408,824]" targetPageId="3">
<paragraph id="8BB636D2FFC6FFC7F7EFFD37EEF2FD12" blockId="3.[2084,2670,400,826]" pageId="3" pageNumber="410">
<emphasis id="B97DEAC0FFC6FFC7F7EFFD37EEEEFD64" bold="true" box="[2084,2259,640,669]" pageId="3" pageNumber="410">Distribution.</emphasis>
S 
<collectingCountry id="F31E7642FFC6FFC7F6C7FD37EF5DFD64" box="[2316,2400,640,669]" name="China" pageId="3" pageNumber="410">China</collectingCountry>
(
<collectingRegion id="49CDF830FFC6FFC7F6B4FD37EFD0FD64" box="[2431,2541,640,669]" country="China" name="Yunnan" pageId="3" pageNumber="410">Yunnan</collectingRegion>
