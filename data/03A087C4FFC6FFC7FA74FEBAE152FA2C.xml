<collectingCountry id="F31E7642FFC6FFC7F7EEFD16EE96FD3B" box="[2085,2219,673,706]" name="Myanmar" pageId="3" pageNumber="410">Myanmar</collectingCountry>
; possibly SE Xizang, NE 
<collectingCountry id="F31E7642FFC6FFC7F5D7FD16EC5BFD3B" box="[2588,2662,673,706]" name="India" pageId="3" pageNumber="410">India</collectingCountry>
