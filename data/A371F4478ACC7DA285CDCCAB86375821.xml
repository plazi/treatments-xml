<emphasis id="694B2DAE655ED2966EAD0BD541AF7A1F" italics="true" pageId="null" pageNumber="92">Polyanthemus</emphasis>
<normalizedToken id="9D2A6D840E933162CA37A37671999550" originalValue="ähnlicher" pageId="null" pageNumber="92">aehnlicher</normalizedToken>
<normalizedToken id="5B4758141927E16E8E5DC21432FFDFB8" originalValue="Hahnenfuß" pageId="null" pageNumber="92">Hahnenfuss</normalizedToken>
</paragraph>
