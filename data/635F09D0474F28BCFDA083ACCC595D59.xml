<subSubSection id="595AB63A18004EB6FDBC6347CCB00080" pageId="null" pageNumber="590" type="description">
<paragraph id="D8BD49A667A36A340F2D8E883A9F592D" pageId="null" pageNumber="590">
Stengel 
<normalizedToken id="B8169A7BA379A0040706EE97B04EB9DE" originalValue="beblättert" pageId="null" pageNumber="590">beblaettert</normalizedToken>
, 
<normalizedToken id="550CAAA20680C1290796C9AFEDEC7F6B" originalValue="vielköpfig" pageId="null" pageNumber="590">vielkoepfig</normalizedToken>
. 
<normalizedToken id="6D8047E45F0835414CDA1906A38E37AB" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
zylindrisch bis 
<normalizedToken id="22632EA12C12E6BD8D98442DF1B11983" originalValue="glockenförmig" pageId="null" pageNumber="590">glockenfoermig</normalizedToken>
. 
<normalizedToken id="54B8E1C7282E70090AB8092052901F2B" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
2reihig, die 
<normalizedToken id="18CF769278CF8E1E9D7BD7D358E35C1B" originalValue="äußern" pageId="null" pageNumber="590">aeussern</normalizedToken>
schmal lanzettlich. Boden des 
<normalizedToken id="CEC3050BDE4A392FDC463E43E9DF088A" originalValue="Blütenkopfes" pageId="null" pageNumber="590">Bluetenkopfes</normalizedToken>
ohne 
<normalizedToken id="6AC0E855CDFE6859DD24E044B9956484" originalValue="Spreublätter" pageId="null" pageNumber="590">Spreublaetter</normalizedToken>
, kahl. 
<normalizedToken id="9AA87C3B556071923430DC90DA0804F2" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
hellgelb; 
<normalizedToken id="C2088F9801E52B4B8B7B6EDC1E965515" originalValue="Kronröhre" pageId="null" pageNumber="590">Kronroehre</normalizedToken>
<normalizedToken id="3889557ACEFB7168994614F9EE871765" originalValue="außen" pageId="null" pageNumber="590">aussen</normalizedToken>
kurz behaart. 
<normalizedToken id="D2473923489A7395487A7B34E2E878C1" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
<normalizedToken id="7CAD9B56A61B3F179ECBFA833503D95E" originalValue="spindelförmig" pageId="null" pageNumber="590">spindelfoermig</normalizedToken>
, wenig abgeflacht, 
<emphasis id="A5D3297A9E564A954AF7814A940AC6FC" italics="true" pageId="null" pageNumber="590">
in der zylindrischen 
<normalizedToken id="3778318A1B3D668DCCF5559971E1C431" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
bleibend
</emphasis>
, ohne Schnabel, 
<emphasis id="2A0B0FEDC06D595ED9203E52380F60E0" italics="true" pageId="null" pageNumber="590">
ohne 
<taxonomicName id="176396966D769A20EEA246901F30D832" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
</emphasis>
.
</paragraph>
<paragraph id="C023170D81CB11BB18AE7D2A9496E093" pageId="null" pageNumber="590">
Die Gattung 
<taxonomicName id="29DB8B48AD9C85ED7949C84C32DB9A9F" class="Magnoliopsida" family="Asteraceae" genus="Lapsana" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="genus">
<emphasis id="D7663379880E56328BC52368538C93F4" italics="true" pageId="null" pageNumber="590">Lapsana</emphasis>
</taxonomicName>
<normalizedToken id="A01FE11FF88D7EBF041164052940A352" originalValue="umfaßt" pageId="null" pageNumber="590">umfasst</normalizedToken>
etwa 
<emphasis id="D5E6121EBE346A08CF90F01E22C1FB8F" italics="true" pageId="null" pageNumber="590">10 Arten</emphasis>
und hat ihre 
<emphasis id="BD0DF0980582F5780325A736110D3330" italics="true" pageId="null" pageNumber="590">Hauptverbreitung im Mittelmeergebiet und in Westasien</emphasis>
.
</paragraph>
