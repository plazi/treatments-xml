<taxonomicName id="4C034D45FFFBFF92FF76F9DEFE9D51F7" authorityName="Sundevall" authorityYear="1833" box="[199,336,1655,1682]" class="Arachnida" family="Thomisidae" kingdom="Animalia" order="Araneae" pageId="14" pageNumber="13" phylum="Arthropoda" rank="family">Thomisidae</taxonomicName>
