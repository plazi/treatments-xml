<subSubSection id="CE21E6F898E61D8F3DE9C3011179FE35" pageId="null" pageNumber="92" type="description">
<paragraph id="691C80B58A139029D667DA8646160753" pageId="null" pageNumber="92">
Ausdauernd; 50-100 cm hoch. Stengel immer aufrecht, reich verzweigt, im untern Teil locker und anliegend behaart. Die ersten 5-7 
<normalizedToken id="D949A0B9B7F7BAF847055AC17B2892D1" originalValue="grundständigen" pageId="null" pageNumber="92">grundstaendigen</normalizedToken>
<normalizedToken id="670F8DD72C6FDB064494AC268E36E0DC" originalValue="Blätter" pageId="null" pageNumber="92">Blaetter</normalizedToken>
(
<normalizedToken id="4D858A53DA12D59BB56B4D331292375B" originalValue="Frühlingsblätter" pageId="null" pageNumber="92">Fruehlingsblaetter</normalizedToken>
) im 
<normalizedToken id="1A5C49DCE574CC509FE6ECD1182D7D48" originalValue="Umriß" pageId="null" pageNumber="92">Umriss</normalizedToken>
5 bis 7eckig, 
<emphasis id="F9E8AC8E4405BB198F9A75AE9DE3C9AF" italics="true" pageId="null" pageNumber="92">bis zum Stielansatz 3-5teilig; Mittelabschnitt bis 8 mm lang gestielt; alle Abschnitte noch mehrmals tief</emphasis>
(
<emphasis id="003C2E7FC48D3DC366C89262C8DA28F2" italics="true" pageId="null" pageNumber="92">bis auf</emphasis>
⅕) 
<emphasis id="F3860DD85A841691F8CFA85BD3C9DB1A" italics="true" pageId="null" pageNumber="92">geteilt;</emphasis>
Abschnitte 2. Ordnung grob und 
<normalizedToken id="B702C382B2B2D3E7D9B845CE6A44164C" originalValue="unregelmäßig" pageId="null" pageNumber="92">unregelmaessig</normalizedToken>
<normalizedToken id="39450CDDACDFFF3C86158533CD6FE8B6" originalValue="gezähnt" pageId="null" pageNumber="92">gezaehnt</normalizedToken>
; 
<emphasis id="B3BE6F16538693C365CAF711B09F2D7E" italics="true" pageId="null" pageNumber="92">
die Zipfel 
<normalizedToken id="1C95CF014FC5177E3384391535D5A88E" originalValue="überdecken" pageId="null" pageNumber="92">ueberdecken</normalizedToken>
sich meist.
</emphasis>
<normalizedToken id="E75872A4A50595A001E67FBCD329454B" originalValue="Grundständige" pageId="null" pageNumber="92">Grundstaendige</normalizedToken>
<normalizedToken id="942283BFB51BE58C6EBBFE0B33722486" originalValue="Sommerblätter" pageId="null" pageNumber="92">Sommerblaetter</normalizedToken>
, 
<normalizedToken id="1819F5062ACA1DC393B6452355DC9E3D" originalValue="Stengelblätter" pageId="null" pageNumber="92">Stengelblaetter</normalizedToken>
, 
<normalizedToken id="DD7C7DEB6DF3CE8AEB866BA8492F9C02" originalValue="Blüten" pageId="null" pageNumber="92">Blueten</normalizedToken>
und 
<normalizedToken id="F4A73B12B1E4A431B14E0B3BE0F3B90C" originalValue="Früchtchen" pageId="null" pageNumber="92">Fruechtchen</normalizedToken>
wie bei 
<taxonomicName id="12AC63DC83825D2D37C2E898ABBC6557" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="92" phylum="Tracheophyta" rank="species" species="nemorosus">
<emphasis id="257E6F9DFA4494795482690C4344E152" italics="true" pageId="null" pageNumber="92">R. nemorosus</emphasis>
</taxonomicName>
(Nr. 25b). - 
<normalizedToken id="98C5F7755440BCED436ACE46C82A47FE" originalValue="Blüte" pageId="null" pageNumber="92">Bluete</normalizedToken>
: 
<normalizedToken id="E1D59BD1D2BDCE8054F38FD2FC690580" originalValue="Später" pageId="null" pageNumber="92">Spaeter</normalizedToken>
<normalizedToken id="8C643714220C92AA51E00FACF8E90888" originalValue="Frühling" pageId="null" pageNumber="92">Fruehling</normalizedToken>
und 
<normalizedToken id="CCF8B0F17496314CBDCE55C0EBC3B513" originalValue="früher" pageId="null" pageNumber="92">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="9126D867BE6B9BE20966744CA60E1F5C" pageId="null" pageNumber="92">
<emphasis id="211AC47D2BB3B8DC5442B56801505E16" italics="true" pageId="null" pageNumber="92">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A90E5E1F01DABD6695CEB8434DF5D333" italics="true" pageId="null" pageNumber="92">16:</emphasis>
Material aus dem St.Galler Rheintal (Hess 1955).
</paragraph>
<paragraph id="6C94DFBC9850F7FEE3A932BF0D5322DD" pageId="null" pageNumber="92">
<emphasis id="F8E74990FB356A94135C22873332305B" italics="true" pageId="null" pageNumber="92">Standort.</emphasis>
Kollin, selten montan. Feuchte Wiesen (oft im Gebiet von 
<normalizedToken id="66A203AB1753F72A2462D6D00BCFE10E" originalValue="Auenwäldern" pageId="null" pageNumber="92">Auenwaeldern</normalizedToken>
), 
<normalizedToken id="9E93292D04308E14B6DA624AACD895BF" originalValue="Föhrenwälder" pageId="null" pageNumber="92">Foehrenwaelder</normalizedToken>
.
</paragraph>
<paragraph id="A08A42471E2CC1635261B30D88DB42E7" pageId="null" pageNumber="92">
<emphasis id="FE5184EC27E35D1767E4C4765616D0AF" italics="true" pageId="null" pageNumber="92">Verbreitung.</emphasis>
<normalizedToken id="183C0E4C97512819C8761D43FAC3F3CA" originalValue="Unvollständig" pageId="null" pageNumber="92">Unvollstaendig</normalizedToken>
bekannt. Im Gebiet: Rheintal zwischen Reichenau und Buchs, Walenseegebiet, Hochrhein, Badisches Grenzgebiet, 
<normalizedToken id="2BF4E98B886FBE22C26912609A220070" originalValue="Elsaß" pageId="null" pageNumber="92">Elsass</normalizedToken>
, Rhonetal; Aostatal (Ausgang des Tals von Cogne), Bergamasker Alpen (Val Brembana, Val Camonica).
</paragraph>
</subSubSection>
