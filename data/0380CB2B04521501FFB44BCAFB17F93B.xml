<taxonomicName id="4C2901BE04521501FC90489CFB13F93B" authority="Barnard, 1963" authorityName="Barnard" authorityYear="1963" box="[947,1272,1717,1743]" class="Gastropoda" family="Triphoridae" genus="Viriola" kingdom="Animalia" pageId="91" pageNumber="92" phylum="Mollusca" rank="species" species="thielei">
