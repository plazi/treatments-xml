<bibRefCitation id="EFB807CC04521501FE21489FFE8FF93B" author="Sowerby, G. B. III" box="[258,356,1717,1744]" pageId="91" pageNumber="92" pagination="125 - 127" refId="ref170187" refString="Sowerby, G. B. III (1921) New shells from Port Alfred, collected by Colonel W. H. Turton. Proceedings of the Malacological Society of London, 14, 125 - 127." type="journal article" year="1921">III, 1921</bibRefCitation>
