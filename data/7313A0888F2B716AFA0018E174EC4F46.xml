<subSubSection id="FE202AB9521927A0AADF73046FAF580A" pageId="null" pageNumber="270" type="description">
<paragraph id="3AD113466F73A1BE13C9623BD16DB4AA" pageId="null" pageNumber="270">
Habitus wie 
<taxonomicName id="527A026CDE65BA74ED34A8ABFA8C966A" class="Magnoliopsida" family="Crassulaceae" genus="Sedum" kingdom="Plantae" order="Saxifragales" pageId="null" pageNumber="270" phylum="Tracheophyta" rank="species" species="acre">
<emphasis id="A6FBE2C621165661E4871133E17E607F" italics="true" pageId="null" pageNumber="270">S. acre</emphasis>
</taxonomicName>
(Nr. 16). Ganze Pflanze ohne 
<normalizedToken id="18D0EE1443A9287888DAC4A15D955AEA" originalValue="Drüsen" pageId="null" pageNumber="270">Druesen</normalizedToken>
. 
<emphasis id="81928FA920F4CB73266CA3118A9B61F5" italics="true" pageId="null" pageNumber="270">
<normalizedToken id="CEA7FCE14DC861B38191752DCB87D19D" originalValue="Blätter" pageId="null" pageNumber="270">Blaetter</normalizedToken>
zylindrisch, bis 6 mm lang. 1 mm dick, stumpf, am Grunde mit etwa 0,3 mm langem, spornartigem Ansatz
</emphasis>
(im Gebiet nur noch bei 
<taxonomicName id="C29B7ADC70416C93342CFC92CF733AF1" authority="Nr." authorityName="Nr." class="Magnoliopsida" family="Crassulaceae" genus="Sedum" kingdom="Plantae" order="Saxifragales" pageId="null" pageNumber="270" phylum="Tracheophyta" rank="species" species="annuum">
<emphasis id="06AB4AC63DD8F84F07FDD0CD852A61C6" italics="true" pageId="null" pageNumber="270">S. annuum</emphasis>
, Nr.
</taxonomicName>
13, so!), 
<normalizedToken id="019140693834EDFDE74764CD5AE7B93F" originalValue="wechselständig" pageId="null" pageNumber="270">wechselstaendig</normalizedToken>
. 
<normalizedToken id="DBA318CB85E95947E4A186A9811B1614" originalValue="Blüten" pageId="null" pageNumber="270">Blueten</normalizedToken>
5 
<normalizedToken id="33B2C11EF1B1B3D769FA2A1E2861958C" originalValue="zählig" pageId="null" pageNumber="270">zaehlig</normalizedToken>
. 
<normalizedToken id="4B5FE0422FCBD4A2D60E542DDBEAC89C" originalValue="Kelchblätter" pageId="null" pageNumber="270">Kelchblaetter</normalizedToken>
<normalizedToken id="DCC11F950680F58FAEEC8CAC2B020AA4" originalValue="eiförmig" pageId="null" pageNumber="270">eifoermig</normalizedToken>
, 
<emphasis id="5E93E1E4DC005E26174250C3CD8F8BA2" italics="true" pageId="null" pageNumber="270">schmal</emphasis>
, 2-3 mm lang, 
<emphasis id="374351A37920A63363869F995096FDFB" italics="true" pageId="null" pageNumber="270">bis 3mal so lang wie breit.</emphasis>
<normalizedToken id="42A6F1D185AA2F9C8342E0B4212D0819" originalValue="Kronblätter" pageId="null" pageNumber="270">Kronblaetter</normalizedToken>
l,8-2,5mal so lang wie die 
<normalizedToken id="19212727602C6AD0720811D27D6B9275" originalValue="Kelchblätter" pageId="null" pageNumber="270">Kelchblaetter</normalizedToken>
, fein zugespitzt, zitronengelb. - 
<normalizedToken id="BA7D817178A3B58B0AE4602E6C32CAF0" originalValue="Blüte" pageId="null" pageNumber="270">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="99D2E73F424F27D868490F8A5DF43E6F" pageId="null" pageNumber="270">
<emphasis id="8B2E283D26986F8571CBD76981C2BA24" italics="true" pageId="null" pageNumber="270">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="BEE5E4E49FD3EE865830AD4E2B43BE12" italics="true" pageId="null" pageNumber="270">74:</emphasis>
Material aus Schweden (Uhl in 
<normalizedToken id="C9B12C65C843ACE8879A48F4DF792A8E" originalValue="Löve" pageId="null" pageNumber="270">Loeve</normalizedToken>
un 
<normalizedToken id="B40FABE336BE535006E38DC7BF547AE8" originalValue="Löve" pageId="null" pageNumber="270">Loeve</normalizedToken>
1961). 2 
<emphasis id="2E81CC69F7B24F35525E6B2510874F7A" italics="true" pageId="null" pageNumber="270">n</emphasis>
= 
<emphasis id="53A2A740CE89764E7FA4B31B962C41B5" italics="true" pageId="null" pageNumber="270">108:</emphasis>
Material aus Holland (Gadella und Kliphuis 1967).
</paragraph>
<paragraph id="D4304A81B0A5FAD9DF21DDAF4414FD05" pageId="null" pageNumber="270">
<emphasis id="047F61FD986646B55F6AACF298D55F91" italics="true" pageId="null" pageNumber="270">Standort.</emphasis>
Kollin, montan und subalpin. Wie 
<taxonomicName id="05F2FAFB64035F87ADBF2C589404F637" class="Magnoliopsida" family="Crassulaceae" genus="Sedum" kingdom="Plantae" order="Saxifragales" pageId="null" pageNumber="270" phylum="Tracheophyta" rank="species" species="album">
<emphasis id="3277C340711DCA4B6E229422CF1F7F49" italics="true" pageId="null" pageNumber="270">S. album</emphasis>
</taxonomicName>
(Nr. 14), jedoch wahrscheinlich nur auf kalkhaltiger Unterlage.
</paragraph>
<paragraph id="0318D6740B5B8113ECE72FD4B9093FE9" pageId="null" pageNumber="270">
<emphasis id="E624E6DF917871E25AB384FC5540E008" italics="true" pageId="null" pageNumber="270">
Verbreitung. 
<normalizedToken id="DC8550F8698229CBFB4D9DC92907316B" originalValue="Europäische" pageId="null" pageNumber="270">Europaeische</normalizedToken>
Pflanze:
</emphasis>
Nordgrenze durch 
<normalizedToken id="413673587A4CC3D9AEA9893E3246BE39" originalValue="Südschweden" pageId="null" pageNumber="270">Suedschweden</normalizedToken>
(in England eingeschleppt), Finnland (?), 
<normalizedToken id="D10E7703E53FEF5BE31AD8EFDCD23BED" originalValue="ostwärts" pageId="null" pageNumber="270">ostwaerts</normalizedToken>
bis Polen und Ukraine; 
<normalizedToken id="E42E8E1D290FE59F4E9B22A8EC5B07B9" originalValue="südwärts" pageId="null" pageNumber="270">suedwaerts</normalizedToken>
bis 
<normalizedToken id="CDD9916BAB0C7335C488525B3A3BA1AF" originalValue="Südfrankreich" pageId="null" pageNumber="270">Suedfrankreich</normalizedToken>
, 
<normalizedToken id="8292CF53E202CD3E1C45E73AF7DBB444" originalValue="Süditalien" pageId="null" pageNumber="270">Sueditalien</normalizedToken>
, Albanien, Donaubecken. - Im Gebiet ziemlich verbreitet, nicht 
<normalizedToken id="F7A7D12802EDC77564B10CE8DF7295F3" originalValue="häufig" pageId="null" pageNumber="270">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
