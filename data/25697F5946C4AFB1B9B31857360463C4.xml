<title id="6E56CCE5F188A717BAC157C73D9F77A0" pageId="null" pageNumber="24">
<subSubSection id="5D265F3D908BB6767B2BDDE28E0048A2" pageId="null" pageNumber="24" type="nomenclature">
<paragraph id="82F54609008E2AB3C7823D7FB909A822" pageId="null" pageNumber="24">
<taxonomicName id="0FDF4B5B5B2487B41185EAFF98F81453" authority="L." class="Magnoliopsida" family="Gentianaceae" genus="Gentiana" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="24" phylum="Tracheophyta" rank="species" species="punctata">
<pageBreakToken id="671220705AC0520B4BD7B90E858CC9FF" pageId="null" pageNumber="24" start="start">Gentiana</pageBreakToken>
<normalizedToken id="B6CED2AB909249AF4A90709D7E32E2D2" originalValue="punctáta" pageId="null" pageNumber="24">punctata</normalizedToken>
<authorityName id="97F7D4419101D4CFFCF2E38ABF9FC085" pageId="null" pageNumber="24">L.</authorityName>
</taxonomicName>
