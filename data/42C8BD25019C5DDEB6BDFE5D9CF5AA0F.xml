<bibRefCitation id="67CC4903F3FBE17C896F149262698611" author="Hebauer, F" journalOrPublisher="Acta Coleopterologica" pageId="0" pageNumber="15" pagination="3 - 72" refId="B9" refString="Hebauer, F, 2002. Hydrophilidae of northern India and southern Himalaya (Coleoptera: Hydrophilidae). Acta Coleopterologica 18 (1): 3 - 72" title="Hydrophilidae of northern India and southern Himalaya (Coleoptera: Hydrophilidae)." volume="18" year="2002">Hebauer 2002</bibRefCitation>
; 
<bibRefCitation id="284DDF929AEA7C9FF81A89978386B8C0" author="Przewozny, M" journalOrPublisher="Bulletin et Annales de la Societe Entomologique de Belgique" pageId="0" pageNumber="15" publicationUrl="http://www.waterbeetles.eu" refId="B24" refString="Przewozny, M, 2021. Catalogue of Palearctic Hydrophiloidea (Coleoptera). Internet version 2021-01-01. http://www.waterbeetles.eu" title="Catalogue of Palearctic Hydrophiloidea (Coleoptera). Internet version 2021 - 01 - 01." url="http://www.waterbeetles.eu" year="2021">
<normalizedToken id="0C3A0E56C9AFC1BC06C0DD8841AED118" originalValue="Przewoźny">Przewozny</normalizedToken>
2021
</bibRefCitation>
). New record for China (Xizang).
</paragraph>
