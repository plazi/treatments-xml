<subSubSection id="7F79D6D28279BF4594CF055ECEBA931C" pageId="null" pageNumber="178" type="description">
<paragraph id="379582EE34811760C8E70A6D6BD7E9DD" pageId="null" pageNumber="178">
Unterscheidet sich von 
<taxonomicName id="8ABF8A5DC3F36B7840EA7BBEF2EE8C8D" class="Magnoliopsida" family="Scrophulariaceae" genus="Verbascum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="178" phylum="Tracheophyta" rank="species" species="thapsiforme">
<emphasis id="07A2B0C8451A8204F70FF3EC97B11ECA" italics="true" pageId="null" pageNumber="178">V. thapsiforme</emphasis>
</taxonomicName>
(Nr.3d) durch die 
<normalizedToken id="D1916EA043ECDBECA075345AF33CFA56" originalValue="Blätter" pageId="null" pageNumber="178">Blaetter</normalizedToken>
: 
<emphasis id="423F7330500CC12977320EF54A27D208" italics="true" pageId="null" pageNumber="178">
<normalizedToken id="8E91CFCEA6D84F0810FCB8245D760B22" originalValue="Grundständige" pageId="null" pageNumber="178">Grundstaendige</normalizedToken>
<normalizedToken id="6D7091E5AD88EB920608BEB85E10B595" originalValue="Blätter" pageId="null" pageNumber="178">Blaetter</normalizedToken>
deutlich gestielt
</emphasis>
, untere 
<normalizedToken id="F2BEE39D728FBDBF52DB1DC6338BCC01" originalValue="Stengelblätter" pageId="null" pageNumber="178">Stengelblaetter</normalizedToken>
kurz gestielt oder sitzend, 
<emphasis id="2BE725615AC24E6F2F1E9AC4C877EC93" italics="true" pageId="null" pageNumber="178">obere sitzend, am Stengel nicht oder nur wenig</emphasis>
(
<emphasis id="8EACD48C73F242548ABEE85577710BF9" italics="true" pageId="null" pageNumber="178">
nicht bis zum 
<normalizedToken id="F6137DF0A400314681DAD49E059CBC1C" originalValue="nächst" pageId="null" pageNumber="178">naechst</normalizedToken>
untern Blatt
</emphasis>
) 
<emphasis id="BCB16D10109EFBA7DF572013D06A8057" italics="true" pageId="null" pageNumber="178">herablaufend;</emphasis>
<normalizedToken id="7EA7432FA937A2DD351C7801F5B65153" originalValue="Blätter" pageId="null" pageNumber="178">Blaetter</normalizedToken>
im 
<normalizedToken id="310B23A0B1B995FD283D7665469CE2C7" originalValue="Blütenstand" pageId="null" pageNumber="178">Bluetenstand</normalizedToken>
9-15 mm lang. Die 
<normalizedToken id="879AACEA8A3E982C4EA676BDC69F75BF" originalValue="Blüten" pageId="null" pageNumber="178">Blueten</normalizedToken>
sollen nach Zitrone riechen. - 
<normalizedToken id="14EE88ADB4CBE257630C85E651FA022D" originalValue="Blüte" pageId="null" pageNumber="178">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="2C8EF6664799E64CA32EB140C73E4AE5" pageId="null" pageNumber="178">
<emphasis id="519357748FB42545E3B27F9DB982FF44" italics="true" pageId="null" pageNumber="178">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E7BE6D04A4D3E07644266CBE41D9662B" italics="true" pageId="null" pageNumber="178">32:</emphasis>
Material aus botanischen 
<normalizedToken id="F034AABC14B2063E74F0D65CFFD22E03" originalValue="Gärten" pageId="null" pageNumber="178">Gaerten</normalizedToken>
(
<normalizedToken id="D64ABB54996CA2F53038E802BA2DE5FB" originalValue="Håkansson" pageId="null" pageNumber="178">Hakansson</normalizedToken>
1926, Perino aus Tischler 1950). 
<emphasis id="B3FC167403784881DE12B93D5A0F54BE" italics="true" pageId="null" pageNumber="178">2n</emphasis>
= 
<emphasis id="010C51821D61542F5B78FFDC2C5F592E" italics="true" pageId="null" pageNumber="178">34:</emphasis>
Material aus botanischem Garten (Arts-Damler 1960).
</paragraph>
<paragraph id="52ECA736545CB67682D86E4A6E1C4216" pageId="null" pageNumber="178">
<emphasis id="AED20C2B5E41E4A26446143C29C391B5" italics="true" pageId="null" pageNumber="178">
<pageBreakToken id="F2B608AFEA9CE88F1295DE41552EF2A6" pageId="null" pageNumber="178">Standort</pageBreakToken>
.
</emphasis>
Kollin. Lockere, steinige, 
<normalizedToken id="05117A99A9D816EE89E79EE6F072BB8B" originalValue="nährstoffreiche" pageId="null" pageNumber="178">naehrstoffreiche</normalizedToken>
<normalizedToken id="CE8C53E99AB0D0B97B7FE2819FAABF73" originalValue="Böden" pageId="null" pageNumber="178">Boeden</normalizedToken>
in warmen Lagen. Sonnige 
<normalizedToken id="7C1065609B71D8E0B9D42CD6DAB950EC" originalValue="Hänge" pageId="null" pageNumber="178">Haenge</normalizedToken>
, 
<normalizedToken id="2ADB467AB1B73344973C261E57624E28" originalValue="Waldschläge" pageId="null" pageNumber="178">Waldschlaege</normalizedToken>
, Kiesgruben, Alluvionen.
</paragraph>
<paragraph id="EB80765A58AA3684C8B6AB3DC358C4C8" pageId="null" pageNumber="178">
<emphasis id="FC07E3986AF376544594AB0F3D173C0A" italics="true" pageId="null" pageNumber="178">Verbreitung. Enrasiatische Pflanze:</emphasis>
Europa (
<normalizedToken id="348D2311EADA70352C1D392B3B9AFC87" originalValue="nordwärts" pageId="null" pageNumber="178">nordwaerts</normalizedToken>
bis Holland, Norddeutschland); Westsibirien, Zentralasien. - Im Gebiet: 
<normalizedToken id="E511C011005970DDEA64448ABE60BCBC" originalValue="Alpensüdseite" pageId="null" pageNumber="178">Alpensuedseite</normalizedToken>
, Wallis (Val de Bagne), Genferseegebiet, 
<normalizedToken id="CE603A88020CFCB4C9E8EED9B03AF202" originalValue="Dép" pageId="null" pageNumber="178">Dep</normalizedToken>
. Doubs und 
<normalizedToken id="73357A21433D221583C0977F60D9A5BD" originalValue="Dép" pageId="null" pageNumber="178">Dep</normalizedToken>
. Jura, Nordschweiz, Hochrheingebiet und Oberrheinische Tiefebene, Oberinntal (Landeck), Vintschgau (Schnals, Lana); selten; im Mittelland sehr selten und 
<normalizedToken id="BA17B764AE93804AB2624B92DA2116CE" originalValue="unbeständig" pageId="null" pageNumber="178">unbestaendig</normalizedToken>
.
</paragraph>
</subSubSection>
