<subSubSection id="CD981FA577DDCBE04C6F510C681FAE93" pageId="null" pageNumber="720" type="description">
<paragraph id="DBA6F1BC3EA798FD770BAE669ABA812B" pageId="null" pageNumber="720">
Unterscheidet sich von 
<taxonomicName id="247CB42A21917B1AA816624E515DD719" class="Magnoliopsida" family="Elatinaceae" genus="Elatine" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="720" phylum="Tracheophyta" rank="species" species="triandra">
<emphasis id="03D376FD55EA7BEE757A5F348BCC1B04" italics="true" pageId="null" pageNumber="720">E. triandra</emphasis>
</taxonomicName>
(Nr. 2) durch folgende Merkmale: 
<normalizedToken id="6DE7349DD621DAC05BBF5479D3E09B94" originalValue="Blätter" pageId="null" pageNumber="720">Blaetter</normalizedToken>
selten 
<normalizedToken id="1503D342EA06B38C9D983F9021068A66" originalValue="über" pageId="null" pageNumber="720">ueber</normalizedToken>
0,5 cm lang, 2-4mal so lang wie breit; 
<emphasis id="2077AE81F279D1A94466522E62039931" italics="true" pageId="null" pageNumber="720">
<normalizedToken id="DFF56A77768E6D7C31532755509F39C1" originalValue="Blüten" pageId="null" pageNumber="720">Blueten</normalizedToken>
gestielt, Stiel 0,5-5 mm lang
</emphasis>
, selten 
<normalizedToken id="9978A48F755250D3D5C0F7344C02C597" originalValue="länger" pageId="null" pageNumber="720">laenger</normalizedToken>
oder nicht vorhanden, sich 
<normalizedToken id="6B16EFE86CB4E1E1790EB817F7F6DA30" originalValue="öffnend" pageId="null" pageNumber="720">oeffnend</normalizedToken>
. 
<normalizedToken id="3D7E6DDD5B3FE111E91DE1034847075C" originalValue="Kronblätter" pageId="null" pageNumber="720">Kronblaetter</normalizedToken>
1-1,5 mm lang, 
<normalizedToken id="EEF03D353FB93A2011F7D09C70F4852A" originalValue="weiß" pageId="null" pageNumber="720">weiss</normalizedToken>
oder 
<normalizedToken id="31F2ECEB3EBB252D407AB173ED0B0736" originalValue="rötlich" pageId="null" pageNumber="720">roetlich</normalizedToken>
, 
<normalizedToken id="161619B2A3E9F8B0C31412F86F31EB7C" originalValue="länger" pageId="null" pageNumber="720">laenger</normalizedToken>
als die 
<normalizedToken id="D4925F8E6956799932C654851852F2EF" originalValue="Kelchblätter" pageId="null" pageNumber="720">Kelchblaetter</normalizedToken>
; 
<emphasis id="457CD329CD352AE9EE086E55C1F86A79" italics="true" pageId="null" pageNumber="720">
<normalizedToken id="55E848C8C2F31AA1365B9A5E83332B22" originalValue="Staubblätter" pageId="null" pageNumber="720">Staubblaetter</normalizedToken>
6;
</emphasis>
Samen mit feinen, aber 
<emphasis id="F247C8FCBA51EDD3F07FDD53D81F207E" italics="true" pageId="null" pageNumber="720">
deutlich sichtbaren 
<normalizedToken id="1BB2B57B4C187A203EB07659FD7414B7" originalValue="Längsrippen" pageId="null" pageNumber="720">Laengsrippen</normalizedToken>
</emphasis>
(25fache 
<normalizedToken id="4A124AB1D97C0F050B5DCA1622A859AF" originalValue="Vergrößerung" pageId="null" pageNumber="720">Vergroesserung</normalizedToken>
!). - 
<normalizedToken id="D0415D051057ADB8223974480E83872A" originalValue="Blüte" pageId="null" pageNumber="720">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="B2A36ADB93C4D27AA498C8F2B346EDFA" pageId="null" pageNumber="720">
<emphasis id="43C85EC3BDC31E937D7D34D2F8B7908D" italics="true" pageId="null" pageNumber="720">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E618A7728BF12674F8C89ABDB3AA6965" italics="true" pageId="null" pageNumber="720">72:</emphasis>
Material aus 
<normalizedToken id="84A39D6D4E83E3A1C86301F75BEE8856" originalValue="Dänemark" pageId="null" pageNumber="720">Daenemark</normalizedToken>
(Hagerup in 
<normalizedToken id="B086887F9DFDCE60916BA7C692A61795" originalValue="Löve" pageId="null" pageNumber="720">Loeve</normalizedToken>
und 
<normalizedToken id="D390F96371706F5E92ABCCB8F47BA9EB" originalValue="Löve" pageId="null" pageNumber="720">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="940B963EEC1C4DB914DF646F042A4BA1" pageId="null" pageNumber="720">
<emphasis id="58DCEAD59ECD7A1F1CA624E43368AFF5" italics="true" pageId="null" pageNumber="720">Standort.</emphasis>
Kollin. Wie 
<taxonomicName id="D8584795865D9BFB450D506C310E7D27" class="Magnoliopsida" family="Elatinaceae" genus="Elatine" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="720" phylum="Tracheophyta" rank="species" species="alsinastrum">
<emphasis id="BF843CD4061151DCC119FC06AD0F2978" italics="true" pageId="null" pageNumber="720">E. Alsinastrum</emphasis>
</taxonomicName>
(Nr. 1).
</paragraph>
<paragraph id="CAA8C9F679DFEA8B41C981A2B3B313A4" pageId="null" pageNumber="720">
<emphasis id="1B4DEA44C1C1F882E55A447B9B0481AE" italics="true" pageId="null" pageNumber="720">
<pageBreakToken id="3334C3A9549A05B063E7EBB03E7AF911" pageId="null" pageNumber="720">Verbreitung</pageBreakToken>
. 
<normalizedToken id="BEC85DB1FE67B9CA649ABDABEE50F3A2" originalValue="Europäische" pageId="null" pageNumber="720">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="4514716C6AB619884604D51709084CC0" originalValue="Nordwärts" pageId="null" pageNumber="720">Nordwaerts</normalizedToken>
bis Irland, Shetlandinseln, 
<normalizedToken id="E654950F01962192AB6B7E62AF0AE296" originalValue="Südskandinavien" pageId="null" pageNumber="720">Suedskandinavien</normalizedToken>
; 
<normalizedToken id="8D97C0886A81E403D0022B0B6169CF88" originalValue="südwärts" pageId="null" pageNumber="720">suedwaerts</normalizedToken>
bis 
<normalizedToken id="5D0FEA543E007BBAF8750E51A63A5027" originalValue="südliches" pageId="null" pageNumber="720">suedliches</normalizedToken>
Frankreich (ohne Mediterrangebiet), Oberitalien (Poebene), 
<normalizedToken id="A80C46400BEE9CE65A36A4E2FDFEE227" originalValue="nördliche" pageId="null" pageNumber="720">noerdliche</normalizedToken>
Balkanhalbinsel; 
<normalizedToken id="80B781FFE1AB468677621FB48F15693C" originalValue="ostwärts" pageId="null" pageNumber="720">ostwaerts</normalizedToken>
bis Ostpolen und 
<normalizedToken id="BB0535A4E8AE1CCA3D4EE82AED3E2EF0" originalValue="Rumänien" pageId="null" pageNumber="720">Rumaenien</normalizedToken>
. - Im Gebiet: 
<normalizedToken id="4988A07B8B2D40842AF83A194C8A62AF" originalValue="Dép" pageId="null" pageNumber="720">Dep</normalizedToken>
. Ain, 
<normalizedToken id="0408B4CBC9DE0C2663ED1E67405757BD" originalValue="Dép" pageId="null" pageNumber="720">Dep</normalizedToken>
, Jura, Gegend von Belfort, Sundgau, Oberrheinische Tiefebene; 
<normalizedToken id="3B0967701304FAF4DB71E74BE02A1EC3" originalValue="früher" pageId="null" pageNumber="720">frueher</normalizedToken>
am Genfersee bei Versoix; Tessin (Magadino, Ufer des Langensees), 
<normalizedToken id="F6B63272F844235DB2EFAD6BCD924124" originalValue="Flußgebiet" pageId="null" pageNumber="720">Flussgebiet</normalizedToken>
der Adda.
</paragraph>
<paragraph id="62C9BBEC95FF19B87DFC33621F565459" pageId="null" pageNumber="720">
<emphasis id="B4699CF95C24C4C85D72035FA79BD3ED" italics="true" pageId="null" pageNumber="720">
Bemerkungen. 
<taxonomicName id="CA1B56782DBDA9C4CA7B90FA63D330EC" class="Magnoliopsida" family="Elatinaceae" genus="Elatine" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="720" phylum="Tracheophyta" rank="species" species="hexandra">E. hexandra</taxonomicName>
</emphasis>
ist in der Gegend der oberitalienischen Reisfelder (Novara, Vercelli) vorhanden und 
<normalizedToken id="E1409BCE79A879CD7985A76326934DD1" originalValue="dürfte" pageId="null" pageNumber="720">duerfte</normalizedToken>
in 
<normalizedToken id="FFB83E11043E3711F4717287B4A4AE4E" originalValue="Sümpfen" pageId="null" pageNumber="720">Suempfen</normalizedToken>
weiter 
<normalizedToken id="1BA42C3096DC1BF86A8FFFDB9FF57A78" originalValue="nördlich" pageId="null" pageNumber="720">noerdlich</normalizedToken>
im Gebiet der 
<normalizedToken id="9E622F02AF898B1FBC2129D6243B152C" originalValue="«Flora»" pageId="null" pageNumber="720">&quot;Flora&quot;</normalizedToken>
noch zu linden sein.
</paragraph>
</subSubSection>
