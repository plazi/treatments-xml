<paragraph id="94DC658696D96A7DD69E056B11C939C3" pageId="null" pageNumber="550">
<taxonomicName id="A644E9CA80C5BB13DCDEFFE481293D65" authority="(L.) DC." class="Magnoliopsida" family="Asteraceae" genus="Anthemis" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="550" phylum="Tracheophyta" rank="species" species="triumfettii">
Anthemis 
<normalizedToken id="51B1FE7BBBF2ACC35A8E35EF64B4FD09" originalValue="Triumféttii" pageId="null" pageNumber="550">Triumfettii</normalizedToken>
(
<authorityName id="F9811344B024196E15AA80156136CE02" pageId="null" pageNumber="550">L.</authorityName>
) DC.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="452FA512BC37B2FA7C24D15BF8DAD9B1" pageId="null" pageNumber="550" type="vernacular_names">
<paragraph id="539A10A5ABDA2D2AEBA15B4D28497BE9" pageId="null" pageNumber="550">Triumfettis Hundskamille</paragraph>
</subSubSection>
</title>
<subSubSection id="BE82F834ECE492E419B036E34BE6D243" pageId="null" pageNumber="550" type="description">
<paragraph id="959FD34B69A717ED7F8A3990D04EAA62" pageId="null" pageNumber="550">
Ausdauernd; 30-80 cm hoch. Stengel zerstreut filzig behaart. 
<normalizedToken id="1B004240630F243643AA83E7BA6EED8F" originalValue="Blätter" pageId="null" pageNumber="550">Blaetter</normalizedToken>
oberseits meist kahl, 
<emphasis id="D598C8E782740A465ABBC5B184C7602C" italics="true" pageId="null" pageNumber="550">unterseits zerstreut filzig behaart</emphasis>
, 1-2fach fiederteilig. 
<normalizedToken id="8223A65EA068D64E80AF296328C10BDF" originalValue="Köpfe" pageId="null" pageNumber="550">Koepfe</normalizedToken>
im Durchmesser 3-4,5 cm. 
<normalizedToken id="85D59A216AF6E8083A0B573B6C24F37A" originalValue="Hüllblätter" pageId="null" pageNumber="550">Huellblaetter</normalizedToken>
zerstreut filzig behaart. 
<normalizedToken id="C96E88B52B07956544AA068DB408BFFB" originalValue="Spreublätter" pageId="null" pageNumber="550">Spreublaetter</normalizedToken>
<normalizedToken id="4EAF1CA265EFE89FBE8121F9AFEDEE35" originalValue="plötzlich" pageId="null" pageNumber="550">ploetzlich</normalizedToken>
oder 
<normalizedToken id="654AB287FD55A84CD03C998D28B5A4EC" originalValue="allmählich" pageId="null" pageNumber="550">allmaehlich</normalizedToken>
in die Spitze 
<normalizedToken id="1FC21981BCFA3C6CD8A99C2220BCC382" originalValue="übergehend" pageId="null" pageNumber="550">uebergehend</normalizedToken>
; Spitze 
<normalizedToken id="8BDCF330FB06AFA7ED4D175D3B4BE97F" originalValue="höchstens" pageId="null" pageNumber="550">hoechstens</normalizedToken>
<normalizedToken id="3D98C9130CF1002303A70C3113112F87" originalValue="½" pageId="null" pageNumber="550">1/2</normalizedToken>
so lang wie das Spreublatt. 
<emphasis id="EEC83F07D8232FB03DDD7BD0C0790A93" italics="true" pageId="null" pageNumber="550">
<normalizedToken id="50C72521B2E30731A4FD6F5751F35A79" originalValue="Zungenförmige" pageId="null" pageNumber="550">Zungenfoermige</normalizedToken>
<normalizedToken id="B0E68D2A1F324D7C11FAE2B6618CF523" originalValue="Blüten" pageId="null" pageNumber="550">Blueten</normalizedToken>
<normalizedToken id="BB857281A6A3462026032994446E17EF" originalValue="weiß" pageId="null" pageNumber="550">weiss</normalizedToken>
</emphasis>
(beim Trocknen oft gelblich werdend). 
<emphasis id="7CF8F5234363A8C3F9F9BB2E8A2A0920" italics="true" pageId="null" pageNumber="550">
<normalizedToken id="BAAFA3134FE3E6079C0F307AA2D9DB70" originalValue="Früchte" pageId="null" pageNumber="550">Fruechte</normalizedToken>
jederseits mit 5
</emphasis>
- 
<emphasis id="E242CD7AEBE57B3189DAA60E8C73B600" italics="true" pageId="null" pageNumber="550">
7 deutlichen 
<normalizedToken id="1747712222EC49F7145DA18858FD3B55" originalValue="Längsrippen" pageId="null" pageNumber="550">Laengsrippen</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="5C28CC2CE53B663502E1107E3861AA1D" originalValue="Blüte" pageId="null" pageNumber="550">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="6D5D552A11E58F6FD89AF53772071ADD" pageId="null" pageNumber="550">
<emphasis id="A9B069F965AF9858D866DBAD6390CDD1" italics="true" pageId="null" pageNumber="550">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="4D7AB6FE1FAB52D341343F9F2B50D493" pageId="null" pageNumber="550">
<emphasis id="5A0309A791DB331544D8A2AE1E4D835C" italics="true" pageId="null" pageNumber="550">Standort.</emphasis>
Kollin und montan. Trockene, felsige 
<normalizedToken id="BD70FB58A147C0E9EA552FCA8AFCFDF0" originalValue="Böden" pageId="null" pageNumber="550">Boeden</normalizedToken>
in warmen Lagen. Steinige 
<normalizedToken id="B2E0A41E6E441A3863F16F7792FAE486" originalValue="Hänge" pageId="null" pageNumber="550">Haenge</normalizedToken>
, 
<normalizedToken id="DDAD4ECCFAEE3E56608FBEA0176B9D43" originalValue="Felsbänder" pageId="null" pageNumber="550">Felsbaender</normalizedToken>
.
</paragraph>
<paragraph id="55FBFA6BAB0195BD8722F005CCCFF70E" pageId="null" pageNumber="550">
<emphasis id="B7F24F15E5982E269A43BE818C79EAE1" italics="true" pageId="null" pageNumber="550">
Verbreitung. 
<normalizedToken id="4A5E8EA6F6836F3BB9307CA7E2E410D6" originalValue="Südeuropäische" pageId="null" pageNumber="550">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Spanien, 
<normalizedToken id="7C8EF3D98A2FA04ED2BCBC7FAB9EF691" originalValue="Südfrankreich" pageId="null" pageNumber="550">Suedfrankreich</normalizedToken>
, Italien, Balkanhalbinsel, 
<normalizedToken id="4EB1E4C1C46773C6A60880654494E4D4" originalValue="nordwärts" pageId="null" pageNumber="550">nordwaerts</normalizedToken>
bis zum Erzgebirge); in abweichenden Sippen auch in Kleinasien und im Kaukasus. - Im Gebiet: 
<normalizedToken id="B30057BBFF4EF13B9BF7E43C83D6CA46" originalValue="Südliches" pageId="null" pageNumber="550">Suedliches</normalizedToken>
Tessin und Comerseegebiet, ziemlich selten.
</paragraph>
</subSubSection>
</treatment>
