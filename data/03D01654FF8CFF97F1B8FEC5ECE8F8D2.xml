<taxonomicName id="4C79DCC1FF8CFF97F05EFCBAEFD1FCD2" baseAuthorityName="Mordvilko" baseAuthorityYear="1895" box="[328,481,784,810]" class="Insecta" family="Aphididae" genus="Cinara" kingdom="Animalia" order="Hemiptera" pageId="9" pageNumber="396" phylum="Arthropoda" rank="species" species="pinea">
<emphasis id="B90D7B50FF8CFF97F05EFCBAEFD1FCD2" box="[328,481,784,810]" italics="true" pageId="9" pageNumber="396">Cinara pinea</emphasis>
</taxonomicName>
