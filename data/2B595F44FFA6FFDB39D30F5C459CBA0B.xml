<superScript id="5485431AFFA6FFDA3A6C0CA94411BC82" attach="left" box="[823,831,1951,1965]" fontSize="6" pageId="40" pageNumber="267">2</superScript>
, EOO= 
<quantity id="640843B7FFA6FFDA3ACD0CA9434DBC96" box="[918,1123,1951,1978]" metricMagnitude="9" metricUnit="m" metricValue="2.675704791" pageId="40" pageNumber="267" unit="km" value="2675704.791">2,675,704.791 km</quantity>
<superScript id="5485431AFFA6FFDA3D380CA94345BC82" attach="left" box="[1123,1131,1951,1965]" fontSize="6" pageId="40" pageNumber="267">2</superScript>
].
</paragraph>
</subSubSection>
