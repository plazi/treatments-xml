<subSubSection id="B5B565769066FF9BB4FC16ECFF06FDFD" pageId="2" pageNumber="495" type="etymology">
<paragraph id="FD1036FD9066FF9BB4FC16ECFF06FDFD" blockId="2.[151,1437,151,643]" pageId="2" pageNumber="495">
<emphasis id="CFDBEAEF9066FF9BB4FC16ECFEA8FE1E" bold="true" box="[199,328,476,500]" inLineHeading="true" pageId="2" pageNumber="495" reason="1">Etymology.</emphasis>
