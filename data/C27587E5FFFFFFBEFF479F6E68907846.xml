<paragraph id="4A6336F3FFFFFFBEFF3D9FE068667EB7" blockId="18.[151,757,904,1039]" pageId="18" pageNumber="32">
1946. 
<taxonomicName id="8DDC4D70FFFFFFBEFF709FE06B2D7EDB" authority="REUSS." authorityName="REUSS." box="[218,544,932,954]" class="Nodosariata" family="Nodosariidae" genus="Dentalina" kingdom="Chromista" order="Nodosariida" pageId="18" pageNumber="32" phylum="Foraminifera" rank="species" species="megalopolitana">
