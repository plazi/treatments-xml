<taxonomicName id="8DDC4D70FFFFFFBEFF709F996B2F7E93" authority="REUSS." authorityName="REUSS." box="[218,546,989,1010]" class="Nodosariata" family="Nodosariidae" genus="Dentalina" kingdom="Chromista" order="Nodosariida" pageId="18" pageNumber="32" phylum="Foraminifera" rank="species" species="megalopolitana">
