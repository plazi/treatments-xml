<subSubSection id="4C601B193401D14A074FF3199A765BD7" pageId="null" pageNumber="484" type="description">
<paragraph id="97CF4A3248A7CD89F6EB4BF6D2F9F758" pageId="null" pageNumber="484">
<emphasis id="E34EABA1A4FF7FB96553FC053A9ECA7B" italics="true" pageId="null" pageNumber="484">
20-50 cm hoch; lange, 
<normalizedToken id="66168BBA92578F0906E78938E14C8B12" originalValue="dünne" pageId="null" pageNumber="484">duenne</normalizedToken>
unterirdische 
<normalizedToken id="CF7B07DA17C02198EFC0365F876EDB40" originalValue="Ausläufer" pageId="null" pageNumber="484">Auslaeufer</normalizedToken>
</emphasis>
treibend. Habitus wie 
<taxonomicName id="996AF3EDB1B6511BB47717B5B31E3EBF" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="484" phylum="Tracheophyta" rank="species" species="brevicollis">
<emphasis id="F43A7BCA099D40341768DB6944A91393" italics="true" pageId="null" pageNumber="484">C. brevicollis</emphasis>
</taxonomicName>
(Nr. 94), 
<normalizedToken id="17F42A530E565226673B6C368535391A" originalValue="Blätter" pageId="null" pageNumber="484">Blaetter</normalizedToken>
jedoch nur 2-3 mm breit. 
<normalizedToken id="627B9A6CFC67CADDC2BE923E6BB2D87C" originalValue="Blütenstand" pageId="null" pageNumber="484">Bluetenstand</normalizedToken>
wie bei 
<taxonomicName id="6D4CB83E796B297C2D563CAF7D6D51CE" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="484" phylum="Tracheophyta" rank="species" species="brevicollis">
<emphasis id="30AB2355E3C3E3DABE9D2CFC40D2A980" italics="true" pageId="null" pageNumber="484">C. brevicollis</emphasis>
</taxonomicName>
, unterstes Hochblatt die 
<normalizedToken id="5D78F4865CD0C5B23EE85299B24FF1DE" originalValue="zugehörige" pageId="null" pageNumber="484">zugehoerige</normalizedToken>
<normalizedToken id="520FE4C1E1171A6331C544948C5814C4" originalValue="Ähre" pageId="null" pageNumber="484">Aehre</normalizedToken>
meist 
<normalizedToken id="71DC9426F725F482A6C6EC737CF711C8" originalValue="überragend" pageId="null" pageNumber="484">ueberragend</normalizedToken>
. 
<normalizedToken id="328F7B081B125AA6280BA43694843D78" originalValue="Tragblätter" pageId="null" pageNumber="484">Tragblaetter</normalizedToken>
etwa so lang wie die reifen 
<normalizedToken id="E51DE0C011F8DD28C56ABF64524B4E73" originalValue="Fruchtschläuche" pageId="null" pageNumber="484">Fruchtschlaeuche</normalizedToken>
, 
<emphasis id="1BF10E6DBDBF1CC38A3BB570B5530D7F" italics="true" pageId="null" pageNumber="484">schmal lanzettlich</emphasis>
, mit grannenartiger Spitze, 
<emphasis id="92FDD606DF0A164AA308EA05A08E4DD9" italics="true" pageId="null" pageNumber="484">
<normalizedToken id="A993705E70369BDC17B55DE0B3136B64" originalValue="häutig" pageId="null" pageNumber="484">haeutig</normalizedToken>
, hell
</emphasis>
, mit 
<normalizedToken id="D12AA702E9A4406145E869506E40EC7E" originalValue="grünem" pageId="null" pageNumber="484">gruenem</normalizedToken>
Mittelnerv. 
<emphasis id="CF8C390ACCD61E1B36B6FF9724D20D8D" italics="true" pageId="null" pageNumber="484">
<normalizedToken id="55FA6C4749004DA781E8E0A9B759ECA3" originalValue="Fruchtschläuche" pageId="null" pageNumber="484">Fruchtschlaeuche</normalizedToken>
5-6 mm lang, etwas unterhalb der Mitte am breitesten
</emphasis>
(
<emphasis id="3A4CC669A91F96C0B0588D17939DC3B3" italics="true" pageId="null" pageNumber="484">2-2,5 mm)</emphasis>
, im Querschnitt rundlich, mit 
<normalizedToken id="9225FC0480C6E088F638C618C5CE2044" originalValue="±" pageId="null" pageNumber="484">+/-</normalizedToken>
deutlichen Nerven, zerstreut borstig behaart, oft auch ganz kahl, matt, 
<normalizedToken id="0BAA3D993A162B3DAD49E1FF2B974F9F" originalValue="plötzlich" pageId="null" pageNumber="484">ploetzlich</normalizedToken>
in den Schnabel 
<normalizedToken id="226B2CFABCA269982E4A439E027446D4" originalValue="verschmälert" pageId="null" pageNumber="484">verschmaelert</normalizedToken>
; 
<emphasis id="3A64EFB1623F64438831D14F1BE0262A" italics="true" pageId="null" pageNumber="484">
Schnabel 2-2,5 mm lang; 
<normalizedToken id="3E36055753E5EE0C1AF05EB3FB3217C0" originalValue="Zähne" pageId="null" pageNumber="484">Zaehne</normalizedToken>
1-2 mm lang
</emphasis>
, gerade oder gespreizt. Narben 3.
</paragraph>
<paragraph id="191BC2E4B63413E54AD09A5A0251B183" pageId="null" pageNumber="484">
<emphasis id="48249676C2429FB958B536E49B8632B7" italics="true" pageId="null" pageNumber="484">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="C9BC811A04C039B5EACAB5550012EDB6" pageId="null" pageNumber="484">
<emphasis id="E59486858299AF92F8676C9AD462EEB1" italics="true" pageId="null" pageNumber="484">Standort.</emphasis>
Kollin. Trockene, lichte 
<normalizedToken id="A2602CE06F9D6DE79B33289053F7787B" originalValue="Laubwälder" pageId="null" pageNumber="484">Laubwaelder</normalizedToken>
und 
<normalizedToken id="421A890378DC03B1BED700FE305A40C3" originalValue="Gebüsche" pageId="null" pageNumber="484">Gebuesche</normalizedToken>
.
</paragraph>
<paragraph id="C89FBDC361BE9C7BC7C1D74E97C06D41" pageId="null" pageNumber="484">
<emphasis id="63EF4736D802B9E210C84008112833AD" italics="true" pageId="null" pageNumber="484">
Verbreitung. 
<normalizedToken id="8857E50FF02D19658EB97B45FD21A68B" originalValue="Südosteuropäische" pageId="null" pageNumber="484">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Polen, Balkanhalbinsel und Donaugebiet, Italien (
<normalizedToken id="B6517972B1139FAC001785AF937FA932" originalValue="westwärts" pageId="null" pageNumber="484">westwaerts</normalizedToken>
bis Rom und 
<normalizedToken id="2AE8BBEA728356BFCE9339BE27A63D81" originalValue="Südtirol" pageId="null" pageNumber="484">Suedtirol</normalizedToken>
), 
<normalizedToken id="2EDA3251984508E32F15EF3D563B5E34" originalValue="Südrußland" pageId="null" pageNumber="484">Suedrussland</normalizedToken>
, Kaukasus. - Im Gebiet: Vintschgau (Laas, Meran, Gargazon), Comerseegebiet (Vercurago, Carenno, Erve).
</paragraph>
</subSubSection>
