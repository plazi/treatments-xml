<geoCoordinate id="D2B3507C3419FF9DFF3CC1D91B379710" box="[210,287,1259,1280]" degrees="38" direction="north" minutes="28" orientation="latitude" pageId="2" pageNumber="271" precision="925" value="38.466667">38°28'N</geoCoordinate>
