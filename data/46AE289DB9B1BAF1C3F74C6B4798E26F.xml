<subSubSection id="FDB3CF4B0152D60EAECBD048D37FCD30" pageId="null" pageNumber="33" type="description">
<paragraph id="CEB1539EE6210D07F6B98CAC25A7729C" pageId="null" pageNumber="33">
<emphasis id="651BD182BD096697D519B998D9621ED9" italics="true" pageId="null" pageNumber="33">
<normalizedToken id="B89DF5A21C208B964AA29979D7B569BC" originalValue="Blüten" pageId="null" pageNumber="33">Blueten</normalizedToken>
dunkelviolett.
</emphasis>
<normalizedToken id="05B034643B5A814CB086812B6933594B" originalValue="Staubblätter" pageId="null" pageNumber="33">Staubblaetter</normalizedToken>
zur Zeit des Aufspringens 
<emphasis id="2809E8A9645E091980232539B30BAFC4" italics="true" pageId="null" pageNumber="33">
1-2 cm aus der 
<normalizedToken id="E86F4DC831452A52CC99925CACD11195" originalValue="Blüte" pageId="null" pageNumber="33">Bluete</normalizedToken>
hervorragend.
</emphasis>
- 
<normalizedToken id="F6E54C6A962DCBD08BEA60FF10948DCA" originalValue="Blüte" pageId="null" pageNumber="33">Bluete</normalizedToken>
: 
<normalizedToken id="BD46A41676E9BEDF345529D1A02113D8" originalValue="Später" pageId="null" pageNumber="33">Spaeter</normalizedToken>
<normalizedToken id="D1CB95ACB740617A420E3F92DB8929BD" originalValue="Frühling" pageId="null" pageNumber="33">Fruehling</normalizedToken>
und 
<normalizedToken id="941ED51949710A12F08638B8EE4BC5E4" originalValue="Frühsommer" pageId="null" pageNumber="33">Fruehsommer</normalizedToken>
.
</paragraph>
<paragraph id="6AE132EFBC08C347D1DEE19729B38843" pageId="null" pageNumber="33">
<emphasis id="2ADB20C12D1E7A49F645C61FDC4FAE9B" italics="true" pageId="null" pageNumber="33">
<pageBreakToken id="6C2EED7256A7A6D60455A063B78F07DF" pageId="null" pageNumber="33">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="F54758BC9C5FA001FAAB9F783DECDB17" italics="true" pageId="null" pageNumber="33">14:</emphasis>
Material aus den Alpen (Mattick in Tischler 1950).
</paragraph>
<paragraph id="EE67E7AFA17145385252A868E5362E58" pageId="null" pageNumber="33">
<emphasis id="43FD35FBF0FE5F38E0C06938B1D71A95" italics="true" pageId="null" pageNumber="33">Standort.</emphasis>
Kollin, montan und subalpin. Trockene bis wechselfeuchte, kalkhaltige bis schwach saure 
<normalizedToken id="792F5A27B20520EB2779544D112BE169" originalValue="Böden" pageId="null" pageNumber="33">Boeden</normalizedToken>
. Lichte 
<normalizedToken id="2F41551B34657C4FB69660A3A24E4A23" originalValue="Wälder" pageId="null" pageNumber="33">Waelder</normalizedToken>
, 
<normalizedToken id="D1C96F9E61F793ECE6C9B9AA6DED63AD" originalValue="Gebüsche" pageId="null" pageNumber="33">Gebuesche</normalizedToken>
, Zwergstrauchgesellschaften, Riedwiesen.
</paragraph>
<paragraph id="2ACC5AACC3F06D79769B5FB7C6FA2915" pageId="null" pageNumber="33">
<emphasis id="1D40E1BBDA122EB985EE1862AF66AED8" italics="true" pageId="null" pageNumber="33">Verbreitung.</emphasis>
<normalizedToken id="678D0065F65999A40221F43B25246F38" originalValue="Ungenügend" pageId="null" pageNumber="33">Ungenuegend</normalizedToken>
bekannt: Alpen, Alpenvorland, Apennin, Jura, 
<normalizedToken id="1B023704AD2B3169D43D1DAA2D2D042D" originalValue="Süddeutschland" pageId="null" pageNumber="33">Sueddeutschland</normalizedToken>
(kommt im Schwarzwald nicht vor). - Im Gebiet verbreitet, ziemlich 
<normalizedToken id="68610C322F376DEC0A199AF4CB411DCE" originalValue="häufig" pageId="null" pageNumber="33">haeufig</normalizedToken>
. Karte der zirkumalpinen Verbreitung von Bresinsky (1965).
</paragraph>
