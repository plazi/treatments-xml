<bibRefCitation id="08403EFAFF90FFCEFB16AA7F8193FACF" author="Poupin, J." box="[355,502,1297,1323]" pageId="36" pageNumber="37" refId="ref74192" refString="Poupin, J. (2018) Les Crustaces decapodes des Petites Antilles: Avec de nouvelles observations pour Saint-Martin, la Guadeloupe et la Martinique. Museum national d'Histoire naturelle, Paris, 264 pp." type="book" year="2018">Poupin 2018</bibRefCitation>
).
</paragraph>
