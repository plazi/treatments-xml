<subSubSection id="4530B538A161CEFD2477E5B8B01FB5BA" pageId="null" pageNumber="545" type="description">
<paragraph id="55497B387F8C596C28B7B5C56B7BCD4C" pageId="null" pageNumber="545">
50-100 cm hoch. Stengel zerstreut und kurz behaart (Haare mehrzellig). 
<normalizedToken id="8201AD26F8F2F150E7CAC818942D8DD8" originalValue="Blätter" pageId="null" pageNumber="545">Blaetter</normalizedToken>
lanzettlich, 
<emphasis id="5F6E606BDD605C76566D39822C57BBD6" italics="true" pageId="null" pageNumber="545">
mit 
<normalizedToken id="5A3CC3F02B9D61B56EC17E70A6CF0397" originalValue="verschmälertem" pageId="null" pageNumber="545">verschmaelertem</normalizedToken>
Grunde sitzend.
</emphasis>
<normalizedToken id="BA3C3CA9FAB3321431F3BD5429A4933B" originalValue="Blütenköpfe" pageId="null" pageNumber="545">Bluetenkoepfe</normalizedToken>
in einer Rispe, 
<emphasis id="60ACED74E92B1AD6263C0C171F82ABE2" italics="true" pageId="null" pageNumber="545">im Durchmesser 1</emphasis>
- 
<emphasis id="0141CB341E79D12099009D7F6DE693E2" italics="true" pageId="null" pageNumber="545">
1,5 cm. 
<normalizedToken id="9077D83B78154C295C11C9DAC724FC1D" originalValue="Hülle" pageId="null" pageNumber="545">Huelle</normalizedToken>
3,5
</emphasis>
- 
<emphasis id="C4C4A47370F00F27CC6B446998AB5ABE" italics="true" pageId="null" pageNumber="545">4,5 mm lang.</emphasis>
<normalizedToken id="D399B9DEAF43F864AFEABD570718F5FB" originalValue="Hüllblätter" pageId="null" pageNumber="545">Huellblaetter</normalizedToken>
anliegend, die 
<normalizedToken id="065F2F5EEA01273EDEC5A62B42F359A6" originalValue="äußern" pageId="null" pageNumber="545">aeussern</normalizedToken>
etwa halb so lang wie die innern, 
<emphasis id="5ED535CB044B4EEEBCDCCD0B4237BA9F" italics="true" pageId="null" pageNumber="545">
schmal 
<normalizedToken id="458215DCD2B5D8593E24094893F05B7B" originalValue="häutig" pageId="null" pageNumber="545">haeutig</normalizedToken>
berandet, nicht lederig
</emphasis>
, am Rande zerstreut behaart, die innern im untersten Drittel oder in der Mitte am breitesten. 
<emphasis id="2817BF6BFB50895890AF41F4949D5DF7" italics="true" pageId="null" pageNumber="545">
<normalizedToken id="00F6BCFCC6B204218E2AAD8CC31B8D01" originalValue="Zungenblüten" pageId="null" pageNumber="545">Zungenblueten</normalizedToken>
<normalizedToken id="FC4A18B3857355D7C5D647E857459368" originalValue="weiß" pageId="null" pageNumber="545">weiss</normalizedToken>
</emphasis>
(bei 
<normalizedToken id="D24A821062E0F7554739220A8497C38F" originalValue="Aufblühen" pageId="null" pageNumber="545">Aufbluehen</normalizedToken>
<normalizedToken id="F9A7CE131AD717C755285D7C04760CAE" originalValue="rötlich" pageId="null" pageNumber="545">roetlich</normalizedToken>
). 
<emphasis id="883ABDB50E0DC4A9CFDD5B429CEEFA71" italics="true" pageId="null" pageNumber="545">
<taxonomicName id="7370D0CB9D34872B743AE4A65A0CA40E" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="545" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
2,3
</emphasis>
- 
<emphasis id="E50ACDBA88B55B2C056BDA651921401D" italics="true" pageId="null" pageNumber="545">4 mm lang.</emphasis>
- 
<normalizedToken id="842990A450097835158144EDD690AAC7" originalValue="Blüte" pageId="null" pageNumber="545">Bluete</normalizedToken>
: 
<normalizedToken id="E5CFA6E630D5413368D276C6E8078C22" originalValue="Später" pageId="null" pageNumber="545">Spaeter</normalizedToken>
Sommer und Herbst.
</paragraph>
<paragraph id="D338360E7358D3D4DF17504FEE24F4C3" pageId="null" pageNumber="545">
<emphasis id="B7B6AFAD26D51CC564A59A68D20736E1" italics="true" pageId="null" pageNumber="545">Zytologische Angaben.</emphasis>
Keine Untersuchungen
</paragraph>
<paragraph id="5306DDA14DFC0A40AD3FDBBC94437A92" pageId="null" pageNumber="545">
<emphasis id="C035E4BFC088728F615002B10C240C03" italics="true" pageId="null" pageNumber="545">Standort.</emphasis>
Kollin. Feuchte, lockere, 
<normalizedToken id="FC8EF600B48F8890F598BC42F758AAA7" originalValue="nährstoffreiche" pageId="null" pageNumber="545">naehrstoffreiche</normalizedToken>
und meist kalkhaltige 
<normalizedToken id="5D348883F73A44549C8C5643E35730C0" originalValue="Böden" pageId="null" pageNumber="545">Boeden</normalizedToken>
. 
<normalizedToken id="CD5A212559E6FA54A00699D28B25C2D4" originalValue="Auenwaldränder" pageId="null" pageNumber="545">Auenwaldraender</normalizedToken>
, Kiesgruben, 
<normalizedToken id="422FDE6DBDDB77EFF8FA20F83D4656D6" originalValue="Schuttplätze" pageId="null" pageNumber="545">Schuttplaetze</normalizedToken>
, Riedwiesen. 
<emphasis id="8D043A0C762460292A4D48B4BF01CB18" italics="true" pageId="null" pageNumber="545">Impatienti-Solidaginetum</emphasis>
Moor 1958.
</paragraph>
<paragraph id="9742B3406C332FC83B030702EB48F55C" pageId="null" pageNumber="545">
<emphasis id="1F1B5FC6915744602B659A92FCE70A9C" italics="true" pageId="null" pageNumber="545">Verbreitung.</emphasis>
<normalizedToken id="3F30B333AC337DDC67D940310CC38043" originalValue="Ursprünglich" pageId="null" pageNumber="545">Urspruenglich</normalizedToken>
<emphasis id="668226EB7EB8969D8B79D834CE5D1008" italics="true" pageId="null" pageNumber="545">nordamerikanische Pflanze.</emphasis>
In Europa als Zierpflanze 
<normalizedToken id="E960CEF496581A3E3BBBAC57FDD8D7A7" originalValue="eingeführt" pageId="null" pageNumber="545">eingefuehrt</normalizedToken>
. - Im Gebiet gelegentlich als Zierpflanze kultiviert, ziemlich selten verwildert.
</paragraph>
</subSubSection>
