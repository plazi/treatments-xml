<subSubSection id="017453210BD9C028BEED513D0F18B58B" pageId="null" pageNumber="590" type="description">
<paragraph id="98C1C4B691731D4C97DC849F69D726AF" pageId="null" pageNumber="590">
Ausdauernd, mit langem, senkrecht stehendem, pfahlwurzelartigem Rhizom; im obern Teil des Rhizoms nur mit wenigen Seitenwurzeln; 10-30 cm hoch. Stengel aufrecht, 1 
<normalizedToken id="8AD766CB49E450C69AEED48B80D1D61C" originalValue="köpfig" pageId="null" pageNumber="590">koepfig</normalizedToken>
, gegen den Kopf meist verdickt, mit 1-2 
<normalizedToken id="2B05555F05F0936AAAA4EF888DA570C2" originalValue="schuppenförmigen" pageId="null" pageNumber="590">schuppenfoermigen</normalizedToken>
, kleinen 
<normalizedToken id="33FF22D4EFD8779ABAFDBD0A8C007A8E" originalValue="Blättern" pageId="null" pageNumber="590">Blaettern</normalizedToken>
, behaart (
<emphasis id="66955AD1918C710E7D397A7F2D62DA2B" italics="true" pageId="null" pageNumber="590">Haare an der Spitze 3</emphasis>
- 
<emphasis id="63C221C5F341D2994B282A2D5DB64296" italics="true" pageId="null" pageNumber="590">
5teilig, die 
<normalizedToken id="C050E506B5AF1D9FC8CE63E8F5B31F4F" originalValue="längeren" pageId="null" pageNumber="590">laengeren</normalizedToken>
ca. 1 mm lang
</emphasis>
). 
<normalizedToken id="2B60E98F786D8325026AD5E7390BB040" originalValue="Grundständige" pageId="null" pageNumber="590">Grundstaendige</normalizedToken>
<normalizedToken id="849E69E0B22FC2C3C42A8A24A7C8D2AA" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
lanzettlich, 
<emphasis id="E9F3DD855DD027CE8809532C7B7A8CA3" italics="true" pageId="null" pageNumber="590">
grob und buchtig 
<normalizedToken id="17F3F739846C41849DBE993CE1FED104" originalValue="gezähnt" pageId="null" pageNumber="590">gezaehnt</normalizedToken>
bis fiederteilig, am Rande oft wellig
</emphasis>
, beiderseits dicht behaart (Haare an der Spitze 3-5teilig). 
<emphasis id="F359E0BBBA0817201F9F1F0CA90C19D0" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="B5573DC917750503DEEA3BB396D66767" originalValue="Köpfe" pageId="null" pageNumber="590">Koepfe</normalizedToken>
vor dem 
<normalizedToken id="FF8D89C519712475B0DB75751D59EB14" originalValue="Aufblühen" pageId="null" pageNumber="590">Aufbluehen</normalizedToken>
nickend.
</emphasis>
<normalizedToken id="0FDA760412461BA16D745F776F3F23D8" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
1,2-1,5 cm lang, entlang der Mittelnerven der 
<normalizedToken id="677808DA884C77C47FF41A993E5D7C6B" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
behaart (Haare 1-1,5 mm lang), sonst meist kahl; innere 
<normalizedToken id="7BFC5FC7F11F3FBF203DDFFD953889D9" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
auf der Innenseite kahl. 
<normalizedToken id="74352164B678417F2BD489F94E20E245" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
gelb, 1,5-2 cm lang. 
<normalizedToken id="860ADDFC56E2B8EF1C1D267AA3BE23A7" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
alle gleich gestaltet, 
<emphasis id="45C4D7E6C1C75365C6F53C1438342A8C" italics="true" pageId="null" pageNumber="590">8</emphasis>
- 
<emphasis id="1A70EF11C3923EB66DFA9145B918A943" italics="true" pageId="null" pageNumber="590">15 mm lang</emphasis>
, braun, undeutlich 15rippig, undeutlich querrunzelig, 
<emphasis id="163CB55173DEE76D1FECF3B4F80447E9" italics="true" pageId="null" pageNumber="590">nach oben kurz und stachelig behaart</emphasis>
, schnabelartig 
<normalizedToken id="A50203611CE245CD9717B359E86E3640" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
. 
<taxonomicName id="DE65C0B500AE1D9E8EB343EB74FEA054" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
gelblich 
<normalizedToken id="CC2DF278B5D260E5008FBD0087B7C749" originalValue="weiß" pageId="null" pageNumber="590">weiss</normalizedToken>
, 2reihig; 
<normalizedToken id="A0CC90619281FA02DB9CBFAAF18297DF" originalValue="äußere" pageId="null" pageNumber="590">aeussere</normalizedToken>
Pappusborsten 
<normalizedToken id="AD2D103FC2669DF28B079E9A1701787C" originalValue="kürzer" pageId="null" pageNumber="590">kuerzer</normalizedToken>
als die innern, nicht federig behaart oder federig behaart, innere federig behaart, 
<emphasis id="E04D13593097EB88150583FB69BBB0D3" italics="true" pageId="null" pageNumber="590">am Grunde wenig verbreitert.</emphasis>
- 
<normalizedToken id="BE29230B647508F8AF93B694BE033D7C" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: 
<normalizedToken id="070BF43BCD5D24F968AE0DEC7F341A02" originalValue="Später" pageId="null" pageNumber="590">Spaeter</normalizedToken>
<normalizedToken id="BB493B90BE7FBD5CE6D51B779D0A0C4D" originalValue="Frühling" pageId="null" pageNumber="590">Fruehling</normalizedToken>
und 
<normalizedToken id="C2E4B684893250E855D88D0CCE55C465" originalValue="früher" pageId="null" pageNumber="590">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="43C0AFB9B9A52EBD4B48D3216E37B3F1" pageId="null" pageNumber="590">
<emphasis id="9C4DEF3676C569AFCD05239BCAAA58FD" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0BCDB9616BAC9248ABC288223412D7CF" italics="true" pageId="null" pageNumber="590">8:</emphasis>
Material aus Italien (Sambuco) (Larsen 1956a), aus den 
<normalizedToken id="4CB139E96E03BE641279C5557EFEA7F8" originalValue="Südwestalpen" pageId="null" pageNumber="590">Suedwestalpen</normalizedToken>
(Delay 1969b). 
<emphasis id="C8A479F34A17919A832C8E3CF271C8D3" italics="true" pageId="null" pageNumber="590">2n</emphasis>
= 
<emphasis id="9937CB39BA9C6DDE7868A5E6CE4C6A1A" italics="true" pageId="null" pageNumber="590">14:</emphasis>
Material aus botanischen 
<normalizedToken id="3B5A63EF9755B01E8A6B4706AEB2355D" originalValue="Gärten" pageId="null" pageNumber="590">Gaerten</normalizedToken>
(Bergman 1935).
</paragraph>
<paragraph id="B704C19EB31CE0B445DC67FF12856D68" pageId="null" pageNumber="590">
<emphasis id="FFBE4B4DB7040BF6D97E37B5344CE8F0" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Kollin und montan. Trockene, sonnige, steinige 
<normalizedToken id="7DEE95A185930B475F4B7E1036298619" originalValue="Hänge" pageId="null" pageNumber="590">Haenge</normalizedToken>
.
</paragraph>
<paragraph id="04219DCD56446363CCD461085AAF14A2" pageId="null" pageNumber="590">
<emphasis id="EEA24A7EC6D880D185E76DA6A5B4DCCC" italics="true" pageId="null" pageNumber="590">
Verbreitung. 
<normalizedToken id="CF1F8421952487B423CCAA58C97DD952" originalValue="Südeuropäische" pageId="null" pageNumber="590">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
West- und 
<normalizedToken id="D1404021915DA06C429AE670B5DC72FE" originalValue="nordwärts" pageId="null" pageNumber="590">nordwaerts</normalizedToken>
bis 
<normalizedToken id="F84EED049E1DA6B30D7570CB78130CA8" originalValue="Ostpyrenäen" pageId="null" pageNumber="590">Ostpyrenaeen</normalizedToken>
, 
<normalizedToken id="716AC78C4094652DD1BDDDDE5BA8F6C8" originalValue="Dép" pageId="null" pageNumber="590">Dep</normalizedToken>
. Ain, Alpen, Thessalonien; die Art bildet mit nahe verwandten Sippen eine mediterrane Artengruppe, die 
<normalizedToken id="78E9C33058A713A018798BAE656A71CC" originalValue="ostwärts" pageId="null" pageNumber="590">ostwaerts</normalizedToken>
bis zum Kaukasus vorkommt. - Im Gebiet: 
<normalizedToken id="BCCADAA215EEA239A4812073535B3EE2" originalValue="Dép" pageId="null" pageNumber="590">Dep</normalizedToken>
. Ain, Savoyen (Gegend des Lac du Bourget, Gegend von 
<normalizedToken id="B970CF3723DB78A73B4156EF4547DEEF" originalValue="Chambéry" pageId="null" pageNumber="590">Chambery</normalizedToken>
), Wallis (zwischen Saxon und den Visper 
<normalizedToken id="49059853546AB3E14D0909AE132C07E2" originalValue="Tälern" pageId="null" pageNumber="590">Taelern</normalizedToken>
), Aostatal (vor allem in der Gegend von Aosta), Comerseegebiet, Bergamasker Alpen, unteres Vintschgau; nicht 
<normalizedToken id="81360645C63199E2694A94C01FC5088E" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
