, 
<collectingRegion id="49CDF830FFCEFFCFF757FCABEECEFCCC" box="[2204,2291,796,821]" country="Russia" name="Samara" pageId="11" pageNumber="418">Samar</collectingRegion>
, and 
<collectingRegion id="49CDF830FFCEFFCFF68AFCABEFB6FCCC" box="[2369,2443,796,821]" country="Philippines" name="Southern Leyte" pageId="11" pageNumber="418">Leyte</collectingRegion>
