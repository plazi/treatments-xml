<paragraph id="33124794DEA2062DB360252DB1B74BD8" pageId="null" pageNumber="144">
<taxonomicName id="2BD328E0B27301339579394CDAA54395" authority="L." class="Insecta" family="Eulophidae" genus="Hyssopus" kingdom="Animalia" order="Hymenoptera" pageId="null" pageNumber="144" phylum="Arthropoda" rank="species" species="officinalis">
Hyssopus 
