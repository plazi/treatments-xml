<subSubSection id="C3485ED60946B218EC95FDFF246848E4" pageId="18" pageNumber="469" type="etymology">
<paragraph id="8BED0D5D0946B218EC95FDFF21904848" blockId="18.[151,1437,547,753]" pageId="18" pageNumber="469">
<emphasis id="B926D14F0946B218EC95FDFF21294814" bold="true" box="[151,290,547,573]" pageId="18" pageNumber="469">Etymology:</emphasis>
<taxonomicName id="4C5276DE0946B218ED2BFDFF21644814" authorityName="Hamilton" authorityYear="1822" box="[297,367,547,573]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="genus">
<emphasis id="B926D14F0946B218ED2BFDFF21644814" box="[297,367,547,573]" italics="true" pageId="18" pageNumber="469">Garra</emphasis>
</taxonomicName>
: named based on a vernacular Indian name, a fish living in mud; 
<taxonomicName id="4C5276DE0946B218E851FDFF25154814" authority=": Latin" authorityName="Latin" box="[1107,1310,547,573]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="species" species="longipinnis">
<emphasis id="B926D14F0946B218E851FDFF24DA4814" box="[1107,1233,547,573]" italics="true" pageId="18" pageNumber="469">longipinnis</emphasis>
: Latin
</taxonomicName>
, 
<emphasis id="B926D14F0946B218E92BFDFF257F4814" box="[1321,1396,547,573]" italics="true" pageId="18" pageNumber="469">longus</emphasis>
for long, and 
<emphasis id="B926D14F0946B218ED04FD9B214D4849" box="[262,326,583,608]" italics="true" pageId="18" pageNumber="469">pinna</emphasis>
for fin.
</paragraph>
