Jabal Akhdar 
<taxonomicName id="4C5276DE0946B218EE2AFDB7226048AC" authorityName="Hamilton" authorityYear="1822" box="[552,619,619,645]" class="Actinopterygii" family="Cyprinidae" genus="Garra" kingdom="Animalia" order="Cypriniformes" pageId="18" pageNumber="469" phylum="Chordata" rank="genus">Garra</taxonomicName>
.
</paragraph>
