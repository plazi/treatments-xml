<taxonomicName id="4C246CDEFFBDFFF880A52976369A986F" authority="Meyl." authorityName="Meyl." box="[136,396,1823,1850]" class="Myxomycetes" family="Cribrariaceae" genus="Cribraria" kingdom="Protozoa" order="Liceales" pageId="5" pageNumber="36" phylum="Mycetozoa" rank="species" species="lepida">
<emphasis id="B950CB4FFFBDFFF880A529763654986F" bold="true" box="[136,322,1823,1850]" italics="true" pageId="5" pageNumber="36">Cribraria lepida</emphasis>
Meyl.
</taxonomicName>
(
<figureCitation id="131F0BD8FFBDFFF881B7294936C8986F" box="[410,478,1824,1850]" captionStart="FIGURE 2" captionStartId="6.[136,229,1417,1439]" captionTargetBox="[151,1436,425,1393]" captionTargetId="figure-139@6.[151,1436,425,1393]" captionTargetPageId="6" captionText="FIGURE 2. Cribraria lepida. a, b. Sporangium. c. Stalk, sporotheca, calyculus, dictydine granules and spores. d. Nodules, dictydine granules and spores." figureDoi="http://doi.org/10.5281/zenodo.6555889" httpUri="https://zenodo.org/record/6555889/files/figure.png" pageId="5" pageNumber="36">Fig. 2</figureCitation>
