<emphasis id="B950CB4FFFBEFFFB80A52BE036169ACB" bold="true" box="[136,256,1417,1439]" pageId="6" pageNumber="37">FIGURE 2.</emphasis>
<taxonomicName id="4C246CDEFFBEFFFB81252BE336BC9ACA" box="[264,426,1418,1439]" class="Myxomycetes" family="Cribrariaceae" genus="Cribraria" kingdom="Protozoa" order="Liceales" pageId="6" pageNumber="37" phylum="Mycetozoa" rank="species" species="lepida">
