<paragraph id="6D0836D113075C59FF15FBBCCFA1FB0E" blockId="3.[174,1233,1057,1307]" pageId="3" pageNumber="456">
Distribution. Widespread in Europe, recorded from Austria, Belgium, British Isles, Czech Republic, Denmark, Estonia, Finland, France, Germany, Greece, Hungary, Italy, Poland, Slovakia, Spain, Sweden, Switzerland (
<bibRefCitation id="09264B2013075C59FCD5FBFCC935FBCE" author="Papp, L. &amp; Cerny, M." box="[803,1056,1120,1147]" pageId="3" pageNumber="456" refId="ref19613" refString="Papp, L. &amp; Cerny, M. 2015. Agromyzidae (Diptera) of Hungary. Volume 1. Agromyzinae. Nagykovacsi, Pars Ltd., 1 - 416. DOI: http: // doi. org / 10.18655 / Agromyzidae. Vol. 1." type="book" year="2015">Papp &amp; Černý, 2015</bibRefCitation>
). 
<emphasis id="5FC3EAC313075C59FBB6FBFCC9C5FBCF" bold="true" box="[1088,1232,1120,1147]" pageId="3" pageNumber="456">
In 
<collectingCountry id="15A0764113075C59FB93FBFDC9DEFBCF" box="[1125,1227,1120,1146]" name="Ukraine" pageId="3" pageNumber="456">Ukraine</collectingCountry>
.
</emphasis>
<collectingRegion id="AF73F83313075C59FF58FB1CCC78FB2E" box="[174,365,1153,1179]" country="Ukraine" name="Dnipropetrovs'k" pageId="3" pageNumber="456">Dnipropetrovsk</collectingRegion>
, 
<collectingRegion id="AF73F83313075C59FE8EFB1CCCCBFB2E" box="[376,478,1153,1179]" country="Ukraine" name="Donets'k" pageId="3" pageNumber="456">Donetsk</collectingRegion>
, 
<collectingRegion id="AF73F83313075C59FE1CFB1CCF59FB2E" box="[490,588,1153,1179]" country="Ukraine" name="Kharkiv" pageId="3" pageNumber="456">Kharkiv</collectingRegion>
, 
<collectingRegion id="AF73F83313075C59FDA1FB1CCF85FB2E" box="[599,656,1153,1179]" country="Ukraine" name="Kyiv" pageId="3" pageNumber="456">Kyiv</collectingRegion>
, 
<collectingRegion id="AF73F83313075C59FD6AFB1CCFE6FB2E" box="[668,755,1153,1179]" country="Ukraine" name="Poltava" pageId="3" pageNumber="456">Poltava</collectingRegion>
and 
<collectingRegion id="AF73F83313075C59FCD8FB1CCE64FB2E" box="[814,881,1153,1179]" country="Ukraine" name="Sumy" pageId="3" pageNumber="456">Sumy</collectingRegion>
Regions (
<bibRefCitation id="09264B2013075C59FC10FB1CC993FB2E" author="Guglya, Yu." box="[998,1158,1153,1179]" pageId="3" pageNumber="456" pagination="61 - 68" refId="ref19059" refString="Guglya, Yu. 2011. A study of the fauna of leaf-miner flies of the subfamily Agromyzinae (Diptera: Agromyzidae) of Ukraine. Report 1. 28 new species for the fauna of Ukraine. The Kharkov Entomological Society Gazette, 19 (2), 61 - 68 [In Russian]." type="journal article" year="2011">Guglya, 2011</bibRefCitation>
, 
<bibRefCitation id="09264B2013075C59FB67FB1DC9D9FB2E" author="Guglya, Yu." box="[1169,1228,1152,1179]" pageId="3" pageNumber="456" pagination="29 - 38" refId="ref19304" refString="Guglya, Yu. 2015. A study of the fauna of leaf-miner flies of the subfamily Agromyzinae (Diptera: Agromyzidae) of Ukraine. Report 3. Eleven new species for the fauna of Ukraine. The Kharkov Entomological Society Gazette, 23 (2), 29 - 38." type="journal article" year="2015">2015</bibRefCitation>
, 
<bibRefCitation id="09264B2013075C59FF58FB3CCDE9FB0E" author="Guglya, Yu." box="[174,252,1185,1211]" pageId="3" pageNumber="456" pagination="17 - 24" refId="ref19357" refString="Guglya, Yu. 2016 a. A study of the fauna of leaf-miner flies of the subfamily Agromyzinae (Diptera: Agromyzidae) of Ukraine. Report 4. Thirteen new species for the fauna of Ukraine. The Kharkov Entomological Society Gazette, 24 (2), 17 - 24. URL: http: // nbuv. gov. ua / UJRN / Vkhet _ 2016 _ 24 _ 2 _ 7" type="journal article" year="2016">2016 a</bibRefCitation>
, 
<bibRefCitation id="09264B2013075C59FEF1FB3DCC51FB0E" author="Guglya, Yu." box="[263,324,1184,1211]" pageId="3" pageNumber="456" pagination="48 - 56" refId="ref19484" refString="Guglya, Yu. 2017. A study of the fauna of leaf-miner flies of the subfamily Agromyzinae (Diptera: Agromyzidae) of Ukraine. Report 5. Seven new species for the fauna of Ukraine. The Kharkov Entomological Society Gazette, 25 (1), 48 - 56." type="journal article" year="2017">2017</bibRefCitation>
); 
<collectingRegion id="AF73F83313075C59FEA1FB3CCF1CFB0E" box="[343,521,1185,1211]" country="Ukraine" name="Zakarpattya" pageId="3" pageNumber="456">Transcarpathia</collectingRegion>
