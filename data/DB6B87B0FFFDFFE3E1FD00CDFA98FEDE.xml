<bibRefCitation id="37534B57FFFDFFE3E0AE00CDFDF4FF72" author="Fruhstorfer, H." box="[404,599,151,177]" pageId="5" pageNumber="30" pagination="310" refId="ref9058" refString="Fruhstorfer, H. (1908) Neue Argynnis und Melitaea. Internationale Entomologische Zeitschrift, 1, 310." type="journal article" year="1908">Fruhstorfer, 1908</bibRefCitation>
