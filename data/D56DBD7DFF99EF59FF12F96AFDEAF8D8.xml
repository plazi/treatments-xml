<geoCoordinate id="38F06AACFF9AEF59FD82F8F0FDEFF8D8" box="[519,602,1861,1888]" degrees="0.009" direction="south" orientation="latitude" pageId="50" pageNumber="51" precision="55" value="-0.009">0.009 s</geoCoordinate>
