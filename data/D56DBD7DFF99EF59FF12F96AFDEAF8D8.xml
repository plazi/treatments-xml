<geoCoordinate id="38F06AACFF9AEF59FD64F894FC93F884" box="[737,806,1825,1852]" degrees="0.13" direction="south" orientation="latitude" pageId="50" pageNumber="51" precision="555" value="-0.13">0.13 s</geoCoordinate>
