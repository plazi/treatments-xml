<heading id="D0BD81EC296BFF90DEB2FAC7F62EB400" bold="true" box="[162,1040,1339,1363]" centered="true" fontSize="8" level="2" pageId="1" pageNumber="174" reason="3">
<emphasis id="B93EEA92296BFF90DEB2FAC7F62EB400" bold="true" box="[162,1040,1339,1363]" pageId="1" pageNumber="174">
Key to the species of the 
<taxonomicName id="4C4A4D03296BFF90DFAAFAC0F151B400" authorityName="Cho &amp; Borowiec" authorityYear="2016" box="[442,879,1339,1363]" class="Insecta" family="Chrysomelidae" genus="Gonioctena" kingdom="Animalia" order="Coleoptera" pageId="1" pageNumber="174" phylum="Arthropoda" rank="species" species="mauroi" subGenus="Brachyphytodecta">
<emphasis id="B93EEA92296BFF90DFAAFAC0F007B400" bold="true" box="[442,569,1339,1363]" italics="true" pageId="1" pageNumber="174">Gonioctena</emphasis>
(
<emphasis id="B93EEA92296BFF90DC58FAC0F131B400" bold="true" box="[584,783,1339,1363]" italics="true" pageId="1" pageNumber="174">Brachyphytodecta</emphasis>
) 
<emphasis id="B93EEA92296BFF90DD0FFAC0F151B400" bold="true" box="[799,879,1339,1363]" italics="true" pageId="1" pageNumber="174">mauroi</emphasis>
</taxonomicName>
species-group
</emphasis>
</heading>
</paragraph>
</subSubSection>
