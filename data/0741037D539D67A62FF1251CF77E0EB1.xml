<subSubSection id="E406D4E033B946646AE272316ED156F8" pageId="null" pageNumber="50" type="description">
<paragraph id="70E74BB1F50F738A3FA768A4EA5813D3" pageId="null" pageNumber="50">
Unterscheidet sich von 
<taxonomicName id="430F3308CE7B16D20016338ECD5E6E62" class="Magnoliopsida" family="Ranunculaceae" genus="Anemone" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="50" phylum="Tracheophyta" rank="species" species="nemorosa">
<emphasis id="71FB481073F7FBBD9E20F108F64EE966" italics="true" pageId="null" pageNumber="50">A. nemorosa</emphasis>
</taxonomicName>
(Nr. 2) durch folgende Merkmale: 
<emphasis id="8AD038F15DC070E1F84D5D01D3C1670B" italics="true" pageId="null" pageNumber="50">
Abschnitte der 3teiligen 
<normalizedToken id="40C83B1659BDC5100AAC7BB3BBA1565A" originalValue="Stengelblätter" pageId="null" pageNumber="50">Stengelblaetter</normalizedToken>
<normalizedToken id="2416FA7E5D5CA90D05BF7A14B596C7F2" originalValue="±" pageId="null" pageNumber="50">+/-</normalizedToken>
<normalizedToken id="6A27C3B335D85540DAFFDE2EFC5D8E85" originalValue="regelmäßig" pageId="null" pageNumber="50">regelmaessig</normalizedToken>
und fein 
<normalizedToken id="85709C4FBA2A0F1C75AFD73E92CBCFFB" originalValue="gezähnt" pageId="null" pageNumber="50">gezaehnt</normalizedToken>
, nicht geteilt
</emphasis>
, mit Achselknospen (bei den andern Arten keine Knospen). Staubbeutel 
<normalizedToken id="262ED8388F13AE262613BBFB4AB3744D" originalValue="weiß" pageId="null" pageNumber="50">weiss</normalizedToken>
oder blau. - 
<normalizedToken id="40C69BE4630C0CCCBC518B6A84F2AF58" originalValue="Blüte" pageId="null" pageNumber="50">Bluete</normalizedToken>
: 
<normalizedToken id="E1A9A653C4FBE5886F859316C34A7B59" originalValue="Später" pageId="null" pageNumber="50">Spaeter</normalizedToken>
<normalizedToken id="E9ECAFA85E0478F8F4D833A4DDDF39BF" originalValue="Frühling" pageId="null" pageNumber="50">Fruehling</normalizedToken>
und 
<normalizedToken id="4AFDA36863DC7DDF199C1B0C4F70D888" originalValue="früher" pageId="null" pageNumber="50">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="FB1DFFE48E5D4846CABD31EA94A6CA60" pageId="null" pageNumber="50">
<emphasis id="A787AE53B85AC927B30EE7C30C1AD825" italics="true" pageId="null" pageNumber="50">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="1C76B98E98E8045A813B801E1DE0529D" italics="true" pageId="null" pageNumber="50">28-32:</emphasis>
Material aus botanischen 
<normalizedToken id="7668638EAF95DEB5757180DBB2BA7368" originalValue="Gärten" pageId="null" pageNumber="50">Gaerten</normalizedToken>
(Langlet 1932). 
<emphasis id="73593C03934EB28C0DFA681F2C4CCC8E" italics="true" pageId="null" pageNumber="50">2n</emphasis>
= 
<emphasis id="A5CA04B950E4ED0C89655EBE20E57E33" italics="true" pageId="null" pageNumber="50">32:</emphasis>
Ohne Herkunftsangabe (Mattick in Tischler 1950), aus Tirol (Favarger 1965). Baumberger (1970) fand an Material aus botanischen 
<normalizedToken id="DED2629E6B75131D7BF6B20616C28A3E" originalValue="Gärten" pageId="null" pageNumber="50">Gaerten</normalizedToken>
<emphasis id="DF98948B5E28F0BAE5727E465BD30618" italics="true" pageId="null" pageNumber="50">2n</emphasis>
= 
<emphasis id="45E2AB3D33FE61FA0B901982E0781AB6" italics="true" pageId="null" pageNumber="50">16, 32</emphasis>
.
</paragraph>
<paragraph id="B2A6081AE7AE1936DC937C18ACADBBA4" pageId="null" pageNumber="50">
<emphasis id="5CC63A9EC2CB01FCC4DD1B6420A0BDC3" italics="true" pageId="null" pageNumber="50">Standort.</emphasis>
Kollin und montan. Steinige 
<normalizedToken id="9D56AE9BE0A564C8B1816893B2B47EE6" originalValue="Böden" pageId="null" pageNumber="50">Boeden</normalizedToken>
. 
<normalizedToken id="8632FFAB4EA9BBAD71226C3E46559F89" originalValue="Laubmischwälder" pageId="null" pageNumber="50">Laubmischwaelder</normalizedToken>
, selten in Wiesen.
</paragraph>
<paragraph id="3EA7307401303C6AC3A5C56F88386846" pageId="null" pageNumber="50">
<emphasis id="B57D76A1F90278903085A936F5DC54D2" italics="true" pageId="null" pageNumber="50">
Verbreitung. 
<normalizedToken id="32BAC6B982FD18B72ACA5DF55767E694" originalValue="Südeuropäische" pageId="null" pageNumber="50">Suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
Nordspanische Gebirge, Westalpen, (nach Gaussen 1966 nicht in Frankreich vorkommend), 
<normalizedToken id="76C3CD2370A4A3F020F713F17C3E5128" originalValue="nördlicher" pageId="null" pageNumber="50">noerdlicher</normalizedToken>
Apennin, Ostalpen (vom Gardasee, Cles und Meran 
<normalizedToken id="5FD68C13858178DDD678EAE9FBEBCB64" originalValue="ostwärts" pageId="null" pageNumber="50">ostwaerts</normalizedToken>
), Nordkroatien, 
<normalizedToken id="81F9682A1AA79A34CB4C6AAD96314FAC" originalValue="Südkarpaten" pageId="null" pageNumber="50">Suedkarpaten</normalizedToken>
. Die in den nordamerikanischen Appalachen vorkommende Sippe wird jetzt als 
<taxonomicName id="B8CE07FD26BBB48C860CB30A8E615EAA" authority="Pursh" authorityName="Pursh" class="Magnoliopsida" family="Ranunculaceae" genus="Anemone" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="50" phylum="Tracheophyta" rank="species" species="lancifolia">
<emphasis id="7DF60CDC6E54CFB14B882D720757E7B8" italics="true" pageId="null" pageNumber="50">A. lancifolia</emphasis>
Pursh
</taxonomicName>
abgetrennt. Verbreitungskarten von 
<normalizedToken id="B9EA55759D9071F02E81993EF6A3D298" originalValue="Hultén" pageId="null" pageNumber="50">Hulten</normalizedToken>
(1958) und Meusel (1965). - Im Gebiet: Gegend von Meran.
</paragraph>
</subSubSection>
