<emphasis id="B9626913FFC7FF07FF1A8873E650F8F8" bold="true" box="[151,282,1857,1881]" pageId="22" pageNumber="23">FIGURE 10</emphasis>
. 
<taxonomicName id="4C16CE82FFC7FF07FEA48873E520F8F8" authority="(Reid, 1951)" authorityName="Just" authorityYear="2022" baseAuthorityName="Reid" baseAuthorityYear="1951" box="[297,618,1857,1881]" class="Malacostraca" family="Synopiidae" genus="Tironella" kingdom="Animalia" order="Amphipoda" pageId="22" pageNumber="23" phylum="Arthropoda" rank="species" species="altifrons" status="comb. nov.">
<emphasis id="B9626913FFC7FF07FEA48873E6ABF8F8" box="[297,481,1857,1881]" italics="true" pageId="22" pageNumber="23">Tironella altifrons</emphasis>
(
<bibRefCitation id="EF87C8F0FFC7FF07FE7D8873E529F8F8" author="Reid, D. M." box="[496,611,1857,1881]" pageId="22" pageNumber="23" pagination="189 - 291" refId="ref50178" refString="Reid, D. M. (1951) Report on the Amphipoda (Gammaridea and Caprellidea) of the Coast of Tropical West Africa. Atlantide Report, 2, 189 - 291." type="journal article" year="1951">Reid, 1951</bibRefCitation>
)
</taxonomicName>
<emphasis id="B9626913FFC7FF07FDFF8873E5ADF8F8" bold="true" box="[626,743,1857,1881]" pageId="22" pageNumber="23">
<taxonomicNameLabel id="A251D468FFC7FF07FDFF8873E5ADF8F8" box="[626,743,1857,1881]" pageId="22" pageNumber="23" rank="species">comb. nov.</taxonomicNameLabel>
</emphasis>
Holotype, ♂. 
<emphasis id="B9626913FFC7FF07FCF18873E4D1F8F8" bold="true" box="[892,923,1857,1881]" pageId="22" pageNumber="23">clv</emphasis>
, head and antennae; 
<emphasis id="B9626913FFC7FF07FBFB8873E3DBF8F8" bold="true" box="[1142,1169,1857,1881]" pageId="22" pageNumber="23">p3</emphasis>
, pereopod 3; 
<emphasis id="B9626913FFC7FF07FAAD8873E210F8F8" bold="true" box="[1312,1370,1857,1881]" pageId="22" pageNumber="23">p.5–7</emphasis>
, pereopods 5 to 7; 
<emphasis id="B9626913FFC7FF07FEAC8857E673F8DC" bold="true" box="[289,313,1893,1917]" pageId="22" pageNumber="23">us</emphasis>
, urosome. (clv and us from 
<bibRefCitation id="EF87C8F0FFC7FF07FDDA8857E588F8DC" author="Reid, D. M." box="[599,706,1893,1917]" pageId="22" pageNumber="23" pagination="189 - 291" refId="ref50178" refString="Reid, D. M. (1951) Report on the Amphipoda (Gammaridea and Caprellidea) of the Coast of Tropical West Africa. Atlantide Report, 2, 189 - 291." type="journal article" year="1951">Reid 1951</bibRefCitation>
, fig.31).
</paragraph>
</caption>
<caption id="DF69E589FFC6FF06FF1A8A88E329FA57" ID-DOI="http://doi.org/10.5281/zenodo.6572047" ID-Zenodo-Dep="6572047" httpUri="https://zenodo.org/record/6572047/files/figure.png" pageId="23" pageNumber="24" startId="23.[151,250,1466,1490]" targetBox="[178,1412,191,1430]" targetPageId="23">
