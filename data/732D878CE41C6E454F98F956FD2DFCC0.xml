<paragraph id="FB3B369AE41F6E454F98FF49FC69FEC9" blockId="58.[151,1436,152,450]" pageId="58" pageNumber="59">
The 
<typeStatus id="243F8838E41F6E454FCBFF49FE91FF0F" box="[196,295,182,204]" pageId="58" pageNumber="59">holotypes</typeStatus>
of 
<taxonomicName id="3C844D19E41F6E454E48FF49FD88FF0F" authorityName="* Cockerell" authorityYear="1905" box="[327,574,182,204]" class="Insecta" family="Colletidae" genus="Paracolletes" kingdom="Animalia" order="Hymenoptera" pageId="58" pageNumber="59" phylum="Arthropoda" rank="species" species="providellus">
<emphasis id="C9F0EA88E41F6E454E48FF49FD88FF0F" box="[327,574,182,204]" italics="true" pageId="58" pageNumber="59">Paracolletes providellus</emphasis>
</taxonomicName>
, 
<taxonomicName id="3C844D19E41F6E454D45FF49FCE8FF0F" authorityName="* Cockerell" authorityYear="1905" box="[586,862,182,204]" class="Insecta" family="Colletidae" genus="Paracolletes" kingdom="Animalia" order="Hymenoptera" pageId="58" pageNumber="59" phylum="Arthropoda" rank="species" species="obscuripennis">
<emphasis id="C9F0EA88E41F6E454D45FF49FCE8FF0F" box="[586,862,182,204]" italics="true" pageId="58" pageNumber="59">Paracolletes obscuripennis</emphasis>
</taxonomicName>
and 
<taxonomicName id="3C844D19E41F6E454C81FF49FAB8FF0F" authorityName="* Cockerell" authorityYear="1929" box="[910,1294,182,204]" class="Insecta" family="Colletidae" genus="Paracolletes" kingdom="Animalia" order="Hymenoptera" pageId="58" pageNumber="59" phylum="Arthropoda" rank="subSpecies" species="providellus" subSpecies="caerulescens">
