<emphasis id="87C4EA8606002E4CFEA6FAB7FDC922FA" box="[297,547,1944,1968]" italics="true" pageId="42" pageNumber="343">Lewindromia unidentata</emphasis>
(
<bibRefCitation id="D1214B6506002E4CFDBDFAB7FD2222FA" author="Ruppell, E. W." box="[562,712,1944,1968]" pageId="42" pageNumber="343" pagination="3 - 28" refId="ref29730" refString="Ruppell, E. W. (1830) Beschreibung und Abbildung von 24 Arten kurzschwanzigen Krabben, als Beitrag zur Naturgeschichte des rothen Meeres. H. L. Bronner, Frankfurt, pp. 3 - 28." type="book chapter" year="1830">Rüppell, 1830</bibRefCitation>
