<subSubSection id="E4770960293553255AE62EF0303E5FF3" pageId="null" pageNumber="93" type="description">
<paragraph id="8C6EDB18851B56BB55AE07261607E73A" pageId="null" pageNumber="93">
Unterscheidet sich von 
<taxonomicName id="3E89460425771A777E50A96970EDA52F" class="Magnoliopsida" family="Lamiaceae" genus="Ajuga" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="93" phylum="Tracheophyta" rank="species" species="reptans">
<emphasis id="DD86553A9320215BDBA756E521F08E05" italics="true" pageId="null" pageNumber="93">A. reptans</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="DACAD22E0B96DA3FEA620F43182118D6" italics="true" pageId="null" pageNumber="93">
Keine 
<normalizedToken id="68FDF99192AA7B69D9DF19DEE9569408" originalValue="Ausläufer" pageId="null" pageNumber="93">Auslaeufer</normalizedToken>
</emphasis>
, jedoch oft 
<normalizedToken id="6A3C9AB451CF19D02163EAC60A958651" originalValue="seitenständige" pageId="null" pageNumber="93">seitenstaendige</normalizedToken>
Rosetten aus Wurzelknospen, 10-30 cm hoch; 
<emphasis id="3338AF9FD5811C0473ABF1E086500969" italics="true" pageId="null" pageNumber="93">Stengel meist dicht und ringsum behaart</emphasis>
; 
<normalizedToken id="3FF05E3A8E9774E50E35A8A0F7DADBCA" originalValue="Blätter" pageId="null" pageNumber="93">Blaetter</normalizedToken>
stumpf 
<normalizedToken id="21FE3D2C3A5BA6A500AF811F649C7EFE" originalValue="gezähnt" pageId="null" pageNumber="93">gezaehnt</normalizedToken>
; 
<emphasis id="438AA94479B56AC3506E2F8F44F4185F" italics="true" pageId="null" pageNumber="93">
die 
<normalizedToken id="9562F2AAECE0FFE8CAEB2552AFCFF246" originalValue="Blätter" pageId="null" pageNumber="93">Blaetter</normalizedToken>
im 
<normalizedToken id="E1CE2B1E9E648AEDF196FB3125566C17" originalValue="Blütenstand" pageId="null" pageNumber="93">Bluetenstand</normalizedToken>
deutlich 
<normalizedToken id="491D68F5653FAC5EA87EF678E654DF9C" originalValue="gezähnt" pageId="null" pageNumber="93">gezaehnt</normalizedToken>
, oft wenig tief 3teilig
</emphasis>
, 
<emphasis id="600A64B52B98685238A9CAFA1F26829E" italics="true" pageId="null" pageNumber="93">
<pageBreakToken id="835D7173B451C25FC6173A3C6E4593B7" pageId="null" pageNumber="93">meist</pageBreakToken>
blau angelaufen;
</emphasis>
Kelch 4-6 mm lang; Krone 1,2-1,8 cm lang; 
<normalizedToken id="3787F24B8F4EFC0590C1364C77E231C2" originalValue="Teilfrüchte" pageId="null" pageNumber="93">Teilfruechte</normalizedToken>
2-2,6 mm lang und 1,2-1,6 mm breit. - 
<normalizedToken id="D60999A3695A37E2371FBD00490D156A" originalValue="Blüte" pageId="null" pageNumber="93">Bluete</normalizedToken>
: 
<normalizedToken id="5DE6F111C9EF6075B7F9B6AF465204B7" originalValue="Frühling" pageId="null" pageNumber="93">Fruehling</normalizedToken>
und oft nochmals im Herbst.
</paragraph>
<paragraph id="F779E3079E5495582095C18B42EA40A6" pageId="null" pageNumber="93">
<emphasis id="9F6B41ABA6CC0E29AB85F93926CB5D1C" italics="true" pageId="null" pageNumber="93">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="779E9077F7D7568D93A078593B3DEBC7" italics="true" pageId="null" pageNumber="93">32:</emphasis>
Material aus Schleswig-Holstein (Scheerer 1940), aus Tirol (Mattick in Tischler 1950).
</paragraph>
<paragraph id="7049A88D46AE030705F88807CECC22C6" pageId="null" pageNumber="93">
<emphasis id="56A529D3A58E828C6CCE2F9362AD301E" italics="true" pageId="null" pageNumber="93">Standort</emphasis>
. Kollin, montan und subalpin. Ziemlich trockene, lockere, 
<normalizedToken id="D9D90D46A9717D13C4CA1CF1FCF03B52" originalValue="nährstoffreiche" pageId="null" pageNumber="93">naehrstoffreiche</normalizedToken>
<normalizedToken id="C20A171EB0444382CD13ACAA8C212EC0" originalValue="Böden" pageId="null" pageNumber="93">Boeden</normalizedToken>
in 
<normalizedToken id="68C659A923C331BCAA012E4C822A4272" originalValue="wärmeren" pageId="null" pageNumber="93">waermeren</normalizedToken>
Lagen. Halbtrockenwiesen, sonnige 
<normalizedToken id="7D1E73FC228687B001726094ED8EEA9E" originalValue="Hänge" pageId="null" pageNumber="93">Haenge</normalizedToken>
; auch in Unkrautgesellschaften.
</paragraph>
<paragraph id="4130B9DFEDE72AABAF1E86E161623C06" pageId="null" pageNumber="93">
<emphasis id="BA00FC93D8D0F456EE5D67ABED9410DC" italics="true" pageId="null" pageNumber="93">Verbreitung. Eurasiatische Pflanze:</emphasis>
West- und 
<normalizedToken id="BDC33E563893B1113E37F9FE425D38F8" originalValue="südwärts" pageId="null" pageNumber="93">suedwaerts</normalizedToken>
bis zu den 
<normalizedToken id="681434CB065CB3A753C9863BDAF9C86D" originalValue="Pyrenäen" pageId="null" pageNumber="93">Pyrenaeen</normalizedToken>
, Kalabrien, Thessalien, Kleinasien, Persien; 
<normalizedToken id="3EB9209B74E7F07E263F84ADB4FC27D9" originalValue="nordwärts" pageId="null" pageNumber="93">nordwaerts</normalizedToken>
bis 
<normalizedToken id="3CDB2B00BB7CE6C47EF892A1AAEAE1F4" originalValue="Südbelgien" pageId="null" pageNumber="93">Suedbelgien</normalizedToken>
, Norddeutschland; 
<normalizedToken id="0DE12C14BC6D3A3D7F926D1301D04A43" originalValue="ostwärts" pageId="null" pageNumber="93">ostwaerts</normalizedToken>
bis Japan. - Im Gebiet verbreitet, nicht 
<normalizedToken id="FC577707FA87C4B43EF6FE251B1F00E9" originalValue="häufig" pageId="null" pageNumber="93">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
