<subSubSection id="F0C7F2B70BE0838D3CD2601880A02555" pageId="null" pageNumber="576" type="nomenclature">
<paragraph id="0EA2E035A1365AADF98ECD83BC6440D2" pageId="null" pageNumber="576">
<taxonomicName id="EBD28E33A924E21CF831FEA1831FD397" authority="(L.) Miller" class="Liliopsida" family="Asparagaceae" genus="Muscari" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="576" phylum="Tracheophyta" rank="species" species="comosum">
Muscari 
<normalizedToken id="FCEA64A57D05858152E62C8B49CD437D" originalValue="comósum" pageId="null" pageNumber="576">comosum</normalizedToken>
(
<authorityName id="8A32D5D9D0864DE2D8BC1CD9C9A8A7C1" pageId="null" pageNumber="576">L.</authorityName>
