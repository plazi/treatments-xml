<paragraph id="A12436C9D37BFFEFFF10FB6018E16F7F" blockId="4.[151,756,257,1383]" pageId="4" pageNumber="148">
<emphasis id="93EFEADBD37BFFEFFF10FB6018D96EDD" bold="true" box="[151,435,1164,1189]" pageId="4" pageNumber="148">Rapports et différences</emphasis>
