<taxonomicName id="A2EA84A9FFE7FFD8FF71FD94FD7DFDCE" authority="(Walker, [1858])" baseAuthorityName="Walker" baseAuthorityYear="1858" box="[151,640,582,609]" class="Insecta" family="Noctuidae" genus="Eudocima" kingdom="Animalia" order="Lepidoptera" pageId="15" pageNumber="16" phylum="Arthropoda" rank="species" species="smaragdipicta">
<emphasis id="579E2338FFE7FFD8FF71FD94FD7DFDCE" bold="true" box="[151,640,582,609]" pageId="15" pageNumber="16">
<emphasis id="579E2338FFE7FFD8FF71FD94FE4AFDCF" bold="true" box="[151,439,582,609]" italics="true" pageId="15" pageNumber="16">Eudocima smaragdipicta</emphasis>
