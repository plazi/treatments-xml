<emphasis id="B90C5669E80851347FD1FE8A3D9DFE92" bold="true" box="[391,732,350,373]" pageId="8" pageNumber="43">
First country record for 
<collectingCountry id="F36FCAEBE80851347CC8FE8A3D96FE92" box="[670,727,350,373]" name="Laos" pageId="8" pageNumber="43">Laos</collectingCountry>
