<subSubSection id="61B08614FDC0ED62B42DBEE2DDBF8CF0" pageId="null" pageNumber="551" type="vernacular_names">
<paragraph id="CFFB4F1A8934019FDD1369097CC26D22" pageId="null" pageNumber="551">Faltenlilie</paragraph>
</subSubSection>
</title>
<subSubSection id="A21D1C245C7C90EAFF0244E62FD885E9" pageId="null" pageNumber="551" type="description">
<paragraph id="0A1E45B210A0049F54E4E7262C78A979" pageId="null" pageNumber="551">
Ausdauernd; Zwiebel vorhanden, klein, meist 
<normalizedToken id="3A79AF1E67879E26D85A01614102B4DB" originalValue="spindelförmig" pageId="null" pageNumber="551">spindelfoermig</normalizedToken>
. 
<normalizedToken id="FA193DB56CA4C272D47CFB7C183F5867" originalValue="Grundständige" pageId="null" pageNumber="551">Grundstaendige</normalizedToken>
<normalizedToken id="9D5A4CB70F57A3FE836E502DF9A36CA5" originalValue="Blätter" pageId="null" pageNumber="551">Blaetter</normalizedToken>
<emphasis id="1FA626543986F5427EF7D4E8767FEAB8" italics="true" pageId="null" pageNumber="551">
<normalizedToken id="5C2AAC0D7A11D9C103431BBA9D6CAF9B" originalValue="grasähnlich" pageId="null" pageNumber="551">grasaehnlich</normalizedToken>
, sehr schmal, fleischig;
</emphasis>
<normalizedToken id="CFB48313D83C203AE277ABC95E8C09C4" originalValue="Stengelblätter" pageId="null" pageNumber="551">Stengelblaetter</normalizedToken>
schmal lanzettlich. Stengel mit einer 
<normalizedToken id="E0C64B8E4A2AEC988ECBE38BC48BB106" originalValue="endständigen" pageId="null" pageNumber="551">endstaendigen</normalizedToken>
, oft noch mit einer 
<normalizedToken id="665FA3EF95F95CA0D042F5E9875D30B4" originalValue="seitenständigen" pageId="null" pageNumber="551">seitenstaendigen</normalizedToken>
<normalizedToken id="0911FBAA1A275E89924099D54733FC6C" originalValue="Blüte" pageId="null" pageNumber="551">Bluete</normalizedToken>
. 
<emphasis id="255D82F71750E4F5B492B2146F23600B" italics="true" pageId="null" pageNumber="551">
<normalizedToken id="0976D7839A65DFF6F2A8694258773B9D" originalValue="Blüten" pageId="null" pageNumber="551">Blueten</normalizedToken>
aufrecht, 
<normalizedToken id="C3DA683813EFE719C316FC4AC8AA0471" originalValue="trichterförmig" pageId="null" pageNumber="551">trichterfoermig</normalizedToken>
, 
<normalizedToken id="3B64EC6AFE004CA38898B3DB4D77D47D" originalValue="weiß" pageId="null" pageNumber="551">weiss</normalizedToken>
</emphasis>
, gelb oder 
<normalizedToken id="F4CDB51FAFE666728D305B9B4B9369C7" originalValue="rötlich" pageId="null" pageNumber="551">roetlich</normalizedToken>
. 
<normalizedToken id="BCB8114FA3C3353F0724DC14CDE4D797" originalValue="Perigonblätter" pageId="null" pageNumber="551">Perigonblaetter</normalizedToken>
6, frei, schmal lanzettlich oder schmal oval, 3-5nervig. 
<normalizedToken id="68C07831FF8E371AD6DD7AA644605379" originalValue="Staubblätter" pageId="null" pageNumber="551">Staubblaetter</normalizedToken>
6, 
<normalizedToken id="0523AF0E28391E73C405A8FA6AD7F878" originalValue="kürzer" pageId="null" pageNumber="551">kuerzer</normalizedToken>
als die 
<normalizedToken id="100AAA2A82F45B08BF563BB981579314" originalValue="Perigonblätter" pageId="null" pageNumber="551">Perigonblaetter</normalizedToken>
. Frucht eine 3 
<normalizedToken id="D67C7AA64DC3DE7315F75689D8FA88C6" originalValue="fächrige" pageId="null" pageNumber="551">faechrige</normalizedToken>
Kapsel, vielsamig; Griffel 1, mit 3 Narben.
</paragraph>
<paragraph id="A2803589A5E74A4C926659977934B629" pageId="null" pageNumber="551">
Die Gattung 
<taxonomicName id="2D09624A67D0C2113E42A3244B0AAF1E" class="Trilobita" family="Leiostegiidae" genus="Lloydia" kingdom="Animalia" order="Corynexochida" pageId="null" pageNumber="551" phylum="Arthropoda" rank="genus">
<emphasis id="B19729749193EF41D77105E5C8B52469" italics="true" pageId="null" pageNumber="551">Lloydia</emphasis>
</taxonomicName>
<normalizedToken id="14BE2E603620625C127F6B30A9A752B9" originalValue="umfaßt" pageId="null" pageNumber="551">umfasst</normalizedToken>
etwa 
<emphasis id="C9FAB905DCAE5FC9732F363663F2470A" italics="true" pageId="null" pageNumber="551">18 Arten, die vor allem im Mittelmeergebiet, in Zentral-, Nord- und Ostasien vorkommen</emphasis>
(am meisten Arten in 
<normalizedToken id="887097605D1E53B9DB8FA3D5A57C74D1" originalValue="Jünnan" pageId="null" pageNumber="551">Juennan</normalizedToken>
); nur unsere 
<taxonomicName id="6999E7FDE7409C91F11F90BB18949270" class="Liliopsida" family="Poaceae" genus="Cleistogenes" kingdom="Plantae" order="Poales" pageId="null" pageNumber="551" phylum="Tracheophyta" rank="species" species="serotina">
<emphasis id="BFF4D195E84E17841EC6C5E1E0BCF0CD" italics="true" pageId="null" pageNumber="551">
<authorityName id="CF2505D8EEF7DF4D49AC299D3DD48B1C" pageId="null" pageNumber="551">L.</authorityName>
serotina
</emphasis>
</taxonomicName>
kommt auch in Nordamerika vor. Verbreitungskarte von Meusel (1964).
</paragraph>
</subSubSection>
