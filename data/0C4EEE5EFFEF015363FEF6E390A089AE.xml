<bibRefCitation id="E07622B9FFEF015360F1F17597238AAE" author="WEISE J." box="[963,1106,373,396]" firstAuthor="WEISE" journalOrPublisher="Tijdschrift voor Entomologie" pageId="13" pageNumber="36" pagination="39 - 130" part="65" refId="ref33557" refString="WEISE J. 1922: Chrysomeliden der Indo-Malayischen Region. Tijdschrift voor Entomologie 65: 39 - 130." title="Chrysomeliden der Indo-Malayischen Region" type="journal article" year="1922">WEISE (1922)</bibRefCitation>
classified both 
<taxonomicName id="43E724CBFFEF015367C5F17597538A8E" authority="Jacoby, 1896" authorityName="Jacoby" authorityYear="1896" class="Insecta" family="Chrysomelidae" genus="Dorydea" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="costatipennis">
<emphasis id="B693835AFFEF015367C5F17590E18A8E" italics="true" pageId="13" pageNumber="36">Dorydea costatipennis</emphasis>
<bibRefCitation id="E07622B9FFEF015360A5F19597538A8E" author="JACOBY M." box="[919,1058,405,428]" firstAuthor="Jacoby" journalOrPublisher="Annali del Museo Civico di Storia Naturale di Genova" pageId="13" pageNumber="36" pagination="377 - 501" part="36" refId="ref31521" refString="JACOBY M. 1896 a: Descriptions of the new genera and species of phytophagous Coleoptera obtained by Dr. Modigliani in Sumatra. Annali del Museo Civico di Storia Naturale di Genova 36: 377 - 501." title="Descriptions of the new genera and species of phytophagous Coleoptera obtained by Dr. Modigliani in Sumatra" type="journal article" year="1896">Jacoby, 1896</bibRefCitation>
</taxonomicName>
and 
<taxonomicName id="43E724CBFFEF01536765F19590008AEE" authority="Jacoby, 1896" authorityName="Jacoby" authorityYear="1896" class="Insecta" family="Chrysomelidae" genus="Metellus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="costatipennis">
<emphasis id="B693835AFFEF01536765F19596368A8E" box="[1111,1351,405,428]" italics="true" pageId="13" pageNumber="36">Metellus costatipennis</emphasis>
<bibRefCitation id="E07622B9FFEF0153667FF19590008AEE" author="JACOBY M." firstAuthor="Jacoby" journalOrPublisher="Annali del Museo Civico di Storia Naturale di Genova" pageId="13" pageNumber="36" pagination="377 - 501" part="36" refId="ref31521" refString="JACOBY M. 1896 a: Descriptions of the new genera and species of phytophagous Coleoptera obtained by Dr. Modigliani in Sumatra. Annali del Museo Civico di Storia Naturale di Genova 36: 377 - 501." title="Descriptions of the new genera and species of phytophagous Coleoptera obtained by Dr. Modigliani in Sumatra" type="journal article" year="1896">
Jacoby, 
<quantity id="431FF2ADFFEF0153600EF1B590008AEE" box="[828,881,437,460]" metricMagnitude="1" metricUnit="m" metricValue="4.81584" pageId="13" pageNumber="36" unit="in" value="1896.0">1896</quantity>
</bibRefCitation>
</taxonomicName>
in the genus 
<taxonomicName id="43E724CBFFEF01536730F1B597F28AEE" authorityName="Baly" authorityYear="1864" box="[1026,1155,437,460]" class="Insecta" family="Chrysomelidae" genus="Platyxantha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFEF01536730F1B597F28AEE" box="[1026,1155,437,460]" italics="true" pageId="13" pageNumber="36">Platyxantha</emphasis>
</taxonomicName>
and due to homonymy he proposed a new substitute name of 
<taxonomicName id="43E724CBFFEF01536794F1D596088ACE" authorityName="Weise" authorityYear="1922" box="[1190,1401,469,492]" class="Insecta" family="Chrysomelidae" genus="Platyxantha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="jacobyi">
<emphasis id="B693835AFFEF01536794F1D596088ACE" box="[1190,1401,469,492]" italics="true" pageId="13" pageNumber="36">Platyxantha jacobyi</emphasis>
</taxonomicName>
for 
<taxonomicName id="43E724CBFFEF0153600EF1F5975C892E" authorityName="Jacoby" authorityYear="1896" box="[828,1069,501,524]" class="Insecta" family="Chrysomelidae" genus="Dorydea" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="costatipennis">
<emphasis id="B693835AFFEF0153600EF1F5975C892E" box="[828,1069,501,524]" italics="true" pageId="13" pageNumber="36">Dorydea costatipennis</emphasis>
</taxonomicName>
. 
<bibRefCitation id="E07622B9FFEF01536709F1F597CA892E" author="REID C. A. M." box="[1083,1211,501,524]" firstAuthor="REID" journalOrPublisher="Australian Journal of Entomology" pageId="13" pageNumber="36" pagination="1 - 9" part="38" refId="ref33192" refString="REID C. A. M. 1999: Reappraisal of the genus Taumacera Thunberg with descriptions of two new species from South-East Asia (Coleoptera: Chrysomelidae: Galerucinae). Australian Journal of Entomology 38: 1 - 9." title="Reappraisal of the genus Taumacera Thunberg with descriptions of two new species from South-East Asia (Coleoptera: Chrysomelidae: Galerucinae)" type="journal article" year="1999">REID (1999)</bibRefCitation>
omitted 
<taxonomicName id="43E724CBFFEF01536629F1F590F8890E" authorityName="Weise" authorityYear="1922" class="Insecta" family="Chrysomelidae" genus="Platyxantha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="jacobyi">
<emphasis id="B693835AFFEF01536629F1F590F8890E" italics="true" pageId="13" pageNumber="36">Platyxantha jacobyi</emphasis>
</taxonomicName>
in his list of 
<taxonomicName id="43E724CBFFEF01536738F215970E890E" authorityName="Thunberg" authorityYear="1814" box="[1034,1151,533,556]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFEF01536738F215970E890E" box="[1034,1151,533,556]" italics="true" pageId="13" pageNumber="36">Taumacera</emphasis>
</taxonomicName>
. In the current arrangement both 
<taxonomicName id="43E724CBFFEF01536044F235971D896E" authorityName="Jacoby" authorityYear="1896" box="[886,1132,565,588]" class="Insecta" family="Chrysomelidae" genus="Dorydea" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="costatipennis">
<emphasis id="B693835AFFEF01536044F235971D896E" box="[886,1132,565,588]" italics="true" pageId="13" pageNumber="36">Dorydea costatipennis</emphasis>
</taxonomicName>
and 
<taxonomicName id="43E724CBFFEF01536795F23596ED896E" authorityName="Jacoby" authorityYear="1896" box="[1191,1436,565,588]" class="Insecta" family="Chrysomelidae" genus="Metellus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="species" species="costatipennis">
<emphasis id="B693835AFFEF01536795F23596ED896E" box="[1191,1436,565,588]" italics="true" pageId="13" pageNumber="36">Metellus costatipennis</emphasis>
</taxonomicName>
are classified in 
<taxonomicName id="43E724CBFFEF015360D4F255972C894E" authorityName="Thunberg" authorityYear="1814" box="[998,1117,597,620]" class="Insecta" family="Chrysomelidae" genus="Taumacera" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="36" phylum="Arthropoda" rank="genus">
<emphasis id="B693835AFFEF015360D4F255972C894E" box="[998,1117,597,620]" italics="true" pageId="13" pageNumber="36">Taumacera</emphasis>
</taxonomicName>
and thus Weiseʼs replacement name is valid.
</paragraph>
