<figureCitation id="81FB2A2EFF99FFF8A784BAE0FA93F38B" box="[1263,1350,410,436]" captionStart="FIGURE 2" captionStartId="7.[136,229,1940,1962]" captionTargetBox="[306,1282,609,1912]" captionTargetId="figure-168@7.[302,1286,605,1916]" captionTargetPageId="7" captionText="FIGURE 2. A) Cereus hildmaninanus (whitish-pink flowers). B) Echinopsis oxygona (pink flowers). C) Frailea albifusca. D) Frailea castanea. E) Frailea albifusca.F) Frailea lepida.G) Frailea mammifera. H) Frailea pumila. I) Frailea pygmaea.J) Frailea erythracantha K) Gymnocalycium denudatum (white flowers). L) Gymnocalycium uruguayense (yellow flowers). Pictures by A. S. Oliveira." figureDoi="http://doi.org/10.5281/zenodo.6415611" httpUri="https://zenodo.org/record/6415611/files/figure.png" pageId="7" pageNumber="160">Fig. 2C</figureCitation>
and 
<figureCitation id="81FB2A2EFF99FFF8A614BAE0FF7CF3E7" captionStart="FIGURE 2" captionStartId="7.[136,229,1940,1962]" captionTargetBox="[306,1282,609,1912]" captionTargetId="figure-168@7.[302,1286,605,1916]" captionTargetPageId="7" captionText="FIGURE 2. A) Cereus hildmaninanus (whitish-pink flowers). B) Echinopsis oxygona (pink flowers). C) Frailea albifusca. D) Frailea castanea. E) Frailea albifusca.F) Frailea lepida.G) Frailea mammifera. H) Frailea pumila. I) Frailea pygmaea.J) Frailea erythracantha K) Gymnocalycium denudatum (white flowers). L) Gymnocalycium uruguayense (yellow flowers). Pictures by A. S. Oliveira." figureDoi="http://doi.org/10.5281/zenodo.6415611" httpUri="https://zenodo.org/record/6415611/files/figure.png" pageId="7" pageNumber="160">Fig. 2F</figureCitation>
), 
<taxonomicName id="DEC04D28FF99FFF8A3D7BAC5FD95F3E6" authority="Backeberg (1936: 415)" authorityName="Backeberg" authorityPageNumber="415" authorityYear="1936" box="[188,576,446,473]" class="Magnoliopsida" family="Cactaceae" genus="Frailea" kingdom="Plantae" order="Caryophyllales" pageId="7" pageNumber="160" phylum="Tracheophyta" rank="species" species="castanea">
<emphasis id="2BB4EAB9FF99FFF8A3D7BAC5FEEFF3E7" box="[188,314,447,472]" italics="true" pageId="7" pageNumber="160">F. castanea</emphasis>
<bibRefCitation id="7D514B5AFF99FFF8A22BBAC4FD95F3E6" author="Backeberg, C." box="[320,576,446,473]" pageId="7" pageNumber="160" pagination="415" refId="ref7724" refString="Backeberg, C. (1936) Frailea castanea Bckbg. sp. n. In: Backeberg, C. &amp; Knuth, F. M. (Eds.) Kaktus ABC. Gyldendals Forlagstrykkeri, Kobenhavn, p. 415." type="book chapter" year="1936">Backeberg (1936: 415)</bibRefCitation>
</taxonomicName>
