<subSubSection id="DCCBBC87FFC0004168C2FED6FD138F13" pageId="43" pageNumber="544" type="discussion">
<paragraph id="946EEF0CFFC0004168C2FED6FD138F13" blockId="43.[151,1436,150,357]" pageId="43" pageNumber="544">
<emphasis id="A6A5331EFFC0004168C2FED6FECE8F6B" bold="true" box="[199,315,258,284]" pageId="43" pageNumber="544">Remarks.</emphasis>
Records from 
<collectingCountry id="ECC6AF9CFFC0004169E1FED6FDBB8F6B" box="[484,590,258,284]" name="Australia" pageId="43" pageNumber="544">Australia</collectingCountry>
, 
<collectingCountry id="ECC6AF9CFFC000416A5FFED6FD368F6B" box="[602,707,258,284]" name="Malaysia" pageId="43" pageNumber="544">Malaysia</collectingCountry>
, and 
<collectingCountry id="ECC6AF9CFFC000416B05FED6FCA78F6B" box="[768,850,258,284]" name="Taiwan" pageId="43" pageNumber="544">Taiwan</collectingCountry>
can actually pertain to other species of 
<taxonomicName id="53D1948FFFC000416D1DFED6FE818F37" authority="Ewing, 1929" authorityName="Ewing" authorityYear="1929" class="Arachnida" family="Trombiculidae" genus="Neoschoengastia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trombidiformes" pageId="43" pageNumber="544" phylum="Arthropoda" rank="genus">
<emphasis id="A6A5331EFFC000416D1DFED6FF2E8F37" italics="true" pageId="43" pageNumber="544">Neoschoengastia</emphasis>
Ewing, 1929
</taxonomicName>
, for example, 
<taxonomicName id="53D1948FFFC000416A16FEF2FB5C8F37" authority="Wharton and Hardcastle, 1946" authorityName="Wharton and Hardcastle" authorityYear="1946" box="[531,1193,294,320]" class="Arachnida" family="Trombiculidae" genus="Neoschoengastia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trombidiformes" pageId="43" pageNumber="544" phylum="Arthropoda" rank="species" species="solomonis">
<emphasis id="A6A5331EFFC000416A16FEF2FCBE8F37" box="[531,843,294,320]" italics="true" pageId="43" pageNumber="544">Neoschoengastia solomonis</emphasis>
<bibRefCitation id="F04092FDFFC000416B54FEF2FB5C8F37" author="Wharton, G. W. &amp; Hardcastle, A. B." box="[849,1193,294,320]" pageId="43" pageNumber="544" pagination="286 - 322" refId="ref29250" refString="Wharton, G. W. &amp; Hardcastle, A. B. (1946) The genus Neoschongastia (Acarinida: Trombiculidae) in the Western Pacific area. Journal of Parasitology, 32, 286 - 322. https: // doi. org / 10.2307 / 3272682" type="journal article" year="1946">Wharton and Hardcastle, 1946</bibRefCitation>
</taxonomicName>
, which was described as a subspecies of 
<taxonomicName id="53D1948FFFC000416963FE9FFD178F13" authority="(Stekolnikov 2021)" baseAuthorityName="Stekolnikov" baseAuthorityYear="2021" box="[358,738,330,356]" class="Arachnida" family="Trombiculidae" genus="Neoschoengastia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trombidiformes" pageId="43" pageNumber="544" phylum="Arthropoda" rank="species" species="americana">
<emphasis id="A6A5331EFFC000416963FE9FFE0A8F13" box="[358,511,331,356]" italics="true" pageId="43" pageNumber="544">N. americana</emphasis>
(Stekolnikov 2021)
</taxonomicName>
.
</paragraph>
</subSubSection>
