<subSubSection id="DA04581D7993447F3AA151312762DADE" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="467DF63866D773489BDB1D6A1D1796A9" pageId="null" pageNumber="590">Blasses Habichtskraut</paragraph>
</subSubSection>
</title>
<subSubSection id="118F17339D2CE5D0CCD92F7A3E4F7E58" pageId="null" pageNumber="590" type="description">
<paragraph id="2A4FCB8177378145649B96E3BC526F17" pageId="null" pageNumber="590">
10-40 cm hoch. Stengel mit 1-3 (oft kleinen) 
<normalizedToken id="5C4B3A3699B31952A0C77B2B58632B98" originalValue="Stengelblättern" pageId="null" pageNumber="590">Stengelblaettern</normalizedToken>
, 2-12 
<normalizedToken id="2F5A5B1295F1A2E79096A37D46DA5065" originalValue="köpfig" pageId="null" pageNumber="590">koepfig</normalizedToken>
, besonders im untern Teil mit zahlreichen 1,2-5 mm langen, einfachen Haaren, im obern Teil mit zahlreichen 
<normalizedToken id="8A504BE1B532E30473A09C71CE4C0FC7" originalValue="Drüsenhaaren" pageId="null" pageNumber="590">Druesenhaaren</normalizedToken>
. 
<normalizedToken id="FC47EC79F198B8AC80C33B93F91A5583" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
am Grunde 
<normalizedToken id="9B71B70A3E9B1573C8BDEE536103EB0B" originalValue="plötzlich" pageId="null" pageNumber="590">ploetzlich</normalizedToken>
<normalizedToken id="9B881C9BC848F4650F3B7874B592F4ED" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
oder 
<normalizedToken id="195B07D5BDC223224462842D1F7AAA96" originalValue="herzförmig" pageId="null" pageNumber="590">herzfoermig</normalizedToken>
, mit 2-6 mm langen 
<normalizedToken id="1C138A7F90BE7D7BC033AC8B0C4C79BB" originalValue="Zähnen" pageId="null" pageNumber="590">Zaehnen</normalizedToken>
, am Rande, am Stiel und oft auch unterseits (besonders auf dem Mittelnerv) 
<emphasis id="7825245050EC4FED803278C83F0EDEF6" italics="true" pageId="null" pageNumber="590">mit 2</emphasis>
- 
<emphasis id="131083F6EF96F1B76F3515A93B9A1D72" italics="true" pageId="null" pageNumber="590">
10 mm langen, einfachen Haaren, 
<normalizedToken id="025B1D70C4E74B782E5C781643D8A7AA" originalValue="blaugrün" pageId="null" pageNumber="590">blaugruen</normalizedToken>
, ohne Flecken.
</emphasis>
<normalizedToken id="2378732BA58FEB8FED7CFA7727317B9B" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
9-12 mm lang. 
<normalizedToken id="1576796F34C77D9EA080749715CEECF7" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
mit 
<normalizedToken id="F0AD0E15E3EBF6F9469A440A828E581F" originalValue="Drüsenhaaren" pageId="null" pageNumber="590">Druesenhaaren</normalizedToken>
. 
<emphasis id="B3CF18943E258DE2073EB95EDFB3010C" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="210288D3B3E09DC3A03DE499ABBBF163" originalValue="Kronzähne" pageId="null" pageNumber="590">Kronzaehne</normalizedToken>
bewimpert
</emphasis>
(
<emphasis id="B0FD155C1703EEEAFF7FC9BCD4E7015A" italics="true" pageId="null" pageNumber="590">bei den andern Arten der Gruppe meist kahl</emphasis>
). 
<normalizedToken id="55384BDD5E227465EA359C5DF35E572C" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
2,5-3 mm lang. - 
<normalizedToken id="FDB34105123576FA4275BF8B3AFC913F" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: 
<normalizedToken id="39EFEF2FFF745068D3ACED8B4F227F45" originalValue="Früher" pageId="null" pageNumber="590">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="D8061D7F5F694E708D481923542EC6EC" pageId="null" pageNumber="590">
<emphasis id="180E7B43B75F1141BA8D507FB36E10EC" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E53075C613BDBD4D157A27F007A36390" italics="true" pageId="null" pageNumber="590">27:</emphasis>
Material aus botanischem Garten (als 
<taxonomicName id="891930FC1DEFA4B78A24F90091791FFC" authority="Fries" authorityName="Fries" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="saxifragum">
<emphasis id="79BEF595C7EDA0B91F0290AA6486AFCD" italics="true" pageId="null" pageNumber="590">H. saxifragum</emphasis>
Fries
</taxonomicName>
); wenige Chromosomenpaarungen, nur selten normaler Pollen (Gentcheff 1937a).
</paragraph>
<paragraph id="34815971ED892FD1BDF2BDAC36AA50E4" pageId="null" pageNumber="590">
<emphasis id="953F6185590E918D89158E365CF39568" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Montan und subalpin. Trockene, steinige, kalkarme 
<normalizedToken id="BAE0DE9B0DD7853EFDAEF2880A4E1E5A" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
in 
<normalizedToken id="5658508F98E904E966AAE82455B7CF44" originalValue="wärmeren" pageId="null" pageNumber="590">waermeren</normalizedToken>
Lagen. Felsspalten, 
<normalizedToken id="3439ADE96CC2524B078647B7E6A639D9" originalValue="Geröll" pageId="null" pageNumber="590">Geroell</normalizedToken>
, steinige 
<normalizedToken id="EC5887F2FADAEFC1F7ACCDDA67E9489D" originalValue="Hänge" pageId="null" pageNumber="590">Haenge</normalizedToken>
.
</paragraph>
<paragraph id="E61425B55288AB57DD88FD4F0A403FDC" pageId="null" pageNumber="590">
<emphasis id="4B395A788A55B67697E1075A714C048B" italics="true" pageId="null" pageNumber="590">
Verbreitung. 
<normalizedToken id="16A60EA31DE1E0CB6B46FD575EB238E3" originalValue="Europäisch-westasiatische" pageId="null" pageNumber="590">Europaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
Irland, 
<normalizedToken id="2719AC29B7EE7175788B2CB2509226C5" originalValue="Großbritannien" pageId="null" pageNumber="590">Grossbritannien</normalizedToken>
, Skandinavien, mittel- und 
<normalizedToken id="21DCE1DD9534C59918B0ACE4119AA03A" originalValue="südeuropäische" pageId="null" pageNumber="590">suedeuropaeische</normalizedToken>
Gebirge, Sardinien, Korsika, Kreta; Kleinasien, Libanon. - Im Gebiet: Vogesen, Schwarzwald (Schramberg, Lauterbach, Witznau), Jura (Orbe), Zentral- und 
<normalizedToken id="FC247B55CA03CFD339B3D50EEA68F6A9" originalValue="Südalpen" pageId="null" pageNumber="590">Suedalpen</normalizedToken>
(besonders im westlichen Teil); nicht 
<normalizedToken id="35655D3639EDD03EFF178561BCFBE982" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
