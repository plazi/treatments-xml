<subSubSection id="248518FCAD89B650F2683BD66FA4CF6E" pageId="null" pageNumber="37" type="description">
<paragraph id="19DB2EACEE86697404487FAE9EC19F51" pageId="null" pageNumber="37">
Ausdauernde 
<normalizedToken id="A88839357BA1F35220B3AB05FF89D3A4" originalValue="Kräuter" pageId="null" pageNumber="37">Kraeuter</normalizedToken>
. 
<normalizedToken id="E0B5D7963ECB098012C22591F7583427" originalValue="Blüten" pageId="null" pageNumber="37">Blueten</normalizedToken>
aktinomorph, zwitterig. 
<emphasis id="E87B962CF5D06F6211BB025B4E815D72" italics="true" pageId="null" pageNumber="37">
<normalizedToken id="97ECF6647B7C1B289DA7C24171B7CA0B" originalValue="Perigonblätter" pageId="null" pageNumber="37">Perigonblaetter</normalizedToken>
meist 5, kronblattartig
</emphasis>
. 
<normalizedToken id="B15378BB7B68BC53AE127CB5FE4A518F" originalValue="Honigblätter" pageId="null" pageNumber="37">Honigblaetter</normalizedToken>
klein, 
<normalizedToken id="73652681FF2BE4FBE1392049F9A7004B" originalValue="trichterförmig" pageId="null" pageNumber="37">trichterfoermig</normalizedToken>
, oder nicht vorhanden. 
<normalizedToken id="8E36A2F5A0E24B40193B6AB1059F61D2" originalValue="Staubblätter" pageId="null" pageNumber="37">Staubblaetter</normalizedToken>
zahlreich. 
<emphasis id="F7315D9AF455149B5C0EAE58BC615968" italics="true" pageId="null" pageNumber="37">Fruchtknoten 2-20</emphasis>
, auf kugeligem 
<normalizedToken id="B36D19F0E525E103DA4279B520326B4A" originalValue="Blütenboden" pageId="null" pageNumber="37">Bluetenboden</normalizedToken>
, 
<emphasis id="7315A2F05DCD5814B7E2BAF1B44CEA34" italics="true" pageId="null" pageNumber="37">mehrsamig.</emphasis>
</paragraph>
<paragraph id="C3C52AE7885F4EAC91FD08966570D4A2" pageId="null" pageNumber="37">
Die Gattung 
<taxonomicName id="B3088A9A5F4637B4C2954E4CE2114DB5" class="Magnoliopsida" family="Ranunculaceae" genus="Isopyrum" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="37" phylum="Tracheophyta" rank="genus">
<emphasis id="F5684CD0117976FC140F3AEA632385C0" italics="true" pageId="null" pageNumber="37">Isopyrum</emphasis>
</taxonomicName>
<normalizedToken id="09A735A3F2EA596AEC6273552FFF96CC" originalValue="umfaßt" pageId="null" pageNumber="37">umfasst</normalizedToken>
etwa 
<emphasis id="5B28BF444F18E9E4F795BBF758DC51B4" italics="true" pageId="null" pageNumber="37">
26 Arten; davon kommen 24 Arten in Ostasien vor; 1 Art ist im Himalaja und 1 Art in 
<normalizedToken id="1995D807790C96A7004E00CE3CCA389D" originalValue="Südeuropa" pageId="null" pageNumber="37">Suedeuropa</normalizedToken>
</emphasis>
. 
<normalizedToken id="573E07DCE1359F09F48C624C713EEBE2" originalValue="Über" pageId="null" pageNumber="37">Ueber</normalizedToken>
die Verwandtschaft mit der Gattung 
<taxonomicName id="02D905A2CEE38DC40BC0339A8A951EC3" class="Magnoliopsida" family="Ranunculaceae" genus="Aquilegia" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="37" phylum="Tracheophyta" rank="genus">
<emphasis id="7C7FAEE4984A984EA2E724F61614C170" italics="true" pageId="null" pageNumber="37">Aquilegia</emphasis>
</taxonomicName>
siehe dort.
</paragraph>
