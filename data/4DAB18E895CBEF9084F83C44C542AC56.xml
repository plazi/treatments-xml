<subSubSection id="960E12C63616FA7781BFA6854BE1194D" lastPageNumber="14" pageId="null" pageNumber="15" type="description">
<paragraph id="763A41F5C62FE4C4D28DB29068C891F2" pageId="null" pageNumber="15">
<normalizedToken id="F29B50CCBEB623C532CD6BF6C13AEBF1" originalValue="Blätter" pageId="null" pageNumber="15">Blaetter</normalizedToken>
<normalizedToken id="FA20F2B6FBDB33BB21F371A3918C9589" originalValue="sommergrün" pageId="null" pageNumber="15">sommergruen</normalizedToken>
, 
<emphasis id="DD8AA67EB72DBC076AA6D7F71022EFE4" italics="true" pageId="null" pageNumber="15">gefiedert</emphasis>
(mit einem Endteilblatt), sehr selten einfach. 
<normalizedToken id="B432396FC7689E5777439DC0C40058A7" originalValue="Blüten" pageId="null" pageNumber="15">Blueten</normalizedToken>
in Rispen, klein, ⚥ und 1geschlechtig (an der gleichen Pflanze), gelegentlich Pflanze 2 
<normalizedToken id="EC63FEB0477E844DEAEB2E040AF95C34" originalValue="häusig" pageId="null" pageNumber="15">haeusig</normalizedToken>
. Kelch 4teilig oder nicht vorhanden. Krone 2- oder 4 
<normalizedToken id="9D32CB8445F2122549C127534619EC3A" originalValue="blätterig" pageId="null" pageNumber="15">blaetterig</normalizedToken>
oder nicht vorhanden. 
<emphasis id="42E87B5082A680FC820F37AD9C1D9656" italics="true" pageId="null" pageNumber="15">
Frucht eine 
<normalizedToken id="CA8B788C0EA847B6D767FA2EA3209EE4" originalValue="geflügelte" pageId="null" pageNumber="15">gefluegelte</normalizedToken>
<normalizedToken id="340989FBD6B1A5AB08086A198BCA944B" originalValue="Nuß" pageId="null" pageNumber="15">Nuss</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="9E18EDCCBE4D569A8411ACF299A2675C" pageId="null" pageNumber="15">
Die Gattung 
<taxonomicName id="41CA9E8AF6EE73843541ABAACD5B558B" class="Magnoliopsida" family="Oleaceae" genus="Fraxinus" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="15" phylum="Tracheophyta" rank="genus">
<emphasis id="BF677803AB57886BA566312CA737FA21" italics="true" pageId="null" pageNumber="15">Fraxinus</emphasis>
</taxonomicName>
<normalizedToken id="211BD472ED2D332B48AF0AC0D0D7ABB2" originalValue="umfaßt" pageId="null" pageNumber="15">umfasst</normalizedToken>
etwa 
<emphasis id="236A24AB0F9233D05070F50A4F18E368" italics="true" pageId="null" pageNumber="15">
60 Arten und ist vor allem 
<normalizedToken id="A6A4F8113F16B329B22CF6AB95D1CBF8" originalValue="über" pageId="null" pageNumber="15">ueber</normalizedToken>
die 
<normalizedToken id="A79EE3903467A888FDE327BE788D3E51" originalValue="nördliche" pageId="null" pageNumber="15">noerdliche</normalizedToken>
<normalizedToken id="C18AB8DF5491B3D535F7CBBB7CA2625F" originalValue="Hemisphäre" pageId="null" pageNumber="15">Hemisphaere</normalizedToken>
verbreitet Chromosomengrundzahl:
</emphasis>
n = 23.
</paragraph>
<paragraph id="05A889D46EAC757B1A25117C8230E25F" pageId="null" pageNumber="15">
Beide im Gebiet vorkommenden Arten sind in bezug auf Blattform, 
<normalizedToken id="E922057F8C4969CA3E71C36D12F51FB5" originalValue="Blütenstand" pageId="null" pageNumber="15">Bluetenstand</normalizedToken>
und Fruchtform sehr vielgestaltig. Taxonomische Untersuchungen mit Verbreitungskarten der 
<normalizedToken id="2463D755F70C91D0D5FBB020E6FE2036" originalValue="europäischen" pageId="null" pageNumber="15">europaeischen</normalizedToken>
Arten von 
<normalizedToken id="A29BD2B5AB35BFD9510E99CC58A1FB50" originalValue="Kárpáti" pageId="null" pageNumber="15">Karpati</normalizedToken>
(1970).
</paragraph>
<paragraph id="0B63DF72EC0531FFCCF7097C92436699" pageId="null" pageNumber="14">
<table id="0399CE4494484186DB6F78E839DFA18F" frame="void" pageId="null" pageNumber="14" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="FDEF763E0A7551F15692E4423F5368B1" pageId="null" pageNumber="14">
<tr id="56CBBEAE7522D704CDC3FB763BD3C823" pageId="null" pageNumber="14">
<td id="8269830BE9C13D1F96FAD89982219E94" align="left" pageId="null" pageNumber="14" valign="top">
<pageBreakToken id="476A90D0D4E5BBB4B748579798616117" pageId="null" pageNumber="14" start="start">1</pageBreakToken>
. 
<normalizedToken id="5B2F5963C8899DB3A49BE951559D3915" originalValue="Blüten" pageId="null" pageNumber="14">Blueten</normalizedToken>
vor den 
<normalizedToken id="38B95472321058305A1002BD4660E5A2" originalValue="Blättern" pageId="null" pageNumber="14">Blaettern</normalizedToken>
erscheinend, ohne Krone und meist ohne Kelch; 
<normalizedToken id="B5ED796036F7DBB2575516BD4CF2E1CD" originalValue="Blätter" pageId="null" pageNumber="14">Blaetter</normalizedToken>
mit 9, 11 oder 13 meist ungestielten 
<normalizedToken id="AE6EA8AB1C7BE8D1EAF05FB8AB1D31B5" originalValue="Teilblättern" pageId="null" pageNumber="14">Teilblaettern</normalizedToken>
</td>
<td id="166858682B9ED52796679C32C48FE079" align="left" pageId="null" pageNumber="14" valign="bottom">
<taxonomicName id="EB145935F85C19BA72A647E7F22FA957" class="Magnoliopsida" family="Oleaceae" genus="Fraxinus" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="14" phylum="Tracheophyta" rank="species" species="excelsior">
<italic id="C1B513504FEC38523A12C92AB00A7E8B" pageId="null" pageNumber="14">F. excelsior</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="29622D9ED76801720534808C48A5A0BC" pageId="null" pageNumber="14">
<td id="AEE82AE0913508DED5E9A70AE1D6C20C" align="left" pageId="null" pageNumber="14" valign="top">
1*. 
<normalizedToken id="15822B5D150422EFC4706D4378814022" originalValue="Blüten" pageId="null" pageNumber="14">Blueten</normalizedToken>
mit den 
<normalizedToken id="423EABBB434C191300E0DC87E9C7D8B6" originalValue="Blättern" pageId="null" pageNumber="14">Blaettern</normalizedToken>
erscheinend, mit 2 oder 4 7-15 mm langen, sehr schmal lanzettlichen, 
<normalizedToken id="6B50CBD2A28A6039E2C5909FA18F5C78" originalValue="weißen" pageId="null" pageNumber="14">weissen</normalizedToken>
<normalizedToken id="57AA62B061B48018F0027FBBE776CC62" originalValue="Kronblättern" pageId="null" pageNumber="14">Kronblaettern</normalizedToken>
und tief 4teiligem Kelch; 
<normalizedToken id="DE8AE72030A306811B28ABE70C8AFDC3" originalValue="Blätter" pageId="null" pageNumber="14">Blaetter</normalizedToken>
mit 5, 7 oder 9 gestielten 
<normalizedToken id="61EAFE64BC64562F78E5C7D4ED6959A6" originalValue="Teilblättern" pageId="null" pageNumber="14">Teilblaettern</normalizedToken>
</td>
<td id="B1F854F3A2B55CC653438F0055968C46" align="left" pageId="null" pageNumber="14" valign="bottom">
<taxonomicName id="A3013F6F1D1E3FF7D0CDCF6BD22201CA" class="Magnoliopsida" family="Oleaceae" genus="Fraxinus" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="14" phylum="Tracheophyta" rank="species" species="ornus">
<italic id="A280842779655DF85CD6E9716B0EDD74" pageId="null" pageNumber="14">F. Ornus</italic>
</taxonomicName>
(Nr. 2)
</td>
</tr>
</tbody>
