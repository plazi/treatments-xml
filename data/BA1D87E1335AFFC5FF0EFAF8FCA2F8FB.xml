<bibRefCitation id="56254B06335AFFC5FCCAFA20FC65FA63" author="Schubart, O." box="[851,1023,1502,1528]" pageId="11" pageNumber="430" pagination="321 - 440" refId="ref9621" refString="Schubart, O. (1944) Os diplopodos de Pirassununga. Acta Zoologica Lilloana, 2, 321 - 440." type="journal article" year="1944">Schubart, 1944</bibRefCitation>
