<bibRefCitation id="56254B06335AFFC5FBB2F9D8FB3AF9DB" author="Carl, J." box="[1067,1184,1574,1600]" pageId="11" pageNumber="430" pagination="821 - 993" refId="ref7515" refString="Carl, J. (1914) Die Diplopoden von Columbien nebst Beitragen zur Morphologie der Stemmatoiuliden. Memoires de la Societe neuchateloise des Sciences naturelles, 5, 821 - 993." type="journal article" year="1914">Carl 1914</bibRefCitation>
; 
<bibRefCitation id="56254B06335AFFC5FB32F9D8FACBF9DB" author="Schubart, O." box="[1195,1361,1574,1600]" pageId="11" pageNumber="430" pagination="321 - 440" refId="ref9621" refString="Schubart, O. (1944) Os diplopodos de Pirassununga. Acta Zoologica Lilloana, 2, 321 - 440." type="journal article" year="1944">Schubart 1944</bibRefCitation>
, 
<bibRefCitation id="56254B06335AFFC5FAC5F9D8FA0DF9DA" author="Schubart, O." box="[1372,1431,1574,1601]" pageId="11" pageNumber="430" pagination="1 - 156" refId="ref9643" refString="Schubart, O. (1945) Os Proterospermophora do Distrito Federal (Myriapoda, Diplopoda). Arquivos do Museu National, 38, 1 - 156." type="journal article" year="1945">1945</bibRefCitation>
; 
<bibRefCitation id="56254B06335AFFC5FF0EF9B4FE86F9FE" author="Kraus, O." box="[151,284,1610,1637]" pageId="11" pageNumber="430" pagination="191 - 208" refId="ref9285" refString="Kraus, O. (1959) Myriapoden aus Peru, VII. Senckenbergiana biologica, 40 (3 / 4), 191 - 208." type="journal article" year="1959">Kraus 1959</bibRefCitation>
, 
<bibRefCitation id="56254B06335AFFC5FEBEF9B4FEF8F9FF" author="Kraus, O." box="[295,354,1610,1636]" pageId="11" pageNumber="430" pagination="241 - 264" refId="ref9312" refString="Kraus, O. (1960) Myriapoden aus Peru, IX. Senckenbergiana biologica, 41 (3 / 4), 241 - 264." type="journal article" year="1960">1960</bibRefCitation>
; 
<bibRefCitation id="56254B06335AFFC5FEF7F9B4FDBFF9FF" author="Golovatch, S. I." box="[366,549,1610,1636]" pageId="11" pageNumber="430" pagination="27 - 30" refId="ref8039" refString="Golovatch, S. I. (2001) Two new polydesmoid millipedes from a whitesand forest area near Manaus, Central Amazonia, Brazil (Diplopoda: Polydesmida: Pyrgodesmidae, Fuhrmannodesmidae). Arthropoda Selecta, 10 (1), 27 - 30. [https: // kmkjournals. com / upload / PDF / ArthropodaSelecta / 10 / 10 _ 1 % 20027 _ 030 % 20 Golovatch. pdf]" type="journal article" year="2001">Golovatch 2001</bibRefCitation>
