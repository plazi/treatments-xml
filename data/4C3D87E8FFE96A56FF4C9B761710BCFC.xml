<paragraph id="C42B36FEFFE96A56F7F194CC19E6B81F" blockId="18.[2060,2655,306,733]" lastBlockId="18.[1448,2656,740,1998]" pageId="18" pageNumber="776">
<emphasis id="F6E0EAECFFE96A56F7F194CC16BDB984" bold="true" box="[2061,2237,661,694]" pageId="18" pageNumber="776">Distribution.</emphasis>
W Africa in N 
<collectingCountry id="BC83766EFFE96A56F66194CC1456B984" box="[2461,2646,661,694]" name="Sierra Leone" pageId="18" pageNumber="776">Sierra Leone</collectingCountry>
, SW 
<collectingCountry id="BC83766EFFE96A56F7B9949916FFB9EF" box="[2117,2303,704,733]" name="Burkina Faso" pageId="18" pageNumber="776">Burkina Faso</collectingCountry>
, C 
<collectingCountry id="BC83766EFFE96A56F6CC9499178EB9EF" box="[2352,2446,704,733]" name="Ghana" pageId="18" pageNumber="776">Ghana</collectingCountry>
, N 
<collectingCountry id="BC83766EFFE96A56F63D94991417B9EF" box="[2497,2583,704,733]" name="Benin" pageId="18" pageNumber="776">Benin</collectingCountry>
, NW 
<collectingCountry id="BC83766EFFE96A56FA5594BD1812B837" box="[1449,1554,740,773]" name="Nigeria" pageId="18" pageNumber="776">Nigeria</collectingCountry>
, and NC 
<collectingCountry id="BC83766EFFE96A56F96394BD1936B837" box="[1695,1846,740,773]" name="Cameroon" pageId="18" pageNumber="776">Cameroon</collectingCountry>
