<collectingCountry id="BC83766EFFE96A56F6BE94BD1799B837" box="[2370,2457,740,773]" name="Sudan" pageId="18" pageNumber="776">Sudan</collectingCountry>
and 
<collectingCountry id="BC83766EFFE96A56F61A94BD1457B837" box="[2534,2647,740,773]" name="Uganda" pageId="18" pageNumber="776">Uganda</collectingCountry>
