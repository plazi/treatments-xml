<materialsCitation id="2AF03CEEFFFDFFA4FC56FB76FC583562" ID-GBIF-Occurrence="3783613302" country="Chile" location="Valparaiso" pageId="3" pageNumber="496" specimenCount="1" stateProvince="Valparaiso">
