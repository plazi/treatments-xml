<subSubSection id="C4CB0C5EFAA0FE4F04A9324BC35AEE1F" pageId="null" pageNumber="201" type="description">
<paragraph id="2FD1EEE523AC09388F74593E18AD18F6" pageId="null" pageNumber="201">
<normalizedToken id="E794B709EC94F87BE7FAEC8BF5EF1A7C" originalValue="Blätter" pageId="null" pageNumber="201">Blaetter</normalizedToken>
fleischig, 
<normalizedToken id="6282C0903831383B25E9A7C690856C59" originalValue="dunkelgrün" pageId="null" pageNumber="201">dunkelgruen</normalizedToken>
, 
<emphasis id="E997F567041C8EA51C09A436CAEFB799" italics="true" pageId="null" pageNumber="201">die mittleren und obern bis 1 cm breit</emphasis>
, mit 1 Endzahn und 
<emphasis id="ADCFB53AEFBA57E29DE40F58859841C0" italics="true" pageId="null" pageNumber="201">
jederseits meist nur mit 1 
<normalizedToken id="4CA52E5109DC9BE6983FFEF5274AB7BB" originalValue="großen" pageId="null" pageNumber="201">grossen</normalizedToken>
Zahn.
</emphasis>
Endzahn bedeutend breiter als lang, stumpf, mit kleiner aufgesetzter Spitze. 
<emphasis id="DAE15BC3A375B41AE05E76F6496E39A0" italics="true" pageId="null" pageNumber="201">Fruchtstiel 1</emphasis>
- 
<emphasis id="50857F767B1142FE55673B8A1D621AB9" italics="true" pageId="null" pageNumber="201">2</emphasis>
<normalizedToken id="1BA79877921B94494E621853B1902146" originalValue="½" pageId="null" pageNumber="201">1/2</normalizedToken>
<emphasis id="B370089C6216183056B3DBA9B61731DF" italics="true" pageId="null" pageNumber="201">mal so lang wie der Kelch</emphasis>
, auf der obern Seite mit 1 Haarreihe, sonst 
<normalizedToken id="3FAA5695F55C90C5EA036322C21E3A80" originalValue="±" pageId="null" pageNumber="201">+/-</normalizedToken>
kahl. Kelch anliegend behaart, 
<emphasis id="CC81BBB79C00B4A137F0BCFB6432E192" italics="true" pageId="null" pageNumber="201">am Rande der Zipfel mit 0,5</emphasis>
- 
<emphasis id="0D60F74592E77E53F70E90077943F582" italics="true" pageId="null" pageNumber="201">0,9 mm langen Haaren.</emphasis>
Krone im Durchmesser 4-6 mm, dunkelblau. 
<emphasis id="651FB2F4F8471C35F5F3B2405F1FD9BC" italics="true" pageId="null" pageNumber="201">Staubbeutel 0,4</emphasis>
- 
<emphasis id="C4E19EECD5FF78AE6872142B987C3614" italics="true" pageId="null" pageNumber="201">0,8 mm lang.</emphasis>
Griffel 0,7-1,1 mm lang. 
<normalizedToken id="F6514D98DF8F9EFCE634ED9761FBFDFB" originalValue="Blüte" pageId="null" pageNumber="201">Bluete</normalizedToken>
: 
<normalizedToken id="1123C1E4BEA5D50DAF52667B88AD7D04" originalValue="Frühling" pageId="null" pageNumber="201">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="2F0F94D46E761F1212A3CCED8BF97694" pageId="null" pageNumber="201">
<emphasis id="EC9D9197335D05AEC0D9C782B60D8ED5" italics="true" pageId="null" pageNumber="201">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E881A96D3183E4156EAED9895F152327" italics="true" pageId="null" pageNumber="201">18:</emphasis>
Material aus der Gegend von Wien und aus 
<normalizedToken id="3E612B07827EB76567B2FCEE00ED70BF" originalValue="Niederösterreich" pageId="null" pageNumber="201">Niederoesterreich</normalizedToken>
(Fischer 1967), aus 
<normalizedToken id="ED363B51EF2465129A7A0BC21A21682C" originalValue="Oberösterreich" pageId="null" pageNumber="201">Oberoesterreich</normalizedToken>
(Speta 1970), aus Mittelitalien (Speta 1971).
</paragraph>
<paragraph id="34B1A7AB2019B232364331B12047D4E6" pageId="null" pageNumber="201">
<emphasis id="384D4C112CBBB1FC2952A3D8EB259030" italics="true" pageId="null" pageNumber="201">Standort.</emphasis>
Kollin und montan. Trockene, lehmige 
<normalizedToken id="A1FB71BDED7A45D5AE926BD213284EDE" originalValue="Böden" pageId="null" pageNumber="201">Boeden</normalizedToken>
in warmen Lagen. Trockenwiesen, Weinberge, 
<normalizedToken id="9190BD375BCA65A6A04928EEB71039D9" originalValue="Getreideäcker" pageId="null" pageNumber="201">Getreideaecker</normalizedToken>
.
</paragraph>
<paragraph id="E1587CE597324B6E74E148D6FDEDE96D" pageId="null" pageNumber="201">
<emphasis id="AB8A6B8ADC28493FA2125F2B73BF8BAE" italics="true" pageId="null" pageNumber="201">Verbreitung. Ostmediterrane Pflanze:</emphasis>
Nord- und 
<normalizedToken id="0771444CD6BD0518A201F1D41058F695" originalValue="ostwärts" pageId="null" pageNumber="201">ostwaerts</normalizedToken>
bis 
<normalizedToken id="2887D82D40501254FD094600515A269B" originalValue="Niederösterreich" pageId="null" pageNumber="201">Niederoesterreich</normalizedToken>
, 
<normalizedToken id="64E0AF0EA4BC64918A53782A516C32E1" originalValue="Mähren" pageId="null" pageNumber="201">Maehren</normalizedToken>
, Bayern, Norditalien; 
<normalizedToken id="2B92A0A980C6E457906F6F8D2FFE1047" originalValue="ostwärts" pageId="null" pageNumber="201">ostwaerts</normalizedToken>
bis Kleinasien. - Im Gebiet mit Sicherheit nicht nachgewiesen; auf die Art ist zu achten.
</paragraph>
</subSubSection>
