<taxonomicName id="4C6D4D5EED3D3859FCEFFB8DFC07FB9F" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[810,962,1091,1118]" class="Maxillopoda" family="Notodelphyidae" genus="Adrodelphys" kingdom="Animalia" order="Cyclopoida" pageId="620" pageNumber="621" phylum="Arthropoda" rank="genus" status="gen. nov.">
