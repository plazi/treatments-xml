<paragraph pageId="0" pageNumber="1">Type species.</paragraph>
<paragraph pageId="0" pageNumber="1">
<taxonomicName authorityName="Devriese" authorityYear="1991" class="Insecta" family="Tetrigidae" genus="Lepocranus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Lepocranus fuscus" order="Orthoptera" pageId="0" pageNumber="1" phylum="Arthropoda" rank="species" species="fuscus">
