female paratype of 
<taxonomicName authority="Gupta, Ghosh, Das &amp; Chandra" authorityName="Gupta, Ghosh, Das &amp; Chandra" authorityYear="2022" box="[551,1083,1259,1283]" class="Insecta" family="Bolboceratidae" genus="Bolboceras" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="94" phylum="Arthropoda" rank="species" species="krikkeni" status="new species">
