<location id="8EEFDFE5FFF00F54FC5DFD64C813FD5B" LSID="urn:lsid:plazi:treatment:03993828FFF00F54FFE5FDBACE61F8CD:8EEFDFE5FFF00F54FC5DFD64C813FD5B" box="[973,1126,731,760]" name="Tamantave" pageId="2" pageNumber="185">Tamantave</location>
