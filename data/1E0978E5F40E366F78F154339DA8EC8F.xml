<subSubSection id="1D0070D67DED3C09DB23C0BB1D563153" pageId="null" pageNumber="210" type="description">
<paragraph id="7DC2B8F1713C715D68429AB45375AA63" pageId="null" pageNumber="210">
Unterscheidet sich von 
<taxonomicName id="5A7AE08C8327EB5A41E347AD7EC6200D" class="Magnoliopsida" family="Brassicaceae" genus="Nasturtium" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="210" phylum="Tracheophyta" rank="species" species="officinale">
<emphasis id="DBA10ABC3616F63C8106CEE7FD52C95B" italics="true" pageId="null" pageNumber="210">N. officinale</emphasis>
</taxonomicName>
(Nr. 1) durcli folgende Merkmale: 
<emphasis id="56CFA2DB22F220F140E839A29383AF58" italics="true" pageId="null" pageNumber="210">
<normalizedToken id="2356132817F75113C4F33FFD0B9A8FB3" originalValue="Blätter" pageId="null" pageNumber="210">Blaetter</normalizedToken>
im Herbst und Winter rotbraun; 
<normalizedToken id="F4E2B7DD5531A2D3AF1310BEFB88DE5F" originalValue="Kelchblätter" pageId="null" pageNumber="210">Kelchblaetter</normalizedToken>
2,8-3,5 mm lang; 
<normalizedToken id="EAC0A92DAE643B0E75CFD28AFA84FD93" originalValue="Kronblätter" pageId="null" pageNumber="210">Kronblaetter</normalizedToken>
5-6 mm lang. 
<normalizedToken id="EDC320BDD75D05F028A10B42A0FF9BA7" originalValue="Früchte" pageId="null" pageNumber="210">Fruechte</normalizedToken>
16-24 mm lang und 1,2-1,8 mm dick; Samen in jedem Fach 1reihig, mit ca. 200 wabenartigen Feldern auf der 
<normalizedToken id="89E9718D04DA78E418623093A6C8C6AB" originalValue="Oberfläche" pageId="null" pageNumber="210">Oberflaeche</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="2C28C35F5991D2C028C842F8547FADD4" originalValue="Blüte" pageId="null" pageNumber="210">Bluete</normalizedToken>
: 
<normalizedToken id="9016050F4C06015667507AAC46AC38F4" originalValue="Früher" pageId="null" pageNumber="210">Frueher</normalizedToken>
Sommer bis Herbst.
</paragraph>
<paragraph id="3450D3724F3047E90308BC4C321D96B3" pageId="null" pageNumber="210">
<emphasis id="DFC964A48D1BFE2FE821C13CF259A23C" italics="true" pageId="null" pageNumber="210">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="9D6DE1E7701B43D9112F9DF9AC4F8985" italics="true" pageId="null" pageNumber="210">64:</emphasis>
Material aus botanischem Garten (Manton 1932), aus England (Howard 1947), aus Schweden (Jonsell 1963).
</paragraph>
<paragraph id="16C0FC700C2950C9178296EA388D6D76" pageId="null" pageNumber="210">
<emphasis id="E16DF3CA377F1E75AB0F026C59A7CD8E" italics="true" pageId="null" pageNumber="210">Standort.</emphasis>
Kollin. 
<normalizedToken id="26DDB6AF469C831961B44D217C9C70CB" originalValue="Ähnlich" pageId="null" pageNumber="210">Aehnlich</normalizedToken>
wie bei 
<taxonomicName id="084B417AED347BC0BCEE13BBE25D25EE" class="Magnoliopsida" family="Brassicaceae" genus="Nasturtium" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="210" phylum="Tracheophyta" rank="species" species="officinale">
<emphasis id="4509DF8CBAC14E3B5C36ABC81AC72571" italics="true" pageId="null" pageNumber="210">N. officinale</emphasis>
</taxonomicName>
(Nr. 1), aber auch in saurerem Wasser.
</paragraph>
<paragraph id="F3C37F5306AF609011A4634BAAB317B5" pageId="null" pageNumber="210">
<emphasis id="930CDACEE5631F83F59A35108FEAC247" italics="true" pageId="null" pageNumber="210">
Verbreitung. 
<normalizedToken id="5085D0ABEC8C1239A571AE1417282743" originalValue="Westeuropäische" pageId="null" pageNumber="210">Westeuropaeische</normalizedToken>
Pflanze
</emphasis>
(nicht genau bekannt): 
<normalizedToken id="2953EC70228245149099466F21767231" originalValue="Ostwärts" pageId="null" pageNumber="210">Ostwaerts</normalizedToken>
bis 
<normalizedToken id="71D5C63E71A98A4D96837E8E878165E5" originalValue="Südschweden" pageId="null" pageNumber="210">Suedschweden</normalizedToken>
, Alpen. - Im Gebiet: Genfersee- und Neuenburgerseegebiet, Rheingebiet vom Bodensee 
<normalizedToken id="65AE95205E12AAF73F52A7BCC2C61F3B" originalValue="abwärts" pageId="null" pageNumber="210">abwaerts</normalizedToken>
.
</paragraph>
<paragraph id="9CA708FD88D6875488335D3C65A7E8BD" pageId="null" pageNumber="210">
<emphasis id="A4024399C1DC51BD93C2597034C88B84" italics="true" pageId="null" pageNumber="210">Bemerkungen.</emphasis>
Genaue Verbreitungsangaben aus der Schweiz und morphologische Charakterisierung von Oefelein (1958 Charakterisierung von Oefelein (1958a).
</paragraph>
</subSubSection>
