<quantity id="640843B7FF95FFE93ACD08344360B833" box="[918,1102,770,797]" metricMagnitude="8" metricUnit="m" metricValue="6.817991509999999" pageId="27" pageNumber="254" unit="km" value="681799.151">681,799.151 km</quantity>
<superScript id="5485431AFF95FFE93D1508344378B83F" attach="left" box="[1102,1110,770,784]" fontSize="6" pageId="27" pageNumber="254">2</superScript>
].
</paragraph>
<paragraph id="A34FEE52FF95FFE939E60810466AB84B" blockId="27.[136,1452,158,977]" pageId="27" pageNumber="254">
<emphasis id="91843240FF95FFE939E60810466DB86F" bold="true" box="[189,323,806,832]" pageId="27" pageNumber="254">Phenology:</emphasis>
