<subSubSection id="322818D0CFD18CE5A2A26EE28996382E" pageId="null" pageNumber="341" type="description">
<paragraph id="6EB70AABD7F5EF4665673ABE40CD2197" pageId="null" pageNumber="341">
<emphasis id="9E66C58AC5DA4D06D5C318A2BB54175E" italics="true" pageId="null" pageNumber="341">Stengel und oft auch der Mittelnerv der Blattunterseite mit Stacheln</emphasis>
(bei den andern Gattungen der Familie keine Stacheln), kantig. 
<emphasis id="C5DAEA57888555DAC6B615CA51C1A7E1" italics="true" pageId="null" pageNumber="341">
<normalizedToken id="0EDB55480962A9E7D60E1DB6B656FC89" originalValue="Blütenstand" pageId="null" pageNumber="341">Bluetenstand</normalizedToken>
kugelig bis zylindrisch.
</emphasis>
<normalizedToken id="DA86096A8057DF106342284A74CE6378" originalValue="Hüllblätter" pageId="null" pageNumber="341">Huellblaetter</normalizedToken>
in 2 Reihen. Fruchtboden mit schmal lanzettlichen, 
<emphasis id="825AFFBF0159098FB6E7BDDDEAAD165C" italics="true" pageId="null" pageNumber="341">
stechenden 
<normalizedToken id="FB86FA267DEB49BA1AE09168E040AD96" originalValue="Spreublättern" pageId="null" pageNumber="341">Spreublaettern</normalizedToken>
.
</emphasis>
<normalizedToken id="D3249C5C8A4B6D2DDA84F7661393BEE9" originalValue="Außenkelch" pageId="null" pageNumber="341">Aussenkelch</normalizedToken>
unscheinbar, 0,1 bis 0,5 mm hoch, ohne deutliche 
<normalizedToken id="655237C9B33F85CD014D8E231809FF55" originalValue="Zähne" pageId="null" pageNumber="341">Zaehne</normalizedToken>
. Kelch 
<normalizedToken id="C443E8E516C5754E35D0826DE65FDFEC" originalValue="aufwärts" pageId="null" pageNumber="341">aufwaerts</normalizedToken>
gebogen, fast 4kantig, ganzrandig oder 
<normalizedToken id="7FC6DF773F1AD03B3E137A065A4305B1" originalValue="vielzähnig" pageId="null" pageNumber="341">vielzaehnig</normalizedToken>
, ohne Borsten. Krone 4zipflig. Frucht 4kantig, mit Furchen oder Rippen.
</paragraph>
<paragraph id="60DCECEFF4D127A09183533BA3CD2CD2" pageId="null" pageNumber="341">
Die Gattung 
<emphasis id="384FBE90D9F7BCD7DC179777647DFFD4" italics="true" pageId="null" pageNumber="341">
<taxonomicName id="12767B4A2582DF2C7D6AB4CAC8942B80" class="Magnoliopsida" family="Caprifoliaceae" genus="Dipsacus" kingdom="Plantae" order="Dipsacales" pageId="null" pageNumber="341" phylum="Tracheophyta" rank="genus">Dipsacus</taxonomicName>
<normalizedToken id="7D87D75FC377B734DDDAD0AB6EE080A1" originalValue="umfaßt" pageId="null" pageNumber="341">umfasst</normalizedToken>
etwa 12 Arten mit vorwiegend mediterraner Verbreitung. Chromosomengrundzahlen
</emphasis>
n = 8 und 9.
</paragraph>
<paragraph id="132F124073951025EAE84C6E5A5A44E7" pageId="null" pageNumber="341">
<table id="214ABD373D6EC38E2B76E2427A2BEC85" frame="void" pageId="null" pageNumber="341" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="20F09BC7B62BC828A3A397A08DF65652" pageId="null" pageNumber="341">
<tr id="A63E68ED218588B52F48A0864D7D4C8A" pageId="null" pageNumber="341">
<td id="9687CE8C6C8F14131172B4EDC4037C7D" align="left" pageId="null" pageNumber="341" valign="top">
1. 
<normalizedToken id="BDCE66BF5E6DEC013651484AC0F74FB4" originalValue="Blütenköpfe" pageId="null" pageNumber="341">Bluetenkoepfe</normalizedToken>
<normalizedToken id="4FC230E62014B44C0C71890E18CF1173" originalValue="eiförmig" pageId="null" pageNumber="341">eifoermig</normalizedToken>
bis zylindrisch, 3-8 cm lang, aufrecht; 
<normalizedToken id="7B977E9169A5C83FE9470C75322E9397" originalValue="stengelständige" pageId="null" pageNumber="341">stengelstaendige</normalizedToken>
<normalizedToken id="FD74FEAF3908C8A2A452911B0499162A" originalValue="Blätter" pageId="null" pageNumber="341">Blaetter</normalizedToken>
je 2 an der Basis 
<normalizedToken id="8350379CF2D788AC736551253F798D3E" originalValue="tütenförmig" pageId="null" pageNumber="341">tuetenfoermig</normalizedToken>
miteinander verwachsen.
</td>
</tr>
<tr id="CE7872FE33BB5C9C19DFF2ECC92080E4" pageId="null" pageNumber="341">
<td id="B61DD87B65CAB0F02BDE45852709AB4B" align="left" pageId="null" pageNumber="341" valign="top">
2. 
<normalizedToken id="929A36C76294FD5F7DB09C94A991295A" originalValue="Stengelblätter" pageId="null" pageNumber="341">Stengelblaetter</normalizedToken>
<normalizedToken id="245BC49507E09B1ED714CD3966DE8A60" originalValue="gezähnt" pageId="null" pageNumber="341">gezaehnt</normalizedToken>
oder ganzrandig, kahl; 
<normalizedToken id="BC86F55BAA46C20AA915840A29BA4BA0" originalValue="Hüllblätter" pageId="null" pageNumber="341">Huellblaetter</normalizedToken>
bogig aufsteigend, die 
<normalizedToken id="48E257FEBE35F4B8D47BEA767A8754D0" originalValue="längeren" pageId="null" pageNumber="341">laengeren</normalizedToken>
meist 
<normalizedToken id="E79857D5E50C6F9D863657EED19EDADD" originalValue="länger" pageId="null" pageNumber="341">laenger</normalizedToken>
als der 
<normalizedToken id="D2B6A2A3C947C3B5CE2F19BDD3BFA68A" originalValue="Blütenkopf" pageId="null" pageNumber="341">Bluetenkopf</normalizedToken>
</td>
<td id="C6B0E85EDA00A166DC64327332581CB3" align="left" pageId="null" pageNumber="341" valign="bottom">
<italic id="822FA3F30333FC8DBF4350386AD88E50" pageId="null" pageNumber="341">D. Silvester</italic>
(Nr. 1)
</td>
</tr>
<tr id="A0F19E62F5861EE8159E1F78294D467E" pageId="null" pageNumber="341">
<td id="DE93E7D76D8FF24965BD8DBD83FC8530" align="left" pageId="null" pageNumber="341" valign="top">
2*. 
<normalizedToken id="C175149E2FCBC852B24F86AF9EBC154A" originalValue="Stengelblätter" pageId="null" pageNumber="341">Stengelblaetter</normalizedToken>
<normalizedToken id="C927A61B1BCE29987552337486417541" originalValue="unregelmäßig" pageId="null" pageNumber="341">unregelmaessig</normalizedToken>
fiederteilig, am Rande borstig bewimpert; 
<normalizedToken id="7EFAAA1CCE53C2746037CB023C9B9992" originalValue="Hüllblätter" pageId="null" pageNumber="341">Huellblaetter</normalizedToken>
abstehend, die 
<normalizedToken id="32B3C537C73C57E41FC6901E019528A0" originalValue="längeren" pageId="null" pageNumber="341">laengeren</normalizedToken>
<normalizedToken id="C07A0F0AEDA3CB35E993B005DAC8AFC5" originalValue="kürzer" pageId="null" pageNumber="341">kuerzer</normalizedToken>
als der 
<normalizedToken id="7876617D998F976DC80E53084076B9B9" originalValue="Blütenkopf" pageId="null" pageNumber="341">Bluetenkopf</normalizedToken>
</td>
<td id="23C0FE7BFFF7DF957170569B9D92DE8A" align="left" pageId="null" pageNumber="341" valign="bottom">
<taxonomicName id="2D95B9A7FB0B196DF51DD6990285DDCD" class="Magnoliopsida" family="Caprifoliaceae" genus="Dipsacus" kingdom="Plantae" order="Dipsacales" pageId="null" pageNumber="341" phylum="Tracheophyta" rank="species" species="laciniatus">
<italic id="2AEF260BAE129C29B236E1BB039393CB" pageId="null" pageNumber="341">D. laciniatus</italic>
</taxonomicName>
(Nr. 2)
</td>
</tr>
<tr id="55F8A1CF7137DF36D96C738C3CEE22C1" pageId="null" pageNumber="341">
<td id="15F67C65C7200129336514555FE1F985" align="left" pageId="null" pageNumber="341" valign="top">
1*. 
<normalizedToken id="579FDDC6DB2D435F042D4DC5FD9C7929" originalValue="Blütenköpfe" pageId="null" pageNumber="341">Bluetenkoepfe</normalizedToken>
kugelig, 2-2,5 cm im Durchmesser, vor dem 
<normalizedToken id="4D0187AA2CAC82F0AB8B795E7D8BDB5A" originalValue="Aufblühen" pageId="null" pageNumber="341">Aufbluehen</normalizedToken>
nickend; 
<normalizedToken id="276603D298755BEC113D4BD4CE47A3A4" originalValue="stengelständige" pageId="null" pageNumber="341">stengelstaendige</normalizedToken>
<normalizedToken id="80DA54CAE7A690120367E703697855E4" originalValue="Blätter" pageId="null" pageNumber="341">Blaetter</normalizedToken>
an der Basis kaum verwachsen
</td>
<td id="7645C8CF677E7E7C6CBF2A1434576470" align="left" pageId="null" pageNumber="341" valign="bottom">
<taxonomicName id="E63D20ABD388F5E5AF426DFB9F8A48D7" class="Magnoliopsida" family="Caprifoliaceae" genus="Dipsacus" kingdom="Plantae" order="Dipsacales" pageId="null" pageNumber="341" phylum="Tracheophyta" rank="species" species="pilosus">
<italic id="E3FCD6B508A26F837F75DA712A968246" pageId="null" pageNumber="341">D. pilosus</italic>
</taxonomicName>
(Nr. 3)
</td>
</tr>
</tbody>
</table>
</paragraph>
