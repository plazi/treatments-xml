<subSubSection id="C339652E433FFFE367F2FC45C232FBC5" pageId="7" pageNumber="80" type="discussion">
<paragraph id="8B9C36A5433FFFE367F2FC45C232FBC5" blockId="7.[136,1452,158,1120]" pageId="7" pageNumber="80">
<emphasis id="B957EAB7433FFFE367F2FC45C175FC75" bold="true" box="[189,256,950,976]" pageId="7" pageNumber="80">Notes</emphasis>
:— 
<bibRefCitation id="EFB24B54433FFFE3666EFC45C1D7FC75" author="Wei, Y." box="[289,418,950,976]" pageId="7" pageNumber="80" pagination="146 - 189" refId="ref3312" refString="Wei, Y. (1999) Artemisia L. In: An, Z. X. (Ed.) Flora Xinjiangensis, vol. 5. Xinjiang Science &amp; Technology &amp; Hygiene Publishing House, Urumqi, pp. 146 - 189." type="book chapter" year="1999">Wei (1999)</bibRefCitation>
and 
<bibRefCitation id="EFB24B54433FFFE36697FC44C224FC75" author="Wu, Y. H." box="[472,593,950,977]" pageId="7" pageNumber="80" refId="ref3358" refString="Wu, Y. H. (2008) The Vascular Plants and their Eco-Geographical Distribution of the Qinghai-Tibetan Plateau. Science Press, Beijing, 1369 pp." type="book" year="2008">Wu (2008)</bibRefCitation>
specifically recorded the distribution of 
<taxonomicName id="4C234D26433FFFE36356FC44C484FC75" authorityName="Linnaeus" authorityYear="1753" box="[1049,1265,951,977]" class="Magnoliopsida" family="Asteraceae" genus="Artemisia" kingdom="Plantae" order="Asterales" pageId="7" pageNumber="80" phylum="Tracheophyta" rank="species" species="rupestris">
