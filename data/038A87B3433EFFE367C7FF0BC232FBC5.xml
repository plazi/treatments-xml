<collectingCountry id="F3347635433FFFE365A7FF31C340FF79" box="[744,821,194,220]" name="Russia" pageId="7" pageNumber="80">Russia</collectingCountry>
, and 
<collectingCountry id="F3347635433FFFE3643AFF31C396FF79" box="[885,995,194,220]" name="Tajikistan" pageId="7" pageNumber="80">Tajikistan</collectingCountry>
(
<bibRefCitation id="EFB24B54433FFFE364BBFF31C4E8FF79" author="Poljakov, P. P." box="[1012,1181,194,220]" pageId="7" pageNumber="80" pagination="425 - 631" refId="ref3258" refString="Poljakov, P. P. (1961) Artemisia L. In: Komarov, V. L. (Ed.) Flora of the U. S. S. R., vol. 26. Izdatel'stvo Akademi Nauk SSSR, Moskva- Leningrad, pp. 425 - 631." type="book chapter" year="1961">Poljakov 1961</bibRefCitation>
, 
<bibRefCitation id="EFB24B54433FFFE363E4FF31C551FF79" author="Ling, Y. R." box="[1195,1316,194,220]" pageId="7" pageNumber="80" pagination="1 - 253" refId="ref3033" refString="Ling, Y. R. (1991) Artemisia L. In: Ling, Y. &amp; Ling, Y. R. (Eds.) Flora Reipublicae Popularis Sinicae, vol. 76 (2). Science Press, Beijing, pp. 1 - 253." type="book chapter" year="1991">Ling 1991</bibRefCitation>
, 
<bibRefCitation id="EFB24B54433FFFE3627DFF31C0B1FEA5" author="Ling, Y. R. &amp; Humphries, C. J. &amp; Gilbert, M. G." pageId="7" pageNumber="80" pagination="676 - 737" refId="ref3085" refString="Ling, Y. R., Humphries, C. J. &amp; Gilbert, M. G. (2011) Artemisia L. In: Wu, Z. Y., Raven, P. H. &amp; Hong, D. Y. (Eds.) Flora of China, vol. 20 - 21. Science Press, Beijing &amp; Missouri Botanical Garden Press, St. Louis, pp. 676 - 737." type="book chapter" year="2011">
