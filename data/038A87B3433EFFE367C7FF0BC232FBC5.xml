</paragraph>
</subSubSection>
<subSubSection id="C339652E433FFFE367F2FEDDC447FEED" box="[189,1074,302,329]" pageId="7" pageNumber="80" type="biology_ecology">
<paragraph id="8B9C36A5433FFFE367F2FEDDC447FEED" blockId="7.[136,1452,158,1120]" box="[189,1074,302,329]" pageId="7" pageNumber="80">
