<taxonomicName id="DEC04D28FF98FFF9A14FBD3CFCBBF463" authority="(Turpin) Zucc." authorityName="Zucc." baseAuthorityName="Turpin" box="[548,878,1606,1628]" class="Magnoliopsida" family="Cactaceae" genus="Echinopsis" kingdom="Plantae" order="Caryophyllales" pageId="6" pageNumber="159" phylum="Tracheophyta" rank="species" species="eyriesii">
