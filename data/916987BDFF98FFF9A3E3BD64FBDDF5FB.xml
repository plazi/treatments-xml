<taxonomicName id="DEC04D28FF98FFF9A0EDBD3CFB4FF463" authority="Turpin" authorityName="Turpin" box="[902,1178,1606,1628]" class="Magnoliopsida" family="Cactaceae" genus="Echinocactus" kingdom="Plantae" order="Caryophyllales" pageId="6" pageNumber="159" phylum="Tracheophyta" rank="species" species="eyriesii">
