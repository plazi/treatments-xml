<subSubSection id="49C942EEFFF03929EBD2C61DFAE75A9B" lastPageId="95" lastPageNumber="96" pageId="94" pageNumber="95" type="description">
<paragraph id="016C1165FFF03928EBD2C61DFDCA5A7E" blockId="94.[227,565,302,328]" box="[227,565,302,328]" pageId="94" pageNumber="95">
<heading id="5A24A609FFF03928EBD2C61DFDCA5A7E" bold="true" box="[227,565,302,328]" fontSize="11" level="3" pageId="94" pageNumber="95" reason="3">
<emphasis id="33A7CD77FFF03928EBD2C61DFDCA5A7E" bold="true" box="[227,565,302,328]" pageId="94" pageNumber="95">
Dimensions of the 
<typeStatus id="DE68AFC7FFF03928EAF8C61DFDCA5A7E" box="[457,565,302,328]" pageId="94" pageNumber="95">holotype</typeStatus>
</emphasis>
</heading>
</paragraph>
<paragraph id="016C1165FFF03928EBD2C66EFC565A41" blockId="94.[227,937,349,375]" box="[227,937,349,375]" pageId="94" pageNumber="95">
Length = 6.00 mm; height = 
<quantity id="C62BBC80FFF03928E904C66EFD5E5A41" box="[565,673,349,375]" metricMagnitude="-3" metricUnit="m" metricValue="3.47" pageId="94" pageNumber="95" unit="mm" value="3.47">3.47 mm</quantity>
; thickness = 
<quantity id="C62BBC80FFF03928E80BC66EFC5B5A41" box="[826,932,349,375]" metricMagnitude="-3" metricUnit="m" metricValue="1.11" pageId="94" pageNumber="95" unit="mm" value="1.11">1.11 mm</quantity>
