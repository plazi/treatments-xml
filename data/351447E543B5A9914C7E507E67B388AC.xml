<subSubSection id="5F72F47F15F311DFED18130B8B3724D7" pageId="null" pageNumber="161" type="description">
<paragraph id="89FF76C58CB9EEA97994319596AC6F7E" pageId="null" pageNumber="161">
Stengel deutlich kantig bis schmal 
<normalizedToken id="50494308723D3FF8D01E645BE1CDCEAE" originalValue="geflügelt" pageId="null" pageNumber="161">gefluegelt</normalizedToken>
, 
<emphasis id="404421D58C56149027A29432878B12B4" italics="true" pageId="null" pageNumber="161">
mit einzelnen 
<normalizedToken id="0B45259D89B583BB40AC97559EC3B7FB" originalValue="Höckern" pageId="null" pageNumber="161">Hoeckern</normalizedToken>
auf den Kanten.
</emphasis>
Zweige und 
<normalizedToken id="F422A1AF34C9EA9694171681049FD692" originalValue="Blätter" pageId="null" pageNumber="161">Blaetter</normalizedToken>
zerstreut (
<normalizedToken id="F6B9178628708A16CE6F4E22155A8BCF" originalValue="drüsenlos" pageId="null" pageNumber="161">druesenlos</normalizedToken>
und 
<normalizedToken id="9760D994F3F03EB8C32FFAEC5E79F439" originalValue="±" pageId="null" pageNumber="161">+/-</normalizedToken>
anliegend) behaart; Haare bis 0,5 mm lang. 
<normalizedToken id="EBD124DE10F5771199FDA749DEEABBF5" originalValue="Blätter" pageId="null" pageNumber="161">Blaetter</normalizedToken>
wie bei 
<taxonomicName id="3A8C7D19EB8842A33794FD7ADA880458" class="Magnoliopsida" family="Solanaceae" genus="Solanum" kingdom="Plantae" order="Solanales" pageId="null" pageNumber="161" phylum="Tracheophyta" rank="species" species="nigrum">
<emphasis id="80CE2925813D4EBFCB0DB8589FEFDD6A" italics="true" pageId="null" pageNumber="161">S. nigrum</emphasis>
</taxonomicName>
(Nr. 2a). 
<normalizedToken id="4A8EC804CA16EB4BF7974AF7E0B5DA68" originalValue="Blütenstandsstiel" pageId="null" pageNumber="161">Bluetenstandsstiel</normalizedToken>
1-1,8 cm lang (selten 
<normalizedToken id="8B2B18B832C6BDB749ED5DC36563589E" originalValue="länger" pageId="null" pageNumber="161">laenger</normalizedToken>
). Kelch mit 
<normalizedToken id="90A9399CED649C828812CDBAF7C6E82B" originalValue="±" pageId="null" pageNumber="161">+/-</normalizedToken>
3eckigen 
<normalizedToken id="BEBDD62CC2B42A0BF11BF0DE5775E676" originalValue="Zähnen" pageId="null" pageNumber="161">Zaehnen</normalizedToken>
und gerundeten Buchten (breite chlorophyllarme 
<normalizedToken id="79F4F44F5B8D2995B20C8116EDA0C275" originalValue="Verwachsungshäute" pageId="null" pageNumber="161">Verwachsungshaeute</normalizedToken>
), der Frucht nicht anliegend. 
<emphasis id="8EC2548CAF0F35C3AC22B4FEBE8E9310" italics="true" pageId="null" pageNumber="161">Frucht rot</emphasis>
, 
<normalizedToken id="6B42A2CA5FA573E72803BC6EC853A02F" originalValue="±" pageId="null" pageNumber="161">+/-</normalizedToken>
<emphasis id="B5E8077E56101BE538A20CBA97AC3F50" italics="true" pageId="null" pageNumber="161">
<normalizedToken id="26860369D6EF309B5FF2A6E65D03ECA7" originalValue="eiförmig" pageId="null" pageNumber="161">eifoermig</normalizedToken>
, 
<normalizedToken id="0A48E248A48390F67E8EC8573512DA2E" originalValue="länger" pageId="null" pageNumber="161">laenger</normalizedToken>
als dick.
</emphasis>
- 
<normalizedToken id="86A37B137BA89E36370B44C1A99E4621" originalValue="Blüte" pageId="null" pageNumber="161">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="824D66BA603A1003B49D1E52A848CACB" pageId="null" pageNumber="161">
<emphasis id="16B55074BA67334F3424CF5E4E6981A9" italics="true" pageId="null" pageNumber="161">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="8F9E85043B9CBD33C5F51F0FF2764441" italics="true" pageId="null" pageNumber="161">48:</emphasis>
Material aus botanischem Garten (Vilmorin und Simonet 1928, 
<normalizedToken id="49CC70A2DF148F3B7DD348D9C4648D2E" originalValue="Jörgensen" pageId="null" pageNumber="161">Joergensen</normalizedToken>
1928a), aus 
<normalizedToken id="34EB4D5E1F3D46D2ADFFB4B1380A7C45" originalValue="Rußland" pageId="null" pageNumber="161">Russland</normalizedToken>
(Gerasimenko und Reznikova (1968), von den Balearen (als 
<taxonomicName id="5819DE20A66A35C2D9467C532D7948DB" class="Magnoliopsida" family="Solanaceae" genus="Solanum" kingdom="Plantae" order="Solanales" pageId="null" pageNumber="161" phylum="Tracheophyta" rank="species" species="nigrum">
<emphasis id="7BBCB4AA56946DEFBF7B800D74BBFD80" italics="true" pageId="null" pageNumber="161">S. nigrum</emphasis>
</taxonomicName>
bezeichnet) (Nilsson und Lassen 1971).
</paragraph>
<paragraph id="06952B458119DED646C9DBDADB8AB0BE" pageId="null" pageNumber="161">
<emphasis id="2F2DECE88CC11F6B0BBF23CA6CDA8EB7" italics="true" pageId="null" pageNumber="161">Standort.</emphasis>
Kollin. Lockere, stickstoffreiche 
<normalizedToken id="DE16A10E157263521106ECFAEB4DEFA6" originalValue="Böden" pageId="null" pageNumber="161">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="009D1297C66246A25F2ECEA0D8F767AA" originalValue="Schuttplätze" pageId="null" pageNumber="161">Schuttplaetze</normalizedToken>
. 
<normalizedToken id="96DBF34BCCAA8FB263F134EA8FFA344F" originalValue="Äcker" pageId="null" pageNumber="161">Aecker</normalizedToken>
.
</paragraph>
<paragraph id="7B552FF8C587C28487E215B908E1ACC7" pageId="null" pageNumber="161">
<emphasis id="BD8BA33578B665E0C06ED569ECD261CD" italics="true" pageId="null" pageNumber="161">Verbreitung.</emphasis>
Nicht genau bekannt, vielleicht 
<emphasis id="6C24D73884AF263EDB8E703F7AEE6A92" italics="true" pageId="null" pageNumber="161">
<normalizedToken id="D6A971675FB396F4E1AB4B319978F43E" originalValue="südeuropäische" pageId="null" pageNumber="161">suedeuropaeische</normalizedToken>
Pflanze
</emphasis>
, z. T. weit nach Norden verschleppt. - Im Gebiet vor allem zentral- und 
<normalizedToken id="A1E8D476B5E22E623188E50424A389DB" originalValue="südalpine" pageId="null" pageNumber="161">suedalpine</normalizedToken>
<normalizedToken id="857A803E39E73E03E929FF192E1CB2BD" originalValue="Täler" pageId="null" pageNumber="161">Taeler</normalizedToken>
, Gegend von Genf, Oberrheinische Tiefebene; selten und oft 
<normalizedToken id="2C0FB8B372D61398C618BB5169AA75B4" originalValue="übersehen" pageId="null" pageNumber="161">uebersehen</normalizedToken>
.
</paragraph>
</subSubSection>
