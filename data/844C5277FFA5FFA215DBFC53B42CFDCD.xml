<bibRefCitation id="68749E90FFA5FFB914D9FBBDB428FB87" author="Rao, K. R." box="[405,543,1083,1107]" pageId="14" pageNumber="239" pagination="59 - 84" refId="ref11466" refString="Rao, K. R. (1989) Descriptions of some new leafhoppers (Homoptera: Cicadellidae) with notes on some synonymies and imperfectly known species from India. Hexapoda, 1, 59 - 84." type="journal article" year="1989">Rao 1989: 65</bibRefCitation>
