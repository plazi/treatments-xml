<subSubSection id="C34C655AFFB7534727DAF4A05B71B0EF" pageId="6" pageNumber="437" type="reference_group">
<paragraph id="8BE936D1FFB7534727DAF4A05BC5B006" blockId="6.[740,1331,2823,3249]" pageId="6" pageNumber="437">
<emphasis id="B922EAC3FFB7534727DAF4A05C41B059" bold="true" box="[740,895,2823,2856]" pageId="6" pageNumber="437">Taxonomy.</emphasis>
<taxonomicName id="4C564D52FFB7534726AEF4A05A15B059" authority="Wied-Neuwied" box="[912,1323,2823,2856]" class="Mammalia" family="Caviidae" genus="Cavia" kingdom="Animalia" order="Rodentia" pageId="6" pageNumber="437" phylum="Chordata" rank="species" species="rupestris">Cavia rupestris Wied-Neuwied</taxonomicName>
