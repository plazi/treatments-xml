<taxonomicName id="4C674D64744AFFE4C73CFA55FB029BC0" authority="(Stackelberg, 1922)" baseAuthorityName="Stackelberg" baseAuthorityYear="1922" box="[823,1233,1478,1500]" class="Agaricomycetes" family="Paxillaceae" genus="Melanogaster" kingdom="Fungi" order="Boletales" pageId="5" pageNumber="22" phylum="Basidiomycota" rank="species" species="nigricans">
