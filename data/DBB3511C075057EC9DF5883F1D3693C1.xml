<figureCitation id="7575C628EFAB303610E96C2A8DC2AF82" captionStart="Figures 20–28" captionStartId="F3" captionText="Figures 20 - 28. Paraleptomenes darugiriensis Kumar, Carpenter &amp; Sharma, 2014. ♀ 20, 22, 24, 26, 27, 28 ♂ 21, 23, 25. 20, 21 habitus (dorsal view) 22, 23 head (frontal view) 24 vertex and part of pronotum (dorsal view) 25 A 7 - A 13 26 mesosoma (dorsal view) 27 tegula (dorsal view) 28 mesosoma (lateral view)." figureDoi="10.3897/jhr.90.82546.figures20-28" httpUri="https://binary.pensoft.net/fig/677829" pageId="0" pageNumber="185">28</figureCitation>
, 
<figureCitation id="B6E43E94F535844481D192E10AD0921A" captionStart="Figures 29–33" captionStartId="F4" captionText="Figures 29 - 33. Paraleptomenes nurseanus montanus Giordani Soika, 1994. ♀ 29 - 33 29 habitus (dorsal view) 30 head (frontal view) 31 vertex and part of pronotum (dorsal view) 32 mesosoma (lateral view) 33 mesosoma (dorsal view)." figureDoi="10.3897/jhr.90.82546.figures29-33" httpUri="https://binary.pensoft.net/fig/677830" pageId="0" pageNumber="185">32</figureCitation>
