<figureCitation id="5E0ACB4E3CE54A0B16EB804E966E521B" captionStart="Figures 1–10" captionStartId="F1" captionText="Figures 1 - 10. Paraleptomenes setaceus sp. nov. Holotype (♀): 1, 3, 5, 7, 9, 10 paratype (♂): 2, 4, 6, 8. 1, 2 habitus (dorsal view) 3, 4 head (frontal view) 5 vertex and part of pronotum (dorsal view) 6 A 6 - A 13 7 mesosoma (dorsal view) 8 metasoma (ventral view) 9 tegula (dorsal view) 10 mesosoma (lateral view)." figureDoi="10.3897/jhr.90.82546.figures1-10" httpUri="https://binary.pensoft.net/fig/677827" pageId="0" pageNumber="185">1</figureCitation>
, 
<figureCitation id="20C60922E7D5A890461060E551FBFFAD" captionStart="Figures 1–10" captionStartId="F1" captionText="Figures 1 - 10. Paraleptomenes setaceus sp. nov. Holotype (♀): 1, 3, 5, 7, 9, 10 paratype (♂): 2, 4, 6, 8. 1, 2 habitus (dorsal view) 3, 4 head (frontal view) 5 vertex and part of pronotum (dorsal view) 6 A 6 - A 13 7 mesosoma (dorsal view) 8 metasoma (ventral view) 9 tegula (dorsal view) 10 mesosoma (lateral view)." figureDoi="10.3897/jhr.90.82546.figures1-10" httpUri="https://binary.pensoft.net/fig/677827" pageId="0" pageNumber="185">2</figureCitation>
, 
<figureCitation id="C57CAFC625E98F8678B3D53181C1131D" captionStart="Figures 11–19" captionStartId="F2" captionText="Figures 11 - 19. Paraleptomenes transfoveolus sp. nov. Holotype (♀) 11, 13, 15, 16, 18, 19 paratype (♂) 12, 14, 17. 11, 12 habitus (dorsal view) 13, 14 head (frontal view) 15 mesosoma (dorsal view) 16 vertex and part of pronotum (dorsal view) 17 A 5 - A 13 18 tegula (dorsal view) 19 mesosoma (lateral view)." figureDoi="10.3897/jhr.90.82546.figures11-19" httpUri="https://binary.pensoft.net/fig/677828" pageId="0" pageNumber="185">11</figureCitation>
