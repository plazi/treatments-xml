<subSubSection id="9099FD2041D206B5D2B4D09D6FBE2064" pageId="null" pageNumber="474" type="description">
<paragraph id="BE6ABC32707A5C1B850F717B90A384F6" pageId="null" pageNumber="474">
<emphasis id="CAC5F3D6AA13CABE41866140C2EB2DE7" italics="true" pageId="null" pageNumber="474">Stengel meist vom Grunde an sparrig verzweigt</emphasis>
, auf steigend. 
<normalizedToken id="337A7822AFB75F58BF249BDCF5257F59" originalValue="Blätter" pageId="null" pageNumber="474">Blaetter</normalizedToken>
lanzettlich, die 
<normalizedToken id="A319557AE8A64C470EA288713131EAE1" originalValue="großem" pageId="null" pageNumber="474">grossem</normalizedToken>
1,5 bis 2,5 cm lang und 
<emphasis id="4B1256E8A76CB2A2F6C3EBF8206E896E" italics="true" pageId="null" pageNumber="474">0,2</emphasis>
- 
<emphasis id="6966A703ACB1D6FD190DE7CD1FA5F1C8" italics="true" pageId="null" pageNumber="474">
0,6 cm breit, kaum wellig. Behaarung 
<normalizedToken id="134499877825E1D2E4DE924EC0CA38C8" originalValue="weiß" pageId="null" pageNumber="474">weiss</normalizedToken>
. 
<normalizedToken id="61498DFBCD4F97B6562B7E1381ECD892" originalValue="Blütenköpfe" pageId="null" pageNumber="474">Bluetenkoepfe</normalizedToken>
zu 8
</emphasis>
- 
<emphasis id="4547C60D0F2109DC1C78D28551EFD468" italics="true" pageId="null" pageNumber="474">16</emphasis>
in kugeligen 
<normalizedToken id="A4BAFC86BAAC1B910DCD6ED434E4CEE6" originalValue="Knäueln" pageId="null" pageNumber="474">Knaeueln</normalizedToken>
, von den 
<normalizedToken id="CE5D83EE564EDD99B8B1EE8AFB28F0B6" originalValue="nächst" pageId="null" pageNumber="474">naechst</normalizedToken>
unter ihnen stehenden 3-5 
<normalizedToken id="0487B654A02D2CAE7F7D4D4387946E17" originalValue="Stengelblättern" pageId="null" pageNumber="474">Stengelblaettern</normalizedToken>
wenig 
<normalizedToken id="A12E89C8A3E2B492E687554D925A31BA" originalValue="überragt" pageId="null" pageNumber="474">ueberragt</normalizedToken>
. 
<emphasis id="4BD12F76A4AC7556A5F5FB272F7BB3DC" italics="true" pageId="null" pageNumber="474">
<normalizedToken id="D497BD84767E2CDC9F47462DA0D34C96" originalValue="Hüllblatt-" pageId="null" pageNumber="474">Huellblatt-</normalizedToken>
</emphasis>
<emphasis id="8B6E060FF5CC92B80DCF6CF2252E60CD" italics="true" pageId="null" pageNumber="474">
<pageBreakToken id="54EEE7E6CAEB28E828BA59FF86F6A146" pageId="null" pageNumber="474">spitzen</pageBreakToken>
gelblich
</emphasis>
, oft nach 
<normalizedToken id="524E97F58B5D801BF463E403264B33AA" originalValue="außen" pageId="null" pageNumber="474">aussen</normalizedToken>
<normalizedToken id="ACB99C72986C32642FFEA2BB1BB805A8" originalValue="gekrümmt" pageId="null" pageNumber="474">gekruemmt</normalizedToken>
. 2-5 
<normalizedToken id="F7C4752ECFD983A523E56FFFD9BFBA5D" originalValue="Fadenblüten" pageId="null" pageNumber="474">Fadenblueten</normalizedToken>
und 4-7 
<normalizedToken id="A9D936C1409F8B15941752D164F19AC2" originalValue="Röhrenblüten" pageId="null" pageNumber="474">Roehrenblueten</normalizedToken>
je Kopf. 
<normalizedToken id="5CD3B0519AEE059441A8C859D35FB1C7" originalValue="Früchte" pageId="null" pageNumber="474">Fruechte</normalizedToken>
0,7-0,8 mm lang. 
<taxonomicName id="E42B0E38FFF674C135351D1F457FC550" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="474" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
(bei innern 
<normalizedToken id="C9624DD12B21FB0883A1CEFBF3DD2D4D" originalValue="Früchten" pageId="null" pageNumber="474">Fruechten</normalizedToken>
) etwa 2 mm lang. - 
<normalizedToken id="6A98411DABC479115DAABE873E40A293" originalValue="Blüte" pageId="null" pageNumber="474">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="CA6C53230B85CD4B02174D0DE204FF2F" pageId="null" pageNumber="474">
<emphasis id="1BA1B8184ADBBA80999762329EDF9266" italics="true" pageId="null" pageNumber="474">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="362036D21283E6A21A8ABAEA9A531A96" italics="true" pageId="null" pageNumber="474">28:</emphasis>
Material aus botanischem Garten Kopenhagen (Hagerup 1941), von den Kanaren (Larsen 1960a), von den Balearen (Dahlgren et al. 1971).
</paragraph>
<paragraph id="6E54430E55C0974A124DD16EC376AF98" pageId="null" pageNumber="474">
<emphasis id="BAF6B271E6BC4D9798CC243451E5E878" italics="true" pageId="null" pageNumber="474">Standort.</emphasis>
Kollin. Trockene, 
<normalizedToken id="B0C3F06FAB74275DC261A0383BFE4F88" originalValue="nährstoffreiche" pageId="null" pageNumber="474">naehrstoffreiche</normalizedToken>
, meist kalkarme, sandige 
<normalizedToken id="9EBC376FB6F4F7D79B53790929B3C830" originalValue="Böden" pageId="null" pageNumber="474">Boeden</normalizedToken>
an offenen Stellen in warmen Lagen. Brachfelder, 
<normalizedToken id="00E0FFD787CE5E541775C763FA9EE203" originalValue="Wegränder" pageId="null" pageNumber="474">Wegraender</normalizedToken>
, 
<emphasis id="928C87D6121DBD8667B7DD5F6F2434E5" italics="true" pageId="null" pageNumber="474">Filagini-Vulpietum</emphasis>
<normalizedToken id="84DA111E086EDA71D6B15D67E5C4CA6B" originalValue="Oberdörfer" pageId="null" pageNumber="474">Oberdoerfer</normalizedToken>
1938.
</paragraph>
<paragraph id="C0C633E50C6F161FA46BC78966F448AC" pageId="null" pageNumber="474">
<emphasis id="A7E470CC0D3CA99C58F95ED46B160B22" italics="true" pageId="null" pageNumber="474">
Verbreitung. 
<normalizedToken id="79EEFD9B1E9707D6ACA6FED5DF729676" originalValue="Mediterran-südwestasiatische" pageId="null" pageNumber="474">Mediterran-suedwestasiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="6078A2E881848D6973CBB765F03ADC30" originalValue="Nordwärts" pageId="null" pageNumber="474">Nordwaerts</normalizedToken>
bis 
<normalizedToken id="258B63156BF7F27AF383CB58070B93BD" originalValue="Südengland" pageId="null" pageNumber="474">Suedengland</normalizedToken>
, Mitteldeutschland, Jugoslawien, Krim; 
<normalizedToken id="C5068D385AA0871BA3DEFCBF3E6A863A" originalValue="ostwärts" pageId="null" pageNumber="474">ostwaerts</normalizedToken>
bis Afghanistan; 
<normalizedToken id="5BEFD0E05CFD1EE3AB50E7D8442E0AF8" originalValue="südwärts" pageId="null" pageNumber="474">suedwaerts</normalizedToken>
bis Nordafrika. Verbreitungskarte von Wagenitz (1970). - Im Gebiet: Genferseegebiet, 
<normalizedToken id="7420E1D6D93AB4B54E678BCB45E31AB2" originalValue="Französischer" pageId="null" pageNumber="474">Franzoesischer</normalizedToken>
Jura, Gegend von Belfort, Pruntrut, Oberrheinische Tiefebene, 
<normalizedToken id="4DFC3D26BA8D3BDE261806DE0B854FD1" originalValue="südliches" pageId="null" pageNumber="474">suedliches</normalizedToken>
Tessin, Comerseegebiet, 
<normalizedToken id="9513AB39DA1AC8052E21F9BAD629E253" originalValue="südöstliche" pageId="null" pageNumber="474">suedoestliche</normalizedToken>
Bergamasker Alpen; ziemlich selten; selten auch adventiv.
</paragraph>
<paragraph id="DFDA2CBDB77E319CA45BFBE8F17B2E1E" pageId="null" pageNumber="474">
<emphasis id="75F51A954396A0BB40FA09A928169ADB" italics="true" pageId="null" pageNumber="474">Bemerkungen.</emphasis>
<normalizedToken id="1B9C6325952BF4AB86FFD9C27421CCA2" originalValue="Über" pageId="null" pageNumber="474">Ueber</normalizedToken>
die Nomenklatur vgl. Wagenitz (1965).
</paragraph>
</subSubSection>
