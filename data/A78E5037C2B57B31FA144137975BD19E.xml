<subSubSection id="7B421D173DC4D8152B46D55F335CB3AB" pageId="null" pageNumber="31" type="description">
<paragraph id="D86E236DC227483A1D89B47749801A6C" pageId="null" pageNumber="31">
<emphasis id="0D09FD3F4979CC7287D5272E50672382" italics="true" pageId="null" pageNumber="31">
<normalizedToken id="6D113B0E4B241A6ABD56DD83BA8DECED" originalValue="Grundständige" pageId="null" pageNumber="31">Grundstaendige</normalizedToken>
<normalizedToken id="2C1759A56CB31446F33E560D18770E23" originalValue="Blätter" pageId="null" pageNumber="31">Blaetter</normalizedToken>
in einer Rosette
</emphasis>
, breit oval bis rhombisch, 
<emphasis id="2A6A82DB4BC6C14EF40A51BEC0A4AE08" italics="true" pageId="null" pageNumber="31">spitz</emphasis>
, 1-2mal so lang wie breit, 
<emphasis id="CA427E50793C604F4AEADB14200EDFB8" italics="true" pageId="null" pageNumber="31">
kaum 1 cm lang, nur wenig 
<normalizedToken id="80D4A8B09496F025AFA73F9357DAB7D5" originalValue="größer" pageId="null" pageNumber="31">groesser</normalizedToken>
als die 
<normalizedToken id="AA6E3A7A9BBFE71842FAB07606056C16" originalValue="Stengelblätter" pageId="null" pageNumber="31">Stengelblaetter</normalizedToken>
</emphasis>
, matt, ziemlich weich. 
<emphasis id="241AA15210CA76059A431DE838317736" italics="true" pageId="null" pageNumber="31">Kelch 2</emphasis>
- 
<emphasis id="506531588C48A086B0F0463490E92B91" italics="true" pageId="null" pageNumber="31">
15 mm 
<normalizedToken id="782EFE12B03CA785952DE0C798F856F7" originalValue="über" pageId="null" pageNumber="31">ueber</normalizedToken>
dem obersten Stengelblattpaar, an den Kanten nicht 
<normalizedToken id="EBB83CD534EABFED0C8942ED0FA49A9C" originalValue="geflügelt" pageId="null" pageNumber="31">gefluegelt</normalizedToken>
</emphasis>
, ⅖-⅗ 
<emphasis id="E3592CD2F5F0D3747CBEDAA1CDFDE223" italics="true" pageId="null" pageNumber="31">
so lang wie die 
<normalizedToken id="E27D23217B6D15A11BC761DC7A7AF522" originalValue="auffällig" pageId="null" pageNumber="31">auffaellig</normalizedToken>
<normalizedToken id="4ADC036F782E8B8FC9E3BB3BDB9B76AB" originalValue="dünne" pageId="null" pageNumber="31">duenne</normalizedToken>
<normalizedToken id="E11420341B144113FF3CFEEE115CC6AC" originalValue="Kronröhre" pageId="null" pageNumber="31">Kronroehre</normalizedToken>
</emphasis>
, bis auf ⅘-⅔ der 
<normalizedToken id="3F0C378DDF36CA3EE6575D385E922144" originalValue="Länge" pageId="null" pageNumber="31">Laenge</normalizedToken>
5teilig, 
<normalizedToken id="93D50427BB78DC6D1377220474930846" originalValue="gepreßt" pageId="null" pageNumber="31">gepresst</normalizedToken>
3-4 mm breit. Krone mit 1,8-2,2 mm langer 
<normalizedToken id="9BDCA3C92F833E524896534E64BB7B97" originalValue="Röhre" pageId="null" pageNumber="31">Roehre</normalizedToken>
, die Zipfel 
<normalizedToken id="6FB6E779B1740AB45CB41A5B74B4C529" originalValue="außerseits" pageId="null" pageNumber="31">ausserseits</normalizedToken>
etwas 
<normalizedToken id="A2D77B4A6C9D45C9AC81661A138BA5A8" originalValue="grünlich" pageId="null" pageNumber="31">gruenlich</normalizedToken>
(nur bei dieser Art der Gruppe so!). - 
<normalizedToken id="2EE5B6391729116E71B9FB0E16F67F2C" originalValue="Blüte" pageId="null" pageNumber="31">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="D39BCCC2E18E6097FDB2739E396BB387" pageId="null" pageNumber="31">
<emphasis id="E655130B2813E6CA1AE889C58ACFCBF5" italics="true" pageId="null" pageNumber="31">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="07BCF5C39BDA246FC891615A26EA284A" italics="true" pageId="null" pageNumber="31">24:</emphasis>
Material aus dem Tirol (Mattick in Tischler 1950). 
<emphasis id="D93C531D0E31DD501A8670860DEEE3EE" italics="true" pageId="null" pageNumber="31">2n</emphasis>
= 
<emphasis id="9720E785E618FA95470A12126CB5573C" italics="true" pageId="null" pageNumber="31">28:</emphasis>
Material vom Simplon (Favarger 1965).
</paragraph>
<paragraph id="6F9093F58D46D610D333C3A7FB841C04" pageId="null" pageNumber="31">
<emphasis id="89CE5E09CF1630AF5E09902F5B76C463" italics="true" pageId="null" pageNumber="31">Standort.</emphasis>
Alpin (bis 4200 m?). Kalkarme, neutrale bis schwach saure 
<normalizedToken id="F4672C2F3928A259C19C2CE783E68320" originalValue="Feinschuttböden" pageId="null" pageNumber="31">Feinschuttboeden</normalizedToken>
. Lockere Rasen, Felsen, Felsschutt.
</paragraph>
<paragraph id="1C336AA30A99259F20A0DDD26274DD3B" pageId="null" pageNumber="31">
<emphasis id="015DF80E24277DF4FE5A4CAAC97B1C6E" italics="true" pageId="null" pageNumber="31">
Verbreitung. 
<normalizedToken id="1AD6F2E7B8A79B5FADE21B78AA15A2BC" originalValue="Alpin-pyrenäische" pageId="null" pageNumber="31">Alpin-pyrenaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="BBDD43053289CADD3D0B225B60076F61" originalValue="Pyrenäen" pageId="null" pageNumber="31">Pyrenaeen</normalizedToken>
, Alpen (
<normalizedToken id="DA8704F9E07176DC7E75F652872D1DA5" originalValue="ostwärts" pageId="null" pageNumber="31">ostwaerts</normalizedToken>
bis Steiermark). - Im Gebiet: Zentral- und 
<normalizedToken id="496F4F158012778AFD998CEC6B43667F" originalValue="Südalpen" pageId="null" pageNumber="31">Suedalpen</normalizedToken>
, nicht 
<normalizedToken id="D1FD2244ABC876E076D48F3CA422B602" originalValue="häufig" pageId="null" pageNumber="31">haeufig</normalizedToken>
; Nordalpen, meist selten.
</paragraph>
</subSubSection>
