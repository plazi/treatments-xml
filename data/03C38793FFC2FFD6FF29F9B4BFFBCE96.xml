</taxonomicName>
and 
<taxonomicName id="4C6A4D06FFC2FFD4FB8CF92BBB82C9D9" baseAuthorityName="Kakishima &amp; Sato" baseAuthorityYear="1980" box="[1069,1207,1734,1759]" class="Pucciniomycetes" family="Pucciniaceae" genus="Puccinia" kingdom="Fungi" order="Pucciniales" pageId="17" pageNumber="238" phylum="Basidiomycota" rank="species" species="vaginatae">
<emphasis id="B91EEA97FFC2FFD4FB8CF92BBB82C9D9" box="[1069,1207,1734,1759]" italics="true" pageId="17" pageNumber="238">P. vaginatae</emphasis>
</taxonomicName>
, but phylogenetically separated from these species.
</paragraph>
</subSubSection>
