<subSubSection id="C370650EFFC2FFD4FF1CF8B8BABAC869" box="[189,1423,1877,1904]" pageId="17" pageNumber="238" type="etymology">
<paragraph id="8BD53685FFC2FFD4FF1CF8B8BABAC869" blockId="17.[136,1452,1733,2084]" box="[189,1423,1877,1904]" pageId="17" pageNumber="238">
<emphasis id="B91EEA97FFC2FFD4FF1CF8B8BE7DC869" bold="true" box="[189,328,1877,1903]" pageId="17" pageNumber="238">Etymology:</emphasis>
—Named after host plant genus of the telial stages, and the locality of collection, 
<collectingRegion id="49AEF867FFC2FFD4FB7BF8B8BABEC869" box="[1242,1419,1877,1903]" country="China" name="Hebei" pageId="17" pageNumber="238">Hebei Province</collectingRegion>
