<subSubSection id="C370650EFFC2FFD4FF29F928BEFAC805" pageId="17" pageNumber="238" type="diagnosis">
<paragraph id="8BD53685FFC2FFD4FF29F928BEFAC805" blockId="17.[136,1452,1733,2084]" pageId="17" pageNumber="238">
<emphasis id="B91EEA97FFC2FFD4FF29F928BE30C9D9" bold="true" box="[136,261,1733,1759]" pageId="17" pageNumber="238">Diagnosis:</emphasis>
—This species is morphologically similar to 
<taxonomicName id="4C6A4D06FFC2FFD4FD5EF92BBCC3C9D9" box="[767,1014,1733,1759]" class="Pucciniomycetes" family="Pucciniaceae" genus="Puccinia" kingdom="Fungi" order="Pucciniales" pageId="17" pageNumber="238" phylum="Basidiomycota" rank="species" species="caricis-atractylodis">
