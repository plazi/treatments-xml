<location id="4F036028FFF7FFB6FBC2989A6C4E7994" LSID="urn:lsid:plazi:treatment:C27587E5FFF7FFB6FC269F3A6C4A7994:4F036028FFF7FFB6FBC2989A6C4E7994" box="[1128,1347,1246,1270]" municipality="Wadi Mallaha" name="Esh El Mallaha area" pageId="26" pageNumber="40" stateProvince="Al Uqsur">Esh El Mallaha area</location>
