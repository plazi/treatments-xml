<collectingCountry id="F377D2EA020D4E2AA7C6FCCE651EFCA7" box="[447,524,768,792]" name="Taiwan" pageId="5" pageNumber="260">Taiwan</collectingCountry>
(
<bibRefCitation id="EFF1EF8B020D4E2AA465FCCE65D5FCA7" author="BORDONI, A." box="[540,711,768,792]" pageId="5" pageNumber="260" pagination="25 - 33" refId="ref5906" refString="BORDONI, A. 2011: New data and records on Xantholinini of Taiwan collected by Ales Smetana, with description of new species (Coleoptera, Staphylinidae). - Redia 94: 25 - 33. - http: // www. redia. it / images / stories / Pdf 2011 / 04 % 20 bordoni __. pdf [accessed 2017 / 11 / 08]." type="journal article" year="2011">BORDONI, 2011</bibRefCitation>
). New record for Sabah. In Borneo occurs two other species, 
<taxonomicName id="4C60E9F9020D4E2AA6D7FC8E651AFCE7" authority="BORDONI, 2002" authorityName="BORDONI" authorityYear="2002" box="[174,520,832,856]" class="Insecta" family="Staphylinidae" genus="Erymus" kingdom="Animalia" order="Coleoptera" pageId="5" pageNumber="260" phylum="Arthropoda" rank="species" species="heumorphus">
<emphasis id="B9144E68020D4E2AA6D7FC8E665FFCE7" box="[174,333,832,856]" italics="true" pageId="5" pageNumber="260">E. heumorphus</emphasis>
<bibRefCitation id="EFF1EF8B020D4E2AA723FC8E651AFCE7" author="BORDONI, A." box="[346,520,832,856]" pageId="5" pageNumber="260" refId="ref5709" refString="BORDONI, A. 2002: Xantholinini della Regione Orientale (Coleoptera: Staphylinidae). Classificazione, Filogenesi e Revisione Tassonomica. Volume 33: Monografie di Museo Regionale di Scienze Naturali - Museo Regionale di Scienze Naturali, Torino: 998 pp. - ISBN 8886041454 - http: // www. nhbs. com / xantholinini-della-regione-orientale-coleoptera- staphylinidae-classificazione-filogenesi-e-revisione- tassonomica-xantholinini-of-the-oriental-col- eoptera-staphylinidae-classification-phylogeny-andtaxonomic-revision-book [accessed 2017 / 10 / 11]." type="book" year="2002">BORDONI, 2002</bibRefCitation>
</taxonomicName>
from Kalimantan and 
<taxonomicName id="4C60E9F9020D4E2AA6D7FCAE66EAFCC7" authority="BORDONI, 2002" authorityName="BORDONI" authorityYear="2002" box="[174,504,864,888]" class="Insecta" family="Staphylinidae" genus="Erymus" kingdom="Animalia" order="Coleoptera" pageId="5" pageNumber="260" phylum="Arthropoda" rank="species" species="bruneianus">
<emphasis id="B9144E68020D4E2AA6D7FCAE6652FCC7" box="[174,320,864,888]" italics="true" pageId="5" pageNumber="260">E. bruneianus</emphasis>
<bibRefCitation id="EFF1EF8B020D4E2AA734FCAE66EAFCC7" author="BORDONI, A." box="[333,504,864,888]" pageId="5" pageNumber="260" refId="ref5709" refString="BORDONI, A. 2002: Xantholinini della Regione Orientale (Coleoptera: Staphylinidae). Classificazione, Filogenesi e Revisione Tassonomica. Volume 33: Monografie di Museo Regionale di Scienze Naturali - Museo Regionale di Scienze Naturali, Torino: 998 pp. - ISBN 8886041454 - http: // www. nhbs. com / xantholinini-della-regione-orientale-coleoptera- staphylinidae-classificazione-filogenesi-e-revisione- tassonomica-xantholinini-of-the-oriental-col- eoptera-staphylinidae-classification-phylogeny-andtaxonomic-revision-book [accessed 2017 / 10 / 11]." type="book" year="2002">BORDONI, 2002</bibRefCitation>
</taxonomicName>
