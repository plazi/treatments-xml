<emphasis id="B9144E68020D4E2AA6D7FD716652FD68" bold="true" box="[174,320,703,727]" pageId="5" pageNumber="260">Distribution:</emphasis>
<taxonomicName id="4C60E9F9020D4E2AA737FD0E66A6FD67" baseAuthorityName="FAUVEL" baseAuthorityYear="1895" box="[334,436,704,728]" class="Insecta" family="Staphylinidae" genus="Erymus" kingdom="Animalia" order="Coleoptera" pageId="5" pageNumber="260" phylum="Arthropoda" rank="species" species="gracilis">
