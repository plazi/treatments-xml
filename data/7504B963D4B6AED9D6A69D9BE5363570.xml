<subSubSection id="03C35972A224AE33DB91E645B8201FFF" pageId="null" pageNumber="487" type="description">
<paragraph id="23FC6048B7C6D1566941F5A545A2675C" pageId="null" pageNumber="487">
1 
<normalizedToken id="8A7E83CC643086F0567FCB221E57F403" originalValue="jährige" pageId="null" pageNumber="487">jaehrige</normalizedToken>
oder ausdauernde 
<normalizedToken id="BFD658F3CE457D305BD03A650588300F" originalValue="Kräuter" pageId="null" pageNumber="487">Kraeuter</normalizedToken>
und 
<normalizedToken id="959428379638697E67B0E26DA590C239" originalValue="Sträucher" pageId="null" pageNumber="487">Straeucher</normalizedToken>
, ohne Dornen. 
<emphasis id="455C1E2E54A60011511E55E14C737F17" italics="true" pageId="null" pageNumber="487">
<normalizedToken id="F3E63DD90D18A040349FBD230DA5E4C3" originalValue="Blätter" pageId="null" pageNumber="487">Blaetter</normalizedToken>
mit 5-17 
<normalizedToken id="E0C55C4F9FDC6B0A293AD1EBDAA57B82" originalValue="radiär" pageId="null" pageNumber="487">radiaer</normalizedToken>
angeordneten 
<normalizedToken id="FF2BFFA30C79F57262418A67FD47763E" originalValue="Teilblättern" pageId="null" pageNumber="487">Teilblaettern</normalizedToken>
</emphasis>
und schmal lanzettlichen 
<normalizedToken id="4F14953383308CB4E1E2C8231FBBB5E0" originalValue="Nebenblättern" pageId="null" pageNumber="487">Nebenblaettern</normalizedToken>
. 
<emphasis id="117615A7D9470E8097D9E53CB7BEE2E1" italics="true" pageId="null" pageNumber="487">
<normalizedToken id="DD77D768F11CABA526C808A23B78A8A2" originalValue="Blüten" pageId="null" pageNumber="487">Blueten</normalizedToken>
in 
<normalizedToken id="AFB4024F0C3287E591F7C062FFFA3E5D" originalValue="endständigen" pageId="null" pageNumber="487">endstaendigen</normalizedToken>
, aufrechten Trauben.
</emphasis>
<normalizedToken id="4822D1BCCABA0DEBC4937F49026051C0" originalValue="Blütenstiele" pageId="null" pageNumber="487">Bluetenstiele</normalizedToken>
nur wenig 
<normalizedToken id="8E1D9481D14CFA813AAE415425FD1787" originalValue="länger" pageId="null" pageNumber="487">laenger</normalizedToken>
oder 
<normalizedToken id="3D9A242BAACB968E138BC8B2A32BBEA3" originalValue="kürzer" pageId="null" pageNumber="487">kuerzer</normalizedToken>
als der Kelch. Kelch tief 21ippig. Krone 
<normalizedToken id="D39D5FA281B4537E7C029B6A7B92C2C1" originalValue="groß" pageId="null" pageNumber="487">gross</normalizedToken>
, gelb, 
<normalizedToken id="8B700F35B9490211AF0127C6CA08A34C" originalValue="weiß" pageId="null" pageNumber="487">weiss</normalizedToken>
, blau oder rot, auch mehrfarbig. Alle 10 
<normalizedToken id="41287A78445927B8C1813C28AD5E5427" originalValue="Staubfäden" pageId="null" pageNumber="487">Staubfaeden</normalizedToken>
verwachsen. Frucht im Kelch ungestielt, bedeutend 
<normalizedToken id="397BE297D49A8AFC0E654CF65EB755CC" originalValue="länger" pageId="null" pageNumber="487">laenger</normalizedToken>
als der Kelch, 2-12samig, zwischen den Samen oft etwas 
<normalizedToken id="220905FBA2D2EBA15E1CD9A3BD42C286" originalValue="eingeschnürt" pageId="null" pageNumber="487">eingeschnuert</normalizedToken>
, ohne 
<normalizedToken id="1879CC6A9D4AFF67D511A01B3A74C6F3" originalValue="Drüsenhaare" pageId="null" pageNumber="487">Druesenhaare</normalizedToken>
. Samen 
<normalizedToken id="2A263D003F4238B44B2534149B12EC0B" originalValue="linsenförmig" pageId="null" pageNumber="487">linsenfoermig</normalizedToken>
bis 
<normalizedToken id="8930E9A231619087EDCDFDFA72B9514A" originalValue="eiförmig" pageId="null" pageNumber="487">eifoermig</normalizedToken>
.
</paragraph>
<paragraph id="A7320DCF185C8964F5919B8D98A275C8" pageId="null" pageNumber="487">
Die Gattung 
<taxonomicName id="80F7B8F2A44CE543C7001A6315D67753" class="Magnoliopsida" family="Fabaceae" genus="Lupinus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="487" phylum="Tracheophyta" rank="genus">
<emphasis id="A9D97E96087114910E618AD1361FBEE7" italics="true" pageId="null" pageNumber="487">Lupinus</emphasis>
</taxonomicName>
<normalizedToken id="10BF5119805638CF449CF8047652EA02" originalValue="umfaßt" pageId="null" pageNumber="487">umfasst</normalizedToken>
etwa 
<emphasis id="0BDA5DCA6C97B1819347E84B03C960B7" italics="true" pageId="null" pageNumber="487">
400 Arten, die zum 
<normalizedToken id="F389FB8CDEBB8E433CB626CE622F708B" originalValue="größten" pageId="null" pageNumber="487">groessten</normalizedToken>
Teil im 
<normalizedToken id="781BFF6120E3ED61847DBE3795F4F46C" originalValue="südwestlichen" pageId="null" pageNumber="487">suedwestlichen</normalizedToken>
Nordamerika verbreitet sind. Chromosomengrundzahl:
</emphasis>
n = 12. Monographie von Smith (1938-1953).
</paragraph>
<paragraph id="E94D1485E348423C93D8BA10E2FA8A61" pageId="null" pageNumber="487">
Neben den 
<normalizedToken id="D9AF07F53EB8BB45FCCC7ADDC86717AB" originalValue="aufgeführten" pageId="null" pageNumber="487">aufgefuehrten</normalizedToken>
Arten werden auch gelegentlich andere Arten als Futterpflanzen 
<normalizedToken id="E3605180A898837F4E08272663A9E48A" originalValue="angesät" pageId="null" pageNumber="487">angesaet</normalizedToken>
, so etwa 
<taxonomicName id="D6CB86D14A2467ABA0CE0A00CE08E8DA" authority="L." authorityName="L." class="Magnoliopsida" family="Fabaceae" genus="Lupinus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="487" phylum="Tracheophyta" rank="species" species="luteus">
<emphasis id="4743CF0BE9DB7BA3297B7DD6595FFB2D" italics="true" pageId="null" pageNumber="487">
<authorityName id="3CB9DFD5BB5EB8879A5D5867C9E07430" pageId="null" pageNumber="487">L.</authorityName>
luteus
</emphasis>
<authorityName id="CCEA8707F73730B99806AB4FCBEE8065" pageId="null" pageNumber="487">L.</authorityName>
</taxonomicName>
, die sich durch gelbe Kronen und 6-8 mm lange Samen von 
<taxonomicName id="81B54648114562D1953D128CEE72CA8F" class="Magnoliopsida" family="Fabaceae" genus="Lupinus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="487" phylum="Tracheophyta" rank="species" species="albus">
<emphasis id="BD7B104BC1BE69002C3DB8CA5B3F615C" italics="true" pageId="null" pageNumber="487">
<authorityName id="C1C3C98CDA0B3E9671F2AF736064BB1D" pageId="null" pageNumber="487">L.</authorityName>
albus
</emphasis>
</taxonomicName>
(Nr. 2) unterscheidet. 2n = 52 (Zusammenstellung zahlreicher 
<normalizedToken id="9778C8A60BF41994CF4636CE9E8382A6" originalValue="Zählungen" pageId="null" pageNumber="487">Zaehlungen</normalizedToken>
von 
<normalizedToken id="DB7B34B45ED9E28BA3D1189F598268A0" originalValue="Löve" pageId="null" pageNumber="487">Loeve</normalizedToken>
und 
<normalizedToken id="5D69CA490BEA29275463461DFA3E8CE2" originalValue="Löve" pageId="null" pageNumber="487">Loeve</normalizedToken>
1961). Zahlreiche weitere Arten werden als Zierpflanzen in 
<normalizedToken id="91C441FEDF9F902B6F448031490B33A4" originalValue="Gärten" pageId="null" pageNumber="487">Gaerten</normalizedToken>
gezogen.
</paragraph>
