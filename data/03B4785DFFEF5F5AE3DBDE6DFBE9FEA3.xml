: a–c. basidiocarps; d. cheilocystidia; e. basidiospores; 
<taxonomicName id="4C1DB2C8FFEC5F5CE0FFDDE9FB92F7EA" box="[940,1058,2027,2049]" form="pileipellis" pageId="10" pageNumber="11" rank="form">f. pileipellis</taxonomicName>
; g. caulocystidia (all from 
<collectionCode id="ED0C518EFFEC5F5CE677DDE9FAF1F7EB" box="[1316,1345,2027,2048]" country="Brazil" name="Servico de Microbiologia e Imunologia" pageId="10" pageNumber="11">LE</collectionCode>
F-312691, 
<typeStatus id="54A677E9FFEC5F5CE3DBD20DFF50F7CE" box="[136,224,2063,2085]" pageId="10" pageNumber="11">holotype</typeStatus>
). Scale bars a–c 
<quantity id="4CE564AEFFEC5F5CE22CD20DFE01F7CF" box="[383,433,2063,2084]" metricMagnitude="-2" metricUnit="m" metricValue="1.0" pageId="10" pageNumber="11" unit="cm" value="1.0">1 cm</quantity>
, d–g 10 μm. Photos by 
<collectionCode id="ED0C518EFFEC5F5CE1C7D20DFD18F7CF" box="[660,680,2063,2084]" country="Norway" lsid="urn:lsid:biocol.org:col:13093" name="Botanical Museum - University of Oslo" pageId="10" pageNumber="11" type="Herbarium">O</collectionCode>
. Morozova.
</paragraph>
</caption>
<caption id="DF6299C3FFED5F5DE3DBDCB0FDF2F907" ID-DOI="http://doi.org/10.5281/zenodo.6608465" ID-Zenodo-Dep="6608465" httpUri="https://zenodo.org/record/6608465/files/figure.png" pageId="11" pageNumber="12" startId="11.[136,229,1714,1736]" targetBox="[165,1419,203,1662]" targetPageId="11">
