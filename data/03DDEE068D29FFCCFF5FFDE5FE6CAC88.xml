<bibRefCitation id="EFE522E18D28FFCFFBE4F894FB31A943" author="Oudemans, A. C." box="[1053,1222,1804,1826]" pageId="9" pageNumber="304" pagination="69 - 74" refId="ref7451" refString="Oudemans, A. C. 1930. Acarologische Aanteekeningen CII. Entomologische Berichte, 8 (172), 69 - 74." type="journal article" year="1930">Oudemans, 1930</bibRefCitation>
