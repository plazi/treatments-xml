<taxonomicName id="3F07F3668CF214216A147F7EBDE4A25B" LSID="E2868E2C-37E5-5EEF-8989-2CE64370337C" authority="Forel, 1886" authorityName="Forel" authorityYear="1886" class="Insecta" family="Formicidae" genus="Formica" kingdom="Animalia" lsidName="Formica clara" order="Hymenoptera" pageId="0" pageNumber="83658" phylum="Arthropoda" rank="species" species="clara">Formica clara Forel, 1886</taxonomicName>
