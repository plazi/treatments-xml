<taxonomicName authorityName="Gusev" authorityYear="1951" class="Hexanauplia" family="Caligidae" genus="Caligus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Caligus orientalis" order="Caligoida" pageId="0" pageNumber="1" phylum="Arthropoda" rank="species" species="orientalis">
<emphasis italics="true" pageId="0" pageNumber="1">Caligus orientalis</emphasis>
