<subSubSection id="BC018559071DAD2E0A3251CC74C4494E" pageId="null" pageNumber="13" type="description">
<paragraph id="3754BF114EEB399626355743AC829079" pageId="null" pageNumber="13">
<emphasis id="ADF087B40F3B70E0575C1B8514519795" italics="true" pageId="null" pageNumber="13">
<normalizedToken id="923E08575B788DFBDDCF219F28B340AF" originalValue="Blätter" pageId="null" pageNumber="13">Blaetter</normalizedToken>
<normalizedToken id="DB362D46D4651C048A30D9B0E14FFF8A" originalValue="immergrün" pageId="null" pageNumber="13">immergruen</normalizedToken>
, lederig
</emphasis>
, ungeteilt. 
<emphasis id="FB564C66CF234D5077B15FBED39F91C1" italics="true" pageId="null" pageNumber="13">
<normalizedToken id="95B746E2387901B67FAAB141739E9E2C" originalValue="Blüten" pageId="null" pageNumber="13">Blueten</normalizedToken>
in Rispen
</emphasis>
, klein, ⚥ oder 1geschlechtig. Kelch klein, 
<normalizedToken id="11DDCA9A3E14BC4FA7FEA1EC1DC00CF0" originalValue="becherförmig" pageId="null" pageNumber="13">becherfoermig</normalizedToken>
, 4 
<normalizedToken id="DA2AC1D484C3DD1DECCDA66EE6D201CA" originalValue="zähnig" pageId="null" pageNumber="13">zaehnig</normalizedToken>
. Krone mit kurzer 
<normalizedToken id="E42A722FD7D3CF468D4DE23467A1425B" originalValue="Röhre" pageId="null" pageNumber="13">Roehre</normalizedToken>
und meist 4teiligem, ausgebreitetem Rand (selten nicht vorhanden). 
<emphasis id="1D1945E5CB2480DE72CAC36BDB7C7A97" italics="true" pageId="null" pageNumber="13">
Frucht eine kugelige bis 
<normalizedToken id="784BBCCDBE9165686011DEC7F1EF419B" originalValue="eiförmige" pageId="null" pageNumber="13">eifoermige</normalizedToken>
Steinfrucht.
</emphasis>
</paragraph>
<paragraph id="A8658CB60EC1788956E6AACBA54DF984" pageId="null" pageNumber="13">
Die Gattung 
<taxonomicName id="FF978AFE048632990831309A40E7A51B" class="Gastropoda" family="Limapontiidae" genus="Olea" kingdom="Animalia" order="Lamiales" pageId="null" pageNumber="13" phylum="Mollusca" rank="genus">
<emphasis id="8E2D938B414E2508330BC68C830A965B" italics="true" pageId="null" pageNumber="13">Olea</emphasis>
</taxonomicName>
<normalizedToken id="5A3C4385FC6200C68DD86F1670166937" originalValue="umfaßt" pageId="null" pageNumber="13">umfasst</normalizedToken>
etwa 
<emphasis id="7638087161E51D1F341184B9FD561620" italics="true" pageId="null" pageNumber="13">
20 Arten, die vorwiegend die 
<normalizedToken id="CFBBB696C9D431C29A76F1FB33670822" originalValue="südliche" pageId="null" pageNumber="13">suedliche</normalizedToken>
<normalizedToken id="CAC993C84A7CDAE0BABC52BEC94E0AB5" originalValue="Hemisphäre" pageId="null" pageNumber="13">Hemisphaere</normalizedToken>
der Alten Welt besiedeln. Chromosomengrundzahl:
</emphasis>
n = 23.
</paragraph>
