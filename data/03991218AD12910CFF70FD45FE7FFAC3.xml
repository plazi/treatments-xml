<emphasis id="B9447F1CAD12910CFCC5FD45FCCCFD03" bold="true" box="[829,838,692,718]" pageId="4" pageNumber="271">(</emphasis>
<figureCitation id="130BBF8BAD12910CFCBFFD45FC04FD03" box="[839,910,692,718]" captionStart="FIGURE 2" captionStartId="5.[136,229,1977,1999]" captionTargetBox="[234,1362,254,1943]" captionTargetId="figure-39@5.[226,1362,245,1952]" captionTargetPageId="5" captionText="FIGURE 2. A. Infected leaves of Juglans regia (LAH37119, holotype) infected by Phyllactinia himalayensis. B. LAH37118.C. Infection under stereomicroscope, showing chasmothecia. D. Chasmothecium. E–F. Chasmothecia with appendages. G. Asci. H. Asci releasing ascospores. Scale bars:A = 2 cm, B = 1 cm, D–F = 30 µm G = 20 µm, H = 15 µm." figureDoi="http://doi.org/10.5281/zenodo.6597886" httpUri="https://zenodo.org/record/6597886/files/figure.png" pageId="4" pageNumber="271">Figs 2</figureCitation>
