<emphasis bold="true" box="[151,465,1725,1752]" italics="true" pageId="13" pageNumber="444">Axinoscymnus hamulatus</emphasis>
Peng et Chen
</taxonomicName>
, 
<taxonomicNameLabel box="[653,719,1726,1752]" pageId="13" pageNumber="444" rank="species">sp. n.</taxonomicNameLabel>
</emphasis>
