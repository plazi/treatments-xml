<taxonomicName authority="Peng et Chen" authorityName="Peng et Chen" authorityYear="2022" box="[891,1337,1944,1969]" class="Insecta" family="Coccinellidae" genus="Axinoscymnus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="433" phylum="Arthropoda" rank="species" species="pingxiangicus" status="sp. n.">
<emphasis box="[891,1187,1945,1968]" italics="true" pageId="2" pageNumber="433">Axinoscymnus pingxiangicus</emphasis>
Peng et Chen
