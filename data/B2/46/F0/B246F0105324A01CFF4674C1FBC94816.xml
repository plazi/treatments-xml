<collectingCountry box="[1076,1144,520,546]" name="Brazil" pageId="3" pageNumber="428">Brazil</collectingCountry>
(
<collectingRegion box="[1160,1276,520,546]" country="Brazil" name="Para" pageId="3" pageNumber="428">Pará State</collectingRegion>
) and one very disjunct locality in 
<collectingCountry box="[367,422,557,583]" name="Peru" pageId="3" pageNumber="428">Peru</collectingCountry>
.
</paragraph>
