<taxonomicName id="FAC46D88DE6EFF9BD691FC1AFE8B9DB9" authorityName="Menge" authorityYear="1866" box="[174,353,949,976]" class="Arachnida" family="Tetragnathidae" kingdom="Animalia" order="Araneae" pageId="11" pageNumber="214" phylum="Arthropoda" rank="family">Tetragnathidae</taxonomicName>
