<taxonomicName id="FAC46D88DE6EFF9BD52AFC3AFC6F9DC6" authority="Marusik &amp; Omelko, 2017" authorityName="Marusik &amp; Omelko" authorityYear="2017" box="[789,901,917,943]" class="Arachnida" family="Tetragnathidae" genus="Nediphya" kingdom="Animalia" order="Araneae" pageId="11" pageNumber="214" phylum="Arthropoda" rank="genus" status="gen. n.">
<emphasis id="0FB0CA19DE6EFF9BD52AFC3AFC6F9DC6" box="[789,901,917,943]" italics="true" pageId="11" pageNumber="214">Nediphya</emphasis>
</taxonomicName>
<taxonomicNameLabel id="14837762DE6EFF9BD5B5FC3AFC3D9DD9" box="[906,983,917,944]" pageId="11" pageNumber="214" rank="genus">gen. n.</taxonomicNameLabel>
