<taxonomicName id="FAC46D88DE6EFF9BD4B7FC3AFD379DC6" authorityName="Nicolet" authorityYear="1849" box="[648,733,917,943]" class="Arachnida" family="Tetragnathidae" genus="Diphya" kingdom="Animalia" order="Araneae" pageId="11" pageNumber="214" phylum="Arthropoda" rank="genus">
