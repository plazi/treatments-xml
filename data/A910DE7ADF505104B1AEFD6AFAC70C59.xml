<taxonomicName id="E6B914EFDF525103B027F8AEFD4D093E" authority="S. R. Yi et H. X. Zhu." authorityName="S. R. Yi et H. X. Zhu Stem Stem" authorityYear="2022" box="[257,705,1840,1862]" class="Liliopsida" family="Asparagaceae" genus="Polygonatum" kingdom="Plantae" order="Asparagales" pageId="3" pageNumber="250" phylum="Tracheophyta" rank="species" species="binatifolium">
