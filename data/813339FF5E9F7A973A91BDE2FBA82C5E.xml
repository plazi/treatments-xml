<taxonomicName id="43FB3653089078C4D33DD520B5A8BA44" authority="L." class="Magnoliopsida" family="Rosaceae" genus="Mespilus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="468" phylum="Tracheophyta" rank="species" species="germanica">
Mespilus 
<normalizedToken id="1AC55DB10E9041340084CEE9B974EF81" originalValue="germánica" pageId="null" pageNumber="468">germanica</normalizedToken>
<authorityName id="0996AB61F1CC3D481F8C2B3016322675" pageId="null" pageNumber="468">L.</authorityName>
