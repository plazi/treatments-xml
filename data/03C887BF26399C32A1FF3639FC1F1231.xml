<subSubSection id="C37B652226399C32A1FF3772FC1F1231" pageId="6" pageNumber="67" type="discussion">
<paragraph id="8BDE36A926399C32A1FF3772FC1F1231" blockId="6.[136,1451,591,829]" pageId="6" pageNumber="67">
Presence of 
<taxonomicName id="4C614D2A26399C32A1893772FEAD1214" authorityName="Miers" authorityYear="1841" box="[254,346,771,793]" class="Liliopsida" family="Burmanniaceae" genus="Gonianthes" kingdom="Plantae" order="Dioscoreales" pageId="6" pageNumber="67" phylum="Tracheophyta" rank="species" species="pusilla">
<emphasis id="B915EABB26399C32A1893772FEAD1214" box="[254,346,771,793]" italics="true" pageId="6" pageNumber="67">B. pusilla</emphasis>
</taxonomicName>
in 
<collectingCountry id="F376763926399C32A00D3775FE2A1215" box="[378,477,771,793]" name="Cambodia" pageId="6" pageNumber="67">Cambodia</collectingCountry>
and 
<collectingCountry id="F376763926399C32A37C3775FDAB1215" box="[523,604,771,793]" name="Vietnam" pageId="6" pageNumber="67">Vietnam</collectingCountry>
is questionable: 
<bibRefCitation id="EFF04B5826399C32A3883775FC741215" author="Zhang, D." box="[767,899,771,793]" pageId="6" pageNumber="67" refId="ref6052" refString="Zhang, D. (1999) Systematics of Burmannia L. (Burmanniaceae) in the Old World. Unpublished PhD thesis, The University of Hong Kong, 331 pp." type="book" year="1999">Zhang (1999)</bibRefCitation>
failed to find any specimens of this species from Eastern Indochina and pointed out that the species has often been confused with 
<taxonomicName id="4C614D2A26399C32A202375EFC141230" authorityName="D. Don" authorityYear="1825" box="[885,995,807,829]" class="Liliopsida" family="Burmanniaceae" genus="Burmannia" kingdom="Plantae" order="Dioscoreales" pageId="6" pageNumber="67" phylum="Tracheophyta" rank="species" species="coelestis">
<emphasis id="B915EABB26399C32A202375EFC141230" box="[885,995,807,829]" italics="true" pageId="6" pageNumber="67">B. coelestis</emphasis>
</taxonomicName>
.
</paragraph>
