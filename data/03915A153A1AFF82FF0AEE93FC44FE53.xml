<bibRefCitation id="EFA996F23A1AFF83FED9EDC0FDB0FD4F" author="CAMERON M" box="[353,518,641,663]" pageId="26" pageNumber="1159" pagination="244 - 247" refId="ref27756" refString="CAMERON M. (1928): On the Oriental species of the Lithocharis ochracea group of Staphylinidae (Col.). - The Entomologist's Monthly Magazine 64: 244 - 247." type="journal article" year="1928">CAMERON 1928</bibRefCitation>
