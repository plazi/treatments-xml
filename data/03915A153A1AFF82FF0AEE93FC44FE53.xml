<location id="8EE7BDD83A1AFF83FCF4EDDFFEBAFD09" LSID="urn:lsid:plazi:treatment:03915A153A1AFF82FF0AEE93FC44FE53:8EE7BDD83A1AFF83FCF4EDDFFEBAFD09" name="Museo Civico di Storia Naturale" pageId="26" pageNumber="1159" stateProvince="Sumatera Utara">Museo Civico di Storia Naturale</location>
