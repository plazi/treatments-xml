<subSubSection id="C18265170727FF88F7DBFCB763914206" pageId="11" pageNumber="244" type="reference_group">
<paragraph id="8927369C0727FF88F7DBFCB7613E4592" blockId="11.[2086,2681,846,1266]" pageId="11" pageNumber="244">
<emphasis id="BBECEA8E0727FF88F7DBFCB763CB4565" bold="true" box="[2088,2244,846,871]" pageId="11" pageNumber="244">Taxonomy.</emphasis>
<taxonomicName id="4E984D1F0727FF88F720FCB7617D4565" authority="Merriam, 1895" authorityName="Merriam" authorityYear="1895" box="[2259,2674,846,871]" class="Mammalia" family="Geomyidae" genus="Geomys" kingdom="Animalia" order="Rodentia" pageId="11" pageNumber="244" phylum="Chordata" rank="species" species="texensis">Geomys texensis Merriam, 1895</taxonomicName>
, 
<materialsCitation id="39F03CC10727FF88F7D9FC8E61224592" ID-GBIF-Occurrence="3799834308" box="[2090,2605,887,912]" pageId="11" pageNumber="244">“Mason, Mason County, Texas,” USA</materialsCitation>
.
</paragraph>
<paragraph id="8927369C0727FF88F7DAFC6763914206" blockId="11.[2086,2681,846,1266]" pageId="11" pageNumber="244">
Molecular studies show 
<taxonomicName id="4E984D1F0727FF88F662FC67611345B5" authorityName="Merriam" authorityYear="1895" box="[2449,2588,926,951]" class="Mammalia" family="Geomyidae" genus="Geomys" kingdom="Animalia" order="Rodentia" pageId="11" pageNumber="244" phylum="Chordata" rank="species" species="texensis">G. texensis</taxonomicName>
to be sister to 
<taxonomicName id="4E984D1F0727FF88F753FC39623345DF" authorityName="Shaw" authorityYear="1800" box="[2208,2364,960,989]" class="Mammalia" family="Geomyidae" genus="Geomys" kingdom="Animalia" order="Rodentia" pageId="11" pageNumber="244" phylum="Chordata" rank="species" species="bursarius">G. bursarius</taxonomicName>
. Three subspecies recognized.
</paragraph>
</subSubSection>
