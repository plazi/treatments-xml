<subSubSection id="B12D36B8B877252265D26A50795A8F90" pageId="null" pageNumber="614" type="vernacular_names">
<paragraph id="DF3FADC360FD50280D643309DFF71AA9" pageId="null" pageNumber="614">Alpen-Zwergorchis</paragraph>
</subSubSection>
</title>
<subSubSection id="72C2AFEC739FCDDC08B5E61860E8F0A1" pageId="null" pageNumber="614" type="description">
<paragraph id="0E9C5CB496E36CFA4383484139177319" pageId="null" pageNumber="614">
5-15 cm hoch. Knollen 
<normalizedToken id="062BD715703355F1A2DEDF60DC609782" originalValue="eiförmig" pageId="null" pageNumber="614">eifoermig</normalizedToken>
bis kugelig. 
<emphasis id="B4E62062352588CFE99AB27C3089A8F2" italics="true" pageId="null" pageNumber="614">
Stengel nur am Grunde 
<normalizedToken id="D0A9CA9EF329E3C95709EC08DE968BEB" originalValue="beblättert" pageId="null" pageNumber="614">beblaettert</normalizedToken>
. 
<normalizedToken id="63B0F94737D6490D15C621538E4B93CF" originalValue="Blätter" pageId="null" pageNumber="614">Blaetter</normalizedToken>
<normalizedToken id="D6D0619D114BDEC6BF97A069C0FE6226" originalValue="grasblattähnlich" pageId="null" pageNumber="614">grasblattaehnlich</normalizedToken>
, fleischig, rinnig gefaltet, oft so hoch wie der 
<normalizedToken id="57773DD6136C109512B04BE1CA137804" originalValue="Blütenstand" pageId="null" pageNumber="614">Bluetenstand</normalizedToken>
.
</emphasis>
<normalizedToken id="F07470E32BDCEDE273E63A6A14B51A13" originalValue="Blütenstand" pageId="null" pageNumber="614">Bluetenstand</normalizedToken>
bis 4 cm lang, 5-10 
<normalizedToken id="DFA66A99940EBCC1009686047FAEE82B" originalValue="blütig" pageId="null" pageNumber="614">bluetig</normalizedToken>
, einseitswendig. 
<emphasis id="0E03B6721DCB1D55C24F7537196E1174" italics="true" pageId="null" pageNumber="614">
Untere 
<normalizedToken id="1294813C6BF6E5EC0D876EC6EFAB5E73" originalValue="Tragblätter" pageId="null" pageNumber="614">Tragblaetter</normalizedToken>
die 
<normalizedToken id="D461CC586684F43C33E2F699F7246285" originalValue="Blüten" pageId="null" pageNumber="614">Blueten</normalizedToken>
<normalizedToken id="B26B77785DE48C7B79DB48EA496306B0" originalValue="überragend" pageId="null" pageNumber="614">ueberragend</normalizedToken>
. 
<normalizedToken id="1425C3E8DF4C8342AED306F417AB47C6" originalValue="Blüten" pageId="null" pageNumber="614">Blueten</normalizedToken>
klein
</emphasis>
, 
<normalizedToken id="680E76DE30AC5B68DDD4CE9CBB4A7236" originalValue="gelbgrün" pageId="null" pageNumber="614">gelbgruen</normalizedToken>
bis rotbraun; 
<emphasis id="E15E4A5CC839B5524C9584EA3D0F5E1E" italics="true" pageId="null" pageNumber="614">
die 
<normalizedToken id="B8EDEE92D8D2E958657B9142869D2E6D" originalValue="Perigonblätter" pageId="null" pageNumber="614">Perigonblaetter</normalizedToken>
<normalizedToken id="50BC77DE39B56B4A38B445A331CBDE2D" originalValue="helmförmig" pageId="null" pageNumber="614">helmfoermig</normalizedToken>
zusammenneigend
</emphasis>
, die 3 
<normalizedToken id="5CCDB7D7853BA12DF7AC367893607736" originalValue="äußern" pageId="null" pageNumber="614">aeussern</normalizedToken>
<normalizedToken id="1F35A9EC479C2BB52D5C52B22FCD25F7" originalValue="Perigonblätter" pageId="null" pageNumber="614">Perigonblaetter</normalizedToken>
oval, bis 4 mm lang und 2 mm breit; die 2 innern 
<normalizedToken id="D888CE957BF23B227D5B232C41B37E0A" originalValue="Perigonblätter" pageId="null" pageNumber="614">Perigonblaetter</normalizedToken>
schmal lanzettlich. 
<emphasis id="C91D0A2762EE6F7F6294B6A95B5A2BC1" italics="true" pageId="null" pageNumber="614">Lippe meist gelb, 3-4 mm lang</emphasis>
, mit 
<normalizedToken id="82BB5EB1F406EF65BE0B65DB7573FEE1" originalValue="rückwärts" pageId="null" pageNumber="614">rueckwaerts</normalizedToken>
gebogenen 
<normalizedToken id="D5B1A285C70ED4BF052DC946EEB6B33D" originalValue="Rändern" pageId="null" pageNumber="614">Raendern</normalizedToken>
und so von vorne gesehen 0,5-1 mm breit, 
<emphasis id="576F27525974CB3E8673F0F6193D1BDE" italics="true" pageId="null" pageNumber="614">
etwa in der Mitte mit 
<normalizedToken id="5C171FE7FF9FC0718A692C4CF3B35DF5" originalValue="seitwärts" pageId="null" pageNumber="614">seitwaerts</normalizedToken>
abstehenden, 0,5 mm langen, stumpfen 
<normalizedToken id="3FAE750BA829D1AF0E62766C95B6B8BB" originalValue="Zähnen" pageId="null" pageNumber="614">Zaehnen</normalizedToken>
; kein Sporn.
</emphasis>
Fruchtknoten sitzend. 
<emphasis id="06CFA40CD3EC38457556E9FDA7FFEFFD" italics="true" pageId="null" pageNumber="614">-</emphasis>
<normalizedToken id="B21433E0CB1BD0A1D2CE7555FA31CEFF" originalValue="Blüte" pageId="null" pageNumber="614">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="1A9C47F824E9FD6562D16637E95B61E7" pageId="null" pageNumber="614">
<emphasis id="D150DA3A2C6D1392591E4AC0D3A473F0" italics="true" pageId="null" pageNumber="614">
<pageBreakToken id="45E02FAB8AC7314871501334469498FB" pageId="null" pageNumber="614">Zytologische</pageBreakToken>
Angaben. 2n = 42
</emphasis>
(unsicher): Material aus Juf, Avers (
<normalizedToken id="6D962DB9E3B45CC2909E56ACEEF78953" originalValue="Graubünden" pageId="null" pageNumber="614">Graubuenden</normalizedToken>
) (Heusser 1938).
</paragraph>
<paragraph id="3D6B504CBF1D0D8559511AF6925CDEB4" pageId="null" pageNumber="614">
<emphasis id="8E0D22EB2F44CDF0C733861A839C51E7" italics="true" pageId="null" pageNumber="614">Standort.</emphasis>
Subalpin und alpin. Kalk- und humusreiche, 
<normalizedToken id="6BBC49B120A177A9CB846E4C14F17082" originalValue="flachgründige" pageId="null" pageNumber="614">flachgruendige</normalizedToken>
, steinige, trockene 
<normalizedToken id="672758E42596A98C663CD34E838762A7" originalValue="Böden" pageId="null" pageNumber="614">Boeden</normalizedToken>
, meist auf Kalkfels und Dolomit, selten auf kalkhaltigen Schiefern wie z. B. 
<normalizedToken id="37BAF44DDD7B7A15E9A7EA82B99AC0CA" originalValue="Bündnerschiefer" pageId="null" pageNumber="614">Buendnerschiefer</normalizedToken>
. Fast nur im 
<emphasis id="E2F9F1C3CBC31578ECA68D2C0D76A9D3" italics="true" pageId="null" pageNumber="614">Caricetum firmae</emphasis>
(Kerner) Br.-Bl. 1926: 
<normalizedToken id="A7E2847C9126EADAEF1786B1D4FB4235" originalValue="Äußerst" pageId="null" pageNumber="614">Aeusserst</normalizedToken>
<normalizedToken id="2079C90FFE13484CDB3A76BE3E8484BB" originalValue="kälte-" pageId="null" pageNumber="614">kaelte-</normalizedToken>
und windharte Pionierrasen-Assoziation, an 
<normalizedToken id="66E1644062E8C9A05E13B9B86135D636" originalValue="Hängen" pageId="null" pageNumber="614">Haengen</normalizedToken>
und 
<normalizedToken id="8EBD4904D79CCA1788180FDAE0221D48" originalValue="Gräten" pageId="null" pageNumber="614">Graeten</normalizedToken>
mit kurzer oder ohne Schneebedeckung.
</paragraph>
<paragraph id="6EAC2453F1E21D8D46B489D6CCE037E2" pageId="null" pageNumber="614">
<emphasis id="89255FB785FAB1AA0E6A97F1AF528856" italics="true" pageId="null" pageNumber="614">Verbreitung. Arktisch-alpine Pflanze</emphasis>
(
<emphasis id="DF0325A99BA95C2E7C9DF6E5B9DAFBFC" italics="true" pageId="null" pageNumber="614">
<normalizedToken id="997E552DB6170769CF4D9BFC3A415DC6" originalValue="europäisch" pageId="null" pageNumber="614">europaeisch</normalizedToken>
</emphasis>
): Nordskandinavien (Lappland bis 72° NB), Alpen (Kottische Alpen bis Wiener Schneeberg und Karawanken), Hohe Tatra. - Im Gebiet in den Alpen verbreitet, nicht 
<normalizedToken id="C471DC4CEA81A26BD055B03E48E8FF55" originalValue="häufig" pageId="null" pageNumber="614">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
