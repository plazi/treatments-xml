<taxonomicName id="4C264D41CA40FFAFC2C43A57F5BCF9E4" authority="Horsfield, 1821" authorityName="Horsfield" authorityYear="1821" box="[2209,2618,1631,1656]" class="Mammalia" family="Mustelidae" genus="Gulo" kingdom="Animalia" order="Carnivora" pageId="16" pageNumber="635" phylum="Chordata" rank="species" species="orientalis">Gulo orientalis Horsfield, 1821</taxonomicName>
, 
<collectingRegion id="49E2F820CA40FFAFCD973A8DF7A9F93E" box="[2034,2095,1669,1698]" country="Indonesia" name="Jawa Timur" pageId="16" pageNumber="635">Java</collectingRegion>
</paragraph>
<paragraph id="8B9936C2CA40FFAFCD9D3AAFF749F8A3" blockId="16.[2034,2626,1631,2052]" pageId="16" pageNumber="635">The Javan Ferret-badger was previously considered a subspecies of the Large-toothed Ferret-badger. Two subspecies are recognized.</paragraph>
</subSubSection>
