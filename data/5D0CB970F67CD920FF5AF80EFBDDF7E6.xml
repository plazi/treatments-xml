<taxonomicName id="12A573E5F67DD920FE20F97FFD51F90F" authorityName="Jeffrey &amp; Chen" authorityYear="1984" box="[498,732,1704,1731]" class="Magnoliopsida" family="Asteraceae" genus="Synotis" kingdom="Plantae" order="Asterales" pageId="9" pageNumber="159" phylum="Tracheophyta" rank="species" species="guizhouensis">
