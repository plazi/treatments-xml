<quantity id="4CFC9B09FFEBF6058A683815FC6BF3BD" box="[886,974,3081,3110]" metricMagnitude="2" metricUnit="m" metricValue="1.8" pageId="47" pageNumber="105" unit="m" value="180.0">180 m</quantity>
