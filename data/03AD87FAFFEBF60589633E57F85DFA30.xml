<collectingCountry id="F313767CFFEBF6058A2D3FFEFC2EF464" box="[819,907,3042,3071]" name="Iceland" pageId="47" pageNumber="105">Island</collectingCountry>
, Molucca Islands], 
<collectingCountry id="F313767CFFEBF6058D823FFEFA8DF464" box="[1180,1320,3042,3071]" name="Indonesia" pageId="47" pageNumber="105">Indonesia</collectingCountry>
