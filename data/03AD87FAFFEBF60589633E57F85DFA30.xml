<geoCoordinate id="EE30502BFFEBF6058A5D3FA7FCC4F443" box="[835,865,3003,3032]" degrees="20" direction="north" orientation="latitude" pageId="47" pageNumber="105" precision="55555" value="20.0">20</geoCoordinate>
