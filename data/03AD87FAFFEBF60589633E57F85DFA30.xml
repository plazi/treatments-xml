<paragraph id="8BBB36ECFFEBF6058BC1382CFBECF3D6" blockId="47.[734,1328,2806,3228]" box="[735,1097,3120,3149]" pageId="47" pageNumber="105">This species is monotypic.</paragraph>
</subSubSection>
<subSubSection id="C31E6567FFEBF6058BC1384FFC3CF307" pageId="47" pageNumber="105" type="distribution">
