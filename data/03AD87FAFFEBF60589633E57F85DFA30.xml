<geoCoordinate id="EE30502BFFEBF6058A843FA7FB83F443" box="[922,1062,3003,3032]" degrees="127" direction="east" minutes="31" orientation="longitude" pageId="47" pageNumber="105" precision="925" value="127.51667">127° 31’ E</geoCoordinate>
