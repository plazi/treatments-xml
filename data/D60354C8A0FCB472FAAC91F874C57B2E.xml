<paragraph id="C2541F332057EC85674DF8EA6EB0810D" pageId="null" pageNumber="425">Breitschuppige Distel</paragraph>
</subSubSection>
</title>
<subSubSection id="6F5DEF53B2910CFFEC69EC63451B1C06" pageId="null" pageNumber="425" type="description">
<paragraph id="10CA69F93A4EFEC2A0D99E7DEC1A0305" pageId="null" pageNumber="425">
<emphasis id="7797850C2ED148FF6EB71E015D5F9CA0" italics="true" pageId="null" pageNumber="425">
<normalizedToken id="FA92CDCEC82EA35E9E8389A0B08FE847" originalValue="Blätter" pageId="null" pageNumber="425">Blaetter</normalizedToken>
mit kaum 
<normalizedToken id="48BCAD8EF19E678ADD17ED0CEF4B3F1F" originalValue="über" pageId="null" pageNumber="425">ueber</normalizedToken>
3 mm langen Stacheln; 
<normalizedToken id="284EF6B5DAC5F0AAFEEDAE09E1250122" originalValue="blühende" pageId="null" pageNumber="425">bluehende</normalizedToken>
<normalizedToken id="01937AFF5426D96BE885368145513838" originalValue="Köpfe" pageId="null" pageNumber="425">Koepfe</normalizedToken>
3
</emphasis>
- 
<emphasis id="0FFFE616B03FAD9972F166D4113AE375" italics="true" pageId="null" pageNumber="425">4 cm dick, immer aufrecht;</emphasis>
<normalizedToken id="372499DBD80890763ADCC1F0544D0CC1" originalValue="äußere" pageId="null" pageNumber="425">aeussere</normalizedToken>
<normalizedToken id="C482D4199ED28D33078232E752920381" originalValue="Hüllblätter" pageId="null" pageNumber="425">Huellblaetter</normalizedToken>
mit 2-4 mm breitem Grund, 
<normalizedToken id="DA47F76626B3C35BDE78C21140F6170B" originalValue="allmählich" pageId="null" pageNumber="425">allmaehlich</normalizedToken>
in den 
<emphasis id="DA7C6B70540C6503E8418DF5CF51F409" italics="true" pageId="null" pageNumber="425">kaum abgesetzten, bogig abstehenden Endteil</emphasis>
<normalizedToken id="ED342B04E3D488FE00FFE27B55975802" originalValue="verschmälert" pageId="null" pageNumber="425">verschmaelert</normalizedToken>
. - 
<normalizedToken id="A7C0C07EB5AA27922FC6572D0ABC26B4" originalValue="Blüte" pageId="null" pageNumber="425">Bluete</normalizedToken>
: 
<normalizedToken id="EDFC23763FE1344A4664738225260D0A" originalValue="Später" pageId="null" pageNumber="425">Spaeter</normalizedToken>
<normalizedToken id="6228A4E3F10BABE49A9B768325DBC5AE" originalValue="Frühling" pageId="null" pageNumber="425">Fruehling</normalizedToken>
bis 
<normalizedToken id="1AFCD8F677AF999321208534D8A7C3AC" originalValue="früher" pageId="null" pageNumber="425">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="E2D9386F86338AF431ECB1A4C4EB7F92" pageId="null" pageNumber="425">
<emphasis id="F642053AAE22A67AE49A027FE3E9E3FF" italics="true" pageId="null" pageNumber="425">Zytologische Angaben</emphasis>
. Keine Untersuchungen.
</paragraph>
<paragraph id="130BD8775B619C3B42EFE18D729F5E98" pageId="null" pageNumber="425">
<emphasis id="ACE7225FCCEEF54D86C51D799E96EAD2" italics="true" pageId="null" pageNumber="425">Standort</emphasis>
. Kollin, montan und subalpin. Trockene, stickstoffreiche, steinige 
<normalizedToken id="4738CE8D263FDA3237F5F9C59E3A0402" originalValue="Böden" pageId="null" pageNumber="425">Boeden</normalizedToken>
in warmen Lagen. Trockenwiesen, Weiden, 
<normalizedToken id="475B31AF596B44F345F49DCC7E93CCA5" originalValue="Wegränder" pageId="null" pageNumber="425">Wegraender</normalizedToken>
, 
<normalizedToken id="0DC35F9CB79BB7E6283F9238917DE0D6" originalValue="Lägerstellen" pageId="null" pageNumber="425">Laegerstellen</normalizedToken>
, 
<normalizedToken id="C7A60B546A82FE5AA7DEE246F0B73A5C" originalValue="Schuttplätze" pageId="null" pageNumber="425">Schuttplaetze</normalizedToken>
, 
<normalizedToken id="36131C6DF6C430803378E4BEFB6644D1" originalValue="Gebüsche" pageId="null" pageNumber="425">Gebuesche</normalizedToken>
.
</paragraph>
<paragraph id="9AA137E92CA9306886DCA68B0CDAC0BB" pageId="null" pageNumber="425">
<emphasis id="15269487996919DDFDEC6F3CECC75CA7" italics="true" pageId="null" pageNumber="425">
Verbreitung. 
<normalizedToken id="011A94F3A0F6AB732253DDF1A22FFBA0" originalValue="Alpin-pyrenäische" pageId="null" pageNumber="425">Alpin-pyrenaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="4C91CC7DE51A8323E270AB7363AE7883" originalValue="Pyrenäen" pageId="null" pageNumber="425">Pyrenaeen</normalizedToken>
, Alpen. - Im Gebiet: Zentrale und 
<normalizedToken id="55F6453784422535675A347B58F7560F" originalValue="südliche" pageId="null" pageNumber="425">suedliche</normalizedToken>
<normalizedToken id="98F718970756285DAEFC8D6BC29F33C9" originalValue="Alpentäler" pageId="null" pageNumber="425">Alpentaeler</normalizedToken>
, nicht 
<normalizedToken id="563EAE018B688E4EE68D06F6E68D0FEF" originalValue="häufig" pageId="null" pageNumber="425">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
