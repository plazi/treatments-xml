<normalizedToken id="9E8A592A284285A15DAF9CBDF1DCC86C" originalValue="Gehörntes" pageId="null" pageNumber="590">Gehoerntes</normalizedToken>
<normalizedToken id="4D33239A73D77696881B4AD8C6989B30" originalValue="Pfaffenröhrlein" pageId="null" pageNumber="590">Pfaffenroehrlein</normalizedToken>
</paragraph>
