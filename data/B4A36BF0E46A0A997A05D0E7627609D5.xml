<paragraph id="7217528E33FE21ED4FB240977E3844CB" pageId="null" pageNumber="181">
Wollige 
<normalizedToken id="75C0BBEF6A4958CA2363600F84E9031E" originalValue="Königskerze" pageId="null" pageNumber="181">Koenigskerze</normalizedToken>
</paragraph>
