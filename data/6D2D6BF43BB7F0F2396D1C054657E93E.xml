<subSubSection id="12F80B1813BD5798774190F7FEE52BDA" pageId="null" pageNumber="293" type="description">
<paragraph id="8B6861D507D9FF9942B0C141630C83E2" pageId="null" pageNumber="293">
10-40 cm hoch. Mittlere 
<normalizedToken id="34B825367F1F4C175040E1506CC8AB13" originalValue="Blätter" pageId="null" pageNumber="293">Blaetter</normalizedToken>
1-2 cm lang, 
<emphasis id="2ED1458FFBEE3F55EA16EEB8E4EE7ACE" italics="true" pageId="null" pageNumber="293">sehr schmal lanzettlich, 10</emphasis>
- 
<emphasis id="209E07E1982C8162D67ABB019633E911" italics="true" pageId="null" pageNumber="293">20mal so lang wie breit</emphasis>
, am Rande und an der Spitze mit einzelnen kaum 0,1 mm langen Haaren. 
<emphasis id="BA2773E33D534C3C2EB3B3A817AE5261" italics="true" pageId="null" pageNumber="293">
<normalizedToken id="2408759B0BB931540598E6709A26918F" originalValue="Teilblütenstände" pageId="null" pageNumber="293">Teilbluetenstaende</normalizedToken>
dicht. 
<normalizedToken id="D8B6E7981C93D77476D56743E155C161" originalValue="Blütenstiele" pageId="null" pageNumber="293">Bluetenstiele</normalizedToken>
0,6
</emphasis>
- 
<emphasis id="C73C7D38FF65FC2E0F35E325DB693480" italics="true" pageId="null" pageNumber="293">
1,5 mm lang, nach der 
<normalizedToken id="2A544E9CF0E478417D7959FD7A73A832" originalValue="Blüte" pageId="null" pageNumber="293">Bluete</normalizedToken>
zusammenneigend.
</emphasis>
Krone 2-3 mm im Durchmesser. 
<normalizedToken id="320D9A23CE7EC2BE2287AF328C82F6B2" originalValue="Früchte" pageId="null" pageNumber="293">Fruechte</normalizedToken>
1,2-1,4 mm hoch. 
<normalizedToken id="7964299B36FC72C166F2FF6350A49643" originalValue="Blüte" pageId="null" pageNumber="293">Bluete</normalizedToken>
: 
<normalizedToken id="4477AB831E088C04B33C6FBA70070240" originalValue="Später" pageId="null" pageNumber="293">Spaeter</normalizedToken>
<normalizedToken id="AF483AF9557FF6B9873D7995D3ECC3C4" originalValue="Frühling" pageId="null" pageNumber="293">Fruehling</normalizedToken>
und 
<normalizedToken id="482A434934D45F5774918B9B8A3D2FC4" originalValue="früher" pageId="null" pageNumber="293">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="0C4CE62A93FDDF5BAF1137628BDE1895" pageId="null" pageNumber="293">
<emphasis id="600C0E1CC4A33C187D940943C114A14E" italics="true" pageId="null" pageNumber="293">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="67F9607A11893D1E149D960C11A2197F" italics="true" pageId="null" pageNumber="293">24:</emphasis>
Material aus England (Hancock 1942).
</paragraph>
<paragraph id="1AAE5530916E97DF4BA0409DA76C481F" pageId="null" pageNumber="293">
<emphasis id="7EEED42DC7DD32882D01B7ADCBC7D4B5" italics="true" pageId="null" pageNumber="293">Standort.</emphasis>
Kollin und montan. Zeitweise 
<normalizedToken id="CCB5DAF8A3AD0C36980B3231F0BA8E24" originalValue="vernäßte" pageId="null" pageNumber="293">vernaesste</normalizedToken>
, torfige 
<normalizedToken id="931CD708E819ED0C0B6DFF4188ED2690" originalValue="Böden" pageId="null" pageNumber="293">Boeden</normalizedToken>
in warmen Lagen. Flachmoore, Sumpfwiesen, 
<normalizedToken id="983B93C4F2C51CCB3607145949F59C40" originalValue="Gräben" pageId="null" pageNumber="293">Graeben</normalizedToken>
, Ufer.
</paragraph>
<paragraph id="E381D5431E10C2E41B09E3575641EF93" pageId="null" pageNumber="293">
<emphasis id="4619FB41B47E3F366DBCE7A594E0F649" italics="true" pageId="null" pageNumber="293">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="C05351D5872EBEEE487A085E2ED014BB" originalValue="Nordwärts" pageId="null" pageNumber="293">Nordwaerts</normalizedToken>
bis 
<normalizedToken id="563307DABE928D3489902360C2A565DB" originalValue="Südengland" pageId="null" pageNumber="293">Suedengland</normalizedToken>
, 
<normalizedToken id="409D1D2A69EF2395F02FD39F60A86301" originalValue="Südwestalpen" pageId="null" pageNumber="293">Suedwestalpen</normalizedToken>
, Nordjugoslawien; 
<normalizedToken id="EBB0FD01A74ECA6F8AA2CB32CAC26CE1" originalValue="südwärts" pageId="null" pageNumber="293">suedwaerts</normalizedToken>
bis Algerien, Kreta und Kleinasien. - Im Gebiet nicht mit Sicherheit nachgewiesen, doch 
<normalizedToken id="DE56E33EFAEAADB32656E7D6C4D4AF32" originalValue="möglicherweise" pageId="null" pageNumber="293">moeglicherweise</normalizedToken>
am 
<normalizedToken id="7A229D569247A6CA39847EF67B4EB8EA" originalValue="Alpensüdrand" pageId="null" pageNumber="293">Alpensuedrand</normalizedToken>
oder im 
<normalizedToken id="7DE5B21ABC73A0802D863C6F2727CB03" originalValue="Dép" pageId="null" pageNumber="293">Dep</normalizedToken>
. Ain aufzufinden.
</paragraph>
</subSubSection>
