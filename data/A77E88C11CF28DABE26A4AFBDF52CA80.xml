<subSubSection id="392D1B6ACB5A0625DD0FDC2A0FB74B4F" pageId="null" pageNumber="62" type="description">
<paragraph id="541A2B79C249D651DB13D00473AC974A" pageId="null" pageNumber="62">
1 
<normalizedToken id="78EF76C8163C2B87314C52AE519C5E6E" originalValue="jährige" pageId="null" pageNumber="62">jaehrige</normalizedToken>
<normalizedToken id="A7C1B713165352080EA21B4B2BACD108" originalValue="Kräuter" pageId="null" pageNumber="62">Kraeuter</normalizedToken>
. 
<emphasis id="E13A262522142959A3787EF1AFCD1158" italics="true" pageId="null" pageNumber="62">Stengel unverzweigt.</emphasis>
<normalizedToken id="02AC1F6AAA415F66838695E144D02352" originalValue="Blüten" pageId="null" pageNumber="62">Blueten</normalizedToken>
aktinomorph, zwitterig, 
<normalizedToken id="E4550B0A0BCE1FD86ECB513AD8CDE03A" originalValue="endständig" pageId="null" pageNumber="62">endstaendig</normalizedToken>
, einzeln. 
<normalizedToken id="4571C5F331AC1EDBDDE2489EAF27D654" originalValue="Perigonblätter" pageId="null" pageNumber="62">Perigonblaetter</normalizedToken>
5 (bis 11). 
<emphasis id="1D1004620756DAC22D41B5849DD8F542" italics="true" pageId="null" pageNumber="62">
<normalizedToken id="19DB7EE84B6B2C386A354849C2DBA7EA" originalValue="Honigblätter" pageId="null" pageNumber="62">Honigblaetter</normalizedToken>
meist 3 oder 5
</emphasis>
(
<emphasis id="761F13F13ECBC0F8939941363BC284E8" italics="true" pageId="null" pageNumber="62">0-9</emphasis>
). 
<normalizedToken id="C8E76A4A01EAE936979B7DFCD2E40EEB" originalValue="Staubblätter" pageId="null" pageNumber="62">Staubblaetter</normalizedToken>
meist weniger als 10. 
<emphasis id="27F00B2D2F54342A7712FA7BE6B11682" italics="true" pageId="null" pageNumber="62">Fruchtknoten zahlreich</emphasis>
(
<emphasis id="C1B35CCF67A8B47FBE3B99B109082F3B" italics="true" pageId="null" pageNumber="62">
<normalizedToken id="11F0607B1076697EF1D4EA44F5AD5216" originalValue="über" pageId="null" pageNumber="62">ueber</normalizedToken>
50
</emphasis>
), 
<emphasis id="F65799AF7CBE363FA6F3FFF3883437A7" italics="true" pageId="null" pageNumber="62">
auf zylindrischem, nach der 
<normalizedToken id="34480DD0130F0442BB1269E74AFD2C77" originalValue="Blüte" pageId="null" pageNumber="62">Bluete</normalizedToken>
weiter wachsendem 
<normalizedToken id="73C5DE59CA7C2B2E892CC3B212222278" originalValue="Blütenboden" pageId="null" pageNumber="62">Bluetenboden</normalizedToken>
</emphasis>
(bei keiner andern unter unsern Gattungen 
<normalizedToken id="4F0E99B584DCFB9E07DF5D67D65F8A9B" originalValue="Blütenachse" pageId="null" pageNumber="62">Bluetenachse</normalizedToken>
so auffallend 
<normalizedToken id="D9890109621D573073EFFD38AD6011D7" originalValue="verlängert" pageId="null" pageNumber="62">verlaengert</normalizedToken>
!), 
<emphasis id="EBE3ABB32592944F89B2CB5B4E0CB540" italics="true" pageId="null" pageNumber="62">dachziegelartig angeordnet</emphasis>
, 1samig.
</paragraph>
<paragraph id="968DA3432B8A886457210F49089AC0EE" pageId="null" pageNumber="62">
Die Gattung 
<normalizedToken id="5710CD1E3A91775D5FAA83817B9B35D3" originalValue="umfaßt" pageId="null" pageNumber="62">umfasst</normalizedToken>
etwa 
<emphasis id="0FC8B931B135D3C821FEAB649847C2CE" italics="true" pageId="null" pageNumber="62">20 Arten mit eurosibirisch-nordamerikanischer Verbreitung.</emphasis>
Weitere Vorkommen in 
<normalizedToken id="4D0D37452E272EE00F76C4EAB9AEF58F" originalValue="Südamerika" pageId="null" pageNumber="62">Suedamerika</normalizedToken>
, Australien und Neuseeland. In Europa wahrscheinlich nur 2 Arten. Verbreitungskarte vieler Arten von Meusel (1965). Stone (1960) untersuchte 4 Arten und 3 Unterarten in Kalifornien; er fand 
<normalizedToken id="15E0E6E9D60A7459ABC1A621ABA28819" originalValue="überall" pageId="null" pageNumber="62">ueberall</normalizedToken>
2n = 16 Chromosomen und normale Meiosen.
</paragraph>
