<subSubSection id="E6BC890BF30370FF0FAA37A85196D025" pageId="null" pageNumber="771" type="description">
<paragraph id="34697C180C32CC561B196F7849DB7E96" pageId="null" pageNumber="771">
1 
<normalizedToken id="939FA87B8F34EB6CD0A7903287DDE390" originalValue="jährig" pageId="null" pageNumber="771">jaehrig</normalizedToken>
, niederliegend oder bogig aufsteigend, bis 50 cm lang, 
<emphasis id="16158183902BB90DBF84DCAC409CE0CA" italics="true" pageId="null" pageNumber="771">
<normalizedToken id="E3FA769545315896D6475E969A15EEEA" originalValue="±" pageId="null" pageNumber="771">+/-</normalizedToken>
</emphasis>
dicht mit glasigen, kurzen Haaren besetzt. 
<normalizedToken id="F6293EA132361FE72D38E0437C9B72F2" originalValue="Blätter" pageId="null" pageNumber="771">Blaetter</normalizedToken>
im 
<normalizedToken id="B68E0E46EFD83216907DEDB609220FBC" originalValue="Umriß" pageId="null" pageNumber="771">Umriss</normalizedToken>
rhombisch, bis 7 cm lang, l-2mal so lang wie breit, mit stumpfer Spitze, 
<normalizedToken id="07EF73732B793589F3F72404BC63274C" originalValue="plötzlich" pageId="null" pageNumber="771">ploetzlich</normalizedToken>
in den 
<normalizedToken id="71854BB84C168464A9DF3448A7E8A80C" originalValue="geflügelten" pageId="null" pageNumber="771">gefluegelten</normalizedToken>
Stiel 
<normalizedToken id="8E020C965C85628B8C5AA5A27369F24D" originalValue="verschmälert" pageId="null" pageNumber="771">verschmaelert</normalizedToken>
, oft mit geschweiftem Rand. 
<normalizedToken id="69005F85792A389C499F901109FB1A8A" originalValue="Blüten" pageId="null" pageNumber="771">Blueten</normalizedToken>
einzeln oder zu 2 in den Blattachseln, sitzend oder kurz gestielt. Kelchzipfel 1,5-2,5 mm lang, 
<emphasis id="28F2E58304478F9AA97B4021F00B0D55" italics="true" pageId="null" pageNumber="771">auf der Innenseite gelb.</emphasis>
<normalizedToken id="3F11D04F517B8D3EF228F1B3402321F9" originalValue="Staubblätter" pageId="null" pageNumber="771">Staubblaetter</normalizedToken>
7-20. Gleich viel Narben wie 
<normalizedToken id="59DFE1BC4E0AFD1889DA965E35E07916" originalValue="Fruchtknotenfächer" pageId="null" pageNumber="771">Fruchtknotenfaecher</normalizedToken>
. Durchmesser der Frucht 8-10 mm; 
<emphasis id="82354BB4E90886F7917CEA2CFFB61CE2" italics="true" pageId="null" pageNumber="771">
im obern Teil auf der 
<normalizedToken id="1E06DDD0A38A8F4A7C6AEFB9495438C9" originalValue="Auβenseite" pageId="null" pageNumber="771">Auβenseite</normalizedToken>
der Frucht 2-5 kornartige Zipfel.
</emphasis>
- 
<normalizedToken id="0F36E7ADBE62626C983B4AF191C4E68A" originalValue="Blüte" pageId="null" pageNumber="771">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="C8413950F020B8070ED6D7EAE9A6FF25" pageId="null" pageNumber="771">
<emphasis id="FB88B5516B46500B2C6849B127191625" italics="true" pageId="null" pageNumber="771">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="7D7FFA9E420066E39A0092EFF6304619" italics="true" pageId="null" pageNumber="771">32:</emphasis>
Zahlreiche und 
<normalizedToken id="0D19C5F9E1BF02DCCCDB58BE6E0FBD58" originalValue="übereinstimmende" pageId="null" pageNumber="771">uebereinstimmende</normalizedToken>
<normalizedToken id="F929CDA5768AA8ED21ADB628FC030A4C" originalValue="Zählungen" pageId="null" pageNumber="771">Zaehlungen</normalizedToken>
, zusammengestellt von 
<normalizedToken id="049303C882E7DB5CFA6B25128739FEF7" originalValue="Löve" pageId="null" pageNumber="771">Loeve</normalizedToken>
und 
<normalizedToken id="7E845E78DEB0E0E3BC677793A8E0A35D" originalValue="Löve" pageId="null" pageNumber="771">Loeve</normalizedToken>
(1961).
</paragraph>
<paragraph id="3F147E979C33B755BBC66B01B5E1170B" pageId="null" pageNumber="771">
<emphasis id="1C00D0CA086FC0EEF893842B207971EC" italics="true" pageId="null" pageNumber="771">Standort.</emphasis>
Kollin. Im 
<normalizedToken id="745C0E4A1857AFBF110792896956AD18" originalValue="Süden" pageId="null" pageNumber="771">Sueden</normalizedToken>
des Gebiets gelegentlich verwilderte Gartenpflanze auf 
<normalizedToken id="A57C55571A5F6EEBF3BD6E6971105C61" originalValue="Schuttplätzen" pageId="null" pageNumber="771">Schuttplaetzen</normalizedToken>
und Ruderalstellen.
</paragraph>
<paragraph id="96666B8270C34DA6ABF644497C1389AD" pageId="null" pageNumber="771">
<emphasis id="0A841E276E527C29191505F5A4625380" italics="true" pageId="null" pageNumber="771">
Verbreitung. Pflanze der 
<normalizedToken id="17811FB72CA6FF0C8203681BC5B60832" originalValue="südlichen" pageId="null" pageNumber="771">suedlichen</normalizedToken>
<normalizedToken id="ED7832BD580D99B6BC22296629ED57B7" originalValue="Hemisphäre" pageId="null" pageNumber="771">Hemisphaere</normalizedToken>
:
</emphasis>
<normalizedToken id="1BD6EDB57A97D4DA0CF23E515CCEDDFD" originalValue="Südamerika" pageId="null" pageNumber="771">Suedamerika</normalizedToken>
, 
<normalizedToken id="A0B1E523450E322D04A6E33E9786B838" originalValue="Südafrika" pageId="null" pageNumber="771">Suedafrika</normalizedToken>
, Australien, Tasmanien, Neuseeland; als 
<normalizedToken id="5B61937DB1C1D2CE4F388498257B0FAC" originalValue="Gemüsepflanze" pageId="null" pageNumber="771">Gemuesepflanze</normalizedToken>
(
<normalizedToken id="EE98E8DDA26D5207E0BDE2F4FD4384CE" originalValue="Neuseeländischer" pageId="null" pageNumber="771">Neuseelaendischer</normalizedToken>
Spinat) auch auf der 
<normalizedToken id="B9620689C7B05A6BF114D77F89E52DBF" originalValue="Nordhemisphäre" pageId="null" pageNumber="771">Nordhemisphaere</normalizedToken>
weit verbreitet. - Im Gebiet im 
<normalizedToken id="51AB4CC435CC876EF227A33449B96B83" originalValue="Süden" pageId="null" pageNumber="771">Sueden</normalizedToken>
gelegentlich verwildert (z.B. Bergell, Puschlav).
</paragraph>
</subSubSection>
