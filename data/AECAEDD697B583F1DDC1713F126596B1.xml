<subSubSection id="3AC8411D71EFAE8E517B69CA63617102" pageId="null" pageNumber="547" type="description">
<paragraph id="BDF656563A8700EF098D4DB716791DB4" pageId="null" pageNumber="547">
Ausdauernd oder 1 
<normalizedToken id="66D11A7CB52DA147C880C08C47A1DEA1" originalValue="jährig" pageId="null" pageNumber="547">jaehrig</normalizedToken>
. Stengel glatt und rund, nicht hohl. 
<normalizedToken id="7360DE67E1CAB36B9D9D66DA932409C5" originalValue="Blütenköpfe" pageId="null" pageNumber="547">Bluetenkoepfe</normalizedToken>
einzeln, lang gestielt. 
<normalizedToken id="A027EF3C517E9882B9AF1BBDE514C10F" originalValue="Hülle" pageId="null" pageNumber="547">Huelle</normalizedToken>
<normalizedToken id="0AF8C151685AE620DFF109BB38256DCC" originalValue="glockenförmig" pageId="null" pageNumber="547">glockenfoermig</normalizedToken>
. 
<emphasis id="54494C693F9D88FF2BAED429CF87897A" italics="true" pageId="null" pageNumber="547">
<normalizedToken id="412E8117EFBD030A255D14F6AC94ACE5" originalValue="Hüllblätter" pageId="null" pageNumber="547">Huellblaetter</normalizedToken>
in 2 Reihen. Boden des 
<normalizedToken id="7B711971F6AD38A7F13031418281668E" originalValue="Blütenkopfes" pageId="null" pageNumber="547">Bluetenkopfes</normalizedToken>
<normalizedToken id="90596975C4210D73D87CCD16D352A9BE" originalValue="kegelförmig" pageId="null" pageNumber="547">kegelfoermig</normalizedToken>
</emphasis>
, mit 
<normalizedToken id="FA2A3DC032C224EF8E6CF53932BCBFC9" originalValue="höckeriger" pageId="null" pageNumber="547">hoeckeriger</normalizedToken>
<normalizedToken id="D3664982DA9577B757DA6BE2E4CE8565" originalValue="Oberfläche" pageId="null" pageNumber="547">Oberflaeche</normalizedToken>
, 
<emphasis id="CE571EBDB603124CAD4B63C32F6F660D" italics="true" pageId="null" pageNumber="547">hohl</emphasis>
(im Gebiet sonst nur bei 
<taxonomicName id="2E772E47884F3E9605605ACBBF1BF7E0" class="Magnoliopsida" family="Asteraceae" genus="Matricaria" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="547" phylum="Tracheophyta" rank="genus">
<emphasis id="CCADD727D15B8D983546B47170705277" italics="true" pageId="null" pageNumber="547">Matricaria</emphasis>
</taxonomicName>
und 
<taxonomicName id="A27C1F2BE00DB3023BEB2983A95F3B8B" class="Magnoliopsida" family="Asteraceae" genus="Achillea" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="547" phylum="Tracheophyta" rank="genus">
<emphasis id="F3A148E0C1C2E88F5BFF21BE2E2C0C81" italics="true" pageId="null" pageNumber="547">Achillea</emphasis>
</taxonomicName>
deutlich hohl), ohne 
<normalizedToken id="F0B71D4E62869B77201C91B20789C42E" originalValue="Spreublätter" pageId="null" pageNumber="547">Spreublaetter</normalizedToken>
und ohne Haare. 
<normalizedToken id="98D26A122F1A7A42438305B3A06A105B" originalValue="Äußere" pageId="null" pageNumber="547">Aeussere</normalizedToken>
<normalizedToken id="B340E6C3EEEF95D5815918D5BB6D3AE8" originalValue="Blüten" pageId="null" pageNumber="547">Blueten</normalizedToken>
<normalizedToken id="F5D66EBC599E2C90FB4CB53B40EECE97" originalValue="zungenförmig" pageId="null" pageNumber="547">zungenfoermig</normalizedToken>
, ♀, zahlreich, meist 1reihig, 
<normalizedToken id="CF703EAF2094E2BA4007213B302577D3" originalValue="weiß" pageId="null" pageNumber="547">weiss</normalizedToken>
oder rosa; innere 
<normalizedToken id="D98FAFA6C2E59FACF8ED0B102EE51E0C" originalValue="Blüten" pageId="null" pageNumber="547">Blueten</normalizedToken>
<normalizedToken id="A74ABB4D868A0369EDEE7B2C4CD0726C" originalValue="röhrenförmig" pageId="null" pageNumber="547">roehrenfoermig</normalizedToken>
, ⚥, gelb. 
<emphasis id="82E56FB45F7C6C9C5D79D356902B3906" italics="true" pageId="null" pageNumber="547">
<normalizedToken id="AED35AD5626BD32A9DDDC72FCB9A61C5" originalValue="Früchte" pageId="null" pageNumber="547">Fruechte</normalizedToken>
<normalizedToken id="E9F9E09E9E0D4FC39C9B88CF0D669EB5" originalValue="eiförmig" pageId="null" pageNumber="547">eifoermig</normalizedToken>
</emphasis>
(
<normalizedToken id="4A616044DB310536177A3A79B2298574" originalValue="größte" pageId="null" pageNumber="547">groesste</normalizedToken>
Breite im obern Teil), wenig abgeflacht, behaart, 
<emphasis id="FCD00812D12744685A6014BDC5F271E1" italics="true" pageId="null" pageNumber="547">
ohne 
<taxonomicName id="1AD93910D11D3027E4469676E8495050" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="547" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
.
</emphasis>
</paragraph>
<paragraph id="946B662CC888DA4E94BC8267589D2DE5" pageId="null" pageNumber="547">
Die Gattung 
<taxonomicName id="1CE96CB7BFB4CFE5EADE64872A00EDE1" class="Magnoliopsida" family="Asteraceae" genus="Bellis" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="547" phylum="Tracheophyta" rank="genus">
<emphasis id="27577E66A70D4E3D6DB8D736DE45CAEA" italics="true" pageId="null" pageNumber="547">Bellis</emphasis>
</taxonomicName>
<normalizedToken id="402BD7385AD3E71F8D61C6D3D1E55BAB" originalValue="umfaßt" pageId="null" pageNumber="547">umfasst</normalizedToken>
etwa 
<emphasis id="7EB3A3D9422A2EA32B608088F337AA65" italics="true" pageId="null" pageNumber="547">10 Arten</emphasis>
und ist vor allem im 
<emphasis id="5B49AF6ED3D5294280196F4338DA8F26" italics="true" pageId="null" pageNumber="547">Mittelmeergebiet</emphasis>
verbreitet.
</paragraph>
</subSubSection>
