<taxonomicName id="DB970A4A2C9B4E7C36D6E2EA485D55CC" authority="Gaudin" class="Magnoliopsida" family="Asteraceae" genus="Erigeron" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="537" phylum="Tracheophyta" rank="species" species="angulosus">
