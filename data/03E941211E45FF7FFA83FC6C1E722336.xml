<emphasis id="B9342C251E45FF7EFA82F85718072A58" bold="true" box="[1393,1792,2028,2057]" pageId="2" pageNumber="30">Subspecies and Distribution.</emphasis>
</paragraph>
<paragraph id="8BFFF0371E45FF7EFA87F7B518972A06" blockId="2.[1391,2600,1550,3277]" pageId="2" pageNumber="30">
<taxonomicName id="4C408BB41E45FF7EFA87F7B5184C2A7E" authority="Milne-Edwards, 1871" authorityName="Milne-Edwards" authorityYear="1871" baseAuthorityName="A. Milne-Edwards" baseAuthorityYear="1871" box="[1396,1867,2062,2095]" class="Mammalia" family="Ochotonidae" genus="Ochotona" kingdom="Animalia" order="Lagomorpha" pageId="2" pageNumber="30" phylum="Chordata" rank="subSpecies" species="thibetana" subSpecies="thibetana">O.t.thibetanaMilne-Edwards,1871—HengduanMtsinSETibet(=Xizang),WSichuan,NWYunnan(China),andNMyanmar.</taxonomicName>
