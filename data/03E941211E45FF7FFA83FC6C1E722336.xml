<caption id="DF3FA0BF1E45FF7EFA82F857195E2A9F" ID-DOI="http://doi.org/10.5281/zenodo.6619795" ID-Zenodo-Dep="6619795" httpUri="https://zenodo.org/record/6619795/files/figure.png" inLine="true" pageId="2" pageNumber="30" targetBox="[1388,1979,1124,1538]" targetPageId="2">
