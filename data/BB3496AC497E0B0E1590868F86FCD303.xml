<subSubSection id="54E7A7105B7375E63A4FD776C002A157" pageId="null" pageNumber="650" type="description">
<paragraph id="A6C1286BA858858E3DFEAE51232D5D99" pageId="null" pageNumber="650">
<normalizedToken id="47E2F988D3D5C72A2E2E160B2A6EA53C" originalValue="Blüten" pageId="null" pageNumber="650">Blueten</normalizedToken>
meist in Trauben. 
<emphasis id="73F594C9731670041FBC22A9864990C9" italics="true" pageId="null" pageNumber="650">
Die beiden seitlichen 
<normalizedToken id="89184E28777DB8015BDCD7F17A5A4AA6" originalValue="Kelchblätter" pageId="null" pageNumber="650">Kelchblaetter</normalizedToken>
kronblattartig
</emphasis>
(
<normalizedToken id="10D546DDD0607DDAADFC5ACD70FD6D56" originalValue="«Flügel»" pageId="null" pageNumber="650">&quot;Fluegel&quot;</normalizedToken>
). 
<emphasis id="21276DD022DB1E6B37CC46A75770AEAD" italics="true" pageId="null" pageNumber="650">
Krone 
<normalizedToken id="07A364BA8EDCDEDD76455AB5B35740C6" originalValue="rinnenförmig" pageId="null" pageNumber="650">rinnenfoermig</normalizedToken>
</emphasis>
(
<emphasis id="8C327C1365FCCD8BF1A67184E3ACD9C6" italics="true" pageId="null" pageNumber="650">Kiel</emphasis>
), 
<emphasis id="9C115A350DCCC9DF89C6FB376888A3CC" italics="true" pageId="null" pageNumber="650">vorn mit 2 freien obern Zipfeln und 1 oft geteilten untern Zipfel.</emphasis>
Frucht auf den Seiten stark abgeflacht und 
<normalizedToken id="D8F04C4F049577936F39014A5E4F6E92" originalValue="herzförmig" pageId="null" pageNumber="650">herzfoermig</normalizedToken>
.
</paragraph>
<paragraph id="5B6AB20F24CA3E08A10B10D092235C9C" pageId="null" pageNumber="650">
Die Gattung 
<taxonomicName id="F3346F27D0A118AD362F466CB6B1EDF9" class="Magnoliopsida" family="Polygalaceae" genus="Polygala" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="650" phylum="Tracheophyta" rank="genus">
<emphasis id="52B6D005A48DE99CD0DD1D9849B8BAFF" italics="true" pageId="null" pageNumber="650">Polygala</emphasis>
</taxonomicName>
<normalizedToken id="DEEDD96BAC9833EC596892E8ABDF697A" originalValue="umfaßt" pageId="null" pageNumber="650">umfasst</normalizedToken>
<emphasis id="4FCF8CC4DDCB9F5685629F56C5B96730" italics="true" pageId="null" pageNumber="650">
etwa 500 Arten und ist 
<normalizedToken id="E88F4557C2346B3EBF0F10D4560EBCCC" originalValue="über" pageId="null" pageNumber="650">ueber</normalizedToken>
die ganze Erde verbreitet
</emphasis>
(ausgenommen Australien).
</paragraph>
<paragraph id="D26BF4BDDB270333B86C4AB2AEC0DC77" pageId="null" pageNumber="650">
<table id="0FFBAF3D3AD03B675466868336EBA7BF" frame="void" pageId="null" pageNumber="650" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="9218AAE63B3A57D497F6C49A821B0891" pageId="null" pageNumber="650">
<tr id="32D48E970654E4F7043CB9562DAE6160" pageId="null" pageNumber="650">
<td id="BE2BB051D7A9955811DCAABBFEB8C8D0" align="left" pageId="null" pageNumber="650" valign="top">
1. Stengel im untern Teil holzig; 
<normalizedToken id="BB4BAC707DBCCB4F8524602CEC137D61" originalValue="Blätter" pageId="null" pageNumber="650">Blaetter</normalizedToken>
<normalizedToken id="5CAC91B6A65732BCF9CBFC2AD95D3E0B" originalValue="immergrün" pageId="null" pageNumber="650">immergruen</normalizedToken>
, lederartig; Fruchtstiele aufrecht; 
<normalizedToken id="D85EB840EE2ED2A05454D67BC91A3CC4" originalValue="Flügel" pageId="null" pageNumber="650">Fluegel</normalizedToken>
10-15 mm lang
</td>
<td id="6D2A3BD681A44AC6BE5733263538304B" align="left" pageId="null" pageNumber="650" valign="bottom">
<italic id="848BFC2259A585F8724001080EA3A2CF" pageId="null" pageNumber="650">
P. 
<taxonomicName id="B488F7C8C4C60569E252A10C9DBEFB3B" class="Magnoliopsida" family="Polygalaceae" genus="Chamaebuxus" higherTaxonomySource="GBIF" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="650" phylum="Tracheophyta" rank="genus">Chamaebuxus</taxonomicName>
</italic>
(Nr. 1)
</td>
</tr>
<tr id="DFF9D170FA350E48B5E715441ED7E73E" pageId="null" pageNumber="650">
<td id="56C35028E92C6EB3AF52DD607EEBBC62" align="left" pageId="null" pageNumber="650" valign="top">
1*. 1 
<normalizedToken id="A312B6C754DA4375CBD134500E6C1EBE" originalValue="jährige" pageId="null" pageNumber="650">jaehrige</normalizedToken>
oder ausdauernde 
<normalizedToken id="A3A1E02892052443D66B590658C2BC1E" originalValue="Kräuter" pageId="null" pageNumber="650">Kraeuter</normalizedToken>
(Stengel nicht holzig); 
<normalizedToken id="AE91286AE8E2606F35C30AA490BA32A7" originalValue="Blätter" pageId="null" pageNumber="650">Blaetter</normalizedToken>
krautig; Fruchtstiele nach unten gebogen; 
<normalizedToken id="BB614D8AB2CB823BF41C66952B334A5C" originalValue="Flügel" pageId="null" pageNumber="650">Fluegel</normalizedToken>
2,5-9 mm lang.
</td>
</tr>
<tr id="FE099C0CC8E82345E02CE55452A280FD" pageId="null" pageNumber="650">
<td id="F051EE7ABDEB38BA2C7448DAD74C8825" align="left" pageId="null" pageNumber="650" valign="top">
2. Pflanze ausdauernd; 
<normalizedToken id="81D840FCAA676242223BEE05214ABDB5" originalValue="Flügel" pageId="null" pageNumber="650">Fluegel</normalizedToken>
2,5-9 mm lang und 1,5-6 mm breit; Frucht 3-6,5 mm lang
</td>
<td id="0A68DC4A087F72DA5464187072BDD6DA" align="left" pageId="null" pageNumber="650" valign="bottom">
<italic id="A59565B738D85F0B3DB47E7B79B2EE3F" pageId="null" pageNumber="650">
Artengruppe der 
<taxonomicName id="D1C1741CD01BF8315D4F918CCAB7E647" class="Magnoliopsida" family="Polygalaceae" genus="Polygala" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="650" phylum="Tracheophyta" rank="species" species="vulgaris">P. vulgaris</taxonomicName>
</italic>
(Nr. 2)
</td>
</tr>
<tr id="87F0A3DEB96F60C4B373BCCE5E139851" pageId="null" pageNumber="650">
<td id="851F86618FB1F1D7F7C31ADF93199A6B" align="left" pageId="null" pageNumber="650" valign="top">
2*. Pflanze 1 
<normalizedToken id="2903338C4C635E3901A2F1478E1D7CF6" originalValue="jährig" pageId="null" pageNumber="650">jaehrig</normalizedToken>
; 
<normalizedToken id="2153B64A90843BF2A26F96A4FEF34212" originalValue="Flügel" pageId="null" pageNumber="650">Fluegel</normalizedToken>
2,5-3,2 mm lang und 1-1,4 mm breit, 
<normalizedToken id="1419071758D3C106A0A946DD7F0278E7" originalValue="weiß" pageId="null" pageNumber="650">weiss</normalizedToken>
mit 
<normalizedToken id="9E9ECA14E4346CBD9A48CED2BF5BD722" originalValue="grünem" pageId="null" pageNumber="650">gruenem</normalizedToken>
Mittelstreifen; Frucht 2,2-3 mm lang. 
<normalizedToken id="49EC902DF0328AC953CDE756B0556320" originalValue="Dép" pageId="null" pageNumber="650">Dep</normalizedToken>
. Ain
</td>
<td id="890AED3D34D9FA2060E18D6DA59C41BE" align="left" pageId="null" pageNumber="650" valign="bottom">
<taxonomicName id="70554F5B365865562281A4103AC102BC" class="Magnoliopsida" family="Polygalaceae" genus="Polygala" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="650" phylum="Tracheophyta" rank="species" species="exilis">
<italic id="98B0259A183826C5CE00B20165B0D720" pageId="null" pageNumber="650">P. exilis</italic>
</taxonomicName>
(Nr. 3)
</td>
</tr>
</tbody>
</table>
</paragraph>
