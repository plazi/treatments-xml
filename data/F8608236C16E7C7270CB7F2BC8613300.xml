<subSubSection id="A29E38783A5FBA0BE30E6696DEFE58B7" pageId="null" pageNumber="213" type="description">
<paragraph id="A37440283E430571909DC6A4722B1A10" pageId="null" pageNumber="213">
Ausdauernd; 30-60 cm hoch; 
<normalizedToken id="231BB14E4639C75F79BFCB64DC20D4EE" originalValue="±" pageId="null" pageNumber="213">+/-</normalizedToken>
kahl. Stengel aufrecht, einfach oder im obern Teil verzweigt. 
<normalizedToken id="2473189463FED779CBDF2312748CB142" originalValue="Blätter" pageId="null" pageNumber="213">Blaetter</normalizedToken>
2gestaltig; 
<emphasis id="02990D4D99158F25A2D2B284A97E0FA2" italics="true" pageId="null" pageNumber="213">jene am Grunde des Stengels in einer Rosette</emphasis>
, kurz gestielt, oval bis breit lanzettlich, scharf und 
<normalizedToken id="49FB0F4AA85B02F822A5FBB47E73EC70" originalValue="unregelmäßig" pageId="null" pageNumber="213">unregelmaessig</normalizedToken>
<normalizedToken id="C6A0BEE09652923097C55CA14792F1EA" originalValue="gezähnt" pageId="null" pageNumber="213">gezaehnt</normalizedToken>
, 
<emphasis id="2FC48513356C99E81E5178A557F6EFF0" italics="true" pageId="null" pageNumber="213">
die 
<normalizedToken id="F43DDBFAC8B95E05E0969C689B1EB87E" originalValue="stengelständigen" pageId="null" pageNumber="213">stengelstaendigen</normalizedToken>
meist 3
</emphasis>
- 
<emphasis id="EE4B89C7DCCCC6073411F3043ADA7046" italics="true" pageId="null" pageNumber="213">5teilig</emphasis>
, mit schmal lanzettlichen Abschnitten. 
<normalizedToken id="30C34B17F3BA602ABB6AF11484563AF4" originalValue="Blüten" pageId="null" pageNumber="213">Blueten</normalizedToken>
kurz gestielt, in oft einseitswendigen, langen Trauben am Ende der Zweige, 
<emphasis id="B2B49B61868039983B4570AF3810CADF" italics="true" pageId="null" pageNumber="213">0,3</emphasis>
- 
<emphasis id="5A0484AF2B3B7E89FEEA979A51E1C44D" italics="true" pageId="null" pageNumber="213">0,4 cm lang. Krone blauviolett. Samen etwa 0,5 mm lang</emphasis>
, 
<normalizedToken id="C896A20364F5819E810FC7221F711498" originalValue="eiförmig" pageId="null" pageNumber="213">eifoermig</normalizedToken>
, 
<normalizedToken id="5AFBCA04BEFDBDCA8C53837A2CA255B6" originalValue="körnig" pageId="null" pageNumber="213">koernig</normalizedToken>
. - 
<normalizedToken id="FAC329D95B09A29C2E25767E26E2170E" originalValue="Blüte" pageId="null" pageNumber="213">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="C1EBF25806937EBAA63B703A59656C98" pageId="null" pageNumber="213">
<emphasis id="F0011BDE4133A8DEF3C88DACCDBD75A7" italics="true" pageId="null" pageNumber="213">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5CF42F855AED1BB0C10B7C7A6D50A4E7" italics="true" pageId="null" pageNumber="213">18:</emphasis>
Material unbekannter Herkunft (Heitz 1927).
</paragraph>
<paragraph id="68B77687F6B1153E34FC28AFB9977366" pageId="null" pageNumber="213">
<emphasis id="62196AFDCA7AEEFBA225FFB5D237D0B8" italics="true" pageId="null" pageNumber="213">Standort.</emphasis>
Kollin. Trockene, steinige, kalkarme 
<normalizedToken id="828EC7546BD94F7720EA5A1289551284" originalValue="Böden" pageId="null" pageNumber="213">Boeden</normalizedToken>
. Felsen, Schutthalden, 
<normalizedToken id="E7BC1C2654D80B50E2CC8BA637B85E19" originalValue="Äcker" pageId="null" pageNumber="213">Aecker</normalizedToken>
.
</paragraph>
<paragraph id="67096643127386F2737D9079DB9786C8" pageId="null" pageNumber="213">
<emphasis id="B28BB925BB212F3D2BB54A47CE31242E" italics="true" pageId="null" pageNumber="213">
Verbreitung. 
<normalizedToken id="0A09B423612BAB1ED130C95D057933A6" originalValue="Westeuropäische" pageId="null" pageNumber="213">Westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="9DE9230331C3BCA4BE4C2980688BF08F" originalValue="Ostwärts" pageId="null" pageNumber="213">Ostwaerts</normalizedToken>
bis Saargebiet, Franken und Oberitalien. - Im Gebiet: 
<normalizedToken id="DD4FDCD5571A6446F31021E636A3AF21" originalValue="Dép" pageId="null" pageNumber="213">Dep</normalizedToken>
. Ain (
<normalizedToken id="23BDAE3A80F0BD3320B78576E1D26DF2" originalValue="Crémieu" pageId="null" pageNumber="213">Cremieu</normalizedToken>
), Savoyen (Pont de Beauvoisin, Ste-Marie 
<normalizedToken id="9DEDDE682C5935F717F196EC07B08275" originalValue="d’Alvey" pageId="null" pageNumber="213">d'Alvey</normalizedToken>
), Gallarate (zwischen Varese und Mailand, Stucchi 1969 in lit.), Comerseegebiet, Iseoseegebiet (Caleppio bis Predore); 
<normalizedToken id="C8C6A8A960A53CE20180427A63AD3D0D" originalValue="früher" pageId="null" pageNumber="213">frueher</normalizedToken>
auch bei Genf.
</paragraph>
</subSubSection>
