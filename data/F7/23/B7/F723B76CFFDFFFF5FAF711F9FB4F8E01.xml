<subSubSection pageId="36" pageNumber="165" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6685483" ID-Zenodo-Dep="6685483" httpUri="https://zenodo.org/record/6685483/files/figure.png" inLine="true" pageId="36" pageNumber="165" targetBox="[1368,1959,2204,2618]" targetPageId="36">
<paragraph blockId="36.[1981,2575,2192,2620]" pageId="36" pageNumber="165">
<emphasis bold="true" box="[1982,2158,2315,2344]" pageId="36" pageNumber="165">Distribution.</emphasis>
SE Colombia, SC Venezuela (Bolivar, Amazonas), W Brazil (Amazonas, Acre), E Ecuador, and N &amp; C Peru (S to Ayacucho) E of the Andes.
</paragraph>
</caption>
