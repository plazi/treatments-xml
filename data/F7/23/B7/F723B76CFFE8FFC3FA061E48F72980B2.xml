<subSubSection pageId="19" pageNumber="148" type="discussion">
<paragraph blockId="19.[2063,2656,2266,2692]" pageId="19" pageNumber="148">
This species was formerly considered a subspecies of 
<taxonomicName baseAuthorityName="Thomas" baseAuthorityYear="1897" box="[2260,2394,2392,2417]" class="Mammalia" family="Didelphidae" genus="Monodelphis" kingdom="Animalia" order="Didelphimorphia" pageId="19" pageNumber="148" phylum="Chordata" rank="species" species="adusta">M. adusta</taxonomicName>
, but it is now considered a separate species. Monotypic.
</paragraph>
</subSubSection>
<subSubSection pageId="19" pageNumber="148" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6685415" ID-Zenodo-Dep="6685415" httpUri="https://zenodo.org/record/6685415/files/figure.png" inLine="true" pageId="19" pageNumber="148" targetBox="[1448,2039,2277,2691]" targetPageId="19">
