<caption ID-DOI="http://doi.org/10.5281/zenodo.6685411" ID-Zenodo-Dep="6685411" httpUri="https://zenodo.org/record/6685411/files/figure.png" inLine="true" pageId="19" pageNumber="148" targetBox="[1448,2039,1015,1430]" targetPageId="19">
