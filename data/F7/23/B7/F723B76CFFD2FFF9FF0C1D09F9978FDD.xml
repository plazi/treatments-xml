<caption ID-DOI="http://doi.org/10.5281/zenodo.6685507" ID-Zenodo-Dep="6685507" httpUri="https://zenodo.org/record/6685507/files/figure.png" inLine="true" pageId="41" pageNumber="170" targetBox="[162,752,3020,3433]" targetPageId="41">
