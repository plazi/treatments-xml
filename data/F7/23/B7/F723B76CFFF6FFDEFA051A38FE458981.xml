<caption ID-DOI="http://doi.org/10.5281/zenodo.6685397" ID-Zenodo-Dep="6685397" box="[1452,2326,3363,3392]" httpUri="https://zenodo.org/record/6685397/files/figure.png" inLine="true" pageId="13" pageNumber="142" targetBox="[94,685,297,712]" targetPageId="14">
