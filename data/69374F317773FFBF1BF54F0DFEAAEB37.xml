<emphasis id="D3EA22357774FFBF19364F00FE0CEB77" box="[338,486,1047,1071]" italics="true" pageId="12" pageNumber="49">Kallirhynchia</emphasis>
Buckman, 1918 
<emphasis id="D3EA22357774FFBF18F34F20FEE8EB17" bold="true" box="[151,258,1079,1103]" pageId="12" pageNumber="49">Typusart</emphasis>
</taxonomicName>
<emphasis id="D3EA22357774FFBF19674F20FEE2EB17" bold="true" box="[259,264,1079,1103]" pageId="12" pageNumber="49">:</emphasis>
<taxonomicName id="269E85A47774FFBF19794F20FEAAEB37" authority="Davidson, 1878" authorityName="Davidson" authorityYear="1878" class="Rhynchonellata" family="Rhynchonellidae" genus="Rhynchonella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Rhynchonellida" pageId="12" pageNumber="49" phylum="Brachiopoda" rank="variety" species="concinna" variety="yaxleyensis">
<emphasis id="D3EA22357774FFBF19794F20FDC2EB17" box="[285,552,1079,1103]" italics="true" pageId="12" pageNumber="49">Rhynchonella concinna</emphasis>
var. 
<emphasis id="D3EA22357774FFBF1A1F4F20FD1EEB17" box="[635,756,1079,1103]" italics="true" pageId="12" pageNumber="49">yaxleyensis</emphasis>
Davidson, 1878
</taxonomicName>
</paragraph>
