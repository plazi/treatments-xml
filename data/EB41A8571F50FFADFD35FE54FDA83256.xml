, 
<taxonomicName id="A4E862C21F57FFACFF7DF982FDBB3573" authority="M.Schmid" authorityName="M. Schmid" authorityYear="2012" box="[231,529,1635,1652]" class="Magnoliopsida" family="Primulaceae" genus="Tapeinosperma" kingdom="Plantae" order="Ericales" pageId="28" pageNumber="307" phylum="Tracheophyta" rank="species" species="ateouense" status="sp.nov.">
<emphasis id="519CC5531F57FFACFF7DF982FE103573" box="[231,442,1635,1652]" italics="true" pageId="28" pageNumber="307">Tapeinosperma ateouense</emphasis>
M.Schmid
</taxonomicName>
, 
<taxonomicNameLabel id="4AAF78281F57FFACFD80F982FDF73573" box="[538,605,1635,1652]" pageId="28" pageNumber="307" rank="species">sp.nov.</taxonomicNameLabel>
, 
<emphasis id="519CC5531F57FFACFDF8F982FD763573" box="[610,732,1635,1652]" italics="true" pageId="28" pageNumber="307">MacKee 45277</emphasis>
