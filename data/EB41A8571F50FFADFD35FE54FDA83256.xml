<emphasis id="519CC5531F57FFACFDC6F971FDC035A6" bold="true" box="[604,618,1680,1697]" pageId="28" pageNumber="307">H</emphasis>
, 
<emphasis id="519CC5531F57FFACFDE9F971FD7035A6" box="[627,730,1680,1697]" italics="true" pageId="28" pageNumber="307">Bamps 6136</emphasis>
