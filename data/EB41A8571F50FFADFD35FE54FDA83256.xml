<emphasis id="519CC5531F57FFACFB97F998FBB1358D" bold="true" box="[1037,1051,1657,1674]" pageId="28" pageNumber="307">G</emphasis>
, fleur (autre conformation); 
<emphasis id="519CC5531F57FFACFF23F971FF6D35A6" bold="true" box="[185,199,1680,1697]" pageId="28" pageNumber="307">H</emphasis>
