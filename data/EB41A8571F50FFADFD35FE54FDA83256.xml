<emphasis id="519CC5531F57FFACFC6AF982FC573573" bold="true" box="[1008,1021,1635,1652]" pageId="28" pageNumber="307">B</emphasis>
, feuille (face inférieure); 
<emphasis id="519CC5531F57FFACFFEBF998FFD5358D" bold="true" box="[113,127,1657,1674]" pageId="28" pageNumber="307">C</emphasis>
, fleur; 
<emphasis id="519CC5531F57FFACFF22F998FF6C358D" bold="true" box="[184,198,1657,1674]" pageId="28" pageNumber="307">D</emphasis>
, calice et style; 
<emphasis id="519CC5531F57FFACFED0F998FEC1358D" bold="true" box="[330,363,1657,1674]" pageId="28" pageNumber="307">E -H</emphasis>
, 
<taxonomicName id="A4E862C21F57FFACFEEEF998FDA4358D" authority="Mez" authorityName="Mez" box="[372,526,1657,1674]" class="Magnoliopsida" family="Primulaceae" genus="Tapeinosperma" kingdom="Plantae" order="Ericales" pageId="28" pageNumber="307" phylum="Tracheophyta" rank="species" species="squarrosum">
<emphasis id="519CC5531F57FFACFEEEF998FE4D358D" box="[372,487,1657,1674]" italics="true" pageId="28" pageNumber="307">T. squarrosum</emphasis>
Mez
</taxonomicName>
: 
<emphasis id="519CC5531F57FFACFD87F998FD83358D" bold="true" box="[541,553,1657,1674]" pageId="28" pageNumber="307">E</emphasis>
, rameau florifère, 
<emphasis id="519CC5531F57FFACFD21F998FC85358D" box="[699,815,1657,1674]" italics="true" pageId="28" pageNumber="307">Tronchet 1391</emphasis>
(P); 
<emphasis id="519CC5531F57FFACFCCFF998FCCA358D" bold="true" box="[853,864,1657,1674]" pageId="28" pageNumber="307">F</emphasis>
