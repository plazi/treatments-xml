<subSubSection id="710AC4F1BA85516106FFB6F9771CD28C" pageId="null" pageNumber="37" type="description">
<paragraph id="4F9770A070D595CA27B56F7CBEDDC800" pageId="null" pageNumber="37">
3-40 cm hoch. Kelch bis auf etwa ⅓ der 
<normalizedToken id="1F15D3EAD264DF12CAD11F9016DA3577" originalValue="Länge" pageId="null" pageNumber="37">Laenge</normalizedToken>
5(selten 4)teilig, 
<emphasis id="01AF29E00215BF3CE30D47FACD0203B1" italics="true" pageId="null" pageNumber="37">mit gerundeten Buchten;</emphasis>
Zipfel schmal lanzettlich, 
<normalizedToken id="1FB940F4E3C85FBB992B3A6D1FE9CD97" originalValue="±" pageId="null" pageNumber="37">+/-</normalizedToken>
<emphasis id="8249E616D59983E9249A55478026AF6F" italics="true" pageId="null" pageNumber="37">gleich, etwa so lang wie die Kronzipfel</emphasis>
, am Rande kahl oder mit ganz kleinen Papillen, kaum nach 
<normalizedToken id="E0C58E76953C1D20007A4F5B7D81A5C0" originalValue="außen" pageId="null" pageNumber="37">aussen</normalizedToken>
umgerollt. 
<emphasis id="3E17F05D77389C9E3A51A85BE755F93E" italics="true" pageId="null" pageNumber="37">Krone lila</emphasis>
, seltener 
<normalizedToken id="5D6025B952F2C3B936EFA0A278B9CD4D" originalValue="weiß" pageId="null" pageNumber="37">weiss</normalizedToken>
, 
<emphasis id="695FE5412BCD8F099152F155224A46EC" italics="true" pageId="null" pageNumber="37">mit 5</emphasis>
(
<emphasis id="A4F75947ACC8FD78A693DC28A4B9EA19" italics="true" pageId="null" pageNumber="37">selten 4</emphasis>
) 
<emphasis id="9E761DB30166E071F929104CB865BC07" italics="true" pageId="null" pageNumber="37">5</emphasis>
- 
<emphasis id="2A92F8AA73D5969DD50250326FB670B2" italics="true" pageId="null" pageNumber="37">7 mm langen Zipfeln.</emphasis>
Fruchtknoten und Frucht 
<normalizedToken id="5F39F3DC7D7F8EE0854CBA47DAF46A9D" originalValue="über" pageId="null" pageNumber="37">ueber</normalizedToken>
dem Kelch kaum gestielt (Stiel 
<normalizedToken id="E1A99690A498B586FBE314C835CB9BDD" originalValue="höchstens" pageId="null" pageNumber="37">hoechstens</normalizedToken>
1 mm lang). - 
<normalizedToken id="1E7522D0965279D901C8834F0FD167B3" originalValue="Blüte" pageId="null" pageNumber="37">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="6D63E2586AB1EE88E70E9AC1F29E7C50" pageId="null" pageNumber="37">
<emphasis id="B648C22DE442A3973023DEB0015A3C8E" italics="true" pageId="null" pageNumber="37">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E752B5FACB2D3CCBED695170EEDEB9BA" italics="true" pageId="null" pageNumber="37">36:</emphasis>
Material aus Island (D. 
<normalizedToken id="706B9E98385073C34174E65670B26DB5" originalValue="Löve" pageId="null" pageNumber="37">Loeve</normalizedToken>
1953).
</paragraph>
<paragraph id="0297B95EC271292A197853F70696DE0A" pageId="null" pageNumber="37">
<emphasis id="057EF02304AC64BD42AAFA53875F10BF" italics="true" pageId="null" pageNumber="37">Standort.</emphasis>
Montan und subalpin. Trockene, magere, kalkarme oder kalkreiche 
<normalizedToken id="9089BC0BE2ABA814D6A24F3F654F43FE" originalValue="Böden" pageId="null" pageNumber="37">Boeden</normalizedToken>
.
</paragraph>
<paragraph id="383EAF8E4453C45C700D89860538A9DF" pageId="null" pageNumber="37">
<emphasis id="ABC42645BFE37777B82A118CD50B01EF" italics="true" pageId="null" pageNumber="37">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
<normalizedToken id="F1B50B7ACECA713AA4F0946707A8CA38" originalValue="Südwärts" pageId="null" pageNumber="37">Suedwaerts</normalizedToken>
bis Nordfrankreich, 
<normalizedToken id="0EB12286B69805A92ED874C1FD0E69EC" originalValue="Thüringen" pageId="null" pageNumber="37">Thueringen</normalizedToken>
, 
<normalizedToken id="0356BE7144E2BD805C97BAF7674327F4" originalValue="Böhmen" pageId="null" pageNumber="37">Boehmen</normalizedToken>
, Karpaten, Alpen (wenige Fundorte); Kaukasus, aralokaspisches Gebiet, westliches Sibirien; Nordamerika (
<normalizedToken id="5A836063D9F42A59425D943F2D86F80B" originalValue="südwärts" pageId="null" pageNumber="37">suedwaerts</normalizedToken>
bis Neufundland und Kalifornien); 
<normalizedToken id="F41A46DD039DE03CF951E6D5E8B5291C" originalValue="Grönland" pageId="null" pageNumber="37">Groenland</normalizedToken>
. - Im Gebiet: Unterengadin, 
<normalizedToken id="53A391CD16943A80A3677F6D94F6C80C" originalValue="Münstertal" pageId="null" pageNumber="37">Muenstertal</normalizedToken>
, und Gebiet von Bormio, Val Camonica (Monte Stabio); nicht 
<normalizedToken id="7D8041DFCA189E2F46C7E276BDFC1A39" originalValue="häufig" pageId="null" pageNumber="37">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
