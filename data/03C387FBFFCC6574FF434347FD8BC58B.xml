<taxonomicName id="4C6A4D6EFFCC6574FE1645CAFDFBC5A9" authorityName="Published" authorityYear="2012" baseAuthorityName="Hampson" baseAuthorityYear="1906" box="[450,604,1197,1219]" class="Insecta" family="Crambidae" genus="Eoophyla" kingdom="Animalia" order="Lepidoptera" pageId="8" pageNumber="9" phylum="Arthropoda" rank="species" species="leucostrialis">
<emphasis id="B91EEAFFFFCC6574FE1645CAFDFBC5A9" box="[450,604,1197,1219]" italics="true" pageId="8" pageNumber="9">E. leucostrialis</emphasis>
</taxonomicName>
lack terminal eyespots of the hindwing and in 
<emphasis id="B91EEAFFFFCC6574FB9545CAFAF4C5A9" box="[1089,1363,1197,1219]" italics="true" pageId="8" pageNumber="9">
<taxonomicName id="4C6A4D6EFFCC6574FB9545CAFB6EC5A9" authorityName="Published" authorityYear="2012" baseAuthorityName="Hampson" baseAuthorityYear="1917" box="[1089,1225,1197,1219]" class="Insecta" family="Crambidae" genus="Eoophyla" kingdom="Animalia" order="Lepidoptera" pageId="8" pageNumber="9" phylum="Arthropoda" rank="species" species="leucostola">E. leucostola</taxonomicName>
, 
<taxonomicName id="4C6A4D6EFFCC6574FB0145CAFAF4C5A9" authorityName="Published" authorityYear="2012" baseAuthorityName="Hampson" baseAuthorityYear="1906" box="[1237,1363,1197,1219]" class="Insecta" family="Crambidae" genus="Eoophyla" kingdom="Animalia" order="Lepidoptera" pageId="8" pageNumber="9" phylum="Arthropoda" rank="species" species="nigerialis">E. nigerialis</taxonomicName>
</emphasis>
and 
<taxonomicName id="4C6A4D6EFFCC6574FA5245CAFEBDC588" authorityName="Published" authorityYear="2012" baseAuthorityName="Hampson" baseAuthorityYear="1917" class="Insecta" family="Crambidae" genus="Eoophyla" kingdom="Animalia" order="Lepidoptera" pageId="8" pageNumber="9" phylum="Arthropoda" rank="species" species="nyasalis">
<emphasis id="B91EEAFFFFCC6574FA5245CAFEBDC588" italics="true" pageId="8" pageNumber="9">E. nyasalis</emphasis>
</taxonomicName>
they can become obsolete.
