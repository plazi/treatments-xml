<bibRefCitation id="EFE24B620E7BFFDBFDB731DDFDC173A4" author="ULMER G" box="[464,591,723,745]" pageId="6" pageNumber="673" pagination="1 - 53" refId="ref7285" refString="ULMER G. (1907): Neue Trichopteren. - Not. Leyden Mus. 29: 1 - 53." type="journal article" year="1907">ULMER, 1907</bibRefCitation>
