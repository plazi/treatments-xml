(
<figureCitation id="15872A2EFFF4FF82A93E71C6FCB0FEBA" box="[789,843,248,270]" captionStart="Fig" captionStartId="4.[162,195,1033,1055]" captionTargetBox="[189,1213,155,1027]" captionTargetId="figure-387@4.[170,1216,155,1031]" captionTargetPageId="4" captionText="Fig. 2. Brachineura polessica, female, holotype (SIZK, N K–1236): 1 — general appearance; 2 — scape, pedicel, flagellomeres 1–2; 3 — flagellomeres 9–10; 4 — flagellomeres 6–7; 5 — flagellomeres 3–5; 6 — palpus; 7 — middle tarsomeres 3–5; 8 — middle tarsomeres 1–2; 9 — middle tarsomere 1; 10 — middle tarsomere 5; 11 — ovipositor laterally. Scale bars 0.1 mm." figureDoi="http://doi.org/10.5281/zenodo.6452795" httpUri="https://zenodo.org/record/6452795/files/figure.png" pageId="5" pageNumber="40">fig. 2</figureCitation>
, 
<emphasis id="BFC8EAB9FFF4FF82A97371C6FC7DFEB9" box="[856,902,248,269]" italics="true" pageId="5" pageNumber="40">
<figureCitation id="15872A2EFFF4FF82A97371C6FC99FEB9" box="[856,866,248,269]" captionStart="Fig" captionStartId="3.[169,202,1208,1230]" captionTargetBox="[394,1138,174,1180]" captionTargetId="figure-186@3.[389,1146,170,1197]" captionTargetPageId="3" captionText="Fig. 1. Rovnobrachineura kiryeyevi, male, holotype (SIZK, N K–3701): 1 — general appearance; 2 — scape, pedicel, flagellomeres 1–2; 3 — flagellomeres 8–10; 4 — flagellomeres 6–7; 5 — mouth parts and palpi; 6 — genitalia dorsally. Scale bars 0.1 mm." figureDoi="http://doi.org/10.5281/zenodo.6452793" httpUri="https://zenodo.org/record/6452793/files/figure.png" pageId="5" pageNumber="40">1</figureCitation>
–11
</emphasis>
; 7, 
<emphasis id="BFC8EAB9FFF4FF82A98471C6FC2FFEBA" box="[943,980,248,270]" italics="true" pageId="5" pageNumber="40">4, 5</emphasis>
