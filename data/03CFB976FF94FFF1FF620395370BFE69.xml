<geoCoordinate id="EE526EA7FF94FFF6FE8E005D32B2FDA0" box="[322,456,557,579]" degrees="30" direction="east" minutes="35" orientation="longitude" pageId="3" pageNumber="348" precision="1" seconds="58.5" value="30.599585">30°35´58.5˝ E</geoCoordinate>
