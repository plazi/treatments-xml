<geoCoordinate id="EE526EA7FF94FFF6FF62005D3242FDA0" box="[174,312,557,579]" degrees="50" direction="north" minutes="19" orientation="latitude" pageId="3" pageNumber="348" precision="1" seconds="53.3" value="50.33147">50°19´53.3˝ N</geoCoordinate>
