<subSubSection id="3B862E458C959A97347C3F87F013758A" pageId="0" pageNumber="201" type="notes">
<paragraph id="5E8707DD04C84D373F31C8D6DE8CE0B8" pageId="0" pageNumber="201">Notes.</paragraph>
<paragraph id="1C47CD2A4A0A36EE1C2A96FB7B6B14F5" pageId="0" pageNumber="201">
Both 
<bibRefCitation id="A72861EB1504659BA65E9C307F6FC479" author="Erlandsson, S" journalOrPublisher="Eos Madrid" pageId="0" pageNumber="201" pagination="11 - 93" refId="B6" refString="Erlandsson, S, 1972. Hymenoptera Aculeata from the European parts of the Mediterranean Countries. Eos Madrid 48: 11 - 93" title="Hymenoptera Aculeata from the European parts of the Mediterranean Countries." volume="48" year="1972">Erlandsson (1972)</bibRefCitation>
and 
<bibRefCitation id="CF8EC9C70A17A1269AE0B74190A3407D" author="Schembri, SP" journalOrPublisher="Bollettino della Societa' Entomologica Italiana" pageId="0" pageNumber="201" pagination="90 - 93" refId="B16" refString="Schembri, SP, 1980. Vespoidea from the Maltese Islands (Hymenoptera Aculeata). Bollettino della Societa' Entomologica Italiana 112 (4-6): 90 - 93" title="Vespoidea from the Maltese Islands (Hymenoptera Aculeata)." volume="112" year="1980">Schembri (1980)</bibRefCitation>
record the subspecies 
<taxonomicName id="A399B0C0E8BA736167F00FB24DF5E9B5" authorityName="Muller" authorityYear="1923" class="Insecta" family="Vespidae" genus="Eumenes" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Eumenes sareptanus subsp. insolatus" order="Hymenoptera" pageId="0" pageNumber="201" phylum="Arthropoda" rank="subSpecies" species="sareptanus" subSpecies="insolatus">
<emphasis id="6B9465634DA863DD87FECF3A97A885E8" italics="true" pageId="0" pageNumber="201">Eumenes sareptanus insolatus</emphasis>
</taxonomicName>
<normalizedToken id="3894BE6EFDC8A3F8BF22186F2FF81F2A" originalValue="Müller">Mueller</normalizedToken>
, 1923 from Malta, a taxon whose distribution includes much of Europe, from France east to Slovakia; the nominate subspecies differs from it by having reddish legs (
<bibRefCitation id="37B035F13FF27DBBC92150A193A2F87A" author="Gusenleitner, J" journalOrPublisher="Eos Madrid" pageId="0" pageNumber="201" refId="B13" refString="Gusenleitner, J, 1999. Bestimmungstabellen mittel- und suedeuropaeischer Eumeniden (Vespoidea, Hymenoptera) Teil 11. Die Gattungen Discoelius LATREILLE 1809, Eumenes LATREILLE 1802, Katamenes MEADE-WALDO 1910, Delta SAUSSURE 1855, Ischnogasteroides MAGRETTI 1884 und Pareumenes SAUSSURE 1855. Linzer Biologische Beitraege 31/2: 561-584." title="Bestimmungstabellen mittel- und suedeuropaeischer Eumeniden (Vespoidea, Hymenoptera) Teil 11. Die Gattungen Discoelius LATREILLE 1809, Eumenes LATREILLE 1802, Katamenes MEADE-WALDO 1910, Delta SAUSSURE 1855, Ischnogasteroides MAGRETTI 1884 und Pareumenes SAUSSURE 1855. Linzer Biologische Beitraege 31 / 2: 561 - 584." year="1999">Gusenleitner 1999</bibRefCitation>
).
</paragraph>
