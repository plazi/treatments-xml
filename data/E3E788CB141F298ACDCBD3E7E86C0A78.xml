<taxonomicName id="D6D6433F5332D6D1FBB9BB5C7B785632" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Helianthus" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="519" phylum="Tracheophyta" rank="species" species="giganteus">
<pageBreakToken id="6BF3BB2DAE10665886ECBC61394B08BA" pageId="null" pageNumber="519">Helianthus</pageBreakToken>
<normalizedToken id="E8110805737FC22AD326508C337FCDEA" originalValue="gigánteus" pageId="null" pageNumber="519">giganteus</normalizedToken>
<authorityName id="6CE55C660F4C7B8404935F2D64825CBA" pageId="null" pageNumber="519">L.</authorityName>
