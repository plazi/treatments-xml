<subSubSection id="7F26CD16616BF6F6F113B1CB157A2633" pageId="null" pageNumber="519" type="vernacular_names">
<paragraph id="3CFC7B9F28BB0A9E31B7BBE8FD82FE9D" pageId="null" pageNumber="519">Riesen-Sonnenblume</paragraph>
</subSubSection>
</title>
<subSubSection id="E541383942ECBC72A33353970B5019E3" pageId="null" pageNumber="519" type="description">
<paragraph id="9F9BFDA34C76E91419B505BAD9ECF8DF" pageId="null" pageNumber="519">
Rhizom kurz, 
<emphasis id="C8739BDDD0DD77DB540A86D58A434542" italics="true" pageId="null" pageNumber="519">mit verdickten Wurzeln;</emphasis>
Pflanze 1-3 m hoch. Stengel im untern Teil meist 
<emphasis id="7F5CE0CD48C0E50929031FC85CBDC241" italics="true" pageId="null" pageNumber="519">fast kahl, nicht rauh.</emphasis>
<normalizedToken id="D97390459867575A816EDBE6EF276846" originalValue="Blätter" pageId="null" pageNumber="519">Blaetter</normalizedToken>
fast ganzrandig bis wenig tief 
<normalizedToken id="E4AF87079ED22A65F030AC37748E7A45" originalValue="gezähnt" pageId="null" pageNumber="519">gezaehnt</normalizedToken>
(
<emphasis id="9C54769BAA7BD376A142A9D895EAE387" italics="true" pageId="null" pageNumber="519">
<normalizedToken id="09E2C23456494AE6E79D1FD0EBA874E9" originalValue="Zähne" pageId="null" pageNumber="519">Zaehne</normalizedToken>
<normalizedToken id="113126E8666BB00AE9660AC02976A902" originalValue="kürzer" pageId="null" pageNumber="519">kuerzer</normalizedToken>
als 1,5 mm
</emphasis>
), 
<emphasis id="D1AC03F6BA1FB23FC8DD4B4D26ED6EA4" italics="true" pageId="null" pageNumber="519">
die 
<normalizedToken id="19C649EE4C8B65BE2FD9DE32E8E3199B" originalValue="grö" pageId="null" pageNumber="519">groe</normalizedToken>
&amp;szligten kaum breiter als 4 cm, unterseits deutlich fiedernervig
</emphasis>
(
<emphasis id="252051DD8C3B8F2A52DB0B44B09701B4" italics="true" pageId="null" pageNumber="519">die untersten Seitennerven kaum mehr als die andern hervortretend</emphasis>
). 
<normalizedToken id="C1041FE805EA1D06580DA2E8DEFC8863" originalValue="Hüllblätter" pageId="null" pageNumber="519">Huellblaetter</normalizedToken>
abstehend bis 
<normalizedToken id="FE1ADEF37C977A8F8DA10FBD2BC7359B" originalValue="zurückgebogen" pageId="null" pageNumber="519">zurueckgebogen</normalizedToken>
, 
<emphasis id="C994B52E0E23A3A102743880491C5CA1" italics="true" pageId="null" pageNumber="519">1,5</emphasis>
- 
<emphasis id="231D6BB9F0F365A3E2E4EC648DEA41F6" italics="true" pageId="null" pageNumber="519">
3 mm breit. 
<normalizedToken id="2854C5B9AC3F05A1733DDA67AA5D0BA3" originalValue="Zungenförmige" pageId="null" pageNumber="519">Zungenfoermige</normalizedToken>
<normalizedToken id="D9A6CD7A6A269812A036E265BAF2DD84" originalValue="Blüten" pageId="null" pageNumber="519">Blueten</normalizedToken>
10
</emphasis>
- 
<emphasis id="4FC0D09027A5B2F3E548E4E448176350" italics="true" pageId="null" pageNumber="519">25, 1,5</emphasis>
- 
<emphasis id="13F73E0913FBC72AB7F814E9E161B285" italics="true" pageId="null" pageNumber="519">
2 cm lang. Scheibe mit den 
<normalizedToken id="71591C1A662D5A6DBE4935480CBCDE7D" originalValue="Röhrenblüten" pageId="null" pageNumber="519">Roehrenblueten</normalizedToken>
im Durchmesser etwa 2 cm. 
<normalizedToken id="DF4E54E64CA78F0BD5F5193B332ED148" originalValue="Röhrenblüten" pageId="null" pageNumber="519">Roehrenblueten</normalizedToken>
behaart.
</emphasis>
- 
<normalizedToken id="19F2AC496035E361592436430E01FC0A" originalValue="Blüte" pageId="null" pageNumber="519">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="1795CABC30CCD6D91CBB138BD8773A0F" pageId="null" pageNumber="519">
<emphasis id="CE036BBB17D92EB05B7FE95B335AD1BF" italics="true" pageId="null" pageNumber="519">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A5896852791AE8F420A1D1583908D72C" italics="true" pageId="null" pageNumber="519">34:</emphasis>
Material aus Nordamerika (Geisler aus Darlington und Wylie 1955, Heiser und Smith 1955, Jackson 1956, Long 1961).
</paragraph>
<paragraph id="8ADD08AD00358866CB7B7E8AB9D053ED" pageId="null" pageNumber="519">
<emphasis id="CC4CC1D2367E4836F5829280F9BC8067" italics="true" pageId="null" pageNumber="519">Standort.</emphasis>
Kollin. Feuchte, lockere, sandige 
<normalizedToken id="51E346DF01C1F2D45AB74AFB92270AD8" originalValue="Böden" pageId="null" pageNumber="519">Boeden</normalizedToken>
. F'lu&amp;szligufer, 
<normalizedToken id="4B749F7C39E38B2F643071F24AADE0A8" originalValue="Auenwaldränder" pageId="null" pageNumber="519">Auenwaldraender</normalizedToken>
, Kiesgruben. 
<emphasis id="22AAC75488BEB4369B6E2FF0D65A2EE2" italics="true" pageId="null" pageNumber="519">Impatienti-Solidaginetum</emphasis>
Moor 1958.
</paragraph>
<paragraph id="5A8934BD348CC66C9C979F02633356DF" pageId="null" pageNumber="519">
<emphasis id="091586FA4AB9CFD714DDC2C9D3666473" italics="true" pageId="null" pageNumber="519">Verbreitung. Nordamerikanische Pflanze;</emphasis>
in Europa als Zierpflanze 
<normalizedToken id="C2F986A5DE004EBAF996D86448C62B37" originalValue="eingeführt" pageId="null" pageNumber="519">eingefuehrt</normalizedToken>
. - Im Gebiet zerstreut, ziemlich selten.
</paragraph>
</subSubSection>
</treatment>
