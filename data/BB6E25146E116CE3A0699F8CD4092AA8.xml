<taxonomicName id="2DEF5B859728D2A7614EA0DF006E770A" authority="Duby" class="Magnoliopsida" family="Orobanchaceae" genus="Orobanche" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="257" phylum="Tracheophyta" rank="species" species="hederae">
