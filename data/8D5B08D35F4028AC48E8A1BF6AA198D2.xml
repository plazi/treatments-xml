<subSubSection id="C87D1697F789CADE7F4ECE1B018DA1FA" pageId="null" pageNumber="482" type="description">
<paragraph id="008D9F77904267264C8E64FE6771C82A" pageId="null" pageNumber="482">
<normalizedToken id="30E216CAA8DB4A47D051A5EEFE1482E2" originalValue="Sträucher" pageId="null" pageNumber="482">Straeucher</normalizedToken>
und 
<normalizedToken id="987D87CAA92EE194D7A27CF29E50E22D" originalValue="Bäume" pageId="null" pageNumber="482">Baeume</normalizedToken>
, 
<emphasis id="E12280D7ED9C2C5F071362F3FFFE347C" italics="true" pageId="null" pageNumber="482">
ohne Dornen. 
<normalizedToken id="DC730A324833411BE6A3ED446C633501" originalValue="Blätter" pageId="null" pageNumber="482">Blaetter</normalizedToken>
ungeteilt, ganzrandig.
</emphasis>
<normalizedToken id="8095A18EC9DE4F598DAE2C05D476EE8B" originalValue="Blüten" pageId="null" pageNumber="482">Blueten</normalizedToken>
⚥, in kurzen Trauben, 
<emphasis id="4136C618D387B810B0883B2D1098D18A" italics="true" pageId="null" pageNumber="482">aus dem Stamm und den Zweigen hervortreibend</emphasis>
, deutlich zygomorph. Kelch 
<normalizedToken id="D53FB2E2B47CD1EBB873603F689DFBFF" originalValue="glockenförmig" pageId="null" pageNumber="482">glockenfoermig</normalizedToken>
, kurz 5 
<normalizedToken id="947BFFCEC87C33851E088CE1C42BFA6E" originalValue="zähnig" pageId="null" pageNumber="482">zaehnig</normalizedToken>
. 
<normalizedToken id="DBF603561D2EE9C7755F24DE0CEE592E" originalValue="Kronblätter" pageId="null" pageNumber="482">Kronblaetter</normalizedToken>
5, die obern 3 kleiner als die untern 2. 
<normalizedToken id="52EEF9DD2402D4E37A7A745A5D103594" originalValue="Staubblätter" pageId="null" pageNumber="482">Staubblaetter</normalizedToken>
10.
</paragraph>
<paragraph id="7D84295FDAAB8290F3BC59318DF29EDF" pageId="null" pageNumber="482">
Die Gattung 
<taxonomicName id="C5A372B121B340856F7B40C69C2EFEEC" class="Magnoliopsida" family="Fabaceae" genus="Cercis" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="482" phylum="Tracheophyta" rank="genus">
<emphasis id="05B203A1ADE5CE5DB8F5C1C41F41F309" italics="true" pageId="null" pageNumber="482">Cercis</emphasis>
</taxonomicName>
<normalizedToken id="AC0827AA1E7A0A586034C797C474F575" originalValue="umfaßt" pageId="null" pageNumber="482">umfasst</normalizedToken>
etwa 
<emphasis id="C1518710475830B3D7A37B9B55E2F861" italics="true" pageId="null" pageNumber="482">7 Arten im Mediterrangebiet, in Asien und Nordamerika.</emphasis>
</paragraph>
