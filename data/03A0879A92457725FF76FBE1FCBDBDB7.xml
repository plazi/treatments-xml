; B, C: 
<emphasis id="B97DEA9E92467724FAA4F9C2FF29BA00" italics="true" pageId="22" pageNumber="175">Cardoso 1712</emphasis>
; D, F: 
<emphasis id="B97DEA9E92467724FF03F9E6FEFABA00" box="[253,363,1590,1611]" italics="true" pageId="22" pageNumber="175">Paixão 319</emphasis>
; E, I: 
<emphasis id="B97DEA9E92467724FE59F9E6FD85BA00" box="[423,532,1590,1611]" italics="true" pageId="22" pageNumber="175">Borges 728</emphasis>
; G: 
<emphasis id="B97DEA9E92467724FDC1F9E6FD55BA00" box="[575,708,1590,1611]" italics="true" pageId="22" pageNumber="175">Carvalho 820</emphasis>
