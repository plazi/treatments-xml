<taxonomicName id="4C5E5AAFFFE56838441E324CB85BF8ED" authorityName="Cartwright" authorityYear="2010" box="[323,544,1863,1889]" class="Insecta" family="Ecnomidae" genus="Wellsomina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trichoptera" pageId="16" pageNumber="299" phylum="Arthropoda" rank="species" species="gumurr">
