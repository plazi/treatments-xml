<subSubSection id="F28AAF21CD643DE532F2DAD97AA65831" pageId="null" pageNumber="190" type="description">
<paragraph id="BD85B850B735597BF48CB250DEAAE9D2" pageId="null" pageNumber="190">
<normalizedToken id="CEE3C99E768731C1E44CDF383BCEE24A" originalValue="Früchte" pageId="null" pageNumber="190">Fruechte</normalizedToken>
8-11 mm lang (mit Schnabel) und ⅓- 
<normalizedToken id="C2FF333009D2F5F319BA6DF7A752F6F4" originalValue="½" pageId="null" pageNumber="190">1/2</normalizedToken>
so dick wie lang, 
<emphasis id="12850CFFBB580F5D5F4485825696CCBD" italics="true" pageId="null" pageNumber="190">
wenig 
<normalizedToken id="BD44EB677DB70501578AD4B5665D667F" originalValue="über" pageId="null" pageNumber="190">ueber</normalizedToken>
der Mitte am dicksten, 
<normalizedToken id="63F19E22E881EDCC844D19605A3D40E9" originalValue="spindelförmig" pageId="null" pageNumber="190">spindelfoermig</normalizedToken>
</emphasis>
(Kanten undeutlich), 
<emphasis id="F63B23DC51590D4A012F2B52DE3244F0" italics="true" pageId="null" pageNumber="190">
ohne 
<normalizedToken id="9DD95EADD344030D3B753BD2BDCE0A2A" originalValue="Einschnürung" pageId="null" pageNumber="190">Einschnuerung</normalizedToken>
.
</emphasis>
</paragraph>
<paragraph id="3A85802BD33109410F5DC861558CFAA0" pageId="null" pageNumber="190">
<emphasis id="960B95F8B5F21B0F7AD915B4FC25C9E8" italics="true" pageId="null" pageNumber="190">Zytologische Angaben.</emphasis>
Siehe unter Artengruppe.
</paragraph>
<paragraph id="72C619DC09197FD084AFE6340307599A" pageId="null" pageNumber="190">
<emphasis id="BA56EAE15579243E0E4A8577F6419573" italics="true" pageId="null" pageNumber="190">Standort.</emphasis>
Kollin und montan. Seichte, im Sommer gelegentlich austrocknende 
<normalizedToken id="5D599F072F445F0A05CD3087B57E09B4" originalValue="Gräben" pageId="null" pageNumber="190">Graeben</normalizedToken>
mit schlammigem Grund und stehendem bis langsam 
<normalizedToken id="E85FAF79DCFD3A9BD52758EDD8F2F699" originalValue="fließendem" pageId="null" pageNumber="190">fliessendem</normalizedToken>
Quellwasser. 
<emphasis id="6D879B5C1BC021DCFA3C3EC096426BE9" italics="true" pageId="null" pageNumber="190">Glycerio-Sparganietum neglecti</emphasis>
W. Koch 1926.
</paragraph>
<paragraph id="2567BFA21C8DDA4A6B69E44502D78806" pageId="null" pageNumber="190">
<emphasis id="15284C85D39909C3CAEA6BDA22224DFC" italics="true" pageId="null" pageNumber="190">
Verbreitung. 
<normalizedToken id="1B0B738217E522B072ED8729A7B3A669" originalValue="Europäische" pageId="null" pageNumber="190">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="FDB7A2FBDE8175901366BCF6B647075A" originalValue="Nordwärts" pageId="null" pageNumber="190">Nordwaerts</normalizedToken>
bis England, 
<normalizedToken id="7DF666E8124D530FF1E0F0F82E10EF56" originalValue="Südschweden" pageId="null" pageNumber="190">Suedschweden</normalizedToken>
, 
<normalizedToken id="F5E05031261B9E1BDAD7C78B4DE8D846" originalValue="südwärts" pageId="null" pageNumber="190">suedwaerts</normalizedToken>
bis Nordafrika, 
<normalizedToken id="C383168F8483E9A87B723531843C86F5" originalValue="ostwärts" pageId="null" pageNumber="190">ostwaerts</normalizedToken>
bis in den Kaukasus (Cook 1961). - Im Gebiet ziemlich verbreitet, nicht 
<normalizedToken id="9883032C6DCD42132998C83A4DCBA444" originalValue="häufig" pageId="null" pageNumber="190">haeufig</normalizedToken>
.
</paragraph>
