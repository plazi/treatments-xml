<taxonomicName id="4C79DCC1FF89FF92F306FE8FECF5FEC5" authorityName="Mackauer" authorityYear="1967" box="[528,709,292,318]" class="Insecta" family="Braconidae" genus="Trioxys" kingdom="Animalia" order="Hymenoptera" pageId="12" pageNumber="399" phylum="Arthropoda" rank="species" species="curvicaudus">
