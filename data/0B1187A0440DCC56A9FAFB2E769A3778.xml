<paragraph id="830736B6440DCC56A9FAFADA713B34B7" blockId="7.[136,1452,1337,1579]" pageId="7" pageNumber="141">
<emphasis id="B1CCEAA4440DCC56A9FAFADA75CC3400" bold="true" box="[136,241,1337,1363]" pageId="7" pageNumber="141">Notes:—</emphasis>
<taxonomicName id="44B84D35440DCC56A982FADA77A53407" authority="Duque (2010: 145 - 146)" authorityName="Duque" authorityPageNumber="145 - 146" authorityYear="2010" box="[240,664,1337,1364]" class="Liliopsida" family="Orchidaceae" genus="Stelis" kingdom="Plantae" order="Asparagales" pageId="7" pageNumber="141" phylum="Tracheophyta" rank="species" species="profusa">
<emphasis id="B1CCEAA4440DCC56A982FADA74B43400" box="[240,393,1337,1363]" italics="true" pageId="7" pageNumber="141">Stelis profusa</emphasis>
<materialsCitation id="33D03CEB440DCC56A8FDFAD977A53407" box="[399,664,1337,1364]" collectionCode="JAUM" pageId="7" pageNumber="141" specimenCount="2" typeStatus="holotype">
<bibRefCitation id="E7294B47440DCC56A8FDFAD977A53407" author="Duque, O." box="[399,664,1337,1364]" pageId="7" pageNumber="141" pagination="119 - 166" refId="ref5912" refString="Duque, O. (2010) Nuevas especies colombianas del genero (Parte II). Orquideologia 27: 119 - 166." type="journal article" year="2010">Duque (2010: 145-146)</bibRefCitation>
</materialsCitation>
</taxonomicName>
was not validly published according to Art. 8.1 and Art. 8.2 as several specimens from locations and dates were cited. To complicate matters, 
<emphasis id="B1CCEAA4440DCC56AAB0FABD71723424" box="[962,1103,1373,1399]" italics="true" pageId="7" pageNumber="141">Duque 2324</emphasis>
was not found at 
<collectionCode id="E5A9AE73440DCC56AC54FABE70483424" box="[1318,1397,1373,1399]" country="Colombia" httpUri="http://biocol.org/urn:lsid:biocol.org:col:13382" lsid="urn:lsid:biocol.org:col:13382" name="Jardín Botánico Joaquín Antonio Uribe" pageId="7" pageNumber="141" type="Herbarium">JAUM</collectionCode>
, and instead we located several specimens that included parts of the original materials, localities, dates and collectors. We are certain that what was published was a mix of different elements. The name is here validated, and one of the specimens selected as 
<typeStatus id="5C038814440DCC56A8F1FA2A74D834B0" box="[387,485,1481,1507]" pageId="7" pageNumber="141">holotype</typeStatus>
(
<figureCitation id="1B832A33440DCC56A887FA2A777834B7" box="[501,581,1481,1508]" captionStart="FIGURE 5" captionStartId="8.[136,229,1143,1165]" captionTargetBox="[151,1436,190,1119]" captionTargetId="figure-19@8.[151,1436,190,1119]" captionTargetPageId="8" captionText="FIGURE 5. Type of Stelis profusa at JAUM. Holotype: Duque &amp; Alzate 2325 (A) and a paratype Duque &amp; Peláez 2328 (B), reproduced with the kind permission of the herbarium." figureDoi="http://doi.org/10.5281/zenodo.5423638" httpUri="https://zenodo.org/record/5423638/files/figure.png" pageId="7" pageNumber="141">Fig. 5a</figureCitation>
), making the others 
<typeStatus id="5C038814440DCC56AA58FA2976A834B7" box="[810,917,1482,1508]" pageId="7" pageNumber="141">paratypes</typeStatus>
(
<figureCitation id="1B832A33440DCC56AAD7FA2A76C434B7" box="[933,1017,1481,1508]" captionStart="FIGURE 5" captionStartId="8.[136,229,1143,1165]" captionTargetBox="[151,1436,190,1119]" captionTargetId="figure-19@8.[151,1436,190,1119]" captionTargetPageId="8" captionText="FIGURE 5. Type of Stelis profusa at JAUM. Holotype: Duque &amp; Alzate 2325 (A) and a paratype Duque &amp; Peláez 2328 (B), reproduced with the kind permission of the herbarium." figureDoi="http://doi.org/10.5281/zenodo.5423638" httpUri="https://zenodo.org/record/5423638/files/figure.png" pageId="7" pageNumber="141">Fig. 5b</figureCitation>
).
</paragraph>
</subSubSection>
