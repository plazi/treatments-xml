<collectingCountry id="F333D7CA7549D70D860CFD4A51FFFD7F" box="[790,897,677,706]" name="Zambia" pageId="6" pageNumber="386">Zambia</collectingCountry>
, 
<collectingCountry id="F333D7CA7549D70D8687FD4A567EFD7F" box="[925,1024,677,706]" name="Malawi" pageId="6" pageNumber="386">Malawi</collectingCountry>
, 
<collectingCountry id="F333D7CA7549D70D8106FD4A56D0FD7F" box="[1052,1198,677,706]" name="Zimbabwe" pageId="6" pageNumber="386">Zimbabwe</collectingCountry>
, C 
<collectingCountry id="F333D7CA7549D70D81EFFD4A5118FD54" name="Mozambique" pageId="6" pageNumber="386">Mozambique</collectingCountry>
, and extreme NE region of 
<collectingCountry id="F333D7CA7549D70D800BFD275117FCAC" name="South Africa" pageId="6" pageNumber="386">South Africa</collectingCountry>
(
<collectingRegion id="49E059B87549D70D869AFD1F5674FCAC" box="[896,1034,752,785]" country="South Africa" name="Limpopo" pageId="6" pageNumber="386">Limpopo</collectingRegion>
