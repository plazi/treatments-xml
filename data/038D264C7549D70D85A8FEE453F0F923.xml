<subSubSection id="C33EC4D17549D70D860FFD975669FCAC" pageId="6" pageNumber="386" type="distribution">
<caption id="DF5BC7D27549D70D860FFD975669FCAC" ID-DOI="http://doi.org/10.5281/zenodo.6576974" ID-Zenodo-Dep="6576974" httpUri="https://zenodo.org/record/6576974/files/figure.png" inLine="true" pageId="6" pageNumber="386" targetBox="[173,766,446,861]" targetPageId="6">
<paragraph id="8B9B975A7549D70D860FFD975669FCAC" blockId="6.[788,1381,441,864]" pageId="6" pageNumber="386">
<emphasis id="B9504B487549D70D860FFD9751BBFD24" bold="true" box="[789,965,632,665]" pageId="6" pageNumber="386">Distribution.</emphasis>
