<bibRefCitation id="37534B57FFFFFFE1E08200CDFDE2FF72" author="Rebel, H." box="[440,577,151,177]" pageId="7" pageNumber="32" pagination="243 - 282" refId="ref10458" refString="Rebel, H. (1917) Eine Lepidopterenausbeute aus dem Amanusgebirge (Alman Dagh). Sitzungsberichte der Kaiserlichen Akademie der Wissenschaften Mathematisch-Naturwissenschaftliche Wien, 126, 243 - 282." type="journal article" year="1917">Rebel, 1917</bibRefCitation>
