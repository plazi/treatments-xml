<emphasis id="B936EAC786086B2EFBFB857AFE3EF6F8" italics="true" pageId="26" pageNumber="89">Eucochlis depressa</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A20557BC86086B2EFE148548FDB2F6F8" box="[460,552,2364,2403]" pageId="26" pageNumber="89" rank="species">n.sp.</taxonomicNameLabel>
, from Swains Gully;' 
<taxonomicName id="4C424D5686086B2EFBC68548FE56F60B" authority="Yoo, 1994" authorityName="Yoo" authorityYear="1994" class="Gastropoda" family="Eucochlidae" genus="Eucochlis" higherTaxonomySource="GBIF" kingdom="Animalia" order="Vetigastropoda" pageId="26" pageNumber="89" phylum="Mollusca" rank="species" species="umbiliparva" status="n.sp.">
<emphasis id="B936EAC786086B2EFBC68548FE56F60B" italics="true" pageId="26" pageNumber="89">Eucochlis umbiliparva</emphasis>
</taxonomicName>
