<bibRefCitation id="EFD34B2486086B2EFE1D857AFD06F6AF" author="Yoo, E. K." box="[453,668,2318,2356]" pageId="26" pageNumber="89" pagination="233 - 264" refId="ref27552" refString="Yoo, E. K., 1988. Early Carboniferous Mollusca from Gundy, Upper Hunter, New South Wales. Records of the Australian Museum 40 (4): 233 - 264." type="journal article" year="1988">Yoo, 1988</bibRefCitation>
