, from Swains Gully; 
<taxonomicName id="4C424D5686086B2EFC05851DFB19F60B" authorityName="Knight" authorityYear="1933" box="[989,1155,2409,2448]" class="Gastropoda" family="Eucochlidae" genus="Eucochlis" higherTaxonomySource="GBIF" kingdom="Animalia" order="Vetigastropoda" pageId="26" pageNumber="89" phylum="Mollusca" rank="genus">
