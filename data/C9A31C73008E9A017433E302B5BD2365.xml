<subSubSection id="E5250F83105489D8C6274E5CA19FAF22" pageId="null" pageNumber="79" type="description">
<paragraph id="A6E7FEE62C9241235D78B47441D200B2" pageId="null" pageNumber="79">
Ausdauernd; 50-150 cm hoch, reich verzweigt, behaart oder kahl; 
<emphasis id="11DE2CA5E01BBECF095D8B930B718E0D" italics="true" pageId="null" pageNumber="79">
bis 1 m lange, hohle, unterirdische 
<normalizedToken id="787C6BE488643E8CCCF7063CB672DF7A" originalValue="Ausläufer" pageId="null" pageNumber="79">Auslaeufer</normalizedToken>
treibend. 
<normalizedToken id="5B25949FF138BAC95E9DEC0B69DB5352" originalValue="Grundständige" pageId="null" pageNumber="79">Grundstaendige</normalizedToken>
und 
<normalizedToken id="F76CFBA24E20EE96DB0EC310224FBA9E" originalValue="Stengelblätter" pageId="null" pageNumber="79">Stengelblaetter</normalizedToken>
gleich gestaltet: bis etwa 25 cm lang und 1,5 cm breit, lanzettlich, 
<normalizedToken id="260D53E0136889CB5FB5695471CBCA64" originalValue="allmählich" pageId="null" pageNumber="79">allmaehlich</normalizedToken>
in den Stiel 
<normalizedToken id="D01A0A5D863AF267B0FFDFD42DAC39C7" originalValue="verschmälert" pageId="null" pageNumber="79">verschmaelert</normalizedToken>
</emphasis>
, ganzrandig oder entfernt 
<normalizedToken id="26F36FF7908A9A60E91B2E696966953F" originalValue="gezähnt" pageId="null" pageNumber="79">gezaehnt</normalizedToken>
. An schwimmenden Sprossen 
<normalizedToken id="D6064EBE82D7E54BAAA1F668CD74C781" originalValue="Blätter" pageId="null" pageNumber="79">Blaetter</normalizedToken>
oval; bei 
<normalizedToken id="987BDABBF2E8D59979F57FF7F36418ED" originalValue="nichtblühenden" pageId="null" pageNumber="79">nichtbluehenden</normalizedToken>
Pflanzen 
<normalizedToken id="F8284847D40B3D55AF65CC5BF120EE87" originalValue="grundständige" pageId="null" pageNumber="79">grundstaendige</normalizedToken>
<normalizedToken id="7E91B44F3A99FA94EB597DC3A6BBE1DB" originalValue="Blätter" pageId="null" pageNumber="79">Blaetter</normalizedToken>
oval, am Grunde 
<normalizedToken id="4BC57532F99EDC0B150F3348B371E356" originalValue="herzförmig" pageId="null" pageNumber="79">herzfoermig</normalizedToken>
. 
<normalizedToken id="DA535D0F6EFC2683B3BE4E352FA5F8E7" originalValue="Blüten" pageId="null" pageNumber="79">Blueten</normalizedToken>
gelb, im 
<emphasis id="B2B7F0AC5F6F580EE11FF3CD6AFCD300" italics="true" pageId="null" pageNumber="79">Durchmesser 3-4 cm</emphasis>
(
<normalizedToken id="F3F0185CB93AB23D2BA4850CF6F5E23A" originalValue="größte" pageId="null" pageNumber="79">groesste</normalizedToken>
aller 
<taxonomicName id="E2265A76716948C87DF5B4373789D045" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="79" phylum="Tracheophyta" rank="genus">
<emphasis id="1F83415374ECCE4D886CD62D8CC23EDF" italics="true" pageId="null" pageNumber="79">Ranunculus</emphasis>
</taxonomicName>
<normalizedToken id="CEBB28E8D4071D2638A50BC0E94B77F1" originalValue="blüten" pageId="null" pageNumber="79">blueten</normalizedToken>
unserer Flora). 
<normalizedToken id="A1D75260E3C486868268659D53684A24" originalValue="Früchtchen" pageId="null" pageNumber="79">Fruechtchen</normalizedToken>
oval, 2,5-3 mm lang, 1,9-2,2 mm breit, berandet, nervenlos, kahl; Schnabel etwa 0,5 mm lang, dick, an der Spitze hakig gebogen. 
<normalizedToken id="C341C65E0E7346481C7B337C5EE5A578" originalValue="Blütenboden" pageId="null" pageNumber="79">Bluetenboden</normalizedToken>
kahl. - 
<normalizedToken id="9A2840BE715C1623DB1D45A027D7ABBB" originalValue="Blüte" pageId="null" pageNumber="79">Bluete</normalizedToken>
: 
<normalizedToken id="A6BB1B043336BF43013F05E9B74BD0E0" originalValue="Früher" pageId="null" pageNumber="79">Frueher</normalizedToken>
Sommer bis Herbst.
</paragraph>
<paragraph id="15D0ECD1B408B55E38BAF3F6043D57A2" pageId="null" pageNumber="79">
<emphasis id="36F2640554793ADBE11C3E1DF470EEE7" italics="true" pageId="null" pageNumber="79">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B2F2A86C97C849930BC0E73DD9FF74CE" italics="true" pageId="null" pageNumber="79">56, 64:</emphasis>
Material aus botanischen 
<normalizedToken id="3C747920D0E0804BCB4D27A0EBCBEC6E" originalValue="Gärten" pageId="null" pageNumber="79">Gaerten</normalizedToken>
(Larter 1932). 
<emphasis id="771013F7604BA0E973E17D80200B8397" italics="true" pageId="null" pageNumber="79">2n</emphasis>
= 
<emphasis id="FD04E1A5C5F4C00A086F2FE4A1B21E2D" italics="true" pageId="null" pageNumber="79">109-111:</emphasis>
Material aus Polen (Pogan 1966). 
<emphasis id="BE96D37B6EFF22775917DCDCD2743CEC" italics="true" pageId="null" pageNumber="79">2n</emphasis>
= 
<emphasis id="718859CF3522E99845920A616C843DA6" italics="true" pageId="null" pageNumber="79">128:</emphasis>
Material aus botanischen 
<normalizedToken id="6A60DC90FA421BF52DE39753E071E34C" originalValue="Gärten" pageId="null" pageNumber="79">Gaerten</normalizedToken>
(Langlet 1932), Pollenmeiose normal (
<normalizedToken id="045BA984A8514B4DDAF4585D7CACCC5C" originalValue="Böcher" pageId="null" pageNumber="79">Boecher</normalizedToken>
1938a); aus 
<normalizedToken id="B02F5E31229B15EB0FCB22C045A1FE7B" originalValue="Rußland" pageId="null" pageNumber="79">Russland</normalizedToken>
(Sokolovskaya aus 
<normalizedToken id="DD25ED7C6309052C837C054BA672F653" originalValue="Löve" pageId="null" pageNumber="79">Loeve</normalizedToken>
und 
<normalizedToken id="330D8372130CD7693B0A75F14BAFBB06" originalValue="Löve" pageId="null" pageNumber="79">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="FF19B3CB6D2D17BA19DCC8DC8AAB4CCC" pageId="null" pageNumber="79">
<pageBreakToken id="48B0921C197B023E066F5BDFB1436682" pageId="null" pageNumber="79">Teiche</pageBreakToken>
, 
<normalizedToken id="BEB18CCB044F17DD30717FA67B2FF24E" originalValue="Gräben" pageId="null" pageNumber="79">Graeben</normalizedToken>
, oft zusammen mit 
<emphasis id="90CA262CE42870B9DC744E0FB345C196" italics="true" pageId="null" pageNumber="79">
<taxonomicName id="53D2F16F408ED0B898D34B7DB82C10ED" class="Liliopsida" family="Typhaceae" genus="Typha" kingdom="Plantae" order="Poales" pageId="null" pageNumber="79" phylum="Tracheophyta" rank="species" species="angustifolia">Typha angustifolia</taxonomicName>
. Scirpo-Phragmitetum
</emphasis>
W. Koch 1926 (vgl. auch 
<normalizedToken id="434A8B36513EBDE5E68AE71B357D20C1" originalValue="Tüxen" pageId="null" pageNumber="79">Tuexen</normalizedToken>
1954).
</paragraph>
<paragraph id="8D739FFAFA155C8E3017AC63E34CB3D5" pageId="null" pageNumber="79">
<emphasis id="DA9E74AA7D74A1565F973E53878394EB" italics="true" pageId="null" pageNumber="79">Verbreitung. Eurasiatische Pflanze:</emphasis>
Fast ganz Europa (isolierte Fundstellen bis 67° NB in Skandinavien, fehlt auf Island, im Mittelmeergebiet vereinzelt), in Asien zwischen 40 und 60° NB 
<normalizedToken id="EBACD0133C1E7DAF84CB0327C5AC5D1C" originalValue="ostwärts" pageId="null" pageNumber="79">ostwaerts</normalizedToken>
bis ins Gebiet des Jenissei; isoliert im Westhimalaja. Verbreitungskarten von Meusel (1960 Westhimalaja. Verbreitungskarten von Meusel (1965). - Im Gebiet: Zerstreut, ziemlich selten und der Meliorationen wegen im 
<normalizedToken id="FED79603FEBF076CC2A7BD8D82FA94BB" originalValue="Rückgang" pageId="null" pageNumber="79">Rueckgang</normalizedToken>
.
</paragraph>
</subSubSection>
