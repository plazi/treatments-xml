<subSubSection id="0902AA4A7BF3D890E5C3740EA3B1F49E" pageId="null" pageNumber="701" type="description">
<paragraph id="ADCB95075A16B09D74BBB8B0D4E6D222" pageId="null" pageNumber="701">
<normalizedToken id="16B5D3BEF153512EEBCFBFCE92663DA9" originalValue="Bäume" pageId="null" pageNumber="701">Baeume</normalizedToken>
oder 
<normalizedToken id="F25E0130123F9CA897586BEA08798F41" originalValue="Sträucher" pageId="null" pageNumber="701">Straeucher</normalizedToken>
, 
<normalizedToken id="DFD24E2B7F1158A37BF395CD0E723B99" originalValue="sommergrün" pageId="null" pageNumber="701">sommergruen</normalizedToken>
oder 
<normalizedToken id="DD991694B6AA15C962DF8DD7301C0876" originalValue="immergrün" pageId="null" pageNumber="701">immergruen</normalizedToken>
. 
<emphasis id="C9BB484BB6AA17CEB598D64170A42B09" italics="true" pageId="null" pageNumber="701">
<normalizedToken id="04F413A9CBC93D45F35DEA50D7E35909" originalValue="Blätter" pageId="null" pageNumber="701">Blaetter</normalizedToken>
vom Grunde aus mit 3 
<normalizedToken id="A679B7E074F76B275ABEA4CC5C1C5DA6" originalValue="Längsnerven" pageId="null" pageNumber="701">Laengsnerven</normalizedToken>
</emphasis>
, mit 
<normalizedToken id="30FB9F7DB2EFCC5DD86E1E212388139D" originalValue="gezähntem" pageId="null" pageNumber="701">gezaehntem</normalizedToken>
Rand, 
<emphasis id="64D06BCADB4049A66BF3A9116A4BBE00" italics="true" pageId="null" pageNumber="701">am Grunde asymmetrisch</emphasis>
, gestielt; 
<normalizedToken id="9E76FFDD2B0AFA98F9EBEAD292AD998D" originalValue="Nebenblätter" pageId="null" pageNumber="701">Nebenblaetter</normalizedToken>
<normalizedToken id="2BC51684E2D8F4B0F301E9F706B5289D" originalValue="früh" pageId="null" pageNumber="701">frueh</normalizedToken>
abfallend. 
<emphasis id="25917068AA6AC9934DD155989B722BFD" italics="true" pageId="null" pageNumber="701">
Auf derselben Pflanze rein ♂ 
<normalizedToken id="A698320958503A09114C3483179C7350" originalValue="Blüten" pageId="null" pageNumber="701">Blueten</normalizedToken>
und zwittrige 
<normalizedToken id="ABEB9B7FFEA21F4F145FA26A5860AFB5" originalValue="Blüten" pageId="null" pageNumber="701">Blueten</normalizedToken>
vorhanden, alle an den 
<normalizedToken id="8637DE134B4350C1A6EB3F66506E3BDA" originalValue="diesjährigen" pageId="null" pageNumber="701">diesjaehrigen</normalizedToken>
Trieben. Rein ♂ 
<normalizedToken id="86A4761DDF7558078F5E7C39C6A95CC0" originalValue="Blüten" pageId="null" pageNumber="701">Blueten</normalizedToken>
in den untern Teilen der Triebe in 
<normalizedToken id="7D1F19C83FAB1A33276AFC254B10D6C7" originalValue="wenigblütigen" pageId="null" pageNumber="701">wenigbluetigen</normalizedToken>
, traubenartigen 
<normalizedToken id="B156FF9361DF388E69ABDB4B51BAD2D1" originalValue="Blütenständen" pageId="null" pageNumber="701">Bluetenstaenden</normalizedToken>
;
</emphasis>
<normalizedToken id="3AB2F9C6ADDACFFC714BC6E3C4FDF793" originalValue="Perigonblätter" pageId="null" pageNumber="701">Perigonblaetter</normalizedToken>
4-8, fast frei, 
<normalizedToken id="FF0DA62578316A2843E57ABCA9224B64" originalValue="häutig" pageId="null" pageNumber="701">haeutig</normalizedToken>
, unscheinbar; 
<normalizedToken id="2B06BB969DF467FABD3465D89D33EB15" originalValue="Staubblätter" pageId="null" pageNumber="701">Staubblaetter</normalizedToken>
so viele wie 
<normalizedToken id="AA235190EC38E8ED1B5EEE201DCCE2B0" originalValue="Perigonblätter" pageId="null" pageNumber="701">Perigonblaetter</normalizedToken>
; 
<normalizedToken id="0020D77D6C0E3754F9D609666FFA7D28" originalValue="rudimentäre" pageId="null" pageNumber="701">rudimentaere</normalizedToken>
♀ 
<normalizedToken id="E822546D80860DAD8037A84F0390304E" originalValue="Blütenteile" pageId="null" pageNumber="701">Bluetenteile</normalizedToken>
meist vorhanden. 
<emphasis id="49AC71B901D79D7C2982BDD0ED7DE29D" italics="true" pageId="null" pageNumber="701">
Zwittrige 
<normalizedToken id="668CC58125C41C5DCFB0844ED412A8B1" originalValue="Blüten" pageId="null" pageNumber="701">Blueten</normalizedToken>
in den 
<normalizedToken id="A01FCC1C12D8C0419677FF9D48354073" originalValue="äuβersten" pageId="null" pageNumber="701">aeuβersten</normalizedToken>
Teilen der Triebe, einzeln auf langen Stielen in Blattachseln;
</emphasis>
<normalizedToken id="D59E01E7711C8003E7B3A1600FFC805A" originalValue="Perigonblätter" pageId="null" pageNumber="701">Perigonblaetter</normalizedToken>
und 
<normalizedToken id="2858990C2849A1D6F2E26394582CA948" originalValue="Staubblätter" pageId="null" pageNumber="701">Staubblaetter</normalizedToken>
wie bei den ♂ 
<normalizedToken id="E6075928C0B71D26088BA3391B8A09D4" originalValue="Blüten" pageId="null" pageNumber="701">Blueten</normalizedToken>
, jedoch oft in verschiedener Zahl. Fruchtknoten 1 
<normalizedToken id="74AB50ED897519F0B99383695011AA1E" originalValue="fächerig" pageId="null" pageNumber="701">faecherig</normalizedToken>
, mit 1 Samenanlage, mit kurzem Griffel und 
<emphasis id="5E8E242DBB5063C4D9D2A7589365C771" italics="true" pageId="null" pageNumber="701">
2 
<normalizedToken id="0865EAE24DBB7AD36464A0022120BF54" originalValue="groβen" pageId="null" pageNumber="701">groβen</normalizedToken>
, 
<normalizedToken id="2EB0C81F17D909CEC7948082D6D6A9CD" originalValue="zurückgebogenen" pageId="null" pageNumber="701">zurueckgebogenen</normalizedToken>
, dicht behaarten Narben. Frucht mit Steinkern und fleischiger 
<normalizedToken id="02C59A04251BEB774D56AA65EAE04AF2" originalValue="Hülle" pageId="null" pageNumber="701">Huelle</normalizedToken>
</emphasis>
(
<emphasis id="A3346622DA3597242CA80962C4523416" italics="true" pageId="null" pageNumber="701">Exokarp</emphasis>
) (bei einigen Arten 
<normalizedToken id="B6676FE9A45ABF9F4F62A44F13B3E52A" originalValue="eßbar" pageId="null" pageNumber="701">essbar</normalizedToken>
).
</paragraph>
<paragraph id="21AF38FC72052C14FF369F4DE54E7F15" pageId="null" pageNumber="701">
Die Gattung 
<taxonomicName id="322205A021BA57047BFC8964E73A202A" class="Magnoliopsida" family="Cannabaceae" genus="Celtis" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="701" phylum="Tracheophyta" rank="genus">
<emphasis id="0FFBE196688A2B66F4791629867253FC" italics="true" pageId="null" pageNumber="701">Celtis</emphasis>
</taxonomicName>
<normalizedToken id="005B8C096F454C777A4C320DD792182C" originalValue="umfaßt" pageId="null" pageNumber="701">umfasst</normalizedToken>
etwa 
<emphasis id="CCA723708A9DB0DD50AEB67D791CD7FC" italics="true" pageId="null" pageNumber="701">70 Arten und hat weltweite Verbreitung</emphasis>
(ausgenommen kalte Zonen).
</paragraph>
</subSubSection>
