<taxonomicName id="4C79DCC1FF8FFF94F214FDFEEDC6FD95" box="[770,1014,596,622]" class="Insecta" family="Carabidae" genus="Batrachium" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="10" pageNumber="397" phylum="Arthropoda" rank="species" species="aquatile">
