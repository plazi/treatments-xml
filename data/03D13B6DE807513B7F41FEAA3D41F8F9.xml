<collectingCountry id="F36FCAEBE807513B7F66F8D33E29F8F9" box="[304,360,1799,1822]" name="Laos" pageId="7" pageNumber="42">Laos</collectingCountry>
: 
<collectingRegion id="49BC4499E807513B7F24F8D33EBDF8F9" box="[370,508,1799,1822]" country="Laos" name="Bolikhamxai" pageId="7" pageNumber="42">Bolikhamsai</collectingRegion>
