<emphasis id="B93BEA967472655FFC59FEFEA30631E5" italics="true" pageId="4" pageNumber="745">Leucoptera coffeella</emphasis>
GUÉRIN- MENEVILLE, (
<taxonomicName id="4C4F4D077472655FFE62FE1AA07E31EA" authorityName="Linnaeus" authorityYear="1758" box="[497,625,402,424]" class="Insecta" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="745" phylum="Arthropoda" rank="order">Lepidoptera</taxonomicName>
: 
<taxonomicName id="4C4F4D077472655FFDE8FE1AA0F931EA" authorityName="Stainton" authorityYear="1854" box="[635,758,402,424]" class="Insecta" family="Lyonetiidae" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="745" phylum="Arthropoda" rank="family">Lyonetiidae</taxonomicName>
) (
<bibRefCitation id="EFDE4B757472655FFC99FE1BA60F31EB" author="YEFREMOVA Z" box="[778,1024,402,425]" pageId="4" pageNumber="745" pagination="197 - 199" refId="ref4314" refString="YEFREMOVA Z. A. &amp; E. N. YEGORENKOVA (2009): A review of the subfamily Tetrastichinae (Hymenoptera: Eulophidae) in Yemen, with descriptions of new species. - Fauna of Arabia 24: 197 - 199." type="journal article" year="2009">YEFREMOVA et al. 2009</bibRefCitation>
