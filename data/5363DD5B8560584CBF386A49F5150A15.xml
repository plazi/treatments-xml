<taxonomicName id="CF15DDE271347FE4F98FA74CC6F34D0A" authority="Tsuneki, 1991" authorityName="Tsuneki" authorityYear="1991" class="Insecta" family="Trigonalyidae" genus="Jezonogonalos" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Jezonogonalos" order="Hymenoptera" pageId="0" pageNumber="101" phylum="Arthropoda" rank="genus">Jezonogonalos</taxonomicName>
Tsuneki, 1991: 32, 2003: 4; 
<bibRefCitation id="29302B114E491D7287E778168C31AEB9" DOI="https://doi.org/10.1046/j.1365-3113.1998.00042.x" author="Carmean, D" journalOrPublisher="Systematic Entomology" pageId="0" pageNumber="101" pagination="35 - 76" refId="B2" refString="Carmean, D, Kimsey, L, 1998. Phylogenetic revision of the parasitoid wasp family Trigonalidae (Hymenoptera). Systematic Entomology 23: 35 - 76, DOI: https://doi.org/10.1046/j.1365-3113.1998.00042.x" title="Phylogenetic revision of the parasitoid wasp family Trigonalidae (Hymenoptera)." url="https://doi.org/10.1046/j.1365-3113.1998.00042.x" volume="23" year="1998">Carmean and Kimsey 1998</bibRefCitation>
: 70; 
<bibRefCitation id="1ADA46188E59A3F218B3A71BAEDDF8DA" DOI="https://doi.org/10.3897/zookeys.385.6560" author="Chen, H-Y" journalOrPublisher="ZooKeys" pageId="0" pageNumber="101" pagination="1 - 207" refId="B6" refString="Chen, H-Y, van Achterberg, C, He, J-H, Xu, Z-F, 2014. A revision of the Chinese Trigonalyidae (Hymenoptera, Trigonalyoidea). ZooKeys 385: 1 - 207, DOI: https://doi.org/10.3897/zookeys.385.6560" title="A revision of the Chinese Trigonalyidae (Hymenoptera, Trigonalyoidea)." url="https://doi.org/10.3897/zookeys.385.6560" volume="385" year="2014">Chen et al. 2014</bibRefCitation>
