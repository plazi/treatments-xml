<subSubSection id="FBEA77F1AB391F8D759B5F896190D26D" pageId="null" pageNumber="906" type="description">
<paragraph id="F48A2A477874A18C7B8D9C740F8131C6" pageId="null" pageNumber="906">
Zweige kriechend, bis 1 mm dick und bis 1 in lang; 
<emphasis id="CC562FC658874996AB2019C1347D38FD" italics="true" pageId="null" pageNumber="906">Triebspitzen bogig aufsteigend.</emphasis>
<normalizedToken id="8563358AD027BD95F2BCEF7292430D8F" originalValue="Blätter" pageId="null" pageNumber="906">Blaetter</normalizedToken>
<normalizedToken id="446083F9A101EB52FB86A58B7A8EF4DA" originalValue="wechselständig" pageId="null" pageNumber="906">wechselstaendig</normalizedToken>
, 
<normalizedToken id="857A659321EC723C73DEEDAA57245DCA" originalValue="immergrün" pageId="null" pageNumber="906">immergruen</normalizedToken>
, lederig, 
<emphasis id="B3ECAE072DC42AF820238DE71F5F5F04" italics="true" pageId="null" pageNumber="906">
oval, mit der 
<normalizedToken id="7736EB39CEF2942E0946BED006E53626" originalValue="größten" pageId="null" pageNumber="906">groessten</normalizedToken>
Breite in der Mitte, 0,8-1,5 cm lang
</emphasis>
, 2- 
<normalizedToken id="BC1F9C11D2DFA847C7EFF47CCA5594E0" originalValue="2½" pageId="null" pageNumber="906">21/2</normalizedToken>
mal so 
<pageBreakToken id="5AE0A33FDDC4A40E3A4448EF00049108" pageId="null" pageNumber="906">lang</pageBreakToken>
wie breit, ganzrandig, 
<emphasis id="3F3B0E496C949264E99F8464BC34DCEA" italics="true" pageId="null" pageNumber="906">
Rand verdickt und 
<normalizedToken id="225233926FFA057B04B50E27A94E857A" originalValue="überall" pageId="null" pageNumber="906">ueberall</normalizedToken>
<normalizedToken id="396E1C39D0AA424819FCE7176DFED424" originalValue="gleichmäßig" pageId="null" pageNumber="906">gleichmaessig</normalizedToken>
und wenig nach unten umgebogen
</emphasis>
, oberseits 
<normalizedToken id="B82728E43A73471FAD582D06DC511A61" originalValue="dunkelgrün" pageId="null" pageNumber="906">dunkelgruen</normalizedToken>
, unterseits 
<normalizedToken id="A78EE2F400DB82AD5B628C7AEE271D51" originalValue="graugrün" pageId="null" pageNumber="906">graugruen</normalizedToken>
. Blattstiel ca. 1 nun lang. 
<normalizedToken id="5F4CF5A9CD30C4BD7BC57492049A8FF8" originalValue="Blütenstiele" pageId="null" pageNumber="906">Bluetenstiele</normalizedToken>
zu 1-10 am Ende der Zweige, aufrecht, 1-3 cm lang, 
<normalizedToken id="E0D35D280B52EE7F1B83D71639278AEC" originalValue="fadenförmig" pageId="null" pageNumber="906">fadenfoermig</normalizedToken>
, rot, flaumig behaart; 
<normalizedToken id="7018F382B7B32C43B72CBCE8D0CB3886" originalValue="Vorblätter" pageId="null" pageNumber="906">Vorblaetter</normalizedToken>
2 oder mehr, meist in der obern 
<normalizedToken id="087DA61846380ED3544FFD6A0A52FCE7" originalValue="Hälfte" pageId="null" pageNumber="906">Haelfte</normalizedToken>
des 
<normalizedToken id="B7CBC804D704AEE578B4F58792853966" originalValue="Blütenstiels" pageId="null" pageNumber="906">Bluetenstiels</normalizedToken>
, 
<emphasis id="7C752870D360215C0519316FE20E6B31" italics="true" pageId="null" pageNumber="906">3</emphasis>
- 
<emphasis id="FF85CDE55A3AE735289B9A43AA22CD45" italics="true" pageId="null" pageNumber="906">
10 mm lang, blattartig, 
<normalizedToken id="65DB7A0E98FAB06F78EDDF333E5BD5F7" originalValue="grün" pageId="null" pageNumber="906">gruen</normalizedToken>
.
</emphasis>
<normalizedToken id="7FB363894AA1BD45BB097FD19B49E0B1" originalValue="Kelchblätter" pageId="null" pageNumber="906">Kelchblaetter</normalizedToken>
4, breit 3eckig. Die 4 freien 
<normalizedToken id="D08DE59C1C6965810F18139C42A914B3" originalValue="zurückgebogenen" pageId="null" pageNumber="906">zurueckgebogenen</normalizedToken>
Teile der Krone 6-10 mm lang, rosa. 
<normalizedToken id="44EE4000A473D1CA01902901A74E21E0" originalValue="Staubblätter" pageId="null" pageNumber="906">Staubblaetter</normalizedToken>
8; 
<normalizedToken id="EE9FE31CEC1EBF2C7AEA5C564C0FBCF8" originalValue="Staubfäden" pageId="null" pageNumber="906">Staubfaeden</normalizedToken>
etwa ⅓ so lang wie die Staubbeutel mit den 
<normalizedToken id="CB4E2F564D233942A66515970A70DCC3" originalValue="röhrenförmigen" pageId="null" pageNumber="906">roehrenfoermigen</normalizedToken>
<normalizedToken id="6CCA0053859193BAAFA7B1D92EC39A07" originalValue="Fortsätzen" pageId="null" pageNumber="906">Fortsaetzen</normalizedToken>
. Frucht kugelig, 
<emphasis id="5531D756743C9022A64FBBC738E53C5C" italics="true" pageId="null" pageNumber="906">im Durchmesser 1-2 cm</emphasis>
, 
<normalizedToken id="FCCCFA15E4488932EDAD3C9B19FB6E24" originalValue="überwinternd" pageId="null" pageNumber="906">ueberwinternd</normalizedToken>
, rot. - 
<normalizedToken id="C27765A92BD5B1045E441D5CB8B7CA52" originalValue="Blüte" pageId="null" pageNumber="906">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="7ABF077C26FAEBEBA5CC06655F11F6B0" pageId="null" pageNumber="906">
<emphasis id="ED304859459B95DC81C12977757D45D4" italics="true" pageId="null" pageNumber="906">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="526097FBF7BC8C9E27D8E8CC99066C07" italics="true" pageId="null" pageNumber="906">24:</emphasis>
Material aus Nordamerika (Darrow et al. 1944).
</paragraph>
<paragraph id="D0C151BFC1692D2C8ECE5C00AAE12AB3" pageId="null" pageNumber="906">
<emphasis id="094C055EA4498F03516C49C8F152F627" italics="true" pageId="null" pageNumber="906">Standort.</emphasis>
Montan. Nasse, saure 
<normalizedToken id="007BE8CB5A7B2C4594BF4BB1C2FF81CC" originalValue="Böden" pageId="null" pageNumber="906">Boeden</normalizedToken>
. Hochmoore.
</paragraph>
<paragraph id="1336FAA3135A51EEB1DA777C7F0BCF11" pageId="null" pageNumber="906">
<emphasis id="32A526B900322783629F17C7C594D3AC" italics="true" pageId="null" pageNumber="906">Verbreitung.</emphasis>
<normalizedToken id="550790C20417D9F0D85DB413FD640BF7" originalValue="Ursprünglich" pageId="null" pageNumber="906">Urspruenglich</normalizedToken>
<emphasis id="E4FD03224767798F7258E65A35045681" italics="true" pageId="null" pageNumber="906">nordamerikanische Pflanze;</emphasis>
<normalizedToken id="FBF962534496677AC17242CA56744629" originalValue="früher" pageId="null" pageNumber="906">frueher</normalizedToken>
in 
<normalizedToken id="5FAAEF7A215EC2AB258DE4547632B047" originalValue="europäischen" pageId="null" pageNumber="906">europaeischen</normalizedToken>
Mooren angepflanzt, da die 
<normalizedToken id="8DA61718CC72218D986D071FBF619CC8" originalValue="Früchte" pageId="null" pageNumber="906">Fruechte</normalizedToken>
gegessen wurden. - Im Gebiet: Roblosenried bei Einsiedeln (Schwyz) 1957 erstmals gefunden, Herkunft unbekannt, breitet sich dort aus (Oberholzer 1958 
<normalizedToken id="9BA482E9654008FC29217816202FE63D" originalValue="mündlich" pageId="null" pageNumber="906">muendlich</normalizedToken>
).
</paragraph>
</subSubSection>
