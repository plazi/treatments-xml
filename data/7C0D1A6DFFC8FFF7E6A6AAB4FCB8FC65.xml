<taxonomicName id="33A4D0F8FFCBFFF7E570AC44FC67FCE6" authority="Fedotova &amp; Perkovsky, 2017" authorityName="Fedotova &amp; Perkovsky" authorityYear="2017" box="[891,993,816,841]" class="Insecta" family="Cecidomyiidae" genus="Rovnoholoneurus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Diptera" pageId="2" pageNumber="25" phylum="Arthropoda" rank="species" species="miyae" status="sp. n.">
<emphasis id="C6D07769FFCBFFF7E570AC44FC67FCE6" box="[891,993,816,841]" italics="true" pageId="2" pageNumber="25">R. miyae</emphasis>
