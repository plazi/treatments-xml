<taxonomicName id="5B964D26FFCEFF88F73C9328F7ACF7DE" authority="de Winton, 1901" authorityName="de Winton" authorityYear="1901" class="Mammalia" family="Herpestidae" genus="Herpestes" kingdom="Animalia" order="Carnivora" pageId="2" pageNumber="307" phylum="Chordata" rank="species" species="naso">
