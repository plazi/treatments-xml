</taxonomicName>
, 
<materialsCitation id="2CFE3CF8FFCEFF88F7C89340F714F707" ID-GBIF-Occurrence="3699972320" pageId="2" pageNumber="307">
“ 
<collectingCountry id="E4817635FFCEFF88F7C49340F76DF7DE" box="[2141,2289,2140,2169]" name="Cameroon" pageId="2" pageNumber="307">Cameroon</collectingCountry>
River, West Africa”, 
<collectingCountry id="E4817635FFCEFF88F874939FF718F707" box="[2029,2180,2179,2208]" name="Cameroon" pageId="2" pageNumber="307">Cameroon</collectingCountry>
