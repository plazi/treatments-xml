<subSubSection id="45BB8BF23C9195F6793ED2C865B32028" pageId="null" pageNumber="168" type="description">
<paragraph id="4D66A4963B6CC980093C25B058B4077D" pageId="null" pageNumber="168">
1 
<normalizedToken id="E531E89310094025D8E6C0C75B253A3D" originalValue="jährige" pageId="null" pageNumber="168">jaehrige</normalizedToken>
bis ausdauernde 
<normalizedToken id="C3D5EC20D35780C0A7D215CB6049E97C" originalValue="Kräuter" pageId="null" pageNumber="168">Kraeuter</normalizedToken>
. 
<emphasis id="252D59FD2033A825E95AE567E16A5A83" italics="true" pageId="null" pageNumber="168">
<normalizedToken id="DDF244373EF2642925BB0630097A6043" originalValue="Blätter" pageId="null" pageNumber="168">Blaetter</normalizedToken>
ungeteilt, oft 
<normalizedToken id="136544056948CAED71276A98F556B1AC" originalValue="gezähnt" pageId="null" pageNumber="168">gezaehnt</normalizedToken>
. 
<normalizedToken id="8CB2BE1C8D55E7A65EFD6F6EE0FB1726" originalValue="Blüten" pageId="null" pageNumber="168">Blueten</normalizedToken>
einzeln
</emphasis>
, aufrecht, gestielt. Kelch 
<normalizedToken id="DECF2B2053D00A5996CB6A9C0B53A1D4" originalValue="röhrenförmig" pageId="null" pageNumber="168">roehrenfoermig</normalizedToken>
, 5 
<normalizedToken id="2725D613F284642F97CEE82BF3651F5B" originalValue="zähnig" pageId="null" pageNumber="168">zaehnig</normalizedToken>
, 
<emphasis id="A4531CE381A53E61470801D45316C55C" italics="true" pageId="null" pageNumber="168">
nach dem 
<normalizedToken id="3FC0E17B1FA425E29B2BC396E4B99FD2" originalValue="Verblühen" pageId="null" pageNumber="168">Verbluehen</normalizedToken>
bis auf den 
<normalizedToken id="05EC83F22C92BA4918EF9E209229A609" originalValue="ringförmigen" pageId="null" pageNumber="168">ringfoermigen</normalizedToken>
Kelchgrund abfallend
</emphasis>
(bei den andern Gattungen im Gebiet bleibend!). 
<emphasis id="9E9970C94B3D6A99D9947E02252C79DB" italics="true" pageId="null" pageNumber="168">
Krone 
<normalizedToken id="11430848A3834EE7849A3CF5F246BD6A" originalValue="groß" pageId="null" pageNumber="168">gross</normalizedToken>
</emphasis>
, 
<normalizedToken id="8596666816997A0CFD03C8AD40559B89" originalValue="trichterförmig" pageId="null" pageNumber="168">trichterfoermig</normalizedToken>
, mit kurz 5 
<normalizedToken id="3AB65CEBB34592D7819B890B608A9780" originalValue="zähnigem" pageId="null" pageNumber="168">zaehnigem</normalizedToken>
, ausgebreitetem Rand. 
<normalizedToken id="A39AC37BBD2F406DA71A459C83A4F8E2" originalValue="Staubblätter" pageId="null" pageNumber="168">Staubblaetter</normalizedToken>
5, gleich lang. Fruchtknoten unten 4-, oben 2 
<normalizedToken id="71D91C0107E3F9C8E22408B65A7830AA" originalValue="fächerig" pageId="null" pageNumber="168">faecherig</normalizedToken>
. 
<emphasis id="5B956B843B2214924E7C44AA793164C9" italics="true" pageId="null" pageNumber="168">
Frucht eine 
<normalizedToken id="946A1247D38E83BDFFDECDDB45D2E7D9" originalValue="eiförmige" pageId="null" pageNumber="168">eifoermige</normalizedToken>
, meist stachlige Kapsel, die mit 4 Klappen aufspringt
</emphasis>
. Samen mit wabenartiger 
<normalizedToken id="44975FF057DE929D706512ADF3DFC2B3" originalValue="Oberfläche" pageId="null" pageNumber="168">Oberflaeche</normalizedToken>
.
</paragraph>
<paragraph id="C4B99AF0481F0D5F8F725895B0469DFF" pageId="null" pageNumber="168">
Die Gattung 
<taxonomicName id="07D33484C1BAB42A8B6BABCDA9D64A1A" class="Magnoliopsida" family="Solanaceae" genus="Datura" kingdom="Plantae" order="Solanales" pageId="null" pageNumber="168" phylum="Tracheophyta" rank="genus">
<emphasis id="6881ECE7B02A8A45AFD09D7013F1DBCC" italics="true" pageId="null" pageNumber="168">Datura</emphasis>
</taxonomicName>
<normalizedToken id="018BBDB3A7BA8EFF987CE1F49A46D4BE" originalValue="umfaßt" pageId="null" pageNumber="168">umfasst</normalizedToken>
nach Avery et al. (1959) 
<emphasis id="D5377A7134A5B24D8A1B6055FDAF16A8" italics="true" pageId="null" pageNumber="168">10 meist amerikanische Arten. Chromosomengrundzahl:</emphasis>
n = 12.
</paragraph>
</subSubSection>
