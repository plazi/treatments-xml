<taxonomicName id="C7C97DC28EC0FF4E48F355D0FD61FCE5" authority="Xu, Olmi &amp; He, 2011" authorityName="Xu, Olmi &amp; He" authorityYear="2011" box="[195,708,763,790]" class="Insecta" family="Dryinidae" genus="Anteon" kingdom="Animalia" order="Hymenoptera" pageId="142" pageNumber="143" phylum="Arthropoda" rank="species" species="nanlingense">Anteon nanlingense Xu, Olmi &amp; He, 2011</taxonomicName>
</paragraph>
