<subSubSection id="1A3033D9F6C07ACB035E0995FA31BB32" pageId="null" pageNumber="12" type="description">
<paragraph id="741EC002F1A7828F18D2484AFB231250" pageId="null" pageNumber="12">
<normalizedToken id="04E2BB0E4DBCF3BD575AA654E9315C9D" originalValue="Blätter" pageId="null" pageNumber="12">Blaetter</normalizedToken>
<normalizedToken id="30FE5FA545774D7C1BE15397DF64F7EC" originalValue="sommergrün" pageId="null" pageNumber="12">sommergruen</normalizedToken>
oder 
<normalizedToken id="43ADA4FFD1B03A1450751DFED2F7C757" originalValue="immergrün" pageId="null" pageNumber="12">immergruen</normalizedToken>
, ungeteilt. 
<emphasis id="283A8647CF0DA0428BC55261553A7E09" italics="true" pageId="null" pageNumber="12">
<normalizedToken id="65B361E282F9CC949DD91C99451B390D" originalValue="Blüten" pageId="null" pageNumber="12">Blueten</normalizedToken>
in dichten Rispen
</emphasis>
, klein, ⚥. Kelch 
<normalizedToken id="7282CAC76C95FECA4C0101196A554132" originalValue="glockenförmig" pageId="null" pageNumber="12">glockenfoermig</normalizedToken>
, 4 
<normalizedToken id="F874884CA36D736F755C50735DC01E4D" originalValue="zähnig" pageId="null" pageNumber="12">zaehnig</normalizedToken>
. Krone mit einer 
<normalizedToken id="4D2FEB07C2D81610F86543AA73373D78" originalValue="Röhre" pageId="null" pageNumber="12">Roehre</normalizedToken>
und tief 4teiligem, ausgebreitetem Rand. 
<emphasis id="363C0F9E865064D0796FC63293154C18" italics="true" pageId="null" pageNumber="12">
Frucht eine kugelige bis 
<normalizedToken id="0B0622B3C824B24B98F9D0FD123F11C1" originalValue="eiförmige" pageId="null" pageNumber="12">eifoermige</normalizedToken>
, 2- oder 4samige Beere.
</emphasis>
</paragraph>
<paragraph id="6A853B4E895FDEE74045A002A12E033E" pageId="null" pageNumber="12">
Die Gattung 
<taxonomicName id="0576EB5906B8D722699DFA125B8A0164" class="Magnoliopsida" family="Oleaceae" genus="Ligustrum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="12" phylum="Tracheophyta" rank="genus">
<emphasis id="714C3821A3EBA078312D38E9DB2CB670" italics="true" pageId="null" pageNumber="12">Ligustrum</emphasis>
</taxonomicName>
<normalizedToken id="934746F4A3D182DD0A5FBDCFF2AACD05" originalValue="umfaßt" pageId="null" pageNumber="12">umfasst</normalizedToken>
etwa 
<emphasis id="F659AC3F390FE8F8AD2105405CBECC26" italics="true" pageId="null" pageNumber="12">40 Arten und hat eurasiatisch-australische Verbreitung. Chromosomengrundzahl:</emphasis>
n = 23.
</paragraph>
<paragraph id="49BEF5D27844E59BAD829A633F2BBBB3" pageId="null" pageNumber="12">
Neben der einheimischen Art werden in 
<normalizedToken id="597FBB2C19F3E91DB788C14DD8F2D540" originalValue="Gärten" pageId="null" pageNumber="12">Gaerten</normalizedToken>
oft ostasiatische Arten als Hecken gepflanzt (z. B. 
<taxonomicName id="0D3438E4C7AC158F1839CD5914F46D52" authority="Hausskn." authorityName="Hausskn." class="Magnoliopsida" family="Oleaceae" genus="Ligustrum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="12" phylum="Tracheophyta" rank="species" species="ovalifolium">
<emphasis id="5CCB3EACE523CD03942BBF08035FF168" italics="true" pageId="null" pageNumber="12">
<authorityName id="B61F016D633389438B1BF3476D754F3D" pageId="null" pageNumber="12">L.</authorityName>
ovalifolium
</emphasis>
Hausskn.
</taxonomicName>
mit ovalen 
<normalizedToken id="01A935813006C8CA0F6163F9D09B5A42" originalValue="Blättern" pageId="null" pageNumber="12">Blaettern</normalizedToken>
).
</paragraph>
</subSubSection>
