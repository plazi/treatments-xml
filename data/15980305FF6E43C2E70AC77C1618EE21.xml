<subSubSection id="404978E0943CA2F1052B2924E1BB70CB" pageId="null" pageNumber="257" type="description">
<paragraph id="C0E6D0D0E4D655BED429B3CE134226C3" pageId="null" pageNumber="257">
10-30 cm hoch. Rosette 
<normalizedToken id="333F80E3640E64BA350A2305A60B81E0" originalValue="sternförmig" pageId="null" pageNumber="257">sternfoermig</normalizedToken>
ausgebreitet, 4-15 cm im Durchmesser. 
<normalizedToken id="DAEB67D047DD147E8135C03E8B396754" originalValue="Rosettenblätter" pageId="null" pageNumber="257">Rosettenblaetter</normalizedToken>
kurz zugespitzt, ohne stachlige Spitze, meist nur an der Spitze rotbraun, sonst 
<normalizedToken id="857FF9AA12B81C9C39BC1E010A5B65DA" originalValue="grün" pageId="null" pageNumber="257">gruen</normalizedToken>
, 
<emphasis id="32F455DB6B18B544608333B7B36055AA" italics="true" pageId="null" pageNumber="257">
<normalizedToken id="4812E755DE5B57C0A2168953FAD4177A" originalValue="überall" pageId="null" pageNumber="257">ueberall</normalizedToken>
<normalizedToken id="760CABD7E73BDE5DC4073BDCE23FF870" originalValue="drüsig" pageId="null" pageNumber="257">druesig</normalizedToken>
bewimpert.
</emphasis>
Stengel und 
<normalizedToken id="FDB339679D3AD4C0BACB0216AFC5690E" originalValue="Stengelblätter" pageId="null" pageNumber="257">Stengelblaetter</normalizedToken>
<normalizedToken id="97F99B6DE7E735DD616F3ECD415AA565" originalValue="überall" pageId="null" pageNumber="257">ueberall</normalizedToken>
mit 
<normalizedToken id="189F2B02EDCF88F20CAC9C85F928A52F" originalValue="Drüsen" pageId="null" pageNumber="257">Druesen</normalizedToken>
. 
<normalizedToken id="D3369861BC674B4D1A1AA4959A002A96" originalValue="Blüten" pageId="null" pageNumber="257">Blueten</normalizedToken>
im Durchmesser 2-3 cm. 
<normalizedToken id="E5F07593D371D8BD2B9E41E1ABF20EBB" originalValue="Kronblätter" pageId="null" pageNumber="257">Kronblaetter</normalizedToken>
meist 12, 
<normalizedToken id="D0D4B4C5537D90E6F64925C92A65FB5C" originalValue="allmählich" pageId="null" pageNumber="257">allmaehlich</normalizedToken>
zugespitzt, 3- 
<normalizedToken id="2B56B6D50C96CBF26B4393FC4E439914" originalValue="3½" pageId="null" pageNumber="257">31/2</normalizedToken>
so lang wie die 
<normalizedToken id="DD60B9158F4D4D458881303F401CDA20" originalValue="Kelchblätter" pageId="null" pageNumber="257">Kelchblaetter</normalizedToken>
, 
<emphasis id="FC57AB43AF9A47284E5307655F5A71A6" italics="true" pageId="null" pageNumber="257">gelb</emphasis>
, am Rande 
<normalizedToken id="4FADB9399E53AEAB2E1D32F394D5B7E1" originalValue="drüsig" pageId="null" pageNumber="257">druesig</normalizedToken>
bewimpert. 
<normalizedToken id="8BF41DE4DB299318C5B0253FD86E33B3" originalValue="Fruchtblätter" pageId="null" pageNumber="257">Fruchtblaetter</normalizedToken>
wie bei 
<taxonomicName id="869E2765C67468BFE222E205AA7FC27F" class="Magnoliopsida" family="Crassulaceae" genus="Sempervivum" kingdom="Plantae" order="Saxifragales" pageId="null" pageNumber="257" phylum="Tracheophyta" rank="species" species="wulfenii">
<emphasis id="FFCCAE868736BB03942725B1C34CDF57" italics="true" pageId="null" pageNumber="257">S. Wulfenii</emphasis>
</taxonomicName>
(Nr. 4). - 
<normalizedToken id="22DEA5DF4F2085D49733C3E6A3B3DAC8" originalValue="Blüte" pageId="null" pageNumber="257">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="89ACCF51C3848B1A6BEC540303D5ECE3" pageId="null" pageNumber="257">
<emphasis id="618D18AF778254B04DC898A35577EB4C" italics="true" pageId="null" pageNumber="257">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="4C9C9AC9F0C937E99AC3ED5DB1481569" italics="true" pageId="null" pageNumber="257">80:</emphasis>
Material aus den Alpen (ohne Fundort) (
<normalizedToken id="BCE2B828A5D19BDB5B956C518F57D8F4" originalValue="Zésiger" pageId="null" pageNumber="257">Zesiger</normalizedToken>
1961).
</paragraph>
<paragraph id="D252632CC160F7C659E16B289C63A998" pageId="null" pageNumber="257">
<emphasis id="37BE25603CAB7B71992465A8D6CE0659" italics="true" pageId="null" pageNumber="257">Standort.</emphasis>
Subalpin. Silikatfelsen (kalkfreie Unterlage).
</paragraph>
<paragraph id="162A1C380E90174516826A11DF5A8FDB" pageId="null" pageNumber="257">
<emphasis id="F939C185C386A67A6AA1A1B71305A2E9" italics="true" pageId="null" pageNumber="257">Verbreitung. Grajisch-penninische Pflanze:</emphasis>
Val Susa bis Valsesia und Simplon. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: Wallis (Zwischbergental; wohl nur angepflanzt bei Liddes und Zermatt), Aostatal (viele Fundorte), Valsesia (Riva), Val Antigorio; Angaben aus dem Tessin (Gordola) sind 
<normalizedToken id="6A830055CF6B51B048309EBA949C42B6" originalValue="nachzuprüfen" pageId="null" pageNumber="257">nachzupruefen</normalizedToken>
.
</paragraph>
</subSubSection>
