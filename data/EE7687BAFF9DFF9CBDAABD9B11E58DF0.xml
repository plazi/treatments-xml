<keyLead id="DD2E9599FF9DFF9CBDAABC3511E48EB5" pageId="106" pageNumber="107">
2. Anterior parapods without any longer claws; total length of fourth instar about 
<quantity id="A1279B49FF9DFF9CBEEBBC35105A8E50" box="[982,1058,343,364]" metricMagnitude="-3" metricUnit="m" metricValue="6.2" pageId="106" pageNumber="107" unit="mm" value="6.2">6.2 mm</quantity>
; postmentum about 137 µm long......................................................................... 
<taxonomicName id="A1DF4D2FFF9DFF9CB929BC1610CC8EB5" box="[1044,1204,372,393]" class="Insecta" family="Chironomidae" genus="Hydrosmittia" kingdom="Animalia" order="Diptera" pageId="106" pageNumber="107" phylum="Arthropoda" rank="species" species="undetermined">
