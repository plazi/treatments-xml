<keyLead id="DD2E9599FF9DFF9CBDAABCF311E48EF8" pageId="106" pageNumber="107">
– Anterior parapods with 20–60 longer claws; total length of fourth instar 
<quantity id="A1279B49FF9DFF9CBEABBCF310748E9A" box="[918,1036,401,422]" metricMagnitude="-3" metricUnit="m" metricValue="3.4499999999999997" metricValueMax="4.6" metricValueMin="2.3" pageId="106" pageNumber="107" unit="mm" value="3.4499999999999997" valueMax="4.6" valueMin="2.3">2.3–4.6 mm</quantity>
; postmentum 73–79 µm long; Holarctic............................................................................. 
<taxonomicName id="A1DF4D2FFF9DFF9CB954BCCD11328EF8" authority="(Edwards)" baseAuthorityName="Edwards" box="[1129,1354,431,452]" class="Insecta" family="Chironomidae" genus="Hydrosmittia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Diptera" pageId="106" pageNumber="107" phylum="Arthropoda" rank="species" species="oxoniana">
