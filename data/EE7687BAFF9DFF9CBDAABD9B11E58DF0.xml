<taxonomicName id="A1DF4D2FFF9DFF9CB9B3BF1E116E8DAD" authority="Ferrington Jr &amp; Saether, 2011" authorityName="Ferrington Jr &amp; Saether" authorityYear="2011" box="[1166,1302,636,657]" class="Insecta" family="Chironomidae" genus="Hydrosmittia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Diptera" pageId="106" pageNumber="107" phylum="Arthropoda" rank="species" species="falsicostata" status="sp. n.">
<emphasis id="54ABEABEFF9DFF9CB9B3BF1E116E8DAD" box="[1166,1302,636,657]" italics="true" pageId="106" pageNumber="107">H. falsicostata</emphasis>
</taxonomicName>
<taxonomicNameLabel id="4F9857C5FF9DFF9CB821BF1E11368DAD" box="[1308,1358,636,657]" pageId="106" pageNumber="107" rank="species">sp. n.</taxonomicNameLabel>
(p. 134)
</keyLead>
</paragraph>
</keyStep>
<keyStep id="DD2B2E09FF9DFF9CBDAABFFB11E58DF0" pageId="106" pageNumber="107">
