<figureCitation id="E3D72A2E6E35FFC347D5E25482ADFE39" box="[703,763,367,393]" captionStart="Fig" captionStartId="4.[167,200,1775,1797]" captionTargetBox="[202,1183,629,1755]" captionTargetId="figure-172@4.[179,1200,615,1773]" captionTargetPageId="4" captionText="Fig. 3. Gastrotrichs of the Karyakiv ravine pond: A — Chaetonotus (Zonochaeta) bisacer, B — Chaetonotus (Primochaetus) heideri, C — Lepidodermella minor minor, D — Lepidodermella squamata, E — Ichthydium maximum, F — Haltidytes festinans. Scale bars 30 µm." figureDoi="http://doi.org/10.5281/zenodo.6455652" httpUri="https://zenodo.org/record/6455652/files/figure.png" pageId="4" pageNumber="353">fig. 3</figureCitation>
