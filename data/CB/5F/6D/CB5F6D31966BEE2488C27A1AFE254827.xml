<taxonomicName authorityName="Ulmer" authorityYear="1906" box="[247,451,870,896]" class="Insecta" family="Helicopsychidae" kingdom="Animalia" order="Trichoptera" pageId="3" pageNumber="581" phylum="Arthropoda" rank="family">Helicopsychidae</taxonomicName>
