<taxonomicName authorityName="Banks" authorityYear="1913" box="[1098,1207,151,177]" class="Insecta" family="Polycentropodidae" genus="Cyrnellus" kingdom="Animalia" order="Trichoptera" pageId="6" pageNumber="584" phylum="Arthropoda" rank="genus">
<emphasis box="[1098,1207,151,177]" italics="true" pageId="6" pageNumber="584">Cyrnellus</emphasis>
</taxonomicName>
, 
<taxonomicName authorityName="Curtis" authorityYear="1835" box="[1221,1382,151,177]" class="Insecta" family="Polycentropodidae" genus="Polycentropus" kingdom="Animalia" order="Trichoptera" pageId="6" pageNumber="584" phylum="Arthropoda" rank="genus">
<emphasis box="[1221,1382,151,177]" italics="true" pageId="6" pageNumber="584">Polycentropus</emphasis>
</taxonomicName>
, and 
<taxonomicName authorityName="Ulmer" authorityYear="1905" box="[151,319,187,213]" class="Insecta" family="Polycentropodidae" genus="Polyplectropus" kingdom="Animalia" order="Trichoptera" pageId="6" pageNumber="584" phylum="Arthropoda" rank="genus">
