<taxonomicName authority="Banks 1904" authorityName="Banks" authorityYear="1904" box="[238,511,1591,1618]" class="Insecta" family="Glossosomatidae" genus="Protoptila" kingdom="Animalia" order="Trichoptera" pageId="2" pageNumber="580" phylum="Arthropoda" rank="genus">
<emphasis bold="true" box="[238,359,1591,1618]" italics="true" pageId="2" pageNumber="580">Protoptila</emphasis>
<bibRefCitation author="Banks, N." box="[366,511,1591,1617]" pageId="2" pageNumber="580" pagination="201 - 217" refId="ref4937" refString="Banks, N. (1904) A list of neuropteroid insects, exclusive of Odonata, from the vicinity of Washington, D. C. Proceedings of the Entomological Society of Washington, 6, 201 - 217." type="journal article" year="1904">Banks 1904</bibRefCitation>
