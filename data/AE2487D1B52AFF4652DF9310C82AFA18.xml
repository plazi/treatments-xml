Scanning electron microscope photographs of 
<taxonomicName id="E18D4D44B52BFF485178912ECF00FBF3" authority="Simon, 1897" authorityName="Simon" authorityYear="1897" box="[816,1139,1026,1050]" class="Arachnida" family="Trachelidae" genus="Orthobula" kingdom="Animalia" order="Araneae" pageId="7" pageNumber="362" phylum="Arthropoda" rank="species" species="radiata">
