<subSubSection id="750DAC470D65337A388D0CF891D943FE" pageId="null" pageNumber="268" type="description">
<paragraph id="3289102FBA367B8918B252516C593B67" pageId="null" pageNumber="268">
<emphasis id="EBD5C714F321B49EBC11FCD709F853C1" italics="true" pageId="null" pageNumber="268">
1 
<normalizedToken id="BAD4A7FFD45450A8219ED6AA9F9953E6" originalValue="jährig" pageId="null" pageNumber="268">jaehrig</normalizedToken>
</emphasis>
, 20-40 cm hoch, 
<normalizedToken id="D01C42954A8FFA27451BB7824EAD5F3F" originalValue="büschelig" pageId="null" pageNumber="268">bueschelig</normalizedToken>
. Stengel knickig aufsteigend. 
<normalizedToken id="1F9730F6E2A7F34CFECED227CB925C95" originalValue="Blätter" pageId="null" pageNumber="268">Blaetter</normalizedToken>
schmal (ca. 1,5 mm breit), kurz, glatt; 
<normalizedToken id="ED0CF791D09384F7804E8A0494EAA179" originalValue="Blatthäutchen" pageId="null" pageNumber="268">Blatthaeutchen</normalizedToken>
bis 1 mm lang, stumpf, derb; 
<emphasis id="38C340DFE31BC32B07395AE44ABA9123" italics="true" pageId="null" pageNumber="268">
oberste Blattscheide auffallend 
<normalizedToken id="27AF5D12C6CF30F7EDD9DB1AF56E25D4" originalValue="spindelförmig" pageId="null" pageNumber="268">spindelfoermig</normalizedToken>
erweitert
</emphasis>
, Durchmesser etwa 7 mm. 
<normalizedToken id="C5C610300FD45A00790AE68E361E6C0C" originalValue="Blütenstand" pageId="null" pageNumber="268">Bluetenstand</normalizedToken>
(ohne Grannen) 1,5-2,5 cm lang, 
<normalizedToken id="EC6EE32CFFA14C29A1DD8F7B6AACCF22" originalValue="eiförmig" pageId="null" pageNumber="268">eifoermig</normalizedToken>
. 
<normalizedToken id="AA2E5EE6E0D5F7FAA0CB87DEC993B71F" originalValue="Hüllspelzen" pageId="null" pageNumber="268">Huellspelzen</normalizedToken>
6-8 mm lang, bis 
<taxonomicName id="440DD23020ACE2C82F8854CA5A8A5FDE" class="Liliopsida" family="Sparganiaceae" genus="Stengelblaetter" higherTaxonomySource="GBIF" kingdom="Plantae" order="Poales" pageId="null" pageNumber="268" phylum="Tracheophyta" rank="species" species="gegen">gegen</taxonomicName>
die Mitte verwachsen; 
<emphasis id="CC3D864202BB41C34DB2C33F7A4201C7" italics="true" pageId="null" pageNumber="268">untere</emphasis>
⅔ 
<emphasis id="55148F34E9048968D3ECC42448F25CBD" italics="true" pageId="null" pageNumber="268">
der beiden 
<normalizedToken id="FA65B86BAF88B8FC48340B8AFC7B760E" originalValue="Hüllspelzen" pageId="null" pageNumber="268">Huellspelzen</normalizedToken>
lederig, knorpelig, gelb, viel weiter als der durch eine 
<normalizedToken id="56AF671087E02E14357A8D589037E273" originalValue="plötzliche" pageId="null" pageNumber="268">ploetzliche</normalizedToken>
Verengung verbundene obere, weiche, 
<normalizedToken id="7CCAAEFB16889843BFBD37F7B5EA4573" originalValue="grüne" pageId="null" pageNumber="268">gruene</normalizedToken>
Drittel der 
<normalizedToken id="3A0040B350E9B97B4D411BC03C4AC7C7" originalValue="Hüllspelzen" pageId="null" pageNumber="268">Huellspelzen</normalizedToken>
;
</emphasis>
nur in der untern 
<normalizedToken id="37AD4962C045FBBFE4A5842059182679" originalValue="Hälfte" pageId="null" pageNumber="268">Haelfte</normalizedToken>
auf dem Kiel mit 0,5 mm langen Haaren. Deckspelze so lang wie die 
<normalizedToken id="8EE8D7E05B17891C4EDA65C265CDA4E9" originalValue="Hüllspelzen" pageId="null" pageNumber="268">Huellspelzen</normalizedToken>
, in der untern 
<normalizedToken id="83CADC3B1B8F7F2B2357EB38A7429BFD" originalValue="Hälfte" pageId="null" pageNumber="268">Haelfte</normalizedToken>
die 
<normalizedToken id="69436152D7280B70A403D7EDA9ED9909" originalValue="Ränder" pageId="null" pageNumber="268">Raender</normalizedToken>
miteinander verwachsen, auf dem 
<normalizedToken id="21B1327BA09EBA69B5A8EF5B9582FF52" originalValue="Rücken" pageId="null" pageNumber="268">Ruecken</normalizedToken>
(nahe dem Grunde) mit Granne, die mehr als 2mal so lang ist wie die Deckspelze. Keine Vorspelze vorhanden. - 
<normalizedToken id="4B93B93D2AA7072350F88CC59C1EE731" originalValue="Blüte" pageId="null" pageNumber="268">Bluete</normalizedToken>
: 
<normalizedToken id="ED0E818D374145997F6A1E0752518622" originalValue="Später" pageId="null" pageNumber="268">Spaeter</normalizedToken>
<normalizedToken id="5C287D391C845649567D42284E9EC36A" originalValue="Frühling" pageId="null" pageNumber="268">Fruehling</normalizedToken>
und 
<normalizedToken id="34E7D149CD262DAF6B2CE2BCE856BD09" originalValue="früher" pageId="null" pageNumber="268">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="69B7B292A0491E9AE695BD5E4ED4E91F" pageId="null" pageNumber="268">
<emphasis id="DDCC98D3492F0291BC2C78B47B903006" italics="true" pageId="null" pageNumber="268">Zytologische Angaben. 2n = 14:</emphasis>
Material aus botanischen 
<normalizedToken id="8460D9F40CDDCFB280F48ECDB282D3C4" originalValue="Gärten" pageId="null" pageNumber="268">Gaerten</normalizedToken>
(Strelkova 1938).
</paragraph>
<paragraph id="B2FC916048E6E7BE0A8C0CD05DCF399A" pageId="null" pageNumber="268">
<emphasis id="30359182CBD770534C26664B12C6B2C5" italics="true" pageId="null" pageNumber="268">Standort.</emphasis>
Kollin. Feuchte bis trockene 
<normalizedToken id="8B82FFDD54FB506DDEA36097778731C2" originalValue="Böden" pageId="null" pageNumber="268">Boeden</normalizedToken>
. Feuchte Wiesen, 
<normalizedToken id="76272651CE7103B14065691B91FA71B3" originalValue="Ödland" pageId="null" pageNumber="268">Oedland</normalizedToken>
, 
<normalizedToken id="283FF67A79DA5037209C7F6BC1E975A1" originalValue="Wegränder" pageId="null" pageNumber="268">Wegraender</normalizedToken>
und 
<normalizedToken id="5872B64255020FB6F9263A8C49576DBE" originalValue="Schuttplätze" pageId="null" pageNumber="268">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="EFE94F157157A94CD13356D4CF6600FA" pageId="null" pageNumber="268">
<emphasis id="6F74C346D6148D5A4258A836BB7EB169" italics="true" pageId="null" pageNumber="268">
Verbreitung. 
<normalizedToken id="EE075F96CA69011AC0B442F29F71926A" originalValue="Westeuropäisch-mediterrane" pageId="null" pageNumber="268">Westeuropaeisch-mediterrane</normalizedToken>
Pflanze:
</emphasis>
In Westeuropa 
<normalizedToken id="B40058FF120CCBEFB65A2AE828CBCF86" originalValue="nordwärts" pageId="null" pageNumber="268">nordwaerts</normalizedToken>
bis Belgien, Rheinland; 
<normalizedToken id="B9D5A91BBBFEE48B3927E01C3AA19369" originalValue="Alpensüdrand" pageId="null" pageNumber="268">Alpensuedrand</normalizedToken>
, Balkanhalbinsel; 
<normalizedToken id="BC1F25CFA067107E01A4AD29E279B67D" originalValue="ostwärts" pageId="null" pageNumber="268">ostwaerts</normalizedToken>
bis Kleinasien; Nordafrika. - Im Gebiet: 
<normalizedToken id="2A22031D8FDF84BBD0B5B296D4233D07" originalValue="Dép" pageId="null" pageNumber="268">Dep</normalizedToken>
. Jura, 
<normalizedToken id="EF4828408386FA21A120486DF9A514C7" originalValue="Dép" pageId="null" pageNumber="268">Dep</normalizedToken>
. Doubs, Gebiet von Belfort, Oberrheinische Tiefebene (
<normalizedToken id="FB250369D2AD5533D93B75736D84B278" originalValue="Elsaß" pageId="null" pageNumber="268">Elsass</normalizedToken>
, Neuenburg), Veltlin, Comerseegebiet, sonst gelegentlich adventiv.
</paragraph>
</subSubSection>
