<subSubSection id="DC53A7290AAD8D13A5D10A1C8D388EC8" pageId="null" pageNumber="590" type="description">
<paragraph id="6847BAD40F2DE1EF17EF43C3548E2608" pageId="null" pageNumber="590">
Unterscheidet sich von 
<taxonomicName id="5A773F63D5FD58D59D0F73B4B25D2DC4" class="Magnoliopsida" family="Asteraceae" genus="Leontodon" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="taraxacoides">
<emphasis id="82B413B0874479F4FE4F599D3D4E0076" italics="true" pageId="null" pageNumber="590">
<authorityName id="D892CC8277C2A0224B3D0E46C15DC2B4" pageId="null" pageNumber="590">L.</authorityName>
taraxacoides
</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: Ausdauernd, 
<emphasis id="1CD7617EAFD377FA1138EB9F8DEE67EE" italics="true" pageId="null" pageNumber="590">
mit 
<normalizedToken id="16FF74D9FE4A87F7CFE1501FE002926A" originalValue="keulenförmig" pageId="null" pageNumber="590">keulenfoermig</normalizedToken>
verdickten Wurzeln
</emphasis>
(bei keiner andern Art im Gebiet so!); 
<emphasis id="94AA966D4807B80E0541C628EF24FA04" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="643895102A8E6B6C3350AE7E9CE72586" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
6
</emphasis>
- 
<emphasis id="BEEDAB5CD515A34CEFF9AB0F28112AAB" italics="true" pageId="null" pageNumber="590">
7 mm lang; Schnabel der innern 
<normalizedToken id="FA47173830C9CE1A67E7AD8E8DD7D921" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
</emphasis>
<normalizedToken id="E37875CF0E385A5ABB94BB9C74AA2D17" originalValue="½" pageId="null" pageNumber="590">1/2</normalizedToken>
-⅔ 
<emphasis id="DB2B0FD6132AE0F445773090958F2631" italics="true" pageId="null" pageNumber="590">so lang wie der Rest der Frucht.</emphasis>
- 
<normalizedToken id="A2F51C41914FBEF0275083169A0027EB" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Herbst.
</paragraph>
<paragraph id="D130E1C8439442B473E05B214DC7D8C0" pageId="null" pageNumber="590">
<emphasis id="0B1289E12D02255DE9921304D5580DAC" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="783F6A0E7973E4BE79E794A45298AFD6" italics="true" pageId="null" pageNumber="590">8:</emphasis>
Material aus Griechenland (Damboldt in 
<normalizedToken id="5E2E82A84D87B715C8ACE209031AB273" originalValue="Löve" pageId="null" pageNumber="590">Loeve</normalizedToken>
1971c).
</paragraph>
<paragraph id="751EF47AE8A63D93653A7ED66C341F37" pageId="null" pageNumber="590">
<emphasis id="537038E258F4CF3CBF605E639A8DF7E7" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Kollin. Lockere, 
<normalizedToken id="3FA5FA46468031BEC0AAF07ED3EC2BD9" originalValue="mäßig" pageId="null" pageNumber="590">maessig</normalizedToken>
trockene, kalkreiche 
<normalizedToken id="D457850F0826DA40821865155B722879" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
in warmen Lagen. Grasige 
<normalizedToken id="24E8EB8549D45C4ECD99454811949C23" originalValue="Hänge" pageId="null" pageNumber="590">Haenge</normalizedToken>
.
</paragraph>
<paragraph id="7CBF212C093D8169F9C50EAECA68DAE3" pageId="null" pageNumber="590">
<emphasis id="6653848693209FCC35A193C12E32F4F1" italics="true" pageId="null" pageNumber="590">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="6255886178AE2B7C898682BCD92BF6F1" originalValue="Nordwärts" pageId="null" pageNumber="590">Nordwaerts</normalizedToken>
bis zu den 
<normalizedToken id="9ABC700A29C328BAA9649A733907FC59" originalValue="Südalpen" pageId="null" pageNumber="590">Suedalpen</normalizedToken>
. - Im Gebiet: Bergamasker Alpen (oberhalb Branzi im Val Brembana).
</paragraph>
