<paragraph id="016C1165FFE2393AEBD2C107FA6D5D78" blockId="76.[227,1426,1588,1614]" box="[227,1426,1588,1614]" pageId="76" pageNumber="77">
Bartonian: Moodys Branch Formation, 
<collectingRegion id="C317DF87FFE2393AE983C107FCD95D78" box="[690,806,1588,1614]" country="United States of America" name="Louisiana" pageId="76" pageNumber="77">Louisiana</collectingRegion>
