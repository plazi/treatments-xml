<paragraph id="BA8BCC89D8C092FDA7078992D2E9E871" pageId="null" pageNumber="152">
<normalizedToken id="C1EC90DD4BD4266F0D22B5145316FDB4" originalValue="Krähenfußblättriges" pageId="null" pageNumber="152">Kraehenfussblaettriges</normalizedToken>
<normalizedToken id="C0B01DC10D70092C5D12F5D6054EE451" originalValue="Brillenschötchen" pageId="null" pageNumber="152">Brillenschoetchen</normalizedToken>
</paragraph>
