; forebody length 
<quantity id="C41CAABFFFF0FFC1FCDBFC573ECDFC73" box="[831,969,979,1006]" metricMagnitude="-3" metricUnit="m" metricValue="3.95" metricValueMax="4.3" metricValueMin="3.6" pageId="1" pageNumber="42" unit="mm" value="3.95" valueMax="4.3" valueMin="3.6">3.6–4.3 mm</quantity>
