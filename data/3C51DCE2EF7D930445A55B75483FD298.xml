Amerikanische 
<taxonomicName id="98D57A806CDEA40F8A501C1BC581AAC9" class="Liliopsida" family="Asparagaceae" genus="Agave" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="585" phylum="Tracheophyta" rank="genus">Agave</taxonomicName>
</paragraph>
