Groupe de 
<taxonomicName id="A4E862C21F42FFB9FCA8FD9AFB093192" authority="Hook. f." authorityName="Hook. f." box="[818,1187,635,662]" class="Magnoliopsida" family="Primulaceae" genus="Tapeinosperma" kingdom="Plantae" order="Ericales" pageId="9" pageNumber="288" phylum="Tracheophyta" rank="species" species="vieillardii">
<emphasis id="519CC5531F42FFB9FCA8FD9AFBE03191" bold="true" box="[818,1098,635,662]" italics="true" pageId="9" pageNumber="288">Tapeinosperma vieillardii</emphasis>
