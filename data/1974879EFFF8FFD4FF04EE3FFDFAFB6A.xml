<figureCitation id="09E62A0DFFF8FFD4FE7CEEA2FDE6FB6A" box="[458,526,1206,1228]" captionStart="Map 2" captionStartId="12.[178,223,1191,1211]" captionTargetBox="[178,1085,212,1169]" captionTargetId="figure-224@12.[178,1085,212,1169]" captionTargetPageId="12" captionText="Map 2: Distributions of Micrillus aegyptiacus (BERNHAUER) (circles), M. sudanicus ASSING (triangles), and M. aethiopicus (CAMERON) (diamonds; open diamonds unrevised records; unidentified locality &quot;Nargi&quot; omitted)." figureDoi="http://doi.org/10.5281/zenodo.6511858" httpUri="https://zenodo.org/record/6511858/files/figure.png" pageId="13" pageNumber="1492">Map 2</figureCitation>
