Comment: 
<taxonomicName id="56DD4D0BFFF8FFD4FED2EE6EFDA9FB37" box="[356,577,1147,1169]" class="Insecta" family="Staphylinidae" genus="Micrillus" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="1492" phylum="Arthropoda" rank="species" species="aegyptiacus">
