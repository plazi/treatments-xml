<emphasis id="0791A165760CFFC4FD4CF8BCE589F88F" bold="true" box="[742,897,1858,1891]" pageId="35" pageNumber="525">Taxonomy.</emphasis>
<taxonomicName id="F2E506F4760CFFC4FC0CF8BCE523F867" authority="Gray" authorityName="Gray" authorityYear="1828" class="Mammalia" family="Delphinidae" genus="Delphinus" kingdom="Animalia" order="Cetacea" pageId="35" pageNumber="525" phylum="Chordata" rank="species" species="heavisidii">Delphinus heavisidii Gray, 1828</taxonomicName>
