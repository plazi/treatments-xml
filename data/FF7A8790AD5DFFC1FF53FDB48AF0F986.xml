<subSubSection id="3FC9650DAD5DFFC1FF53FDEC8A76FCC2" pageId="3" pageNumber="298" type="reference_group">
<paragraph id="776C3686AD5DFFC1FF53FDEC8BE6FD6E" blockId="3.[136,1452,557,796]" pageId="3" pageNumber="298">
<emphasis id="45A7EA94AD5DFFC1FF53FDEC89EBFD55" bold="true" box="[136,184,630,651]" pageId="3" pageNumber="298">Note</emphasis>
:— 
<bibRefCitation id="13424B77AD5DFFC1FF0FFDEC88CCFD52" author="van Soest, J. L." box="[212,415,630,652]" pageId="3" pageNumber="298" pagination="1 - 32" refId="ref4321" refString="van Soest, J. L. (1954) Sur quelques Taraxaca d'Espagne. Collectanea Botanica 4: 1 - 32." type="journal article" year="1954">Van Soest (1954: 16)</bibRefCitation>
explicitly included the name 
<taxonomicName id="B0D34D05AD5DFFC1FD62FDEC8A01FD55" authorityName="Dahlstedt" authorityYear="1907" box="[697,850,630,651]" class="Magnoliopsida" family="Asteraceae" genus="Taraxacum" kingdom="Plantae" order="Asterales" pageId="3" pageNumber="298" phylum="Tracheophyta" rank="species" species="rhodocarpum">
<emphasis id="45A7EA94AD5DFFC1FD62FDEC8A01FD55" box="[697,850,630,651]" italics="true" pageId="3" pageNumber="298">T. rhodocarpum</emphasis>
</taxonomicName>
in his new 
<emphasis id="45A7EA94AD5DFFC1FC64FDEC8A81FD55" box="[959,978,630,651]" italics="true" pageId="3" pageNumber="298">T.</emphasis>
sect. 
<emphasis id="45A7EA94AD5DFFC1FBDCFDEC8D2DFD55" box="[1031,1150,630,651]" italics="true" pageId="3" pageNumber="298">Rhodocarpa</emphasis>
and did not designate any 
<typeStatus id="A8688824AD5DFFC1FAA7FDEC8CFBFD55" box="[1404,1448,630,651]" pageId="3" pageNumber="298">type</typeStatus>
, and therefore Art. 10.8 applies (
<bibRefCitation id="13424B77AD5DFFC1FE35FD008BF9FD6E" author="Turland, N. J. &amp; Wiersema, J. H. &amp; Barrie, F. R. &amp; Greuter, W. &amp; Hawksworth, D. L. &amp; Herendeen, P. S. &amp; Knapp, S. &amp; Kusber, W. - H. &amp; Li, D. - Z. &amp; Marhold, K. &amp; May, T. W. &amp; McNeill, J. &amp; Monro, A. M. &amp; Prado, J. &amp; Price, M. J. &amp; Smith, G. F." box="[494,682,666,688]" pageId="3" pageNumber="298" refId="ref4150" refString="Turland, N. J., Wiersema, J. H., Barrie, F. R., Greuter, W., Hawksworth, D. L., Herendeen, P. S., Knapp, S., Kusber, W. - H., Li, D. - Z., Marhold, K., May, T. W., McNeill, J., Monro, A. M., Prado, J., Price, M. J. &amp; Smith, G. F. (eds.) (2018) International Code of Nomenclature for algae, fungi, and plants (Shenzhen Code) [...]. Koeltz Botanical Books, Glashutten. https: // doi. org / 10.12705 / Code. 2018" type="book" year="2018">
Turland 
<emphasis id="45A7EA94AD5DFFC1FD9BFD008B22FD71" box="[576,625,666,687]" italics="true" pageId="3" pageNumber="298">et al.</emphasis>
2018
</bibRefCitation>
).
</paragraph>
<paragraph id="776C3686AD5DFFC1FF53FD248A09FD0A" blockId="3.[136,1452,557,796]" box="[136,858,701,724]" pageId="3" pageNumber="298">
= 
