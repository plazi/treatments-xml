<bibRefCitation id="13424B77AD5DFFC1FE74FC9C8B2EFCC5" author="van Soest, J. L." box="[431,637,774,796]" pageId="3" pageNumber="298" pagination="77 - 138" refId="ref4344" refString="van Soest, J. L. (1959) Alpine species of Taraxacum. Acta Botanica Neerlandica 8: 77 - 138. https: // doi. org / 10.1111 / j. 1438 - 8677.1959. tb 00013. x" type="journal article" year="1959">van Soest (1959: 132</bibRefCitation>
