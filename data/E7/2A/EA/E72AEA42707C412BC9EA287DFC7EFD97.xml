<emphasis box="[257,463,1803,1824]" italics="true" pageId="3" pageNumber="288">Nepenthes candalaga</emphasis>
</taxonomicName>
. 
<emphasis bold="true" box="[475,500,1803,1825]" pageId="3" pageNumber="288">A)</emphasis>
Aerial pitcher lateral view, 
<emphasis bold="true" box="[763,786,1803,1825]" pageId="3" pageNumber="288">B)</emphasis>
lid adaxial, 
<emphasis bold="true" box="[902,927,1803,1825]" pageId="3" pageNumber="288">C)</emphasis>
lid abaxial showing lid spur, 
<emphasis bold="true" box="[1205,1231,1803,1825]" pageId="3" pageNumber="288">D)</emphasis>
seed, 
<emphasis bold="true" box="[1289,1313,1803,1825]" pageId="3" pageNumber="288">E)</emphasis>
tepal showing floral nectar glands, 
<emphasis bold="true" box="[334,356,1839,1861]" pageId="3" pageNumber="288">F)</emphasis>
dehisced capsule, 
<emphasis bold="true" box="[537,563,1839,1861]" pageId="3" pageNumber="288">G)</emphasis>
female flower, 
<emphasis bold="true" box="[715,742,1839,1861]" pageId="3" pageNumber="288">H)</emphasis>
lid spur, 
<emphasis bold="true" box="[832,849,1839,1861]" pageId="3" pageNumber="288">I)</emphasis>
close up of the lid appendage, 
