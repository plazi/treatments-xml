<emphasis box="[650,880,160,184]" italics="true" pageId="2" pageNumber="287">Nepenthes candalaga</emphasis>
</taxonomicName>
and 
<taxonomicName authorityName="Gronemeyer, Wistuba, Mey &amp; W. B. Amoroso" authorityYear="2016" box="[932,1047,161,184]" class="Magnoliopsida" family="Nepenthaceae" genus="Nepenthes" kingdom="Plantae" order="Caryophyllales" pageId="2" pageNumber="287" phylum="Tracheophyta" rank="species" species="justinae">
<emphasis box="[932,1047,161,184]" italics="true" pageId="2" pageNumber="287">N. justinae</emphasis>
