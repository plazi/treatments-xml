<taxonomicName authority="Gray" box="[795,1184,439,535]" class="Mammalia" family="Tupaiidae" kingdom="Animalia" order="Scandentia" pageId="0" pageNumber="242" phylum="Chordata" rank="family">TUPAIIDAE</taxonomicName>
