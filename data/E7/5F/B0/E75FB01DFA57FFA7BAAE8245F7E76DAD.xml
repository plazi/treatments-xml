<subSubSection pageId="7" pageNumber="268" type="activity">
<paragraph blockId="7.[1441,2649,1396,2256]" pageId="7" pageNumber="268">
<emphasis bold="true" box="[1441,1675,1908,1941]" pageId="7" pageNumber="268">Activity patterns.</emphasis>
