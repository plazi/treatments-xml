<subSubSection id="A413488C1411A62AFB0A505CDC209A53" pageId="null" pageNumber="646" type="vernacular_names">
<paragraph id="131A6C5FCF12B697CCB9580086665279" pageId="null" pageNumber="646">Kalk-Kreuzblume</paragraph>
</subSubSection>
</title>
<subSubSection id="458FA3D505021E4494460CFC2E6CDBBE" pageId="null" pageNumber="646" type="description">
<paragraph id="F23B404225C6563C3239E2A393AF2F2E" pageId="null" pageNumber="646">
5-20 cm hoch. Stengel am Grunde 
<emphasis id="D022D8F614B38663A9855D8CBB749C57" italics="true" pageId="null" pageNumber="646">meist mehrere Zentimeter lang</emphasis>
(von der Wurzel bis zur Blattrosette) 
<emphasis id="0DE3DDDDF6B21529C64B22C3B5B2CCC7" italics="true" pageId="null" pageNumber="646">niederliegend.</emphasis>
Untere 
<normalizedToken id="A1D4554311F44C871EFBD6B56571FFFE" originalValue="Blätter" pageId="null" pageNumber="646">Blaetter</normalizedToken>
<normalizedToken id="C4050F9DAD5A9ED569A8A2FFA488C3D1" originalValue="wechselständig" pageId="null" pageNumber="646">wechselstaendig</normalizedToken>
, am Ort, wo die Zweige aufsteigen, rosettenartig angeordnet, die obern nur wenig 
<normalizedToken id="1E815675AB1DFA82CE9158387BB55523" originalValue="länger" pageId="null" pageNumber="646">laenger</normalizedToken>
oder meist 
<normalizedToken id="A392DDEBCF66C7D9382EC76371928568" originalValue="kürzer" pageId="null" pageNumber="646">kuerzer</normalizedToken>
als die untern, 
<emphasis id="84E18A5440D0A03CA04E1CA223DA7972" italics="true" pageId="null" pageNumber="646">0,8-1,5 cm lang</emphasis>
, oberhalb der Mitte am breitesten. 
<normalizedToken id="799A6DF1D6158A970106BB5077F3D65F" originalValue="Blütenstände" pageId="null" pageNumber="646">Bluetenstaende</normalizedToken>
6-20 
<normalizedToken id="5D0D3CD031558CF2DF8359A4B0C9F9BD" originalValue="blütig" pageId="null" pageNumber="646">bluetig</normalizedToken>
. 
<normalizedToken id="326657407EBEAF575E07E07FA15DAA2E" originalValue="Tragblätter" pageId="null" pageNumber="646">Tragblaetter</normalizedToken>
1,2-1,7 mm lang. 
<normalizedToken id="C56F757BE9822080619CE2080495462C" originalValue="Blüten" pageId="null" pageNumber="646">Blueten</normalizedToken>
blau, selten 
<normalizedToken id="7386F15D7F6208F99F455031BC37D6A9" originalValue="weiß" pageId="null" pageNumber="646">weiss</normalizedToken>
. Oberstes Kelchblatt 2-3 mm lang. 
<normalizedToken id="232AA562483BBDAE53B37A565A2193B6" originalValue="Flügel" pageId="null" pageNumber="646">Fluegel</normalizedToken>
5-7 mm lang und 2,5-3,5 mm breit; die seitlichen Nerven nicht sehr deutlich sichtbar und etwas verzweigt, nur 0-4 geschlossene Netzmaschen bildend. Fransen der untern Kronzipfel 10-30. Frucht 4-5 mm lang, mit 0,3-0,5 mm breitem Rand. Samen 2-2,6 mm lang. - 
<normalizedToken id="13D35A2DCC5A6F1AFFD83F80E0115971" originalValue="Blüte" pageId="null" pageNumber="646">Bluete</normalizedToken>
: 
<normalizedToken id="FAF4C6532189267CC3CAD11013A843D3" originalValue="Später" pageId="null" pageNumber="646">Spaeter</normalizedToken>
<normalizedToken id="D6603648DC15DED0D8D857CD1D702832" originalValue="Frühling" pageId="null" pageNumber="646">Fruehling</normalizedToken>
und 
<normalizedToken id="F7680C7FEE40CB793AC54B9B6B0EEB7F" originalValue="früher" pageId="null" pageNumber="646">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="0D6C6C3695E46AD4C789545FF5EEC4A2" pageId="null" pageNumber="646">
<emphasis id="61C68B82F537D718FC0E18CA210A5276" italics="true" pageId="null" pageNumber="646">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0A345B81D8E9E446FBC0761B59AA0D42" italics="true" pageId="null" pageNumber="646">34:</emphasis>
Material aus der Schweiz und 
<normalizedToken id="922D6FD27B20FE0EBFF43A08882303BA" originalValue="Großbritannien" pageId="null" pageNumber="646">Grossbritannien</normalizedToken>
(Glendinning 1960).
</paragraph>
<paragraph id="7ECE50BBC80864E323759E64271003E2" pageId="null" pageNumber="646">
<emphasis id="1C46AD92C5E55DAEFDBA742E887E485C" italics="true" pageId="null" pageNumber="646">Standort.</emphasis>
Kollin.Trockene, lockere, steinige, kalkreiche 
<normalizedToken id="36EB375F47F923CAA893222269F782F3" originalValue="Böden" pageId="null" pageNumber="646">Boeden</normalizedToken>
. Trockenwiesen. 
<emphasis id="BD6245C300A1F1501A5B58F97987A588" italics="true" pageId="null" pageNumber="646">Mesobromion</emphasis>
Br.-Bl. und Moor 1938.
</paragraph>
<paragraph id="CC8CCA985C6C3DC335F1A5E9D70B1A8F" pageId="null" pageNumber="646">
<emphasis id="510E82E04D2F67B71104DA20EE6836D6" italics="true" pageId="null" pageNumber="646">
Verbreitung. 
<normalizedToken id="3DB7C5EB513B5A03B887944140908E4B" originalValue="Westeuropäische" pageId="null" pageNumber="646">Westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Westeuropa (ohne mediterrane Gebiete) 
<normalizedToken id="511BCDD79046617E6A401717D2557DDF" originalValue="ostwärts" pageId="null" pageNumber="646">ostwaerts</normalizedToken>
bis 
<normalizedToken id="8813D6C6DCB2548051D5FF1B017FACD5" originalValue="Großbritannien" pageId="null" pageNumber="646">Grossbritannien</normalizedToken>
, Belgien, Baden, Rhonetal. - Im Gebiet: Westliches Savoyen, Ajoie, Gegend von Belfort, Oberrheinische Tiefebene, 
<normalizedToken id="A617FC71C530618696D4566E71AE8014" originalValue="südliche" pageId="null" pageNumber="646">suedliche</normalizedToken>
Bergamasker Alpen (Carenno?); ziemlich selten.
</paragraph>
</subSubSection>
