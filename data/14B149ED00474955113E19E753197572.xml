<paragraph id="D67EBD0830166306553742510B66E490" pageId="null" pageNumber="818">
<taxonomicName id="729A0EC4D90EE52E60F9E156CE4D8ABF" authority="L." class="Magnoliopsida" family="Caryophyllaceae" genus="Cerastium" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="818" phylum="Tracheophyta" rank="species" species="arvense">
