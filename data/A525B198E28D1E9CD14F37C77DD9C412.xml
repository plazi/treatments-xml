<subSubSection id="218FA0F16F36A8640D540952DB832C8B" pageId="null" pageNumber="286" type="description">
<paragraph id="E5C72ECCE124E256488FFE7B21AAFE79" pageId="null" pageNumber="286">
Ausdauernd. 
<normalizedToken id="9D5CF48545C851523EADC88F969AEBC7" originalValue="Blütenstand" pageId="null" pageNumber="286">Bluetenstand</normalizedToken>
eine 
<normalizedToken id="02A4C19244E768B59D2B4FC3728DC8BA" originalValue="knäuelige" pageId="null" pageNumber="286">knaeuelige</normalizedToken>
Rispe. 
<normalizedToken id="A31917F1B9DA7386DA2102F96AEB1243" originalValue="Ährchen" pageId="null" pageNumber="286">Aehrchen</normalizedToken>
2 
<normalizedToken id="5DE4E7C03CFFBE924F4DACCD0AF1209E" originalValue="blütig" pageId="null" pageNumber="286">bluetig</normalizedToken>
. 
<normalizedToken id="CB1F1293FB5F020AC6F5E68D60090A49" originalValue="Hüllspelzen" pageId="null" pageNumber="286">Huellspelzen</normalizedToken>
2, die beiden 
<normalizedToken id="E3F4FC6AA9D2886DEB75AB1020B19E32" originalValue="Blüten" pageId="null" pageNumber="286">Blueten</normalizedToken>
<normalizedToken id="5EF88A600E10D49C997B09BFB6092427" originalValue="einschließend" pageId="null" pageNumber="286">einschliessend</normalizedToken>
, flach, gekielt, untere 1nervig, obere 3nervig. 
<emphasis id="77781186AD6B15564C3D003DB958A2D5" italics="true" pageId="null" pageNumber="286">
Untere 
<normalizedToken id="41A2E273AE2F8886BA3A0F86883542F6" originalValue="Blüte" pageId="null" pageNumber="286">Bluete</normalizedToken>
zwitterig, mit nicht begrannter Deckspelze. Obere 
<normalizedToken id="40A45088DDDF0D22403D37788B180775" originalValue="Blüte" pageId="null" pageNumber="286">Bluete</normalizedToken>
</emphasis>
♂, 
<emphasis id="AF474DF41BCE8678E7CBA20BAB837A99" italics="true" pageId="null" pageNumber="286">
mit auf dem 
<normalizedToken id="CE8FF7DF1CC66030AD216DBD400B2098" originalValue="Rücken" pageId="null" pageNumber="286">Ruecken</normalizedToken>
begrannter Deckspelze.
</emphasis>
</paragraph>
<paragraph id="9969B86C99BB7668286CB4F765E67809" pageId="null" pageNumber="286">
Die Gattung 
<taxonomicName id="6F79F65880CBE1A2E4F2266058D31128" class="Liliopsida" family="Poaceae" genus="Holcus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="286" phylum="Tracheophyta" rank="genus">
<emphasis id="A480A47BACF2AA74803E406FDB77CCE0" italics="true" pageId="null" pageNumber="286">Holcus</emphasis>
</taxonomicName>
<normalizedToken id="65036567FE4A352A229588B62B88A4FF" originalValue="umfaßt" pageId="null" pageNumber="286">umfasst</normalizedToken>
<emphasis id="0C1161EF69AB49D00143E5A84E687727" italics="true" pageId="null" pageNumber="286">
etwa 10 Arten, die in Eurasien, Nord- und 
<normalizedToken id="D9606351BC0BF951628097E1BBF82C3B" originalValue="Südafrika" pageId="null" pageNumber="286">Suedafrika</normalizedToken>
vorkommen.
</emphasis>
Die Chromosomenzahlen bilden eine 
<emphasis id="F22D3C435AFA44A70A072E298ED53E73" italics="true" pageId="null" pageNumber="286">polyploide Reihe</emphasis>
: 2n = 14, 28, 35, 42, 49; aus experimentellen Untersuchungen sind auch viele 
<emphasis id="BA710E39410857410C9B35C16A411054" italics="true" pageId="null" pageNumber="286">aneuploide</emphasis>
Chromosomenzahlen bekannt, doch werden solche an Pflanzen aus 
<normalizedToken id="DF76827ED2025A16C80456AC3764BF32" originalValue="natürlichen" pageId="null" pageNumber="286">natuerlichen</normalizedToken>
Populationen nur sehr selten gefunden.
</paragraph>
<paragraph id="DFDDA117E84B611D245F0208B4B91BF7" pageId="null" pageNumber="286">
<table id="78898979A9BEB91552B2D6A493B93D52" frame="void" pageId="null" pageNumber="286" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="211AF38C47E1E7D1F422666F8A2FAEA2" pageId="null" pageNumber="286">
<tr id="ADE00989CC5B0577F45015664DBF971B" pageId="null" pageNumber="286">
<td id="406CDDA077E2B16F689B6119E97E550D" align="left" pageId="null" pageNumber="286" valign="top">
1. Pflanze meist weich behaart, selten fast kahl; Granne der Deckspelze der ♂ 
<normalizedToken id="EB2F788A072AC9E27565FDFA3EC4F156" originalValue="Blüte" pageId="null" pageNumber="286">Bluete</normalizedToken>
die 
<normalizedToken id="CFD2405D6684390C9195DE09CB727F4A" originalValue="Hüllspelzen" pageId="null" pageNumber="286">Huellspelzen</normalizedToken>
nicht oder nur wenig 
<normalizedToken id="0B2A4152FA239FCC7FEA6289016CF5B4" originalValue="überragend" pageId="null" pageNumber="286">ueberragend</normalizedToken>
</td>
<td id="74F2B455A650611FFCDEB0D194034DB0" align="left" pageId="null" pageNumber="286" valign="bottom">
<taxonomicName id="14C5F9862FFA96846F3260772176BC7E" class="Liliopsida" family="Poaceae" genus="Holcus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="286" phylum="Tracheophyta" rank="species" species="lanatus">
<italic id="30EA1F0A6361C16BE0607F5187E5AD90" pageId="null" pageNumber="286">H. lanatus</italic>
</taxonomicName>
(Nr. 1)
</td>
</tr>
<tr id="06EBF6D1ABD1A234218236190650BA81" pageId="null" pageNumber="286">
<td id="9124B0346CB7796348792EA8036C3EA1" align="left" pageId="null" pageNumber="286" valign="top">
1*. Pflanze an den Halmknoten 
<normalizedToken id="37A2E48379711BF4A05C3B19F5894C48" originalValue="bärtig" pageId="null" pageNumber="286">baertig</normalizedToken>
behaart, sonst kahl oder zerstreut behaart; Granne der Deckspelze der ♂ 
<normalizedToken id="EE1507F77EA8B01DBF7CA3456FBEBA36" originalValue="Blüte" pageId="null" pageNumber="286">Bluete</normalizedToken>
die 
<normalizedToken id="0BA73A930D239BCFB480EC70CA11B78E" originalValue="Hüllspelzen" pageId="null" pageNumber="286">Huellspelzen</normalizedToken>
etwa um ⅓ ihrer 
<normalizedToken id="1CF286F03B552AC0236FE5143364D540" originalValue="Länge" pageId="null" pageNumber="286">Laenge</normalizedToken>
<normalizedToken id="0B7CB6FF8015B5E2BAA23D143D4BBC00" originalValue="überragend" pageId="null" pageNumber="286">ueberragend</normalizedToken>
</td>
<td id="395A09307E43A27D9EF9F8E01B23D605" align="left" pageId="null" pageNumber="286" valign="bottom">
<taxonomicName id="9AF03A9CF65663694DCF9C3EDEFA0C3A" class="Liliopsida" family="Poaceae" genus="Holcus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="286" phylum="Tracheophyta" rank="species" species="mollis">
<italic id="6BF28D15F7FDC303FA81FFC8F83456A4" pageId="null" pageNumber="286">H. mollis</italic>
</taxonomicName>
(Nr. 2)
</td>
</tr>
</tbody>
</table>
</paragraph>
