<subSubSection id="2D820877818A348BFC020507BEB80883" pageId="null" pageNumber="590" type="nomenclature">
<paragraph id="6C25AD6862C7F3EDCFDB1DC2F509F55E" pageId="null" pageNumber="590">
<taxonomicName id="BF17F26C09853140C745530D02CD9068" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Lactuca" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="sativa">
<pageBreakToken id="74EC89148D40B3E1AEF3B5331F9A1B0E" pageId="null" pageNumber="590" start="start">Lactuca</pageBreakToken>
<normalizedToken id="D82A2A06E046941BB4DE69EF05FEE72B" originalValue="satíva" pageId="null" pageNumber="590">sativa</normalizedToken>
<authorityName id="7BB735A24A417FCE88EAD66986318589" pageId="null" pageNumber="590">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="DD4E5480A3BD00A7567C75FFCEFAFB83" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="85ADB7483B58F72D4F5B5165E713F42F" pageId="null" pageNumber="590">Kopfsalat</paragraph>
</subSubSection>
</title>
<subSubSection id="59625F69EAABF2017F5037D302B4598D" pageId="null" pageNumber="590" type="description">
<paragraph id="8063ACA2E60DC5194770924F7A1B02A1" pageId="null" pageNumber="590">
1-2 
<normalizedToken id="25D5457C3FBEC8D62EF0E75027242B76" originalValue="jährig" pageId="null" pageNumber="590">jaehrig</normalizedToken>
, mit Pfahlwurzel; 30-100 cm hoch. Stengel aufrecht, kahl, im obern Teil stark verzweigt. 
<emphasis id="54B75313EC287530AEFDEB39D9503C71" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="6152F2D55239A16C3DEF486F60DEFE70" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
weich, kahl
</emphasis>
, 
<normalizedToken id="A29CB31518058D0025D320136ABEB999" originalValue="gelbgrün" pageId="null" pageNumber="590">gelbgruen</normalizedToken>
, breit oval, ganzrandig oder buchtig 
<normalizedToken id="B9F1E994E936FAB0A12AA2950885E4E2" originalValue="gezähnt" pageId="null" pageNumber="590">gezaehnt</normalizedToken>
; 
<emphasis id="4ADCB56769FC12F5504805B448B7FCA8" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="CFC987D76679774358C98B96B505CEE2" originalValue="Zähne" pageId="null" pageNumber="590">Zaehne</normalizedToken>
nicht steif.
</emphasis>
<normalizedToken id="2BCF221F93E2EBC667EE4512E5560BC7" originalValue="Stengelblätter" pageId="null" pageNumber="590">Stengelblaetter</normalizedToken>
mit horizontaler Spreite, nicht schmal lanzettlich, 
<normalizedToken id="B5051025E5D541915FEFB75B97AE31F5" originalValue="gezähnt" pageId="null" pageNumber="590">gezaehnt</normalizedToken>
, sitzend, den Stengel mit 2 breiten, meist spitzen Zipfeln umfassend. 
<normalizedToken id="B600CAA08F96B772AF839399E661FD70" originalValue="Blütenköpfe" pageId="null" pageNumber="590">Bluetenkoepfe</normalizedToken>
in einer doldenartigen Rispe, mehr als 5 
<normalizedToken id="D067D534462EDBE1322B3D2D47155909" originalValue="blütig" pageId="null" pageNumber="590">bluetig</normalizedToken>
. 
<normalizedToken id="3DCE5F7B3DAE16B1FF14F1A7F67D71F5" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
8-15 mm lang, zur Fruchtzeit nach unten gebogen. Krone hellgelb (auch getrocknet), 1-2 cm lang. 
<normalizedToken id="A73C2A16A905657BBB8B03A455DBF5BE" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
wie 
<taxonomicName id="2EFEB324392B81F9DD54C02C88B2B2C3" class="Magnoliopsida" family="Asteraceae" genus="Lactuca" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="serriola">
<emphasis id="53CAF7CA359A9DBEC87144365233CBF0" italics="true" pageId="null" pageNumber="590">
<authorityName id="873B6AA04D491AFBDB21BE6ECB477071" pageId="null" pageNumber="590">L.</authorityName>
Serriola
</emphasis>
</taxonomicName>
(Nr. 6). - 
<normalizedToken id="AD2F19352CA82E4B4A19576E0B50907E" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="3C975D033A5F21AB264C40F246F45889" pageId="null" pageNumber="590">
<emphasis id="65B5DE7599AF052604CB3AC939985461" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="74EF22E1B6D7F5C888803286E75DFC21" italics="true" pageId="null" pageNumber="590">18:</emphasis>
Material aus Kulturen (Gates und Rees 1921, Whitaker und Jagger 1939, Thompson et al. 1941, Lindqvist 1960, Chatterjee und Sharma 1969).
</paragraph>
<paragraph id="A49658A22ED1C7E87CD08130E6B414FB" pageId="null" pageNumber="590">
<emphasis id="B357969BD939CDEA4772B07469F1C02B" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Kollin, montan und subalpin. Lockere, 
<normalizedToken id="E03C4EED184CA8EA37099F1E326E4AB2" originalValue="nährstoffreiche" pageId="null" pageNumber="590">naehrstoffreiche</normalizedToken>
, humose, lehmige 
<normalizedToken id="6067469158448D139B3652D47011D095" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
. 
<normalizedToken id="FDECFE28D47C277AA24AC36151688ECE" originalValue="Schuttplätze" pageId="null" pageNumber="590">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="52851A3B4E245FC7AFCD7202B18F4F24" pageId="null" pageNumber="590">
<emphasis id="FBED03AC5D7984113E62AD89E2A4B197" italics="true" pageId="null" pageNumber="590">
<pageBreakToken id="3B2AAB226BB709A366EAFA410C803719" pageId="null" pageNumber="590">Verbreitung</pageBreakToken>
.
</emphasis>
Nur als Kulturpflanze bekannt. - Im Gebiet 
<normalizedToken id="AB1C14A73149F194D5D232F4F8E3D9BB" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
als Salatpflanze angebaut und selten verwildert.
</paragraph>
<paragraph id="1E0812C2C8E60C7B4EE99E736F65AE94" pageId="null" pageNumber="590">
<emphasis id="3CFA62CD059FCC8CDF44637F74D085F6" italics="true" pageId="null" pageNumber="590">Bemerkungen.</emphasis>
Die in ihren vegetativen Teilen 
<normalizedToken id="37392E49BF1111FC83F57B02DAA6BEC4" originalValue="äußerst" pageId="null" pageNumber="590">aeusserst</normalizedToken>
vielgestaltige Pflanze (Kopfsalat, Sommerendivie oder 
<normalizedToken id="AB2ACF6E343761705BA97EE08D0B89FE" originalValue="Gemüselattich" pageId="null" pageNumber="590">Gemueselattich</normalizedToken>
, Schnittsalat) ist eine alte Kulturpflanze, die zuerst in 
<normalizedToken id="F55399437A9740D2706979E7F65BABD0" originalValue="Ägypten" pageId="null" pageNumber="590">Aegypten</normalizedToken>
gepflanzt wurde. 
<normalizedToken id="3D644DEF2CC10AE6C6172B99A1005FB7" originalValue="Über" pageId="null" pageNumber="590">Ueber</normalizedToken>
die wahrscheinliche Entstehung von 
<taxonomicName id="EC75E02030646652A16408D5F979658F" class="Magnoliopsida" family="Asteraceae" genus="Lactuca" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="sativa">
<emphasis id="B2DC16A6795FB117EA53A09EB39265A1" italics="true" pageId="null" pageNumber="590">
<authorityName id="E74DABA724A01DA4248CF28BDF3FC9F9" pageId="null" pageNumber="590">L.</authorityName>
sativa
</emphasis>
</taxonomicName>
vgl. Lindqvist (1960a).
</paragraph>
</subSubSection>
