<typeStatus id="5C4C8864A9196617FE8DFDBFFE57973E" box="[381,495,564,590]" pageId="5" pageNumber="6">Holotype</typeStatus>
: body length 
<quantity id="440F9B23A9196617FD7CFDBFFD51973E" box="[652,745,564,590]" metricMagnitude="-3" metricUnit="m" metricValue="9.4" pageId="5" pageNumber="6" unit="mm" value="9.4">9.4 mm</quantity>
; forewing length 
<quantity id="440F9B23A9196617FC47FDBFFB9B973E" box="[951,1059,564,590]" metricMagnitude="-2" metricUnit="m" metricValue="1.23" pageId="5" pageNumber="6" unit="mm" value="12.3">12.3 mm</quantity>
