<subSubSection id="ADC5AF6E7DF21F1AD9E03DBC360BF28F" pageId="null" pageNumber="210" type="nomenclature">
<paragraph id="7EDDE26110621B73B0F6BB69A26B5140" pageId="null" pageNumber="210">
<taxonomicName id="0DF61C65354465839605DD993F8CCA30" authority="L." class="Liliopsida" family="Scheuchzeriaceae" genus="Scheuchzeria" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="210" phylum="Tracheophyta" rank="species" species="palustris">
<pageBreakToken id="302FF9ABB2DFBCB5B38D03C34F703E58" pageId="null" pageNumber="210">Scheuchzeria</pageBreakToken>
<normalizedToken id="00BA54582F14815B378B07EEB90C5F39" originalValue="palústris" pageId="null" pageNumber="210">palustris</normalizedToken>
<authorityName id="CEEC3B57AE2B9A7B26D1E2890ACDF744" pageId="null" pageNumber="210">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="AA285C6FFEDDB428477B95552CDB4247" pageId="null" pageNumber="210" type="vernacular_names">
<paragraph id="A6065CA30CFEAB6A398E28879A3F47FD" pageId="null" pageNumber="210">Sumpf-Blumenbinse</paragraph>
</subSubSection>
</title>
<subSubSection id="145C1C530990E8E4EC0AEBA6013B9B00" pageId="null" pageNumber="210" type="description">
<paragraph id="3E156EB8B4289FA15BF519FD1C7516C7" pageId="null" pageNumber="210">
Ausdauernde, 10-20 cm hohe, aufrechte, lange, unterirdische 
<normalizedToken id="970D5E9BD6F661CBF23478856FCE376A" originalValue="Ausläufer" pageId="null" pageNumber="210">Auslaeufer</normalizedToken>
treibende Sumpfpflanze. Rhizom von verwitterten Blattscheiden umgeben. Stengel oft deutlich zickzackartig hin und 
<pageBreakToken id="0441B46F33D4412CE42B81A155016E50" pageId="null" pageNumber="210">her</pageBreakToken>
gebogen. 
<normalizedToken id="8F191427B622BDB4B286391F6D57670E" originalValue="Blätter" pageId="null" pageNumber="210">Blaetter</normalizedToken>
grasblattartig, bis 30 cm lang, hohlrinnig, am Grunde mit einer bis 3 cm langen, 
<normalizedToken id="CBA6B379BA68187D4094D14A1F238811" originalValue="häutig" pageId="null" pageNumber="210">haeutig</normalizedToken>
berandeten Scheide; 
<emphasis id="4AFF5B5BA1F33DE90625E0063EC71ADB" italics="true" pageId="null" pageNumber="210">
Blattspitze mit grubiger Pore. 
<normalizedToken id="AE2F21F1B5F05DE88CCE013E64666FF1" originalValue="Tragblätter" pageId="null" pageNumber="210">Tragblaetter</normalizedToken>
der untern 
<normalizedToken id="51530C3D92B27583C1016A2CB8A702C5" originalValue="Blüten" pageId="null" pageNumber="210">Blueten</normalizedToken>
<normalizedToken id="11DE9144F12981229E621F25340E1A2D" originalValue="groβ" pageId="null" pageNumber="210">groβ</normalizedToken>
, laubblattartig, die der obern 
<normalizedToken id="6620CA77A9BECB4D6640340E65D5A23A" originalValue="häutig" pageId="null" pageNumber="210">haeutig</normalizedToken>
, schuppenartig.
</emphasis>
<normalizedToken id="D78BF7903910CFC2DE28BD9CD85E0488" originalValue="Blütenstiele" pageId="null" pageNumber="210">Bluetenstiele</normalizedToken>
schief aufrecht, bis 1 cm lang. 
<normalizedToken id="F446DE40E44D772B0BE0DFF8128E944A" originalValue="Perigonblätter" pageId="null" pageNumber="210">Perigonblaetter</normalizedToken>
lanzettlich, 2-3 mm lang, 0,8-1,5 mm breit, 
<normalizedToken id="F81A7855D81603CD835FB57406B4BBB7" originalValue="gelbgrün" pageId="null" pageNumber="210">gelbgruen</normalizedToken>
. 
<normalizedToken id="BFC255284243E400A2819E7078D5789A" originalValue="Früchtchen" pageId="null" pageNumber="210">Fruechtchen</normalizedToken>
kugelig bis 
<normalizedToken id="15200D9773DAC33F057CE98C8771DE1A" originalValue="eiförmig" pageId="null" pageNumber="210">eifoermig</normalizedToken>
, 5-7 mm lang, mit sitzender Narbe. - 
<normalizedToken id="05F42BC48E1C9F201675A9CA0B27421C" originalValue="Blüte" pageId="null" pageNumber="210">Bluete</normalizedToken>
: 
<normalizedToken id="C201F25E1A805999D9A5FE53F2BE74B2" originalValue="Frühling" pageId="null" pageNumber="210">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="70D1814232EA3E3EFEF205DA1A88E08A" pageId="null" pageNumber="210">
<emphasis id="8A7AEF9A8C963479D0EB35F25F1DBB5C" italics="true" pageId="null" pageNumber="210">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="820F15E1CD65E4E1D089D4CAD4DF7DA4" italics="true" pageId="null" pageNumber="210">22:</emphasis>
Material von 1 Fundort in England (Manton 1949), ohne Herkunftsangabe (Harada 1956), aus Kanada (
<normalizedToken id="FBABEC6B1095EC2DAC2FE2131ED4B155" originalValue="Löve" pageId="null" pageNumber="210">Loeve</normalizedToken>
und 
<normalizedToken id="5B3F954D65135264C7BDD21AD8AEC732" originalValue="Löve" pageId="null" pageNumber="210">Loeve</normalizedToken>
1961, 
<normalizedToken id="348962D35CEAE153BABD1C4EE92A0AFE" originalValue="Löve" pageId="null" pageNumber="210">Loeve</normalizedToken>
und Ritchie 1966).
</paragraph>
<paragraph id="07E26DDB7A7FA16900E6C4BC5B11FEC9" pageId="null" pageNumber="210">
<emphasis id="C2CC99C1659EB87498A0B63E0C785DE3" italics="true" pageId="null" pageNumber="210">Standort.</emphasis>
Kollin, montan und subalpin. In Schlenken (flach 
<normalizedToken id="AE6C35AF578A21E67230F95D1D20C85B" originalValue="überschwemmte" pageId="null" pageNumber="210">ueberschwemmte</normalizedToken>
<normalizedToken id="D14FC58A1A8F3CAA61A79235860BA008" originalValue="TorfSchlammböden" pageId="null" pageNumber="210">TorfSchlammboeden</normalizedToken>
) und auf Schwingrasen von Hochmooren; 
<taxonomicName id="4D3DDEC14ECCF6A1BCE115C8AD9BF07F" authority="Br." authorityName="Br." class="Lycopodiopsida" family="Lycopodiaceae" genus="Caricetum" kingdom="Plantae" order="Lycopodiales" pageId="null" pageNumber="210" phylum="Tracheophyta" rank="species" species="limosae">
<emphasis id="ECE06FC063377249EE16D5981CE15379" italics="true" pageId="null" pageNumber="210">Caricetum limosae</emphasis>
Br.
</taxonomicName>
-Bl. 1921. Auch in einer sehr feuchten Variante des 
<emphasis id="E8903ACAD7085F3F0AC8D676B3EBA388" italics="true" pageId="null" pageNumber="210">Rhynchosporetum</emphasis>
W. Koch 1926.
</paragraph>
<paragraph id="E48BC772E511E287EE1CA5DBDC33F721" pageId="null" pageNumber="210">
<emphasis id="4E5C9010AFB8D7D16CE4873A417DCE5A" italics="true" pageId="null" pageNumber="210">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
<normalizedToken id="8A52BAC96189692EF8EB61238AD595E0" originalValue="Nordwärts" pageId="null" pageNumber="210">Nordwaerts</normalizedToken>
bis Nordskandinavien (70° NB) (aus Island nur 1 Fundstelle), im Ural bis zum Polarkreis, sonst in Sibirien nicht 
<normalizedToken id="D528401D7BA876E3703E481A6669A205" originalValue="über" pageId="null" pageNumber="210">ueber</normalizedToken>
65° NB, 
<normalizedToken id="595EFB0FB8870D4FE492838EFC708CE9" originalValue="südwärts" pageId="null" pageNumber="210">suedwaerts</normalizedToken>
bis 
<normalizedToken id="BAD5C1537EAD3314DDF86F4386727322" originalValue="Pyrenäen" pageId="null" pageNumber="210">Pyrenaeen</normalizedToken>
(?), Norditalien, 
<normalizedToken id="46A54C1ADC86ADFAFB82AA1C5983E262" originalValue="nördliche" pageId="null" pageNumber="210">noerdliche</normalizedToken>
Balkanhalbinsel, Kaukasus; in Asien (ausgenommen chinesische 
<normalizedToken id="085C6C6A6B64F931DB8E99272B596DF9" originalValue="Küstengebiete" pageId="null" pageNumber="210">Kuestengebiete</normalizedToken>
und Japan) 
<normalizedToken id="40FCC01645498BF8E4CD643EBB47C547" originalValue="südwärts" pageId="null" pageNumber="210">suedwaerts</normalizedToken>
bis ca. 50° NB; in Nordamerika die eurosibirische Sippe nur in einem kleinen, atlantischen Gebiet 
<normalizedToken id="1F7DDECA6E12BBCCE04E37BC5186D864" originalValue="südlich" pageId="null" pageNumber="210">suedlich</normalizedToken>
der St. 
<normalizedToken id="25A5C0B6AE1DF98E5413C505B85B0F98" originalValue="Lorenz-Mündung" pageId="null" pageNumber="210">Lorenz-Muendung</normalizedToken>
; in Nordamerika von Alaska und Neufundland 
<normalizedToken id="576AF2D3E18DE5653501B1E26BFEDA7A" originalValue="südwärts" pageId="null" pageNumber="210">suedwaerts</normalizedToken>
bis ca. 35° NB die 
<taxonomicName id="2E4F06CD2CB0B93BD62BE4FBBF4CE3BD" authority="Fern. Verbreitungskarten von Hulten (1962)" pageId="null" pageNumber="210" rank="variety" variety="americana">
var. 
<emphasis id="4D578F045B42D60DF2CB63E89CB60701" italics="true" pageId="null" pageNumber="210">americana</emphasis>
Fern. Verbreitungskarten von 
<normalizedToken id="1D88E142ED7ED4854F74C59E5BEBBE3F" originalValue="Hultén" pageId="null" pageNumber="210">Hulten</normalizedToken>
(1962)
</taxonomicName>
und Meusel (1964).- Im Gebiet zerstreut und ziemlich selten.
</paragraph>
</subSubSection>
