<collectingMunicipality id="3449A9515911A638FD2FC0028446FCF5" box="[643,808,815,842]" pageId="2" pageNumber="389">Tsegiv village</collectingMunicipality>
, 
<location id="D14D65F05911A638FC9AC002835CFCF5" LSID="urn:lsid:plazi:treatment:5C3B823D5911A638FF0AC26285A4FCD5:D14D65F05911A638FC9AC002835CFCF5" box="[822,1074,815,842]" county="Ruzhynsky District" municipality="Tsegiv village" name="Gorokhivsky District" pageId="2" pageNumber="389" stateProvince="Volyn'">Gorokhivsky District</location>
and 
<location id="D14D65F05911A638FBDFC002879AFCD5" LSID="urn:lsid:plazi:treatment:5C3B823D5911A638FF0AC26285A4FCD5:D14D65F05911A638FBDFC002879AFCD5" county="Ruzhynsky District" municipality="Tsegiv village" name="Bubniv village" pageId="2" pageNumber="389" stateProvince="Volyn'">Bubniv village</location>
, 
<location id="D14D65F05911A638FF53C062869FFCD5" LSID="urn:lsid:plazi:treatment:5C3B823D5911A638FF0AC26285A4FCD5:D14D65F05911A638FF53C062869FFCD5" box="[255,497,847,874]" county="Ruzhynsky District" municipality="Tsegiv village" name="Lokachivsky District" pageId="2" pageNumber="389" stateProvince="Volyn'">Lokachivsky District</location>
of 
<collectingRegion id="1656FDC95911A638FDBAC06285D0FCD5" box="[534,702,847,874]" country="Ukraine" name="Volyn'" pageId="2" pageNumber="389">Volyn Region</collectingRegion>
