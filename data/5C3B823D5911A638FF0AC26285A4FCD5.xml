<taxonomicName id="139248A85911A638FF0AC26285F9FED5" authority="(Carter, 1856)" baseAuthorityName="Carter" baseAuthorityYear="1856" box="[166,663,335,362]" class="Lobosa" family="Thecamoebidae" genus="Thecamoeba" kingdom="Protozoa" order="Amoebida" pageId="2" pageNumber="389" phylum="Amoebozoa" rank="species" species="quadrilineata">
<emphasis id="E6E6EF395911A638FF0AC2628685FED5" bold="true" box="[166,491,335,362]" italics="true" pageId="2" pageNumber="389">Thecamoeba quadrilineata</emphasis>
(Carter, 1856)
</taxonomicName>
(
<figureCitation id="4CA92FAE5911A638FD09C262858FFED5" box="[677,737,335,362]" captionStart="Fig" captionStartId="2.[166,199,1821,1843]" captionTargetBox="[166,1225,1287,1784]" captionTargetPageId="2" captionText="Fig. 2. Thecamoeba quadrilineata, locomotory forms (a, b). x1240." figureDoi="http://doi.org/10.5281/zenodo.6449223" httpUri="https://zenodo.org/record/6449223/files/figure.png" pageId="2" pageNumber="389">fig. 2</figureCitation>
)
</paragraph>
