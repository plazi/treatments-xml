<emphasis id="ABD046063544FFE4FE758AE65731D1F2" box="[418,564,1689,1715]" italics="true" pageId="10" pageNumber="463">flavigenualis</emphasis>
</taxonomicName>
, 
<emphasis id="ABD046063544FFE4FD938AE55753D1F2" box="[580,598,1690,1715]" italics="true" pageId="10" pageNumber="463">
<collectionCode id="FFB502D13544FFE4FD938AE55753D1F2" box="[580,598,1690,1715]" country="Chile" name="Departamento de Geologia, Universidad de Chile" pageId="10" pageNumber="463">R</collectionCode>
</emphasis>
. sp. near 
<taxonomicName id="5EA4E1973544FFE4FD198AE65665D1F2" authorityName="Hering" authorityYear="1958" box="[718,864,1689,1715]" class="Insecta" family="Tephritidae" genus="Rhagoletis" kingdom="Animalia" order="Diptera" pageId="10" pageNumber="463" phylum="Arthropoda" rank="species" species="flavigenualis">
