<subSubSection id="E7A079C0EB9D1970A4B208C84538D93B" pageId="null" pageNumber="254" type="nomenclature">
<paragraph id="7327B9086B4943E53FA0257D3E011DE5" pageId="null" pageNumber="254">
<taxonomicName id="15368D3B53EE1D0319E4D585EDAC8556" authority="Thuill." class="Magnoliopsida" family="Orobanchaceae" genus="Orobanche" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="254" phylum="Tracheophyta" rank="species" species="amethystea">
<pageBreakToken id="8C0EC6754FD9CB68698F58E3A269A447" pageId="null" pageNumber="254" start="start">Orobanche</pageBreakToken>
<normalizedToken id="E787841A664EAF08BA72E075BCD5B4EE" originalValue="amethýstea" pageId="null" pageNumber="254">amethystea</normalizedToken>
Thuill.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="02F2AB049462CA661CB02444DD96539C" pageId="null" pageNumber="254" type="vernacular_names">
<paragraph id="54B5F33A0F8EC792F353947DEB25BD01" pageId="null" pageNumber="254">Amethystblaue Sommerwurz</paragraph>
</subSubSection>
</title>
<subSubSection id="FDD5FD1BE15150CF8581712A18BECEFB" pageId="null" pageNumber="254" type="description">
<paragraph id="5ECD380A7858F8AB4488D2E0988994EE" pageId="null" pageNumber="254">
Stengel 10-45 cm hoch, violett. Tragblatt fast so lang wie die 
<normalizedToken id="FA6CC71E20D0B9D02FE0F4E60C45790B" originalValue="Blüte" pageId="null" pageNumber="254">Bluete</normalizedToken>
, 
<emphasis id="1A96FA5A12FF2AFFDFD4DF9B19294C05" italics="true" pageId="null" pageNumber="254">am Grunde 2</emphasis>
- 
<emphasis id="7E12655AEC3DDFDB867CE81DBCC13516" italics="true" pageId="null" pageNumber="254">3 mm breit.</emphasis>
<normalizedToken id="51DF16A0F3DD1385A628586621EE445A" originalValue="Vorblätter" pageId="null" pageNumber="254">Vorblaetter</normalizedToken>
nicht vorhanden. Kelch wie bei 
<taxonomicName id="DBA3F4D282B5A633537BF97ABE55D1DD" class="Magnoliopsida" family="Orobanchaceae" genus="Orobanche" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="254" phylum="Tracheophyta" rank="species" species="cernua">
<emphasis id="8634D1964145AB3098C3274E71E70BE1" italics="true" pageId="null" pageNumber="254">O. cernua</emphasis>
</taxonomicName>
(Nr. 4). Krone 15-23 mm lang, oberhalb des 
<pageBreakToken id="745353F2B5B14103F7578C7F3B541738" pageId="null" pageNumber="254">Fruchtknotens</pageBreakToken>
4-6 mm im Durchmesser, 
<emphasis id="5911763EC80D31A21308A205D57DECC6" italics="true" pageId="null" pageNumber="254">
<normalizedToken id="187BF62878B6E4EE4AEA957F3B49AF6E" originalValue="über" pageId="null" pageNumber="254">ueber</normalizedToken>
dem Fruchtknoten deutlich gebogen
</emphasis>
(
<emphasis id="9E85BF4C01A983E2620546C2A0788E12" italics="true" pageId="null" pageNumber="254">abgewinkelt</emphasis>
), 
<emphasis id="6D520B5E011FC72C61B0A3BAE741655E" italics="true" pageId="null" pageNumber="254">im vordern Teil fast gerade</emphasis>
, mit vereinzelten hellen oder 
<normalizedToken id="9F47ACF418DBD01C8EAEC7D8FBE23D8D" originalValue="gefärbten" pageId="null" pageNumber="254">gefaerbten</normalizedToken>
<normalizedToken id="7C9DBC5BA2F29726A140EA9BC8787060" originalValue="Drüsenhaaren" pageId="null" pageNumber="254">Druesenhaaren</normalizedToken>
, 
<emphasis id="4F44A81AB9F7EF5B6FD256E3A4B4BBE8" italics="true" pageId="null" pageNumber="254">
<normalizedToken id="D35D7D01D7D2DA98E2F35B203E52C6F3" originalValue="weiß" pageId="null" pageNumber="254">weiss</normalizedToken>
, mit violetten oder amethystblauen Adern;
</emphasis>
der mittlere Zipfel der Unterlippe wenig 
<normalizedToken id="7D9D13E7BBB8EE5158B9609EF85CA427" originalValue="größer" pageId="null" pageNumber="254">groesser</normalizedToken>
als die seitlichen. 
<normalizedToken id="D45CB57A1CFDD53694C41E5FA8A7B129" originalValue="Staubfäden" pageId="null" pageNumber="254">Staubfaeden</normalizedToken>
3-4 mm 
<normalizedToken id="431AAEC2EDB38E1BF9812A5F6C13C755" originalValue="über" pageId="null" pageNumber="254">ueber</normalizedToken>
dem Grunde der Krone 
<normalizedToken id="23C5433E9565E4D70E620231036C13DF" originalValue="eingefügt" pageId="null" pageNumber="254">eingefuegt</normalizedToken>
, unten mit 
<normalizedToken id="341263B0994EC61046280236CC101575" originalValue="drüsenlosen" pageId="null" pageNumber="254">druesenlosen</normalizedToken>
Haaren. 
<emphasis id="50A093089CD97B218F77A906F0A42DAA" italics="true" pageId="null" pageNumber="254">Narbe violett oder rotbraun.</emphasis>
- 
<normalizedToken id="1AC76D0F825A8F8F794FF2ACDF81ECBF" originalValue="Blüte" pageId="null" pageNumber="254">Bluete</normalizedToken>
: 
<normalizedToken id="214654A3B9411DBC9C228DD66DABBE9D" originalValue="Früher" pageId="null" pageNumber="254">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="3F33E9C0743984D187A92B284E68E817" pageId="null" pageNumber="254">
<emphasis id="27D109A396F31605ACA42D3AB0DCD3BD" italics="true" pageId="null" pageNumber="254">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="814D45AFA8981BC2992A8E01E63C85D4" pageId="null" pageNumber="254">
<emphasis id="8371F002FD14B94B6544E4A9EC79AF4C" italics="true" pageId="null" pageNumber="254">Standort.</emphasis>
Kollin. Trockene, lockere, meist kalkhaltige 
<normalizedToken id="CAC316C194C185E05CDF15219A6D3FBE" originalValue="Böden" pageId="null" pageNumber="254">Boeden</normalizedToken>
in warmen Lagen. Trockenrasen. - Auf 
<taxonomicName id="F3C2099EE718728BCB6558D6F3FB86CA" class="Magnoliopsida" family="Apiaceae" genus="Eryngium" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="254" phylum="Tracheophyta" rank="genus">
<emphasis id="9D1D4F20EA7F7E134C7EFE61DDADED5C" italics="true" pageId="null" pageNumber="254">Eryngium</emphasis>
</taxonomicName>
arten, selten auch auf andern Pflanzen.
</paragraph>
<paragraph id="A313419B304BF6B02CCF743500A80FC1" pageId="null" pageNumber="254">
<emphasis id="C167E5F8D9948D9634AEF078311D897C" italics="true" pageId="null" pageNumber="254">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="4C99F0AC7E754C5CAE2F4EA412831455" originalValue="Südeuropa" pageId="null" pageNumber="254">Suedeuropa</normalizedToken>
(
<normalizedToken id="5E3C5788DEC790DE96FA8999063FB408" originalValue="nordwärts" pageId="null" pageNumber="254">nordwaerts</normalizedToken>
vereinzelt bis 
<normalizedToken id="A3A4413A588E902DB5C98F36AA8E8895" originalValue="Südengland" pageId="null" pageNumber="254">Suedengland</normalizedToken>
, Mittelrhein, Alpen, Bulgarien); Kleinasien; Nordwestafrika. - Im Gebiet: Oberrheinische Tiefebene (Istein, Kaiserstuhl, Staufen, Heiteren, Neuf-Brisach, Bollenberg), Savoyen (Maurienne), Veltlin (Sondrio); selten.
</paragraph>
</subSubSection>
