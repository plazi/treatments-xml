(
<bibRefCitation id="8B4703C7FFFAFFD1FE71FE9AFDBAFE23" author="BALY" box="[397,516,380,403]" firstAuthor="BALY" pageId="32" pageNumber="307" pagination="83 - 90" refId="ref47482" refString="BALY J. S. 1869: Characters of some undescribed species of Phytophaga belonging to the families Cassidinae and Hispidae. Transactions of the Entomological Society of London 1869: 83 - 90." type="journal article" year="1869">BALY 1869</bibRefCitation>
