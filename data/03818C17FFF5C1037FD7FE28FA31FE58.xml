<subSubSection id="C3326E8AFFF5C1037FE2FB64FBAFF2A0" box="[189,1078,1238,1265]" pageId="5" pageNumber="230" type="materials_examined">
<paragraph id="8B973D01FFF5C1037FE2FB64FBAFF2A0" blockId="5.[136,1452,482,2057]" box="[189,1078,1238,1265]" pageId="5" pageNumber="230">
Other specimens examined:—Only known from 
<specimenCount id="9D2EF688FFF5C1037DBFFB64FCECF2A1" box="[736,885,1238,1265]" pageId="5" pageNumber="230" type="generic" typeStatus="syntypes">five syntypes</specimenCount>
