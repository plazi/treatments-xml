: 
<taxonomicName id="57E14D7CFFF0BD5A1E09AA7F91F0027F" authority="Assing, 2014" authorityName="Assing" authorityYear="2014" box="[295,469,779,799]" class="Insecta" family="Staphylinidae" genus="Orsunius" kingdom="Animalia" order="Coleoptera" pageId="15" pageNumber="476" phylum="Arthropoda" rank="species" species="cuneatus" status="nov.sp.">
