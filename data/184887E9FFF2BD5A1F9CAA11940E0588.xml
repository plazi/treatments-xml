, 
<collectingCountry id="E8F6766FFFF0BD5A1D39ADA692510588" box="[535,628,1234,1256]" name="Malaysia" pageId="15" pageNumber="476">Malaysia</collectingCountry>
(
<figureCitation id="08DA2A7AFFF0BD5A1DAFADA692E30588" box="[641,710,1234,1256]" captionStart="Map 2" captionStartId="2.[178,223,1075,1095]" captionTargetBox="[178,1092,212,1064]" captionTargetId="figure-2@2.[178,1092,212,1064]" captionTargetPageId="2" captionText="Map 2: Distributions of Orsunius gladiator (white and black circles), O. latexcisus (black circle), O. flavovirgatus (black circle), O. heissi (black star), O. stimulans (black and grey triangles), O. granulosus (white and grey triangles), O. cuneatus (white diamond), and O. spathulatus (black square)." figureDoi="http://doi.org/10.5281/zenodo.5305061" httpUri="https://zenodo.org/record/5305061/files/figure.png" pageId="15" pageNumber="476">Map 2</figureCitation>
