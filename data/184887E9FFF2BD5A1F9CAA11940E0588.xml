<taxonomicName id="57E14D7CFFF0BD5A1DB0AA7F92D4027F" authority="Assing, 2014" authorityName="Assing" authorityYear="2014" box="[670,753,779,799]" class="Insecta" family="Staphylinidae" genus="Orsunius" kingdom="Animalia" order="Coleoptera" pageId="15" pageNumber="476" phylum="Arthropoda" rank="species" species="heissi" status="nov.sp.">
<emphasis id="A295EAEDFFF0BD5A1DB0AA7F92D4027F" box="[670,753,779,799]" italics="true" pageId="15" pageNumber="476">O. heissi</emphasis>
</taxonomicName>
<taxonomicNameLabel id="B9A65796FFF0BD5A1DD7AA7F9319027F" box="[761,828,779,799]" pageId="15" pageNumber="476" rank="species">nov.sp.</taxonomicNameLabel>
(
<emphasis id="A295EAEDFFF0BD5A1C65AA7F93A5027F" bold="true" box="[843,896,779,799]" pageId="15" pageNumber="476">47-48</emphasis>
