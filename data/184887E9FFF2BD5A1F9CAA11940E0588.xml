(
<emphasis id="A295EAEDFFF1BD5B1C1DACB8934D0480" bold="true" box="[819,872,1484,1504]" pageId="14" pageNumber="475">40-43</emphasis>
): (
<emphasis id="A295EAEDFFF1BD5B1CAAACB893980480" bold="true" box="[900,957,1484,1504]" pageId="14" pageNumber="475">36, 40</emphasis>
) habitus; (
<emphasis id="A295EAEDFFF1BD5B1B0EACB890EC0497" bold="true" pageId="14" pageNumber="475">37, 41</emphasis>
) forebody; (
<emphasis id="A295EAEDFFF1BD5B1E10AC97915C0497" bold="true" box="[318,377,1507,1527]" pageId="14" pageNumber="475">38, 42</emphasis>
) aedeagus in lateral view; (
<emphasis id="A295EAEDFFF1BD5B1D54AC9792900497" bold="true" box="[634,693,1507,1527]" pageId="14" pageNumber="475">39, 43</emphasis>
) aedeagus in ventral view. Scale bars: 36- 37, 40-41: 1.0 mm; 38-39, 42-43: 0.2 mm.
</paragraph>
</caption>
