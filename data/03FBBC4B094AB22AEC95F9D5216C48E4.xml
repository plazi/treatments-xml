<subSubSection id="C3485ED6094AB22AEC95F9AA251E4BA0" lastPageId="32" lastPageNumber="483" pageId="30" pageNumber="481" type="etymology">
<paragraph id="8BED0D5D094AB214EC95F9AA20C74C9D" blockId="30.[151,1437,1654,2004]" pageId="30" pageNumber="481">
<emphasis id="B926D14F094AB214EC95F9AA21294CB9" bold="true" box="[151,290,1654,1680]" pageId="30" pageNumber="481">Etymology:</emphasis>
<taxonomicName id="4C5276DE094AB214ED28F9AA21E04CB9" authorityName="Popta" authorityYear="1922" box="[298,491,1654,1680]" class="Actinopterygii" family="Gobiidae" genus="Cryptocentroides" kingdom="Animalia" order="Perciformes" pageId="30" pageNumber="481" phylum="Chordata" rank="genus">
<emphasis id="B926D14F094AB214ED28F9AA21E04CB9" box="[298,491,1654,1680]" italics="true" pageId="30" pageNumber="481">Cryptocentroides</emphasis>
</taxonomicName>
: the Greek, 
<emphasis id="B926D14F094AB214EE7BF9AA22C04CB9" box="[633,715,1654,1680]" italics="true" pageId="30" pageNumber="481">kryptos</emphasis>
= hidden, 
<emphasis id="B926D14F094AB214EF3CF9AA23994CB9" box="[830,914,1654,1680]" italics="true" pageId="30" pageNumber="481">kentron</emphasis>
= sting; 
<taxonomicName id="4C5276DE094AB214EFF3F9AA24584CB9" baseAuthorityName="Gmelin" baseAuthorityYear="1789" box="[1009,1107,1654,1680]" class="Actinopterygii" family="Gobiidae" genus="Cryptocentroides" kingdom="Animalia" order="Perciformes" pageId="30" pageNumber="481" phylum="Chordata" rank="species" species="arabicus">
<emphasis id="B926D14F094AB214EFF3F9AA24584CB9" box="[1009,1107,1654,1680]" italics="true" pageId="30" pageNumber="481">arabicus</emphasis>
</taxonomicName>
: refers to the Arabian Peninsula.
</paragraph>
<paragraph id="8BED0D5D094AB214ECC5F961223F4CF1" blockId="30.[151,1437,1654,2004]" box="[199,564,1725,1752]" pageId="30" pageNumber="481">
<emphasis id="B926D14F094AB214ECC5F961218C4CF1" bold="true" box="[199,391,1725,1752]" pageId="30" pageNumber="481">Common name:</emphasis>
Arabian Goby.
</paragraph>
<paragraph id="8BED0D5D094AB214ECC5F93E23D14D6D" blockId="30.[151,1437,1654,2004]" pageId="30" pageNumber="481">
<emphasis id="B926D14F094AB214ECC5F93E21454CD5" bold="true" box="[199,334,1762,1788]" pageId="30" pageNumber="481">Taxonomy:</emphasis>
<taxonomicName id="4C5276DE094AB214ED5AF93E221E4CD5" authorityName="Gmelin" authorityYear="1789" box="[344,533,1762,1788]" class="Actinopterygii" family="Gobiidae" genus="Gobius" kingdom="Animalia" order="Perciformes" pageId="30" pageNumber="481" phylum="Chordata" rank="species" species="arabicus">
<emphasis id="B926D14F094AB214ED5AF93E221E4CD5" box="[344,533,1762,1788]" italics="true" pageId="30" pageNumber="481">Gobius arabicus</emphasis>
</taxonomicName>
<materialsCitation id="3B3A0700094AB214EE1DF93E23DD4D6D" ID-GBIF-Occurrence="3766721323" country="Saudi Arabia" location="Saudi Arabia" pageId="30" pageNumber="481" specimenCount="1">
was originally described by Gmelin [
<collectorName id="26A7688B094AB214EFCDF93E24084CD5" box="[975,1027,1761,1788]" name="J. Freyhof" pageId="30" pageNumber="481">J. F.</collectorName>
] (ex 
<collectorName id="26A7688B094AB214E840F93D24A84CD5" box="[1090,1187,1761,1788]" pageId="30" pageNumber="481">Forsskål</collectorName>
) 1789:1198 [
<collectorName id="26A7688B094AB214E93EF93E258E4CD5" box="[1340,1413,1762,1788]" pageId="30" pageNumber="481">Caroli</collectorName>
a 
<collectorName id="26A7688B094AB214EC95F8DA20D34D09" box="[151,216,1798,1824]" pageId="30" pageNumber="481">Linné</collectorName>
... 
<collectorName id="26A7688B094AB214ECFEF8DA21B04D09" box="[252,443,1798,1824]" pageId="30" pageNumber="481">Systema Naturae</collectorName>
per regna tria naturae v. 1 (pt 3)] form Jeddah, 
<collectingCountry id="F3454DCD094AB214EFD0F8DA246D4D09" box="[978,1126,1798,1824]" name="Saudi Arabia" pageId="30" pageNumber="481">Saudi Arabia</collectingCountry>
, Red Sea. No 
<typeStatus id="54E9B3FF094AB214E904F8DA254A4D09" box="[1286,1345,1798,1824]" pageId="30" pageNumber="481">types</typeStatus>
known. Based 
<collectedFrom id="384E4EA0094AB214ECE1F8F621D24D6D" box="[227,473,1834,1860]" pageId="30" pageNumber="481">
on 
<taxonomicName id="4C5276DE094AB214ED04F8F621D24D6D" authorityName="Forsskal" authorityYear="1775" box="[262,473,1834,1860]" class="Actinopterygii" family="Gobiidae" genus="Gobius" kingdom="Animalia" order="Perciformes" pageId="30" pageNumber="481" phylum="Chordata" rank="species" species="anguillaris">
<emphasis id="B926D14F094AB214ED04F8F621D24D6D" box="[262,473,1834,1860]" italics="true" pageId="30" pageNumber="481">Gobius anguillaris</emphasis>
</taxonomicName>
</collectedFrom>
(non 
<bibRefCitation id="EFC370AC094AB214EE18F8F622CC4D6D" author="Linnaeus, C." box="[538,711,1833,1860]" pageId="30" pageNumber="481" refId="ref24780" refString="Linnaeus, C. (1758) Systema Naturae. Laurentii Salvii, Stockholm, 824 pp." type="book" year="1758">Linnaeus, 1758</bibRefCitation>
) of Forsskål 1775:x, 23
</materialsCitation>
.
</paragraph>
<paragraph id="8BED0D5D094AB214ECC5F891237F4DFD" blockId="30.[151,1437,1654,2004]" pageId="30" pageNumber="481">
<emphasis id="B926D14F094AB214ECC5F89121404D4E" bold="true" box="[199,331,1869,1895]" pageId="30" pageNumber="481">Synonyms:</emphasis>
<taxonomicName id="4C5276DE094AB214ED53F89222834D41" authority="Forsskal" authorityName="Forsskal" authorityYear="1775" box="[337,648,1869,1896]" class="Actinopterygii" family="Gobiidae" genus="Gobius" kingdom="Animalia" order="Perciformes" pageId="30" pageNumber="481" phylum="Chordata" rank="species" species="anguillaris">
<emphasis id="B926D14F094AB214ED53F89222284D41" box="[337,547,1870,1896]" italics="true" pageId="30" pageNumber="481">Gobius anguillaris</emphasis>
Forsskål
</taxonomicName>
(nec Linnaeus), 1775, Descr. Animalium: 23 (Jidda, 
<collectingCountry id="F3454DCD094AB214E8D0F892256E4D41" box="[1234,1381,1870,1896]" name="Saudi Arabia" pageId="30" pageNumber="481">Saudi Arabia</collectingCountry>
, Red Sea). Misidentification of 
<taxonomicName id="4C5276DE094AB214EDBEF8AE234F4DA5" authority="Linnaeus, 1758" authorityName="Linnaeus" authorityYear="1758" box="[444,836,1905,1932]" class="Actinopterygii" family="Gobiidae" genus="Gobius" kingdom="Animalia" order="Perciformes" pageId="30" pageNumber="481" phylum="Chordata" rank="species" species="anguillaris">
<emphasis id="B926D14F094AB214EDBEF8AE22854DA5" box="[444,654,1906,1932]" italics="true" pageId="30" pageNumber="481">Gobius anguillaris</emphasis>
<bibRefCitation id="EFC370AC094AB214EE97F8AE234F4DA5" author="Linnaeus, C." box="[661,836,1905,1932]" pageId="30" pageNumber="481" refId="ref24780" refString="Linnaeus, C. (1758) Systema Naturae. Laurentii Salvii, Stockholm, 824 pp." type="book" year="1758">Linnaeus, 1758</bibRefCitation>
</taxonomicName>
. 
<taxonomicName id="4C5276DE094AB214EF4CF8AE24E84DA5" authority="Bonnaterre, 1788" authorityName="Bonnaterre" authorityYear="1788" box="[846,1251,1906,1932]" class="Actinopterygii" family="Gobiidae" genus="Gobius" kingdom="Animalia" order="Perciformes" pageId="30" pageNumber="481" phylum="Chordata" rank="species" species="djiddensis">
<emphasis id="B926D14F094AB214EF4CF8AE24134DA5" box="[846,1048,1906,1932]" italics="true" pageId="30" pageNumber="481">Gobius djiddensis</emphasis>
Bonnaterre, 1788
</taxonomicName>
, Tabl. Encyclop. Méthod. Ichthyol. 64 (Red Sea). 
<taxonomicName id="4C5276DE094AB214EE0BF84A23634D99" authority="Gmelin, 1789" authorityName="Gmelin" authorityYear="1789" box="[521,872,1942,1968]" class="Actinopterygii" family="Gobiidae" genus="Gobius" kingdom="Animalia" order="Perciformes" pageId="30" pageNumber="481" phylum="Chordata" rank="species" species="arabicus">
<emphasis id="B926D14F094AB214EE0BF84A22C84D99" box="[521,707,1942,1968]" italics="true" pageId="30" pageNumber="481">Gobius arabicus</emphasis>
<bibRefCitation id="EFC370AC094AB214EEC8F84A23634D99" author="Gmelin, J. F." box="[714,872,1942,1968]" pageId="30" pageNumber="481" pagination="1033 - 1516" refId="ref23788" refString="Gmelin, J. F. (1789) s. n. In: Caroli a Linne ... Systema Naturae per regna tria naturae, secundum classes, ordines, genera, species; cum characteribus, differentiis, synonymis, locis. Editio decimo tertia, aucta, reformata. Vol. 1. Pt. 3. Impensis Georg. Emanuel. Beer, Lipsiae, pp. 1033 - 1516. https: // doi. org / 10.5962 / bhl. title. 36932" type="book chapter" year="1789">Gmelin, 1789</bibRefCitation>
</taxonomicName>
, Systema Naturae Linné, v. 1 (pt 3): 1198. Nomen novum, replacement name for 
