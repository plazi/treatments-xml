<caption id="90EB6676FF956A2AFCE495351A89B887" ID-DOI="http://doi.org/10.5281/zenodo.6398306" ID-Zenodo-Dep="6398306" httpUri="https://zenodo.org/record/6398306/files/figure.png" inLine="true" pageId="110" pageNumber="868" targetBox="[178,769,733,1146]" targetPageId="110">
