<subSubSection id="F2198107B084018CC8FEEED210A9573A" pageId="null" pageNumber="841" type="description">
<paragraph id="B9FE965413E56D87166BA3DDE1724384" pageId="null" pageNumber="841">
2-15 cm hoch. Internodien 0,3-0,8 cm lang. 
<normalizedToken id="0B17F622FCA2E688AECAE63952D5B30D" originalValue="Blätter" pageId="null" pageNumber="841">Blaetter</normalizedToken>
0,4-0,8 cm lang. 
<emphasis id="62B192D46B655117659FB8E1B90C5D6E" italics="true" pageId="null" pageNumber="841">
<normalizedToken id="067B1121FFBA7F1C9F3D27F45184E31F" originalValue="Blütenknäuel" pageId="null" pageNumber="841">Bluetenknaeuel</normalizedToken>
meist nur sehr kurz gestielt und 
<normalizedToken id="0A6D4C307E568398A9C881F3B59A041F" originalValue="längs" pageId="null" pageNumber="841">laengs</normalizedToken>
des Stengels und der Zweige angeordnet. 
<normalizedToken id="179001001C795671F51D31E2E7C459E0" originalValue="Blüten" pageId="null" pageNumber="841">Blueten</normalizedToken>
zur Fruchtzeit 2,2-3,8 mm lang, mit aufrechten oder wenig 
<normalizedToken id="E39303C51B6990C3EE34E4FDFBC4320D" originalValue="einwärts" pageId="null" pageNumber="841">einwaerts</normalizedToken>
gebogenen Kelchzipfeln
</emphasis>
. - 
<normalizedToken id="9C45541FE432E66D89BB7D0D13BE87F5" originalValue="Blüte" pageId="null" pageNumber="841">Bluete</normalizedToken>
: 
<normalizedToken id="057C5F40E13725C57905AEA60D4C42B6" originalValue="Frühling" pageId="null" pageNumber="841">Fruehling</normalizedToken>
bis Herbst.
</paragraph>
<paragraph id="AAF1C174C842F2A69B7C10B8C2ECCE6E" pageId="null" pageNumber="841">
<emphasis id="5316E29FE51126527E3DD1563754DF14" italics="true" pageId="null" pageNumber="841">Zytologische Angaben. 2n = 22:</emphasis>
Material aus Schleswig-Holstein (Rohweder 1939). 
<emphasis id="D306DB9C3995B9CEA293399559A4ABBD" italics="true" pageId="null" pageNumber="841">2n = 44:</emphasis>
Material von 5 Orten aus den Karpaten (Trela-Sawicka 1966).
</paragraph>
<paragraph id="7EF02C98F66A64B4D369A8DB526A3961" pageId="null" pageNumber="841">
<emphasis id="B5BDEED4E331A6A908EFB61972F65C7D" italics="true" pageId="null" pageNumber="841">Standort.</emphasis>
Montan und subalpin, seltener kollin. Saure, eher sandige 
<normalizedToken id="71C05661CBD3C5E6390CB3B0F17AF112" originalValue="Böden" pageId="null" pageNumber="841">Boeden</normalizedToken>
. Unbebaute 
<normalizedToken id="5BB28AD0ECE2698CFA5CE8FF95E368EA" originalValue="Plätze" pageId="null" pageNumber="841">Plaetze</normalizedToken>
, 
<normalizedToken id="985617DAA68CDAB00EC072EF5C82381B" originalValue="Felsblöcke" pageId="null" pageNumber="841">Felsbloecke</normalizedToken>
, 
<normalizedToken id="6C73797F72EEA355C1DDE2E2DCDBD831" originalValue="Wegränder" pageId="null" pageNumber="841">Wegraender</normalizedToken>
, Alluvionen.
</paragraph>
<paragraph id="DE0E912439A336C386FE61E2F42C127D" pageId="null" pageNumber="841">
<emphasis id="AD0B23AA9FE78AEF69325403CCA10274" italics="true" pageId="null" pageNumber="841">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="58AADA90E1B10EE1AFA93639DB2BC90E" originalValue="Südeuropa" pageId="null" pageNumber="841">Suedeuropa</normalizedToken>
, 
<normalizedToken id="6A76A480158C36558F9AB732D7753A9C" originalValue="nordwärts" pageId="null" pageNumber="841">nordwaerts</normalizedToken>
verschleppt bis Skandinavien; Kaukasus, Kleinasien, Syrien; Nordafrika. - Im Gebiet: Alpen und Alpenvorland, Oberrheinische Tiefebene, Schwarzwald, Nordostschweiz, Hegau; ziemlich 
<normalizedToken id="EAA7BBFC7A24E6FFE443D9E30277E88A" originalValue="häufig" pageId="null" pageNumber="841">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
