<geoCoordinate id="F1BF45EE294F0970FE5F4E36FE90FC44" box="[284,374,876,897]" degrees="39" direction="north" minutes="44" orientation="latitude" pageId="20" pageNumber="1064" precision="925" value="39.733334">39°44’N</geoCoordinate>
