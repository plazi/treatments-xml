<taxonomicName id="3101ABD9A2935EFB729D1BB2F8F91D38" authority="L." class="Magnoliopsida" family="Caryophyllaceae" genus="Silene" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="785" phylum="Tracheophyta" rank="species" species="rupestris">
