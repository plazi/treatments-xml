<normalizedToken id="DCF8120BF6E2E36BE6EC83F129FADEC1" originalValue="rupéstris" pageId="null" pageNumber="785">rupestris</normalizedToken>
<authorityName id="09E497B20EB4E8ED1AFAAA5A2FA4DACE" pageId="null" pageNumber="785">L.</authorityName>
