<taxonomicName id="67B78C3979775C5064A305E66ED24992" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Tragopogon" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="porrifolius">
<pageBreakToken id="604A1C1FFA423B2242576CD7EBE9CE94" pageId="null" pageNumber="590">Tragopogon</pageBreakToken>
