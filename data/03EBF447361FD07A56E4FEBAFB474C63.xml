<taxonomicName id="4C423ED23612D07A5355FA58FF854EAC" authorityName="Latreille" authorityYear="1817" pageId="24" pageNumber="34" rank="superFamily" superFamily="Chalcidoidea">Chalcidoidea</taxonomicName>
