<subSubSection id="85B697B590C06106DA926A84E3AFC5B6" pageId="null" pageNumber="36" type="description">
<paragraph id="B62B2CC267A4F6A3E3A4753F886F5457" pageId="null" pageNumber="36">
2-25 cm hoch. 
<emphasis id="A9309FD058B54434C652065DA5D244E1" italics="true" pageId="null" pageNumber="36">Kelch meist bis auf etwa</emphasis>
<normalizedToken id="B94C8CA9014D5016948D7847F8199862" originalValue="¼" pageId="null" pageNumber="36">1/4</normalizedToken>
<emphasis id="04BBBD9955924A8E87067E718C80A858" italics="true" pageId="null" pageNumber="36">
der 
<normalizedToken id="B933D17A887961A798B750CDA75ED227" originalValue="Länge" pageId="null" pageNumber="36">Laenge</normalizedToken>
5
</emphasis>
(
<emphasis id="1F24CCA12A06CFFE0F87A2D35E7D1CCF" italics="true" pageId="null" pageNumber="36">selten 4</emphasis>
) 
<emphasis id="CDA3179A4212A94383E5F510978694C8" italics="true" pageId="null" pageNumber="36">teilig</emphasis>
, oft mit gerundeten Buchten; Zipfel schmal lanzettlich, 
<emphasis id="AB5228C4FB07CB48A85AEE8C7B9A01FE" italics="true" pageId="null" pageNumber="36">
bei den meisten 
<normalizedToken id="C409D83AA54B86E36959117EBA724C4D" originalValue="Blüten" pageId="null" pageNumber="36">Blueten</normalizedToken>
</emphasis>
<normalizedToken id="861927A5795D080BFCE24D1428A35B10" originalValue="±" pageId="null" pageNumber="36">+/-</normalizedToken>
<emphasis id="AD5B19DC83D140E820BBA4575DD97C8C" italics="true" pageId="null" pageNumber="36">
gleich, so lang oder 
<normalizedToken id="FD74107893B51FC315436061F9296A50" originalValue="länger" pageId="null" pageNumber="36">laenger</normalizedToken>
als die Kronzipfel
</emphasis>
, am Rande ohne Papillen, nicht nach 
<normalizedToken id="EFF307B4D9092408DA3B0A741AD5CFDA" originalValue="außen" pageId="null" pageNumber="36">aussen</normalizedToken>
umgerollt. 
<emphasis id="A63CF3431E4FFAD3D1F9B8A77415D113" italics="true" pageId="null" pageNumber="36">Krone lila</emphasis>
, seltener 
<normalizedToken id="C25F70FC2D69A7B336E30E3606C66E79" originalValue="weiß" pageId="null" pageNumber="36">weiss</normalizedToken>
, mit 5 (selten 4) 
<emphasis id="454E007AFD3EE291BE29AEB15016CCF5" italics="true" pageId="null" pageNumber="36">6</emphasis>
- 
<emphasis id="341CF11BBAE0C0005A1BC990228857D4" italics="true" pageId="null" pageNumber="36">9 mm langen Zipfeln.</emphasis>
Fruchtknoten und Frucht 
<normalizedToken id="912441FA9E376D504D9AD1E6E4E66B4B" originalValue="über" pageId="null" pageNumber="36">ueber</normalizedToken>
dem Kelch 
<emphasis id="2953C1BFBF55C623A9676C424502B678" italics="true" pageId="null" pageNumber="36">deutlich gestielt</emphasis>
(Stiel 2-4 mm lang). - 
<normalizedToken id="D0EAD678CF03CD7ADB701AF0AE5BCBE2" originalValue="Blüte" pageId="null" pageNumber="36">Bluete</normalizedToken>
: 
<normalizedToken id="EE7D77CEAA37A05F2F50372DFE0067CF" originalValue="Später" pageId="null" pageNumber="36">Spaeter</normalizedToken>
Sommer und 
<normalizedToken id="9DFA10403D6E4CA6FE925402FE4FCC01" originalValue="früher" pageId="null" pageNumber="36">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="49012C441224127ED68B3DD12E6630A9" pageId="null" pageNumber="36">
<emphasis id="4CDA186A2DE3FBB008C467CC3A60B2AB" italics="true" pageId="null" pageNumber="36">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="29C9D1F29FA65FD3F24EBEE952BB577B" pageId="null" pageNumber="36">
<emphasis id="C2A2F7663587E0DCC57C8805427FB729" italics="true" pageId="null" pageNumber="36">Standort.</emphasis>
Alpin, seltener subalpin. Magere, kalkarme 
<normalizedToken id="66C2B92259F8A7BAC8D92537BCFF9D6F" originalValue="Böden" pageId="null" pageNumber="36">Boeden</normalizedToken>
. Weiden.
</paragraph>
<paragraph id="BBE023F204F52CFBCD605CAADD557AD6" pageId="null" pageNumber="36">
<emphasis id="205A821A02F3A59C153701633ADFCF33" italics="true" pageId="null" pageNumber="36">Verbreitung. Mittelalpen-Pflanze:</emphasis>
Zentral- und 
<normalizedToken id="C9E8F9769088408C0387ACD1477BCF30" originalValue="Südalpen" pageId="null" pageNumber="36">Suedalpen</normalizedToken>
(
<normalizedToken id="B7E7FF8E6EFABD79B52D8E0EE5326688" originalValue="westwärts" pageId="null" pageNumber="36">westwaerts</normalizedToken>
bis in die mittleren Grajischen Alpen, in die Visper 
<normalizedToken id="8B9BB6BF233C89F1115B322C428B612D" originalValue="Täler" pageId="null" pageNumber="36">Taeler</normalizedToken>
und ins Aletschgebiet, 
<normalizedToken id="7C13C9E6060B7DF8F8628EFD15D3F598" originalValue="ostwärts" pageId="null" pageNumber="36">ostwaerts</normalizedToken>
bis zum Stilfserjoch und Brenner), Nordalpen (Berner Oberland, Napf [
<normalizedToken id="E6A6E61D29248594F642882740F922D2" originalValue="nachzuprüfen" pageId="null" pageNumber="36">nachzupruefen</normalizedToken>
], Uri); nicht 
<normalizedToken id="7024847BDAD800F445BA9C72C0CD5516" originalValue="häufig" pageId="null" pageNumber="36">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
