<heading bold="true" box="[151,748,1467,1494]" fontSize="11" level="1" pageId="7" pageNumber="590" reason="1">
<emphasis bold="true" box="[151,748,1467,1494]" pageId="7" pageNumber="590">
Key to adults of the Hungarian 
<taxonomicName authority="Linnaeus, 1758" authorityName="Linnaeus" authorityYear="1758" box="[547,655,1467,1494]" class="Insecta" family="Curculionidae" genus="Curculio" kingdom="Animalia" order="Coleoptera" pageId="7" pageNumber="590" phylum="Arthropoda" rank="genus" species="undefined-1">
