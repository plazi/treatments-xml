<taxonomicName box="[1315,1444,850,872]" class="Magnoliopsida" family="Moraceae" genus="Broussonetia" kingdom="Plantae" order="Rosales" pageId="5" pageNumber="277" phylum="Tracheophyta" rank="species" species="papyrifera">B. papyrifera</taxonomicName>
)
</emphasis>
</keyLead>
</paragraph>
</keyStep>
