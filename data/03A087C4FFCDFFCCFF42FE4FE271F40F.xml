<subSubSection id="C3136559FFCDFFCCFD25FD47E22BFC53" pageId="8" pageNumber="415" type="discussion">
<paragraph id="8BB636D2FFCDFFCCFD25FD47E22BFC53" blockId="8.[749,1337,673,1095]" pageId="8" pageNumber="415">
The genus 
<taxonomicName id="4C094D51FFCDFFCCFC45FD47E5FAFCF4" box="[910,967,752,781]" class="Mammalia" family="Cervidae" genus="Axis" kingdom="Animalia" order="Artiodactyla" pageId="8" pageNumber="415" phylum="Chordata" rank="genus">Axis</taxonomicName>
