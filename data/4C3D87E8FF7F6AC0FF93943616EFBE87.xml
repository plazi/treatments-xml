<emphasis id="F6E0EAECFF7F6AC0FD2F95781D6BB80C" bold="true" box="[723,875,801,830]" pageId="132" pageNumber="891">Taxonomy.</emphasis>
<taxonomicName id="03944D7DFF7F6AC0FC7495781D17B854" authority="A. Smith, 1833" authorityName="A. Smith" authorityYear="1833" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="132" pageNumber="891" phylum="Chordata" rank="species" species="dinganii">Vespertilio dinganii A. Smith, 1833</taxonomicName>
, 
<materialsCitation id="74FC3CA3FF7F6AC0FCBF95141B1EB8BE" ID-GBIF-Occurrence="3783319327" pageId="132" pageNumber="891">
“ 
<collectingCountry id="BC83766EFF7F6AC0FCB195141A1CB854" box="[845,1052,845,870]" name="South Africa" pageId="132" pageNumber="891">South Africa</collectingCountry>
,—between Natal [= Durban] and Delagoa Bay [= Maputo].”
</materialsCitation>
