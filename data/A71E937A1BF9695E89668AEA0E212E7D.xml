<subSubSection id="CFE5C8EC517FCF9D3F12C283819A825D" pageId="null" pageNumber="720" type="description">
<paragraph id="B4B2DE3FA375C7B45A3CD9E7C893D7C1" pageId="null" pageNumber="720">
<emphasis id="DEE6F794BFCB1B9525A037F8A3F6C661" italics="true" pageId="null" pageNumber="720">
Die meisten 
<normalizedToken id="20ADB9C70E2F8CDEED89B8C1916876A0" originalValue="Blätter" pageId="null" pageNumber="720">Blaetter</normalizedToken>
nicht 
<normalizedToken id="3C572ED8E04E51704B0FFF5C54F210A9" originalValue="über" pageId="null" pageNumber="720">ueber</normalizedToken>
2 mm breit, mehr als 10mal so lang wie breit
</emphasis>
(im Gebiet nur bei dieser Art so!). Innere 
<normalizedToken id="9121C8FF2950373DEC08D68B4118B1CD" originalValue="Perigonblätter" pageId="null" pageNumber="720">Perigonblaetter</normalizedToken>
mit der reifen Frucht nicht verbunden. 
<emphasis id="2AED2104FE3B640E2ECF4F8CDB044960" italics="true" pageId="null" pageNumber="720">Reife Frucht 0,9</emphasis>
- 
<emphasis id="188F1B45E3D8D075C62D5E933115FD7B" italics="true" pageId="null" pageNumber="720">1,3 mm lang. -</emphasis>
<normalizedToken id="F79569000C30915F18F362C3EB71B02D" originalValue="Blüte" pageId="null" pageNumber="720">Bluete</normalizedToken>
: 
<normalizedToken id="D7C2ADD22ACA3FF738083D99B76CFDE8" originalValue="Später" pageId="null" pageNumber="720">Spaeter</normalizedToken>
<normalizedToken id="F394EB82742C53C714F85C0F2FF29645" originalValue="Frühling" pageId="null" pageNumber="720">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="3E8C387EB2500F4F1A4C59FBCE30206D" pageId="null" pageNumber="720">
<emphasis id="751D2FAA151AB384663BB66ABF32F4B8" italics="true" pageId="null" pageNumber="720">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="2D6EFA6B8AEE0AE6AF7965FBB43DD552" italics="true" pageId="null" pageNumber="720">28:</emphasis>
Material von vielen Fundorten in Skandinavien, Island, Finnland, 
<normalizedToken id="63554FFFFAF6011C4B28EE78E5117805" originalValue="Nordrußland" pageId="null" pageNumber="720">Nordrussland</normalizedToken>
, Belgien, Ungarn (
<normalizedToken id="1D3B4798AFCCE855E2471D3584522363" originalValue="Löve" pageId="null" pageNumber="720">Loeve</normalizedToken>
1944).
</paragraph>
<paragraph id="12CF64CD9E7B41CC241557EDD7D0D9F7" pageId="null" pageNumber="720">
<emphasis id="B1AFD84DFB195B362A3FFE2FFF758E49" italics="true" pageId="null" pageNumber="720">Standort.</emphasis>
Kollin und montan. Sandige, trockene, 
<normalizedToken id="777D88EDB96FD6FA52DD4F8C36FCA2BC" originalValue="nährstoffarme" pageId="null" pageNumber="720">naehrstoffarme</normalizedToken>
, kalkarme 
<normalizedToken id="5BF71B7A2D7341760B8BD11307BC88AB" originalValue="Böden" pageId="null" pageNumber="720">Boeden</normalizedToken>
in warmen Lagen. Trockenwiesengesellschaften.
</paragraph>
<paragraph id="F112D9EEFC7C29AE68253AD8713EAA48" pageId="null" pageNumber="720">
<emphasis id="F22E0CECF578D03166F58C8B8856EB11" italics="true" pageId="null" pageNumber="720">Verbreitung. Eurosibirische Pflanze:</emphasis>
<normalizedToken id="36DB14A033A0630C7358065E6DF4F2FB" originalValue="Grönland" pageId="null" pageNumber="720">Groenland</normalizedToken>
, Island, England, auf dem Kontinent 
<normalizedToken id="60CF506D2456EA110F2169BFC7F62889" originalValue="westwärts" pageId="null" pageNumber="720">westwaerts</normalizedToken>
bis ins Rheingebiet und in die Westalpen, 
<normalizedToken id="2806AF06A6337AD68A5613A817A2B687" originalValue="nordwärts" pageId="null" pageNumber="720">nordwaerts</normalizedToken>
bis Nordkap, 
<normalizedToken id="DB1A92CC7C7F082C57F4387D62913A11" originalValue="südwärts" pageId="null" pageNumber="720">suedwaerts</normalizedToken>
bis 
<normalizedToken id="856690ACBF7F24EEDDDDC7D3A439BE1E" originalValue="Süditalien" pageId="null" pageNumber="720">Sueditalien</normalizedToken>
, 
<normalizedToken id="2F6E71BDC7695E6E9533447D676579C7" originalValue="Ägäische" pageId="null" pageNumber="720">Aegaeische</normalizedToken>
Inseln, Kleinasien, Kaukasus, 
<normalizedToken id="D9A4CA5F4CE766DEEF9E2BC9B82F5EE4" originalValue="ostwärts" pageId="null" pageNumber="720">ostwaerts</normalizedToken>
bis Baikalseegebiet. - Im Gebiet: Verbreitung noch 
<normalizedToken id="24936BA91F65247DBD5A5CCF5864E6DB" originalValue="abzuklären" pageId="null" pageNumber="720">abzuklaeren</normalizedToken>
, nach Rechinger in Hegi III/1, 1957: Weil a. Rh. bei Basel; Simplon; Sondrio im Veltlin. Unteres Aostatal (Herb. ETH).
</paragraph>
</subSubSection>
