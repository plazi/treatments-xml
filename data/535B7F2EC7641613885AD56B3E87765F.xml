<taxonomicName id="7FFA6ACD67983C87073D0025D74F3AE9" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Inula" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="527" phylum="Tracheophyta" rank="species" species="hirta">
