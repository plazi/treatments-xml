<subSubSection id="8C8E6575FF366A89F8159D281765B797" pageId="205" pageNumber="967" type="discussion">
<paragraph id="C42B36FEFF366A89F8159D281765B797" blockId="205.[2023,2616,2855,3277]" pageId="205" pageNumber="967">
Subgenus 
<taxonomicName id="03944D7DFF366A89F7839D2816D3B0A0" authority="Kaup, 1829" box="[2175,2259,2929,2962]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="205" pageNumber="967" phylum="Chordata" rank="genus">Myotis</taxonomicName>
; 
<taxonomicName id="03944D7DFF366A89F7149D281762B0A0" authorityName="Temminck" authorityYear="1840" box="[2280,2402,2929,2962]" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="205" pageNumber="967" phylum="Chordata" rank="species" species="horsfieldii">horsfieldii</taxonomicName>
species group. 
<collectingRegion id="0650F81CFF366A89F8159DC01618B088" box="[2025,2072,2969,3002]" country="South Sudan" name="Lakes" pageId="205" pageNumber="967">See</collectingRegion>
<taxonomicName id="03944D7DFF366A89F7D59DC016ACB088" authorityName="Thomas" authorityYear="1898" box="[2089,2220,2969,3002]" class="Mammalia" family="Vespertilionidae" genus="Pipistrellus" kingdom="Animalia" order="Chiroptera" pageId="205" pageNumber="970" phylum="Chordata" rank="species" species="ridleyi">M. ridleyi</taxonomicName>
. 
<taxonomicName id="03944D7DFF366A89F73D9DC01715B088" authority="Kaup, 1829" box="[2241,2325,2969,3002]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="205" pageNumber="967" phylum="Chordata" rank="genus">Myotis</taxonomicName>
horsfieldit was previously included under 
<taxonomicName id="03944D7DFF366A89F6E69D9917B5B0D3" baseAuthorityName="Horsfield" baseAuthorityYear="1824" box="[2330,2485,3008,3041]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="205" pageNumber="967" phylum="Chordata" rank="species" species="adversus">M. adversus</taxonomicName>
and later found closely related to 
<taxonomicName id="03944D7DFF366A89F6C49DBE17FCB73A" baseAuthorityName="Waterhouse" baseAuthorityYear="1845" box="[2360,2556,3047,3080]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="205" pageNumber="967" phylum="Chordata" rank="species" species="macrotarsus">M. macrotarsus</taxonomicName>
and M. 
<taxonomicName id="03944D7DFF366A89F7E09A561680B702" baseAuthorityName="Temminck" baseAuthorityYear="1840" box="[2076,2176,3087,3120]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="205" pageNumber="967" phylum="Chordata" rank="species" species="hasseltii">hasseltii</taxonomicName>
, with 
<taxonomicName id="03944D7DFF366A89F7219A561765B702" authorityName="E. H. Taylor" authorityYear="1934" box="[2269,2405,3087,3120]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="205" pageNumber="967" phylum="Chordata" rank="species" species="browni">M. browni</taxonomicName>
in a more basal position. 
<taxonomicName id="03944D7DFF366A89F75E9A6F177DB765" baseAuthorityName="Temminck" baseAuthorityYear="1840" box="[2210,2429,3126,3159]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="205" pageNumber="967" phylum="Chordata" rank="species" species="horsfieldii">Myotis horsfieldii</taxonomicName>
represents a species complex in need of deep revision. Five subspecies recognized.
</paragraph>
</subSubSection>
