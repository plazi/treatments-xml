<taxonomicName id="A79D5370DC908C83CF88A228F41B3BBF" class="Liliopsida" family="Poaceae" genus="Hordeum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="386" phylum="Tracheophyta" rank="species" species="nodosum">H. nodosum</taxonomicName>
</emphasis>
(Nr. 3) 
<emphasis id="5E428B7AEC563ED9658B651AD1E4BBAE" italics="true" pageId="null" pageNumber="386">vor allem durch die 5-6 cm langen Grannen.</emphasis>
- 
<normalizedToken id="B2EBF1A5B509711151B8EA06C917CBC3" originalValue="Blüte" pageId="null" pageNumber="386">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="7097DB0A7C7B3D25EA03DFCBA644F9D6" pageId="null" pageNumber="386">
<emphasis id="45E628CDC84B3D39D406C720EA5456BC" italics="true" pageId="null" pageNumber="386">Zytologische Angaben. 2n = 28:</emphasis>
