<taxonomicName id="3FCB8FEA3D7D4EECACC502A6A71190C2" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="386" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
