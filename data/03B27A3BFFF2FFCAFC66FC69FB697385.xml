<subSubSection id="C30198A6FFF2FFCAFCABFA48FB697385" pageId="14" pageNumber="127" type="discussion">
<paragraph id="8BA4CB2DFFF2FFCAFCABFA48FC927084" blockId="14.[811,1455,1492,1774]" box="[813,888,1492,1518]" pageId="14" pageNumber="127">NOTES</paragraph>
<paragraph id="8BA4CB2DFFF2FFCAFCABFA68FB697385" blockId="14.[811,1455,1492,1774]" pageId="14" pageNumber="127">
<bibRefCitation id="EF8AB6DCFFF2FFCAFCABFA68FBF77366" author="LECOMTE H." box="[813,1053,1524,1550]" pageId="14" pageNumber="127" pagination="99 - 121" refId="ref13173" refString="LECOMTE H. 1928 a. - Ebenacees nouvelles de l'Indochine. Notulae Systematicae 4 (4): 99 - 121. https: // www. biodiversitylibrary. org / page / 6463259" type="journal article" year="1928">Lecomte (1928a: 109)</bibRefCitation>
cited three 
<emphasis id="B96F173FFFF2FFCAFB1DFA68FB0D7366" box="[1179,1255,1524,1550]" italics="true" pageId="14" pageNumber="127">Poilane</emphasis>
collections (
<emphasis id="B96F173FFFF2FFCAFAF6FA68FA427366" box="[1392,1448,1524,1550]" italics="true" pageId="14" pageNumber="127">7571</emphasis>
, 
<emphasis id="B96F173FFFF2FFCAFCABF988FC8F7346" box="[813,869,1556,1582]" italics="true" pageId="14" pageNumber="127">7741</emphasis>
and 
<emphasis id="B96F173FFFF2FFCAFC10F988FC247346" box="[918,974,1556,1582]" italics="true" pageId="14" pageNumber="127">8071</emphasis>
) from “ 
<collectingCountry id="F30C8BBDFFF2FFCAFBA7F988FB9E7346" box="[1057,1140,1556,1582]" name="Vietnam" pageId="14" pageNumber="127">Annam</collectingCountry>
, 
<location id="8EC49DF6FFF2FFCAFBFBF988FACE7346" LSID="urn:lsid:plazi:treatment:03B27A3BFFF2FFCAFC66FC69FB697385:8EC49DF6FFF2FFCAFBFBF988FACE7346" box="[1149,1316,1556,1582]" country="Vietnam" name="Col des Nuages" pageId="14" pageNumber="127">Col des Nuages</location>
, près de Tourane” as the original material. The cited collections have been located at 
<collectionCode id="ED0A53E8FFF2FFCAFC1DF9C8FC307306" box="[923,986,1620,1646]" country="Japan" httpUri="http://grbio.org/cool/fv5j-intd" name="Hiroshima Botanical Garden" pageId="14" pageNumber="127">HBG</collectionCode>
, 
<collectionCode id="ED0A53E8FFF2FFCAFC60F9C8FBE77306" box="[998,1037,1620,1646]" country="USA" lsid="urn:lsid:biocol.org:col:15556" name="William and Lynda Steere Herbarium of the New York Botanical Garden" pageId="14" pageNumber="127" type="Herbarium">NY</collectionCode>
, 
<collectionCode id="ED0A53E8FFF2FFCAFB9EF9C8FBCC7306" box="[1048,1062,1620,1646]" country="France" lsid="urn:lsid:biocol.org:col:15763" name="Museum National d' Histoire Naturelle, Paris (MNHN) - Vascular Plants" pageId="14" pageNumber="127" type="Herbarium">P</collectionCode>
, 
<collectionCode id="ED0A53E8FFF2FFCAFBB7F9C8FB997306" box="[1073,1139,1620,1646]" country="Singapore" httpUri="http://biocol.org/urn:lsid:biocol.org:col:15640" lsid="urn:lsid:biocol.org:col:15640" name="Singapore Botanic Gardens" pageId="14" pageNumber="127" type="Herbarium">SING</collectionCode>
and 
<collectionCode id="ED0A53E8FFF2FFCAFB2CF9C8FB057306" box="[1194,1263,1620,1646]" country="Viet Nam" httpUri="http://grbio.org/cool/tj07-dt2h" name="Institute of Tropical Biology" pageId="14" pageNumber="127" type="Herbarium">VNM</collectionCode>
, of which 
<emphasis id="B96F173FFFF2FFCAFAE5F9CFFC8F73E5" italics="true" pageId="14" pageNumber="127">Poilane 7741</emphasis>
is in the best condition and has the greatest number of duplicates. Here we designate the specimen 
<specimenCode id="DBBD6356FFF2FFCAFAACF90FFA4273C5" box="[1322,1448,1683,1709]" collectionCode="P" country="France" lsid="urn:lsid:biocol.org:col:15763" name="Museum National d' Histoire Naturelle, Paris (MNHN) - Vascular Plants" pageId="14" pageNumber="127" type="Herbarium">P00721731</specimenCode>
, the best preserved, including a detailed label and Lecomte’s determination, as the 
<typeStatus id="54A0758FFFF2FFCAFB9FF94FFB947385" box="[1049,1150,1747,1773]" pageId="14" pageNumber="127">lectotype</typeStatus>
.
</paragraph>
</subSubSection>
