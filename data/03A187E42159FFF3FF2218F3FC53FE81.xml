(
<figureCitation id="13332A772159FFF4FF2A1F1EFEBDFBD1" box="[159,291,1051,1077]" captionStart="FIGURE 1" captionStartId="3.[151,250,1866,1890]" captionTargetBox="[171,1412,191,1824]" captionTargetId="figure-20@3.[171,1416,181,1841]" captionTargetPageId="3" captionText="FIGURE 1. Grammedessa. A–B: G. hamata comb.n. A: Dorsal view. B: Ventral view. C–D: G. nigricava sp.n. C: Dorsal view. D: Ventral view. E–F: G. longispina sp.n. E: Dorsal view. F: Ventral view. G–H: G. fundicava sp.n. G: Dorsal view. H: Ventral view. I–J: G. graciligramma sp.n. I: Dorsal view. J: Ventral view. K–L: G. stichtocephala sp.n. K: Dorsal view. L: Ventral view. M–N: G. acalyptoprocta sp.n. M: Dorsal view. N: Ventral view. Scale = 10 mm." figureDoi="http://doi.org/10.5281/zenodo.6500667" httpUri="https://zenodo.org/record/6500667/files/figure.png" pageId="11" pageNumber="222">Figs. 1K–L</figureCitation>
; 
<figureCitation id="13332A772159FFF4FE9A1F1EFEEAFBD1" box="[303,372,1051,1077]" captionStart="FIGURE 7" captionStartId="12.[151,250,1843,1867]" captionTargetBox="[154,1417,400,1801]" captionTargetId="figure-91@12.[154,1434,381,1820]" captionTargetPageId="12" captionText="FIGURE 7. Male genitalia of G. stichtocephala sp.n. A: Pygophore in dorsal view. B: Pygophore in ventral view. C: Pygophore in posterior view. Scale = 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6500689" httpUri="https://zenodo.org/record/6500689/files/figure.png" pageId="11" pageNumber="222">7A–C</figureCitation>
)
