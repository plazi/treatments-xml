On following pages: 4. Common 
<taxonomicName id="C2D14D2D442FFFE7B6E1F2C0B70369D3" box="[471,532,3440,3465]" class="Mammalia" family="Ctenodactylidae" genus="Ctenodactylus" kingdom="Animalia" order="Rodentia" pageId="2" pageNumber="297" phylum="Chordata" rank="species" species="gundi">Gundi</taxonomicName>
(
