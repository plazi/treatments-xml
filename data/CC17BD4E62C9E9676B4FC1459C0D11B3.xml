<paragraph id="0AFF4082CD25579B0F09CC719BF7499D" pageId="0" pageNumber="1">
<emphasis id="2048ECFAD26B4552732ADF0EE1A0DC08" bold="true" pageId="0" pageNumber="1">
(Fig. 
<figureCitation id="FA34EFBAF787E65C7986ADFBC3E49841" captionStart="Figure 72" captionStartId="F72" captionText="Figure 72. Distribution of S. torvoideum." figureDoi="10.3897/phytokeys.198.79514.figure72" httpUri="https://binary.pensoft.net/fig/689765" pageId="0" pageNumber="1">72</figureCitation>
