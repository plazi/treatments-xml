<taxonomicName id="AAA05C90A214A5B3E8C0B81A0F9D5E95" class="Magnoliopsida" family="Solanaceae" genus="Solanum" higherTaxonomySource="CoL" kingdom="Plantae" lsidName="Solanum torvoideum" order="Solanales" pageId="0" pageNumber="1" phylum="Tracheophyta" rank="species" species="torvoideum">
