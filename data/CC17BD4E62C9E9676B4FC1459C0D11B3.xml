Distribution of 
<taxonomicName id="A7C56B1C83FA55D63C857CD00F8D7014" family="Solanaceae" genus="S." kingdom="Plantae" lsidName="S. torvoideum" order="Solanales" pageId="0" pageNumber="1" rank="species" species="torvoideum">
