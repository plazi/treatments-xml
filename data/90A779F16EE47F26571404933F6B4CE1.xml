<subSubSection id="8BCC9557567AA2AB9E95D7AED1CB0234" pageId="null" pageNumber="249" type="description">
<paragraph id="0A0ADA209BBBD19F21F1D892D1174EE5" pageId="null" pageNumber="249">
<normalizedToken id="B482F25A862E7BC4796F7CD6381CF16D" originalValue="Kelchblätter" pageId="null" pageNumber="249">Kelchblaetter</normalizedToken>
4-6. 
<emphasis id="FCD6631FFFDFCA3A04B855A53DB8A47B" italics="true" pageId="null" pageNumber="249">
<normalizedToken id="79078402DA32BC08522485D91ABCCEA7" originalValue="Kronblätter" pageId="null" pageNumber="249">Kronblaetter</normalizedToken>
4
</emphasis>
- 
<emphasis id="331C4836E70D2E4A438480F5D403CB5B" italics="true" pageId="null" pageNumber="249">6, mit vielen schmalen Zipfeln, mit bewimpertem Stiel</emphasis>
, die obern 
<normalizedToken id="F36AAC48454AA57061F6AF26FA9579D6" originalValue="größer" pageId="null" pageNumber="249">groesser</normalizedToken>
als die untern. 
<normalizedToken id="A82F46ECBC3481BDC419B8D4FF1EEDA8" originalValue="Staubblätter" pageId="null" pageNumber="249">Staubblaetter</normalizedToken>
7 bis viele. Fruchtknoten 2-5 
<normalizedToken id="F85E255AFF0C9D8149254A7847697432" originalValue="blättrig" pageId="null" pageNumber="249">blaettrig</normalizedToken>
. Frucht eine vielsamige Kapsel, oben offen.
</paragraph>
<paragraph id="22D5CE4516C9EFB8F2B0B7C7ADA94300" pageId="null" pageNumber="249">
Die Gattung 
<taxonomicName id="86560069FD91B205D62D036872AD0B12" class="Magnoliopsida" family="Resedaceae" genus="Reseda" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="249" phylum="Tracheophyta" rank="genus">
<emphasis id="91FB8428ACA4B537766F76C3F5645D5D" italics="true" pageId="null" pageNumber="249">Reseda</emphasis>
</taxonomicName>
<normalizedToken id="690B31DA7AB603CD54B7239CB338451C" originalValue="umfaßt" pageId="null" pageNumber="249">umfasst</normalizedToken>
etwa 
<emphasis id="3854209BADEBAE2C30165F902E2CBCC5" italics="true" pageId="null" pageNumber="249">50 vorwiegend mediterrane Arten. Chromosomengrundzahlen</emphasis>
n = 5 und 6.
</paragraph>
