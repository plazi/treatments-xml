(figs 7–10) and 
<taxonomicName id="4C739882227AFFAFABE01417FCB2AEAC" baseAuthorityName="Meigen" baseAuthorityYear="1822" box="[709,808,1131,1153]" class="Insecta" family="Syrphidae" genus="Platycheirus" kingdom="Animalia" order="Diptera" pageId="3" pageNumber="244" phylum="Arthropoda" rank="species" species="peltatus">
