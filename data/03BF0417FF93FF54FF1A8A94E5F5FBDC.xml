<emphasis id="B9626913FF92FF52FEC988BAE629F801" bold="true" box="[324,355,1928,1952]" pageId="67" pageNumber="68">clv</emphasis>
, head lateral view; 
<emphasis id="B9626913FF92FF52FDA788B5E512F83E" bold="true" box="[554,600,1927,1951]" pageId="67" pageNumber="68">mx1</emphasis>
