<emphasis id="B9626913FF92FF52FB758856E264F8DA" bold="true" box="[1272,1326,1891,1916]" pageId="67" pageNumber="68">ant 1</emphasis>
and 
<emphasis id="B9626913FF92FF52FAED8856E2DCF8DA" bold="true" box="[1376,1430,1891,1916]" pageId="67" pageNumber="68">ant 2</emphasis>
