<taxonomicName id="4C16CE82FF95FF55FEAB881EE5F1F8E2" authority="(Reid, 1951)" authorityName="Just" authorityYear="2022" baseAuthorityName="Reid" baseAuthorityYear="1951" box="[294,699,1835,1860]" class="Malacostraca" family="Synopiidae" genus="Glandulotiron" kingdom="Animalia" order="Amphipoda" pageId="68" pageNumber="69" phylum="Arthropoda" rank="species" species="intermedius" status="comb. nov.">
<emphasis id="B9626913FF95FF55FEAB881EE57FF8E5" box="[294,565,1836,1860]" italics="true" pageId="68" pageNumber="69">Glandulotiron intermedius</emphasis>
(
<bibRefCitation id="EF87C8F0FF95FF55FDCF881EE5FEF8E2" author="Reid, D. M." box="[578,692,1835,1860]" pageId="68" pageNumber="69" pagination="189 - 291" refId="ref50178" refString="Reid, D. M. (1951) Report on the Amphipoda (Gammaridea and Caprellidea) of the Coast of Tropical West Africa. Atlantide Report, 2, 189 - 291." type="journal article" year="1951">Reid, 1951</bibRefCitation>
)
</taxonomicName>
<emphasis id="B9626913FF95FF55FD4F881EE47FF8E5" bold="true" box="[706,821,1836,1860]" pageId="68" pageNumber="69">
<taxonomicNameLabel id="A251D468FF95FF55FD4F881EE47FF8E5" box="[706,821,1836,1860]" pageId="68" pageNumber="69" rank="species">comb. nov.</taxonomicNameLabel>
</emphasis>
Lectotype, ♀. 
<emphasis id="B9626913FF95FF55FC438819E34AF8E2" bold="true" box="[974,1024,1835,1859]" pageId="68" pageNumber="69">cox3</emphasis>
, coxal plate 3; 
<emphasis id="B9626913FF95FF55FB118819E397F8E2" bold="true" box="[1180,1245,1835,1859]" pageId="68" pageNumber="69">gp1–2</emphasis>
, gnathopods 1 and 2; 
<emphasis id="B9626913FF95FF55FF3C887DE786F8C6" bold="true" box="[177,204,1871,1895]" pageId="68" pageNumber="69">p4</emphasis>
, pereopod 4; 
<emphasis id="B9626913FF95FF55FEDA8862E6C6F8C9" bold="true" box="[343,396,1872,1896]" pageId="68" pageNumber="69">p5–7</emphasis>
, pereopods 5 to 7; 
<emphasis id="B9626913FF95FF55FDC38862E523F8C9" bold="true" box="[590,617,1872,1896]" pageId="68" pageNumber="69">tel</emphasis>
, telson; 
<emphasis id="B9626913FF95FF55FD32887DE5ADF8C6" bold="true" box="[703,743,1871,1895]" pageId="68" pageNumber="69">up3</emphasis>
, uropod 3; 
<emphasis id="B9626913FF95FF55FCD18862E43EF8C9" bold="true" box="[860,884,1872,1896]" pageId="68" pageNumber="69">us</emphasis>
, urosome.
</paragraph>
