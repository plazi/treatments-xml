<caption id="DF69E589FF95FF55FF1A8819E4AAF8C6" ID-DOI="http://doi.org/10.5281/zenodo.6572121" ID-Zenodo-Dep="6572121" httpUri="https://zenodo.org/record/6572121/files/figure.png" pageId="68" pageNumber="69" startId="68.[151,250,1835,1859]" targetBox="[159,1411,196,1801]" targetPageId="68">
