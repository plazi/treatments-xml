<emphasis id="B9626913FF94FF54FF4A8B50E613FBDD" bold="true" box="[199,345,1122,1148]" pageId="69" pageNumber="70">Distribution</emphasis>
. West Africa, off 
<collectingCountry id="F301F591FF94FF54FDAD8B51E53FFBDC" box="[544,629,1123,1149]" name="Guinea-Bissau" pageId="69" pageNumber="70">Guinea</collectingCountry>
. 
<specimenCount id="9D107E88FF94FF54FDF28B50E5F5FBDC" box="[639,703,1122,1149]" pageId="69" pageNumber="70" type="generic">
<quantity id="4CEE18E4FF94FF54FDF28B50E5F1FBDC" box="[639,699,1122,1149]" metricMagnitude="1" metricUnit="m" metricValue="4.5" pageId="69" pageNumber="70" unit="m" value="45.0">45 m</quantity>
.
</specimenCount>
</paragraph>
