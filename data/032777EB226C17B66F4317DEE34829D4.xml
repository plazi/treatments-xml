<subSubSection id="8D6AB6411B8C133735835D8CC6A0E212" pageId="null" pageNumber="590" type="nomenclature">
<paragraph id="806C50D795932B1756D73BF37B4A6F07" pageId="null" pageNumber="590">
<taxonomicName id="D3F1F41264D038B8707CF05C777FA467" authority="Schleicher" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="alpicola">
Hieracium 
<normalizedToken id="185E9D6D4393F8E4F0204871522E8928" originalValue="alpícola" pageId="null" pageNumber="590">alpicola</normalizedToken>
Schleicher
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="65C89BB0107DCB74B1364D9EA27AA05F" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="DF51EEC9EBDC8C2D17C9509EFE8F8FB2" pageId="null" pageNumber="590">Alpenbewohnendes Habichtskraut</paragraph>
</subSubSection>
</title>
<subSubSection id="E25B115ED06B084E9DBA96D567ADB848" pageId="null" pageNumber="590" type="description">
<paragraph id="2A9673B1B36EC65680018923B5021CAC" pageId="null" pageNumber="590">
10-20 cm hoch; ohne 
<normalizedToken id="A70681CDFD6151A5A0AFBA4A6830EE89" originalValue="Ausläufer" pageId="null" pageNumber="590">Auslaeufer</normalizedToken>
. 
<emphasis id="5768A90E59BDFFEBC1C719161799E741" italics="true" pageId="null" pageNumber="590">Stengel mit 2</emphasis>
- 
<emphasis id="4CA7736B718532A8F42928C943CE1EC2" italics="true" pageId="null" pageNumber="590">
3 
<normalizedToken id="D24D792021926B14752D28A6FEAC6C1C" originalValue="Stengelblättern" pageId="null" pageNumber="590">Stengelblaettern</normalizedToken>
</emphasis>
, im obersten Teil verzweigt und 
<emphasis id="DA119BA322E523343CA6A976441C7BB1" italics="true" pageId="null" pageNumber="590">2</emphasis>
- 
<emphasis id="FDF2B700E87143112C5C2E6C4574AF11" italics="true" pageId="null" pageNumber="590">
5 
<normalizedToken id="D088B8FAAB10352C294D1CD331E18AD5" originalValue="köpfig" pageId="null" pageNumber="590">koepfig</normalizedToken>
</emphasis>
, mit zahlreichen Sternhaaren und dicht mit 2-7 mm langen, einfachen Haaren bedeckt, ohne 
<normalizedToken id="BE74D79A39A911BD663B6C57377CEF02" originalValue="Drüsenhaare" pageId="null" pageNumber="590">Druesenhaare</normalizedToken>
. 
<normalizedToken id="771D731028C0145CCE4F3FE091CC96D8" originalValue="Grundständige" pageId="null" pageNumber="590">Grundstaendige</normalizedToken>
<normalizedToken id="AE1E08FC69E1940ECDDCCD467BE8650C" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
zur 
<normalizedToken id="0A0E818D28A301E2AE8EC065C586D1C4" originalValue="Blütezeit" pageId="null" pageNumber="590">Bluetezeit</normalizedToken>
vorhanden, schmal lanzettlich, am Grunde 
<normalizedToken id="409D0913084A069E5B8F94439B8D67F8" originalValue="allmählich" pageId="null" pageNumber="590">allmaehlich</normalizedToken>
<normalizedToken id="B3109AE68229B415A968335FCE159FEE" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
, ganzrandig (selten mit einzelnen, feinen 
<normalizedToken id="59AA5CC5325CE3372CAF8E5C7EDB8CF4" originalValue="Zähnen" pageId="null" pageNumber="590">Zaehnen</normalizedToken>
), 
<emphasis id="6F8FEC0F557543F041C2BE8EAC92C4AF" italics="true" pageId="null" pageNumber="590">
die 
<normalizedToken id="1C21C874972E58602725B82B80A29E81" originalValue="großem" pageId="null" pageNumber="590">grossem</normalizedToken>
8
</emphasis>
- 
<emphasis id="49E91A0D97549109F34186299E3469E2" italics="true" pageId="null" pageNumber="590">20mal so lang wie breit</emphasis>
, auf der Oberseite (seltener auch auf der Unterseite) mit 3-7 mm langen, einfachen Haaren, beiderseits mit Sternhaaren und, besonders am Rande, mit hellen 
<normalizedToken id="F6932AE4375803F5BD9887FAF2A482BB" originalValue="Drüsenhaaren" pageId="null" pageNumber="590">Druesenhaaren</normalizedToken>
, 
<normalizedToken id="8A8F0E6FD854C5028AB52FBAB0AF3B1D" originalValue="grün" pageId="null" pageNumber="590">gruen</normalizedToken>
. 
<emphasis id="324A1B802E71B9BB695A4D8A30FE69D3" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="C62C0FA633E9DF85B6C30B146BE50DB9" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
8
</emphasis>
- 
<emphasis id="89BEED0C13225EFCAF015885A168DDD5" italics="true" pageId="null" pageNumber="590">11 mm lang.</emphasis>
<normalizedToken id="EDADE64894A373C145B4B2778DF0CE94" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
fein zugespitzt, dunkel, neben den Sternhaaren 
<emphasis id="8B82F5B2BAC62428C2B8D68F3B3F8CB0" italics="true" pageId="null" pageNumber="590">
mit sehr zahlreichen, das 
<normalizedToken id="C54D102EBA81006CC58232D4167BAE9D" originalValue="Hüllblatt" pageId="null" pageNumber="590">Huellblatt</normalizedToken>
verdeckenden, seidenartigen, 4
</emphasis>
- 
<emphasis id="CEA03D7B6DA2A576214499FB7572E585" italics="true" pageId="null" pageNumber="590">8 mm langen, einfachen Haaren</emphasis>
, ohne oder nur mit wenigen 
<normalizedToken id="678A4280B0508B477B160D331E70C726" originalValue="Drüsenhaaren" pageId="null" pageNumber="590">Druesenhaaren</normalizedToken>
. 
<normalizedToken id="3D74F423D8B4BB90B2BB3A26B736E233" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
goldgelb. 
<normalizedToken id="B917BB9D9D206928E5BDA24138FEAEF1" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
schwarz, 2-2,5 mm lang. - 
<normalizedToken id="FBEA4F5C4A0E053B4BF53E75A8939632" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="F2B825EA1ED05B8943C9D9005AEAB908" pageId="null" pageNumber="590">
<emphasis id="AE40B26904CF7306A3A344F7FFC55BA6" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A6190C899AAB6C9ACD7011998542D65D" italics="true" pageId="null" pageNumber="590">36:</emphasis>
Material vom Simplon (Favarger 1959).
</paragraph>
<paragraph id="25314029B9A65E00102E55AAA873B7BC" pageId="null" pageNumber="590">
<emphasis id="E29C22EB311A32D49AD8B557B0535321" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Alpin. Steinige, kalkarme 
<normalizedToken id="B49D387A70F2F26EA336D36861B44F50" originalValue="Schüttböden" pageId="null" pageNumber="590">Schuettboeden</normalizedToken>
. 
<normalizedToken id="5F0FE04C416865136A5AF4C0B403E8EA" originalValue="Moränen" pageId="null" pageNumber="590">Moraenen</normalizedToken>
, 
<normalizedToken id="B99BC20D7370F78977D6BB702FF184C9" originalValue="Geröll" pageId="null" pageNumber="590">Geroell</normalizedToken>
, lockere Rasen.
</paragraph>
<paragraph id="CD623016AA9FE836BBF884D82A73DE9A" pageId="null" pageNumber="590">
<emphasis id="1508018FFE7C3D3A488E249F3F909849" italics="true" pageId="null" pageNumber="590">
Verbreitung. Mittel- und 
<normalizedToken id="BD4A381F3673BF3DF7076C8389FD2F0A" originalValue="südeuropäische" pageId="null" pageNumber="590">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="9F859F47D0EE38DEA1ED2F3F157D6318" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="B2DD75D4DB4586F38F10330DF381EF76" originalValue="östlich" pageId="null" pageNumber="590">oestlich</normalizedToken>
</emphasis>
)
<emphasis id="DBEB1C06DD839A1246E4D6862A81074F" italics="true" pageId="null" pageNumber="590">:</emphasis>
Alpen (Basses Alpes, Savoyen, Wallis, Schlern, Stangalpen?), Karpaten, Gebirge der Balkanhalbinsel. - Im Gebiet: Savoyen (Alpes 
<normalizedToken id="561DB342C23966135CDE00D972086EB2" originalValue="Lémaniennes" pageId="null" pageNumber="590">Lemaniennes</normalizedToken>
), Wallis (Illalp, Bellalui, 
<normalizedToken id="6D31968AAFDCE0799BD654B14E702CD5" originalValue="VisperTäler" pageId="null" pageNumber="590">VisperTaeler</normalizedToken>
, Simplon, Saflischtal, Mettental).
</paragraph>
<paragraph id="E07995043E609AF9A0C6832DA8BCC61F" pageId="null" pageNumber="590">
<emphasis id="14C9E23F51153B8F2D570AC97026A492" italics="true" pageId="null" pageNumber="590">
Bemerkungen. 
<taxonomicName id="2D45C21A21F50FD26324A4282C31D567" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="alpicola">H. alpicola</taxonomicName>
</emphasis>
ist eine morphologisch ziemlich isoliert stehende Art; Bastarde und Zwischenarten sind nur wenige bekannt, so etwa mit 
<taxonomicName id="3E6E1062B8E93D7AA7A01D07A7648AEC" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="glaciale">
<emphasis id="1220E69B1EAF9E50280567DB0406E1F9" italics="true" pageId="null" pageNumber="590">H. glaciale</emphasis>
</taxonomicName>
(Nr. 3b) und mit der der Untergattung 
<emphasis id="5E67CC88187029E6D3B934DD9D6F428A" italics="true" pageId="null" pageNumber="590">Euhieracium</emphasis>
<normalizedToken id="E45412551E27EBE72B0D7F8211D45350" originalValue="angehörenden" pageId="null" pageNumber="590">angehoerenden</normalizedToken>
Art 
<emphasis id="A7412D918B6EE9DA6F5119A7B195E056" italics="true" pageId="null" pageNumber="590">H. glanduiifer um</emphasis>
(Hirschmann in Becherer 1956).
</paragraph>
</subSubSection>
