<subSubSection id="9ECC98D7C753FF9943ADBCEF6585FE36" pageId="2" pageNumber="403" type="discussion">
<paragraph id="D669CB5CC753FF9943ADBCEF6585FE36" blockId="2.[151,1436,223,430]" pageId="2" pageNumber="403">
<emphasis id="E4A2174EC753FF9943ADBCEF646DFF61" bold="true" box="[151,267,223,249]" pageId="2" pageNumber="403">Remarks.</emphasis>
<bibRefCitation id="B247B6ADC753FF99422EBCEF6721FF62" author="Lohse, G. A. &amp; Smetana A." box="[276,583,223,250]" pageId="2" pageNumber="403" pagination="281 - 300" refId="ref9265" refString="Lohse, G. A. &amp; Smetana A. (1985) Revision of the types of species of Oxypodini and Athetini (sensu Seevers) described by Mannerheim and Maklin from North America (Coleoptera: Staphylinidae). The Coleopterists Bulletin, 39, 281 - 300." type="journal article" year="1985">Lohse and Smetana (1985)</bibRefCitation>
resurrected 
<taxonomicName id="11D6B0DFC753FF9941EFBCEF615AFF61" baseAuthorityName="Thomson" baseAuthorityYear="1856" box="[725,1084,223,249]" class="Insecta" family="Staphylinidae" genus="Atheta" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="403" phylum="Arthropoda" rank="species" species="aeneipennis" subGenus="Dimetrota">
<emphasis id="E4A2174EC753FF9941EFBCEF615AFF61" box="[725,1084,223,249]" italics="true" pageId="2" pageNumber="403">Atheta (Dimetrota) aeneipennis</emphasis>
</taxonomicName>
from the synonymy of 
<emphasis id="E4A2174EC753FF994677BCEF6038FF61" box="[1357,1374,223,249]" italics="true" pageId="2" pageNumber="403">A</emphasis>
. 
<taxonomicName id="11D6B0DFC753FF994654BCEF64D0FE86" authority="(Mannerheim)" baseAuthorityName="Mannerheim" baseAuthorityYear="1843" class="Insecta" family="Staphylinidae" genus="Atheta" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="403" phylum="Arthropoda" rank="species" species="picipennis" subGenus="Dimetrota">
(
<emphasis id="E4A2174EC753FF994642BCD060EAFF61" box="[1400,1420,224,249]" italics="true" pageId="2" pageNumber="403">D</emphasis>
.) 
<emphasis id="E4A2174EC753FF9943ADBD34646CFE85" box="[151,266,260,285]" italics="true" pageId="2" pageNumber="403">picipennis</emphasis>
(Mannerheim)
</taxonomicName>
. 
<bibRefCitation id="B247B6ADC753FF9942FABD33673DFE85" author="Pasnik, G." box="[448,603,259,285]" pageId="2" pageNumber="403" pagination="185 - 234" refId="ref9470" refString="Pasnik, G. (2001) The North Korean Aleocharinae (Coleoptera, Staphylinidae): diversity and biogeography. Acta Zoological Cracoviensia, 44, 185 - 234." type="journal article" year="2001">Paśnik (2001)</bibRefCitation>
recorded 
<taxonomicName id="11D6B0DFC753FF9941F0BD33617EFE85" baseAuthorityName="Mannerheim" baseAuthorityYear="1843" box="[714,1048,259,286]" class="Insecta" family="Staphylinidae" genus="Atheta" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="403" phylum="Arthropoda" rank="species" species="picipennis" subGenus="Dimetrota">
<emphasis id="E4A2174EC753FF9941F0BD336675FE85" box="[714,787,259,285]" italics="true" pageId="2" pageNumber="403">Atheta</emphasis>
(
<emphasis id="E4A2174EC753FF994019BD3466F3FE85" box="[803,917,260,285]" italics="true" pageId="2" pageNumber="403">Dimetrota</emphasis>
) 
<emphasis id="E4A2174EC753FF99409FBD34617EFE85" box="[933,1048,260,285]" italics="true" pageId="2" pageNumber="403">picipennis</emphasis>
</taxonomicName>
from 
<collectingCountry id="AEC18BCCC753FF994761BD33618DFE86" box="[1115,1259,259,286]" name="North Korea" pageId="2" pageNumber="403">North Korea</collectingCountry>
. Later, 
<bibRefCitation id="B247B6ADC753FF994606BD336584FED9" author="Smetana, A." pageId="2" pageNumber="403" pagination="504 - 698" refId="ref9730" refString="Smetana, A. (2004) Family Saphylinidae: Omaliinae, Proteininae, Micropeplinae, Dasycerinae, Phleocharinae, Olisthaerinae, Tachyporinae, Trichophyinae, Habrocerinae, Aleocharinae, Trigonurinae, Apaticinae, Piestinae, Osoriinae, Oxytelinae, Oxyporinae, Megalopsiinae, Steninae, Euaesthetinae, Leptotyphlinae, Pseudopsinae, Paederinae, Staphylininae. In: Lobl, I. &amp; Smetana, A. (Eds.), Catalogue of Palaearctic Coleoptera. Vol. 2. Apollo Books, Stenstrup, pp. 237 - 272 + 329 - 495 + 504 - 698." type="book chapter" year="2004">Smetana (2004)</bibRefCitation>
replaced the record of 
<emphasis id="E4A2174EC753FF9942DFBD176490FED9" box="[485,502,295,321]" italics="true" pageId="2" pageNumber="403">A</emphasis>
. 
<taxonomicName id="11D6B0DFC753FF99413FBD1767CBFED9" baseAuthorityName="Mannerheim" baseAuthorityYear="1843" box="[517,685,295,322]" class="Insecta" family="Staphylinidae" genus="Atheta" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="403" phylum="Arthropoda" rank="species" species="picipennis" subGenus="Dimetrota">
(
<emphasis id="E4A2174EC753FF994134BD186744FED9" box="[526,546,296,321]" italics="true" pageId="2" pageNumber="403">D</emphasis>
.) 
<emphasis id="E4A2174EC753FF994100BD1867CBFED9" box="[570,685,296,321]" italics="true" pageId="2" pageNumber="403">picipennis</emphasis>
</taxonomicName>
with 
<taxonomicName id="11D6B0DFC753FF9941D7BD1766AEFED9" baseAuthorityName="Thomson" baseAuthorityYear="1856" box="[749,968,295,322]" class="Insecta" family="Staphylinidae" genus="Atheta" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="402" phylum="Arthropoda" rank="species" species="aeneipennis" subGenus="Dimetrota">
<emphasis id="E4A2174EC753FF9941D7BD176798FED9" box="[749,766,295,321]" italics="true" pageId="2" pageNumber="403">A</emphasis>
. (
<emphasis id="E4A2174EC753FF99402CBD18664CFED9" box="[790,810,296,321]" italics="true" pageId="2" pageNumber="403">D</emphasis>
.) 
<emphasis id="E4A2174EC753FF994078BD1866AEFED9" box="[834,968,296,321]" italics="true" pageId="2" pageNumber="403">aeneipennis</emphasis>
</taxonomicName>
. After examining all North Korean specimens of 
<taxonomicName id="11D6B0DFC753FF9943CCBD7B6725FEFD" baseAuthorityName="Mannerheim" baseAuthorityYear="1843" box="[246,579,331,358]" class="Insecta" family="Staphylinidae" genus="Atheta" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="403" phylum="Arthropoda" rank="species" species="picipennis" subGenus="Dimetrota">
<emphasis id="E4A2174EC753FF9943CCBD7B6459FEFD" box="[246,319,331,357]" italics="true" pageId="2" pageNumber="403">Atheta</emphasis>
(
<emphasis id="E4A2174EC753FF994275BD7C64A7FEFD" box="[335,449,332,357]" italics="true" pageId="2" pageNumber="403">Dimetrota</emphasis>
) 
<emphasis id="E4A2174EC753FF9942EABD7C6725FEFD" box="[464,579,332,357]" italics="true" pageId="2" pageNumber="403">picipennis</emphasis>
</taxonomicName>
, we found that the record by 
<bibRefCitation id="B247B6ADC753FF9940BDBD7B6144FEFD" author="Pasnik, G." box="[903,1058,331,357]" pageId="2" pageNumber="403" pagination="185 - 234" refId="ref9470" refString="Pasnik, G. (2001) The North Korean Aleocharinae (Coleoptera, Staphylinidae): diversity and biogeography. Acta Zoological Cracoviensia, 44, 185 - 234." type="journal article" year="2001">Paśnik (2001)</bibRefCitation>
is the result of a misidentification of 
<taxonomicName id="11D6B0DFC753FF99438FBD5F6770FE11" baseAuthorityName="Thomson" baseAuthorityYear="1856" box="[181,534,367,394]" class="Insecta" family="Staphylinidae" genus="Atheta" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="403" phylum="Arthropoda" rank="species" species="aeneipennis" subGenus="Dimetrota">
<emphasis id="E4A2174EC753FF99438FBD5F6598FE11" box="[181,254,367,393]" italics="true" pageId="2" pageNumber="403">Atheta</emphasis>
(
<emphasis id="E4A2174EC753FF994234BD4064E6FE11" box="[270,384,368,393]" italics="true" pageId="2" pageNumber="403">Dimetrota</emphasis>
) 
<emphasis id="E4A2174EC753FF9942AABD406770FE11" box="[400,534,368,393]" italics="true" pageId="2" pageNumber="403">aeneipennis</emphasis>
</taxonomicName>
, in agreement with 
<bibRefCitation id="B247B6ADC753FF9941C9BD5F66CEFE11" author="Smetana, A." box="[755,936,367,393]" pageId="2" pageNumber="403" pagination="504 - 698" refId="ref9730" refString="Smetana, A. (2004) Family Saphylinidae: Omaliinae, Proteininae, Micropeplinae, Dasycerinae, Phleocharinae, Olisthaerinae, Tachyporinae, Trichophyinae, Habrocerinae, Aleocharinae, Trigonurinae, Apaticinae, Piestinae, Osoriinae, Oxytelinae, Oxyporinae, Megalopsiinae, Steninae, Euaesthetinae, Leptotyphlinae, Pseudopsinae, Paederinae, Staphylininae. In: Lobl, I. &amp; Smetana, A. (Eds.), Catalogue of Palaearctic Coleoptera. Vol. 2. Apollo Books, Stenstrup, pp. 237 - 272 + 329 - 495 + 504 - 698." type="book chapter" year="2004">Smetana (2004)</bibRefCitation>
. This species has not been collected in 
<collectingCountry id="AEC18BCCC753FF994661BD5F65B9FE36" name="South Korea" pageId="2" pageNumber="403">South Korea</collectingCountry>
.
</paragraph>
</subSubSection>
