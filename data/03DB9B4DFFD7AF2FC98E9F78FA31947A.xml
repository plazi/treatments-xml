<taxonomicName id="4C7251D8FFD7AF2EC9F79F79FD60913F" authority="Engel &amp; Grimaldi, 2008" authorityName="Engel &amp; Grimaldi" authorityYear="2008" box="[238,717,1062,1089]" class="Insecta" family="Prostomidae" genus="Vetuprostomis" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="565" phylum="Arthropoda" rank="genus">
Vetuprostomis 
