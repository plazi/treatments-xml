<collectionCode id="61FB3AA6FF3CFF76A330FDB4FBB8DE74" box="[1056,1150,603,629]" collectionName="Switzerland, Geneva, Museum d'Histoire Naturelle" pageId="165" pageNumber="166">MHNG</collectionCode>
