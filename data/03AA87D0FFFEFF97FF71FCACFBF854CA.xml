<date id="FFBD1006FFFEFF97FD56FC82FC0D5420" box="[743,960,811,837]" pageId="11" pageNumber="10" value="2020-11-20">20 November 2020</date>
; A. Gómez Benítez. Host: 
<taxonomicName id="4C034D45FFFEFF97FB5EFC82FA6D5420" authorityName="O. Pickard-Cambridge" authorityYear="1898" box="[1263,1440,811,837]" class="Arachnida" family="Segestriidae" genus="Ariadna" kingdom="Animalia" order="Araneae" pageId="11" pageNumber="10" phylum="Arthropoda" rank="species" species="pilifera">
