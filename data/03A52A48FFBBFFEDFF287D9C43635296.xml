<emphasis id="B978474CFFB9FFE2FF2878EA47F455A5" box="[174,185,1674,1696]" italics="true" pageId="7" pageNumber="218">5</emphasis>
— wing; 
<emphasis id="B978474CFFB9FFE2FE9F78EA466955A5" box="[281,292,1674,1696]" italics="true" pageId="7" pageNumber="218">6</emphasis>
— mesonotum, dorsal view; 
<emphasis id="B978474CFFB9FFE2FDC578EA450355A5" box="[579,590,1674,1696]" italics="true" pageId="7" pageNumber="218">7</emphasis>
— fore femur; 
<emphasis id="B978474CFFB9FFE2FD6178EA45BF55A5" box="[743,754,1674,1696]" italics="true" pageId="7" pageNumber="218">8</emphasis>
— mid femur; 
<emphasis id="B978474CFFB9FFE2FC0D78EA44DB55A5" box="[907,918,1674,1696]" italics="true" pageId="7" pageNumber="218">9</emphasis>
— hind femur; 
<emphasis id="B978474CFFB9FFE2FBB378EA430155A5" box="[1077,1100,1674,1696]" italics="true" pageId="7" pageNumber="218">10</emphasis>
— abdomen, dorsal view; 
<emphasis id="B978474CFFB9FFE2FEA078C5467055BE" box="[294,317,1701,1723]" italics="true" pageId="7" pageNumber="218">11</emphasis>
— oviscape, lateroventral view; 
<emphasis id="B978474CFFB9FFE2FDF478C545C455BE" box="[626,649,1701,1723]" italics="true" pageId="7" pageNumber="218">12</emphasis>
— same, setae enlarged.
