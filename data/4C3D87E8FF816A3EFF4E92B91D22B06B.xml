<emphasis id="F6E0EAECFF816A3EFCEA93DD1DB2BE97" bold="true" box="[790,946,1412,1445]" pageId="122" pageNumber="880">Taxonomy.</emphasis>
<taxonomicName id="03944D7DFF816A3EFC2593DD1D9CBEFF" authority="Handley, 1960" authorityName="Handley" authorityYear="1960" class="Liliopsida" family="Poaceae" genus="Lasiurus" kingdom="Plantae" order="Poales" pageId="122" pageNumber="880" phylum="Tracheophyta" rank="species" species="castaneus">Lasiurus castaneus Handley, 1960</taxonomicName>
, 
<materialsCitation id="74FC3CA3FF816A3EFC4593E91B4ABEC7" ID-GBIF-Occurrence="3783319534" pageId="122" pageNumber="880">
“Tacarcuna Village, 
<quantity id="036C9B1BFF816A3EFB1693E91B63BEFF" box="[1258,1379,1456,1485]" metricMagnitude="-1" metricUnit="m" metricValue="9.7536" pageId="122" pageNumber="880" unit="ft" value="3.2">3,200 ft.</quantity>
