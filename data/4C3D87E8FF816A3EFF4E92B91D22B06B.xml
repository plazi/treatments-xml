<collectingCountry id="BC83766EFF816A3EFB3993811B3BBEC7" box="[1221,1339,1496,1525]" name="Panama" pageId="122" pageNumber="880">Panama</collectingCountry>
.”
</materialsCitation>
</subSubSection>
<subSubSection id="8C8E6575FF816A3EFCEB93A21B63BD59" pageId="122" pageNumber="880" type="discussion">
See 
<taxonomicName id="03944D7DFF816A3EFC9D93A21DF8BD2E" baseAuthorityName="Peters" baseAuthorityYear="1870" box="[865,1016,1531,1564]" class="Liliopsida" family="Poaceae" genus="Lasiurus" kingdom="Plantae" order="Poales" pageId="122" pageNumber="880" phylum="Tracheophyta" rank="species" species="egregius">L. egregius</taxonomicName>
. 
<taxonomicName id="03944D7DFF816A3EFBE493A21B19BD2E" authorityName="Handley" authorityYear="1960" box="[1048,1305,1531,1564]" class="Liliopsida" family="Poaceae" genus="Lasiurus" kingdom="Plantae" order="Poales" pageId="122" pageNumber="880" phylum="Tracheophyta" rank="species" species="castaneus">Lasiurus castaneus</taxonomicName>
