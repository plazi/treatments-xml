(Brues, 1937); 
<taxonomicName id="EC31C15FC42ED40B7D8B8967D3BFFCF7" class="Insecta" family="Braconidae" genus="Protorhyssalodes" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Protorhyssalodes arnaudi" order="Hymenoptera" pageId="0" pageNumber="65" phylum="Arthropoda" rank="species" species="arnaudi">
