</taxonomicName>
Perrichot, Nel, &amp; Quicke, 2009; 
<taxonomicName id="D0A214EA25A4587ADA8E7370646DBE90" class="Insecta" family="Braconidae" genus="Protorhyssalopsis" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Protorhyssalopsis perrichoti" order="Hymenoptera" pageId="0" pageNumber="65" phylum="Arthropoda" rank="species" species="perrichoti">
<emphasis id="033209BF3252B4DD6772D07923B8F47A" italics="true" pageId="0" pageNumber="65">Protorhyssalopsis perrichoti</emphasis>
</taxonomicName>
Ortega-Blanco, 
<normalizedToken id="BA0C39B90561C5212BC945D68143B5E4" originalValue="Delclòs">Delclos</normalizedToken>
, &amp; Engel, 2011; 
<taxonomicName id="6A6FF743227C37873CFBEE4DA85B3AD5" authorityName="Basibuyuk &amp; Quicke" authorityYear="1999" class="Insecta" family="Braconidae" genus="Protorhyssalus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Protorhyssalus goldmani" order="Hymenoptera" pageId="0" pageNumber="65" phylum="Arthropoda" rank="species" species="goldmani">
<emphasis id="B7C5FAC93B8F3F9E8F0DA96693DF5348" italics="true" pageId="0" pageNumber="65">Protorhyssalus goldmani</emphasis>
