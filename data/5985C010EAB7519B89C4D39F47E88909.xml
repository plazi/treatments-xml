<taxonomicName id="D6F1C998935BE0A14518C266CE6B1186" LSID="5985C010-EAB7-519B-89C4-D39F47E88909" authority="Basibuyuk, Quicke, &amp; van Achterberg, 1999" authorityName="Basibuyuk, Quicke, &amp; van Achterberg" authorityYear="1999" family="Braconidae" genus="Protorhyssalinae" higherTaxonomySource="treatment-meta" kingdom="Animalia" lsidName="" order="Hymenoptera" pageId="0" pageNumber="65" rank="subSpecies" species="longiscapus" subGenus="Basibuyuk" subSpecies="1999">Protorhyssalinae Basibuyuk, Quicke, &amp; van Achterberg, 1999</taxonomicName>
