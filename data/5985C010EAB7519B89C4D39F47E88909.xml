</taxonomicName>
Li, Shih, &amp; Ren, 2021; 
<taxonomicName id="E8A25384633E186994512BB2E89942AF" baseAuthorityName="Brues" baseAuthorityYear="1937" class="Insecta" family="Braconidae" genus="Diorhyssalus" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Diorhyssalus allani" order="Hymenoptera" pageId="0" pageNumber="65" phylum="Arthropoda" rank="species" species="allani">
