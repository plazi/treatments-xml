<figureCitation id="13022A7D043FFFF8FE9EF982FE77778B" box="[374,444,1663,1689]" captionStart="FIGURES 31–36" captionStartId="17.[151,264,1896,1920]" captionTargetBox="[151,1435,489,1873]" captionTargetId="figure-196@17.[151,1435,489,1873]" captionTargetPageId="17" captionText="FIGURES 31–36. Diglyphomorphomyia spp. nov., head in frontal view; 31 D. pilosa, female holotype; 32 D. costulata, female paratype; 33 D. carinifer, male paratype; 34 D. pedunculata, male paratype; 35 D. costulata, male paratype; 36 D. pilosa, male paratype." figureDoi="http://doi.org/10.5281/zenodo.6592906" httpUri="https://zenodo.org/record/6592906/files/figure.png" pageId="13" pageNumber="334">31, 36</figureCitation>
