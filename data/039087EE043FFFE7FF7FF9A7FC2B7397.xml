<taxonomicName id="4C394D7B043CFFFBFEB4F8E1FDA47626" box="[348,623,1820,1844]" class="Insecta" family="Eulophidae" genus="Diglyphomorphomyia" kingdom="Animalia" order="Hymenoptera" pageId="14" pageNumber="335" phylum="Arthropoda" rank="species" species="undetermined">
