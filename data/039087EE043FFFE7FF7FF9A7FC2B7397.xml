, 
<figureCitation id="13022A7D043FFFF8FECAF982FEA0778B" box="[290,363,1663,1689]" captionStart="FIGURES 21–24" captionStartId="15.[151,264,1794,1818]" captionTargetBox="[151,1435,237,1771]" captionTargetId="figure-39@15.[151,1435,237,1771]" captionTargetPageId="15" captionText="FIGURES 21–24. Diglyphomorphomyia spp. nov., males; 21–22. D. pilosa; 21 body in lateral view, paratype; 22 body in dorsal view, paratype; 23–24. D. costulata; 23 body in dorsal view, paratype; 24 body in lateral view, paratype." figureDoi="http://doi.org/10.5281/zenodo.6592902" httpUri="https://zenodo.org/record/6592902/files/figure.png" pageId="13" pageNumber="334">21, 22</figureCitation>
