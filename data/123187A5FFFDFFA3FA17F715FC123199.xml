, 
<materialsCitation id="2AF03CEEFFFDFFA4F7F8F6A2F6413A74" ID-GBIF-Occurrence="3783613303" country="Argentina" elevation="3000" latitude="-28.75" location="Catamarca" pageId="3" pageNumber="496" specimenCount="2023" specimenCount-male="2023" stateProvince="Catamarca">
“Otro Cerro, 
<collectingRegion id="585CF851FFFDFFA4F736F6A2F6DB3988" box="[2279,2429,2416,2441]" country="Argentina" name="Catamarca" pageId="3" pageNumber="496">Catamarca</collectingRegion>
. Alt. 
<elevation id="11B5D180FFFDFFA4F618F6A2F5943988" box="[2505,2610,2416,2441]" metricMagnitude="3" metricUnit="m" metricValue="3.0" pageId="3" pageNumber="496" unit="m" value="3000.0">
