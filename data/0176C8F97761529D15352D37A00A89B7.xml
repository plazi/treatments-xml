<subSubSection id="EA89112E13F7EA1EF736CF44C365B127" pageId="null" pageNumber="308" type="description">
<paragraph id="C5CDD33DE078E664C343475D1BA7678D" pageId="null" pageNumber="308">
<emphasis id="9595B008B86AD1E498FAE5507AA15CEF" italics="true" pageId="null" pageNumber="308">Ausdauernd</emphasis>
, 10-25 cm hoch, horstbildend. Stengel aufrecht, besonders unterhalb des 
<normalizedToken id="E1C9A26D7168DCEF9C4B5CD8FEBD3165" originalValue="Blütenstandes" pageId="null" pageNumber="308">Bluetenstandes</normalizedToken>
dicht und abstehend behaart. 
<normalizedToken id="3402EE08E7E31CBC0FF7B450E9658C1F" originalValue="Blätter" pageId="null" pageNumber="308">Blaetter</normalizedToken>
<normalizedToken id="2C004B8B50913D8F9FA2E36BA43686E2" originalValue="allmählich" pageId="null" pageNumber="308">allmaehlich</normalizedToken>
zugespitzt, mit kapuzenartiger Spitze, wie die Blattscheiden 
<normalizedToken id="A4D7B163ECD296D7CB3895DEC20AB9BE" originalValue="vollständig" pageId="null" pageNumber="308">vollstaendig</normalizedToken>
kahl; 
<normalizedToken id="49E5F996CE4711D75B733F1FF1D070D5" originalValue="Blatthäutchen" pageId="null" pageNumber="308">Blatthaeutchen</normalizedToken>
ca. 1 mm lang, gefranst und bewimpert. 
<emphasis id="F6091FFDE30EF7DC368D8A4AFA3F3E2F" italics="true" pageId="null" pageNumber="308">
Rispe 
<normalizedToken id="5ABB56307960A934035C97E0DEC08A04" originalValue="ährenartig" pageId="null" pageNumber="308">aehrenartig</normalizedToken>
zusammengezogen
</emphasis>
, 
<normalizedToken id="B7F9B4D0C68D7250C87368FB3F2BFC07" originalValue="eiförmig" pageId="null" pageNumber="308">eifoermig</normalizedToken>
, 1,5-3 cm lang. 
<normalizedToken id="E128E414C29030C21C064E10DD29987C" originalValue="Ährchen" pageId="null" pageNumber="308">Aehrchen</normalizedToken>
meist 2 
<normalizedToken id="6660AFACD6AB3E1388A32D79F3633431" originalValue="blütig" pageId="null" pageNumber="308">bluetig</normalizedToken>
, 
<emphasis id="7CBF1C6E72DB229A81FAFC44B3CF72B4" italics="true" pageId="null" pageNumber="308">
bunt 
<normalizedToken id="2BB740639B04E6CEA45CD215D3B0DA47" originalValue="gefärbt" pageId="null" pageNumber="308">gefaerbt</normalizedToken>
</emphasis>
(rot und braun). Beide 
<normalizedToken id="587ED016E21E75B4009A97188532A971" originalValue="Hüllspelzen" pageId="null" pageNumber="308">Huellspelzen</normalizedToken>
fast gleich lang (4-5 mm), oft auch die untere 3nervig. Keine Haare unterhalb der untersten Deckspelze oder Haare weniger als 1/10 so lang wie die Deckspelze; 
<emphasis id="84090E5416E46776E56269379FAC023B" italics="true" pageId="null" pageNumber="308">
<pageBreakToken id="733D8DAD1AA4B73CEE607C3600F1AF68" pageId="null" pageNumber="308">Deckspelzen</pageBreakToken>
an der Spitze mit 2 
<normalizedToken id="8442FD60F84D5BC720AA66506336403D" originalValue="Zähnen" pageId="null" pageNumber="308">Zaehnen</normalizedToken>
, die oft nicht in Grannen auslaufen, oder Grannen nur etwa 0,5 mm lang
</emphasis>
; Granne auf dem 
<normalizedToken id="27180DA156D7767B83428178FC8477AB" originalValue="Rücken" pageId="null" pageNumber="308">Ruecken</normalizedToken>
etwa so lang.wie die Deckspelze. - 
<normalizedToken id="CAED513ACF8ED0CBF1BF476F3DB213EA" originalValue="Blüte" pageId="null" pageNumber="308">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="94C3E51485FFAC39DE55552FF051C3DA" pageId="null" pageNumber="308">
<emphasis id="5F6890239C6D7D5E57DD107EC427B7BB" italics="true" pageId="null" pageNumber="308">Zytologische Angaben. 2n = 28:</emphasis>
Material aus Skandinavien, Island, Spitzbergen, Halbinsel Kola, 
<normalizedToken id="D7DB00ABC51E06A7EF9AC09116069B0F" originalValue="Grönland" pageId="null" pageNumber="308">Groenland</normalizedToken>
, Kanada, Mexiko, Japan und 
<taxonomicName id="048BC6053DE96BBD09BD491D5B26EDB8" class="Liliopsida" family="Poaceae" genus="Baldingera" higherTaxonomySource="GBIF" kingdom="Plantae" order="Poales" pageId="null" pageNumber="308" phylum="Tracheophyta" rank="species" species="formosa">Formosa</taxonomicName>
(Zusammenstellung der vielen 
<normalizedToken id="2924A835F8D142CBBB0A9D452555A29E" originalValue="Zählungen" pageId="null" pageNumber="308">Zaehlungen</normalizedToken>
von Tateoka 1954, 
<normalizedToken id="C3C208F9918D5D1295116E282592A277" originalValue="Böcher" pageId="null" pageNumber="308">Boecher</normalizedToken>
1959, Bowden 1960a, Chen und Hsu 1962, Beaman et al. 1962). 
<emphasis id="53C30C44F555FC77A9CD8F1DEBFF5184" italics="true" pageId="null" pageNumber="308">2n = 42:</emphasis>
Material aus Island, 
<normalizedToken id="B59D60264F57700B9EBD07D6652E7F4E" originalValue="Grönland" pageId="null" pageNumber="308">Groenland</normalizedToken>
und Kanada (
<normalizedToken id="22629EA4E1969DB6DEAAD2E93E3237B2" originalValue="Böcher" pageId="null" pageNumber="308">Boecher</normalizedToken>
1959).
</paragraph>
<paragraph id="4CD76E0CEF35D370D8BFD58C6A0AC4DF" pageId="null" pageNumber="308">
<emphasis id="A953B6B3C25456CEC2A7B377FC3BD205" italics="true" pageId="null" pageNumber="308">Standort</emphasis>
. Alpin, seltener subalpin. Kalkhaltige, bis schwach saure, humose 
<normalizedToken id="A8C77F3425148DBF82C8C0436DBD06D3" originalValue="Böden" pageId="null" pageNumber="308">Boeden</normalizedToken>
(auch Feinschutt) in wind-exponierten Lagen mit kurzer Schneebedeckung. 
<emphasis id="929B42A25A5F47B93EE175B02A8CA412" italics="true" pageId="null" pageNumber="308">Elynetum</emphasis>
Br.-Bl. 1913, 
<emphasis id="B44EDE3DC085A2C88A9084A1F77AA1EA" italics="true" pageId="null" pageNumber="308">Drabo-Saxifragetum</emphasis>
Br.-Bl. 1949.
</paragraph>
<paragraph id="D0FC8699CCE144265896CCDB591B90B0" pageId="null" pageNumber="308">
<emphasis id="163A8E54FCF52058A0D645A9A5EE0542" italics="true" pageId="null" pageNumber="308">
Verbreitung. Gebirgspflanze mit fast weltweiter 
<normalizedToken id="5EEE2ABCAEC7DB012463280CD70BAA47" originalValue="ursprünglicher" pageId="null" pageNumber="308">urspruenglicher</normalizedToken>
Verbreitung
</emphasis>
. Arktische Gebiete und Gebirge von Eurasien, Nord- und 
<normalizedToken id="3813CD0B8F75DADAD81E791A7C0127EB" originalValue="Südamerika" pageId="null" pageNumber="308">Suedamerika</normalizedToken>
, 
<normalizedToken id="EE891916742E8A7D45B869A76FB4F3DF" originalValue="Grönland" pageId="null" pageNumber="308">Groenland</normalizedToken>
(bis ca. 83° NB), Australien, Neuseeland; kommt in Afrika nicht vor; Verbreitungskarten von 
<normalizedToken id="E866FC97FF1EE305A219DE670D5CC3B8" originalValue="Hultén" pageId="null" pageNumber="308">Hulten</normalizedToken>
(1959 Verbreitungskarten von 
<normalizedToken id="AF6AEC6B66F3499E6F7CDA17ADF7CBFA" originalValue="Hultén" pageId="null" pageNumber="308">Hulten</normalizedToken>
(1962) und Meusel (1964) (mit 10 Unterarten!). - Im Gebiet: Alpen, verbreitet, nicht 
<normalizedToken id="5D81D7721505FD8C40C7716227CF2E5F" originalValue="häufig" pageId="null" pageNumber="308">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="8F85F0E7934FD04D9AE8669DE2EAFA31" pageId="null" pageNumber="308">
<emphasis id="9D9F0E5D70BEA5D10049897AD681E9CB" italics="true" pageId="null" pageNumber="308">Bemerkungen</emphasis>
. Die Vielgestaltigkeit der morphologischen und physiologischen Merkmale wurde im weiten Verbreitungsareal des 
<taxonomicName id="9BF3F7B8578746EFE9967D4E6CD49889" authority="von Clebsch (1960)" authorityName="von Clebsch" authorityYear="1960" class="Liliopsida" family="Poaceae" genus="Trisetum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="308" phylum="Tracheophyta" rank="species" species="spicatum">
<emphasis id="918EB1CE8E7F649BCE6E96A8DBFB44C5" italics="true" pageId="null" pageNumber="308">T. spicatum</emphasis>
von Clebsch (1960)
</taxonomicName>
untersucht. 
<taxonomicName id="66AB7E8983B6467B67C31729FB8551A2" class="Liliopsida" family="Poaceae" genus="Trisetum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="308" phylum="Tracheophyta" rank="species" species="spicatum">
<emphasis id="46C707B7CBC883D604EB2CFD0008A4D5" italics="true" pageId="null" pageNumber="308">T. spicatum</emphasis>
</taxonomicName>
ist von 
<normalizedToken id="9633EBDE36A2521923C3C159CEF8AC94" originalValue="Hultén" pageId="null" pageNumber="308">Hulten</normalizedToken>
(1959) anhand von Herbarstudien in zahlreiche Unterarten und 
<normalizedToken id="25F6AEBE37AE684D7B4D4FD6CE5F526B" originalValue="Varietäten" pageId="null" pageNumber="308">Varietaeten</normalizedToken>
gegliedert worden; danach 
<normalizedToken id="0449E15DE4AD33464FB2B69C2D505F9E" originalValue="gehören" pageId="null" pageNumber="308">gehoeren</normalizedToken>
alle Belege aus den 
<normalizedToken id="22FB2FCA3BAD1A72359D2DAEA32EE04D" originalValue="Pyrenäen" pageId="null" pageNumber="308">Pyrenaeen</normalizedToken>
, Alpen und dem Kaukasus zur 
<taxonomicName id="107AE4EC35D7E177624959C88D27E293" authority="Hulten. Es" authorityName="Hulten. Es" pageId="null" pageNumber="308" rank="subSpecies" subSpecies="ovatipaniculatum">
ssp. 
<emphasis id="2B5F5F046A18C72244BABD9C22718744" italics="true" pageId="null" pageNumber="308">ovatipaniculatum</emphasis>
<normalizedToken id="0BB0E1C7A7D2DE426BF9A2763131BA0E" originalValue="Hultén" pageId="null" pageNumber="308">Hulten</normalizedToken>
. Es
</taxonomicName>
ist festzustellen, welche Chromosomensippen in den Alpen vorkommen.
</paragraph>
</subSubSection>
