<collectingCountry id="F31CBCD0FF95BD43FE6DFE3D8B49FE76" box="[497,587,461,483]" name="Thailand" pageId="2" pageNumber="1551">Thailand</collectingCountry>
(
<bibRefCitation id="EF9A81B1FF95BD43FDC5FE3D8BEDFE76" author="ASSING V" box="[601,751,461,483]" journalOrPublisher="Beitrage zur Entomologie, Keltern" pageId="2" pageNumber="1551" pagination="89 - 148" part="61" refId="ref3466" refString="ASSING V. (2011 a): A revision of the genus Neosclerus CAMERON (Coleoptera: Staphylinidae: Paederinae). - Beitrage zur Entomologie, Keltern 61 (1): 89 - 148." title="A revision of the genus Neosclerus CAMERON (Coleoptera: Staphylinidae: Paederinae)" type="journal article" year="2011">ASSING 2011a</bibRefCitation>
