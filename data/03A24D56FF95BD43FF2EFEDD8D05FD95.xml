<taxonomicName id="4C0B87C3FF95BD43FD2AFE418A46FE53" box="[694,836,432,454]" class="Insecta" family="Staphylinidae" genus="Neosclerus" kingdom="Animalia" order="Coleoptera" pageId="2" pageNumber="1551" phylum="Arthropoda" rank="species" species="barbatulus">
