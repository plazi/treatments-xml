<subSubSection id="7E67557BFB28533CD72887DB38983BFB" pageId="null" pageNumber="610" type="description">
<paragraph id="F1923C17C51BCDCB7FDC44A7B81C33EB" pageId="null" pageNumber="610">
<normalizedToken id="264CA42F732D4A0BA09EAD479628D4BD" originalValue="Teilblätter" pageId="null" pageNumber="610">Teilblaetter</normalizedToken>
meist ganzrandig; 
<normalizedToken id="68C07A9389A6F82D3262F1CE44BA899A" originalValue="Nebenblätter" pageId="null" pageNumber="610">Nebenblaetter</normalizedToken>
ohne Flecken. 
<normalizedToken id="44B921B46DBCEEBA24AFD1C45E82AB6F" originalValue="Blüten" pageId="null" pageNumber="610">Blueten</normalizedToken>
zu 1-2. Stiel des 
<normalizedToken id="D8BBC64338B3E62784312878F7797621" originalValue="Blütenstandes" pageId="null" pageNumber="610">Bluetenstandes</normalizedToken>
wenig 
<normalizedToken id="0CF8F579FE582930CBBB7315D2A7083D" originalValue="kürzer" pageId="null" pageNumber="610">kuerzer</normalizedToken>
bis wenig 
<normalizedToken id="F721BCC592DF6F530D41303D0EC1C797" originalValue="länger" pageId="null" pageNumber="610">laenger</normalizedToken>
als die 
<normalizedToken id="27262CB6A154D33407A16F27B47085CA" originalValue="nächststehenden" pageId="null" pageNumber="610">naechststehenden</normalizedToken>
<normalizedToken id="345DB33E111BDAD14D37E287525A8792" originalValue="Nebenblätter" pageId="null" pageNumber="610">Nebenblaetter</normalizedToken>
. Krone 1,5-3 cm lang, 
<emphasis id="A5BE63C34E4193BA568C51C47C4E2257" italics="true" pageId="null" pageNumber="610">
meist einfarbig 
<normalizedToken id="3B07ED86058819BEBBAE5137942CFB8C" originalValue="weiß" pageId="null" pageNumber="610">weiss</normalizedToken>
oder 
<normalizedToken id="B015B3564A7A7AC3D5F2C075BC5A159C" originalValue="rötlich" pageId="null" pageNumber="610">roetlich</normalizedToken>
. Frucht 1,4-2,5 cm breit.
</emphasis>
Samen kugelig, 5-8 mm im Durchmesser. - 
<normalizedToken id="4EBA31B0EAEACEB2BB34ABF434E6BE85" originalValue="Blüte" pageId="null" pageNumber="610">Bluete</normalizedToken>
: 
<normalizedToken id="06CDA29CE8B686B8DAD2D57AADBB2476" originalValue="Später" pageId="null" pageNumber="610">Spaeter</normalizedToken>
<normalizedToken id="4F619900AFA76B3C83FB55214967CCEE" originalValue="Frühling" pageId="null" pageNumber="610">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="C7381F3FA2BF7C4C44147AF725666B4F" pageId="null" pageNumber="610">
<emphasis id="65F8BF400964EC675B3A576F3E059BD1" italics="true" pageId="null" pageNumber="610">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="12B2BC503A2AB9E17C3117356D28D84B" italics="true" pageId="null" pageNumber="610">14:</emphasis>
Material aus Kulturen (Sansome aus Darlington und Wylie 1955, Atabekova 1959, zahlreiche weitere Autoren bei Senn 1938a und 
<normalizedToken id="9FBCB1751E2DFF44AC49AD1714A89446" originalValue="Löve" pageId="null" pageNumber="610">Loeve</normalizedToken>
und 
<normalizedToken id="7EF0B90FCD37EF735EFF1B12BE09CE3F" originalValue="Löve" pageId="null" pageNumber="610">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="FCD43CFE10369671D86B09BC9AB58C25" pageId="null" pageNumber="610">
<emphasis id="743E90970CB0E40578BB43905907A961" italics="true" pageId="null" pageNumber="610">Standort.</emphasis>
Kollin und montan. Lockere, eher kalkarme, lehmige 
<normalizedToken id="B76D8018393139ACD25017E733CE14FF" originalValue="Böden" pageId="null" pageNumber="610">Boeden</normalizedToken>
. 
<normalizedToken id="DEB81379FFF1B18F533F9F897B1B1EC9" originalValue="Äcker" pageId="null" pageNumber="610">Aecker</normalizedToken>
.
</paragraph>
<paragraph id="C847DCBF22309865DA475B33166ABA5E" pageId="null" pageNumber="610">
<emphasis id="D7714C2C03F3207CC677AA85A99CAFAB" italics="true" pageId="null" pageNumber="610">Verbreitung.</emphasis>
<normalizedToken id="EDBBAEF985292857F02828141739883F" originalValue="Ursprüngliche" pageId="null" pageNumber="610">Urspruengliche</normalizedToken>
Verbreitung nicht bekannt, wahrscheinlich aus den folgenden Arten 
<normalizedToken id="2A91AF6CF2730B9980FC0DBA13F2A95D" originalValue="herausgezüchtet" pageId="null" pageNumber="610">herausgezuechtet</normalizedToken>
. - Im Gebiet oft angepflanzt und selten verwildert.
</paragraph>
</subSubSection>
