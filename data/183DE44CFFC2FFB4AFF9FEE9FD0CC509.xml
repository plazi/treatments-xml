(
<bibRefCitation id="F40528ABFFC2FFB4AE9CFEE8FDEAC63C" author="Schaus W." box="[421,591,286,315]" pageId="66" pageNumber="65" pagination="383 - 460" refId="ref86973" refString="Schaus W. 1902. Descriptions of new American butterflies. Proceedings of the United States national Museum 24 (1262): 383 - 460." type="journal article" year="1902">Schaus, 1902</bibRefCitation>
)
</taxonomicName>
