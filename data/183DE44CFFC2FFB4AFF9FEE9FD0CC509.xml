<subSubSection id="D88E06D1FFC2FFB4AFF9FEBDFD0CC509" pageId="66" pageNumber="65" type="reference_group">
<paragraph id="902B555AFFC2FFB4AFF9FEBDFD0CC509" blockId="66.[192,1444,330,526]" pageId="66" pageNumber="65">
<taxonomicName id="57942ED9FFC2FFB4AFF9FEBDFDACC663" authority="Schaus, 1902" authorityName="Schaus" authorityYear="1902" box="[192,521,330,356]" class="Insecta" family="Hesperiidae" genus="Papias" kingdom="Animalia" order="Lepidoptera" pageId="66" pageNumber="65" phylum="Arthropoda" rank="species" species="sobrinus">
<emphasis id="A2E08948FFC2FFB4AFF9FEBDFEC8C663" box="[192,365,330,356]" italics="true" pageId="66" pageNumber="65">Papias sobrinus</emphasis>
<bibRefCitation id="F40528ABFFC2FFB4AE4FFEBCFDACC663" author="Schaus W." box="[374,521,330,356]" pageId="66" pageNumber="65" pagination="383 - 460" refId="ref86973" refString="Schaus W. 1902. Descriptions of new American butterflies. Proceedings of the United States national Museum 24 (1262): 383 - 460." type="journal article" year="1902">Schaus, 1902</bibRefCitation>
</taxonomicName>
(type locality 
<collectingCountry id="E88315CAFFC2FFB4AD96FEBCFD51C663" box="[687,756,330,356]" name="Brazil" pageId="66" pageNumber="65">Brazil</collectingCountry>
: 
<collectingRegion id="52509BB8FFC2FFB4ADC6FEBCFC00C662" box="[767,933,330,357]" country="Brazil" name="Rio de Janeiro" pageId="66" pageNumber="65">Rio de Janeiro</collectingRegion>
) is currently a junior subjective synonym of 
<taxonomicName id="57942ED9FFC2FFB4AFF9FE9BFDAEC681" authority="Godman, 1900" authorityName="Godman" authorityYear="1900" box="[192,523,364,390]" class="Insecta" family="Hesperiidae" genus="Papias" kingdom="Animalia" order="Lepidoptera" pageId="66" pageNumber="65" phylum="Arthropoda" rank="species" species="phainis">
<emphasis id="A2E08948FFC2FFB4AFF9FE9BFEFAC681" box="[192,351,364,390]" italics="true" pageId="66" pageNumber="65">Papias phainis</emphasis>
Godman, 1900
</taxonomicName>
(type locality 
<collectingCountry id="E88315CAFFC2FFB4AD93FE9AFCA5C681" box="[682,768,364,390]" name="Mexico" pageId="66" pageNumber="65">Mexico</collectingCountry>
: 
<collectingRegion id="52509BB8FFC2FFB4AC30FE9AFCD5C681" box="[777,880,364,390]" country="Mexico" name="Veracruz de Ignacio de la Llave" pageId="66" pageNumber="65">Veracruz</collectingRegion>
; 
<collectingCountry id="E88315CAFFC2FFB4AC42FE9AFC51C681" box="[891,1012,364,390]" name="Guatemala" pageId="66" pageNumber="65">Guatemala</collectingCountry>
and 
<collectingCountry id="E88315CAFFC2FFB4AB12FE9AFB0DC680" box="[1067,1192,364,391]" name="Costa Rica" pageId="66" pageNumber="65">Costa Rica</collectingCountry>
). Sequencing of 
<specimenCount id="86929ED3FFC2FFB4AA67FE9AFA01C681" box="[1374,1444,364,390]" pageId="66" pageNumber="65" type="generic">
two 
<taxonomicName id="57942ED9FFC2FFB4AAB7FE9BFA01C681" authorityName="Schaus" authorityYear="1902" box="[1422,1444,365,390]" class="Insecta" family="Hesperiidae" genus="Papias" kingdom="Animalia" order="Lepidoptera" pageId="66" pageNumber="65" phylum="Arthropoda" rank="species" species="sobrinus">
<emphasis id="A2E08948FFC2FFB4AAB7FE9BFA01C681" box="[1422,1444,365,390]" italics="true" pageId="66" pageNumber="65">P.</emphasis>
</taxonomicName>
</specimenCount>
sobrinus 
<typeStatus id="4F2FEBF8FFC2FFB4AE1AFE78FE21C6AF" box="[291,388,398,424]" pageId="66" pageNumber="65">syntypes</typeStatus>
revealed that they are not even in the same genus with 
<taxonomicName id="57942ED9FFC2FFB4ACCCFE78FBFBC6AF" authorityName="Godman" authorityYear="1900" box="[1013,1118,398,424]" class="Insecta" family="Hesperiidae" genus="Papias" kingdom="Animalia" order="Lepidoptera" pageId="66" pageNumber="65" phylum="Arthropoda" rank="species" species="phainis">
<emphasis id="A2E08948FFC2FFB4ACCCFE78FBFBC6AF" box="[1013,1118,398,424]" italics="true" pageId="66" pageNumber="65">P.phainis</emphasis>
</taxonomicName>
(
<figureCitation id="08AF49DFFFC2FFB4AB55FE78FB18C6AF" box="[1132,1213,398,424]" captionStart="Figure 14" captionStartId="67.[192,268,1900,1926]" captionTargetBox="[194,1437,361,1873]" captionTargetId="figure-11@67.[192,1440,361,1878]" captionTargetPageId="67" captionText="Figure 14. Genomic tree of Moncina, part 2. See Fig. 1 legend for notations." figureDoi="http://doi.org/10.5281/zenodo.6392088" httpUri="https://zenodo.org/record/6392088/files/figure.png" pageId="66" pageNumber="65">Fig. 14</figureCitation>
). In genitalia, uncus arms are long and wide apart in 
<taxonomicName id="57942ED9FFC2FFB4AD1AFE46FD2EC6CE" authorityName="Godman" authorityYear="1900" box="[547,651,431,457]" class="Insecta" family="Hesperiidae" genus="Papias" kingdom="Animalia" order="Lepidoptera" pageId="66" pageNumber="65" phylum="Arthropoda" rank="species" species="phainis">
<emphasis id="A2E08948FFC2FFB4AD1AFE46FD2EC6CE" box="[547,651,431,457]" italics="true" pageId="66" pageNumber="65">P.phainis</emphasis>
</taxonomicName>
, but are small and close together in 
<taxonomicName id="57942ED9FFC2FFB4AB20FE46FB28C6CE" authorityName="Schaus" authorityYear="1902" box="[1049,1165,431,457]" class="Insecta" family="Hesperiidae" genus="Papias" kingdom="Animalia" order="Lepidoptera" pageId="66" pageNumber="65" phylum="Arthropoda" rank="species" species="sobrinus">
<emphasis id="A2E08948FFC2FFB4AB20FE46FB28C6CE" box="[1049,1165,431,457]" italics="true" pageId="66" pageNumber="65">P. sobrinus</emphasis>
</taxonomicName>
. Our genomic tree demonstrates that 
<taxonomicName id="57942ED9FFC2FFB4AE67FE24FE76C6EC" authorityName="Schaus" authorityYear="1902" box="[350,467,465,491]" class="Insecta" family="Hesperiidae" genus="Papias" kingdom="Animalia" order="Lepidoptera" pageId="66" pageNumber="65" phylum="Arthropoda" rank="species" species="sobrinus">
<emphasis id="A2E08948FFC2FFB4AE67FE24FE76C6EC" box="[350,467,465,491]" italics="true" pageId="66" pageNumber="65">P. sobrinus</emphasis>
</taxonomicName>
belongs to a new genus named above. Therefore, we propose 
<taxonomicName id="57942ED9FFC2FFB4ABBAFE24FEA7C50A" authority="(Schaus, 1902)" baseAuthorityName="Schaus" baseAuthorityYear="1902" class="Insecta" family="Hesperiidae" genus="Rectava" kingdom="Animalia" order="Lepidoptera" pageId="66" pageNumber="65" phylum="Arthropoda" rank="species" species="sobrinus">
<emphasis id="A2E08948FFC2FFB4ABBAFE24FA99C6EC" box="[1155,1340,465,491]" italics="true" pageId="66" pageNumber="65">Rectava sobrinus</emphasis>
(
<bibRefCitation id="F40528ABFFC2FFB4AA72FE27FF5FC50A" author="Schaus W." pageId="66" pageNumber="65" pagination="383 - 460" refId="ref86973" refString="Schaus W. 1902. Descriptions of new American butterflies. Proceedings of the United States national Museum 24 (1262): 383 - 460." type="journal article" year="1902">Schaus, 1902</bibRefCitation>
)
</taxonomicName>
, 
<emphasis id="A2E08948FFC2FFB4AE35FE05FE6EC50A" bold="true" box="[268,459,499,525]" pageId="66" pageNumber="65">reinstated status</emphasis>
, 
<emphasis id="A2E08948FFC2FFB4AEE1FE05FD06C50A" bold="true" box="[472,675,499,525]" pageId="66" pageNumber="65">new combination</emphasis>
.
</paragraph>
</subSubSection>
