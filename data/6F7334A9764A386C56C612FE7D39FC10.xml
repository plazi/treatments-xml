<taxonomicName id="8E52FF76AC5FCD51CAE796356C98938B" authority="Hackel" class="Liliopsida" family="Poaceae" genus="Bromus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="363" phylum="Tracheophyta" rank="species" species="condensatus">
