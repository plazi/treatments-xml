<collectingRegion id="A225F80DFFD3D65D0285FA3A185033EE" box="[2255,2431,1494,1527]" country="Papua New Guinea" name="New Ireland" pageId="5" pageNumber="696">New Ireland</collectingRegion>
I in 
<collectingCountry id="18F6767FFFD3D65D0381FA3A176A3007" name="Papua New Guinea" pageId="5" pageNumber="696">Bismarck Archipelago</collectingCountry>
, and D’Entrecasteaux Is), and Solomon Is; possibly this species also recorded on mainland SE Asia (
<collectingCountry id="18F6767FFFD3D65D0D75F9C116EE305F" box="[1855,1985,1581,1606]" name="Thailand" pageId="5" pageNumber="696">Thailand</collectingCountry>
, S 
<collectingCountry id="18F6767FFFD3D65D0DA1F9C11952305F" box="[2027,2173,1581,1606]" name="Cambodia" pageId="5" pageNumber="696">Cambodia</collectingCountry>
, and S 
<collectingCountry id="18F6767FFFD3D65D02A9F9C1184D305F" box="[2275,2402,1581,1606]" name="Vietnam" pageId="5" pageNumber="696">Vietnam</collectingCountry>
).
</paragraph>
