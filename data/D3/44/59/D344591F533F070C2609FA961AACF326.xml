<subSubSection pageId="2" pageNumber="483" type="reference_group">
<paragraph blockId="2.[1992,2585,1525,1948]" pageId="2" pageNumber="483">
<emphasis bold="true" box="[1992,2147,1525,1554]" pageId="2" pageNumber="483">Taxonomy.</emphasis>
<taxonomicName authority="Ramsay, 1888" authorityName="Ramsay" authorityYear="1888" class="Mammalia" family="Phalangeridae" genus="Phalangista" kingdom="Animalia" order="Diprotodontia" pageId="2" pageNumber="483" phylum="Chordata" rank="species" species="johnstonii">Phalangista johnstonii Ramsay, 1888</taxonomicName>
