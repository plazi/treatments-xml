<caption id="DF3E50CB9E7DFFB9B7E7FA55FDF06B8F" ID-DOI="http://doi.org/10.5281/zenodo.6538436" ID-Zenodo-Dep="6538436" httpUri="https://zenodo.org/record/6538436/files/figure.png" pageId="10" pageNumber="409" startId="10.[151,264,1415,1439]" targetBox="[151,1435,183,1391]" targetPageId="10">
<paragraph id="8BFE00439E7DFFB9B7E7FA55FDF06B8F" blockId="10.[151,1436,1415,1475]" pageId="10" pageNumber="409">
<emphasis id="B935DC519E7DFFB9B7E7FA55FEC56BD3" bold="true" box="[151,340,1415,1439]" pageId="10" pageNumber="409">FIGURES 19–23.</emphasis>
