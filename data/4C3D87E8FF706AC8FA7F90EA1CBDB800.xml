No information.
</paragraph>
</subSubSection>
<subSubSection id="8C8E6575FF706ACFFA869B4D18F0B603" box="[1402,1776,3348,3377]" pageId="139" pageNumber="899" type="breeding">
<paragraph id="C42B36FEFF706ACFFA869B4D18F0B603" blockId="139.[1400,2612,2320,3497]" box="[1402,1776,3348,3377]" pageId="139" pageNumber="899">
