<taxonomicName LSID="http://zoobank.org/58FB3D34-B53E-4735-8948-27371BB740DA" authority="Carmo and Sampronha" authorityName="Carmo and Sampronha" authorityYear="2022" family="Tabanidae" genus="Araripus" higherTaxonomySource="treatment-meta" kingdom="Animalia" lsidName="Araripus" order="Diptera" pageId="0" pageNumber="295" rank="genus" status="gen. nov.">Araripus Carmo and Sampronha</taxonomicName>
