</paragraph>
</subSubSection>
<subSubSection id="96BC651BB73328410FA5FD673775FC64" pageId="22" pageNumber="412" type="multiple">
<caption id="8AD96618B73328410FA5FD673775FC64" ID-DOI="http://doi.org/10.5281/zenodo.6628630" ID-Zenodo-Dep="6628630" httpUri="https://zenodo.org/record/6628630/files/figure.png" inLine="true" pageId="22" pageNumber="412" targetBox="[1433,2015,495,904]" targetPageId="22">
<paragraph id="DE193690B73328410FA5FD6739A5FC0C" blockId="22.[2046,2633,486,909]" lastBlockId="22.[1429,2636,915,2679]" pageId="22" pageNumber="412">
<emphasis id="ECD2EA82B73328410FA5FD6736D1FCAF" bold="true" box="[2047,2447,758,791]" pageId="22" pageNumber="412">Subspecies and Distribution.</emphasis>
<taxonomicName id="19A64D13B73328410058FCB036EEFC86" authority="Linnaeus, 1758" authorityName="Linnaeus" authorityYear="1758" baseAuthorityName="Linnaeus" baseAuthorityYear="1758" box="[2050,2480,801,830]" class="Mammalia" family="Cebidae" genus="Cebus" kingdom="Animalia" order="Primates" pageId="22" pageNumber="412" phylum="Chordata" rank="subSpecies" species="capucinus" subSpecies="capucinus">C.c.capucinusLinnaeus,1758—EPanama,WColombia(Pacificcoastalregion),andNWEcuador(SasfarastheRioEs-</taxonomicName>
meraldas-Guayllabamba).
</paragraph>
<paragraph id="DE193690B73328410DC0FC523775FC64" blockId="22.[1429,2636,915,2679]" box="[1434,2091,963,988]" pageId="22" pageNumber="412">
<taxonomicName id="19A64D13B73328410DC0FC523989FC64" authority="Bangs, 1905" authorityName="Bangs" authorityYear="1905" box="[1434,1751,963,988]" class="Mammalia" family="Cebidae" genus="Cebus" kingdom="Animalia" order="Primates" pageId="22" pageNumber="412" phylum="Chordata" rank="subSpecies" species="capucinus" subSpecies="curtus">C. c. curtus Bangs, 1905</taxonomicName>
