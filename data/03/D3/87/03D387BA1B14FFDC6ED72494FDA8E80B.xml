Basidiomata of 
<taxonomicName authorityName="N. K. Zeng, Y. Wang, C. Xu &amp; Y. Y. Yang" authorityYear="2022" box="[407,563,1377,1398]" class="Agaricomycetes" family="Boletaceae" genus="Boletus" kingdom="Fungi" order="Boletales" pageId="7" pageNumber="183" phylum="Basidiomycota" rank="species" species="littoreus">
<emphasis box="[407,563,1377,1398]" italics="true" pageId="7" pageNumber="183">Boletus littoreus</emphasis>
</taxonomicName>
. (
<emphasis bold="true" box="[583,595,1377,1398]" pageId="7" pageNumber="183">a</emphasis>
, 
<emphasis bold="true" box="[606,617,1377,1398]" pageId="7" pageNumber="183">c</emphasis>
from FHMU5923; 
<emphasis bold="true" box="[802,815,1377,1398]" pageId="7" pageNumber="183">b</emphasis>
, 
