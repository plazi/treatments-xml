<collectingCountry box="[825,877,615,637]" name="India" pageId="17" pageNumber="1150">India</collectingCountry>
was collected from elephant dung at an altitude of 
<quantity box="[492,571,645,666]" metricMagnitude="3" metricUnit="m" metricValue="1.0" pageId="17" pageNumber="1150" unit="m" value="1000.0">1000 m</quantity>
, together with 
<taxonomicName authorityName="Kraatz" authorityYear="1859" box="[721,846,645,666]" class="Insecta" family="Staphylinidae" genus="Lithocharis" kingdom="Animalia" order="Coleoptera" pageId="17" pageNumber="1150" phylum="Arthropoda" rank="species" species="sororcula">
<emphasis box="[721,846,645,666]" italics="true" pageId="17" pageNumber="1150">L. sororcula</emphasis>
</taxonomicName>
.
