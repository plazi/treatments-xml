<subSubSection box="[534,1789,525,621]" pageId="0" pageNumber="412" type="vernacular_names">
<paragraph blockId="0.[534,1789,424,621]" box="[534,1789,525,621]" pageId="0" pageNumber="412">(SMOKY BAT THUMBLESS BAT)</paragraph>
