<paragraph blockId="27.[151,670,978,1005]" box="[151,670,978,1005]" pageId="27" pageNumber="178">
<heading bold="true" box="[151,670,978,1005]" fontSize="11" level="1" pageId="27" pageNumber="178" reason="1">
<taxonomicName authority="(Gerstaecker, 1883)" baseAuthorityName="Gerstaecker" baseAuthorityYear="1883" box="[151,670,978,1005]" class="Insecta" family="Cetoniidae" genus="Niphobleta" kingdom="Animalia" order="Coleoptera" pageId="27" pageNumber="178" phylum="Arthropoda" rank="species" species="squamipes">
<emphasis bold="true" box="[151,670,978,1005]" pageId="27" pageNumber="178">
<emphasis bold="true" box="[151,419,978,1005]" italics="true" pageId="27" pageNumber="178">Niphobleta squamipes</emphasis>
(Gerstaecker, 1883)
</emphasis>
</taxonomicName>
</heading>
</paragraph>
