<taxonomicName authorityName="Janson" authorityYear="1888" box="[809,928,223,249]" class="Insecta" family="Cetoniidae" genus="Charadronota" kingdom="Animalia" order="Coleoptera" pageId="27" pageNumber="178" phylum="Arthropoda" rank="species" species="curvata">
<emphasis box="[809,928,223,249]" italics="true" pageId="27" pageNumber="178">C. curvata</emphasis>
</taxonomicName>
, 
<taxonomicName baseAuthorityName="Gory &amp; Percheron" baseAuthorityYear="1883" box="[941,1131,223,249]" class="Insecta" family="Cetoniidae" genus="Charadronota" kingdom="Animalia" order="Coleoptera" pageId="27" pageNumber="178" phylum="Arthropoda" rank="species" species="quadrisignata">
<emphasis box="[941,960,223,249]" italics="true" pageId="27" pageNumber="178">C</emphasis>
. 
<emphasis box="[974,1131,223,249]" italics="true" pageId="27" pageNumber="178">quadrisignata</emphasis>
