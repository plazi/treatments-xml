<subSubSection pageId="91" pageNumber="370" type="activity">
<paragraph blockId="91.[1399,2606,926,1472]" pageId="91" pageNumber="370">
<emphasis bold="true" box="[1399,1642,1281,1314]" pageId="91" pageNumber="370">Activity patterns.</emphasis>
