<subSubSection pageId="89" pageNumber="368" type="reference_group">
<paragraph blockId="89.[738,1331,1400,1827]" pageId="89" pageNumber="368">
<emphasis bold="true" box="[738,893,1400,1433]" pageId="89" pageNumber="368">Taxonomy.</emphasis>
<taxonomicName authorityName="Chapman" authorityYear="1889" class="Mammalia" family="Cricetidae" genus="Hesperomys" kingdom="Animalia" order="Rodentia" pageId="89" pageNumber="368" phylum="Chordata" rank="species" species="floridanus">Hesperomys floridanus F. M. Chapman, 1889</taxonomicName>
