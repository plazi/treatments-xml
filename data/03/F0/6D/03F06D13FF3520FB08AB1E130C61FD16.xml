<caption ID-DOI="http://doi.org/10.5281/zenodo.6761409" ID-Zenodo-Dep="6761409" box="[2047,2458,3088,3121]" httpUri="https://zenodo.org/record/6761409/files/figure.png" inLine="true" pageId="155" pageNumber="434" startId="155.[2047,2219,3088,3121]" targetBox="[1433,2024,2859,3272]" targetPageId="155">
