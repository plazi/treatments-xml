<paragraph blockId="116.[1451,2653,3369,3481]" pageId="116" pageNumber="394">
<taxonomicName authority=". A. Allen, 1891" authorityName=". A. Allen" authorityYear="1891" box="[1452,1853,3409,3442]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="116" pageNumber="394" phylum="Chordata" rank="subSpecies" species="nasutus" subSpecies="nasutusJ">P. n. nasutusJ. A. Allen, 1891</taxonomicName>
— from SE Utah and NC Colorado S through E Arizona, New Mexico, and W Texas, USA, to C Coahuila, Mexico.
</paragraph>
<paragraph blockId="117.[137,1346,297,1318]" pageId="117" pageNumber="395">
<taxonomicName authority="Benson, 1932" authorityName="Benson" authorityYear="1932" box="[141,497,297,330]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="117" pageNumber="395" phylum="Chordata" rank="subSpecies" species="nasutus" subSpecies="griseus">P.n.griseusBenson,1932—restrictedtolavafieldssurroundingthetypelocalityinCNewMexico,USA.</taxonomicName>
</paragraph>
<paragraph blockId="117.[137,1346,297,1318]" pageId="117" pageNumber="395">
<taxonomicName authority="Mearns, 1896" authorityName="Mearns" authorityYear="1896" box="[141,563,375,408]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="117" pageNumber="395" phylum="Chordata" rank="subSpecies" species="nasutus" subSpecies="penicillatus">P.n. penicillatus Mearns, 1896</taxonomicName>
