<paragraph blockId="79.[2066,2659,3012,3439]" pageId="79" pageNumber="358">
<emphasis bold="true" box="[2066,2221,3012,3045]" pageId="79" pageNumber="358">Taxonomy.</emphasis>
<taxonomicName authority=" Merriam, 1903" authorityName=" Merriam" authorityYear="1903" class="Mammalia" family="Cricetidae" genus="Neotoma" kingdom="Animalia" order="Rodentia" pageId="79" pageNumber="358" phylum="Chordata" rank="species" species="goldmani">Neotoma goldmani: Merriam, 1903</taxonomicName>
, 
