<subSubSection pageId="187" pageNumber="466" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6707278" ID-Zenodo-Dep="6707278" httpUri="https://zenodo.org/record/6707278/files/figure.png" inLine="true" pageId="187" pageNumber="466" targetBox="[127,717,2502,2916]" targetPageId="187">
<paragraph blockId="187.[740,1333,2500,2922]" pageId="187" pageNumber="466">
<emphasis bold="true" box="[741,916,2696,2725]" pageId="187" pageNumber="466">Distribution.</emphasis>
SE Peru (S 
<taxonomicName authority="Carabaya" authorityName="Carabaya" class="Magnoliopsida" family="Chrysobalanaceae" genus="Cordillera" kingdom="Plantae" order="Malpighiales" pageId="187" pageNumber="466" phylum="Tracheophyta" rank="genus">Cordillera Carabaya</taxonomicName>
) and WC Bolivia (
<taxonomicName authority="Real" authorityName="Real" box="[1065,1286,2736,2765]" class="Magnoliopsida" family="Chrysobalanaceae" genus="Cordillera" kingdom="Plantae" order="Malpighiales" pageId="187" pageNumber="466" phylum="Tracheophyta" rank="genus">Cordillera Real</taxonomicName>
).
</paragraph>
</caption>
