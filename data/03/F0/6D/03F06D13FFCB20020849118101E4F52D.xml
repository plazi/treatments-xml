<taxonomicName authority="Burt, 1932" authorityName="Burt" authorityYear="1932" box="[2191,2603,1670,1703]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="101" pageNumber="380" phylum="Chordata" rank="species" species="dickeyi">Peromyscus dickeyi Burt, 1932</taxonomicName>
