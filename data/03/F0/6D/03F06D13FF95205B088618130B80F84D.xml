<subSubSection pageId="59" pageNumber="338" type="reference_group">
<paragraph blockId="59.[1452,2660,3324,3478]" pageId="59" pageNumber="338">
<emphasis bold="true" box="[1453,1608,3324,3349]" pageId="59" pageNumber="338">Taxonomy.</emphasis>
<taxonomicName authority=": Baird, 1858" authorityName=": Baird" authorityYear="1858" box="[1624,2012,3324,3349]" class="Mammalia" family="Cricetidae" genus="Arvicola" kingdom="Animalia" order="Rodentia" pageId="59" pageNumber="338" phylum="Chordata" rank="species" species="brewer">Arvicola brewer: Baird, 1858</taxonomicName>
