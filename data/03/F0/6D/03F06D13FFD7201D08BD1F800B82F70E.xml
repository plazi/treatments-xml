— montane areas from N Puebla S to NW 
<taxonomicName box="[1089,1195,739,764]" class="Insecta" family="Acrididae" genus="Oaxaca" kingdom="Animalia" order="Orthoptera" pageId="122" pageNumber="400" phylum="Arthropoda" rank="genus">Oaxaca</taxonomicName>
