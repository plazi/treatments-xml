<subSubSection pageId="190" pageNumber="469" type="reference_group">
<paragraph blockId="190.[2065,2658,2388,2811]" pageId="190" pageNumber="469">
<emphasis bold="true" box="[2065,2221,2388,2417]" pageId="190" pageNumber="469">Taxonomy.</emphasis>
<taxonomicName authority="J. A. Allen &amp; F. M. Chapman, 1897" authorityName="J. A. Allen &amp; F. M. Chapman" authorityYear="1897" class="Mammalia" family="Cricetidae" genus="Akodon" kingdom="Animalia" order="Rodentia" pageId="190" pageNumber="469" phylum="Chordata" rank="species" species="urichi">Akodon urichi J. A. Allen &amp; F. M. Chapman, 1897</taxonomicName>
