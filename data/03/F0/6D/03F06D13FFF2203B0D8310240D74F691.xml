<taxonomicName baseAuthorityName="Saussure" baseAuthorityYear="1860" box="[1035,1216,1557,1590]" class="Mammalia" family="Cricetidae" genus="Reithrodontomys" kingdom="Animalia" order="Rodentia" pageId="92" pageNumber="371" phylum="Chordata" rank="species" species="mexicanus">R. mexicanus</taxonomicName>
. 
<taxonomicName class="Mammalia" family="Cricetidae" genus="Reithrodontomys" kingdom="Animalia" order="Rodentia" pageId="92" pageNumber="371" phylum="Chordata" rank="genus">Reithrodontomys</taxonomicName>
