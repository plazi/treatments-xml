<paragraph blockId="92.[178,1385,1758,2378]" box="[178,1216,2148,2181]" pageId="92" pageNumber="371">
<emphasis bold="true" box="[178,413,2148,2181]" pageId="92" pageNumber="371">Activity patterns.</emphasis>
