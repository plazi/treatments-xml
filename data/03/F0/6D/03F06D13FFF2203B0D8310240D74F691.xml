<subSubSection pageId="92" pageNumber="371" type="discussion">
<paragraph blockId="92.[794,1387,1324,1747]" pageId="92" pageNumber="371">
<taxonomicName box="[796,1003,1521,1550]" class="Mammalia" family="Cricetidae" genus="Reithrodontomys" kingdom="Animalia" order="Rodentia" pageId="92" pageNumber="371" phylum="Chordata" rank="genus">Reithrodontomys</taxonomicName>
