<taxonomicName authorityName="Zagorodnyuk" authorityYear="1990" box="[2138,2232,2341,2374]" class="Mammalia" family="Cricetidae" genus="Volemys" kingdom="Animalia" order="Rodentia" pageId="46" pageNumber="325" phylum="Chordata" rank="genus">Volemys</taxonomicName>
