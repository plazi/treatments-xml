<taxonomicName authorityName="Blyth" authorityYear="1863" box="[2253,2360,2424,2453]" class="Mammalia" family="Cricetidae" genus="Phaiomys" kingdom="Animalia" order="Rodentia" pageId="46" pageNumber="325" phylum="Chordata" rank="species" species="leucurus">leucurus</taxonomicName>
