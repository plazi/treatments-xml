</paragraph>
</subSubSection>
<subSubSection box="[1375,2327,2418,2451]" pageId="201" pageNumber="479" type="breeding">
<paragraph blockId="201.[1373,2580,2147,2727]" box="[1375,2327,2418,2451]" pageId="201" pageNumber="479">
<emphasis bold="true" box="[1375,1510,2418,2451]" pageId="201" pageNumber="479">Breeding.</emphasis>
