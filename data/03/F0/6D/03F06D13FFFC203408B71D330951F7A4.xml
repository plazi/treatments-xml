<taxonomicName authorityName="Goldman" authorityYear="1904" box="[2064,2127,2735,2768]" class="Mammalia" family="Cricetidae" genus="Neotoma" kingdom="Animalia" order="Rodentia" pageId="82" pageNumber="359" phylum="Chordata" rank="species" species="picta">picta</taxonomicName>
