<taxonomicName authorityName="Baird" authorityYear="1855" box="[2435,2554,2660,2689]" class="Mammalia" family="Cricetidae" genus="Neotoma" kingdom="Animalia" order="Rodentia" pageId="82" pageNumber="359" phylum="Chordata" rank="species" species="mexicana">mexicana</taxonomicName>
