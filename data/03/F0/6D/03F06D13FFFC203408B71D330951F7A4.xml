<taxonomicName box="[2269,2347,2774,2807]" class="Mammalia" family="Cricetidae" genus="Oligoryzomys" kingdom="Animalia" order="Rodentia" pageId="82" pageNumber="359" phylum="Chordata" rank="species" species="navus">navus</taxonomicName>
