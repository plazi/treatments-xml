<taxonomicName authorityName="Thomas" authorityYear="1911" box="[951,1091,767,796]" class="Mammalia" family="Cricetidae" genus="Proedromys" kingdom="Animalia" order="Rodentia" pageId="44" pageNumber="321" phylum="Chordata" rank="genus">Proedromys</taxonomicName>
