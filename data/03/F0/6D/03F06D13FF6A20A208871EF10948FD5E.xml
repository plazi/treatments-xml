<taxonomicName authority="Thomas, 1917" authorityName="Thomas" authorityYear="1917" box="[2238,2651,2904,2933]" class="Mammalia" family="Cricetidae" genus="Akodon" kingdom="Animalia" order="Rodentia" pageId="196" pageNumber="475" phylum="Chordata" rank="species" species="surdus">Akodon surdus Thomas, 1917</taxonomicName>
