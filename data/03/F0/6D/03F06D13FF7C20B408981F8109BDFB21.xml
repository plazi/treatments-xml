<taxonomicName box="[2130,2210,3337,3362]" class="Magnoliopsida" family="Asteraceae" genus="Bahia" kingdom="Plantae" order="Asterales" pageId="210" pageNumber="489" phylum="Tracheophyta" rank="genus">Bahia</taxonomicName>
