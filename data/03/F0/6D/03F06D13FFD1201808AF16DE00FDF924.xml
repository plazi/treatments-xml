<caption ID-DOI="http://doi.org/10.5281/zenodo.6761190" ID-Zenodo-Dep="6761190" box="[2042,2523,973,1002]" httpUri="https://zenodo.org/record/6761190/files/figure.png" inLine="true" pageId="127" pageNumber="406" startId="127.[2042,2214,973,1002]" targetBox="[1427,2019,821,1236]" targetPageId="127">
