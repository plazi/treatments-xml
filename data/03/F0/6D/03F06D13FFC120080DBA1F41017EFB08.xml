<taxonomicName authority="Elliot, 1903" authorityName="Elliot" authorityYear="1903" box="[306,696,2983,3008]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="111" pageNumber="389" phylum="Chordata" rank="species" species="sagax">Peromyscus sagax Elliot, 1903</taxonomicName>
