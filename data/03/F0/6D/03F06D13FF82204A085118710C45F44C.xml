<taxonomicName authorityName="Lataste" authorityYear="1887" box="[1933,2109,3370,3399]" class="Mammalia" family="Cricetidae" genus="Lasiopodomys" kingdom="Animalia" order="Rodentia" pageId="44" pageNumber="323" phylum="Chordata" rank="genus">Lasiopodomys</taxonomicName>
