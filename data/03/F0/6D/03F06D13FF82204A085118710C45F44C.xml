<taxonomicName box="[2288,2400,3405,3438]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="44" pageNumber="323" phylum="Chordata" rank="genus">Microtus</taxonomicName>
