<taxonomicName authorityName="Nehring" authorityYear="1898" box="[1656,1794,3405,3438]" class="Mammalia" family="Cricetidae" genus="Cricetus" kingdom="Animalia" order="Rodentia" pageId="44" pageNumber="323" phylum="Chordata" rank="species" species="brandti">L. brandti</taxonomicName>
