<taxonomicName authorityName="Thomas" authorityYear="1893" box="[1165,1267,2104,2137]" class="Mammalia" family="Cricetidae" genus="Neotoma" kingdom="Animalia" order="Rodentia" pageId="84" pageNumber="363" phylum="Chordata" rank="species" species="macrotis">macrotis</taxonomicName>
