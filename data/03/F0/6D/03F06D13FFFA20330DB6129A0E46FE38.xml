<taxonomicName authorityName="Baird" authorityYear="1858" box="[940,1042,2069,2098]" class="Mammalia" family="Cricetidae" genus="Neotoma" kingdom="Animalia" order="Rodentia" pageId="84" pageNumber="363" phylum="Chordata" rank="species" species="fuscipes">fuscipes</taxonomicName>
