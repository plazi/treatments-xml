<subSubSection pageId="113" pageNumber="392" type="breeding">
<paragraph blockId="113.[1415,2624,2140,3039]" pageId="113" pageNumber="392">
<emphasis bold="true" box="[1416,1556,2770,2803]" pageId="113" pageNumber="392">Breeding.</emphasis>
