— known only from San Martin I, Baja 
<taxonomicName box="[2389,2529,3408,3437]" class="Magnoliopsida" family="Geraniaceae" genus="California" kingdom="Plantae" order="Geraniales" pageId="84" pageNumber="361" phylum="Tracheophyta" rank="genus">California</taxonomicName>
