<taxonomicName box="[2101,2196,2547,2576]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="107" pageNumber="386" phylum="Chordata" rank="species" species="nudipes">nudipes</taxonomicName>
