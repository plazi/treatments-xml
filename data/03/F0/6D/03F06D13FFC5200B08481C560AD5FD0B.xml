<taxonomicName baseAuthorityName="Saussure" baseAuthorityYear="1860" box="[2480,2609,2350,2379]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="107" pageNumber="386" phylum="Chordata" rank="species" species="mexicanus">mexicanus</taxonomicName>
