<taxonomicName box="[2441,2515,1668,1701]" class="Mammalia" family="Cricetidae" genus="Eolagurus" kingdom="Animalia" order="Rodentia" pageId="38" pageNumber="317" phylum="Chordata" rank="species" species="luteus">luteus</taxonomicName>
