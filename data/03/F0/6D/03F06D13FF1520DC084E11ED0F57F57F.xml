<subSubSection box="[2013,2489,1867,1896]" pageId="187" pageNumber="466" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6707284" ID-Zenodo-Dep="6707284" box="[2013,2489,1867,1896]" httpUri="https://zenodo.org/record/6707284/files/figure.png" inLine="true" pageId="187" pageNumber="466" targetBox="[1398,1989,1634,2047]" targetPageId="187">
<paragraph blockId="187.[2010,2607,1631,2054]" box="[2013,2489,1867,1896]" pageId="187" pageNumber="466">
<emphasis bold="true" box="[2013,2189,1867,1896]" pageId="187" pageNumber="466">Distribution.</emphasis>
