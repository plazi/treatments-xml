<taxonomicName authorityName="Miller" authorityYear="1899" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="57" pageNumber="336" phylum="Chordata" rank="species" species="abbreviatus">Microtus abbreviatus G. S. Miller, 1899</taxonomicName>
