<subSubSection pageId="119" pageNumber="397" type="reference_group">
<paragraph blockId="119.[2032,2625,1051,1474]" pageId="119" pageNumber="397">
<emphasis bold="true" box="[2032,2188,1051,1080]" pageId="119" pageNumber="397">Taxonomy.</emphasis>
<taxonomicName authorityName="Merriam" authorityYear="1898" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="119" pageNumber="397" phylum="Chordata" rank="species" species="lepturus">Peromyscus lepturus Merriam, 1898</taxonomicName>
