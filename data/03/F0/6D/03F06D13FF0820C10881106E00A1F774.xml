E Paraguay, NE &amp; EC 
<taxonomicName class="Magnoliopsida" family="Rosaceae" genus="Argentina" kingdom="Plantae" order="Rosales" pageId="166" pageNumber="444" phylum="Tracheophyta" rank="genus">Argentina</taxonomicName>
