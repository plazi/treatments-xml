<paragraph blockId="92.[1454,2662,1204,2062]" box="[1455,2394,1909,1942]" pageId="92" pageNumber="370">
<emphasis bold="true" box="[1455,2155,1909,1942]" pageId="92" pageNumber="370">Movements, Home range and Social organization.</emphasis>
