<paragraph blockId="187.[738,1329,1199,1622]" pageId="187" pageNumber="465">
<emphasis bold="true" box="[738,893,1199,1228]" pageId="187" pageNumber="465">Taxonomy.</emphasis>
<taxonomicName authority="Thomas, 1902" authorityName="Thomas" authorityYear="1902" class="Mammalia" family="Cricetidae" genus="Oxymycterus" kingdom="Animalia" order="Rodentia" pageId="187" pageNumber="465" phylum="Chordata" rank="species" species="paramensis">Oxymycterus paramensis Thomas, 1902</taxonomicName>
