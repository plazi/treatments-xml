<taxonomicName baseAuthorityName="Wagner" baseAuthorityYear="1842" box="[600,722,3411,3444]" class="Mammalia" family="Cricetidae" genus="Cerradomys" kingdom="Animalia" order="Rodentia" pageId="168" pageNumber="447" phylum="Chordata" rank="species" species="subflavus">subflavus</taxonomicName>
as reciprocally monophyletic to 
<taxonomicName box="[1202,1335,3411,3444]" class="Mammalia" family="Cricetidae" genus="Cerradomys" kingdom="Animalia" order="Rodentia" pageId="168" pageNumber="446" phylum="Chordata" rank="species" species="goytaca">C. goytaca</taxonomicName>
and C. 
<taxonomicName box="[237,299,3454,3483]" class="Mammalia" family="Cricetidae" genus="Cerradomys" kingdom="Animalia" order="Rodentia" pageId="168" pageNumber="447" phylum="Chordata" rank="species" species="vivoi">vivoi</taxonomicName>
