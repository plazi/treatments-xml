<subSubSection pageId="168" pageNumber="447" type="discussion">
<paragraph blockId="168.[195,1400,3293,3491]" pageId="168" pageNumber="447">
<taxonomicName baseAuthorityName="Wagner" baseAuthorityYear="1842" box="[200,478,3372,3405]" class="Mammalia" family="Cricetidae" genus="Cerradomys" kingdom="Animalia" order="Rodentia" pageId="168" pageNumber="447" phylum="Chordata" rank="species" species="subflavus">Cerradomys subflavus</taxonomicName>
is the type species of the genus 
<taxonomicName box="[947,1092,3372,3405]" class="Mammalia" family="Cricetidae" genus="Cerradomys" kingdom="Animalia" order="Rodentia" pageId="168" pageNumber="447" phylum="Chordata" rank="genus">Cerradomys</taxonomicName>
