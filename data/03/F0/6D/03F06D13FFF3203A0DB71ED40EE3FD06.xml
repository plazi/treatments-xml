<subSubSection pageId="93" pageNumber="371" type="discussion">
<paragraph blockId="93.[737,1331,2835,3253]" pageId="93" pageNumber="371">
<taxonomicName authorityName="Benson" authorityYear="1939" box="[739,1017,2945,2978]" class="Mammalia" family="Cricetidae" genus="Reithrodontomys" kingdom="Animalia" order="Rodentia" pageId="93" pageNumber="371" phylum="Chordata" rank="species" species="burti">Reithrodontomys burti</taxonomicName>
is in subgenus 
<taxonomicName class="Mammalia" family="Cricetidae" genus="Reithrodontomys" kingdom="Animalia" order="Rodentia" pageId="93" pageNumber="371" phylum="Chordata" rank="genus">Reithrodontomys</taxonomicName>
