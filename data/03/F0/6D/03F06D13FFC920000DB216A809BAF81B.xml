<subSubSection pageId="103" pageNumber="381" type="discussion">
<paragraph blockId="103.[744,1337,926,1352]" pageId="103" pageNumber="381">
<taxonomicName authorityName="Burt" authorityYear="1932" box="[745,978,1086,1115]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="103" pageNumber="381" phylum="Chordata" rank="species" species="sejugis">Peromyscus sejugis</taxonomicName>
is in the 
<taxonomicName baseAuthorityName="Wagner" baseAuthorityYear="1845" box="[1115,1273,1086,1115]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="103" pageNumber="381" phylum="Chordata" rank="species" species="maniculatus">maniculatus</taxonomicName>
