</paragraph>
</subSubSection>
<subSubSection box="[134,1152,1757,1786]" pageId="103" pageNumber="381" type="breeding">
<paragraph blockId="103.[133,1337,1367,1984]" box="[134,1152,1757,1786]" pageId="103" pageNumber="381">
<emphasis bold="true" box="[134,268,1757,1786]" pageId="103" pageNumber="381">Breeding.</emphasis>
