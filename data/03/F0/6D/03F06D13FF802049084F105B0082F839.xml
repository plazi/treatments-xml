<caption ID-DOI="http://doi.org/10.5281/zenodo.6760501" ID-Zenodo-Dep="6760501" httpUri="https://zenodo.org/record/6760501/files/figure.png" inLine="true" pageId="46" pageNumber="325" startId="46.[2007,2179,1317,1350]" targetBox="[1392,1983,1170,1583]" targetPageId="46">
