<taxonomicName box="[1958,2055,3210,3243]" class="Mammalia" family="Cricetidae" genus="Pitymys" kingdom="Animalia" order="Rodentia" pageId="67" pageNumber="344" phylum="Chordata" rank="genus">Pitymys</taxonomicName>
