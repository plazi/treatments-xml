<subSubSection pageId="99" pageNumber="378" type="reference_group">
<paragraph blockId="99.[741,1336,610,1033]" pageId="99" pageNumber="378">
<emphasis bold="true" box="[741,896,610,639]" pageId="99" pageNumber="378">Taxonomy.</emphasis>
<taxonomicName authorityName="Lee &amp; Schmidly" authorityYear="1977" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="99" pageNumber="378" phylum="Chordata" rank="species" species="hooperi">Peromyscus hooperi Lee &amp; Schmidly, 1977</taxonomicName>
