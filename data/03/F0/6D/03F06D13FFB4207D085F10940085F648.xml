<taxonomicName authorityName="True" authorityYear="1894" box="[2035,2160,1600,1625]" class="Mammalia" family="Cricetidae" genus="Arvicola" kingdom="Animalia" order="Rodentia" pageId="26" pageNumber="305" phylum="Chordata" rank="species" species="albicauda">albicauda</taxonomicName>
