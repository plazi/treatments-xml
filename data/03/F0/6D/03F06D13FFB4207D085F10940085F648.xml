<taxonomicName baseAuthorityName="Severtzov" baseAuthorityYear="1879" box="[2269,2402,1560,1585]" class="Mammalia" family="Cricetidae" genus="Alticola" kingdom="Animalia" order="Rodentia" pageId="26" pageNumber="305" phylum="Chordata" rank="species" species="argentatus">argentatus</taxonomicName>
