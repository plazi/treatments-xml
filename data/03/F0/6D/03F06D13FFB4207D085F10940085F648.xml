<subSubSection pageId="26" pageNumber="305" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6760395" ID-Zenodo-Dep="6760395" httpUri="https://zenodo.org/record/6760395/files/figure.png" inLine="true" pageId="26" pageNumber="305" startId="26.[1994,2166,1674,1703]" targetBox="[1380,1971,1404,1818]" targetPageId="26">
<paragraph blockId="26.[1994,2587,1394,1822]" pageId="26" pageNumber="305">
<emphasis bold="true" box="[1994,2170,1674,1703]" pageId="26" pageNumber="305">Distribution.</emphasis>
