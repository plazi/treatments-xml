<taxonomicName authority="Rhoads, 1894" authorityName="Rhoads" authorityYear="1894" box="[929,1332,2232,2257]" class="Mammalia" family="Cricetidae" genus="Sitomys" kingdom="Animalia" order="Rodentia" pageId="103" pageNumber="381" phylum="Chordata" rank="species" species="keeni">Sitomys keeni Rhoads, 1894</taxonomicName>
