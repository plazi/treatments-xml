<subSubSection pageId="200" pageNumber="478" type="discussion">
<paragraph blockId="200.[2068,2661,1441,1864]" pageId="200" pageNumber="478">
Taxonomy of 
<taxonomicName authorityName="Hershkovitz" authorityYear="1998" box="[2264,2391,1599,1628]" class="Mammalia" family="Cricetidae" genus="Akodon" kingdom="Animalia" order="Rodentia" pageId="200" pageNumber="478" phylum="Chordata" rank="species" species="mystax">A. mystax</taxonomicName>
