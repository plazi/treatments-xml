<taxonomicName box="[834,976,1983,2008]" class="Magnoliopsida" family="Rosaceae" genus="Argentina" kingdom="Plantae" order="Rosales" pageId="252" pageNumber="530" phylum="Tracheophyta" rank="genus">Argentina</taxonomicName>
(E Catamarca, La Rioja, W 
<taxonomicName box="[173,293,2014,2047]" class="Insecta" family="Apidae" genus="Santiago" kingdom="Animalia" order="Hymenoptera" pageId="252" pageNumber="530" phylum="Arthropoda" rank="genus">Santiago</taxonomicName>
