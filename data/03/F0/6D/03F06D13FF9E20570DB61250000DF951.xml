<paragraph blockId="48.[1399,2608,735,1674]" box="[1399,1873,1325,1358]" pageId="48" pageNumber="327">
<emphasis bold="true" box="[1399,1634,1325,1358]" pageId="48" pageNumber="327">Activity patterns.</emphasis>
