<subSubSection pageId="91" pageNumber="370" type="discussion">
<paragraph blockId="91.[1392,2598,3250,3490]" pageId="91" pageNumber="370">
<taxonomicName box="[1395,1691,3290,3323]" class="Mammalia" family="Cricetidae" genus="Reithrodontomys" kingdom="Animalia" order="Rodentia" pageId="91" pageNumber="370" phylum="Chordata" rank="species" species="cherrii">Reithrodontomys cherrii</taxonomicName>
was considered a subspecies of 
<taxonomicName baseAuthorityName="Saussure" baseAuthorityYear="1860" box="[2138,2311,3290,3323]" class="Mammalia" family="Cricetidae" genus="Reithrodontomys" kingdom="Animalia" order="Rodentia" pageId="91" pageNumber="370" phylum="Chordata" rank="species" species="mexicanus">R. mexicanus</taxonomicName>
and elevated to species status in 2005. 
<taxonomicName box="[1662,1958,3329,3362]" class="Mammalia" family="Cricetidae" genus="Reithrodontomys" kingdom="Animalia" order="Rodentia" pageId="91" pageNumber="370" phylum="Chordata" rank="species" species="cherrii">Reithrodontomys cherrii</taxonomicName>
