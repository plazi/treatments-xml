<taxonomicName authority="Merriam, 1894" authorityName="Merriam" authorityYear="1894" class="Mammalia" family="Cricetidae" genus="Neotoma" kingdom="Animalia" order="Rodentia" pageId="81" pageNumber="358" phylum="Chordata" rank="species" species="melanura">Neotoma melanura Merriam, 1894</taxonomicName>
