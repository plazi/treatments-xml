<taxonomicName authority="Grinnell &amp; Orr, 1934" authorityName="Grinnell &amp; Orr" authorityYear="1934" box="[1408,1897,1833,1858]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="99" pageNumber="377" phylum="Chordata" rank="subSpecies" species="californicus" subSpecies="mariposae">P.c.mariposaeGrinnell&amp;Orr,1934—restrictedtoCCalifornia,USA.</taxonomicName>
