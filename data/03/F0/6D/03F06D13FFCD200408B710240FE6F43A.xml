<subSubSection pageId="99" pageNumber="377" type="discussion">
<paragraph blockId="99.[2019,2613,1321,1740]" pageId="99" pageNumber="377">
<taxonomicName authorityName="Gambel" authorityYear="1848" box="[2020,2321,1435,1464]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="99" pageNumber="377" phylum="Chordata" rank="species" species="californicus">Peromyscus californicus</taxonomicName>
is in the 
<taxonomicName authorityName="Gambel" authorityYear="1848" box="[2467,2613,1435,1464]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="99" pageNumber="377" phylum="Chordata" rank="species" species="californicus">californicus</taxonomicName>
species group. Five subspecies recognized.
</paragraph>
</subSubSection>
