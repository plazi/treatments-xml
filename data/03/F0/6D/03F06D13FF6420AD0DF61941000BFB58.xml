<subSubSection pageId="202" pageNumber="480" type="reference_group">
<paragraph blockId="202.[2074,2667,302,721]" pageId="202" pageNumber="480">
<emphasis bold="true" box="[2074,2229,302,327]" pageId="202" pageNumber="480">Taxonomy.</emphasis>
<taxonomicName authority="Gonzalez, Langguth &amp; L. F. Oliveira, 1998" authorityName="Gonzalez, Langguth &amp; L. F. Oliveira" authorityYear="1998" class="Mammalia" family="Cricetidae" genus="Akodon" kingdom="Animalia" order="Rodentia" pageId="202" pageNumber="480" phylum="Chordata" rank="species" species="reigi">Akodon reigi Gonzalez, Langguth &amp; L. F. Oliveira, 1998</taxonomicName>
, 
<materialsCitation pageId="202" pageNumber="480">
“Paso Averias, 
<paragraph blockId="202.[2074,2667,302,721]" pageId="202" pageNumber="480">Departamento de Lavalleja, Uruguay (Lat. 33°60’S; Long. 54°40°W).” This species is monotypic.</paragraph>
</materialsCitation>
</paragraph>
