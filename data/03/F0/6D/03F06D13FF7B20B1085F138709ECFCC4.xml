<taxonomicName authority="de" box="[2058,2239,2534,2567]" class="Magnoliopsida" family="Chrysobalanaceae" genus="Cordillera" kingdom="Plantae" order="Malpighiales" pageId="213" pageNumber="497" phylum="Tracheophyta" rank="genus">Cordillera de</taxonomicName>
