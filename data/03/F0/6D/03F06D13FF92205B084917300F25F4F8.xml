</paragraph>
<paragraph blockId="60.[1396,2605,1480,2851]" pageId="60" pageNumber="337">
<taxonomicName authority="Goldman, 1938" authorityName="Goldman" authorityYear="1938" box="[1401,1870,1716,1749]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="60" pageNumber="337" phylum="Chordata" rank="subSpecies" species="mogollonensis" subSpecies="hualpaiensis">M.m.hualpaiensisGoldman,1938—knownonlyfromHualapaiPeak,MohaveCounty,Arizona,USA.</taxonomicName>
</paragraph>
<paragraph blockId="60.[1396,2605,1480,2851]" pageId="60" pageNumber="337">
