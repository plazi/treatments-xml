<subSubSection pageId="37" pageNumber="314" type="discussion">
<paragraph blockId="37.[766,1385,1678,2096]" pageId="37" pageNumber="314">
<taxonomicName box="[793,991,1792,1821]" class="Mammalia" family="Cricetidae" genus="Ellobius" kingdom="Animalia" order="Rodentia" pageId="37" pageNumber="314" phylum="Chordata" rank="species" species="tancrer">Ellobius tancrer</taxonomicName>
is in the subgenus 
<taxonomicName box="[1277,1379,1792,1821]" class="Mammalia" family="Cricetidae" genus="Ellobius" kingdom="Animalia" order="Rodentia" pageId="37" pageNumber="314" phylum="Chordata" rank="genus">Ellobius</taxonomicName>
