<taxonomicName box="[1926,2065,3365,3394]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="32" pageNumber="309" phylum="Chordata" rank="subGenus" subGenus="Anteliomys">Anteliomys</taxonomicName>
