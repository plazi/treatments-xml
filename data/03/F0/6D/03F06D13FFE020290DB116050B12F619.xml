<subSubSection pageId="78" pageNumber="355" type="discussion">
<paragraph blockId="78.[744,1334,771,1198]" pageId="78" pageNumber="355">
<taxonomicName authorityName="Merriam" authorityYear="1897" box="[745,855,851,884]" class="Mammalia" family="Cricetidae" genus="Nelsonia" kingdom="Animalia" order="Rodentia" pageId="78" pageNumber="355" phylum="Chordata" rank="genus">Nelsonia</taxonomicName>
neomotodon 
<taxonomicName authorityName="Merriam" authorityYear="1903" box="[1028,1149,851,884]" class="Mammalia" family="Cricetidae" genus="Nelsonia" kingdom="Animalia" order="Rodentia" pageId="78" pageNumber="355" phylum="Chordata" rank="species" species="goldmani">goldmani</taxonomicName>
was elevated to species status, and N. n. cliftoni was assigned to N. 
<taxonomicName authorityName="Merriam" authorityYear="1903" box="[923,1044,933,962]" class="Mammalia" family="Cricetidae" genus="Nelsonia" kingdom="Animalia" order="Rodentia" pageId="78" pageNumber="355" phylum="Chordata" rank="species" species="goldmani">goldmani</taxonomicName>
