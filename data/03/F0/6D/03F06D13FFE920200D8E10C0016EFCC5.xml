, 
<taxonomicName box="[804,958,2423,2452]" class="Magnoliopsida" family="Lamiaceae" kingdom="Plantae" order="Lamiales" pageId="71" pageNumber="348" phylum="Tracheophyta" rank="family">Lamiaceae</taxonomicName>
