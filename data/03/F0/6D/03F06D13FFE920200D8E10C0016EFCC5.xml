), pea (
<taxonomicName box="[676,757,2502,2531]" class="Magnoliopsida" family="Fabaceae" genus="Pisum" kingdom="Plantae" order="Fabales" pageId="71" pageNumber="348" phylum="Tracheophyta" rank="genus">Pisum</taxonomicName>
