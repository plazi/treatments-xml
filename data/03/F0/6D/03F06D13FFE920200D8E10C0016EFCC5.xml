<taxonomicName box="[755,853,2383,2412]" class="Liliopsida" family="Poaceae" genus="Bromus" kingdom="Plantae" order="Poales" pageId="71" pageNumber="348" phylum="Tracheophyta" rank="genus">Bromus</taxonomicName>
, 
<taxonomicName box="[867,985,2383,2412]" class="Liliopsida" family="Poaceae" kingdom="Plantae" order="Poales" pageId="71" pageNumber="348" phylum="Tracheophyta" rank="family">Poaceae</taxonomicName>
), sulphur cinquefoil (
<taxonomicName class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="71" pageNumber="348" phylum="Tracheophyta" rank="genus">Potentilla</taxonomicName>
recta, 
<taxonomicName box="[287,419,2423,2452]" class="Magnoliopsida" family="Rosaceae" kingdom="Plantae" order="Rosales" pageId="71" pageNumber="348" phylum="Tracheophyta" rank="family">Rosaceae</taxonomicName>
