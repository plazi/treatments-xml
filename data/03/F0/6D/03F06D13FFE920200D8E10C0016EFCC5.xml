<taxonomicName box="[489,621,2383,2412]" class="Magnoliopsida" family="Fabaceae" kingdom="Plantae" order="Fabales" pageId="71" pageNumber="348" phylum="Tracheophyta" rank="family">Fabaceae</taxonomicName>
