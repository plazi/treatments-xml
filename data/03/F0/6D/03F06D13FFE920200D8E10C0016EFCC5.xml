<taxonomicName box="[271,338,2383,2412]" class="Magnoliopsida" family="Fabaceae" genus="Vicia" kingdom="Plantae" order="Fabales" pageId="71" pageNumber="348" phylum="Tracheophyta" rank="genus">Vicia</taxonomicName>
