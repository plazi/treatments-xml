<taxonomicName authorityName="Barrett-Hamilton" authorityYear="1903" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="71" pageNumber="348" phylum="Chordata" rank="species" species="hartingi" subGenus="Microtus">Microtus (Microtus) hartingi Barrett-Hamilton, 1903</taxonomicName>
