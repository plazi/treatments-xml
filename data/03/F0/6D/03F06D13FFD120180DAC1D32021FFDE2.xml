<subSubSection pageId="127" pageNumber="405" type="discussion">
<paragraph blockId="127.[767,1360,2593,3011]" pageId="127" pageNumber="405">
<taxonomicName baseAuthorityName="Thomas" baseAuthorityYear="1897" box="[771,1058,2706,2735]" class="Mammalia" family="Cricetidae" genus="Chibchanomys" kingdom="Animalia" order="Rodentia" pageId="127" pageNumber="405" phylum="Chordata" rank="species" species="trichotis">Chibchanomys trichotis</taxonomicName>
