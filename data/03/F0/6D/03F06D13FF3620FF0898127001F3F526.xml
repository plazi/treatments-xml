<subSubSection pageId="152" pageNumber="431" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6761385" ID-Zenodo-Dep="6761385" httpUri="https://zenodo.org/record/6761385/files/figure.png" inLine="true" pageId="152" pageNumber="431" startId="152.[2066,2238,1992,2025]" targetBox="[1451,2042,1762,2178]" targetPageId="152">
<paragraph blockId="152.[2066,2659,1763,2182]" pageId="152" pageNumber="431">
<emphasis bold="true" box="[2066,2242,1992,2025]" pageId="152" pageNumber="431">Distribution.</emphasis>
Endemic to E Atlantic Forest from S 
<taxonomicName box="[2179,2258,2031,2064]" class="Magnoliopsida" family="Asteraceae" genus="Bahia" kingdom="Plantae" order="Asterales" pageId="152" pageNumber="431" phylum="Tracheophyta" rank="genus">Bahia</taxonomicName>
