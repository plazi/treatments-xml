<paragraph blockId="106.[179,1385,291,642]" box="[180,1133,369,402]" pageId="106" pageNumber="384">
<emphasis bold="true" box="[180,415,369,402]" pageId="106" pageNumber="384">Activity patterns.</emphasis>
The 
<taxonomicName authority="Deermouse" authorityName="Deermouse" box="[493,778,369,402]" class="Insecta" family="Staphylinidae" genus="Catalina" kingdom="Animalia" order="Coleoptera" pageId="106" pageNumber="384" phylum="Arthropoda" rank="genus">Catalina Deermouse</taxonomicName>
is presumably nocturnal.
</paragraph>
</subSubSection>
<subSubSection box="[182,1120,409,442]" pageId="106" pageNumber="384" type="biology_ecology">
<paragraph blockId="106.[179,1385,291,642]" box="[182,1120,409,442]" pageId="106" pageNumber="384">
<emphasis bold="true" box="[182,882,409,442]" pageId="106" pageNumber="384">Movements, Home range and Social organization.</emphasis>
