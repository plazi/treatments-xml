<paragraph blockId="57.[182,1390,293,794]" box="[183,557,446,475]" pageId="57" pageNumber="334">
<emphasis bold="true" box="[183,318,446,475]" pageId="57" pageNumber="334">Breeding.</emphasis>
No information.
</paragraph>
</subSubSection>
