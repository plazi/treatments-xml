<subSubSection box="[1404,2412,1754,1787]" pageId="107" pageNumber="385" type="activity">
<paragraph blockId="107.[1404,2610,1285,1984]" box="[1404,2412,1754,1787]" pageId="107" pageNumber="385">
<emphasis bold="true" box="[1404,1639,1754,1787]" pageId="107" pageNumber="385">Activity patterns.</emphasis>
The Talamancan Deermouse is presumably nocturnal.
</paragraph>
</subSubSection>
<subSubSection box="[1405,2344,1798,1827]" pageId="107" pageNumber="385" type="biology_ecology">
<paragraph blockId="107.[1404,2610,1285,1984]" box="[1405,2344,1798,1827]" pageId="107" pageNumber="385">
