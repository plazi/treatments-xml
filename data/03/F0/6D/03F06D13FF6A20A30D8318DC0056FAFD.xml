<caption ID-DOI="http://doi.org/10.5281/zenodo.6707430" ID-Zenodo-Dep="6707430" httpUri="https://zenodo.org/record/6707430/files/figure.png" inLine="true" pageId="196" pageNumber="475" targetBox="[1456,2047,306,720]" targetPageId="196">
<paragraph blockId="196.[2069,2663,300,727]" box="[2071,2472,300,333]" pageId="196" pageNumber="475">
<emphasis bold="true" box="[2071,2472,300,333]" pageId="196" pageNumber="475">Subspecies and Distribution.</emphasis>
</paragraph>
<paragraph blockId="196.[2069,2663,300,727]" pageId="196" pageNumber="475">
<taxonomicName authority="Osgood, 1944" authorityName="Osgood" authorityYear="1944" box="[2071,2464,347,372]" class="Mammalia" family="Cricetidae" genus="Akodon" kingdom="Animalia" order="Rodentia" pageId="196" pageNumber="475" phylum="Chordata" rank="subSpecies" species="subfuscus" subSpecies="subfuscus">A.s.subfuscusOsgood,1944—NAltiplanoandEAndeanslopes,SPeru.</taxonomicName>
</paragraph>
<paragraph blockId="196.[2069,2663,300,727]" pageId="196" pageNumber="475">A. s. arequipae Myers, Patton &amp; M. F. Smith, 1990 — W side of the Altiplano and upper slopes of the W Andes Range, from S Peru to C Bolivia.</paragraph>
