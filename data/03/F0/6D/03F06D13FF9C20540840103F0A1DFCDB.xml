<paragraph blockId="50.[1388,2599,1683,3130]" box="[1394,1794,1717,1750]" pageId="50" pageNumber="329">
<emphasis bold="true" box="[1394,1794,1717,1750]" pageId="50" pageNumber="329">Subspecies and Distribution.</emphasis>
</paragraph>
<paragraph blockId="50.[1388,2599,1683,3130]" pageId="50" pageNumber="329">
<taxonomicName authority="Schrenck, 1859" authorityName="Schrenck" authorityYear="1859" box="[1394,1887,1757,1790]" class="Mammalia" family="Cricetidae" genus="Alexandromys" higherTaxonomySource="GBIF" kingdom="Animalia" order="Rodentia" pageId="50" pageNumber="329" phylum="Chordata" rank="subSpecies" species="maximowiczii" subSpecies="maximowiczu">A.m.maximowiczuSchrenck,1859—SESiberia(SEZabaykalskyKrai),RussianFarEast(A.m.Region,YevreyskayaAutonomousOblast,KhabarovskKrai,andPrimorskyKrai),EMongolia,andNEChina(InnerMongolia[=NeiMongol],Heilongjiang,Jilin,Hebei,andShaanxi).</taxonomicName>
