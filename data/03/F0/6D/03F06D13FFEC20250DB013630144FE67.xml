<emphasis bold="true" box="[131,531,2536,2569]" pageId="66" pageNumber="343">Subspecies and Distribution.</emphasis>
</paragraph>
<paragraph blockId="66.[125,1335,2419,3475]" box="[132,917,2576,2609]" pageId="66" pageNumber="343">
<taxonomicName authority="Thomas, 1906" authorityName="Thomas" authorityYear="1906" box="[132,505,2576,2609]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="66" pageNumber="343" phylum="Chordata" rank="subSpecies" species="major" subSpecies="majori">M.m.majoriThomas,1906—NETurkeyandWGeorgia.</taxonomicName>
</paragraph>
<paragraph blockId="66.[125,1335,2419,3475]" box="[132,1149,2616,2649]" pageId="66" pageNumber="343">
<taxonomicName authority="Ognev, 1924" authorityName="Ognev" authorityYear="1924" box="[132,565,2616,2649]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="66" pageNumber="343" phylum="Chordata" rank="subSpecies" species="major" subSpecies="aiscaucasicus">M.m.aiscaucasicusOgnev,1924—NslopesofGreaterCaucasusinRussia.</taxonomicName>
</paragraph>
<paragraph blockId="66.[125,1335,2419,3475]" pageId="66" pageNumber="343">
<taxonomicName authority="Heptner, 1948" authorityName="Heptner" authorityYear="1948" box="[132,575,2655,2688]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="66" pageNumber="343" phylum="Chordata" rank="subSpecies" species="major" subSpecies="suramensis">M. m. suramensis Heptner, 1948</taxonomicName>
— S slopes of Greater Caucasus in Georgia, Armenia, and Azerbaijan.
