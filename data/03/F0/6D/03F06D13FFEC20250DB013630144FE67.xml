<taxonomicName authority="Thomas, 1906" authorityName="Thomas" authorityYear="1906" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="66" pageNumber="343" phylum="Chordata" rank="species" species="majori" subGenus="Pitymys">Microtus (Pitymys) majori Thomas, 1906</taxonomicName>
