<subSubSection pageId="169" pageNumber="447" type="reference_group">
<paragraph blockId="169.[2010,2603,2350,2772]" box="[2011,2601,2350,2379]" pageId="169" pageNumber="447">
<emphasis bold="true" box="[2011,2166,2350,2379]" pageId="169" pageNumber="447">Taxonomy.</emphasis>
<taxonomicName authority="Peters, 1861" authorityName="Peters" authorityYear="1861" box="[2183,2596,2350,2379]" class="Mammalia" family="Cricetidae" genus="Nectomys" kingdom="Animalia" order="Rodentia" pageId="169" pageNumber="447" phylum="Chordata" rank="species" species="apicalis">Nectomys apicalis Peters, 1861</taxonomicName>
,
