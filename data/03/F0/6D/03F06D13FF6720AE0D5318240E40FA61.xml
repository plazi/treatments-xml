<subSubSection pageId="201" pageNumber="479" type="reference_group">
<paragraph blockId="201.[97,1301,3365,3480]" box="[99,937,3365,3394]" pageId="201" pageNumber="479">
<emphasis bold="true" box="[99,254,3365,3394]" pageId="201" pageNumber="479">Taxonomy.</emphasis>
<taxonomicName authority="Thomas, 1897" authorityName="Thomas" authorityYear="1897" box="[265,712,3365,3394]" class="Mammalia" family="Cricetidae" genus="Akodon" kingdom="Animalia" order="Rodentia" pageId="201" pageNumber="479" phylum="Chordata" rank="species" species="spegazzinii">Akodon spegazzinii Thomas, 1897</taxonomicName>
