<subSubSection pageId="105" pageNumber="384" type="discussion">
<paragraph blockId="105.[742,1336,2779,3202]" pageId="105" pageNumber="384">
<taxonomicName authorityName="Merriam" authorityYear="1898" box="[743,1010,2936,2965]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="105" pageNumber="384" phylum="Chordata" rank="species" species="megalops">Peromyscus megalops</taxonomicName>
is in the 
<taxonomicName authorityName="Merriam" authorityYear="1898" box="[1157,1268,2936,2965]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="105" pageNumber="384" phylum="Chordata" rank="species" species="megalops">megalops</taxonomicName>
species group. Some authors included subspecies azulensis and 
<taxonomicName authorityName="Osgood" authorityYear="1909" box="[1090,1224,3011,3044]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="105" pageNumber="384" phylum="Chordata" rank="species" species="melanurus">melanurus</taxonomicName>
under 
<taxonomicName authorityName="Merriam" authorityYear="1898" box="[744,891,3050,3083]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="105" pageNumber="384" phylum="Chordata" rank="species" species="megalops">P. megalops</taxonomicName>
, but others considered subspecies azulensis under 
<taxonomicName baseAuthorityName="Saussure" baseAuthorityYear="1860" box="[1027,1195,3094,3123]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="105" pageNumber="384" phylum="Chordata" rank="species" species="mexicanus">P. mexicanus</taxonomicName>
and 
<taxonomicName authorityName="Osgood" authorityYear="1909" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="105" pageNumber="384" phylum="Chordata" rank="species" species="melanurus">melanurus</taxonomicName>
as a separate species. Two subspecies recognized.
</paragraph>
</subSubSection>
