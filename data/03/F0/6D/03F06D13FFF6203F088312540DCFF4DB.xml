<paragraph blockId="88.[1456,2663,2155,2816]" box="[1456,2381,2624,2657]" pageId="88" pageNumber="366">
<emphasis bold="true" box="[1456,1691,2624,2657]" pageId="88" pageNumber="366">Activity patterns.</emphasis>
