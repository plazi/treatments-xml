<taxonomicName authority="Severtzov, 1879" authorityName="Severtzov" authorityYear="1879" box="[2077,2507,420,453]" class="Mammalia" family="Cricetidae" genus="Microtus" kingdom="Animalia" order="Rodentia" pageId="55" pageNumber="334" phylum="Chordata" rank="subSpecies" species="juldaschi" subSpecies="juldaschi">M.j.juldaschiSevertzov,1879—SWKyrgyzstan,ETajikistan,NEAfghanistan,NWPakistan,andSWChina(SWXinjiangandNWTibet[=Xizang]).</taxonomicName>
</paragraph>
