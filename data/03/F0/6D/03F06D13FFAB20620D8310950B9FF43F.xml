<subSubSection pageId="5" pageNumber="284" type="discussion">
<paragraph blockId="5.[791,1385,1400,1822]" pageId="5" pageNumber="284">
<taxonomicName authorityName="Milne-Edwards" authorityYear="1867" box="[794,1111,1518,1547]" class="Mammalia" family="Cricetidae" genus="Cricetulus" kingdom="Animalia" order="Rodentia" pageId="5" pageNumber="284" phylum="Chordata" rank="species" species="longicaudatus">Cricetulus longicaudatus</taxonomicName>
