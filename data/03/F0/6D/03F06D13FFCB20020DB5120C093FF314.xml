, USA, and Baja 
<taxonomicName box="[200,339,2231,2256]" class="Magnoliopsida" family="Geraniaceae" genus="California" kingdom="Plantae" order="Geraniales" pageId="101" pageNumber="380" phylum="Tracheophyta" rank="genus">California</taxonomicName>
and NW Baja 
<taxonomicName authority="Sur" authorityName="Sur" box="[543,739,2231,2256]" class="Magnoliopsida" family="Geraniaceae" genus="California" kingdom="Plantae" order="Geraniales" pageId="101" pageNumber="380" phylum="Tracheophyta" rank="genus">California Sur</taxonomicName>
