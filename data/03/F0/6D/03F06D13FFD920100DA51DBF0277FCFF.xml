<subSubSection pageId="119" pageNumber="398" type="reference_group">
<paragraph blockId="119.[756,1348,2705,3127]" pageId="119" pageNumber="398">
<emphasis bold="true" box="[756,911,2705,2734]" pageId="119" pageNumber="398">Taxonomy.</emphasis>
<taxonomicName authority="Robertson &amp; Musser, 1976" authorityName="Robertson &amp; Musser" authorityYear="1976" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="119" pageNumber="398" phylum="Chordata" rank="species" species="chinanteco">Peromyscus chinanteco Robertson &amp; Musser, 1976</taxonomicName>
