<caption ID-DOI="http://doi.org/10.5281/zenodo.6707518" ID-Zenodo-Dep="6707518" httpUri="https://zenodo.org/record/6707518/files/figure.png" inLine="true" pageId="200" pageNumber="478" targetBox="[179,771,696,1112]" targetPageId="200">
