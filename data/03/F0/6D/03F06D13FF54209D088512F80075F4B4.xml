<taxonomicName authorityName="S. Anderson &amp; Yates" authorityYear="2000" box="[2071,2299,1990,2023]" class="Mammalia" family="Cricetidae" genus="Tapecomys" kingdom="Animalia" order="Rodentia" pageId="250" pageNumber="528" phylum="Chordata" rank="species" species="primus">Tapecomys primus</taxonomicName>
