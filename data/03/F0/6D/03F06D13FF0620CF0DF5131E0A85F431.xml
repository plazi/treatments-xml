<subSubSection pageId="168" pageNumber="447" type="breeding">
<paragraph blockId="168.[194,1399,2465,3050]" pageId="168" pageNumber="447">
<emphasis bold="true" box="[195,329,2780,2813]" pageId="168" pageNumber="447">Breeding.</emphasis>
