<taxonomicName baseAuthorityName="Saussure" baseAuthorityYear="1860" box="[427,559,3450,3479]" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="107" pageNumber="386" phylum="Chordata" rank="species" species="mexicanus">mexicanus</taxonomicName>
saxatilis).
</paragraph>
</subSubSection>
