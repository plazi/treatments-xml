<taxonomicName authority="Townsend, 1912" authorityName="Townsend" authorityYear="1912" class="Mammalia" family="Cricetidae" genus="Peromyscus" kingdom="Animalia" order="Rodentia" pageId="101" pageNumber="379" phylum="Chordata" rank="species" species="guardia">Peromyscus guardia Townsend, 1912</taxonomicName>
