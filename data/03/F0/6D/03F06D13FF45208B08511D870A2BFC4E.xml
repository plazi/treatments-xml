<subSubSection pageId="236" pageNumber="515" type="biology_ecology">
<paragraph blockId="236.[176,1386,294,920]" pageId="236" pageNumber="515">
<emphasis bold="true" box="[179,290,373,406]" pageId="236" pageNumber="515">Habitat.</emphasis>
Open vegetation and shrubs (
<taxonomicName box="[722,973,373,406]" class="Magnoliopsida" family="Asteraceae" genus="Grindelia" kingdom="Plantae" order="Asterales" pageId="236" pageNumber="515" phylum="Tracheophyta" rank="species" species="glutinosa">Grindelia glutinosa</taxonomicName>
