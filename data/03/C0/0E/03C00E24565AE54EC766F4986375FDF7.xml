<quantity box="[808,844,494,516]" metricMagnitude="0" metricUnit="m" metricValue="1.0" pageId="5" pageNumber="6" unit="m" value="1.0">1 ♂</quantity>
22: 
<quantity box="[885,921,494,516]" metricMagnitude="0" metricUnit="m" metricValue="1.0" pageId="5" pageNumber="6" unit="m" value="1.0">1 ♂</quantity>
, 24: 
<quantity box="[968,1004,494,516]" metricMagnitude="0" metricUnit="m" metricValue="1.0" pageId="5" pageNumber="6" unit="m" value="1.0">1 ♂</quantity>
