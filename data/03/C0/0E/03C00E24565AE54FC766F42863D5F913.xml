<collectingCountry box="[317,374,1704,1725]" name="China" pageId="4" pageNumber="5">China</collectingCountry>
(
<bibRefCitation author="CHEN, J. &amp; WU, ZH" box="[387,612,1704,1725]" pageId="4" pageNumber="5" pagination="154 - 168" refId="ref22630" refString="CHEN, J. &amp; WU, ZH. (1994) The Alysiini of China (Hymenoptera: Braconidae: Alysiinae). China Agriculture Press 178 pp. + 40 tables. [In Chinese with English abbreviated text on pp. 154 - 168.]" type="book chapter" year="1994">CHEN &amp; WU 1994: 101</bibRefCitation>
