<bibRefCitation author="PAPP, J." pageId="4" pageNumber="5" pagination="133 - 156" refId="ref23377" refString="PAPP, J. (1994) Braconidae (Hymenopter) from Korea, XV. Acta Zoologica Academiae Scientiarum Hungaricae 40 (1 - 2): 133 - 156." type="journal article" year="1994">PAPP 1994: 142</bibRefCitation>
