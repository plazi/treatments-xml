<collectingCountry box="[1039,1131,753,774]" name="Germany" pageId="8" pageNumber="9">Germany</collectingCountry>
, 
<collectingCountry box="[1139,1212,753,774]" name="Austria" pageId="8" pageNumber="9">Austria</collectingCountry>
