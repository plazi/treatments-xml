<bibRefCitation author="PAPP, J." box="[841,991,1473,1494]" pageId="8" pageNumber="9" pagination="221 - 251" refId="ref23540" refString="PAPP, J. (2005) Braconidae (Hymenoptera) from Mongolia, XV. Acta Zoologica Academiae Scientiarum Hungaricae 51 (3): 221 - 251." type="journal article" year="2005">PAPP 2005: 228</bibRefCitation>
