<treatmentCitation author="SHENEFELT, R. D." box="[377,613,1444,1465]" page="1069" pageId="8" pageNumber="9" year="1974">
<bibRefCitation author="SHENEFELT, R. D." box="[377,613,1444,1465]" pageId="8" pageNumber="9" pagination="937 - 1113" refId="ref23570" refString="SHENEFELT, R. D. (1974) Braconidae 7. Alysiinae. Hymenopterorum Catalogus 11: 937 - 1113." type="journal article" year="1974">SHENEFELT 1974: 1069</bibRefCitation>
