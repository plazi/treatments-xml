<bibRefCitation author="PAPP, J." box="[324,483,1646,1667]" pageId="5" pageNumber="6" pagination="133 - 156" refId="ref23377" refString="PAPP, J. (1994) Braconidae (Hymenopter) from Korea, XV. Acta Zoologica Academiae Scientiarum Hungaricae 40 (1 - 2): 133 - 156." type="journal article" year="1994">PAPP 1994: 147</bibRefCitation>
