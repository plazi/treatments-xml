<figureCitation captionStart="FIGURE 34" captionStartId="62.[151,250,1943,1967]" captionTargetBox="[168,1419,197,1920]" captionTargetId="figure-21@62.[159,1429,181,1920]" captionTargetPageId="62" captionText="FIGURE 34. Lichenomorphus species. Cerci and subgenital plates. A, D, E. L. montealegrezi. Habitus in lateral view, cerci and subgenital plates. B–C. L. oscari. F–G. L. berezini. H–I. L. ocraceithorax. J–K. L. fuscifrons. (Figs. H–K. after Costa-Lima &amp; Guitton, 1961)." pageId="61" pageNumber="62">Fig. 34J</figureCitation>
)............................................................ 
<taxonomicName authority="(Brunner von Wattenwyl, 1878)" baseAuthorityName="Brunner von Wattenwyl" baseAuthorityYear="1878" box="[998,1436,180,203]" class="Insecta" family="Tettigoniidae" genus="Lichenomorphus" kingdom="Animalia" order="Orthoptera" pageId="61" pageNumber="62" phylum="Arthropoda" rank="species" species="fuscifrons">
