<subSubSection box="[151,675,1874,1901]" pageId="59" pageNumber="60" type="nomenclature">
<paragraph blockId="59.[151,675,1874,1901]" box="[151,675,1874,1901]" pageId="59" pageNumber="60">
<heading bold="true" box="[151,675,1874,1901]" fontSize="11" level="2" pageId="59" pageNumber="60" reason="4">
<taxonomicName authority="Cadena-Castaneda, 2011" authorityName="Cadena-Castaneda" authorityYear="2011" box="[151,675,1874,1901]" class="Insecta" family="Tettigoniidae" genus="Lichenomorphus" kingdom="Animalia" order="Orthoptera" pageId="59" pageNumber="60" phylum="Arthropoda" rank="genus">
<emphasis bold="true" box="[151,675,1874,1901]" pageId="59" pageNumber="60">
<emphasis bold="true" box="[151,358,1874,1901]" italics="true" pageId="59" pageNumber="60">Lichenomorphus</emphasis>
Cadena-Castañeda, 2011
</emphasis>
</taxonomicName>
