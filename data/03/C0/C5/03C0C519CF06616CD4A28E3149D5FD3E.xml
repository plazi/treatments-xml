<figureCitation box="[1011,1101,1983,2005]" captionStart="FIGURE 34" captionStartId="62.[151,250,1943,1967]" captionTargetBox="[168,1419,197,1920]" captionTargetId="figure-21@62.[159,1429,181,1920]" captionTargetPageId="62" captionText="FIGURE 34. Lichenomorphus species. Cerci and subgenital plates. A, D, E. L. montealegrezi. Habitus in lateral view, cerci and subgenital plates. B–C. L. oscari. F–G. L. berezini. H–I. L. ocraceithorax. J–K. L. fuscifrons. (Figs. H–K. after Costa-Lima &amp; Guitton, 1961)." pageId="60" pageNumber="61">Fig. 34H</figureCitation>
)....................................................................................................... 
<taxonomicName authority="(Piza, 1951)" baseAuthorityName="Piza" baseAuthorityYear="1951" box="[1149,1436,2012,2035]" class="Insecta" family="Tettigoniidae" genus="Lichenomorphus" kingdom="Animalia" order="Orthoptera" pageId="60" pageNumber="61" phylum="Arthropoda" rank="species" species="ocraceithorax">
<emphasis bold="true" box="[1149,1313,2012,2034]" italics="true" pageId="60" pageNumber="61">L. ocraceithorax</emphasis>
(
<bibRefCitation author="Piza Jr., S. T." box="[1326,1429,2013,2035]" pageId="60" pageNumber="61" pagination="75 - 82" refId="ref42412" refString="Piza Jr., S. T. (1951 [1950]) Novas especies do genero Dysonia (Orthoptera - Phaneropteridae). Anais da Escola Superior de Agricultura &quot; Luiz de Queiroz &quot;, Universidade de Sao Paulo, 7, 75 - 82. https: // doi. org / 10.1590 / S 0071 - 12761950000100009" type="journal article" year="1951">Piza, 1951</bibRefCitation>
)
</taxonomicName>
</keyLead>
</paragraph>
<paragraph blockId="61.[151,1437,151,672]" pageId="61" pageNumber="62">
<keyLead pageId="61" pageNumber="62">
