<collectingRegion box="[813,959,799,825]" country="Brazil" name="Mato Grosso" pageId="39" pageNumber="40">Mato Grosso</collectingRegion>
and 
<collectingRegion box="[1014,1125,798,824]" country="Brazil" name="Rondonia" pageId="39" pageNumber="40">Rondônia</collectingRegion>
