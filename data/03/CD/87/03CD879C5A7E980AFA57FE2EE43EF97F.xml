<paragraph blockId="9.[1436,2642,968,1746]" box="[1438,1810,1319,1352]" pageId="9" pageNumber="202">
<emphasis bold="true" box="[1438,1572,1319,1352]" pageId="9" pageNumber="202">Breeding.</emphasis>
