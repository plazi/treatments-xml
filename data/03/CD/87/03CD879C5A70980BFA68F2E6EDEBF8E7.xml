<taxonomicName authorityName="Matschie" authorityYear="1894" box="[1160,1308,452,485]" class="Mammalia" family="Chrysochloridae" genus="Chrysochloris" kingdom="Animalia" order="Afrosoricida" pageId="8" pageNumber="201" phylum="Chordata" rank="species" species="stuhlmanni">stuhlmanni</taxonomicName>
