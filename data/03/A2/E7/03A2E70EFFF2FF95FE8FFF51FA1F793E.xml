<taxonomicName box="[811,952,1365,1390]" class="Liliopsida" family="Orchidaceae" genus="Dendrobium" kingdom="Plantae" order="Asparagales" pageId="12" pageNumber="163" phylum="Tracheophyta" rank="species" species="seemannii">
