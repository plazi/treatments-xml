<taxonomicName authorityName="Thomas" authorityYear="1910" class="Mammalia" family="Lorisidae" genus="Perodicticus" kingdom="Animalia" order="Primates" pageId="3" pageNumber="213" phylum="Chordata" rank="species" species="ibeanus">Perodicticus ibeanus Thomas, 1910</taxonomicName>
, 
