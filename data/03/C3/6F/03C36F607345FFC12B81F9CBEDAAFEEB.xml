<paragraph blockId="5.[151,1437,1699,1980]" lastBlockId="6.[151,1436,150,285]" lastPageId="6" lastPageNumber="427" pageId="5" pageNumber="426">
<emphasis bold="true" box="[199,623,1951,1977]" pageId="5" pageNumber="426">Distribution and published records.</emphasis>
The species was described by 
<bibRefCitation author="Svihla, V." box="[965,1118,1951,1980]" pageId="5" pageNumber="426" pagination="260 - 266" refId="ref6819" refString="Svihla, V. (1984) Insects of Saudi Arabia. Coleoptera: Fam. Oedemeridae (part 2). Fauna of Saudi Arabia, 6, 260 - 266." type="journal article" year="1984">Švihla (1984)</bibRefCitation>
for 
<collectingCountry box="[1163,1308,1951,1977]" name="Saudi Arabia" pageId="5" pageNumber="426">Saudi Arabia</collectingCountry>
and Southern 
<collectingCountry box="[195,240,151,177]" name="Iran" pageId="6" pageNumber="427">Iran</collectingCountry>
and then reported also for 
<collectingCountry box="[551,798,151,177]" name="United Arab Emirates" pageId="6" pageNumber="427">United Arab Emirates</collectingCountry>
and 
<collectingCountry box="[855,923,151,177]" name="Oman" pageId="6" pageNumber="427">Oman</collectingCountry>
(SE 
<collectingCountry box="[982,1067,151,177]" name="Oman" pageId="6" pageNumber="427">Muscat</collectingCountry>
, Wdi Maysh, 
<quantity box="[1228,1302,151,177]" metricMagnitude="2" metricUnit="m" metricValue="2.0" pageId="6" pageNumber="427" unit="m" value="200.0">200 m</quantity>
, 
<geoCoordinate box="[1316,1400,150,177]" degrees="23" direction="north" minutes="27" orientation="latitude" pageId="6" pageNumber="427" precision="925" value="23.45">23 27N</geoCoordinate>
