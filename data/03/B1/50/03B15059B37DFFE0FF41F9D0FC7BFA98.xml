<taxonomicName authority="Gustafsson &amp; Bush, 2022" authorityName="Gustafsson &amp; Bush" authorityYear="2022" box="[330,679,367,393]" class="Insecta" family="Philopteridae" genus="Guimaraesiella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Psocodea" pageId="38" pageNumber="39" phylum="Arthropoda" rank="species" species="nouankaoensis" status="new species">
<emphasis box="[330,679,367,393]" italics="true" pageId="38" pageNumber="39">Guimaraesiella nouankaoensis</emphasis>
</taxonomicName>
<emphasis bold="true" box="[688,827,367,393]" pageId="38" pageNumber="39">
<taxonomicNameLabel box="[688,827,367,393]" pageId="38" pageNumber="39" rank="species">new species</taxonomicNameLabel>
</emphasis>
is most similar to 
<taxonomicName authority="Gustafsson &amp; Bush, 2022" authorityName="Gustafsson &amp; Bush" authorityYear="2022" box="[1043,1236,367,394]" class="Insecta" family="Philopteridae" genus="Guimaraesiella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Psocodea" pageId="38" pageNumber="39" phylum="Arthropoda" rank="species" species="sphagmotica" status="new species">
