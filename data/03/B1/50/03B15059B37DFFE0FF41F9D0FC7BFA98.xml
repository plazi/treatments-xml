</taxonomicName>
<emphasis bold="true" box="[1245,1384,367,393]" pageId="38" pageNumber="39">
<taxonomicNameLabel box="[1245,1384,367,393]" pageId="38" pageNumber="39" rank="species">new species</taxonomicNameLabel>
</emphasis>
; see diagnosis of 
<taxonomicName authorityName="Gustafsson &amp; Bush" authorityYear="2022" box="[294,486,403,430]" class="Insecta" family="Philopteridae" genus="Guimaraesiella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Psocodea" pageId="38" pageNumber="39" phylum="Arthropoda" rank="species" species="sphagmotica">
