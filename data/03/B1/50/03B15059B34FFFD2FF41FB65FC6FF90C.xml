</taxonomicName>
<emphasis bold="true" box="[832,971,726,753]" pageId="20" pageNumber="21">
<taxonomicNameLabel box="[832,971,726,753]" pageId="20" pageNumber="21" rank="species">new species</taxonomicNameLabel>
</emphasis>
is most similar to 
<taxonomicName authority="Gustafsson &amp; Bush, 2022" authorityName="Gustafsson &amp; Bush" authorityYear="2022" box="[1184,1380,727,753]" class="Insecta" family="Philopteridae" genus="Indoceoplanetes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Psocodea" pageId="20" pageNumber="21" phylum="Arthropoda" rank="species" species="incisoma" status="new species" subGenus="Indoceoplanetes">
