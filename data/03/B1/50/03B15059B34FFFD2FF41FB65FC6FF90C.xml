<taxonomicName authorityName="Gustafsson &amp; Bush" authorityYear="2022" box="[996,1190,763,789]" class="Insecta" family="Philopteridae" genus="Indoceoplanetes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Psocodea" pageId="20" pageNumber="21" phylum="Arthropoda" rank="species" species="incisoma" subGenus="Indoceoplanetes">
