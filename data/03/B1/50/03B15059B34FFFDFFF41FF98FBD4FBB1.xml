<taxonomicName authority="Gustafsson &amp; Bush, 2022" authorityName="Gustafsson &amp; Bush" authorityYear="2022" box="[331,867,1940,1966]" class="Insecta" family="Philopteridae" genus="Indoceoplanetes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Psocodea" pageId="20" pageNumber="21" phylum="Arthropoda" rank="species" species="cinitemnina" status="new species" subGenus="Indoceoplanetes">
