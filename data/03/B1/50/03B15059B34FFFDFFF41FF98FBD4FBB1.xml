<emphasis box="[735,867,1941,1966]" italics="true" pageId="20" pageNumber="21">cinitemnina</emphasis>
</taxonomicName>
<emphasis bold="true" box="[877,1017,1940,1966]" pageId="20" pageNumber="21">
<taxonomicNameLabel box="[877,1017,1940,1966]" pageId="20" pageNumber="21" rank="species">new species</taxonomicNameLabel>
</emphasis>
is most similar to 
<taxonomicName authorityName="Gustafsson &amp; Bush" authorityYear="2022" box="[1237,1436,1940,1966]" class="Insecta" family="Philopteridae" genus="Indoceoplanetes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Psocodea" pageId="20" pageNumber="21" phylum="Arthropoda" rank="species" species="incisoma" subGenus="Indoceoplanetes">
<emphasis box="[1237,1268,1941,1966]" italics="true" pageId="20" pageNumber="21">In.</emphasis>
