<caption ID-DOI="http://doi.org/10.5281/zenodo.6723721" ID-Zenodo-Dep="6723721" httpUri="https://zenodo.org/record/6723721/files/figure.png" inLine="true" pageId="2" pageNumber="693" targetBox="[1375,1966,696,1112]" targetPageId="2">
