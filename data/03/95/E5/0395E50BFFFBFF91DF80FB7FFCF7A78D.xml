<subSubSection pageId="115" pageNumber="115" type="distribution">
<paragraph blockId="115.[128,654,213,1624]" pageId="115" pageNumber="115">
DISTRIBUTION: From the Okanagan Valley of southern 
<collectingRegion box="[315,521,627,649]" country="Canada" name="British Columbia" pageId="115" pageNumber="115">
British 
<taxonomicName box="[402,521,627,649]" class="Magnoliopsida" family="Malvaceae" genus="Columbia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Malvales" pageId="115" pageNumber="211" phylum="Tracheophyta" rank="genus">Columbia</taxonomicName>
</collectingRegion>
, the northern foothills of the 
<taxonomicName authority="Basin" authorityName="Basin" box="[406,608,657,679]" class="Magnoliopsida" family="Malvaceae" genus="Columbia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Malvales" pageId="115" pageNumber="115" phylum="Tracheophyta" rank="genus">Columbia Basin</taxonomicName>
of 
<collectingRegion box="[128,272,686,708]" country="United States of America" name="Washington" pageId="115" pageNumber="115">Washington</collectingRegion>
