(Uhler)
</taxonomicName>
</keyLead>
</paragraph>
<paragraph blockId="82.[93,620,212,1758]" pageId="82" pageNumber="82">
<keyLead pageId="82" pageNumber="82">
– Foretibia black; antennal segment 
<collectionCode box="[531,540,346,365]" pageId="82" pageNumber="82">I</collectionCode>
black; male genitalia as in figure 49A–O.............................. 
<taxonomicName authority="Kelton" authorityName="Kelton" box="[467,619,398,418]" class="Insecta" family="Miridae" genus="Slaterocoris" kingdom="Animalia" order="Hemiptera" pageId="82" pageNumber="82" phylum="Arthropoda" rank="species" species="alpinus">
