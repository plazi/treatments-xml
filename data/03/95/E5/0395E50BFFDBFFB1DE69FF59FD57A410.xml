<keyLead pageId="82" pageNumber="82">
14. Foretibia partly pale; antennal segment 
<collectionCode box="[553,562,266,285]" pageId="82" pageNumber="82">I</collectionCode>
pale; male genitalia as in figure 19A–E.............................. 
<taxonomicName authority="(Uhler)" baseAuthorityName="Uhler" baseAuthorityYear="1894" box="[463,619,318,337]" class="Insecta" family="Miridae" genus="Slaterocoris" kingdom="Animalia" order="Hemiptera" pageId="82" pageNumber="82" phylum="Arthropoda" rank="species" species="atratus">
