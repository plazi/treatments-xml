<heading box="[258,524,213,234]" centered="true" fontSize="36" level="2" pageId="81" pageNumber="81" reason="8">KEY TO THE SPECIES OF</heading>
<taxonomicName authority="WAGNER" authorityName="WAGNER" box="[250,531,242,263]" class="Insecta" family="Miridae" genus="Slaterocoris" kingdom="Animalia" order="Hemiptera" pageId="81" pageNumber="81" phylum="Arthropoda" rank="genus">
