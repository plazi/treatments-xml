<taxonomicName authorityName="Schwartz" authorityYear="2011" box="[231,502,1419,1439]" class="Insecta" family="Miridae" genus="Slaterocoris" kingdom="Animalia" order="Hemiptera" pageId="124" pageNumber="124" phylum="Arthropoda" rank="species" species="argenteoides">
<emphasis box="[231,502,1419,1439]" italics="true" pageId="124" pageNumber="124">Slaterocoris argenteoides</emphasis>
</taxonomicName>
, scanning electron micrographs. 
<emphasis bold="true" box="[332,350,1446,1465]" pageId="124" pageNumber="124">A</emphasis>
. Head, anterior view. 
<emphasis bold="true" box="[596,612,1446,1465]" pageId="124" pageNumber="124">B</emphasis>
. Hemelytron, setae, dorsal view. 
<emphasis bold="true" box="[472,490,1473,1492]" pageId="124" pageNumber="124">C</emphasis>
