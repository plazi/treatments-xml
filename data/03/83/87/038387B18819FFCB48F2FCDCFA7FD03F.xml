within the distribution range of 
<taxonomicName authorityName="Swanepoel &amp; E. Tripp" authorityYear="2022" box="[435,630,806,833]" class="Magnoliopsida" family="Acanthaceae" genus="Petalidium" kingdom="Plantae" order="Lamiales" pageId="7" pageNumber="134" phylum="Tracheophyta" rank="species" species="sesfonteinense">
