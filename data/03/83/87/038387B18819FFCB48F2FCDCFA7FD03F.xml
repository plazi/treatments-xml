<paragraph blockId="7.[136,1451,770,833]" pageId="7" pageNumber="134">
<heading bold="true" centered="true" fontSize="11" level="1" pageId="7" pageNumber="134" reason="1">
<emphasis bold="true" pageId="7" pageNumber="134">
Identification key to 
<taxonomicName authority="Nees von Esenbeck (1832: 75)" authorityName="Nees von Esenbeck" authorityPageNumber="75" authorityYear="1832" box="[383,1368,770,797]" class="Magnoliopsida" family="Acanthaceae" genus="Petalidium" kingdom="Plantae" order="Lamiales" pageId="7" pageNumber="134" phylum="Tracheophyta" rank="genus">
