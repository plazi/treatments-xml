<subSubSection box="[199,565,582,609]" pageId="4" pageNumber="418" type="distribution">
<paragraph blockId="4.[151,1437,150,825]" box="[199,565,582,609]" pageId="4" pageNumber="418">
<emphasis bold="true" box="[199,345,582,608]" pageId="4" pageNumber="418">Distribution</emphasis>
. 
<collectingCountry box="[359,417,582,608]" name="India" pageId="4" pageNumber="418">India</collectingCountry>
(
<collectingRegion box="[432,554,582,609]" country="India" name="Karnataka" pageId="4" pageNumber="418">Karnataka</collectingRegion>
).
</paragraph>
