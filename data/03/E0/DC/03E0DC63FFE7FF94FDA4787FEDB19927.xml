<emphasis bold="true" box="[1123,1158,311,337]" pageId="33" pageNumber="127">
A 
<quantity box="[1144,1158,311,337]" metricMagnitude="-1" metricUnit="m" metricValue="1.016" pageId="33" pageNumber="127" unit="in" value="4.0">4</quantity>
</emphasis>
