<taxonomicName authority="Lukasheva, 1986" authorityName="Lukasheva" authorityYear="1986" box="[483,894,382,408]" class="Insecta" family="Muscidae" genus="Coenosia" kingdom="Animalia" order="Diptera" pageId="33" pageNumber="127" phylum="Arthropoda" rank="species" species="emiliae">
<emphasis box="[483,686,382,408]" italics="true" pageId="33" pageNumber="127">Coenosia emiliae</emphasis>
Lukasheva, 1986
</taxonomicName>
(
<figureCitation box="[909,1017,382,408]" captionStart="Fig" captionStartId="34.[189,232,1925,1951]" captionTargetBox="[237,1350,271,1900]" captionTargetId="figure-62@34.[236,1352,265,1906]" captionTargetPageId="34" captionText="Fig. 18. ♀♀ of Coenosia Meigen, 1826. A. C. intermedia (Fallén, 1825), wing, ventral view. B. Same, detail of wing showing CS1‒3, ventral view. C. Same, detail of wing showing CS1‒3, dorsal view. D. C. emiliae Lukasheva, 1986, detail of wing showing CS1‒3, dorsal view." figureDoi="http://doi.org/10.5281/zenodo.6784167" httpUri="https://zenodo.org/record/6784167/files/figure.png" pageId="33" pageNumber="127">Fig. 18D</figureCitation>
