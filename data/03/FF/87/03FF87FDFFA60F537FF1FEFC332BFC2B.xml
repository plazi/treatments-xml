<bibRefCitation author="Nuss, M. &amp; Landry, B. &amp; Mally, R. &amp; Vegliante, F. &amp; Trankner, A. &amp; Bauer, F. &amp; Hayden, J. &amp; Segerer, A. &amp; Schouten, R. &amp; Li, H. &amp; Trofimova, T. &amp; Solis, M. A. &amp; Prins, J. De &amp; Speidel, W." pageId="1" pageNumber="416" refId="ref5672" refString="Nuss, M., Landry, B., Mally, R., Vegliante, F., Trankner, A., Bauer, F., Hayden, J., Segerer, A., Schouten, R., Li, H., Trofimova, T., Solis, M. A., Prins, J. De &amp; Speidel, W. (2003 - 2022) Global Information System on Pyraloidea. http: // www. pyraloidea. org (accessed 31 January 2022)" type="url" year="2003">
