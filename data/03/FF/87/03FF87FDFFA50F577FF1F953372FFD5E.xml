<taxonomicName box="[502,693,2001,2025]" class="Insecta" family="Pyralidae" genus="Termioptycha" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="419" phylum="Arthropoda" rank="species" species="undetermined">
<emphasis box="[502,640,2001,2025]" italics="true" pageId="4" pageNumber="419">Termioptycha</emphasis>
spp.
</taxonomicName>
: 
<taxonomicName authority=", Mamit" authorityName="Mamit" box="[702,909,2001,2025]" class="Insecta" family="Pyralidae" genus="Termioptycha" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="419" phylum="Arthropoda" rank="species" species="conjuncta">
<emphasis box="[702,827,2001,2024]" italics="true" pageId="4" pageNumber="419">T. conjuncta</emphasis>
, Mamit
</taxonomicName>
, 
<collectingRegion box="[920,1016,2001,2025]" country="India" name="Mizoram" pageId="4" pageNumber="419">Mizoram</collectingRegion>
.
