<taxonomicName authority="Zhao &amp; Zorn" authorityName="Zhao &amp; Zorn" authorityYear="2022" box="[401,756,1745,1770]" class="Insecta" family="Rutelidae" genus="Anomala" kingdom="Animalia" order="Coleoptera" pageId="8" pageNumber="183" phylum="Arthropoda" rank="species" species="wutaiensis" status="new species">
<emphasis box="[401,608,1745,1769]" italics="true" pageId="8" pageNumber="183">Anomala wutaiensis</emphasis>
Zhao &amp; Zorn
