spp. A
</taxonomicName>
–C, holotype of 
<taxonomicName authority="Zhao &amp; Zorn" authorityName="Zhao &amp; Zorn" authorityYear="2022" box="[808,1098,730,754]" class="Insecta" family="Rutelidae" genus="Anomala" kingdom="Animalia" order="Coleoptera" pageId="19" pageNumber="194" phylum="Arthropoda" rank="species" species="longilobata" status="new species">
<emphasis box="[808,954,730,754]" italics="true" pageId="19" pageNumber="194">A. longilobata</emphasis>
Zhao &amp; Zorn
</taxonomicName>
, 
<emphasis bold="true" box="[1109,1235,730,754]" pageId="19" pageNumber="194">
<taxonomicNameLabel box="[1109,1235,730,754]" pageId="19" pageNumber="194" rank="species">new species</taxonomicNameLabel>
</emphasis>
; D–F, 
<taxonomicName authority="Arrow, 1899" authorityName="Arrow" authorityYear="1899" class="Insecta" family="Rutelidae" genus="Anomala" kingdom="Animalia" order="Coleoptera" pageId="19" pageNumber="194" phylum="Arthropoda" rank="species" species="imperialis">
