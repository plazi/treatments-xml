Moderate size, usually 
<quantity box="[623,722,1649,1675]" metricMagnitude="-3" metricUnit="m" metricValue="1.5" metricValueMax="2.0" metricValueMin="1.0" pageId="10" pageNumber="381" unit="mm" value="1.5" valueMax="2.0" valueMin="1.0">1−2 mm</quantity>
