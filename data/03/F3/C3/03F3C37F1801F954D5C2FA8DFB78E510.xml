<caption ID-DOI="http://doi.org/10.5281/zenodo.6831568" ID-Zenodo-Dep="6831568" httpUri="https://zenodo.org/record/6831568/files/figure.png" pageId="3" pageNumber="272" startId="3.[136,243,1953,1975]" targetBox="[230,1355,190,1928]" targetPageId="3">
<paragraph blockId="3.[136,1451,1953,2083]" pageId="3" pageNumber="272">
<emphasis bold="true" box="[136,302,1953,1975]" pageId="3" pageNumber="272">FIGURES 9–11.</emphasis>
<taxonomicName authority="Shea &amp; Greifenstein &amp; Kociolek, 2022" authorityName="Shea &amp; Greifenstein &amp; Kociolek" authorityYear="2022" box="[309,513,1953,1974]" class="Bacillariophyceae" family="Naviculaceae" genus="Luticola" higherTaxonomySource="GBIF" kingdom="Chromista" order="Naviculales" pageId="3" pageNumber="272" phylum="Bacillariophyta" rank="species" species="coloradiana" status="sp. nov.">
