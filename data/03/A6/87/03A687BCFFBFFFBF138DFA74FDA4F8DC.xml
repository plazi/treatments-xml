, S 
<collectingCountry box="[1227,1374,1857,1882]" name="Venezuela" pageId="14" pageNumber="498">Venezuela</collectingCountry>
, and SW 
<collectingCountry box="[908,1016,1888,1921]" name="Guyana" pageId="14" pageNumber="498">Guyana</collectingCountry>
