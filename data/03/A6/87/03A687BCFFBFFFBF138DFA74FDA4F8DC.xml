<taxonomicName authority="Linares &amp; Ojasti, 1971" authorityName="Linares &amp; Ojasti" authorityYear="1971" class="Mammalia" family="Phyllostomidae" genus="Lonchorhina" kingdom="Animalia" order="Chiroptera" pageId="14" pageNumber="498" phylum="Chordata" rank="species" species="orinocensis">Lonchorhina orinocensis Linares &amp; Ojasti, 1971</taxonomicName>
