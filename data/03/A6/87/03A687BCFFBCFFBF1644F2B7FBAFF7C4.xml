SSE Esmeralda, 
<geoCoordinate box="[954,1069,353,382]" degrees="2" direction="north" minutes="30" orientation="latitude" pageId="14" pageNumber="498" precision="925" value="2.5">2°30'N</geoCoordinate>
- 
<geoCoordinate box="[1077,1186,353,382]" degrees="65" direction="west" minutes="13" orientation="longitude" pageId="14" pageNumber="498" precision="925" value="-65.21667">65°13’W</geoCoordinate>
, 
<quantity box="[1205,1291,353,382]" metricMagnitude="2" metricUnit="m" metricValue="1.38" pageId="14" pageNumber="498" unit="m" value="138.0">138 m</quantity>
