, 
<materialsCitation pageId="59" pageNumber="543">
“Bacza, Upper Coca River, Oriente [= 
<collectingRegion box="[785,864,796,825]" country="Ecuador" name="Napo" pageId="59" pageNumber="543">Napo</collectingRegion>
