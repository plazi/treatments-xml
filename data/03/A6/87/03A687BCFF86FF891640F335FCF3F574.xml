<subSubSection pageId="56" pageNumber="540" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6458841" ID-Zenodo-Dep="6458841" httpUri="https://zenodo.org/record/6458841/files/figure.png" inLine="true" pageId="56" pageNumber="540" targetBox="[179,770,277,690]" targetPageId="56">
<paragraph blockId="56.[794,1385,269,697]" pageId="56" pageNumber="540">
<emphasis bold="true" box="[794,971,269,302]" pageId="56" pageNumber="540">Distribution.</emphasis>
Pacific slope of 
<collectingCountry box="[1248,1385,269,302]" name="Colombia" pageId="56" pageNumber="540">Colombia</collectingCountry>
(Choco S to 
<collectingRegion box="[1002,1100,309,342]" country="Colombia" name="Narino" pageId="56" pageNumber="540">Narino</collectingRegion>
departments) and 
<collectingCountry box="[795,914,352,381]" name="Ecuador" pageId="56" pageNumber="540">Ecuador</collectingCountry>
