<taxonomicName box="[931,1077,892,925]" class="Mammalia" family="Phyllostomidae" genus="Dermanura" higherTaxonomySource="GBIF" kingdom="Animalia" order="Chiroptera" pageId="95" pageNumber="579" phylum="Chordata" rank="genus">Dermanura</taxonomicName>
