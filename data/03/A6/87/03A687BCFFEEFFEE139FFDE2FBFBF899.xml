<subSubSection pageId="95" pageNumber="579" type="discussion">
<paragraph blockId="95.[773,1367,739,1162]" pageId="95" pageNumber="579">
<taxonomicName box="[773,977,814,847]" class="Mammalia" family="Phyllostomidae" genus="Artibeus" kingdom="Animalia" order="Chiroptera" pageId="95" pageNumber="579" phylum="Chordata" rank="species" species="aztecus">Artibeus aztecus</taxonomicName>
is placed in 
<taxonomicName box="[1175,1321,814,847]" class="Mammalia" family="Phyllostomidae" genus="Dermanura" higherTaxonomySource="GBIF" kingdom="Animalia" order="Chiroptera" pageId="95" pageNumber="579" phylum="Chordata" rank="genus">Dermanura</taxonomicName>
by some authors but reassigned to 
<taxonomicName box="[1264,1367,853,886]" class="Mammalia" family="Phyllostomidae" genus="Artibeus" kingdom="Animalia" order="Chiroptera" pageId="95" pageNumber="579" phylum="Chordata" rank="genus">Artibeus</taxonomicName>
