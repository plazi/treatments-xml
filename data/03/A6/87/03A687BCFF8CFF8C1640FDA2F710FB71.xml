<emphasis bold="true" box="[2014,2191,1029,1054]" pageId="61" pageNumber="545">Distribution.</emphasis>
E 
<collectingCountry box="[2242,2360,1029,1054]" name="Ecuador" pageId="61" pageNumber="545">Ecuador</collectingCountry>
, E 
<collectingCountry box="[2415,2483,1029,1054]" name="Peru" pageId="61" pageNumber="545">Peru</collectingCountry>
, 
<collectingCountry box="[2505,2601,1029,1054]" name="Bolivia" pageId="61" pageNumber="545">Bolivia</collectingCountry>
, and NW 
<collectingCountry box="[2138,2283,1061,1094]" name="Argentina" pageId="61" pageNumber="545">Argentina</collectingCountry>
