Through Andean zone of W 
<collectingCountry box="[1982,2121,3279,3312]" name="Colombia" pageId="37" pageNumber="521">Colombia</collectingCountry>
, W &amp; E 
<collectingCountry box="[2233,2351,3279,3312]" name="Ecuador" pageId="37" pageNumber="521">Ecuador</collectingCountry>
, W &amp; E 
<collectingCountry box="[2463,2530,3279,3312]" name="Peru" pageId="37" pageNumber="521">Peru</collectingCountry>
, and W &amp; C 
<collectingCountry box="[1495,1591,3320,3353]" name="Bolivia" pageId="37" pageNumber="521">Bolivia</collectingCountry>
