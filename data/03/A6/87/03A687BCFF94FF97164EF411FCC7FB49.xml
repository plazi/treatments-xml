<subSubSection pageId="37" pageNumber="521" type="discussion">
<paragraph blockId="37.[1391,2598,3121,3478]" pageId="37" pageNumber="521">
<taxonomicName box="[1392,1607,3200,3233]" class="Mammalia" family="Phyllostomidae" genus="Anoura" kingdom="Animalia" order="Chiroptera" pageId="37" pageNumber="521" phylum="Chordata" rank="species" species="peruana">Anoura peruana</taxonomicName>
wassplit from 
<taxonomicName box="[1817,1959,3200,3233]" class="Mammalia" family="Phyllostomidae" genus="Anoura" kingdom="Animalia" order="Chiroptera" pageId="37" pageNumber="521" phylum="Chordata" rank="species" species="geoffroyi">A. geoffroyi</taxonomicName>
