<subSubSection box="[1447,2489,985,1018]" pageId="46" pageNumber="530" type="breeding">
<paragraph blockId="46.[1445,2654,275,1337]" box="[1447,2489,985,1018]" pageId="46" pageNumber="530">
<emphasis bold="true" box="[1447,1582,985,1018]" pageId="46" pageNumber="530">Breeding.</emphasis>
In 
<collectingCountry box="[1633,1751,985,1018]" name="Ecuador" pageId="46" pageNumber="530">Ecuador</collectingCountry>
