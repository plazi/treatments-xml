<taxonomicName class="Mammalia" family="Phyllostomidae" genus="Sturnira" kingdom="Animalia" order="Chiroptera" pageId="60" pageNumber="544" phylum="Chordata" rank="species" species="oporaphilum">S. oporaphilum</taxonomicName>
