<subSubSection pageId="60" pageNumber="544" type="discussion">
<taxonomicName box="[2070,2289,1939,1972]" class="Mammalia" family="Phyllostomidae" genus="Sturnira" kingdom="Animalia" order="Chiroptera" pageId="60" pageNumber="544" phylum="Chordata" rank="species" species="ludovici">Sturnira ludovici</taxonomicName>
