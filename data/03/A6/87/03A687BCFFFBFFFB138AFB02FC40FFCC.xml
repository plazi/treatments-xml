, 
<collectingCountry box="[967,1075,1896,1925]" name="Guyana" pageId="74" pageNumber="558">Guyana</collectingCountry>
, and from E slope of Andes in E 
<collectingCountry box="[349,488,1935,1964]" name="Colombia" pageId="74" pageNumber="558">Colombia</collectingCountry>
, E 
<collectingCountry box="[540,658,1935,1964]" name="Ecuador" pageId="74" pageNumber="558">Ecuador</collectingCountry>
