<subSubSection pageId="61" pageNumber="545" type="discussion">
<taxonomicName box="[740,977,826,859]" class="Mammalia" family="Phyllostomidae" genus="Sturnira" kingdom="Animalia" order="Chiroptera" pageId="61" pageNumber="545" phylum="Chordata" rank="species" species="adrianae">Sturnira adrianae</taxonomicName>
