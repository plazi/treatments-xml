<paragraph blockId="83.[1404,2613,287,1263]" box="[1406,1780,953,986]" pageId="83" pageNumber="567">
<emphasis bold="true" box="[1406,1541,953,986]" pageId="83" pageNumber="567">Breeding.</emphasis>
