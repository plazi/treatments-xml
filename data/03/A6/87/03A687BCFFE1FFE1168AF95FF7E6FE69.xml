<taxonomicName box="[2285,2400,2098,2131]" class="Insecta" family="Anthribidae" genus="Platyrrhinus" kingdom="Animalia" order="Coleoptera" pageId="80" pageNumber="564" phylum="Arthropoda" rank="species" species="helleri">P. helleri</taxonomicName>
