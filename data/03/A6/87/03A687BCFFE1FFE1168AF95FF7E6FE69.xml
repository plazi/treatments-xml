<subSubSection pageId="80" pageNumber="564" type="discussion">
<taxonomicName box="[2071,2386,2062,2091]" class="Mammalia" family="Phyllostomidae" genus="Platyrrhinus" kingdom="Animalia" order="Chiroptera" pageId="80" pageNumber="564" phylum="Chordata" rank="species" species="guianensis">Platyrrhinus guianensis</taxonomicName>
