<taxonomicName box="[2508,2646,1854,1887]" class="Mammalia" family="Phyllostomidae" genus="Lonchophylla" kingdom="Animalia" order="Chiroptera" pageId="46" pageNumber="530" phylum="Chordata" rank="species" species="robusta">L. robusta</taxonomicName>
