<taxonomicName authority="Osgood, 1916" authorityName="Osgood" authorityYear="1916" box="[2221,2645,303,328]" class="Mammalia" family="Phyllostomidae" genus="Artibeus" kingdom="Animalia" order="Chiroptera" pageId="94" pageNumber="578" phylum="Chordata" rank="species" species="anderseni">Artibeus anderseni Osgood, 1916</taxonomicName>
