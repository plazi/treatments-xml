<quantity box="[1163,1241,1355,1380]" metricMagnitude="1" metricUnit="m" metricValue="5.4" pageId="80" pageNumber="564" unit="m" value="54.0">54 m</quantity>
in elevation, Province of Zarumilla, Department of 
<collectingRegion box="[840,953,1434,1459]" country="Peru" name="Tumbes" pageId="80" pageNumber="564">Tumbes</collectingRegion>
, 
