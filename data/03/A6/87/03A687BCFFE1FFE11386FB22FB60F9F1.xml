<geoCoordinate box="[1291,1380,1434,1459]" degrees="3" direction="south" minutes="40" orientation="latitude" pageId="80" pageNumber="564" precision="925" value="-3.6666667">3°40’S</geoCoordinate>
, 
<geoCoordinate box="[796,909,1465,1498]" degrees="80" direction="west" minutes="12" orientation="longitude" pageId="80" pageNumber="564" precision="925" value="-80.2">80º12’W</geoCoordinate>
