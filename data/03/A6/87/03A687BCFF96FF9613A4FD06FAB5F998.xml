E 
<collectingCountry box="[1003,1142,1231,1260]" name="Colombia" pageId="39" pageNumber="523">Colombia</collectingCountry>
, E 
<collectingCountry box="[1204,1351,1231,1260]" name="Venezuela" pageId="39" pageNumber="523">Venezuela</collectingCountry>
, 
<collectingCountry box="[767,888,1274,1299]" name="Trinidad and Tobago" pageId="39" pageNumber="523">Trinidad</collectingCountry>
I, the Guianas, both Andean slopes of 
<collectingCountry box="[284,403,1307,1340]" name="Ecuador" pageId="39" pageNumber="523">Ecuador</collectingCountry>
and 
<collectingCountry box="[475,542,1307,1340]" name="Peru" pageId="39" pageNumber="523">Peru</collectingCountry>
, and Amazonian Basin in 
<collectingCountry box="[912,991,1307,1340]" name="Brazil" pageId="39" pageNumber="523">Brazil</collectingCountry>
and 
<collectingCountry box="[1063,1160,1307,1340]" name="Bolivia" pageId="39" pageNumber="523">Bolivia</collectingCountry>
