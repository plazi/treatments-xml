<taxonomicName box="[263,490,1336,1357]" class="Magnoliopsida" family="Brassicaceae" genus="Christolea" kingdom="Plantae" order="Brassicales" pageId="0" pageNumber="205" phylum="Tracheophyta" rank="species" species="pterosperma">
