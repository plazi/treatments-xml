(
<typeStatus box="[794,894,799,825]" pageId="21" pageNumber="472">holotype</typeStatus>
<quantity box="[903,1010,799,825]" metricMagnitude="-2" metricUnit="m" metricValue="2.29" pageId="21" pageNumber="472" unit="mm" value="22.9">22.9 mm</quantity>
), female 
<quantity box="[1117,1285,798,825]" metricMagnitude="-2" metricUnit="m" metricValue="2.445" metricValueMax="2.54" metricValueMin="2.35" pageId="21" pageNumber="472" unit="mm" value="24.45" valueMax="25.4" valueMin="23.5">23.5–25.4 mm</quantity>
; body width: male 
<quantity box="[213,374,834,861]" metricMagnitude="-2" metricUnit="m" metricValue="1.135" metricValueMax="1.15" metricValueMin="1.1199999999999999" pageId="21" pageNumber="472" unit="mm" value="11.35" valueMax="11.5" valueMin="11.2">11.2–11.5 mm</quantity>
(
