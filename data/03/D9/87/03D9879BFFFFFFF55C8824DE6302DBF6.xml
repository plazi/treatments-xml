<taxonomicName authorityName="M. Asif, A. Izhar, Niazi &amp; Khalid" authorityYear="2022" box="[443,547,312,337]" class="Agaricomycetes" family="Psathyrellaceae" genus="Candolleomyces" higherTaxonomySource="GBIF" kingdom="Fungi" order="Agaricales" pageId="5" pageNumber="181" phylum="Basidiomycota" rank="species" species="asiaticus">
