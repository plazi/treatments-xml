<taxonomicName authority="Silva &amp; Gonçalves &amp; Takiya, 2022" authorityName="Silva &amp; Gonçalves &amp; Takiya" authorityYear="2022" box="[284,561,1652,1678]" class="Insecta" family="Cicadellidae" genus="Domahovana" kingdom="Animalia" order="Hemiptera" pageId="4" pageNumber="162" phylum="Arthropoda" rank="species" species="icamiabas" status="sp. nov.">
