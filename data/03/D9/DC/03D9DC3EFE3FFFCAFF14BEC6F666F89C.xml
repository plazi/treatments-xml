<taxonomicNameLabel box="[572,666,1653,1679]" pageId="4" pageNumber="162" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
can be distinguished from other 
<taxonomicName authorityName="Silva &amp; Gonçalves &amp; Takiya" authorityYear="2022" box="[1059,1210,1652,1678]" class="Insecta" family="Cicadellidae" genus="Domahovana" kingdom="Animalia" order="Hemiptera" pageId="4" pageNumber="162" phylum="Arthropoda" rank="genus">
<emphasis box="[1059,1210,1652,1678]" italics="true" pageId="4" pageNumber="162">Domahovana</emphasis>
</taxonomicName>
