<taxonomicNameLabel box="[497,587,1921,1947]" pageId="12" pageNumber="170" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
closely resembles 
<taxonomicName authority="Silva &amp; Gonçalves &amp; Takiya, 2022" authorityName="Silva &amp; Gonçalves &amp; Takiya" authorityYear="2022" box="[802,1100,1921,1947]" class="Insecta" family="Cicadellidae" genus="Domahovana" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="170" phylum="Arthropoda" rank="species" species="yamurikuma" status="sp. nov.">
