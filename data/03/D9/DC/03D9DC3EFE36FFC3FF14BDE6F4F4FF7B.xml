<taxonomicName authority="Silva &amp; Gonçalves &amp; Takiya, 2022" authorityName="Silva &amp; Gonçalves &amp; Takiya" authorityYear="2022" box="[281,489,1921,1947]" class="Insecta" family="Cicadellidae" genus="Domahovana" kingdom="Animalia" order="Hemiptera" pageId="12" pageNumber="170" phylum="Arthropoda" rank="species" species="naia" status="sp. nov.">
