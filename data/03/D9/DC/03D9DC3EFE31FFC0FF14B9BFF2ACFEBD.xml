<taxonomicName authority="Silva &amp; Gonçalves &amp; Takiya, 2022" authorityName="Silva &amp; Gonçalves &amp; Takiya" authorityYear="2022" box="[1170,1353,210,232]" class="Insecta" family="Cicadellidae" genus="Domahovana" kingdom="Animalia" order="Hemiptera" pageId="14" pageNumber="172" phylum="Arthropoda" rank="species" species="naia" status="sp. nov.">
