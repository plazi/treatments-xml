<taxonomicName authority="(Pashtshenko, 1988)" authorityName="Stekolshchikov" authorityYear="2022" baseAuthorityName="Pashtshenko" baseAuthorityYear="1988" box="[1034,1436,1760,1783]" class="Insecta" family="Aphididae" genus="Neoceruraphis" kingdom="Animalia" order="Hemiptera" pageId="36" pageNumber="59" phylum="Arthropoda" rank="species" species="pseudosensoriata">
