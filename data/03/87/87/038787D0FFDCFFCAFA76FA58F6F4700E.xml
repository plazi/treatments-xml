<subSubSection box="[2023,2444,1869,1898]" pageId="12" pageNumber="329" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6639406" ID-Zenodo-Dep="6639406" box="[2023,2444,1869,1898]" httpUri="https://zenodo.org/record/6639406/files/figure.png" inLine="true" pageId="12" pageNumber="329" targetBox="[1407,1999,1601,2014]" targetPageId="12">
<paragraph blockId="12.[2022,2617,1593,2016]" box="[2023,2444,1869,1898]" pageId="12" pageNumber="329">
<emphasis bold="true" box="[2023,2199,1869,1898]" pageId="12" pageNumber="329">Distribution.</emphasis>
