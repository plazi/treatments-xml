<subSubSection pageId="3" pageNumber="320" type="reference_group">
<paragraph blockId="3.[774,1369,486,909]" pageId="3" pageNumber="320">
<emphasis bold="true" box="[775,928,486,515]" pageId="3" pageNumber="320">Taxonomy.</emphasis>
<taxonomicName authorityName="Linnaeus" authorityYear="1758" box="[946,1207,486,515]" class="Mammalia" family="Erinaceidae" genus="Erinaceus" kingdom="Animalia" order="Erinaceomorpha" pageId="3" pageNumber="320" phylum="Chordata" rank="species" species="europaeus">Erinaceus europaeus</taxonomicName>
<taxonomicName authority="Barrett-Hamilton, 1900" authorityName="Barrett-Hamilton" authorityYear="1900" class="Mammalia" family="Erinaceidae" genus="Erimaceus" kingdom="Animalia" order="Erinaceomorpha" pageId="3" pageNumber="320" phylum="Chordata" rank="species" species="roumanicus">roumanicus Barrett-Hamilton, 1900</taxonomicName>
, 
<materialsCitation pageId="3" pageNumber="320">“Gageni, Roumania [= Romania].”</materialsCitation>
</paragraph>
<paragraph blockId="3.[774,1369,486,909]" pageId="3" pageNumber="320">
<taxonomicName authorityName="Barrett-Hamilton" authorityYear="1900" box="[775,1057,600,633]" class="Mammalia" family="Erinaceidae" genus="Erinaceus" kingdom="Animalia" order="Erinaceomorpha" pageId="3" pageNumber="320" phylum="Chordata" rank="species" species="roumanicus">Erinaceus roumanicus</taxonomicName>
was first described as a subspecies of 
<taxonomicName authorityName="Linnaeus" authorityYear="1758" box="[1007,1172,639,672]" class="Mammalia" family="Erinaceidae" genus="Erinaceus" kingdom="Animalia" order="Erinaceomorpha" pageId="3" pageNumber="320" phylum="Chordata" rank="species" species="europaeus">E. europaeus</taxonomicName>
and then included as a subspecies of 
<taxonomicName authorityName="Martin" authorityYear="1838" box="[1154,1296,678,711]" class="Mammalia" family="Erinaceidae" genus="Erinaceus" kingdom="Animalia" order="Erinaceomorpha" pageId="3" pageNumber="320" phylum="Chordata" rank="species" species="concolor">E. concolor</taxonomicName>
, current genetic and morphologic data suggest that 
<taxonomicName authorityName="Martin" authorityYear="1838" box="[908,1050,757,790]" class="Mammalia" family="Erinaceidae" genus="Erinaceus" kingdom="Animalia" order="Erinaceomorpha" pageId="3" pageNumber="320" phylum="Chordata" rank="species" species="concolor">E. concolor</taxonomicName>
and 
<taxonomicName authorityName="Barrett-Hamilton" authorityYear="1900" box="[1124,1312,757,790]" class="Mammalia" family="Erinaceidae" genus="Erinaceus" kingdom="Animalia" order="Erinaceomorpha" pageId="3" pageNumber="320" phylum="Chordata" rank="species" species="roumanicus">E. roumanicus</taxonomicName>
are distinct species with parapatric distributions. 
<taxonomicName authorityName="Barrett-Hamilton" authorityYear="1900" box="[857,1135,840,869]" class="Mammalia" family="Erinaceidae" genus="Erinaceus" kingdom="Animalia" order="Erinaceomorpha" pageId="3" pageNumber="320" phylum="Chordata" rank="species" species="roumanicus">Erinaceus roumanicus</taxonomicName>
is sympatric with 
<taxonomicName authorityName="Linnaeus" authorityYear="1758" box="[774,933,880,909]" class="Mammalia" family="Erinaceidae" genus="Erinaceus" kingdom="Animalia" order="Erinaceomorpha" pageId="3" pageNumber="320" phylum="Chordata" rank="species" species="europaeus">E. europaeus</taxonomicName>
in parts of central Europe. Five
</paragraph>
<paragraph blockId="3.[155,1367,912,2443]" box="[162,473,912,945]" pageId="3" pageNumber="320">subspecies recognized.</paragraph>
</subSubSection>
