<taxonomicName authorityName="Ball" authorityYear="1931" box="[887,1008,1609,1634]" class="Insecta" family="Cicadellidae" genus="Japananus" kingdom="Animalia" order="Hemiptera" pageId="5" pageNumber="350" phylum="Arthropoda" rank="genus">
<emphasis box="[887,1008,1609,1634]" italics="true" pageId="5" pageNumber="350">Japananus</emphasis>
</taxonomicName>
.
</paragraph>
</subSubSection>
