<quantity box="[727,865,367,393]" metricMagnitude="-3" metricUnit="m" metricValue="4.65" metricValueMax="4.7" metricValueMin="4.6" pageId="6" pageNumber="351" unit="mm" value="4.65" valueMax="4.7" valueMin="4.6">4.6–4.7 mm</quantity>
; 
<specimenCount box="[877,898,367,393]" pageId="6" pageNumber="351" type="female">♀</specimenCount>
