<treatmentCitationGroup box="[136,1210,1444,1466]" pageId="2" pageNumber="280">
<taxonomicName authorityName="Jeffrey &amp; Chen" authorityYear="1984" baseAuthorityName="Wallich ex Candolle" baseAuthorityYear="1838" box="[136,307,1444,1465]" class="Magnoliopsida" family="Asteraceae" genus="Synotis" kingdom="Plantae" order="Asterales" pageId="2" pageNumber="280" phylum="Tracheophyta" rank="species" species="kunthiana">
