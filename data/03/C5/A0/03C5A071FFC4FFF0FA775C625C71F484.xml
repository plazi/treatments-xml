<taxonomicName authority="Thomas, 1928" authorityName="Thomas" authorityYear="1928" class="Mammalia" family="Echimyidae" genus="Echimys" kingdom="Animalia" order="Rodentia" pageId="41" pageNumber="593" phylum="Chordata" rank="species" species="saturnus">Echimys saturnus Thomas, 1928</taxonomicName>
