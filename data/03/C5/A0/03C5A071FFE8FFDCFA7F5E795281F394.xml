<subSubSection pageId="5" pageNumber="557" type="activity">
<paragraph blockId="5.[1471,2677,2212,3072]" pageId="5" pageNumber="557">
<emphasis bold="true" box="[1471,1709,2684,2717]" pageId="5" pageNumber="557">Activity patterns.</emphasis>
