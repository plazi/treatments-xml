<subSubSection pageId="88" pageNumber="659" type="discussion">
<paragraph blockId="88.[710,1298,2244,2665]" pageId="88" pageNumber="659">
Formerly in the synonymy of 
<taxonomicName baseAuthorityName="Matschie" baseAuthorityYear="1892" box="[1165,1289,2362,2391]" class="Mammalia" family="Bovidae" genus="Damaliscus" kingdom="Animalia" order="Artiodactyla" pageId="88" pageNumber="659" phylum="Chordata" rank="species" species="jimela">D. jimela</taxonomicName>
