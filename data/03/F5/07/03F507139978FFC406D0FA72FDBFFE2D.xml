<taxonomicName authority="Blaine, 1913" authorityName="Blaine" authorityYear="1913" class="Mammalia" family="Bovidae" genus="Cervicapra" kingdom="Animalia" order="Artiodactyla" pageId="51" pageNumber="666" phylum="Chordata" rank="subSpecies" species="bohor" subSpecies="nigeriensis">Cervicapra bohor nigeriensis Blaine, 1913</taxonomicName>
, 
<materialsCitation ID-GBIF-Occurrence="3785198404" box="[2282,2588,1697,1722]" pageId="51" pageNumber="666">
Ibi, Northern 
<collectingCountry box="[2480,2585,1697,1722]" name="Nigeria" pageId="51" pageNumber="666">Nigeria</collectingCountry>
