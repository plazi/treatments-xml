<collectingCountry box="[2451,2569,2794,2823]" name="Vietnam" pageId="132" pageNumber="747">Vietnam</collectingCountry>
through 
<collectingCountry box="[2117,2248,2837,2862]" name="Myanmar" pageId="132" pageNumber="747">Myanmar</collectingCountry>
, 
<collectingCountry box="[2268,2397,2837,2862]" name="Thailand" pageId="132" pageNumber="747">Thailand</collectingCountry>
