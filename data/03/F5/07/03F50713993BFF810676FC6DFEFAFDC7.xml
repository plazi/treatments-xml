<collectingCountry box="[1664,1760,1766,1799]" name="Turkey" pageId="112" pageNumber="683">Turkey</collectingCountry>
, N 
<collectingCountry box="[1807,1865,1766,1799]" name="Iraq" pageId="112" pageNumber="683">Iraq</collectingCountry>
, S 
<collectingCountry box="[1904,2029,1766,1799]" name="Armenia" pageId="112" pageNumber="683">Armenia</collectingCountry>
, 
<collectingCountry box="[2042,2191,1766,1799]" name="Azerbaijan" pageId="112" pageNumber="683">Azerbaijan</collectingCountry>
(
<collectingRegion box="[2214,2382,1766,1799]" country="Azerbaijan" name="Naxcivan" pageId="112" pageNumber="683">Nakhchivan</collectingRegion>
Autonomous Republic), N 
<collectingCountry box="[1561,1635,1813,1838]" name="Israel" pageId="112" pageNumber="683">Israel</collectingCountry>
(Mt Carmel), and NW 
<collectingCountry box="[1959,2011,1813,1838]" name="Iran" pageId="112" pageNumber="683">Iran</collectingCountry>
;its distribution boundaries in 
<collectingCountry box="[2444,2501,1813,1838]" name="Iran" pageId="112" pageNumber="683">Iran</collectingCountry>
have not been fully determined. Introduced on Kabudan I in Lake Urumiyeh, NW 
<collectingCountry box="[2468,2528,1844,1877]" name="Iran" pageId="112" pageNumber="683">Iran</collectingCountry>
