</taxonomicName>
<emphasis bold="true" box="[464,545,1975,1999]" pageId="5" pageNumber="398">
<taxonomicNameLabel box="[464,545,1975,1999]" pageId="5" pageNumber="398" rank="species">sp. nov.</taxonomicNameLabel>
