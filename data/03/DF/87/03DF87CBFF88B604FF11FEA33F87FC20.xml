<taxonomicName authority="Ariyama &amp; Kohtsuka, 2022" authorityName="Ariyama &amp; Kohtsuka" authorityYear="2022" box="[281,458,1944,1968]" class="Malacostraca" family="Aoridae" genus="Aora" kingdom="Animalia" order="Amphipoda" pageId="6" pageNumber="399" phylum="Arthropoda" rank="species" species="biarticulata" status="sp. nov.">
