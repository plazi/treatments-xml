<paragraph blockId="11.[181,1142,832,1411]" box="[181,295,1352,1379]" pageId="11" pageNumber="134">
<taxonomicName authority="Oldroyd, 1974" authorityName=": Oldroyd" authorityYear="1974" box="[181,287,1352,1379]" class="Insecta" family="Asilidae" genus="Anypodetus" kingdom="Animalia" order="Diptera" pageId="11" pageNumber="134" phylum="Arthropoda" rank="species" species="rigidis">
<emphasis bold="true" box="[181,287,1352,1379]" italics="true" pageId="11" pageNumber="134">A. rigidis</emphasis>
