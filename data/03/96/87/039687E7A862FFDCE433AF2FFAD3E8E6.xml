4.1.12. 
<taxonomicName authorityName="Leach" authorityYear="1815" box="[179,303,788,808]" class="Insecta" family="Tettigoniidae" genus="Libelluloidea" higherTaxonomySource="GBIF" kingdom="Animalia" order="Orthoptera" pageId="11" pageNumber="12" phylum="Arthropoda" rank="genus">Libelluloidea</taxonomicName>
</emphasis>
</heading>
</paragraph>
</subSubSection>
