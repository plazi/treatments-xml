<paragraph blockId="6.[493,1095,920,948]" box="[493,1095,920,948]" pageId="6" pageNumber="147">
<heading box="[493,1095,920,948]" centered="true" fontSize="11" level="2" pageId="6" pageNumber="147" reason="2">
<taxonomicName authority="Lohse, 1958" authorityName="Lohse" authorityYear="1958" box="[493,1095,920,948]" class="Insecta" family="Staphylinidae" genus="Quedius" kingdom="Animalia" order="Coleoptera" pageId="6" pageNumber="147" phylum="Arthropoda" rank="species" species="pseudoumbrinus" subGenus="Raphirus">
<emphasis bold="true" box="[493,942,920,947]" pageId="6" pageNumber="147">
<emphasis bold="true" box="[493,594,920,947]" italics="true" pageId="6" pageNumber="147">Quedius</emphasis>
(
<emphasis bold="true" box="[611,723,920,947]" italics="true" pageId="6" pageNumber="147">Raphirus</emphasis>
) 
<emphasis bold="true" box="[740,942,920,947]" italics="true" pageId="6" pageNumber="147">pseudoumbrinus</emphasis>
</emphasis>
Lohse, 1958
</taxonomicName>
</heading>
</paragraph>
