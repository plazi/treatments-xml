<taxonomicName authority="Salnitska &amp; Solodovnikov, 2022" authorityName="Salnitska &amp; Solodovnikov" authorityYear="2022" box="[191,526,1467,1493]" class="Insecta" family="Staphylinidae" genus="Quedius" kingdom="Animalia" order="Coleoptera" pageId="13" pageNumber="154" phylum="Arthropoda" rank="species" species="gissaricus" status="sp. nov." subGenus="Distichalius">
