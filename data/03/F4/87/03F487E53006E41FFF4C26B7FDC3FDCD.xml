<taxonomicName box="[282,521,1982,2004]" class="Hexactinellida" family="Rossellidae" genus="Nodastrella" kingdom="Animalia" order="Lyssacinosida" pageId="5" pageNumber="6" phylum="Porifera" rank="species" species="nodastrella">
