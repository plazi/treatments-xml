<paragraph blockId="3.[317,1270,439,501]" lastBlockId="5.[317,1270,439,853]" lastPageId="5" lastPageNumber="6" pageId="3" pageNumber="4">
<emphasis box="[382,501,440,466]" italics="true" pageId="3" pageNumber="4">Diagnosis</emphasis>
