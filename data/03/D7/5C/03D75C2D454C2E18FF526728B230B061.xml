<emphasis bold="true" box="[151,808,1837,1864]" pageId="38" pageNumber="39">
2.4 
<taxonomicName baseAuthorityName="Okada" baseAuthorityYear="1980" box="[195,536,1837,1864]" class="Insecta" family="Drosophilidae" genus="Colocasiomyia" kingdom="Animalia" order="Diptera" pageId="38" pageNumber="39" phylum="Arthropoda" rank="species" species="xenalocasiae">
<emphasis bold="true" box="[195,536,1837,1864]" italics="true" pageId="38" pageNumber="39">Colocasiomyia xenalocasiae</emphasis>
</taxonomicName>
species complex, new
</emphasis>
</paragraph>
