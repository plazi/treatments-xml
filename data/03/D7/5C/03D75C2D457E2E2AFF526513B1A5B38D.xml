<paragraph blockId="20.[151,740,1302,1329]" box="[151,740,1302,1329]" pageId="20" pageNumber="21">
<emphasis bold="true" box="[151,740,1302,1329]" pageId="20" pageNumber="21">
2. 
<taxonomicName authorityName="de Meijere" authorityYear="1914" box="[181,455,1302,1329]" class="Insecta" family="Drosophilidae" genus="Colocasiomyia" kingdom="Animalia" order="Diptera" pageId="20" pageNumber="21" phylum="Arthropoda" rank="species" species="cristata">
