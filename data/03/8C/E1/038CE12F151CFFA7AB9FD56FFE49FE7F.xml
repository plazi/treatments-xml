<collectingCountry box="[975,1077,1634,1660]" name="Thailand" pageId="15" pageNumber="128">Thailand</collectingCountry>
, 
<collectingCountry box="[1086,1191,1634,1660]" name="Malaysia" pageId="15" pageNumber="128">Malaysia</collectingCountry>
