<paragraph blockId="15.[136,1452,1526,2093]" pageId="15" pageNumber="128">
<emphasis bold="true" box="[189,733,1562,1588]" pageId="15" pageNumber="128">Habitat, phenology and conservation status:</emphasis>
—Epiphyte. Broad-leaved evergreen lowland and submontane forests on granite at elevation 
<quantity box="[474,601,1598,1625]" metricMagnitude="2" metricUnit="m" metricValue="7.0" metricValueMax="8.0" metricValueMin="6.0" pageId="15" pageNumber="128" unit="m" value="700.0" valueMax="800.0" valueMin="600.0">600–800 m</quantity>
