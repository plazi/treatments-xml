<subSubSection pageId="16" pageNumber="129" type="distribution">
<paragraph blockId="16.[136,1452,698,1589]" pageId="16" pageNumber="129">
<emphasis bold="true" box="[189,345,806,832]" pageId="16" pageNumber="129">Distribution:</emphasis>
—Southern 
<collectingCountry box="[478,573,806,832]" name="Vietnam" pageId="16" pageNumber="129">Vietnam</collectingCountry>
(
<collectingRegion box="[585,697,806,832]" country="Vietnam" name="Dong Nai" pageId="16" pageNumber="129">Dong Nai</collectingRegion>
