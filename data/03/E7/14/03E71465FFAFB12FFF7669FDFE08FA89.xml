<subSubSection pageId="16" pageNumber="239" type="distribution">
<paragraph blockId="16.[151,1437,1111,1354]" pageId="16" pageNumber="239">
<emphasis bold="true" box="[199,353,1255,1281]" pageId="16" pageNumber="239">Distribution.</emphasis>
Known from 
<collectingCountry box="[516,583,1255,1281]" name="China" pageId="16" pageNumber="239">China</collectingCountry>
(Fukien) and 
<collectingCountry box="[745,845,1255,1281]" name="Thailand" pageId="16" pageNumber="239">Thailand</collectingCountry>
(Balthasar 1961; 
<bibRefCitation author="Stebnicka, Z." box="[1050,1229,1255,1281]" pageId="16" pageNumber="239" pagination="1 - 16" refId="ref9224" refString="Stebnicka, Z. (1992) Aphodiinae from Thailand (Coleoptera: Scarabaeidae). Stuttgarter Beitrage zur Naturkunde, Serie A, Biologie, 481, 1 - 16." type="journal article" year="1992">Stebnicka 1992</bibRefCitation>
). New records for 
<collectingCountry box="[151,269,1291,1317]" name="Cambodia" pageId="16" pageNumber="239">Cambodia</collectingCountry>
, 
<collectingCountry box="[282,394,1291,1317]" name="Indonesia" pageId="16" pageNumber="239">Indonesia</collectingCountry>
, 
<collectingCountry box="[407,516,1292,1318]" name="Myanmar" pageId="16" pageNumber="239">Myanmar</collectingCountry>
and 
<collectingCountry box="[575,674,1291,1317]" name="Vietnam" pageId="16" pageNumber="239">Vietnam</collectingCountry>
. In 
<collectingCountry box="[718,827,1291,1317]" name="Indonesia" pageId="16" pageNumber="239">Indonesia</collectingCountry>
collected together with dominant 
<taxonomicName authority="Ochi, Kon &amp; Kakizoe, 2016" authorityName="Ochi, Kon &amp; Kakizoe" authorityYear="2016" class="Insecta" family="Aphodiidae" genus="Gilletianus" kingdom="Animalia" order="Coleoptera" pageId="16" pageNumber="239" phylum="Arthropoda" rank="species" species="schoolmeestersi">
<emphasis box="[1221,1436,1291,1318]" italics="true" pageId="16" pageNumber="239">G. schoolmeestersi</emphasis>
<bibRefCitation author="Ochi, T. &amp; Kon, M. &amp; Kakizoe, S." box="[151,471,1327,1354]" pageId="16" pageNumber="239" pagination="307 - 320" refId="ref8804" refString="Ochi, T., Kon, M. &amp; Kakizoe, S. (2016) Nine new taxa of the genus Gilletianus from Southeast Asia (Coleoptera: Scarabaeidae). Japanese Journal of Systematic Entomology, 22 (2), 307 - 320." type="journal article" year="2016">Ochi, Kon &amp; Kakizoe, 2016</bibRefCitation>
</taxonomicName>
