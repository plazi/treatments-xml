<emphasis box="[151,348,1792,1816]" italics="true" pageId="4" pageNumber="272">Casinaria australis</emphasis>
<bibRefCitation author="Smits van Burgst, C. A. L." box="[354,592,1792,1817]" pageId="4" pageNumber="272" refId="ref6824" refString="Smits van Burgst, C. A. L. (1913) Tunesian Hymenoptera. Privatdruck, Den Haag, 37 pp." type="book" year="1913">Smits van Burgst, 1913</bibRefCitation>
