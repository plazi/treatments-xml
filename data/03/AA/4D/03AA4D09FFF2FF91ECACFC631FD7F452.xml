<taxonomicName authority="Ariyama, 2021" authorityName="Ariyama" authorityYear="2021" box="[410,703,1724,1750]" class="Malacostraca" family="Ochlesidae" genus="Metodius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Amphipoda" pageId="2" pageNumber="487" phylum="Arthropoda" rank="species" species="cyanomaculatus" status="sp. nov.">
<emphasis box="[410,703,1724,1750]" italics="true" pageId="2" pageNumber="487">Metodius cyanomaculatus</emphasis>
</taxonomicName>
<emphasis bold="true" box="[710,800,1724,1750]" pageId="2" pageNumber="487">
<taxonomicNameLabel box="[710,800,1724,1750]" pageId="2" pageNumber="487" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
and 
<taxonomicName authority="Ariyama, 2021" authorityName="Ariyama" authorityYear="2021" box="[854,1067,1724,1750]" class="Malacostraca" family="Ochlesidae" genus="Metodius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Amphipoda" pageId="2" pageNumber="487" phylum="Arthropoda" rank="species" species="leucomaculatus" status="sp. nov.">
