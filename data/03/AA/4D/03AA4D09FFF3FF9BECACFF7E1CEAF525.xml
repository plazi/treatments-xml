<taxonomicName authority="Ariyama, 2021" authorityName="Ariyama" authorityYear="2021" box="[280,546,1132,1156]" class="Malacostraca" family="Ochlesidae" genus="Metodius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Amphipoda" pageId="8" pageNumber="493" phylum="Arthropoda" rank="species" species="cyanomaculatus" status="gen. et sp. nov.">
