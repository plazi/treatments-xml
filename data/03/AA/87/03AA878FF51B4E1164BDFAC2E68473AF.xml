<taxonomicName authority="Li &amp; Jin &amp; Bu &amp; Ye, 2022" authorityName="Li &amp; Jin &amp; Bu &amp; Ye" authorityYear="2022" box="[886,1056,1524,1550]" class="Insecta" family="Veliidae" genus="Pseudovelia" kingdom="Animalia" order="Hemiptera" pageId="13" pageNumber="520" phylum="Arthropoda" rank="species" species="shannxiensis" status="sp. nov.">
