<taxonomicName authority="Esaki &amp; Miyamoto, 1955" authorityName="Esaki &amp; Miyamoto" authorityYear="1955" box="[182,670,1560,1587]" class="Insecta" family="Veliidae" genus="Pseudovelia" kingdom="Animalia" order="Hemiptera" pageId="13" pageNumber="520" phylum="Arthropoda" rank="subSpecies" species="tibialis" subSpecies="tibialis">
