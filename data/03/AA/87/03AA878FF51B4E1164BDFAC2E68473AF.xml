The genital segments (
<figureCitation box="[581,674,1524,1550]" captionStart="FIGURES 35–40" captionStartId="9.[151,264,1771,1795]" captionTargetBox="[174,1415,226,1669]" captionTargetId="figure-18@9.[151,1436,211,1681]" captionTargetPageId="9" captionText="FIGURES 35–40. Abdominal segment VIII of Pseudovelia spp. (males). 35. P. buccula Andersen, 1983; 36. P. takarai Miyamoto, 1964; 37. P. curvisetae sp. nov.; 38. P. plauta sp. nov.; 39. P. shaanxiensis sp. nov.; 40. P. zhengi sp. nov. Scale 0.2 mm." figureDoi="http://doi.org/10.5281/zenodo.6816737" httpUri="https://zenodo.org/record/6816737/files/figure.png" pageId="13" pageNumber="520">Figs. 39</figureCitation>
, 
<figureCitation box="[686,716,1524,1551]" captionStart="FIGURES 41–46" captionStartId="10.[151,264,1813,1837]" captionTargetBox="[151,1427,216,1720]" captionTargetId="figure-21@10.[151,1436,211,1738]" captionTargetPageId="10" captionText="FIGURES 41–46. Abdominal segment VIII of Pseudovelia spp. (males). 41. P. buccula Andersen, 1983; 42. P. takarai Miyamoto, 1964; 43. P. curvisetae sp. nov.; 44. P. plauta sp. nov.; 45. P. shaanxiensis sp. nov.; 46. P. zhengi sp. nov. Scale 0.2 mm." figureDoi="http://doi.org/10.5281/zenodo.6816739" httpUri="https://zenodo.org/record/6816739/files/figure.png" pageId="13" pageNumber="520">45</figureCitation>
, 
<figureCitation box="[728,758,1524,1551]" captionStart="FIGURES 47–52" captionStartId="11.[151,264,1860,1884]" captionTargetBox="[173,1410,201,1790]" captionTargetId="figure-18@11.[151,1436,181,1808]" captionTargetPageId="11" captionText="FIGURES 47–52. Abdominal segment VIII of Pseudovelia spp. (males). 47. P. buccula Andersen, 1983; 48. P. takarai Miyamoto, 1964; 49. P. curvisetae sp. nov.; 50. P. plauta sp. nov.; 51. P. shaanxiensis sp. nov.; 52. P. zhengi sp. nov. Scale 0.2 mm." figureDoi="http://doi.org/10.5281/zenodo.6816743" httpUri="https://zenodo.org/record/6816743/files/figure.png" pageId="13" pageNumber="520">51</figureCitation>
, 
<figureCitation box="[770,800,1524,1551]" captionStart="FIGURES 53–58" captionStartId="12.[151,264,1862,1886]" captionTargetBox="[154,1433,182,1778]" captionTargetId="figure-21@12.[151,1436,181,1795]" captionTargetPageId="12" captionText="FIGURES 53–58. Abdominal segment VIII of Pseudovelia spp. (males). 53. P. buccula Andersen, 1983; 54. P. takarai Miyamoto, 1964; 55. P. curvisetae sp. nov.; 56. P. plauta sp. nov.; 57. P. shaanxiensis sp. nov.; 58. P. zhengi sp. nov. Scale 0.2 mm." figureDoi="http://doi.org/10.5281/zenodo.6816745" httpUri="https://zenodo.org/record/6816745/files/figure.png" pageId="13" pageNumber="520">57</figureCitation>
, 
<figureCitation box="[812,841,1524,1550]" captionStart="FIGURES 59–64" captionStartId="13.[151,264,1165,1189]" captionTargetBox="[234,1369,196,1128]" captionTargetId="figure-18@13.[205,1381,181,1141]" captionTargetPageId="13" captionText="FIGURES 59–64. Pygophore of Pseudovelia spp. (males). 59. P. buccula Andersen, 1983; 60. P. takarai Miyamoto, 1964; 61. P. curvisetae sp. nov.; 62. P. plauta sp. nov.; 63. P. shaanxiensis sp. nov.; 64. P. zhengi sp. nov. Scale 0.1 mm." figureDoi="http://doi.org/10.5281/zenodo.6816747" httpUri="https://zenodo.org/record/6816747/files/figure.png" pageId="13" pageNumber="520">63</figureCitation>
