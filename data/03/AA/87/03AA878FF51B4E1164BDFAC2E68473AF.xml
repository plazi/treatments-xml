<taxonomicName authority="Li &amp; Jin &amp; Bu &amp; Ye, 2022" authorityName="Li &amp; Jin &amp; Bu &amp; Ye" authorityYear="2022" box="[798,969,1560,1586]" class="Insecta" family="Veliidae" genus="Pseudovelia" kingdom="Animalia" order="Hemiptera" pageId="13" pageNumber="520" phylum="Arthropoda" rank="species" species="shannxiensis" status="sp. nov.">
<emphasis box="[798,969,1560,1586]" italics="true" pageId="13" pageNumber="520">P. shannxiensis</emphasis>
</taxonomicName>
<emphasis bold="true" box="[977,1067,1560,1586]" pageId="13" pageNumber="520">
<taxonomicNameLabel box="[977,1067,1560,1586]" pageId="13" pageNumber="520" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
