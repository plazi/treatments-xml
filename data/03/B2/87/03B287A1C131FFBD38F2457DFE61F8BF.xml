<emphasis box="[280,397,1388,1412]" italics="true" pageId="6" pageNumber="60">Apodryinus</emphasis>
<bibRefCitation author="Olmi, M." box="[403,519,1388,1412]" pageId="6" pageNumber="60" pagination="1 - 1913" refId="ref8258" refString="Olmi, M. (1984) A revision of the Dryinidae (Hymenoptera). Memoirs of the American Entomological Institute, 37, I - XII + 1 - 1913." type="journal article" year="1984">Olmi, 1984</bibRefCitation>
