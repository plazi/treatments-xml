<subSubSection pageId="2" pageNumber="56" type="etymology">
<paragraph blockId="2.[151,1436,1689,1895]" pageId="2" pageNumber="56">
<emphasis bold="true" box="[199,328,1833,1859]" pageId="2" pageNumber="56">Etymology</emphasis>
. The term “ 
<taxonomicName authorityName="Olmi &amp; Guglielmino &amp; Vasilenko &amp; Perkovsky" authorityYear="2022" box="[466,622,1833,1859]" class="Insecta" family="Dryinidae" genus="Rovnodryinus" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="56" phylum="Arthropoda" rank="genus">
<emphasis box="[466,622,1833,1859]" italics="true" pageId="2" pageNumber="56">Rovnodryinus</emphasis>
</taxonomicName>
” derives from Rovno- (the Ukrainian region where the amber piece has been found) + 
<taxonomicName box="[315,405,1870,1895]" class="Insecta" family="Dryinidae" genus="Dryinus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="56" phylum="Arthropoda" rank="genus">
<emphasis box="[315,405,1870,1895]" italics="true" pageId="2" pageNumber="56">Dryinus</emphasis>
</taxonomicName>
, 
<typeStatus box="[420,468,1869,1895]" pageId="2" pageNumber="56">type</typeStatus>
genus of 
<taxonomicName authorityName="Haliday" authorityYear="1833" box="[578,695,1869,1895]" class="Insecta" family="Dryinidae" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="56" phylum="Arthropoda" rank="family">Dryinidae</taxonomicName>
).
</paragraph>
</subSubSection>
