<subSubSection pageId="6" pageNumber="115" type="diagnosis">
<paragraph blockId="6.[189,310,1527,1553]" box="[189,310,1527,1553]" pageId="6" pageNumber="115">
<heading bold="true" box="[189,310,1527,1553]" fontSize="11" level="3" pageId="6" pageNumber="115" reason="3">
<emphasis bold="true" box="[189,310,1527,1553]" pageId="6" pageNumber="115">Diagnosis</emphasis>
</heading>
</paragraph>
<paragraph blockId="6.[189,1398,1574,1670]" pageId="6" pageNumber="115">More than 50 pairs of outer paleae per lobe. Outer paleae with irregularly expanded margins resembling small denticles. Four to five inner paleae per lobe. Inner paleae with conspicuous transverse thecae and slightly curved tip. Three pairs of buccal tentacles.</paragraph>
</subSubSection>
<subSubSection box="[189,1134,1710,1783]" pageId="6" pageNumber="115" type="etymology">
<paragraph blockId="6.[189,324,1710,1736]" box="[189,324,1710,1736]" pageId="6" pageNumber="115">
<heading bold="true" box="[189,324,1710,1736]" fontSize="11" level="3" pageId="6" pageNumber="115" reason="3">
<emphasis bold="true" box="[189,324,1710,1736]" pageId="6" pageNumber="115">Etymology</emphasis>
</heading>
</paragraph>
<paragraph blockId="6.[189,1134,1756,1783]" box="[189,1134,1756,1783]" pageId="6" pageNumber="115">The species name is referred to the Caribbean Sea, where the species was found.</paragraph>
</subSubSection>
