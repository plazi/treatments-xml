depth (
<figureCitation box="[993,1081,776,803]" captionStart="Fig" captionStartId="37.[189,232,1795,1821]" captionTargetBox="[203,1386,282,1742]" captionTargetId="figure-12@37.[189,1398,265,1758]" captionTargetPageId="37" captionText="Fig. 22. Localities for studied specimens. A. Caribbean Sea and the Gulf of Mexico. B. South Florida. C. Southeastern Bahamas. The crosses indicate type localities of species previously recorded in the tropical Western Atlantic." figureDoi="http://doi.org/10.5281/zenodo.6885320" httpUri="https://zenodo.org/record/6885320/files/figure.png" pageId="33" pageNumber="142">Fig. 22</figureCitation>
).
</paragraph>
