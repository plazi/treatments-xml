<subSubSection pageId="11" pageNumber="198" type="discussion">
<paragraph blockId="11.[151,1437,1670,1948]" pageId="11" pageNumber="198">
<emphasis bold="true" box="[199,335,1670,1696]" pageId="11" pageNumber="198">Comments.</emphasis>
The 
<taxonomicName authorityName="Nunes &amp; Mendonça &amp; Fernandes" authorityYear="2022" box="[397,603,1670,1696]" class="Insecta" family="Pentatomidae" genus="Hypoxys" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hemiptera" pageId="11" pageNumber="198" phylum="Arthropoda" rank="species" species="dorsocarinatus">
<emphasis box="[397,603,1670,1696]" italics="true" pageId="11" pageNumber="198">H. dorsocarinatus</emphasis>
</taxonomicName>
has a paramere similar to that of 
<taxonomicName authorityName="Nunes &amp; Mendonça &amp; Fernandes" authorityYear="2022" box="[995,1184,1671,1696]" class="Insecta" family="Pentatomidae" genus="Hypoxys" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hemiptera" pageId="11" pageNumber="198" phylum="Arthropoda" rank="species" species="nigrosinuatus">
<emphasis box="[995,1184,1671,1696]" italics="true" pageId="11" pageNumber="198">H. nigrosinuatus</emphasis>
</taxonomicName>
, 
<taxonomicName authorityName="Breddin" authorityYear="1907" box="[1200,1351,1670,1696]" class="Insecta" family="Pentatomidae" genus="Hypoxys" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hemiptera" pageId="11" pageNumber="198" phylum="Arthropoda" rank="species" species="offuscatus">
<emphasis box="[1200,1351,1670,1696]" italics="true" pageId="11" pageNumber="198">H. offuscatus</emphasis>
</taxonomicName>
and 
<taxonomicName authorityName="Fabricius" authorityYear="1803" class="Insecta" family="Pentatomidae" genus="Edessa" kingdom="Animalia" order="Hemiptera" pageId="11" pageNumber="198" phylum="Arthropoda" rank="species" species="quadridens">
<emphasis italics="true" pageId="11" pageNumber="198">H. quadridens</emphasis>
</taxonomicName>
(
<figureCitation box="[296,386,1706,1732]" captionStart="FIGURE 6" captionStartId="11.[151,250,1564,1588]" captionTargetBox="[166,1417,193,1524]" captionTargetId="figure-20@11.[151,1436,181,1540]" captionTargetPageId="11" captionText="FIGURE 6. Hypoxys dorsocarinatus sp. n. A–D Male, pygophore; A—dorsal view; B—posterior view; C—lateroposterior view; D—ventral view (Scale = 1mm)." figureDoi="http://doi.org/10.5281/zenodo.6777072" httpUri="https://zenodo.org/record/6777072/files/figure.png" pageId="11" pageNumber="198">Fig. 6B</figureCitation>
; 
<bibRefCitation author="Nunes, B. M. &amp; Campos, L. D. &amp; Mendonca, M. T. S. &amp; Cunha, E. V. P. &amp; Fernandes, J. A. M." box="[402,611,1706,1733]" pageId="11" pageNumber="198" pagination="401 - 441" refId="ref18209" refString="Nunes, B. M., Campos, L. D., Mendonca, M. T. S., Cunha, E. V. P. &amp; Fernandes, J. A. M. (2020) Revision of Hypoxys Amyot &amp; Serville, 1843 stat. rest. (Heteroptera Pentatomidae). Zootaxa, 4742 (3), 401 - 441. https: // doi. org / 10.11646 / zootaxa. 4742.3.1" type="journal article" year="2020">
