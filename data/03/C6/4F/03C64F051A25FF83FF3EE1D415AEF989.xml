<subSubSection pageId="15" pageNumber="202" type="description">
<paragraph blockId="15.[151,1437,863,1575]" pageId="15" pageNumber="202">
<emphasis bold="true" box="[199,382,936,962]" pageId="15" pageNumber="202">Measurements.</emphasis>
