<caption pageId="3" pageNumber="596" startId="3.[151,250,1679,1703]" targetBox="[189,1398,188,1644]" targetPageId="3">
<paragraph blockId="3.[151,1436,1679,1739]" pageId="3" pageNumber="596">
<emphasis bold="true" box="[151,270,1679,1703]" pageId="3" pageNumber="596">FIGURE 4</emphasis>
. Photographs of 
<taxonomicName authority="Yuan &amp; Zheng &amp; Ma &amp; Gu, 2022" authorityName="Yuan &amp; Zheng &amp; Ma &amp; Gu" authorityYear="2022" box="[444,659,1679,1703]" class="Insecta" family="Trigonidiidae" genus="Trigonidium" kingdom="Animalia" order="Orthoptera" pageId="3" pageNumber="596" phylum="Arthropoda" rank="species" species="nigripes" status="sp. nov.">
