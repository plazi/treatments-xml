<paragraph blockId="40.[813,1457,1268,1421]" box="[813,903,1268,1294]" pageId="40" pageNumber="297">REMARK</paragraph>
<paragraph blockId="40.[813,1457,1268,1421]" pageId="40" pageNumber="297">
Perrier’s 
<typeStatus box="[907,954,1300,1326]" pageId="40" pageNumber="297">type</typeStatus>
specimen shares all the characteristics of the common west Indian Ocean species 
<taxonomicName baseAuthorityName="Blainville" baseAuthorityYear="1830" box="[1197,1380,1331,1357]" class="Asteroidea" family="Oreasteridae" genus="Protoreaster" kingdom="Animalia" order="Valvatida" pageId="40" pageNumber="297" phylum="Echinodermata" rank="species" species="lincki">
