<paragraph blockId="15.[813,1456,705,896]" box="[813,913,705,731]" pageId="15" pageNumber="272">REMARKS</paragraph>
<paragraph blockId="15.[813,1456,705,896]" pageId="15" pageNumber="272">
Photographs and drawings of 
<taxonomicName box="[1129,1355,738,764]" class="Asteroidea" family="Asterinidae" genus="Meridiastra" kingdom="Animalia" order="Valvatida" pageId="15" pageNumber="272" phylum="Echinodermata" rank="variety" species="calcar" variety="octogona">
