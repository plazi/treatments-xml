var. 
<emphasis box="[1266,1355,738,763]" italics="true" pageId="15" pageNumber="272">octogona</emphasis>
</taxonomicName>
<typeStatus box="[1360,1455,738,764]" pageId="15" pageNumber="272">holotype</typeStatus>
are presented in 
<bibRefCitation author="Jangoux" box="[990,1208,771,797]" firstAuthor="Jangoux" page="219" pageId="15" pageNumber="272" pagination="213 - 252" refId="ref44008" refString="JANGOUX M. 2021. - The asteroid species of Lamarck (Echinodermata: Asteroidea). Zoosystema 43 (13): 213 - 252. https: // doi. org / 10.5252 / zoosystema 2021 v 43 a 13. http: // zoosystema. com / 43 / 13" type="journal article" year="2021">Jangoux (2021: 219</bibRefCitation>
, fig. 4).
</paragraph>
<paragraph blockId="15.[813,1456,705,896]" pageId="15" pageNumber="272">
<treatmentCitationGroup pageId="15" pageNumber="272">
<taxonomicName box="[835,1060,804,830]" class="Asteroidea" family="Asterinidae" genus="Meridiastra" kingdom="Animalia" order="Valvatida" pageId="15" pageNumber="272" phylum="Echinodermata" rank="variety" species="calcar" variety="octogona">
<emphasis box="[835,924,804,830]" italics="true" pageId="15" pageNumber="272">A. calcar</emphasis>
var. 
<emphasis box="[972,1060,804,829]" italics="true" pageId="15" pageNumber="272">octogona</emphasis>
</taxonomicName>
<typeStatus box="[1065,1159,804,830]" pageId="15" pageNumber="272">holotype</typeStatus>
was not recognized by 
<treatmentCitation author="MULLER J. &amp; TROSCHEL H." page="43" pageId="15" pageNumber="272" year="1842">
<bibRefCitation author="Muller &amp; Troschel" firstAuthor="Muller" page="43" pageId="15" pageNumber="272" refId="ref45916" refString="MULLER J. &amp; TROSCHEL H. 1842. - System der Asteriden. Braunschweig, 134 p." type="book" year="1842">Müller &amp; Troschel (1842: 43)</bibRefCitation>
</treatmentCitation>
who described it as one of the type specimens of a new species (
<taxonomicName authorityName="Muller &amp; Troschel" authorityYear="1842" box="[1116,1306,869,896]" class="Magnoliopsida" family="Asteraceae" genus="Asteriscus" kingdom="Plantae" order="Asterales" pageId="15" pageNumber="272" phylum="Tracheophyta" rank="species" species="australis">
<emphasis box="[1116,1306,869,896]" italics="true" pageId="15" pageNumber="272">Asteriscus australis</emphasis>
</taxonomicName>
).
</treatmentCitationGroup>
</paragraph>
