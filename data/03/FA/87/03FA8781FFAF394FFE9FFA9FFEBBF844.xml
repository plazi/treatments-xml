<typeStatus box="[346,428,1970,1996]" pageId="58" pageNumber="315">syntype</typeStatus>
of 
<taxonomicName baseAuthorityName="Lamarck" baseAuthorityYear="1816" box="[464,612,1969,1995]" class="Asteroidea" family="Luidiidae" genus="Luidia" kingdom="Animalia" order="Paxillosida" pageId="58" pageNumber="315" phylum="Echinodermata" rank="species" species="senegalensis">
<emphasis box="[464,612,1969,1995]" italics="true" pageId="58" pageNumber="315">A. senegalensis</emphasis>
</taxonomicName>
is presented in 
<bibRefCitation author="Jangoux" box="[132,360,2001,2028]" firstAuthor="Jangoux" page="244" pageId="58" pageNumber="315" pagination="213 - 252" refId="ref44008" refString="JANGOUX M. 2021. - The asteroid species of Lamarck (Echinodermata: Asteroidea). Zoosystema 43 (13): 213 - 252. https: // doi. org / 10.5252 / zoosystema 2021 v 43 a 13. http: // zoosystema. com / 43 / 13" type="journal article" year="2021">Jangoux (2021: 244)</bibRefCitation>
.
</paragraph>
