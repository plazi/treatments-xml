<location LSID="urn:lsid:plazi:treatment:03D0097DE223FF94E520DBC8DC8FFE2F:8EA6EEB0E223FF96E625D8B1D9FBF917" box="[382,498,1720,1741]" country="Ecuador" county="Cayambe" municipality="Cayame" name="Designation" pageId="17" pageNumber="18">Designation</location>
