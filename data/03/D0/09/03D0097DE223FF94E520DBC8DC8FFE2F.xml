<typeStatus box="[646,730,1720,1741]" pageId="17" pageNumber="18">holotype</typeStatus>
of 
<taxonomicName authorityName="BRULLE" authorityYear="1846" box="[766,941,1720,1741]" class="Insecta" family="Braconidae" genus="Myosoma" kingdom="Animalia" order="Hymenoptera" pageId="17" pageNumber="18" phylum="Arthropoda" rank="species" species="hirtipes">
<emphasis box="[766,941,1720,1741]" italics="true" pageId="17" pageNumber="18">Myosoma hirtipes</emphasis>
</taxonomicName>
– (
<location LSID="urn:lsid:plazi:treatment:03D0097DE223FF94E520DBC8DC8FFE2F:8EA6EEB0E223FF96E48BD8B1DBF7F917" box="[976,1022,1720,1741]" country="Ecuador" county="Cayambe" municipality="Cayame" name="First" pageId="17" pageNumber="18">First</location>
label, printed) “Museum Paris / EY000000166”; (second label) “Museum Paris” (printed) “Cayame / Leprieur 302 1899” (handwriting, “ 
<collectingMunicipality box="[464,545,1777,1798]" pageId="17" pageNumber="18">Cayame</collectingMunicipality>
” = 
<collectingCounty box="[585,676,1777,1798]" pageId="17" pageNumber="18">Cayambe</collectingCounty>
in 
<collectingCountry box="[711,796,1777,1798]" name="Ecuador" pageId="17" pageNumber="18">Ecuador</collectingCountry>
); (third label, handwriting) “ 
<taxonomicName authority="Br." authorityName="BRULLE and Mysomatoides QUICKE. The" authorityYear="1846" class="Insecta" family="Braconidae" genus="Myosoma" kingdom="Animalia" order="Hymenoptera" pageId="17" pageNumber="18" phylum="Arthropoda" rank="genus" species="hirtipes">Myosoma / hirtipes Br.</taxonomicName>
