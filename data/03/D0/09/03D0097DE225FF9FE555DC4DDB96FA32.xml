<caption ID-DOI="http://doi.org/10.5281/zenodo.5732049" ID-Zenodo-Dep="5732049" httpUri="https://zenodo.org/record/5732049/files/figure.png" pageId="23" pageNumber="24" startId="23.[317,359,1777,1798]" targetBox="[318,1266,1418,1740]" targetPageId="23">
<paragraph blockId="23.[317,1270,1777,1827]" pageId="23" pageNumber="24">
<emphasis bold="true" box="[317,428,1777,1798]" pageId="23" pageNumber="24">Figs 94–97.</emphasis>
<taxonomicName authority="(BRULLE)" authorityName="Papp" authorityYear="2012" baseAuthorityName="BRULLE" baseAuthorityYear="1846" box="[433,770,1777,1798]" class="Insecta" family="Braconidae" genus="Myosomatoides" kingdom="Animalia" order="Hymenoptera" pageId="23" pageNumber="24" phylum="Arthropoda" rank="species" species="fasciatus" status="comb. n.">
