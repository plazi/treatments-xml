</taxonomicName>
<emphasis bold="true" box="[485,541,1372,1396]" pageId="20" pageNumber="513">
<taxonomicNameLabel box="[485,541,1372,1396]" pageId="20" pageNumber="513" rank="species">n. sp.</taxonomicNameLabel>
</emphasis>
, 32mm SL holotype, ZRC 54321, Sulaibikhat Bay, Kuwait. Photograph by Heok Hui Tan.
</paragraph>
</caption>
<caption ID-DOI="http://doi.org/10.5281/zenodo.6691410" ID-Zenodo-Dep="6691410" httpUri="https://zenodo.org/record/6691410/files/figure.png" pageId="20" pageNumber="513" startId="20.[151,250,1960,1984]" targetBox="[380,1207,1429,1931]" targetPageId="20">
<paragraph blockId="20.[151,1436,1960,2021]" pageId="20" pageNumber="513">
<emphasis bold="true" box="[151,289,1960,1984]" pageId="20" pageNumber="513">FIGURE 15.</emphasis>
Sensory pores and papilla in 
<taxonomicName authority="Larson &amp; Jaafar, 2022" authorityName="Larson &amp; Jaafar" authorityYear="2022" box="[594,786,1961,1985]" class="Actinopterygii" family="Gobiidae" genus="Aulopareia" kingdom="Animalia" order="Perciformes" pageId="20" pageNumber="513" phylum="Chordata" rank="species" species="vadosa" status="n. sp.">
<emphasis box="[594,786,1961,1985]" italics="true" pageId="20" pageNumber="513">Aulopareia vadosa</emphasis>
</taxonomicName>
<emphasis bold="true" box="[793,852,1961,1985]" pageId="20" pageNumber="513">
<taxonomicNameLabel box="[793,852,1961,1985]" pageId="20" pageNumber="513" rank="species">n. sp.</taxonomicNameLabel>
