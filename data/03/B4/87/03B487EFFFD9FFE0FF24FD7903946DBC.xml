<heading bold="true" box="[151,582,763,789]" fontSize="11" level="1" pageId="9" pageNumber="492" reason="1">
<emphasis bold="true" box="[151,582,763,789]" pageId="9" pageNumber="492">
<taxonomicName authorityName="Stach" authorityYear="1949" box="[151,384,763,789]" class="Collembola" family="Brachystomellidae" kingdom="Animalia" order="Poduromorpha" pageId="9" pageNumber="492" phylum="Arthropoda" rank="family">Brachystomellidae</taxonomicName>
