. 
<taxonomicName authority="Janion-Scheepers &amp; Deharveng, 2022" authorityName="Janion-Scheepers &amp; Deharveng" authorityYear="2022" box="[283,490,1233,1257]" class="Collembola" family="Brachystomellidae" genus="Setanodosa" kingdom="Animalia" order="Poduromorpha" pageId="4" pageNumber="487" phylum="Arthropoda" rank="species" species="jacquesi" status="sp. nov.">
