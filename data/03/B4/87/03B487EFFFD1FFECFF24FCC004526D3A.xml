</taxonomicName>
<emphasis bold="true" box="[498,579,1233,1257]" pageId="4" pageNumber="487">
<taxonomicNameLabel box="[498,579,1233,1257]" pageId="4" pageNumber="487" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
A, Dorso-external S-chaeta of Th. II; B, Dorso-internal macrochaeta of Abd. VI; C, Dorso-external (De) and dorso-lateral (DL) chaetal groups of Abd. I; D, furcal area; E, female genital plate. Scales. A,B,C, 10 µm; D,E, 20 µm.
</paragraph>
</caption>
<caption ID-DOI="http://doi.org/10.5281/zenodo.6651295" ID-Zenodo-Dep="6651295" httpUri="https://zenodo.org/record/6651295/files/figure.png" pageId="4" pageNumber="487" startId="4.[151,250,1969,1993]" targetBox="[205,1377,1362,1936]" targetPageId="4">
<paragraph blockId="4.[151,1437,1969,2030]" pageId="4" pageNumber="487">
<emphasis bold="true" box="[151,271,1969,1993]" pageId="4" pageNumber="487">FIGURE 6</emphasis>
. 
<taxonomicName authority="Janion-Scheepers &amp; Deharveng, 2022" authorityName="Janion-Scheepers &amp; Deharveng" authorityYear="2022" box="[285,494,1970,1994]" class="Collembola" family="Brachystomellidae" genus="Setanodosa" kingdom="Animalia" order="Poduromorpha" pageId="4" pageNumber="487" phylum="Arthropoda" rank="species" species="jacquesi" status="sp. nov.">
