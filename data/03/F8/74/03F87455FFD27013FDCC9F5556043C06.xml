<subSubSection pageId="7" pageNumber="132" type="diagnosis">
<paragraph blockId="7.[189,311,400,426]" box="[189,311,400,426]" pageId="7" pageNumber="132">
<heading bold="true" box="[189,311,400,426]" fontSize="11" level="3" pageId="7" pageNumber="132" reason="3">
<emphasis bold="true" box="[189,311,400,426]" pageId="7" pageNumber="132">Diagnosis</emphasis>
</heading>
</paragraph>
<paragraph blockId="7.[189,1399,447,509]" pageId="7" pageNumber="132">General color dark brown. Vesicle reduced to a black transverse band. Ventrobasal sclerite of aedeagus black, generally subquadrate in outline with a triangular postcentral notch.</paragraph>
</subSubSection>
<subSubSection box="[189,1183,548,621]" pageId="7" pageNumber="132" type="etymology">
<paragraph blockId="7.[189,325,548,574]" box="[189,325,548,574]" pageId="7" pageNumber="132">
<heading bold="true" box="[189,325,548,574]" fontSize="11" level="3" pageId="7" pageNumber="132" reason="3">
<emphasis bold="true" box="[189,325,548,574]" pageId="7" pageNumber="132">Etymology</emphasis>
</heading>
</paragraph>
<paragraph blockId="7.[189,1183,594,621]" box="[189,1183,594,621]" pageId="7" pageNumber="132">The specific epithet refers to the sclerotized ventrobasal sclerite of everted aedeagus.</paragraph>
</subSubSection>
