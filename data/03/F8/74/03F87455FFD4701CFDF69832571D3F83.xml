<subSubSection box="[189,1388,265,338]" pageId="3" pageNumber="128" type="etymology">
<paragraph blockId="3.[189,325,265,291]" box="[189,325,265,291]" pageId="3" pageNumber="128">
<heading bold="true" box="[189,325,265,291]" fontSize="11" level="3" pageId="3" pageNumber="128" reason="3">
<emphasis bold="true" box="[189,325,265,291]" pageId="3" pageNumber="128">Etymology</emphasis>
</heading>
</paragraph>
<paragraph blockId="3.[189,1388,311,338]" box="[189,1388,311,338]" pageId="3" pageNumber="128">The specific epithet refers to the vesicle being long, which was presumed to be atypical for this genus.</paragraph>
</subSubSection>
