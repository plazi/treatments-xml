<specimenCount box="[681,816,326,352]" pageId="4" pageNumber="99" type="female">two females</specimenCount>
and 
<specimenCount box="[868,969,326,352]" pageId="4" pageNumber="99" type="male">one male</specimenCount>
from 
<collectingCountry box="[1035,1103,326,352]" name="Brazil" pageId="4" pageNumber="99">Brazil</collectingCountry>
(
<collectingRegion box="[1117,1198,326,352]" country="Brazil" name="Parana" pageId="4" pageNumber="99">Paraná</collectingRegion>
, 
<collectingRegion box="[1208,1376,326,352]" country="Brazil" name="Santa Catarina" pageId="4" pageNumber="99">Santa Catarina</collectingRegion>
). The geographical distribution remains unchanged (
<bibRefCitation author="Bezark, L. G." box="[670,832,362,388]" pageId="4" pageNumber="99" refId="ref4389" refString="Bezark, L. G. (2022 b) Checklist of the Oxypeltidae, Vesperidae, Disteniidae and Cerambycidae, (Coleoptera) of the Western Hemisphere. 2022 Edition. Updated through 31 December 2021. Available from: http: // bezbycids. com / byciddb / wdefault. asp? w = n / (accessed 22 April 2022)" type="url" year="2022">Bezark 2022b</bibRefCitation>
