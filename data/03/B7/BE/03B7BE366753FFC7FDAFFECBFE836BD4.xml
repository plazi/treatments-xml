<paragraph blockId="33.[189,1399,578,640]" pageId="33" pageNumber="34">
<taxonomicName authorityName="Meigen" authorityYear="1822" box="[189,302,578,604]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="33" pageNumber="34" phylum="Arthropoda" rank="genus">
<emphasis box="[189,302,578,604]" italics="true" pageId="33" pageNumber="34">Cheilosia</emphasis>
</taxonomicName>
<taxonomicName authorityName="Barkalov &amp; Cheng" authorityYear="1998" box="[311,472,578,604]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="33" pageNumber="34" phylum="Arthropoda" rank="species" species="distincta" subGenus="Montanocheila">
(
<emphasis box="[320,344,579,604]" italics="true" pageId="33" pageNumber="34">M</emphasis>
.) 
<emphasis box="[371,472,578,604]" italics="true" pageId="33" pageNumber="34">distincta</emphasis>
</taxonomicName>
is among the Nepalese species closest to 
<taxonomicName authorityName="Barkalov &amp; Peck" authorityYear="1997" box="[976,1166,578,605]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="33" pageNumber="34" phylum="Arthropoda" rank="species" species="erratica" subGenus="Montanocheila">
<emphasis box="[976,1003,579,605]" italics="true" pageId="33" pageNumber="34">C.</emphasis>
(
<emphasis box="[1020,1053,579,604]" italics="true" pageId="33" pageNumber="34">M.</emphasis>
) 
<emphasis box="[1071,1166,579,604]" italics="true" pageId="33" pageNumber="34">erratica</emphasis>
</taxonomicName>
. 
<taxonomicName authorityName="Barkalov &amp; Peck" authorityYear="1997" box="[1182,1399,578,604]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="33" pageNumber="34" phylum="Arthropoda" rank="species" species="erratica">
<emphasis box="[1182,1399,578,604]" italics="true" pageId="33" pageNumber="34">Cheilosia erratica</emphasis>
</taxonomicName>
differs by having tergite III entirely yellowish pilose, while 
<taxonomicName authorityName="Barkalov &amp; Cheng" authorityYear="1998" box="[889,1024,613,640]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="33" pageNumber="34" phylum="Arthropoda" rank="species" species="distincta">
<emphasis box="[889,1024,613,640]" italics="true" pageId="33" pageNumber="34">C. distincta</emphasis>
</taxonomicName>
has tergite III black pilose.
</paragraph>
