<subSubSection pageId="17" pageNumber="18" type="diagnosis">
<paragraph blockId="17.[189,454,404,430]" box="[189,454,404,430]" pageId="17" pageNumber="18">
<heading bold="true" box="[189,454,404,430]" fontSize="11" level="3" pageId="17" pageNumber="18" reason="3">
