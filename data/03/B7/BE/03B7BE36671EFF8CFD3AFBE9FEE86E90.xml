<paragraph blockId="108.[189,1398,1250,1312]" pageId="108" pageNumber="109">
For characters distinguishing 
<taxonomicName authority="Barkalov &amp; Ståhls, 2022" authorityName="Barkalov &amp; Ståhls" authorityYear="2022" box="[525,852,1250,1276]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="108" pageNumber="109" phylum="Arthropoda" rank="species" species="spuria" status="sp. nov." subGenus="Cheilosia">
