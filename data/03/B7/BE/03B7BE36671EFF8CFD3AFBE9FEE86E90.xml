<subSubSection pageId="108" pageNumber="109" type="etymology">
<paragraph blockId="108.[189,324,1352,1378]" box="[189,324,1352,1378]" pageId="108" pageNumber="109">
<heading bold="true" box="[189,324,1352,1378]" fontSize="11" level="3" pageId="108" pageNumber="109" reason="3">
<emphasis bold="true" box="[189,324,1352,1378]" pageId="108" pageNumber="109">Etymology</emphasis>
</heading>
</paragraph>
<paragraph blockId="108.[189,1398,1398,1460]" pageId="108" pageNumber="109">
‘ 
<taxonomicName authorityName="Kaup" authorityYear="1871" box="[199,289,1399,1425]" class="Insecta" family="Passalidae" genus="Spurius" kingdom="Animalia" order="Coleoptera" pageId="108" pageNumber="109" phylum="Arthropoda" rank="genus">
<emphasis box="[199,289,1399,1425]" italics="true" pageId="108" pageNumber="109">Spurius</emphasis>
</taxonomicName>
ʼ is a Latin praenomen (personal name), with feminine form ‘ 
<taxonomicName authorityName="Barkalov &amp; Ståhls" authorityYear="2022" box="[1006,1081,1399,1424]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="108" pageNumber="109" phylum="Arthropoda" rank="species" species="spuria">
<emphasis box="[1006,1081,1399,1424]" italics="true" pageId="108" pageNumber="109">spuria</emphasis>
</taxonomicName>
ʼ, used during the period of the Roman Republic.
</paragraph>
</subSubSection>
