<subSubSection pageId="26" pageNumber="27" type="diagnosis">
<paragraph blockId="26.[189,454,1403,1429]" box="[189,454,1403,1429]" pageId="26" pageNumber="27">
<heading bold="true" box="[189,454,1403,1429]" fontSize="11" level="3" pageId="26" pageNumber="27" reason="3">
