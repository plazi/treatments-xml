(
<emphasis box="[412,582,1893,1919]" italics="true" pageId="78" pageNumber="79">Taeniochilosia</emphasis>
) 
<emphasis box="[598,721,1893,1919]" italics="true" pageId="78" pageNumber="79">nepalensis</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[726,818,1893,1919]" pageId="78" pageNumber="79" rank="species">sp. nov.</taxonomicNameLabel>
;A, C, E–H = holotype, ♂ (CNC), B, D = paratype, ♀ (CNC). 
<emphasis bold="true" box="[321,342,1928,1954]" pageId="78" pageNumber="79">A</emphasis>
. Head, lateral view. 
<emphasis bold="true" box="[600,620,1928,1954]" pageId="78" pageNumber="79">B</emphasis>
. Head, dorsal view. 
<emphasis bold="true" box="[875,934,1928,1954]" pageId="78" pageNumber="79">C–D</emphasis>
