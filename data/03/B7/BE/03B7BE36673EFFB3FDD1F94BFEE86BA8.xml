<caption pageId="79" pageNumber="80" startId="79.[189,231,1890,1916]" targetBox="[189,1398,265,1852]" targetPageId="79">
<paragraph blockId="79.[189,1399,1890,1987]" pageId="79" pageNumber="80">
<emphasis bold="true" box="[189,278,1890,1916]" pageId="79" pageNumber="80">Fig. 44.</emphasis>
<taxonomicName authority="Barkalov &amp; Ståhls, 2022" authorityName="Barkalov &amp; Ståhls" authorityYear="2022" box="[284,716,1890,1916]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="79" pageNumber="80" phylum="Arthropoda" rank="species" species="nepalensis" status="sp. nov." subGenus="Taeniochilosia">
<emphasis box="[284,395,1890,1916]" italics="true" pageId="79" pageNumber="80">Cheilosia</emphasis>
(
<emphasis box="[410,579,1890,1916]" italics="true" pageId="79" pageNumber="80">Taeniochilosia</emphasis>
) 
<emphasis box="[594,716,1890,1916]" italics="true" pageId="79" pageNumber="80">nepalensis</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[722,809,1891,1917]" pageId="79" pageNumber="80" rank="species">sp. nov.</taxonomicNameLabel>
<emphasis bold="true" box="[813,868,1890,1916]" pageId="79" pageNumber="80">A–B</emphasis>
