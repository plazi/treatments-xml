<paragraph blockId="20.[187,1399,1926,2024]" pageId="20" pageNumber="21">
<taxonomicName authority="Barkalov &amp; Ståhls, 2022" authorityName="Barkalov &amp; Ståhls" authorityYear="2022" box="[189,531,1926,1952]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="20" pageNumber="21" phylum="Arthropoda" rank="species" species="angusta" status="sp. nov." subGenus="Cheilosia">
<emphasis box="[189,299,1926,1952]" italics="true" pageId="20" pageNumber="21">Cheilosia</emphasis>
(
<emphasis box="[314,424,1926,1952]" italics="true" pageId="20" pageNumber="21">Cheilosia</emphasis>
) 
<emphasis box="[440,531,1927,1952]" italics="true" pageId="20" pageNumber="21">angusta</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[537,624,1927,1953]" pageId="20" pageNumber="21" rank="species">sp. nov.</taxonomicNameLabel>
can be discerned from all other Nepalese 
<taxonomicName authorityName="Meigen" authorityYear="1822" box="[1094,1204,1926,1952]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="20" pageNumber="21" phylum="Arthropoda" rank="genus">
