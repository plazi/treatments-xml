<taxonomicName authority="Barkalov &amp; Ståhls, 2022" authorityName="Barkalov &amp; Ståhls" authorityYear="2022" box="[297,718,1892,1918]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="29" pageNumber="30" phylum="Arthropoda" rank="species" species="crassata" status="sp. nov." subGenus="Floccocheila">
