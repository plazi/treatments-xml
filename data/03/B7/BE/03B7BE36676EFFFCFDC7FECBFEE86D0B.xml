(
<emphasis box="[435,593,1892,1918]" italics="true" pageId="29" pageNumber="30">Floccocheila</emphasis>
) 
<emphasis box="[615,718,1893,1918]" italics="true" pageId="29" pageNumber="30">crassata</emphasis>
</taxonomicName>
