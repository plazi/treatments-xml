<taxonomicName authority="Barkalov &amp; Ståhls, 2022" authorityName="Barkalov &amp; Ståhls" authorityYear="2022" box="[365,742,1929,1955]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="116" pageNumber="117" phylum="Arthropoda" rank="species" species="vellea" status="sp. nov." subGenus="Floccocheila">
