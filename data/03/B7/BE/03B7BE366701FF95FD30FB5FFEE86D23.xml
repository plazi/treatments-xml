<taxonomicName authority="Barkalov &amp; Ståhls, 2022" authorityName="Barkalov &amp; Ståhls" authorityYear="2022" box="[351,535,1964,1990]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="116" pageNumber="117" phylum="Arthropoda" rank="species" species="versa" status="sp. nov.">
