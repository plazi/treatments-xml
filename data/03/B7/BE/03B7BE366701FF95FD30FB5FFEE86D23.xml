<caption ID-DOI="http://doi.org/10.5281/zenodo.6840118" ID-Zenodo-Dep="6840118" httpUri="https://zenodo.org/record/6840118/files/figure.png" pageId="116" pageNumber="117" startId="116.[189,232,1929,1955]" targetBox="[189,1398,424,1888]" targetPageId="116">
<paragraph blockId="116.[189,1399,1929,2026]" pageId="116" pageNumber="117">
<emphasis bold="true" box="[189,349,1929,1955]" pageId="116" pageNumber="117">Fig. 64. A–B</emphasis>
