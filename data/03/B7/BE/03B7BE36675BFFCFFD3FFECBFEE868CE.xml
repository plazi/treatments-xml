<emphasis box="[555,637,1861,1887]" italics="true" pageId="42" pageNumber="43">falcata</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[646,741,1862,1888]" pageId="42" pageNumber="43" rank="species">sp. nov.</taxonomicNameLabel>
