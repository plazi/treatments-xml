<paragraph blockId="13.[151,594,613,676]" box="[151,449,650,676]" pageId="13" pageNumber="414">
(
<figureCitation box="[159,352,650,676]" captionStart="FIGURE 8" captionStartId="14.[151,250,1693,1717]" captionTargetBox="[155,1424,509,1656]" captionTargetId="figure-190@14.[151,1435,489,1669]" captionTargetPageId="14" captionText="FIGURE 8. Protohelius japonicus sp. nov. (A–E, G–H) and P. tinkhami Alexander, 1938 (F, traced from the holotype slide): A, habitus (male); B, wing; C, male terminalia, dorsal view; D, sternite 9, ventral view; E, outer and inner gonostyli, outer surface; F, lobe of gonostylus; G, aedeagal complex, dorsal view; H, ibid, lateral view (left = dorsal). Scale bars: A–B, 2 mm; C–H, 0.1 mm (not given in F)." figureDoi="http://doi.org/10.5281/zenodo.6902808" httpUri="https://zenodo.org/record/6902808/files/figure.png" pageId="13" pageNumber="414">Figs 8A–E, G–H</figureCitation>
, 
<figureCitation box="[364,380,650,676]" captionStart="FIGURE 9" captionStartId="15.[151,250,1541,1565]" captionTargetBox="[155,1424,391,1513]" captionTargetId="figure-122@15.[154,1432,381,1517]" captionTargetPageId="15" captionText="FIGURE 9. Female terminalia of Protohelius japonicus sp. nov.: A, overall, lateral view; B, ibid, dorsal view; C, sternite 8 and hypogynial valve, ventral view; D, sternite 9, ventral view (left = anterior); E, sternite 10, ventral view (left = anterior). Scale bars: A–C, 0.3 mm; D–E, 0.1 mm." figureDoi="http://doi.org/10.5281/zenodo.6902812" httpUri="https://zenodo.org/record/6902812/files/figure.png" pageId="13" pageNumber="414">9</figureCitation>
, 
<figureCitation box="[392,441,650,676]" captionStart="FIGURE 10" captionStartId="16.[151,250,1156,1180]" captionTargetBox="[151,1434,181,1121]" captionTargetId="figure-36@16.[151,1435,181,1133]" captionTargetPageId="16" captionText="FIGURE 10. Distributions of species. A, Crypteria nippon sp. nov.; B, Dasymallomyia ditenostyla Alexander, 1964 (red), and D. tachii sp. nov. (orange); C, Eupilaria japonica sp. nov.; D, Protohelius japonicus sp. nov." figureDoi="http://doi.org/10.5281/zenodo.6902814" httpUri="https://zenodo.org/record/6902814/files/figure.png" pageId="13" pageNumber="414">10D</figureCitation>
