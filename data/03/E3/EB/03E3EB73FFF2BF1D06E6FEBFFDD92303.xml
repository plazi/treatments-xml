<paragraph blockId="20.[151,1436,475,1114]" pageId="20" pageNumber="471">
<emphasis bold="true" box="[199,435,583,609]" pageId="20" pageNumber="471">Material examined.</emphasis>
<specimenCount box="[444,616,583,610]" pageId="20" pageNumber="471" type="generic">152 specimens</specimenCount>
, maximum size of 
<quantity box="[837,940,583,610]" metricMagnitude="-2" metricUnit="m" metricValue="4.07" pageId="20" pageNumber="471" unit="mm" value="40.7">40.7 mm</quantity>
