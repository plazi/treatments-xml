<bibRefCitation author="Reyes-Gomez, A." box="[1048,1277,475,502]" pageId="20" pageNumber="471" pagination="1 - 150" refId="ref22739" refString="Reyes-Gomez, A. (2016) The Polyplacophora from the Mexican Pacific. Supplement to The Festivus, 48, 1 - 150." type="journal article" year="2016">Reyes-Gómez 2016</bibRefCitation>
