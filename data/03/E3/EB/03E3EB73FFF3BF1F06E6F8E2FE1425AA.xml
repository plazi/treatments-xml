<subSubSection pageId="21" pageNumber="472" type="distribution">
<paragraph blockId="21.[151,1436,1950,2013]" pageId="21" pageNumber="472">
<emphasis bold="true" box="[151,305,1950,1976]" pageId="21" pageNumber="472">Distribution.</emphasis>
Throughout the Mexican Tropical Pacific, 
<collectingCountry box="[778,867,1951,1977]" name="Mexico" pageId="21" pageNumber="472">México</collectingCountry>
. From 
<collectingRegion box="[941,1023,1951,1977]" country="Mexico" name="Sonora" pageId="21" pageNumber="472">Sonora</collectingRegion>
, 
<collectingCountry box="[1033,1119,1951,1977]" name="Mexico" pageId="21" pageNumber="472">México</collectingCountry>
to Salinas, 
<collectingCountry box="[1244,1337,1951,1977]" name="Ecuador" pageId="21" pageNumber="472">Ecuador</collectingCountry>
(
<bibRefCitation author="Watters, G. T." pageId="21" pageNumber="472" pagination="241 - 271" refId="ref23472" refString="Watters, G. T. (1990) A review of the Recent Eastern Pacific Acanthochitoninae (Mollusca: Polyplacophora: Criptoplacidae) with the description of a new genus Americhiton. The Veliger, 33 (3), 241 - 271." type="journal article" year="1990">Watters 1990</bibRefCitation>
).
</paragraph>
</subSubSection>
