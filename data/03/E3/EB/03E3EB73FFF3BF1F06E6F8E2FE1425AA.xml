Locality.
</emphasis>
<location LSID="urn:lsid:plazi:treatment:03E3EB73FFF3BF1F06E6F8E2FE1425AA:8E950CBEFFF0BF1F0706FF0EFE6B27A2" box="[375,482,222,248]" country="Mexico" name="Mazatlan" pageId="22" pageNumber="473" stateProvince="Sinaloa">Mazatlán</location>
, 
<collectingRegion box="[493,580,222,248]" country="Mexico" name="Sinaloa" pageId="22" pageNumber="473">Sinaloa</collectingRegion>
, 
<collectingCountry box="[591,680,222,248]" name="Mexico" pageId="22" pageNumber="473">México</collectingCountry>
</materialsCitation>
