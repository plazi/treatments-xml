<typeStatus box="[752,855,150,176]" pageId="22" pageNumber="473">lectotype</typeStatus>
by designation of 
<bibRefCitation author="Keen, M. A." box="[1075,1271,150,177]" pageId="22" pageNumber="473" refId="ref22051" refString="Keen, M. A. (1958) Sea Shells of Tropical West America, Marine Mollusks from Lower California to Colombia, Stanford University Press, Stanford, California, 624 pp." type="book" year="1958">Keen (1958:414)</bibRefCitation>
