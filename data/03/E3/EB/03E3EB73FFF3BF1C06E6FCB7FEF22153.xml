<paragraph blockId="21.[151,1437,978,1545]" pageId="21" pageNumber="472">
<emphasis bold="true" box="[199,433,1122,1148]" pageId="21" pageNumber="472">Material examined.</emphasis>
<specimenCount box="[440,596,1123,1149]" pageId="21" pageNumber="472" type="generic">40 specimens</specimenCount>
