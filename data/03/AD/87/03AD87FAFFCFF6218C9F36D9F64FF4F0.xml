<taxonomicName authorityName="E. H. Taylor" authorityYear="1934" box="[2189,2574,999,1028]" class="Mammalia" family="Pteropodidae" genus="Megaerops" kingdom="Animalia" order="Chiroptera" pageId="11" pageNumber="69" phylum="Chordata" rank="subSpecies" species="wetmorei" subSpecies="albicollis">Megaerops wetmorei albicollis</taxonomicName>
