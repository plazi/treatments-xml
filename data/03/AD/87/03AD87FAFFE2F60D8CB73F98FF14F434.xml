<paragraph blockId="38.[1446,2656,3078,3474]" pageId="38" pageNumber="96">
<subSubSection pageId="38" pageNumber="96" type="discussion">
<taxonomicName baseAuthorityName="Ogilby" baseAuthorityYear="1835" box="[1447,1766,3157,3190]" class="Mammalia" family="Pteropodidae" genus="Epomophorus" kingdom="Animalia" order="Chiroptera" pageId="38" pageNumber="96" phylum="Chordata" rank="species" species="gambianus">Epomophorus gambianus</taxonomicName>
