<subSubSection box="[1443,2384,1228,1261]" pageId="68" pageNumber="126" type="biology_ecology">
<paragraph blockId="68.[1441,2650,281,1580]" box="[1443,2384,1228,1261]" pageId="68" pageNumber="126">
<emphasis bold="true" box="[1443,2144,1228,1261]" pageId="68" pageNumber="126">Movements, Home range and Social organization.</emphasis>
