<subSubSection pageId="92" pageNumber="150" type="discussion">
<paragraph blockId="92.[2060,2654,868,1295]" pageId="92" pageNumber="150">
<taxonomicName authorityName="Felten &amp; Kock" authorityYear="1972" box="[2061,2293,947,980]" class="Mammalia" family="Pteropodidae" genus="Pteropus" kingdom="Animalia" order="Chiroptera" pageId="92" pageNumber="150" phylum="Chordata" rank="species" species="fundatus">Pteropus fundatus</taxonomicName>
