<taxonomicName box="[2423,2548,947,980]" class="Magnoliopsida" family="Sapindaceae" genus="Cupaniopsis" kingdom="Plantae" order="Sapindales" pageId="92" pageNumber="150" phylum="Tracheophyta" rank="species" species="samoensis">samoensis</taxonomicName>
