<subSubSection pageId="87" pageNumber="145" type="discussion">
<paragraph blockId="87.[724,1317,1300,1728]" pageId="87" pageNumber="145">
<taxonomicName authorityName="Gould" authorityYear="1850" box="[724,1005,1419,1452]" class="Mammalia" family="Pteropodidae" genus="Pteropus" kingdom="Animalia" order="Chiroptera" pageId="87" pageNumber="145" phylum="Chordata" rank="species" species="conspicillatus">Pteropus conspicillatus</taxonomicName>
