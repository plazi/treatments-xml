<subSubSection pageId="89" pageNumber="147" type="discussion">
<paragraph blockId="89.[721,1316,798,1217]" pageId="89" pageNumber="147">
<taxonomicName authorityName="Peters" authorityYear="1883" box="[723,953,910,943]" class="Mammalia" family="Pteropodidae" genus="Pteropus" kingdom="Animalia" order="Chiroptera" pageId="89" pageNumber="147" phylum="Chordata" rank="species" species="ualanus">Pteropus ualanus</taxonomicName>
is in the 
<taxonomicName box="[1115,1201,910,943]" class="Magnoliopsida" family="Moraceae" genus="Pleropus" kingdom="Plantae" order="Rosales" pageId="89" pageNumber="147" phylum="Tracheophyta" rank="species" species="griseus">griseus</taxonomicName>
species group. It is distinct from 
<taxonomicName authorityName="Desmarest" authorityYear="1822" box="[1113,1254,949,982]" class="Dothideomycetes" family="Pteropodidae" genus="Pteropus" kingdom="Fungi" order="Chiroptera" pageId="89" pageNumber="147" phylum="Ascomycota" rank="species" species="mariannus">mariannus</taxonomicName>
but closely related to 
<taxonomicName authorityName="Quoy &amp; Gaimard" authorityYear="1830" box="[995,1112,985,1018]" class="Dothideomycetes" family="Pteropodidae" genus="Pteropus" kingdom="Fungi" order="Chiroptera" pageId="89" pageNumber="147" phylum="Ascomycota" rank="species" species="tonganus">tonganus</taxonomicName>
and 
<taxonomicName authorityName="Thomas" authorityYear="1894" class="Dothideomycetes" family="Pteropodidae" genus="Pteropus" kingdom="Fungi" order="Chiroptera" pageId="89" pageNumber="147" phylum="Ascomycota" rank="species" species="admiralitatum">admiralitatum</taxonomicName>
. Monotypic.
</paragraph>
</subSubSection>
