<taxonomicName authorityName="Brisson" authorityYear="1762" box="[724,833,749,782]" class="Mammalia" family="Pteropodidae" genus="Pteropus" kingdom="Animalia" order="Chiroptera" pageId="75" pageNumber="133" phylum="Chordata" rank="genus">Pteropus</taxonomicName>
. Monotypic.
</subSubSection>
</paragraph>
<subSubSection pageId="75" pageNumber="133" type="distribution">
<caption inLine="true" pageId="75" pageNumber="133" targetBox="[793,797,2177,2202]" targetPageId="75">
