“Pelew Islands [= 
<collectingCountry box="[1110,1357,2336,2365]" name="Palau" pageId="88" pageNumber="146">Republic of Palau</collectingCountry>
],” western chain of the 
<collectingCountry box="[1094,1320,2376,2405]" name="Micronesia" pageId="88" pageNumber="146">Caroline Islands</collectingCountry>
