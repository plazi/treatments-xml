<taxonomicName box="[2463,2547,1700,1729]" class="Magnoliopsida" family="Moraceae" genus="Pleropus" kingdom="Plantae" order="Rosales" pageId="88" pageNumber="146" phylum="Tracheophyta" rank="species" species="griseus">griseus</taxonomicName>
