<subSubSection pageId="88" pageNumber="146" type="discussion">
<paragraph blockId="88.[2066,2661,1582,2005]" pageId="88" pageNumber="146">
<taxonomicName authorityName="Quoy &amp; Gaimard" authorityYear="1830" box="[2066,2304,1700,1729]" class="Mammalia" family="Pteropodidae" genus="Pteropus" kingdom="Animalia" order="Chiroptera" pageId="88" pageNumber="146" phylum="Chordata" rank="species" species="tonganus">Pteropus tonganus</taxonomicName>
