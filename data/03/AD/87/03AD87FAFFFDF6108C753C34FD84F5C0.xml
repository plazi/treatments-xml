<paragraph blockId="57.[1998,2593,2299,2728]" pageId="57" pageNumber="115">
<subSubSection pageId="57" pageNumber="115" type="reference_group">
<emphasis bold="true" box="[1999,2151,2299,2332]" pageId="57" pageNumber="115">Taxonomy</emphasis>
. 
<taxonomicName authority="Pollen" authorityName="Pollen" box="[2176,2544,2299,2332]" class="Mammalia" family="Pteropodidae" genus="Pteropus" kingdom="Animalia" order="Chiroptera" pageId="57" pageNumber="115" phylum="Chordata" rank="species" species="dupreanus">Pteropus dupreanus Pollen</taxonomicName>
in 
