(
<bibRefCitation author="Fall, H. C." box="[517,636,1440,1466]" pageId="2" pageNumber="592" pagination="161 - 170" refId="ref2511" refString="Fall, H. C. (1909) New Coleoptera from the South-west. - IV. The Canadian Entom ologist, 41 (5), 161 - 170. https: // doi. org / 10.4039 / Ent 41161 - 5" type="journal article" year="1909">Fall, 1909</bibRefCitation>
