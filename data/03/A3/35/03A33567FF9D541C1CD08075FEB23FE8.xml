</taxonomicName>
infested with 
<taxonomicName authorityName="Targioni" authorityYear="1893" box="[990,1107,151,177]" class="Insecta" family="Coccidae" genus="Gascardia" kingdom="Animalia" order="Hemiptera" pageId="33" pageNumber="34" phylum="Arthropoda" rank="genus">
