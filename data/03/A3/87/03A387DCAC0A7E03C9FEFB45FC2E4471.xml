<taxonomicName authority="Jouault &amp; Nel, 2021" authorityName="Jouault &amp; Nel" authorityYear="2021" box="[883,1286,775,801]" class="Insecta" family="Aulacidae" genus="Paleoaulacus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="1" pageNumber="270" phylum="Arthropoda" rank="genus">
