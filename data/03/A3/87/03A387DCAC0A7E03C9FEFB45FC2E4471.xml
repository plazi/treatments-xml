</taxonomicName>
and the Mesozoic 
<taxonomicName authority="Engel, 2017" authorityName="Engel" authorityYear="2017" class="Insecta" family="Aulacidae" genus="Electrofoenops" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="1" pageNumber="270" phylum="Arthropoda" rank="genus">
<emphasis box="[1203,1371,704,730]" italics="true" pageId="1" pageNumber="270">Electrofoenops</emphasis>
<bibRefCitation author="Engel, M. S." pageId="1" pageNumber="270" pagination="1 - 28" refId="ref2952" refString="Engel, M. S. (2017) New evanioid wasps from the Cenomanian of Myanmar (Hymenoptera: Othniodellithidae, Aulacidae), with a summary of family-group names among Evanioidea. American Museum Novitates, 3871, 1 - 28. https: // doi. org / 10.1206 / 3871.1" type="journal article" year="2017">Engel, 2017</bibRefCitation>
</taxonomicName>
, 
<taxonomicName authority="Cockerell, 1917" authorityName="Cockerell" authorityYear="1917" box="[877,1216,739,766]" class="Insecta" family="Aulacidae" genus="Electrofoenus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="1" pageNumber="270" phylum="Arthropoda" rank="genus">
<emphasis box="[877,1031,739,765]" italics="true" pageId="1" pageNumber="270">Electrofoenus</emphasis>
<bibRefCitation author="Cockerell, T. D. A." box="[1036,1216,739,766]" pageId="1" pageNumber="270" pagination="1 - 22" refId="ref2831" refString="Cockerell, T. D. A. (1917) Fossil insects. Annals of the Entomological Society of America, 10, 1 - 22. https: // doi. org / 10.1093 / aesa / 10.1.1" type="journal article" year="1917">Cockerell, 1917</bibRefCitation>
</taxonomicName>
, 
<taxonomicName authority="Li et al., 2018" authorityName="Li" authorityYear="2018" class="Insecta" family="Aulacidae" genus="Exilaulacus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="1" pageNumber="270" phylum="Arthropoda" rank="genus">
