. 
<collectingCountry box="[359,426,1720,1746]" name="Japan" pageId="17" pageNumber="18">Japan</collectingCountry>
, Sagami Sea, 
<specimenCount box="[583,661,1720,1747]" pageId="17" pageNumber="18" type="generic">
<quantity box="[583,657,1720,1747]" metricMagnitude="2" metricUnit="m" metricValue="5.64" pageId="17" pageNumber="18" unit="m" value="564.0">564 m</quantity>
