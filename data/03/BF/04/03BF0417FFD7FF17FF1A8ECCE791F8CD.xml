<bibRefCitation author="Stebbing, T. R. R." box="[255,403,579,603]" pageId="6" pageNumber="7" pagination="1 - 806" refId="ref50350" refString="Stebbing, T. R. R. (1906) Amphipoda I. Gammaridea. Das Tierreich, 21, 1 - 806." type="journal article" year="1906">Stebbing 1906</bibRefCitation>
