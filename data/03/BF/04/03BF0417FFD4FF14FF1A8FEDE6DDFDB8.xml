<taxonomicName authority="Stebbing, 1906" authorityName="Stebbing" authorityYear="1906" box="[151,466,223,249]" class="Malacostraca" family="Synopiidae" kingdom="Animalia" order="Amphipoda" pageId="5" pageNumber="2" phylum="Arthropoda" rank="subFamily" subFamily="Tironinae">
