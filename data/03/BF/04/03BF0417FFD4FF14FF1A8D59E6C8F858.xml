<keyLead box="[151,1436,1076,1098]" pageId="5" pageNumber="6">
- Telson entire................................................................ 
<taxonomicName authority="G. Karaman, 1986" authorityName="G. Karaman" authorityYear="1986" box="[1128,1436,1076,1098]" class="Malacostraca" family="Synopiidae" genus="Telsosynopia" kingdom="Animalia" order="Amphipoda" pageId="5" pageNumber="6" phylum="Arthropoda" rank="genus">
