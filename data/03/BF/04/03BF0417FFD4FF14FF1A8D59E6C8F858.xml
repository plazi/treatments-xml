<taxonomicName authorityName="J. L. Barnard" authorityYear="1972" box="[882,988,1487,1508]" class="Malacostraca" family="Synopiidae" genus="Ileraustroe" kingdom="Animalia" order="Amphipoda" pageId="5" pageNumber="6" phylum="Arthropoda" rank="genus">
