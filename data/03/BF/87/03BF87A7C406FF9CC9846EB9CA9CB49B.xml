<emphasis bold="true" box="[151,616,151,178]" pageId="5" pageNumber="410">
<emphasis bold="true" box="[151,434,151,178]" italics="true" pageId="5" pageNumber="410">Macropsidius kajkanus</emphasis>
<bibRefCitation author="Mityaev, I. D." box="[441,616,151,177]" pageId="5" pageNumber="410" pagination="5 - 20" refId="ref4762" refString="Mityaev, I. D. (1990) New Auchenorrhyncha from mountain landscapes of Kazakhstan. Trudy Instituta Zoologii Akademii Nauk Kazakhskoy SSR, 45, 5 - 20. [in Russian]" type="journal article" year="1990">Mityaev, 1990</bibRefCitation>
