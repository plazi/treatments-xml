<specimenCount box="[826,845,1529,1552]" pageId="6" pageNumber="67" type="female">♀</specimenCount>
, by subsequent designation of Ashmead 1903: 324 (junior subjective synonym of 
<taxonomicName authority="Villers, 1789" authorityName="Villers" authorityYear="1789" box="[435,710,1560,1584]" class="Insecta" family="Mutillidae" genus="Mutilla" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="6" pageNumber="67" phylum="Arthropoda" rank="species" species="calva">
<emphasis box="[435,571,1560,1584]" italics="true" pageId="6" pageNumber="67">Mutilla calva</emphasis>
<bibRefCitation author="Villers, C. de" box="[577,710,1560,1584]" pageId="6" pageNumber="67" pagination="7 - 10" refId="ref20582" refString="Villers, C. de (1789) Caroli Linnaei entomologia, faunae Suecicae descriptionibus aucta; etc. Tomus tertius. s. n., Lugduni [Lyon], xxiv + 657 pp., pls. 7 - 10." type="book chapter" year="1789">Villers, 1789</bibRefCitation>
</taxonomicName>
, 
<specimenCount box="[720,738,1560,1584]" pageId="6" pageNumber="67" type="female">♀</specimenCount>
