<taxonomicName authority="Lepeletier de Saint-Fargeau, 1845" authorityName="Lepeletier de Saint-Fargeau" authorityYear="1845" box="[294,815,1529,1553]" class="Insecta" family="Mutillidae" genus="Mutilla" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="6" pageNumber="67" phylum="Arthropoda" rank="species" species="distincta">
<emphasis box="[294,462,1529,1553]" italics="true" pageId="6" pageNumber="67">Mutilla distincta</emphasis>
<bibRefCitation author="Lepeletier de Saint-Fargeau, A." box="[469,815,1529,1553]" pageId="6" pageNumber="67" refId="ref18495" refString="Lepeletier de Saint-Fargeau, A. (1845) Histoire Naturelle des Insectes. Hymenopteres. Tome Troisieme. Roret, Paris, [4] + 646 pp." type="book" year="1845">Lepeletier de Saint-Fargeau, 1845</bibRefCitation>
</taxonomicName>
