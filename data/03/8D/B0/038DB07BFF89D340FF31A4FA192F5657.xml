<taxonomicName authority="Fabricius, 1787" authorityName="Fabricius" authorityYear="1787" box="[295,630,579,603]" class="Insecta" family="Mutillidae" genus="Mutilla" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="4" pageNumber="65" phylum="Arthropoda" rank="species" species="arenaria">
<emphasis box="[295,464,579,603]" italics="true" pageId="4" pageNumber="65">Mutilla arenaria</emphasis>
<bibRefCitation author="Fabricius, J. Ch." box="[470,630,579,603]" pageId="4" pageNumber="65" refId="ref16906" refString="Fabricius, J. Ch. (1787) Mantissa insectorum sistens eorum species nuper detecta, adjectis characteribus genericis, differentiis specificis, emendationibus, observationibus. Tome 1. Impensis C. G. Proft, Hafniae [Copenhagen], 348 pp. https: // doi. org / 10.5962 / bhl. title. 36471" type="book" year="1787">Fabricius, 1787</bibRefCitation>
</taxonomicName>
, 
<specimenCount box="[641,660,579,602]" pageId="4" pageNumber="65" type="female">♀</specimenCount>
, by subsequent designation of Ashmead 1904: 7 (junior subjective synonym of 
<taxonomicName authority="Linnaeus, 1767" authorityName="Linnaeus" authorityYear="1767" box="[227,487,609,633]" class="Insecta" family="Mutillidae" genus="Mutilla" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="4" pageNumber="65" phylum="Arthropoda" rank="species" species="atrata">
<emphasis box="[227,322,610,633]" italics="true" pageId="4" pageNumber="65">M. atrata</emphasis>
<bibRefCitation author="Linnaeus, C." box="[329,487,609,633]" pageId="4" pageNumber="65" pagination="533 - 1327" refId="ref18597" refString="Linnaeus, C. (1767) In: Systema Naturae per Regna Tria Naturae secundum Classes, Ordines, Genera, Species, cum Characteribus, Differentiis, Synonymis, Locis. Tomus I. Pars II. Editio Duodecima Reformata. Laurentii Salvii, Holmiae [Stockholm], pp. [2] + 533 - 1327 + [37]." type="journal article" year="1767">Linnaeus, 1767</bibRefCitation>
</taxonomicName>
