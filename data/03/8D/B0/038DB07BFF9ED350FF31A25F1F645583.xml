<emphasis bold="true" box="[282,426,1883,1910]" italics="true" pageId="19" pageNumber="80">Trogaspidia</emphasis>
<bibRefCitation author="Ashmead, W. H." box="[432,623,1883,1909]" pageId="19" pageNumber="80" pagination="45 - 60" refId="ref16303" refString="Ashmead, W. H. (1899) Superfamilies in the Hymenoptera and generic synopses of the families Thynnidae, Myrmosidae, and Mutillidae. Journal of the New York Entomological Society, 7, 45 - 60." type="journal article" year="1899">Ashmead, 1899</bibRefCitation>
