<taxonomicName authority="Lucas, 1849" authorityName="Lucas" authorityYear="1849" class="Insecta" family="Mutillidae" genus="Mutilla" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="11" pageNumber="72" phylum="Arthropoda" rank="species" species="rubrocincta">
<emphasis italics="true" pageId="11" pageNumber="72">Mutilla rubrocincta</emphasis>
<bibRefCitation author="Lucas, H." box="[267,394,393,417]" pageId="11" pageNumber="72" refId="ref18713" refString="Lucas, H. (1849) Exploration Scientifique de l'Algerie pendant des Annees 1840, 1841, 1842. Sciences Physiques, Zoologie. III. Histoire Naturelle des Animaux Articules, Troisieme Partie, Insectes &amp; Zoologie. IV. Histoire Naturelle des Animaux Articules, Atlas. Imprimerie Nationale, Paris, [6] + 527 pp. &amp; 122 pls." type="book" year="1849">Lucas, 1849</bibRefCitation>
