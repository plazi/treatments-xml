<taxonomicName authority="Schuster, 1949" authorityName="Schuster" authorityYear="1949" box="[297,685,363,387]" class="Insecta" family="Mutillidae" genus="Physetopoda" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="11" pageNumber="72" phylum="Arthropoda" rank="species" species="insularis">
<emphasis box="[297,524,363,387]" italics="true" pageId="11" pageNumber="72">Physetopoda insularis</emphasis>
<bibRefCitation author="Schuster, R. M." box="[532,685,363,387]" pageId="11" pageNumber="72" pagination="59 - 140" refId="ref20055" refString="Schuster, R. M. (1949) Contribution towards a monograph of the Mutillidae of the Neotropical region. III. A key to the subfamilies represented and descriptions of several new genera (Hymenoptera). Entomologica Americana, New Series, 29 (3 - 4), 59 - 140." type="journal article" year="1949">Schuster, 1949</bibRefCitation>
