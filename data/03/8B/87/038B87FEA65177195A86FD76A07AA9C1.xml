<subSubSection box="[151,444,654,681]" pageId="17" pageNumber="18" type="nomenclature">
<paragraph blockId="17.[151,444,654,717]" box="[151,444,654,681]" pageId="17" pageNumber="18">
<heading bold="true" box="[151,444,654,681]" fontSize="11" level="1" pageId="17" pageNumber="18" reason="1">
<emphasis bold="true" box="[151,444,654,681]" pageId="17" pageNumber="18">
<taxonomicName authority="Ulitzka, 2022" authorityName="Ulitzka" authorityYear="2022" box="[151,371,654,681]" class="Insecta" family="Rohrthripidae" genus="Rohrthrips" kingdom="Animalia" order="Thysanoptera" pageId="17" pageNumber="18" phylum="Arthropoda" rank="species" species="setiger" status="sp. n.">
