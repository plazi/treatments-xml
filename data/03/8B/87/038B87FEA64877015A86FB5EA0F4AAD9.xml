</taxonomicName>
<emphasis bold="true" box="[625,791,1864,1888]" pageId="9" pageNumber="10">
<taxonomicNameLabel box="[625,756,1864,1888]" pageId="9" pageNumber="10" rank="species">gen. et sp. n.</taxonomicNameLabel>
(8)
</emphasis>
holotype female, dorsal view, fore wings indicated; 
<emphasis bold="true" box="[1314,1344,1864,1888]" pageId="9" pageNumber="10">(9)</emphasis>
paratype female, indicated: fungal spores; 
<emphasis bold="true" box="[491,533,1900,1924]" pageId="9" pageNumber="10">(10)</emphasis>
