<taxonomicName authority="Ulitzka, 2022" authorityName="Ulitzka" authorityYear="2022" box="[604,933,1972,1996]" class="Insecta" family="Rohrthripidae" genus="Gemineurothrips" kingdom="Animalia" order="Thysanoptera" pageId="7" pageNumber="8" phylum="Arthropoda" rank="species" species="microcephalus" status="gen. et sp. n.">
