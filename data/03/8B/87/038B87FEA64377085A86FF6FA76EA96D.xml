<emphasis bold="true" box="[199,404,1663,1689]" pageId="3" pageNumber="4">Material studied.</emphasis>
<materialsCitation country="Myanmar" location="Hukawng Valley" pageId="3" pageNumber="4" specimenCount="2" stateProvince="Kachin" typeStatus="holotype">
<typeStatus box="[410,514,1663,1689]" pageId="3" pageNumber="4">Holotype</typeStatus>
female MU-Fos-134/1 (
