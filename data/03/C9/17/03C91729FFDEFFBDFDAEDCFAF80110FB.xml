<caption ID-DOI="http://doi.org/10.5281/zenodo.6621791" ID-Zenodo-Dep="6621791" httpUri="https://zenodo.org/record/6621791/files/figure.png" inLine="true" pageId="11" pageNumber="398" targetBox="[181,772,1051,1466]" targetPageId="11">
