<paragraph blockId="11.[136,1017,986,1013]" box="[136,1017,986,1013]" pageId="11" pageNumber="28">
<heading box="[136,1017,986,1013]" fontSize="11" level="2" pageId="11" pageNumber="28" reason="4">
13. 
<taxonomicName authority="H. S. Irwin &amp; Barneby (1982: 660)" authorityName="H. S. Irwin &amp; Barneby" authorityPageNumber="660" authorityYear="1982" box="[178,910,986,1013]" class="Magnoliopsida" family="Fabaceae" genus="Chamaecrista" kingdom="Plantae" order="Fabales" pageId="11" pageNumber="28" phylum="Tracheophyta" rank="species" species="zygophylloides">
<emphasis bold="true" box="[178,513,986,1013]" italics="true" pageId="11" pageNumber="28">Chamaecrista zygophylloides</emphasis>
H.S. Irwin &amp; Barneby (1982: 660)
</taxonomicName>
. (
<figureCitation box="[929,1009,986,1012]" captionStart="FIGURE 4" captionStartId="8.[136,229,1991,2013]" captionTargetBox="[166,1422,191,1966]" captionTargetId="figure-22@8.[165,1422,190,1966]" captionTargetPageId="8" captionText="FIGURE 4. Species of Fabaceae Lindl. of the study area, Pico do Jabre State Park, Paraíba, Brazil. a Chamaecrista nictitans. b Anadenanthera colubrina. c Chamaecrista zygophylloides. d Albizia polycephala. e Senna macranthera. f Mimosa invisa. g Senna rizzinii. h Calliandra subspicata. i Enterolobium contortisiliquum. j Senna martiana. (Source: the authors)." figureDoi="http://doi.org/10.5281/zenodo.6875649" httpUri="https://zenodo.org/record/6875649/files/figure.png" pageId="11" pageNumber="28">Fig. 4c</figureCitation>
)
</heading>
</paragraph>
</subSubSection>
<subSubSection pageId="11" pageNumber="28" type="description">
<paragraph blockId="11.[136,1452,1058,1625]" pageId="11" pageNumber="28">
<emphasis bold="true" box="[136,222,1058,1084]" pageId="11" pageNumber="28">Shrubs</emphasis>
, branches glabrous, inermous. 
<emphasis bold="true" box="[581,676,1058,1084]" pageId="11" pageNumber="28">Nectary</emphasis>
absent. 
<emphasis bold="true" box="[773,868,1058,1084]" pageId="11" pageNumber="28">Stipules</emphasis>
caducous. 
<emphasis bold="true" box="[998,1080,1058,1084]" pageId="11" pageNumber="28">Leaves</emphasis>
paripinnate, 4–foliolate, leaflets opposite, obovate, venation brochidodromous, translucid punctuation absent. 
<emphasis bold="true" box="[1072,1230,1094,1120]" pageId="11" pageNumber="28">Inflorescence</emphasis>
raceme, terminal. 
<emphasis bold="true" box="[136,231,1130,1156]" pageId="11" pageNumber="28">Flowers</emphasis>
pedicellate, asymmetric, diplostemonous; calyx dialysepalous, sepals 5, corolla dialypetalous, violet, petals 5; androecium dialystaminous, homodinamous, anthers longitudinal; ovary superior, sessile, pluriovulate. 
<emphasis bold="true" box="[1293,1355,1166,1192]" pageId="11" pageNumber="28">Fruit</emphasis>
legume, sessile, linear, plane, margin straight, epicarp glabrous, brown. 
<emphasis bold="true" box="[844,911,1202,1228]" pageId="11" pageNumber="28">Seeds</emphasis>
obovate, plane, coat black, hilum basal.
</paragraph>
</subSubSection>
