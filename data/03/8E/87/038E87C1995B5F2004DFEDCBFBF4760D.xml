<paragraph blockId="10.[136,1040,986,1013]" box="[136,1040,986,1013]" pageId="10" pageNumber="27">
<heading box="[136,1040,986,1013]" fontSize="11" level="2" pageId="10" pageNumber="27" reason="4">
