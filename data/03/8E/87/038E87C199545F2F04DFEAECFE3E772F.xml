<bibRefCitation author="Brenan, J. P. M." box="[684,907,1276,1303]" pageId="5" pageNumber="22" pagination="182" refId="ref14778" refString="Brenan, J. P. M. (1955) Anadenanthera colubrina (Vell.) Brenan. Kew Bulletin 10 (2): 182. https: // doi. org / 10.2307 / 4108864" type="journal article" year="1955">Brenan (1955: 182)</bibRefCitation>
