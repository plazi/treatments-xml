<subSubSection pageId="6" pageNumber="23" type="description">
<paragraph blockId="6.[136,1452,1418,1984]" pageId="6" pageNumber="23">
<emphasis bold="true" box="[136,200,1418,1444]" pageId="6" pageNumber="23">Trees</emphasis>
, branches tomentulous, inermous. 
<emphasis bold="true" box="[584,679,1418,1444]" pageId="6" pageNumber="23">Nectary</emphasis>
leaflet, sessile. 
<emphasis bold="true" box="[851,946,1418,1444]" pageId="6" pageNumber="23">Stipules</emphasis>
caducous. 
<emphasis bold="true" box="[1068,1150,1418,1444]" pageId="6" pageNumber="23">Leaves</emphasis>
imparipinnate, 1–foliolate, bilobed leaflets, venation actinodromous, translucid punctuation absent. 
<emphasis bold="true" box="[977,1135,1454,1480]" pageId="6" pageNumber="23">Inflorescence</emphasis>
raceme, terminal. 
<emphasis bold="true" box="[1356,1451,1454,1480]" pageId="6" pageNumber="23">Flowers</emphasis>
pedicellate, zygomorphic, diplostemonous; calyx dialysepalous, sepals 5, corolla dialypetalous, whitish, petals 5; androecium dialystaminous, homodinamous, anthers longitudinal; ovary superior, stipitate, pluriovulate. 
<emphasis bold="true" box="[1295,1357,1526,1552]" pageId="6" pageNumber="23">Fruit</emphasis>
legume, stipitate, linear, plane, margin straight, epicarp tomentose, brown. 
<emphasis bold="true" box="[878,945,1562,1588]" pageId="6" pageNumber="23">Seeds</emphasis>
oblong, plane, coat brown, hilum basal.
</paragraph>
</subSubSection>
