<subSubSection pageId="10" pageNumber="27" type="description">
<paragraph blockId="10.[136,1452,374,940]" pageId="10" pageNumber="27">
<emphasis bold="true" box="[136,202,374,400]" pageId="10" pageNumber="27">Vines</emphasis>
, branches glabrous, inermous. 
<emphasis bold="true" box="[584,679,374,400]" pageId="10" pageNumber="27">Nectary</emphasis>
absent. 
<emphasis bold="true" box="[788,883,374,400]" pageId="10" pageNumber="27">Stipules</emphasis>
lateral, triangular. 
<emphasis bold="true" box="[1120,1202,374,400]" pageId="10" pageNumber="27">Leaves</emphasis>
imparipinnate, 1–3– foliolate, opposite, sagittate, venation brochidodromous, translucid punctuation absent absent. 
<emphasis bold="true" box="[1198,1356,410,436]" pageId="10" pageNumber="27">Inflorescence</emphasis>
raceme, axillary. 
<emphasis bold="true" box="[238,333,446,472]" pageId="10" pageNumber="27">Flowers</emphasis>
pedicellate, zygomorphic, diplostemonous; calyx gamosepalous, sepals 5, corolla dialypetalous, papilionaceous, whitish, petals 5; androecium diadelphous, heterodinamous, anthers longitudinal; ovary superior, sessile, pluriovulate. 
<emphasis bold="true" box="[375,437,518,544]" pageId="10" pageNumber="27">Fruit</emphasis>
legume, sessile, linear, plane, margin straight, epicarp glabrous, whitish. 
<emphasis bold="true" box="[1271,1338,518,544]" pageId="10" pageNumber="27">Seeds</emphasis>
reniform, plane, coat marbled, hilum central.
</paragraph>
</subSubSection>
