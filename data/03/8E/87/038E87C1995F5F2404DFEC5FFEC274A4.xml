21. 
<taxonomicName authority="Martius ex Colla (1834: 255)" authorityName="Martius ex Colla" authorityPageNumber="255" authorityYear="1834" box="[178,683,590,617]" class="Magnoliopsida" family="Fabaceae" genus="Mimosa" kingdom="Plantae" order="Fabales" pageId="14" pageNumber="31" phylum="Tracheophyta" rank="species" species="invisa">
<emphasis bold="true" box="[178,346,590,616]" italics="true" pageId="14" pageNumber="31">Mimosa invisa</emphasis>
Martius ex Colla (1834: 255)
</taxonomicName>
. (
<figureCitation box="[703,780,590,616]" captionStart="FIGURE 4" captionStartId="8.[136,229,1991,2013]" captionTargetBox="[166,1422,191,1966]" captionTargetId="figure-22@8.[165,1422,190,1966]" captionTargetPageId="8" captionText="FIGURE 4. Species of Fabaceae Lindl. of the study area, Pico do Jabre State Park, Paraíba, Brazil. a Chamaecrista nictitans. b Anadenanthera colubrina. c Chamaecrista zygophylloides. d Albizia polycephala. e Senna macranthera. f Mimosa invisa. g Senna rizzinii. h Calliandra subspicata. i Enterolobium contortisiliquum. j Senna martiana. (Source: the authors)." figureDoi="http://doi.org/10.5281/zenodo.6875649" httpUri="https://zenodo.org/record/6875649/files/figure.png" pageId="14" pageNumber="31">Fig. 4f</figureCitation>
)
</heading>
</paragraph>
</subSubSection>
<subSubSection pageId="14" pageNumber="31" type="description">
<paragraph blockId="14.[136,1452,662,1264]" pageId="14" pageNumber="31">
<emphasis bold="true" box="[136,202,662,688]" pageId="14" pageNumber="31">Vines</emphasis>
, branches glabrous, aculeate. 
<emphasis bold="true" box="[534,629,662,688]" pageId="14" pageNumber="31">Nectary</emphasis>
absent. 
<emphasis bold="true" box="[719,814,662,688]" pageId="14" pageNumber="31">Stipules</emphasis>
lateral, narrow–triangular. Leaves bipinnate, paripinnate, 8–foliolate, leaflets opposite, oblong, venation actinodromous, translucid punctuation absent. 
<emphasis bold="true" box="[1217,1375,698,724]" pageId="14" pageNumber="31">Inflorescence</emphasis>
spike, axillary. 
<emphasis bold="true" box="[234,329,734,760]" pageId="14" pageNumber="31">Flowers</emphasis>
sessile, actinomorphic, isostemonous; calyx gamosepalous, sepals 4, corolla gamopetalous, tubular, rose, petals 4; androecium dialystaminous, homodinamous, anthers longitudinal; ovary superior, sessile, pluriovulate. 
<emphasis bold="true" box="[136,198,806,832]" pageId="14" pageNumber="31">Fruit</emphasis>
craspedium, sessile, linear, plane, margin straight, epicarp pilose, brown. 
<emphasis bold="true" box="[1056,1123,806,832]" pageId="14" pageNumber="31">Seeds</emphasis>
obovate, plane, coat brown, hilum basal.
</paragraph>
</subSubSection>
