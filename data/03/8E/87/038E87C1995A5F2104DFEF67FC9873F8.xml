<paragraph blockId="11.[136,925,374,401]" box="[136,925,374,401]" pageId="11" pageNumber="28">
<heading box="[136,925,374,401]" fontSize="11" level="2" pageId="11" pageNumber="28" reason="4">
12. 
<taxonomicName authority="(Persoon 1805: 456) Greene (1899: 31)" authorityName="Greene" authorityYear="1899" baseAuthorityName="Persoon" baseAuthorityYear="1805" box="[178,925,374,401]" class="Magnoliopsida" family="Fabaceae" genus="Chamaecrista" kingdom="Plantae" order="Fabales" pageId="11" pageNumber="28" phylum="Tracheophyta" rank="species" species="rotundifolia">
<emphasis bold="true" box="[178,483,374,401]" italics="true" pageId="11" pageNumber="28">Chamaecrista rotundifolia</emphasis>
(
<bibRefCitation author="Persoon, C. H." box="[498,712,374,401]" pageId="11" pageNumber="28" pagination="456" refId="ref18042" refString="Persoon, C. H. (1805) Cassia rotundifolia Pers. Synopsis Plantarum 1: 456." type="journal article" year="1805">Persoon 1805: 456</bibRefCitation>
) 
<bibRefCitation author="Greene, E. L." box="[726,925,374,400]" pageId="11" pageNumber="28" pagination="20" refId="ref16255" refString="Greene, E. L. (1899) Chamaecrista rotundifolia (Pers.) Greene. Pittonia 4 (20 D): 31." type="journal article" year="1899">Greene (1899:31)</bibRefCitation>
</taxonomicName>
</heading>
</paragraph>
</subSubSection>
<subSubSection pageId="11" pageNumber="28" type="description">
<paragraph blockId="11.[136,1452,446,940]" pageId="11" pageNumber="28">
<emphasis bold="true" box="[136,209,446,472]" pageId="11" pageNumber="28">Herbs</emphasis>
, branches pilose, inermous. 
<emphasis bold="true" box="[538,633,446,472]" pageId="11" pageNumber="28">Nectary</emphasis>
absent. 
<emphasis bold="true" box="[730,825,446,472]" pageId="11" pageNumber="28">Stipules</emphasis>
lateral stipules, ovate. Leaves paripinnate, 2–foliolate, leaflets opposite, obovate, venation actinodromous, translucid punctuation absent. 
<emphasis bold="true" box="[1089,1247,482,508]" pageId="11" pageNumber="28">Inflorescence</emphasis>
cymose, axillary. 
<emphasis bold="true" box="[136,231,518,544]" pageId="11" pageNumber="28">Flowers</emphasis>
pedicellate, asymmetric, diplostemonous; calyx dialysepalous, sepals 5, corolla dialypetalous, yellow, petals 5; androecium dialystaminous, homodinamous, anthers longitudinal; ovary superior, sessile, pluriovulate. 
<emphasis bold="true" box="[1293,1355,554,580]" pageId="11" pageNumber="28">Fruit</emphasis>
legume, sessile, linear, plane, margin straight, epicarp glabrous, brown. 
<emphasis bold="true" box="[844,911,590,616]" pageId="11" pageNumber="28">Seeds</emphasis>
trapezoid, plane, coat black, hilum basal.
</paragraph>
</subSubSection>
