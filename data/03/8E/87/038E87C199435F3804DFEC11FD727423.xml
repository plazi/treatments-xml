<taxonomicName authority="(Bentham 1870: 127 - 128) H. S. Irwin &amp; Barneby (1982: 465)" authorityName="H. S. Irwin &amp; Barneby" authorityPageNumber="465" authorityYear="1982" baseAuthorityName="Bentham" baseAuthorityPageNumber="127 - 128" baseAuthorityYear="1870" box="[178,1063,511,538]" class="Magnoliopsida" family="Fabaceae" genus="Senna" kingdom="Plantae" order="Fabales" pageId="18" pageNumber="35" phylum="Tracheophyta" rank="species" species="martiana">
<emphasis bold="true" box="[178,364,511,537]" italics="true" pageId="18" pageNumber="35">Senna martiana</emphasis>
(
<bibRefCitation author="Bentham, G." box="[378,659,511,538]" pageId="18" pageNumber="35" pagination="127 - 128" refId="ref14521" refString="Bentham, G. (1870) Cassia martiana Benth. Flora Brasiliensis 15 (2): 127 - 128." type="journal article" year="1870">Bentham 1870: 127–128</bibRefCitation>
) H.S. Irwin &amp; Barneby (1982: 465)
</taxonomicName>
. (
<figureCitation box="[1082,1157,511,537]" captionStart="FIGURE 4" captionStartId="8.[136,229,1991,2013]" captionTargetBox="[166,1422,191,1966]" captionTargetId="figure-22@8.[165,1422,190,1966]" captionTargetPageId="8" captionText="FIGURE 4. Species of Fabaceae Lindl. of the study area, Pico do Jabre State Park, Paraíba, Brazil. a Chamaecrista nictitans. b Anadenanthera colubrina. c Chamaecrista zygophylloides. d Albizia polycephala. e Senna macranthera. f Mimosa invisa. g Senna rizzinii. h Calliandra subspicata. i Enterolobium contortisiliquum. j Senna martiana. (Source: the authors)." figureDoi="http://doi.org/10.5281/zenodo.6875649" httpUri="https://zenodo.org/record/6875649/files/figure.png" pageId="18" pageNumber="35">Fig. 4j</figureCitation>
