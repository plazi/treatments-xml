<bibRefCitation author="Bentham, G." box="[695,905,475,502]" pageId="13" pageNumber="30" refId="ref14623" refString="Bentham, G. (1837) Centrosema brasilianum (L.) Benth. Commentationes de Leguminosarum Generibus 54." type="journal volume" year="1837">Bentham 1837: 68</bibRefCitation>
