<taxonomicName authority="Kirejtshuk" authorityName="Kirejtshuk &amp; Kovalev" authorityYear="2022" box="[309,574,355,382]" class="Insecta" family="Nitidulidae" genus="Adocimus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="20" pageNumber="21" phylum="Arthropoda" rank="subGenus" subGenus="Belonotus">
