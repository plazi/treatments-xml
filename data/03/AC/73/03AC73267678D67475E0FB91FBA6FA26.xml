<bibRefCitation author="Grouvelle, A." box="[339,577,1123,1149]" pageId="12" pageNumber="13" pagination="234 - 256" refId="ref105215" refString="Grouvelle, A. (1916) Descriptions des Clavicornes nouveaux de la Republique Argentine. Revista del Museo de La Plata, 23, 234 - 256." type="journal article" year="1916">Grouvelle, 1916: 236</bibRefCitation>
