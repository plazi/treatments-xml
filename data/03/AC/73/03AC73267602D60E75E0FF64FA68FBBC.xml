<emphasis box="[1240,1354,1093,1115]" italics="true" pageId="118" pageNumber="119">O. lobanovi</emphasis>
</taxonomicName>
<emphasis bold="true" box="[1360,1436,1094,1115]" pageId="118" pageNumber="119">
<taxonomicNameLabel box="[1360,1436,1094,1115]" pageId="118" pageNumber="119" rank="species">sp. nov.</taxonomicNameLabel>
