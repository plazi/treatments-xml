<taxonomicName authority="Kirejtshuk et Kovalev, 2016: 230" authorityName="Kirejtshuk et Kovalev" authorityYear="2016" box="[296,918,502,526]" class="Insecta" family="Nitidulidae" genus="Allenipeplus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="26" pageNumber="27" phylum="Arthropoda" rank="species" species="philippinensis">
