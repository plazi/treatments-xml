<taxonomicName authorityName="Kirejtshuk et Kovalev" authorityYear="2017" box="[639,767,403,428]" class="Insecta" family="Nitidulidae" genus="Brittonoma" kingdom="Animalia" order="Coleoptera" pageId="77" pageNumber="78" phylum="Arthropoda" rank="genus">
