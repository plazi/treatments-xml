<taxonomicName authority="(Kirejtshuk 2011)" authorityName="Kirejtshuk &amp; Kovalev" authorityYear="2022" baseAuthorityName="Kirejtshuk" baseAuthorityYear="2011" class="Insecta" family="Nitidulidae" genus="Brittonoma" kingdom="Animalia" order="Coleoptera" pageId="77" pageNumber="78" phylum="Arthropoda" rank="species" species="pygidiatum">
