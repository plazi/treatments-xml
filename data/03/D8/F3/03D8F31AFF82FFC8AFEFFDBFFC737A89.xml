<paragraph blockId="4.[151,758,532,559]" box="[151,758,532,559]" pageId="4" pageNumber="298">
<heading bold="true" box="[151,758,532,559]" fontSize="11" level="1" pageId="4" pageNumber="298" reason="1">
<emphasis bold="true" box="[151,758,532,559]" pageId="4" pageNumber="298">
Validity of 
<taxonomicName authority="Arrow, 1908" authorityName="Arrow" authorityYear="1908" box="[289,569,533,559]" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis bold="true" box="[289,408,533,559]" italics="true" pageId="4" pageNumber="298">Neoryctes</emphasis>
Arrow, 1908
</taxonomicName>
(Pentodontini)
</emphasis>
</heading>
</paragraph>
</subSubSection>
<subSubSection pageId="4" pageNumber="298" type="description">
<paragraph blockId="4.[151,1437,605,1280]" pageId="4" pageNumber="298">
<bibRefCitation author="Linell, M. L." box="[151,303,605,631]" pageId="4" pageNumber="298" pagination="249 - 268" refId="ref4097" refString="Linell, M. L. (1898) On the coleopterous insects of the Galapagos Islands. Proceedings of the United States National Museum, 21, 249 - 268. https: // doi. org / 10.5479 / si. 00963801.1143.249" type="journal article" year="1898">Linell (1898)</bibRefCitation>
established 
<taxonomicName authority="Linell, 1898" authorityName="Linell" authorityYear="1898" box="[449,750,605,631]" class="Insecta" family="Dynastidae" genus="Pseudoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[449,598,605,631]" italics="true" pageId="4" pageNumber="298">Pseudoryctes</emphasis>
<bibRefCitation author="Linell, M. L." box="[609,750,605,631]" pageId="4" pageNumber="298" pagination="249 - 268" refId="ref4097" refString="Linell, M. L. (1898) On the coleopterous insects of the Galapagos Islands. Proceedings of the United States National Museum, 21, 249 - 268. https: // doi. org / 10.5479 / si. 00963801.1143.249" type="journal article" year="1898">Linell, 1898</bibRefCitation>
</taxonomicName>
for 
<taxonomicName authority="Waterhouse, 1845" authorityName="Waterhouse" authorityYear="1845" box="[804,1282,605,632]" class="Insecta" family="Dynastidae" genus="Oryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="species" species="galapagoensis">
<emphasis box="[804,1064,605,631]" italics="true" pageId="4" pageNumber="298">Oryctes galapagoensis</emphasis>
Waterhouse, 1845
</taxonomicName>
, collected by Charles Darwin in the Galápagos Islands. However, this name was preoccupied by another dynastine genus, 
<taxonomicName authority="Sharp, 1873" authorityName="Sharp" authorityYear="1873" class="Insecta" family="Dynastidae" genus="Pseudoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis italics="true" pageId="4" pageNumber="298">Pseudoryctes</emphasis>
Sharp, 1873
</taxonomicName>
from 
<collectingCountry box="[460,566,677,703]" name="Australia" pageId="4" pageNumber="298">Australia</collectingCountry>
. Three replacement names have been proposed for Linell’s genus: 
<taxonomicName authority="Arrow, 1908" authorityName="Arrow" authorityYear="1908" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[1324,1436,678,703]" italics="true" pageId="4" pageNumber="298">Neoryctes</emphasis>
Arrow, 1908
</taxonomicName>
; 
<taxonomicName authority="Mutchler, 1925" authorityName="Mutchler" authorityYear="1925" box="[306,689,713,740]" class="Insecta" family="Dynastidae" genus="Parapseudoryctes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[306,508,713,739]" italics="true" pageId="4" pageNumber="298">Parapseudoryctes</emphasis>
Mutchler, 1925
</taxonomicName>
; and 
<taxonomicName authority="Prell, 1936" authorityName="Prell" authorityYear="1936" box="[748,1026,713,739]" class="Insecta" family="Dynastidae" genus="Neobothynus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[748,894,713,739]" italics="true" pageId="4" pageNumber="298">Neobothynus</emphasis>
<bibRefCitation author="Prell, H." box="[901,1026,713,739]" pageId="4" pageNumber="298" pagination="145 - 152" refId="ref4412" refString="Prell, H. (1936) Beitrage zur Kenntnis der Dynastinen. Uber die Homonymieverhaltnisse der Namen von Gattungen und Unter- gattungen. Entomologische Blatter, 32, 145 - 152." type="journal article" year="1936">Prell, 1936</bibRefCitation>
</taxonomicName>
. Both 
<taxonomicName authorityName="Mutchler" authorityYear="1925" box="[1098,1300,713,739]" class="Insecta" family="Dynastidae" genus="Parapseudoryctes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[1098,1300,713,739]" italics="true" pageId="4" pageNumber="298">Parapseudoryctes</emphasis>
</taxonomicName>
and 
<taxonomicName authorityName="Prell" authorityYear="1936" class="Insecta" family="Dynastidae" genus="Neobothynus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis italics="true" pageId="4" pageNumber="298">Neobothynus</emphasis>
</taxonomicName>
are valid, albeit perhaps unnecessary and not in common usage. 
<taxonomicName authorityName="Arrow" authorityYear="1908" box="[951,1063,750,775]" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[951,1063,750,775]" italics="true" pageId="4" pageNumber="298">Neoryctes</emphasis>
</taxonomicName>
is in common usage.
</paragraph>
<paragraph blockId="4.[151,1437,605,1280]" pageId="4" pageNumber="298">
<bibRefCitation author="Stirling, E. C." box="[199,364,785,811]" pageId="4" pageNumber="298" pagination="154 - 187" refId="ref4552" refString="Stirling, E. C. (1891) Description of a new genus and species of Marsupiala, &quot; Notoryctes typhlops &quot;. Transactions of the Royal Society of South Australia, 14, 154 - 187." type="journal article" year="1891">Stirling (1891)</bibRefCitation>
proposed the replacement name 
<taxonomicName authorityName="Stirling" authorityYear="1891" box="[734,855,786,811]" class="Mammalia" family="Notoryctidae" genus="Notoryctes" kingdom="Animalia" order="Notoryctemorphia" pageId="4" pageNumber="298" phylum="Chordata" rank="genus">
<emphasis box="[734,855,786,811]" italics="true" pageId="4" pageNumber="298">Notoryctes</emphasis>
</taxonomicName>
for 
<taxonomicName authority="Stirling, 1889" authorityName="Stirling" authorityYear="1889" box="[902,1229,785,811]" class="Mammalia" family="Notoryctidae" genus="Psammoryctes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Notoryctemorphia" pageId="4" pageNumber="298" phylum="Chordata" rank="genus">
<emphasis box="[902,1065,786,811]" italics="true" pageId="4" pageNumber="298">Psammoryctes</emphasis>
Stirling, 1889
</taxonomicName>
, the genus of Australian marsupial moles (
<taxonomicName authorityName="Linnaeus" authorityYear="1758" box="[434,561,821,847]" class="Mammalia" kingdom="Animalia" pageId="4" pageNumber="298" phylum="Chordata" rank="class">Mammalia</taxonomicName>
: 
<taxonomicName authorityName="Ogilby" authorityYear="1892" box="[574,726,821,847]" class="Mammalia" family="Notoryctidae" kingdom="Animalia" order="Notoryctemorphia" pageId="4" pageNumber="298" phylum="Chordata" rank="family">Notoryctidae</taxonomicName>
). However, he included the statement “Professor Newton suggested 
<taxonomicName authorityName="Stirling" authorityYear="1891" box="[232,353,858,883]" class="Mammalia" family="Notoryctidae" genus="Notoryctes" kingdom="Animalia" order="Notoryctemorphia" pageId="4" pageNumber="298" phylum="Chordata" rank="genus">
<emphasis box="[232,353,858,883]" italics="true" pageId="4" pageNumber="298">Notoryctes</emphasis>
</taxonomicName>
as being appropriate, in view of its Australian habitat, and this name is, I think, preferable to 
<taxonomicName authorityName="Arrow" authorityYear="1908" box="[151,263,894,919]" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[151,263,894,919]" italics="true" pageId="4" pageNumber="298">Neoryctes</emphasis>
</taxonomicName>
, which had been previously proposed by Dr. Sclater”. This appears to be the first published reference to Sclater’s proposed name, 
<bibRefCitation author="Sclater, P. L." box="[440,600,929,955]" pageId="4" pageNumber="298" pagination="645" refId="ref4484" refString="Sclater, P. L. (1890) The new Australian mammal. Nature, 42, 645. https: // doi. org / 10.1038 / 042645 b 0" type="journal article" year="1890">Sclater (1890)</bibRefCitation>
having published a note on the species but not naming it and later (
<bibRefCitation author="Sclater, P. L." pageId="4" pageNumber="298" pagination="449" refId="ref4516" refString="Sclater, P. L. (1891) The new Australian marsupial mole - Notoryctes typhlops. Nature, 44, 449. https: // doi. org / 10.1038 / 044449 a 0" type="journal article" year="1891">Sclater 1891</bibRefCitation>
) using 
<taxonomicName authority="Stirling, 1891" authorityName="Stirling" authorityYear="1891" box="[291,577,965,991]" class="Mammalia" family="Notoryctidae" genus="Notoryctes" kingdom="Animalia" order="Notoryctemorphia" pageId="4" pageNumber="298" phylum="Chordata" rank="genus">
<emphasis box="[291,412,966,991]" italics="true" pageId="4" pageNumber="298">Notoryctes</emphasis>
<bibRefCitation author="Stirling, E. C." box="[419,577,965,991]" pageId="4" pageNumber="298" pagination="154 - 187" refId="ref4552" refString="Stirling, E. C. (1891) Description of a new genus and species of Marsupiala, &quot; Notoryctes typhlops &quot;. Transactions of the Royal Society of South Australia, 14, 154 - 187." type="journal article" year="1891">Stirling, 1891</bibRefCitation>
</taxonomicName>
.
</paragraph>
<paragraph blockId="4.[151,1437,605,1280]" pageId="4" pageNumber="298">
However, “ 
<taxonomicName authority="Sclater" authorityName="Sclater" authorityYear="1891" box="[328,525,1001,1027]" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[328,440,1002,1027]" italics="true" pageId="4" pageNumber="298">Neoryctes</emphasis>
Sclater
</taxonomicName>
in 
<bibRefCitation author="Stirling, E. C." box="[562,719,1001,1027]" pageId="4" pageNumber="298" pagination="154 - 187" refId="ref4552" refString="Stirling, E. C. (1891) Description of a new genus and species of Marsupiala, &quot; Notoryctes typhlops &quot;. Transactions of the Royal Society of South Australia, 14, 154 - 187." type="journal article" year="1891">Stirling, 1891</bibRefCitation>
” is not an available name since it was not valid when proposed (Article 11.5 of the 
<emphasis box="[373,432,1037,1063]" italics="true" pageId="4" pageNumber="298">Code</emphasis>
), and, therefore, not a homonym of 
<taxonomicName authority="Arrow, 1908" authorityName="Arrow" authorityYear="1908" box="[839,1101,1037,1063]" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[839,951,1038,1063]" italics="true" pageId="4" pageNumber="298">Neoryctes</emphasis>
Arrow, 1908
</taxonomicName>
. Consequently, 
<taxonomicName authority="Arrow, 1908" authorityName="Arrow" authorityYear="1908" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[1279,1391,1038,1063]" italics="true" pageId="4" pageNumber="298">Neoryctes</emphasis>
Arrow, 1908
</taxonomicName>
remains the valid name for the dynastine genus, and 
<taxonomicName authority="Stirling" authorityName="Stirling" authorityYear="1891" box="[870,1084,1073,1099]" class="Mammalia" family="Notoryctidae" genus="Notoryctes" kingdom="Animalia" order="Notoryctemorphia" pageId="4" pageNumber="298" phylum="Chordata" rank="genus">
<emphasis box="[870,991,1074,1099]" italics="true" pageId="4" pageNumber="298">Notoryctes</emphasis>
Stirling
</taxonomicName>
and 
<taxonomicName authorityName="Ogilby" authorityYear="1892" box="[1140,1286,1073,1099]" class="Mammalia" family="Notoryctidae" kingdom="Animalia" order="Notoryctemorphia" pageId="4" pageNumber="298" phylum="Chordata" rank="family">Notoryctidae</taxonomicName>
remain valid names for the marsupial moles. 
<taxonomicName authority="Tong, 1997" authorityName="Tong" authorityYear="1997" box="[505,750,1109,1135]" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[505,617,1110,1135]" italics="true" pageId="4" pageNumber="298">Neoryctes</emphasis>
Tong, 1997
</taxonomicName>
(
<taxonomicName authorityName="Linnaeus" authorityYear="1758" box="[764,891,1109,1135]" class="Mammalia" kingdom="Animalia" pageId="4" pageNumber="298" phylum="Chordata" rank="class">Mammalia</taxonomicName>
: 
<taxonomicName authorityName="Winge" authorityYear="1917" box="[901,1068,1109,1135]" class="Insecta" family="Palaeoryctidae" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="family">Palaeoryctidae</taxonomicName>
) was replaced by 
<taxonomicName authority="Tong, 2003" authorityName="Tong" authorityYear="2003" class="Mammalia" family="Palaeoryctidae" genus="Nuryctes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cimolesta" pageId="4" pageNumber="298" phylum="Chordata" rank="genus">
<emphasis box="[1266,1366,1110,1135]" italics="true" pageId="4" pageNumber="298">Nuryctes</emphasis>
Tong, 2003
</taxonomicName>
.
</paragraph>
<paragraph blockId="4.[151,1437,605,1280]" pageId="4" pageNumber="298">
Five valid species are known in 
<taxonomicName authority="Arrow, 1908" authorityName="Arrow" authorityYear="1908" box="[572,841,1181,1207]" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="genus">
<emphasis box="[572,684,1182,1207]" italics="true" pageId="4" pageNumber="298">Neoryctes</emphasis>
Arrow, 1908
</taxonomicName>
: 
<taxonomicName authority="(Waterhouse, 1845)" baseAuthorityName="Waterhouse" baseAuthorityYear="1845" box="[853,1367,1181,1208]" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="species" species="galapagoensis">
<emphasis box="[853,1136,1181,1207]" italics="true" pageId="4" pageNumber="298">Neoryctes galapagoensis</emphasis>
(Waterhouse, 1845)
</taxonomicName>
(= 
<taxonomicName authority="Arrow, 1908" authorityName="Arrow" authorityYear="1908" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="species" species="patagonicus">
<emphasis italics="true" pageId="4" pageNumber="298">N. patagonicus</emphasis>
Arrow, 1908
</taxonomicName>
), 
<taxonomicName authority="(Mutchler, 1938)" baseAuthorityName="Mutchler" baseAuthorityYear="1938" box="[462,759,1217,1243]" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="species" species="linelli">
<emphasis box="[462,560,1217,1243]" italics="true" pageId="4" pageNumber="298">N. linelli</emphasis>
(Mutchler, 1938)
</taxonomicName>
, 
<taxonomicName authority="Dechambre, 1991" authorityName="Dechambre" authorityYear="1991" box="[774,1175,1217,1243]" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="species" species="moreti">
<emphasis box="[774,965,1218,1243]" italics="true" pageId="4" pageNumber="298">Neoryctes moreti</emphasis>
Dechambre, 1991
</taxonomicName>
, 
<taxonomicName authority="Ratcliffe, 2014" authorityName="Ratcliffe" authorityYear="2014" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="species" species="similis">
<emphasis box="[1188,1380,1217,1243]" italics="true" pageId="4" pageNumber="298">Neoryctes similis</emphasis>
Ratcliffe, 2014
</taxonomicName>
, and 
<taxonomicName authority="Cook, Howden, &amp; Peck, 1995" authorityName="Cook, Howden, &amp; Peck" authorityYear="1995" box="[341,907,1253,1280]" class="Insecta" family="Dynastidae" genus="Neoryctes" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="298" phylum="Arthropoda" rank="species" species="williamsi">
<emphasis box="[341,563,1253,1279]" italics="true" pageId="4" pageNumber="298">Neoryctes williamsi</emphasis>
Cook, Howden, &amp; Peck, 1995
</taxonomicName>
(
<figureCitation box="[922,989,1253,1279]" captionStart="FIGURES 3–4" captionStartId="3.[151,264,1508,1532]" captionTargetBox="[151,1421,426,1485]" captionTargetId="figure-90@3.[151,1436,426,1485]" captionTargetPageId="3" captionText="FIGURES 3–4. Dorsal view of males. 3, Kirprellius syrichtus (Fabricius, 1775), new combination (image by Johan Pretorius, https://inaturalist.ca/photos/15855083, Creative Commons). 4, Neoryctes williamsi Cook, Howden, &amp; Peck, 1995, paratype (image by Alain Galant)." figureDoi="http://doi.org/10.5281/zenodo.6831919" httpUri="https://zenodo.org/record/6831919/files/figure.png" pageId="4" pageNumber="298">Fig. 4</figureCitation>
).
</paragraph>
</subSubSection>
