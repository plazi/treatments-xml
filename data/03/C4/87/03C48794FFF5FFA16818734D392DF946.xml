(
<figureCitation box="[516,624,604,630]" captionStart="Figure 1" captionStartId="3.[160,225,1708,1731]" captionTargetBox="[164,1152,143,1690]" captionTargetId="figure-1@3.[163,1153,142,1691]" captionTargetPageId="3" captionText="Figure 1. Dorylaimoides teres Thorne and Swanger, 1936 (LM photographs). (a, b) Anterior region; (c) anterior region showing amphid; (d) pharyngeal region;(e) pharyngeal expansion;(f) expanded part of pharynx; (g, h) female genital system; (i) vulval region; (j) female posterior region; (k) female posterior end; (l, m) male posterior end. Scale bars: a–c, e, f, i, k–m = 10 μm; d, g, h, j = 20 μm." figureDoi="http://doi.org/10.5281/zenodo.6758372" httpUri="https://zenodo.org/record/6758372/files/figure.png" pageId="2" pageNumber="313">Figures 1</figureCitation>
and 
<figureCitation box="[685,699,604,630]" captionStart="Figure 2" captionStartId="4.[160,225,1647,1670]" captionTargetBox="[164,1152,143,1629]" captionTargetId="figure-1@4.[163,1153,142,1630]" captionTargetPageId="4" captionText="Figure 2. Dorylaimoides teres Thorne and Swanger, 1936 (SEM photographs). (a, b) en face view showing labial papillae and amphid aperture; (c) vulval region; (d) male posterior region (arrows showing ventromedian supplements, adcloacal pair and cloacal aperture); (e) female posterior end, with arrow showing anal opening. Scale bars: a, b = 2 μm; c–e = 10 μm." figureDoi="http://doi.org/10.5281/zenodo.6758374" httpUri="https://zenodo.org/record/6758374/files/figure.png" pageId="2" pageNumber="313">2</figureCitation>
; 
<tableCitation box="[713,798,604,630]" captionStart="Table 1" captionStartId="5.[160,216,142,165]" captionTargetPageId="5" captionText="Table 1. Morphometrics of Dorylaimoides teres Thorne and Swanger, 1936. All measurements are in μm and in the form mean ± standard deviation (range)." httpUri="http://table.plazi.org/id/DF12660AFFF2FFA269D171F93AFAFDF6" pageId="2" pageNumber="313" tableUuid="DF12660AFFF2FFA269D171F93AFAFDF6">Table 1</tableCitation>
