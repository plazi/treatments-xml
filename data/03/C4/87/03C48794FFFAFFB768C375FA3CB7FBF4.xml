(
<figureCitation box="[559,656,1199,1225]" captionStart="Figure 5" captionStartId="14.[160,225,1647,1670]" captionTargetBox="[164,1152,143,1629]" captionTargetId="figure-1@14.[163,1153,142,1630]" captionTargetPageId="14" captionText="Figure 5. Dorylaimoides leptura Siddiqi, 1965 (LM photographs). (a, b) Anterior region; (c) anterior region showing amphid; (d) pharyngeal region; (e) expanded part of pharynx; (f, g) female genital system; (h) vulval region; (i) female posterior region; (j) male posterior region; (k) male posterior region showing spicules. Scale bars: a–c, e–h, k = 10 μm; d, i, j = 20 μm." figureDoi="http://doi.org/10.5281/zenodo.6758384" httpUri="https://zenodo.org/record/6758384/files/figure.png" pageId="13" pageNumber="324">Figure 5</figureCitation>
; 
<tableCitation box="[670,755,1199,1225]" captionStart="Table 4" captionStartId="15.[160,216,142,165]" captionTargetPageId="15" captionText="Table 4. Morphometrics of Dorylaimoides leptura Siddiqi, 1965. All measurements in μm." httpUri="http://table.plazi.org/id/DF12660AFFF8FFA869D171F93C38FD91" pageId="13" pageNumber="324" tableUuid="DF12660AFFF8FFA869D171F93C38FD91">Table 4</tableCitation>
