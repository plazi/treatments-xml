, 
<tableCitation box="[670,755,177,203]" captionStart="Table 5" captionStartId="19.[133,189,463,486]" captionTargetPageId="19" captionText="Table 5. Morphometrics of Dorylaimoides malabaricus Ahmad and Jairajpuri, 1982. All measurements are in μm and in the form mean ± standard deviation (range)." httpUri="http://table.plazi.org/id/DF12660AFFE4FFB469F470B83E84FCD2" pageId="17" pageNumber="328" tableUuid="DF12660AFFE4FFB469F470B83E84FCD2">Table 5</tableCitation>
