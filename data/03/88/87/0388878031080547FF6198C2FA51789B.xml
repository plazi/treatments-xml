<subSubSection pageId="1" pageNumber="528" type="diagnosis">
<paragraph blockId="1.[151,1436,824,1030]" pageId="1" pageNumber="528">
<emphasis bold="true" box="[151,274,824,850]" pageId="1" pageNumber="528">Diagnosis.</emphasis>
Head transverse (
<figureCitation box="[483,579,824,851]" captionStart="FIGURE 2" captionStartId="3.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@3.[179,1407,181,1919]" captionTargetPageId="3" captionText="FIGURE 2. Chelonus (Arichelonus) allokotosus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854030" httpUri="https://zenodo.org/record/6854030/files/figure.png" pageId="1" pageNumber="528">Figs 2H</figureCitation>
, 
<figureCitation box="[593,632,825,851]" captionStart="FIGURE 4" captionStartId="5.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@5.[179,1407,181,1919]" captionTargetPageId="5" captionText="FIGURE 4. Chelonus (Arichelonus) kenosetrus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854036" httpUri="https://zenodo.org/record/6854036/files/figure.png" pageId="1" pageNumber="528">4G</figureCitation>
); antenna slender, filiform (
<figureCitation box="[952,1037,824,851]" captionStart="FIGURE 2" captionStartId="3.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@3.[179,1407,181,1919]" captionTargetPageId="3" captionText="FIGURE 2. Chelonus (Arichelonus) allokotosus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854030" httpUri="https://zenodo.org/record/6854030/files/figure.png" pageId="1" pageNumber="528">Figs 2I</figureCitation>
, 
<figureCitation box="[1052,1078,825,851]" captionStart="FIGURE 4" captionStartId="5.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@5.[179,1407,181,1919]" captionTargetPageId="5" captionText="FIGURE 4. Chelonus (Arichelonus) kenosetrus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854036" httpUri="https://zenodo.org/record/6854036/files/figure.png" pageId="1" pageNumber="528">4I</figureCitation>
); face and vertex behind ocelli smooth to densely granulate, clypeus flat and densely punctate (
<figureCitation box="[854,946,860,887]" captionStart="FIGURE 2" captionStartId="3.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@3.[179,1407,181,1919]" captionTargetPageId="3" captionText="FIGURE 2. Chelonus (Arichelonus) allokotosus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854030" httpUri="https://zenodo.org/record/6854030/files/figure.png" pageId="1" pageNumber="528">Figs 2G</figureCitation>
, 
<figureCitation box="[957,990,861,887]" captionStart="FIGURE 4" captionStartId="5.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@5.[179,1407,181,1919]" captionTargetPageId="5" captionText="FIGURE 4. Chelonus (Arichelonus) kenosetrus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854036" httpUri="https://zenodo.org/record/6854036/files/figure.png" pageId="1" pageNumber="528">4F</figureCitation>
); eyes setose (
<figureCitation box="[1146,1229,860,887]" captionStart="FIGURE 2" captionStartId="3.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@3.[179,1407,181,1919]" captionTargetPageId="3" captionText="FIGURE 2. Chelonus (Arichelonus) allokotosus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854030" httpUri="https://zenodo.org/record/6854030/files/figure.png" pageId="1" pageNumber="528">Figs 2J</figureCitation>
, 
<figureCitation box="[1239,1278,861,887]" captionStart="FIGURE 4" captionStartId="5.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@5.[179,1407,181,1919]" captionTargetPageId="5" captionText="FIGURE 4. Chelonus (Arichelonus) kenosetrus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854036" httpUri="https://zenodo.org/record/6854036/files/figure.png" pageId="1" pageNumber="528">4H</figureCitation>
); mesoscutum evenly convex, transverse suture distinct; scutellar suture comparatively deep; propodeum coarsely reticulate-rugose with transversal carina (
<figureCitation box="[478,569,932,959]" captionStart="FIGURE 2" captionStartId="3.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@3.[179,1407,181,1919]" captionTargetPageId="3" captionText="FIGURE 2. Chelonus (Arichelonus) allokotosus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854030" httpUri="https://zenodo.org/record/6854030/files/figure.png" pageId="1" pageNumber="528">Figs 2C</figureCitation>
, 
<figureCitation box="[581,618,933,959]" captionStart="FIGURE 4" captionStartId="5.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@5.[179,1407,181,1919]" captionTargetPageId="5" captionText="FIGURE 4. Chelonus (Arichelonus) kenosetrus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854036" httpUri="https://zenodo.org/record/6854036/files/figure.png" pageId="1" pageNumber="528">4C</figureCitation>
); metasomal carapace with the straight elongate apex (
<figureCitation box="[1230,1323,932,959]" captionStart="FIGURE 2" captionStartId="3.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@3.[179,1407,181,1919]" captionTargetPageId="3" captionText="FIGURE 2. Chelonus (Arichelonus) allokotosus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854030" httpUri="https://zenodo.org/record/6854030/files/figure.png" pageId="1" pageNumber="528">Figs 2D</figureCitation>
, 
<figureCitation box="[1335,1373,933,959]" captionStart="FIGURE 4" captionStartId="5.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-18@5.[179,1407,181,1919]" captionTargetPageId="5" captionText="FIGURE 4. Chelonus (Arichelonus) kenosetrus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, dorsal aspect; E, metasoma, lateral aspect; F, head, anterior aspect; G, head, dorsal aspect; H, head, lateral aspect; I, antenna." figureDoi="http://doi.org/10.5281/zenodo.6854036" httpUri="https://zenodo.org/record/6854036/files/figure.png" pageId="1" pageNumber="528">4D</figureCitation>
).
</paragraph>
