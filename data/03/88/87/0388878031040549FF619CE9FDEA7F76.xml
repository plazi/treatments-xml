<subSubSection pageId="15" pageNumber="542" type="diagnosis">
<paragraph blockId="15.[151,1436,150,536]" pageId="15" pageNumber="542">
<emphasis bold="true" box="[151,274,150,176]" pageId="15" pageNumber="542">Diagnosis.</emphasis>
Head triangular in anterior view (
<figureCitation box="[672,775,150,176]" captionStart="FIGURE 14" captionStartId="16.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@16.[179,1407,181,1919]" captionTargetPageId="16" captionText="FIGURE 14. Chelonus (Scabrichelonus) nigrifemoratus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, hind leg; F, head, anterior aspect; G, head, dorsal aspect; H, metasoma, dorsal aspect; I, head, lateral aspect." figureDoi="http://doi.org/10.5281/zenodo.6854058" httpUri="https://zenodo.org/record/6854058/files/figure.png" pageId="15" pageNumber="542">Figs 14F</figureCitation>
, 
<figureCitation box="[789,841,150,176]" captionStart="FIGURE 16" captionStartId="18.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@18.[179,1407,181,1919]" captionTargetPageId="18" captionText="FIGURE 16. Chelonus (Scabrichelonus) nigrifemoratus sp. nov., male, paratypes. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, metasoma, dorsal aspect; F, hind leg; G, head, anterior aspect; H, head, dorsal aspect; I, head, lateral aspect; J, antenna; K, metasoma, posterior aspect." figureDoi="http://doi.org/10.5281/zenodo.6854062" httpUri="https://zenodo.org/record/6854062/files/figure.png" pageId="15" pageNumber="542">16G</figureCitation>
), trapezoid in dorsal view (
<figureCitation box="[1160,1270,150,176]" captionStart="FIGURE 14" captionStartId="16.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@16.[179,1407,181,1919]" captionTargetPageId="16" captionText="FIGURE 14. Chelonus (Scabrichelonus) nigrifemoratus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, hind leg; F, head, anterior aspect; G, head, dorsal aspect; H, metasoma, dorsal aspect; I, head, lateral aspect." figureDoi="http://doi.org/10.5281/zenodo.6854058" httpUri="https://zenodo.org/record/6854058/files/figure.png" pageId="15" pageNumber="542">Figs 14G</figureCitation>
, 
<figureCitation box="[1285,1337,150,176]" captionStart="FIGURE 16" captionStartId="18.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@18.[179,1407,181,1919]" captionTargetPageId="18" captionText="FIGURE 16. Chelonus (Scabrichelonus) nigrifemoratus sp. nov., male, paratypes. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, metasoma, dorsal aspect; F, hind leg; G, head, anterior aspect; H, head, dorsal aspect; I, head, lateral aspect; J, antenna; K, metasoma, posterior aspect." figureDoi="http://doi.org/10.5281/zenodo.6854062" httpUri="https://zenodo.org/record/6854062/files/figure.png" pageId="15" pageNumber="542">16H</figureCitation>
); temple distinctly swollen, with 3 strong ridge-like transverse carinae; face evenly convex, distinctly transversely rugose, with a longitudinal carina dorso-medially, mandibles robust, not twisted apically, upper tooth longer than lower tooth; (
<figureCitation box="[230,330,258,284]" captionStart="FIGURE 14" captionStartId="16.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@16.[179,1407,181,1919]" captionTargetPageId="16" captionText="FIGURE 14. Chelonus (Scabrichelonus) nigrifemoratus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, hind leg; F, head, anterior aspect; G, head, dorsal aspect; H, metasoma, dorsal aspect; I, head, lateral aspect." figureDoi="http://doi.org/10.5281/zenodo.6854058" httpUri="https://zenodo.org/record/6854058/files/figure.png" pageId="15" pageNumber="542">Figs 14F</figureCitation>
, 
<figureCitation box="[340,392,258,284]" captionStart="FIGURE 16" captionStartId="18.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@18.[179,1407,181,1919]" captionTargetPageId="18" captionText="FIGURE 16. Chelonus (Scabrichelonus) nigrifemoratus sp. nov., male, paratypes. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, metasoma, dorsal aspect; F, hind leg; G, head, anterior aspect; H, head, dorsal aspect; I, head, lateral aspect; J, antenna; K, metasoma, posterior aspect." figureDoi="http://doi.org/10.5281/zenodo.6854062" httpUri="https://zenodo.org/record/6854062/files/figure.png" pageId="15" pageNumber="542">16G</figureCitation>
); occipital carina thin, arched dorso-medially, ventrally connected to hypostomal carina above base of mandible (
<figureCitation box="[368,479,294,320]" captionStart="FIGURE 14" captionStartId="16.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@16.[179,1407,181,1919]" captionTargetPageId="16" captionText="FIGURE 14. Chelonus (Scabrichelonus) nigrifemoratus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, hind leg; F, head, anterior aspect; G, head, dorsal aspect; H, metasoma, dorsal aspect; I, head, lateral aspect." figureDoi="http://doi.org/10.5281/zenodo.6854058" httpUri="https://zenodo.org/record/6854058/files/figure.png" pageId="15" pageNumber="542">Figs 14G</figureCitation>
, 
<figureCitation box="[494,546,294,320]" captionStart="FIGURE 16" captionStartId="18.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@18.[179,1407,181,1919]" captionTargetPageId="18" captionText="FIGURE 16. Chelonus (Scabrichelonus) nigrifemoratus sp. nov., male, paratypes. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, metasoma, dorsal aspect; F, hind leg; G, head, anterior aspect; H, head, dorsal aspect; I, head, lateral aspect; J, antenna; K, metasoma, posterior aspect." figureDoi="http://doi.org/10.5281/zenodo.6854062" httpUri="https://zenodo.org/record/6854062/files/figure.png" pageId="15" pageNumber="542">16H</figureCitation>
); mesoscutum evenly convex, transverse suture distinct; notauli superficially impressed; propodeum short, near posterior margin of propodeum (
<figureCitation box="[913,1020,330,356]" captionStart="FIGURE 14" captionStartId="16.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@16.[179,1407,181,1919]" captionTargetPageId="16" captionText="FIGURE 14. Chelonus (Scabrichelonus) nigrifemoratus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, hind leg; F, head, anterior aspect; G, head, dorsal aspect; H, metasoma, dorsal aspect; I, head, lateral aspect." figureDoi="http://doi.org/10.5281/zenodo.6854058" httpUri="https://zenodo.org/record/6854058/files/figure.png" pageId="15" pageNumber="542">Figs 14C</figureCitation>
, 
<figureCitation box="[1033,1084,330,356]" captionStart="FIGURE 16" captionStartId="18.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@18.[179,1407,181,1919]" captionTargetPageId="18" captionText="FIGURE 16. Chelonus (Scabrichelonus) nigrifemoratus sp. nov., male, paratypes. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, metasoma, dorsal aspect; F, hind leg; G, head, anterior aspect; H, head, dorsal aspect; I, head, lateral aspect; J, antenna; K, metasoma, posterior aspect." figureDoi="http://doi.org/10.5281/zenodo.6854062" httpUri="https://zenodo.org/record/6854062/files/figure.png" pageId="15" pageNumber="542">16C</figureCitation>
); metapleuron coarsely rugose, without metapleural flange; apical transverse carina of (
<figureCitation box="[797,906,366,392]" captionStart="FIGURE 14" captionStartId="16.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@16.[179,1407,181,1919]" captionTargetPageId="16" captionText="FIGURE 14. Chelonus (Scabrichelonus) nigrifemoratus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, hind leg; F, head, anterior aspect; G, head, dorsal aspect; H, metasoma, dorsal aspect; I, head, lateral aspect." figureDoi="http://doi.org/10.5281/zenodo.6854058" httpUri="https://zenodo.org/record/6854058/files/figure.png" pageId="15" pageNumber="542">Figs 14B</figureCitation>
, 
