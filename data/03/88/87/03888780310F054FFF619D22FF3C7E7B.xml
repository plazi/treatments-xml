<subSubSection pageId="9" pageNumber="536" type="etymology">
<paragraph blockId="9.[151,1437,150,789]" pageId="9" pageNumber="536">
<emphasis bold="true" box="[199,334,727,753]" pageId="9" pageNumber="536">Etymology.</emphasis>
From 
<emphasis box="[411,430,727,752]" italics="true" pageId="9" pageNumber="536">ir</emphasis>
(Latin for without) and 
<emphasis box="[706,784,727,753]" italics="true" pageId="9" pageNumber="536">lamina</emphasis>
(Latin for thin plate), because metasoma lacks the lateral lamella.
</paragraph>
