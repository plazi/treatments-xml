<subSubSection pageId="6" pageNumber="533" type="diagnosis">
<paragraph blockId="6.[151,1436,823,1101]" pageId="6" pageNumber="533">
<emphasis bold="true" box="[151,274,823,849]" pageId="6" pageNumber="533">Diagnosis.</emphasis>
Head transverse (
<figureCitation box="[481,576,823,849]" captionStart="FIGURE 6" captionStartId="8.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@8.[179,1407,181,1919]" captionTargetPageId="8" captionText="FIGURE 6. Chelonus (Megachelonus) irilaminatus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, metasoma, dorsal aspect; F, head, anterior aspect; G, head, dorsal aspect; H, ovipositor and ovipositor sheath, lateral aspect; I, head, lateral aspect; J, propodeum, dorsal aspect." figureDoi="http://doi.org/10.5281/zenodo.6854040" httpUri="https://zenodo.org/record/6854040/files/figure.png" pageId="6" pageNumber="533">Figs 6G</figureCitation>
, 
<figureCitation box="[589,624,824,850]" captionStart="FIGURE 8" captionStartId="10.[151,250,1941,1965]" captionTargetBox="[151,1436,181,1917]" captionTargetId="figure-22@10.[151,1436,181,1917]" captionTargetPageId="10" captionText="FIGURE 8. Chelonus (Megachelonus) longqiensis Zhang, Chen &amp; He, female, holotype. A, head, anterior aspect; B, head, dorsal aspect; C, metasoma, dorsal aspect; D, metasoma, lateral aspect; E, mesosoma, lateral aspect; F, mesosoma, dorsal aspect; G, head, lateral aspect; H, fore wing." figureDoi="http://doi.org/10.5281/zenodo.6854046" httpUri="https://zenodo.org/record/6854046/files/figure.png" pageId="6" pageNumber="533">8B</figureCitation>
, 
<figureCitation box="[638,687,824,850]" captionStart="FIGURE 10" captionStartId="12.[151,250,1942,1966]" captionTargetBox="[179,1408,181,1918]" captionTargetId="figure-22@12.[179,1408,181,1918]" captionTargetPageId="12" captionText="FIGURE 10. Chelonus (Megachelonus) macrodontus sp. nov. female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, head, anterior aspect; E, head, dorsal aspect; F, head, lateral aspect; G, metasoma, lateral aspect; H, metasoma, dorsal aspect." figureDoi="http://doi.org/10.5281/zenodo.6854050" httpUri="https://zenodo.org/record/6854050/files/figure.png" pageId="6" pageNumber="533">10B</figureCitation>
, 
<figureCitation box="[701,750,824,850]" captionStart="FIGURE 12" captionStartId="14.[151,250,1918,1942]" captionTargetBox="[154,1434,181,1890]" captionTargetId="figure-22@14.[154,1434,181,1894]" captionTargetPageId="14" captionText="FIGURE 12. Chelonus (Megachelonus) macros Zhang, Chen &amp; He, female, holotype. A, head, anterior aspect; B, head, dorsal aspect; C, metasoma, dorsal aspect; D, metasoma, lateral aspect; E, mesosoma, lateral aspect; F, mesosoma, dorsal aspect; G, head, lateral aspect; H, fore wing." figureDoi="http://doi.org/10.5281/zenodo.6854054" httpUri="https://zenodo.org/record/6854054/files/figure.png" pageId="6" pageNumber="533">12E</figureCitation>
); antennomeres of apical half of antenna distinctly flattened and broadened; face striate to reticulate rugose, clypeus semi-elliptical (
<figureCitation box="[949,1035,859,885]" captionStart="FIGURE 6" captionStartId="8.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@8.[179,1407,181,1919]" captionTargetPageId="8" captionText="FIGURE 6. Chelonus (Megachelonus) irilaminatus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, metasoma, dorsal aspect; F, head, anterior aspect; G, head, dorsal aspect; H, ovipositor and ovipositor sheath, lateral aspect; I, head, lateral aspect; J, propodeum, dorsal aspect." figureDoi="http://doi.org/10.5281/zenodo.6854040" httpUri="https://zenodo.org/record/6854040/files/figure.png" pageId="6" pageNumber="533">Figs 6F</figureCitation>
, 
<figureCitation box="[1045,1082,860,886]" captionStart="FIGURE 8" captionStartId="10.[151,250,1941,1965]" captionTargetBox="[151,1436,181,1917]" captionTargetId="figure-22@10.[151,1436,181,1917]" captionTargetPageId="10" captionText="FIGURE 8. Chelonus (Megachelonus) longqiensis Zhang, Chen &amp; He, female, holotype. A, head, anterior aspect; B, head, dorsal aspect; C, metasoma, dorsal aspect; D, metasoma, lateral aspect; E, mesosoma, lateral aspect; F, mesosoma, dorsal aspect; G, head, lateral aspect; H, fore wing." figureDoi="http://doi.org/10.5281/zenodo.6854046" httpUri="https://zenodo.org/record/6854046/files/figure.png" pageId="6" pageNumber="533">8A</figureCitation>
, 
<figureCitation box="[1093,1143,860,886]" captionStart="FIGURE 10" captionStartId="12.[151,250,1942,1966]" captionTargetBox="[179,1408,181,1918]" captionTargetId="figure-22@12.[179,1408,181,1918]" captionTargetPageId="12" captionText="FIGURE 10. Chelonus (Megachelonus) macrodontus sp. nov. female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, head, anterior aspect; E, head, dorsal aspect; F, head, lateral aspect; G, metasoma, lateral aspect; H, metasoma, dorsal aspect." figureDoi="http://doi.org/10.5281/zenodo.6854050" httpUri="https://zenodo.org/record/6854050/files/figure.png" pageId="6" pageNumber="533">10A</figureCitation>
, 
<figureCitation box="[1155,1207,860,886]" captionStart="FIGURE 12" captionStartId="14.[151,250,1918,1942]" captionTargetBox="[154,1434,181,1890]" captionTargetId="figure-22@14.[154,1434,181,1894]" captionTargetPageId="14" captionText="FIGURE 12. Chelonus (Megachelonus) macros Zhang, Chen &amp; He, female, holotype. A, head, anterior aspect; B, head, dorsal aspect; C, metasoma, dorsal aspect; D, metasoma, lateral aspect; E, mesosoma, lateral aspect; F, mesosoma, dorsal aspect; G, head, lateral aspect; H, fore wing." figureDoi="http://doi.org/10.5281/zenodo.6854054" httpUri="https://zenodo.org/record/6854054/files/figure.png" pageId="6" pageNumber="533">12D</figureCitation>
); eyes long elliptical or ovoid in lateral view (
<figureCitation box="[435,518,895,921]" captionStart="FIGURE 6" captionStartId="8.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@8.[179,1407,181,1919]" captionTargetPageId="8" captionText="FIGURE 6. Chelonus (Megachelonus) irilaminatus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, metasoma, dorsal aspect; F, head, anterior aspect; G, head, dorsal aspect; H, ovipositor and ovipositor sheath, lateral aspect; I, head, lateral aspect; J, propodeum, dorsal aspect." figureDoi="http://doi.org/10.5281/zenodo.6854040" httpUri="https://zenodo.org/record/6854040/files/figure.png" pageId="6" pageNumber="533">Figs 6I</figureCitation>
, 
<figureCitation box="[532,568,896,922]" captionStart="FIGURE 8" captionStartId="10.[151,250,1941,1965]" captionTargetBox="[151,1436,181,1917]" captionTargetId="figure-22@10.[151,1436,181,1917]" captionTargetPageId="10" captionText="FIGURE 8. Chelonus (Megachelonus) longqiensis Zhang, Chen &amp; He, female, holotype. A, head, anterior aspect; B, head, dorsal aspect; C, metasoma, dorsal aspect; D, metasoma, lateral aspect; E, mesosoma, lateral aspect; F, mesosoma, dorsal aspect; G, head, lateral aspect; H, fore wing." figureDoi="http://doi.org/10.5281/zenodo.6854046" httpUri="https://zenodo.org/record/6854046/files/figure.png" pageId="6" pageNumber="533">8G</figureCitation>
, 
<figureCitation box="[582,632,896,922]" captionStart="FIGURE 10" captionStartId="12.[151,250,1942,1966]" captionTargetBox="[179,1408,181,1918]" captionTargetId="figure-22@12.[179,1408,181,1918]" captionTargetPageId="12" captionText="FIGURE 10. Chelonus (Megachelonus) macrodontus sp. nov. female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, head, anterior aspect; E, head, dorsal aspect; F, head, lateral aspect; G, metasoma, lateral aspect; H, metasoma, dorsal aspect." figureDoi="http://doi.org/10.5281/zenodo.6854050" httpUri="https://zenodo.org/record/6854050/files/figure.png" pageId="6" pageNumber="533">10G</figureCitation>
, 
<figureCitation box="[646,693,896,922]" captionStart="FIGURE 12" captionStartId="14.[151,250,1918,1942]" captionTargetBox="[154,1434,181,1890]" captionTargetId="figure-22@14.[154,1434,181,1894]" captionTargetPageId="14" captionText="FIGURE 12. Chelonus (Megachelonus) macros Zhang, Chen &amp; He, female, holotype. A, head, anterior aspect; B, head, dorsal aspect; C, metasoma, dorsal aspect; D, metasoma, lateral aspect; E, mesosoma, lateral aspect; F, mesosoma, dorsal aspect; G, head, lateral aspect; H, fore wing." figureDoi="http://doi.org/10.5281/zenodo.6854054" httpUri="https://zenodo.org/record/6854054/files/figure.png" pageId="6" pageNumber="533">12F</figureCitation>
); mesosoma coarsely reticulate-rugose, transverse suture distinct; scutellum distinctly protruding above level of mesoscutum, with same sculpture as mesosoma; propodeum with a transverse carina and distinct tooth-like tubercles(
<figureCitation box="[710,838,967,993]" captionStart="FIGURE 6" captionStartId="8.[151,250,1943,1967]" captionTargetBox="[179,1407,181,1919]" captionTargetId="figure-22@8.[179,1407,181,1919]" captionTargetPageId="8" captionText="FIGURE 6. Chelonus (Megachelonus) irilaminatus sp. nov., female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, metasoma, lateral aspect; E, metasoma, dorsal aspect; F, head, anterior aspect; G, head, dorsal aspect; H, ovipositor and ovipositor sheath, lateral aspect; I, head, lateral aspect; J, propodeum, dorsal aspect." figureDoi="http://doi.org/10.5281/zenodo.6854040" httpUri="https://zenodo.org/record/6854040/files/figure.png" pageId="6" pageNumber="533">Figs 6C, 6J</figureCitation>
, 
<figureCitation box="[850,879,968,994]" captionStart="FIGURE 8" captionStartId="10.[151,250,1941,1965]" captionTargetBox="[151,1436,181,1917]" captionTargetId="figure-22@10.[151,1436,181,1917]" captionTargetPageId="10" captionText="FIGURE 8. Chelonus (Megachelonus) longqiensis Zhang, Chen &amp; He, female, holotype. A, head, anterior aspect; B, head, dorsal aspect; C, metasoma, dorsal aspect; D, metasoma, lateral aspect; E, mesosoma, lateral aspect; F, mesosoma, dorsal aspect; G, head, lateral aspect; H, fore wing." figureDoi="http://doi.org/10.5281/zenodo.6854046" httpUri="https://zenodo.org/record/6854046/files/figure.png" pageId="6" pageNumber="533">8F</figureCitation>
, 
<figureCitation box="[891,935,968,994]" captionStart="FIGURE 10" captionStartId="12.[151,250,1942,1966]" captionTargetBox="[179,1408,181,1918]" captionTargetId="figure-22@12.[179,1408,181,1918]" captionTargetPageId="12" captionText="FIGURE 10. Chelonus (Megachelonus) macrodontus sp. nov. female, holotype. A, fore wing; B, mesosoma, lateral aspect; C, mesosoma, dorsal aspect; D, head, anterior aspect; E, head, dorsal aspect; F, head, lateral aspect; G, metasoma, lateral aspect; H, metasoma, dorsal aspect." figureDoi="http://doi.org/10.5281/zenodo.6854050" httpUri="https://zenodo.org/record/6854050/files/figure.png" pageId="6" pageNumber="533">10F</figureCitation>
, 
<figureCitation box="[946,997,968,994]" captionStart="FIGURE 12" captionStartId="14.[151,250,1918,1942]" captionTargetBox="[154,1434,181,1890]" captionTargetId="figure-22@14.[154,1434,181,1894]" captionTargetPageId="14" captionText="FIGURE 12. Chelonus (Megachelonus) macros Zhang, Chen &amp; He, female, holotype. A, head, anterior aspect; B, head, dorsal aspect; C, metasoma, dorsal aspect; D, metasoma, lateral aspect; E, mesosoma, lateral aspect; F, mesosoma, dorsal aspect; G, head, lateral aspect; H, fore wing." figureDoi="http://doi.org/10.5281/zenodo.6854054" httpUri="https://zenodo.org/record/6854054/files/figure.png" pageId="6" pageNumber="533">12C</figureCitation>
); metasomal carapace with two ventroapical tooth-like protuberances (
