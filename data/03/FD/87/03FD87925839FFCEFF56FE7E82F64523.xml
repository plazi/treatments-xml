<subSubSection pageId="11" pageNumber="12" type="distribution">
<paragraph blockId="11.[151,1437,649,1324]" box="[199,1033,1261,1288]" pageId="11" pageNumber="12">
<emphasis bold="true" box="[199,353,1261,1287]" pageId="11" pageNumber="12">Distribution.</emphasis>
<collectingCountry box="[359,576,1261,1288]" name="Papua New Guinea" pageId="11" pageNumber="12">Papua New Guinea</collectingCountry>
