<subSubSection pageId="6" pageNumber="7" type="distribution">
<paragraph blockId="6.[151,1436,151,393]" box="[199,1010,330,357]" pageId="6" pageNumber="7">
<emphasis bold="true" box="[199,353,330,356]" pageId="6" pageNumber="7">Distribution.</emphasis>
Borneo (
<collectingCountry box="[457,566,331,357]" name="Malaysia" pageId="6" pageNumber="7">Malaysia</collectingCountry>
: West 
<collectingRegion box="[637,735,331,357]" country="Malaysia" name="Sarawak" pageId="6" pageNumber="7">Sarawak</collectingRegion>
) (
<figureCitation box="[758,843,331,357]" captionStart="FIGURE 98" captionStartId="20.[151,250,1436,1460]" captionTargetBox="[151,1436,956,1413]" captionTargetId="figure-372@20.[151,1436,956,1413]" captionTargetPageId="20" captionText="FIGURE 98. Distribution of the new genera and species in Malaysia, Brunei and Papua New Guinea." figureDoi="http://doi.org/10.5281/zenodo.6911205" httpUri="https://zenodo.org/record/6911205/files/figure.png" pageId="6" pageNumber="7">Fig. 98</figureCitation>
: blue squares).
</paragraph>
<paragraph blockId="6.[151,1436,151,393]" box="[199,658,366,393]" pageId="6" pageNumber="7">
<emphasis bold="true" box="[199,403,366,392]" pageId="6" pageNumber="7">Species included.</emphasis>
