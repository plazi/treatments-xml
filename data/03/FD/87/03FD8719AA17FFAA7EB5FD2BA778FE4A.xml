<taxonomicName authority="Lesne, 1901" authorityName="Lesne" authorityYear="1901" box="[1100,1399,1024,1051]" class="Insecta" family="Bostrichidae" genus="Octodesmus" kingdom="Animalia" order="Coleoptera" pageId="7" pageNumber="52" phylum="Arthropoda" rank="genus">
