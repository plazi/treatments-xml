<figureCitation box="[654,738,1549,1575]" captionStart="FIGURE 98" captionStartId="20.[151,250,1436,1460]" captionTargetBox="[151,1436,956,1413]" captionTargetId="figure-372@20.[151,1436,956,1413]" captionTargetPageId="20" captionText="FIGURE 98. Distribution of the new genera and species in Malaysia, Brunei and Papua New Guinea." figureDoi="http://doi.org/10.5281/zenodo.6911205" httpUri="https://zenodo.org/record/6911205/files/figure.png" pageId="15" pageNumber="16">Fig. 98</figureCitation>
