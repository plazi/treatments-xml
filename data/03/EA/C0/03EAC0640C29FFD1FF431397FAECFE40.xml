. 
<collectingCounty box="[681,746,338,364]" pageId="4" pageNumber="175">North</collectingCounty>
<collectingRegion box="[755,885,338,364]" country="Russia" name="Kamchatka" pageId="4" pageNumber="175">Kamchatka</collectingRegion>
, eastern coast, 
<collectingMunicipality box="[1058,1290,338,364]" pageId="4" pageNumber="175">Karaginskiy District</collectingMunicipality>
, 
<location LSID="urn:lsid:plazi:treatment:03EAC0640C29FFD1FF431397FAECFE40:8E9C27A90C2CFFD1FADD1551FA46FEF4" box="[1302,1451,338,364]" country="Russia" county="North" latitude="59.663807" longLatPrecision="8" longitude="162.62222" municipality="Karaginskiy District" name="Tymlat River" pageId="4" pageNumber="175" stateProvince="Kamchatka">Tymlat River</location>
basin, 
<location LSID="urn:lsid:plazi:treatment:03EAC0640C29FFD1FF431397FAECFE40:8E9C27A90C2CFFD1FF1B1575FE91FE09" box="[208,380,374,401]" country="Russia" county="North" latitude="59.663807" longLatPrecision="8" longitude="162.62222" municipality="Karaginskiy District" name="Yakotvon' Mts." pageId="4" pageNumber="175" stateProvince="Kamchatka">Yakotvon’ Mts.</location>
[ca. 
<geoCoordinate box="[434,601,374,401]" degrees="59" direction="north" minutes="39" orientation="latitude" pageId="4" pageNumber="175" precision="1" seconds="49.7" value="59.663807">59°39’49.7” N</geoCoordinate>
, 
<geoCoordinate box="[612,768,374,401]" degrees="162" direction="east" minutes="37" orientation="longitude" pageId="4" pageNumber="175" precision="15" seconds="20" value="162.62222">162°37’20” E</geoCoordinate>
, 
<quantity box="[780,908,374,401]" metricMagnitude="2" metricUnit="m" metricValue="3.25" metricValueMax="3.3" metricValueMin="3.2" pageId="4" pageNumber="175" unit="m" value="325.0" valueMax="330.0" valueMin="320.0">
<elevation box="[780,908,374,401]" metricMagnitude="2" metricUnit="m" metricValue="3.25" metricValueMax="3.3" metricValueMin="3.2" pageId="4" pageNumber="175" unit="m" value="325.0" valueMax="330.0" valueMin="320.0">320–330 m</elevation>
</quantity>
, slopes of a nameless mountain 
<quantity box="[1266,1336,374,401]" metricMagnitude="2" metricUnit="m" metricValue="8.25" pageId="4" pageNumber="175" unit="m" value="825.0">
<elevation box="[1266,1336,374,401]" metricMagnitude="2" metricUnit="m" metricValue="8.25" pageId="4" pageNumber="175" unit="m" value="825.0">825 m</elevation>
</quantity>
high, 
