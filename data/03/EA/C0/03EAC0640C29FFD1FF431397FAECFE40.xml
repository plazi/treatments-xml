:— 
<materialsCitation collectingDate="2011-08-21" collectionCode="S, O, KAM" country="Russia" county="North" elevation="325" latitude="59.663807" location="Tymlat River" longLatPrecision="8" longitude="162.62222" municipality="Karaginskiy District" pageId="4" pageNumber="175" specimenCount="1" stateProvince="Kamchatka" typeStatus="paratype">
