2. 
<taxonomicName authority="Deng" authorityName="Deng" authorityYear="2022" box="[179,501,150,177]" class="Insecta" family="Tetrigidae" genus="Xistra" kingdom="Animalia" order="Orthoptera" pageId="7" pageNumber="190" phylum="Arthropoda" rank="species" species="nigriabdominis" status="sp. nov.">
