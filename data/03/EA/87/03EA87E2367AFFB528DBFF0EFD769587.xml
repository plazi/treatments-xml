<subSubSection pageId="29" pageNumber="236" type="discussion">
<paragraph blockId="29.[178,1085,1270,1351]" pageId="29" pageNumber="236">Comparative notes: This species is distinguished from its congeners by the nearly uniformly yellowish coloration of the body and by the shape of the median lobe of the aedeagus.</paragraph>
</subSubSection>
<subSubSection pageId="29" pageNumber="236" type="distribution">
<paragraph blockId="29.[178,1086,1374,1455]" pageId="29" pageNumber="236">
