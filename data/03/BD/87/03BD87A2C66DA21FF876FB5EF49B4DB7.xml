<taxonomicName box="[2849,2978,1881,1920]" class="Mammalia" family="Hipposideridae" genus="Hipposideros" kingdom="Animalia" order="Chiroptera" pageId="27" pageNumber="254" phylum="Chordata" rank="species" species="fulvus">fulvus</taxonomicName>
