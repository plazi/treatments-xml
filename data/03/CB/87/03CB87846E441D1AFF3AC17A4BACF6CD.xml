<bibRefCitation author="Reed, F. R. C." box="[514,633,1407,1431]" pageId="17" pageNumber="318" pagination="1 - 98" refId="ref46807" refString="Reed, F. R. C. (1915) Supplementary Memoir on new Ordovician and Silurian fossils from the Northern Shan States. Palaeontologia Indica, New Series 6, 1 - 98." type="book chapter" year="1915">Reed, 1915</bibRefCitation>
