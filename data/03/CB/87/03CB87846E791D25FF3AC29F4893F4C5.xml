<taxonomicName authority="Dalman, 1827" authorityName="Dalman" authorityYear="1827" box="[151,431,1758,1785]" class="Trilobita" family="Illaenidae" genus="Illaenus" kingdom="Animalia" order="Corynexochida" pageId="44" pageNumber="345" phylum="Arthropoda" rank="genus">
<emphasis bold="true" box="[151,431,1758,1785]" pageId="44" pageNumber="345">
<emphasis bold="true" box="[151,250,1758,1785]" italics="true" pageId="44" pageNumber="345">Illaenus</emphasis>
<bibRefCitation author="Dalman, J. W." box="[258,431,1758,1785]" pageId="44" pageNumber="345" pagination="113 - 152" refId="ref43331" refString="Dalman, J. W. (1827) Om Palaederna eller de sa kallade Trilobiterna. Kungliga Svenska Vetenskaps Akadamiens Handlingar, Stockholm, 1, 113 - 152 + 226 - 294." type="journal article" year="1827">Dalman, 1827</bibRefCitation>
