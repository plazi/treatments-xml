<emphasis bold="true" box="[151,286,1832,1859]" italics="true" pageId="29" pageNumber="330">Pliomerina</emphasis>
<bibRefCitation author="Chugaeva, M. N." box="[294,493,1832,1858]" pageId="29" pageNumber="330" pagination="1336 - 1339" refId="ref43063" refString="Chugaeva, M. N. (1956) New trilobite genera from the Middle and Upper Ordovician of southern Kazakhstan. Doklady Akademia Nauk SSSR, 111 (6), 1336 - 1339. [in Russian]" type="journal article" year="1956">Chugaeva, 1956</bibRefCitation>
