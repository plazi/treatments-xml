<taxonomicName baseAuthorityName="Reed" baseAuthorityYear="1917" box="[1315,1436,1668,1693]" class="Trilobita" family="Telephinidae" genus="Phorocephala" kingdom="Animalia" order="Proetida" pageId="47" pageNumber="348" phylum="Arthropoda" rank="species" species="mansuyi">
