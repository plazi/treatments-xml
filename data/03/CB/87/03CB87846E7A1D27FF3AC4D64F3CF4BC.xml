<collectionCode box="[834,879,326,352]" country="India" httpUri="http://grbio.org/cool/jprb-qxkv" name="Geological Survey of India" pageId="47" pageNumber="348">GSI</collectionCode>
11905
</accessionNumber>
; cranidium (
<bibRefCitation author="Reed, F. R. C." box="[1095,1226,326,352]" pageId="47" pageNumber="348" pagination="1 - 69" refId="ref46843" refString="Reed, F. R. C. (1917) Ordovician and Silurian fossils from Yun-nan. Palaeontologia Indica, 6 (3), 1 - 69." type="journal article" year="1917">Reed, 1917</bibRefCitation>
, pl. 7, fig. 14), 
<accessionNumber httpUri="http://www.ncbi.nlm.nih.gov/protein/GSI11903" pageId="47" pageNumber="348">
