<bibRefCitation author="Reed, F. R. C." box="[527,658,326,352]" pageId="47" pageNumber="348" pagination="1 - 69" refId="ref46843" refString="Reed, F. R. C. (1917) Ordovician and Silurian fossils from Yun-nan. Palaeontologia Indica, 6 (3), 1 - 69." type="journal article" year="1917">Reed, 1917</bibRefCitation>
