<taxonomicName authority="Pompeckj" authorityName="Pompeckj" box="[247,560,256,280]" class="Trilobita" family="Asaphidae" genus="Asaphus" isUncertain="true" kingdom="Animalia" order="Asaphida" pageId="26" pageNumber="327" phylum="Arthropoda" rank="species" species="ornatus">
