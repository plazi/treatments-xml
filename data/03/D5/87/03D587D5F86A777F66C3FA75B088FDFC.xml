<collectingCountry box="[359,426,439,465]" name="China" pageId="18" pageNumber="119">China</collectingCountry>
(
<collectingRegion box="[441,621,439,465]" country="China" name="Nei Mongol" pageId="18" pageNumber="119">Inner Mongolia</collectingRegion>
