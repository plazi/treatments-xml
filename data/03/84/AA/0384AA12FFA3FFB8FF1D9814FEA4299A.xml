</subSubSection>
</emphasis>
<subSubSection pageId="1" pageNumber="152" type="discussion">
<paragraph blockId="1.[151,1437,1554,2013]" pageId="1" pageNumber="152">
<collectorName box="[808,998,1555,1581]" pageId="1" pageNumber="152">The Afrotropical</collectorName>
species under the name 
<taxonomicName authority="Kopelke 1980" authorityName="Kopelke" authorityYear="1980" class="Insecta" family="Baetidae" genus="Centroptilum" kingdom="Animalia" order="Ephemeroptera" pageId="1" pageNumber="152" phylum="Arthropoda" rank="species" species="boettgeri">
<emphasis italics="true" pageId="1" pageNumber="152">Centroptilum boettgeri</emphasis>
Kopelke 1980
</taxonomicName>
was originally described as male and female imagines (
<bibRefCitation author="Kopelke, J. - P." box="[1039,1212,1591,1617]" pageId="1" pageNumber="152" pagination="99 - 129" refId="ref31875" refString="Kopelke, J. - P. (1980 a) Ephemeroptera aus der Emergenz des zentralafrikanischen Bergbaches Kalengo (Zaire) Teil I: Baetidae. In: Entomologische Abhandlungen. 43 (6). Staatliches Museum fur Tierkunde, Dresden, pp. 99 - 129. [1979]" type="book chapter" year="1980">Kopelke 1980a</bibRefCitation>
) and eggs (
<bibRefCitation author="Kopelke, J. - P." pageId="1" pageNumber="152" pagination="297 - 311" refId="ref31928" refString="Kopelke, J. - P. (1980 b) Morphologische Studien an den Eiern der Eintagsfliegen (Ephemeroptera) aus der Emergenz des zentralafrikanischen Bergbaches Kalengo. Mitteilungen der Schweizerischen Entomologischen Gesellschaf, 53 (2 - 3), 297 - 311." type="journal article" year="1980">Kopelke 1980b</bibRefCitation>
) from 
<collectorName box="[300,359,1627,1653]" pageId="1" pageNumber="152">Zaire</collectorName>
(recently 
<collectorName box="[473,599,1627,1653]" pageId="1" pageNumber="152">DR Congo</collectorName>
). 
<collectorName box="[618,770,1627,1653]" pageId="1" pageNumber="152">Subsequently</collectorName>
, 
<bibRefCitation author="Gillies, M. T." box="[781,938,1627,1653]" pageId="1" pageNumber="152" pagination="97 - 128" refId="ref29556" refString="Gillies, M. T. (1990) A revision of the African species of Centroptilum Eaton (Baetidae, Ephemeroptera). Aquatic Insects, 12 (2), 97 - 128. https: // doi. org / 10.1080 / 01650429009361395" type="journal article" year="1990">Gillies (1990)</bibRefCitation>
moved this species in the newly established genus 
<taxonomicName authority="Gillies 1990" authorityName="Gillies" authorityYear="1990" box="[224,492,1663,1689]" class="Insecta" family="Baetidae" genus="Afroptilum" kingdom="Animalia" order="Ephemeroptera" pageId="1" pageNumber="152" phylum="Arthropoda" rank="genus">
<emphasis box="[224,344,1663,1689]" italics="true" pageId="1" pageNumber="152">Afroptilum</emphasis>
<bibRefCitation author="Gillies, M. T." box="[351,492,1663,1689]" pageId="1" pageNumber="152" pagination="97 - 128" refId="ref29556" refString="Gillies, M. T. (1990) A revision of the African species of Centroptilum Eaton (Baetidae, Ephemeroptera). Aquatic Insects, 12 (2), 97 - 128. https: // doi. org / 10.1080 / 01650429009361395" type="journal article" year="1990">Gillies 1990</bibRefCitation>
</taxonomicName>
. 
<collectorName box="[502,546,1663,1689]" pageId="1" pageNumber="152">The</collectorName>
species 
<taxonomicName authority="Lugo-Ortiz &amp; McCafferty 1997 a" authorityName="Lugo-Ortiz &amp; McCafferty" authorityYear="1997" box="[641,1276,1663,1689]" class="Insecta" family="Baetidae" genus="Xyrodromeus" kingdom="Animalia" order="Ephemeroptera" pageId="1" pageNumber="152" phylum="Arthropoda" rank="species" species="africanus">
<emphasis box="[641,902,1663,1689]" italics="true" pageId="1" pageNumber="152">Xyrodromeus africanus</emphasis>
<bibRefCitation author="Lugo-Ortiz, C. R. &amp; McCafferty, W. P." box="[909,1276,1663,1689]" pageId="1" pageNumber="152" pagination="41 - 46" refId="ref31974" refString="Lugo-Ortiz, C. R. &amp; McCafferty, W. P. (1997 a) New Afrotropical genus of Baetidae (Insecta: Ephemeroptera) with bladelike mandibles. Bulletin de la Societe d'Histoire Naturelle de Toulouse, 133 (1), 41 - 46." type="journal article" year="1997">Lugo-Ortiz &amp; McCafferty 1997a</bibRefCitation>
</taxonomicName>
(the 
<typeStatus box="[1334,1382,1663,1689]" pageId="1" pageNumber="152">type</typeStatus>
species of 
<taxonomicName authority="Lugo-Ortiz &amp; McCafferty 1997" authorityName="Lugo-Ortiz &amp; McCafferty" authorityYear="1997" box="[236,757,1699,1725]" class="Insecta" family="Baetidae" genus="Xyrodromeus" kingdom="Animalia" order="Ephemeroptera" pageId="1" pageNumber="152" phylum="Arthropoda" rank="genus">
<emphasis box="[236,385,1699,1725]" italics="true" pageId="1" pageNumber="152">Xyrodromeus</emphasis>
Lugo-Ortiz &amp; McCafferty 1997
</taxonomicName>
) was originally described as larvae from 
<collectingCounty box="[1236,1313,1699,1725]" pageId="1" pageNumber="152">Kenya</collectingCounty>
; according to the original description, it corresponds to the larvae described from 
<collectingMunicipality box="[945,1018,1735,1761]" pageId="1" pageNumber="152">Kenya</collectingMunicipality>
and 
<location LSID="urn:lsid:plazi:treatment:0384AA12FFA3FFB8FF1D9814FEA4299A:8EF24DDFFFA3FFB8FBB898C1FB1728A6" box="[1074,1161,1735,1761]" country="Uganda" county="Kenya" municipality="Kenya" name="Uganda" pageId="1" pageNumber="152" stateProvince="Kasese">Uganda</location>
as « 
<taxonomicName box="[1213,1422,1735,1761]" class="Insecta" family="Baetidae" genus="Centroptilum" kingdom="Animalia" order="Ephemeroptera" pageId="1" pageNumber="152" phylum="Arthropoda" rank="species" species="undefined-2">
<emphasis box="[1213,1361,1735,1761]" italics="true" pageId="1" pageNumber="152">Centroptilum</emphasis>
sp. 2
</taxonomicName>
» by 
<bibRefCitation author="Demoulin, G." box="[187,398,1771,1797]" pageId="1" pageNumber="152" pagination="279 - 294" refId="ref29488" refString="Demoulin, G. (1964 a) Mission H. Loffler en Afrique Orientale. Ephemeroptera. Bulletin et Annales de la Societe Entomologique de Belgique, 100 (21), 279 - 294." type="journal article" year="1964">Demoulin (1964a)</bibRefCitation>
. 
<location LSID="urn:lsid:plazi:treatment:0384AA12FFA3FFB8FF1D9814FEA4299A:8EF24DDFFFA3FFB8FE1098EDFD9F2942" box="[410,513,1771,1797]" country="Uganda" county="Kenya" municipality="Kenya" name="Imagines" pageId="1" pageNumber="152" stateProvince="Kasese">Imagines</location>
corresponding to the description of 
<taxonomicName baseAuthorityName="Kopelke" baseAuthorityYear="1980" box="[926,1156,1771,1797]" class="Insecta" family="Baetidae" genus="Afroptilum" kingdom="Animalia" order="Ephemeroptera" pageId="1" pageNumber="152" phylum="Arthropoda" rank="species" species="boettgeri">
<emphasis box="[926,1156,1771,1797]" italics="true" pageId="1" pageNumber="152">Afroptilum boettgeri</emphasis>
</taxonomicName>
were reared from larvae corresponding to the description of 
<taxonomicName authorityName="Lugo-Ortiz &amp; McCafferty" authorityYear="1997" box="[550,812,1807,1833]" class="Insecta" family="Baetidae" genus="Xyrodromeus" kingdom="Animalia" order="Ephemeroptera" pageId="1" pageNumber="152" phylum="Arthropoda" rank="species" species="africanus">
<emphasis box="[550,812,1807,1833]" italics="true" pageId="1" pageNumber="152">Xyrodromeus africanus</emphasis>
</taxonomicName>
; this allows to conclude that these two names belong to one and the same species.
</paragraph>
</subSubSection>
