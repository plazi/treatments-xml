<taxonomicName authorityName="Lugo-Ortiz &amp; McCafferty" authorityYear="1997" box="[426,691,1554,1581]" class="Insecta" family="Baetidae" genus="Xyrodromeus" kingdom="Animalia" order="Ephemeroptera" pageId="1" pageNumber="152" phylum="Arthropoda" rank="species" species="africanu">
