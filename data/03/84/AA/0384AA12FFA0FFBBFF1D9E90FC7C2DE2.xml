<paragraph blockId="2.[151,1437,150,933]" pageId="2" pageNumber="153">
<collectingCounty box="[701,890,151,177]" pageId="2" pageNumber="153">The Afrotropical</collectingCounty>
species under the name 
<taxonomicName authority="Barnard 1932" authorityName="Barnard" authorityYear="1932" class="Insecta" family="Baetidae" genus="Pseudocloeon" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="vinosum">
<emphasis box="[1177,1436,151,177]" italics="true" pageId="2" pageNumber="153">Pseudocloeon vinosum</emphasis>
<bibRefCitation author="Barnard, K. H." box="[151,304,187,213]" pageId="2" pageNumber="153" pagination="201 - 259" refId="ref29227" refString="Barnard, K. H. (1932) South African May-flies (Ephemeroptera). Transactions of the Royal Society of South Africa, 20, 201 - 259. https: // doi. org / 10.1080 / 00359193209518858" type="journal article" year="1932">Barnard 1932</bibRefCitation>
</taxonomicName>
was originally described as male and female imagines and larvae from South Africa and then moved in the genus 
<taxonomicName authorityName="Novikova &amp; Kluge" authorityYear="1987" box="[294,426,223,249]" class="Insecta" family="Baetidae" genus="Labiobaetis" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis box="[294,426,223,249]" italics="true" pageId="2" pageNumber="153">Labiobaetis</emphasis>
</taxonomicName>
by 
<bibRefCitation author="Lugo-Ortiz, C. R. &amp; McCafferty, W. P." box="[468,878,223,249]" pageId="2" pageNumber="153" pagination="241 - 260" refId="ref32023" refString="Lugo-Ortiz, C. R. &amp; McCafferty, W. P. (1997 b) Labiobaetis Novikova &amp; Kluge (Ephemeroptera: Baetidae) from the Afrotropical region. African Entomology, 5 (2), 241 - 260." type="journal article" year="1997">Lugo-Ortiz and McCafferty (1997b)</bibRefCitation>
. 
<collectingMunicipality box="[888,932,223,249]" pageId="2" pageNumber="153">The</collectingMunicipality>
species under the name 
<taxonomicName authority="Kopelke 1980" authorityName="Kopelke" authorityYear="1980" class="Insecta" family="Baetidae" genus="Pseudocloeon" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="tenuicrinitum">
<emphasis italics="true" pageId="2" pageNumber="153">Pseudocloeon tenuicrinitum</emphasis>
Kopelke 1980
</taxonomicName>
was originally described as male and female imagines (
<bibRefCitation author="Kopelke, J. - P." box="[1037,1211,259,285]" pageId="2" pageNumber="153" pagination="99 - 129" refId="ref31875" refString="Kopelke, J. - P. (1980 a) Ephemeroptera aus der Emergenz des zentralafrikanischen Bergbaches Kalengo (Zaire) Teil I: Baetidae. In: Entomologische Abhandlungen. 43 (6). Staatliches Museum fur Tierkunde, Dresden, pp. 99 - 129. [1979]" type="book chapter" year="1980">Kopelke 1980a</bibRefCitation>
) and eggs (
<bibRefCitation author="Kopelke, J. - P." pageId="2" pageNumber="153" pagination="297 - 311" refId="ref31928" refString="Kopelke, J. - P. (1980 b) Morphologische Studien an den Eiern der Eintagsfliegen (Ephemeroptera) aus der Emergenz des zentralafrikanischen Bergbaches Kalengo. Mitteilungen der Schweizerischen Entomologischen Gesellschaf, 53 (2 - 3), 297 - 311." type="journal article" year="1980">Kopelke 1980b</bibRefCitation>
) from 
<collectingCountry box="[302,361,295,321]" name="Democratic Republic of the Congo" pageId="2" pageNumber="153">Zaire</collectingCountry>
(recently DR Congo); nobody compared 
<taxonomicName authorityName="Kopelke" authorityYear="1980" box="[837,1017,295,320]" class="Insecta" family="Baetidae" genus="Pseudocloeon" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="tenuicrinitum">
<emphasis box="[837,1017,295,320]" italics="true" pageId="2" pageNumber="153">P. tenuicrinitum</emphasis>
</taxonomicName>
with 
<taxonomicName authorityName="Barnard" authorityYear="1932" box="[1084,1206,295,320]" class="Insecta" family="Baetidae" genus="Pseudocloeon" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="vinosum">
<emphasis box="[1084,1206,295,320]" italics="true" pageId="2" pageNumber="153">P. vinosum</emphasis>
</taxonomicName>
. 
<location LSID="urn:lsid:plazi:treatment:0384AA12FFA0FFBBFF1D9E90FC7C2DE2:8EF24DDFFFA0FFBBFB4C9F21FA942F06" box="[1222,1290,295,321]" country="Democratic Republic of the Congo" county="The Afrotropical" municipality="The" name="Based" pageId="2" pageNumber="153" stateProvince="Kasese">Based</location>
on imagines reared from larvae in Uganda, 
<bibRefCitation author="Kluge, N. J. &amp; Novikova, E. A." box="[505,826,331,357]" pageId="2" pageNumber="153" pagination="1 - 43" refId="ref31493" refString="Kluge, N. J. &amp; Novikova, E. A. (2016) New tribe Labiobaetini tribus n., redefinition of Pseudopannota Waltz &amp; McCafferty 1987 and descriptions of new and little known species from Zambia and Uganda. Zootaxa, 4169 (1), 1 - 43. https: // doi. org / 10.11646 / zootaxa. 4169.1.1" type="journal article" year="2016">Kluge and Novikova (2016)</bibRefCitation>
moved 
<taxonomicName authorityName="Kopelke" authorityYear="1980" box="[919,1100,331,356]" class="Insecta" family="Baetidae" genus="Pseudocloeon" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="tenuicrinitum">
<emphasis box="[919,1100,331,356]" italics="true" pageId="2" pageNumber="153">P. tenuicrinitum</emphasis>
</taxonomicName>
in the genus 
<taxonomicName authorityName="Novikova &amp; Kluge" authorityYear="1987" box="[1257,1389,331,357]" class="Insecta" family="Baetidae" genus="Labiobaetis" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis box="[1257,1389,331,357]" italics="true" pageId="2" pageNumber="153">Labiobaetis</emphasis>
</taxonomicName>
, redescribed its larvae, subimagines, imagines and eggs and established its synonymy with the species originally described from 
<collectingCountry box="[334,435,403,429]" name="Tanzania" pageId="2" pageNumber="153">Tanzania</collectingCountry>
as 
<taxonomicName authority="Gillies 1994" authorityName="Gillies" authorityYear="1994" box="[481,832,403,429]" class="Insecta" family="Baetidae" genus="Baetis" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="spatulatus">
<emphasis box="[481,677,403,429]" italics="true" pageId="2" pageNumber="153">Baetis spatulatus</emphasis>
<bibRefCitation author="Gillies, M. T." box="[688,832,403,429]" pageId="2" pageNumber="153" pagination="105 - 118" refId="ref29602" refString="Gillies, M. T. (1994) Description of some Afrotropical Baetidae (Ephemeroptera): II. Baetis Leach, s. l., East African species. Aquatic Insects, 16 (2), 105 - 118. https: // doi. org / 10.1080 / 01650429409361543" type="journal article" year="1994">Gillies 1994</bibRefCitation>
</taxonomicName>
. 
<location LSID="urn:lsid:plazi:treatment:0384AA12FFA0FFBBFF1D9E90FC7C2DE2:8EF24DDFFFA0FFBBFCC49F95FCF42FEA" box="[846,874,403,429]" country="Democratic Republic of the Congo" county="The Afrotropical" municipality="The" name="At" pageId="2" pageNumber="153" stateProvince="Kasese">At</location>
present, examination of larvae, reared imagines and eggs from Tanzania and 
<collectingCountry box="[480,624,439,465]" name="South Africa" pageId="2" pageNumber="153">South Africa</collectingCountry>
allows to conclude that the names 
<taxonomicName authorityName="Barnard" authorityYear="1932" box="[1025,1118,439,464]" class="Insecta" family="Baetidae" genus="Pseudocloeon" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="vinosum">
<emphasis box="[1025,1118,439,464]" italics="true" pageId="2" pageNumber="153">vinosum</emphasis>
</taxonomicName>
[
<taxonomicName box="[1136,1293,439,465]" class="Insecta" family="Baetidae" genus="Pseudocloeon" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis box="[1136,1293,439,465]" italics="true" pageId="2" pageNumber="153">Pseudocloeon</emphasis>
</taxonomicName>
], 
<taxonomicName authorityName="Kopelke" authorityYear="1980" class="Insecta" family="Baetidae" genus="Pseudocloeon" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="tenuicrinitum">
<emphasis italics="true" pageId="2" pageNumber="153">tenuicrinitum</emphasis>
</taxonomicName>
[
<taxonomicName box="[210,367,475,501]" class="Insecta" family="Baetidae" genus="Pseudocloeon" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis box="[210,367,475,501]" italics="true" pageId="2" pageNumber="153">Pseudocloeon</emphasis>
</taxonomicName>
] and 
<taxonomicName authorityName="Gillies" authorityYear="1994" box="[432,547,475,501]" class="Insecta" family="Baetidae" genus="Baetis" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="species" species="spatulatus">
<emphasis box="[432,547,475,501]" italics="true" pageId="2" pageNumber="153">spatulatus</emphasis>
</taxonomicName>
[
<taxonomicName authorityName="Leach" authorityYear="1815" box="[564,634,475,500]" class="Insecta" family="Baetidae" genus="Baetis" kingdom="Animalia" order="Ephemeroptera" pageId="2" pageNumber="153" phylum="Arthropoda" rank="genus">
<emphasis box="[564,634,475,500]" italics="true" pageId="2" pageNumber="153">Baetis</emphasis>
</taxonomicName>
] belong to one and the same species.
</paragraph>
</subSubSection>
