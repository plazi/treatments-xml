<bibRefCitation author="Kaddumi, H. F." box="[441,547,651,675]" pageId="2" pageNumber="413" refId="ref14564" refString="Kaddumi, H. F. (2007) The Amber of Jordan. The Oldest Prehistoric Insects in Fossilized Resin. 3 rd Edition. Eternal River Museum of Natural History, Amman, 298 pp." type="book" year="2007">2007: 121</bibRefCitation>
</treatmentCitation>
). 
<typeStatus box="[564,614,652,676]" pageId="2" pageNumber="413">Type</typeStatus>
species: 
<taxonomicName authority="Kaddumi, 2005" authorityName="Kaddumi" authorityYear="2005" box="[708,1029,651,675]" class="Insecta" family="Chironomidae" genus="Curvus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Diptera" pageId="2" pageNumber="413" phylum="Arthropoda" rank="species" species="khuludi">
