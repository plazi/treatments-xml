<paragraph blockId="2.[151,1437,721,1432]" pageId="2" pageNumber="413">
<emphasis bold="true" box="[151,354,721,747]" pageId="2" pageNumber="413">Included species.</emphasis>
<taxonomicName authority="Kaddumi, 2005: 85" authorityName="Kaddumi" authorityPageNumber="85" authorityYear="2005" box="[361,759,721,748]" class="Insecta" family="Chironomidae" genus="Curvus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Diptera" pageId="2" pageNumber="413" phylum="Arthropoda" rank="species" species="khuludi">
<emphasis box="[361,534,721,748]" italics="true" pageId="2" pageNumber="413">Curvus khuludi</emphasis>
<bibRefCitation author="Kaddumi, H. F." box="[541,759,721,748]" pageId="2" pageNumber="413" refId="ref14526" refString="Kaddumi, H. F. (2005) The Amber of Jordan. The Oldest Prehistoric Insects in Fossilized Resin. 2 nd Edition. Eternal River Museum of Natural History, Amman, 224 pp." type="book" year="2005">Kaddumi, 2005: 85</bibRefCitation>
</taxonomicName>
(
<bibRefCitation author="Kaddumi, H. F." box="[775,892,721,747]" pageId="2" pageNumber="413" refId="ref14564" refString="Kaddumi, H. F. (2007) The Amber of Jordan. The Oldest Prehistoric Insects in Fossilized Resin. 3 rd Edition. Eternal River Museum of Natural History, Amman, 298 pp." type="book" year="2007">2007: 121</bibRefCitation>
