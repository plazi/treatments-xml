<bibRefCitation author="Ulrich, H." box="[1139,1288,1616,1642]" pageId="3" pageNumber="414" pagination="233 - 243" refId="ref16673" refString="Ulrich, H. (2004) Phylogenetic considerations about an early colonization of the sea coasts by Dolichopodidae (Diptera). Studia dipterologica, 11, 233 - 243." type="journal article" year="2004">Ulrich (2004</bibRefCitation>
; unpublished notes on Meunier’s types) found only 
<specimenCount box="[581,777,1652,1679]" pageId="3" pageNumber="414" type="male" typeStatus="syntype">one syntype male</specimenCount>
