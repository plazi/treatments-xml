<collectingCountry box="[1095,1200,1231,1257]" name="Paraguay" pageId="4" pageNumber="293">Paraguay</collectingCountry>
, 
<collectingCountry box="[1214,1370,1231,1257]" name="United States of America" pageId="4" pageNumber="293">United States</collectingCountry>
, 
<collectingCountry name="Uruguay" pageId="4" pageNumber="293">Uruguay</collectingCountry>
