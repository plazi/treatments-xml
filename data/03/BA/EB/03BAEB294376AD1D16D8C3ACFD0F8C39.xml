, 
<collectingCountry box="[526,594,1195,1221]" name="Malta" pageId="4" pageNumber="293">Malta</collectingCountry>
, 
<collectingCountry box="[607,711,1195,1221]" name="Morocco" pageId="4" pageNumber="293">Morocco</collectingCountry>
, 
<collectingCountry box="[724,822,1195,1221]" name="Portugal" pageId="4" pageNumber="293">Portugal</collectingCountry>
, 
<collectingCountry box="[835,899,1195,1221]" name="Spain" pageId="4" pageNumber="293">Spain</collectingCountry>
and 
<collectingCountry box="[957,1041,1195,1222]" name="Turkey" pageId="4" pageNumber="293">Turkey</collectingCountry>
