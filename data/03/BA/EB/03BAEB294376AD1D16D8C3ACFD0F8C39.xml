, 
<collectingCountry box="[392,475,1231,1257]" name="Tunisia" pageId="4" pageNumber="293">Tunisia</collectingCountry>
and 
<collectingCountry box="[535,622,1231,1258]" name="Zambia" pageId="4" pageNumber="293">Zambia</collectingCountry>
) and America (
<collectingCountry box="[802,918,1231,1257]" name="Argentina" pageId="4" pageNumber="293">Argentina</collectingCountry>
, 
<collectingCountry box="[932,1003,1231,1257]" name="Brazil" pageId="4" pageNumber="293">Brazil</collectingCountry>
