<collectingCountry box="[1149,1239,1195,1221]" name="Malawi" pageId="4" pageNumber="293">Malawi</collectingCountry>
, 
<collectingCountry box="[1252,1328,1195,1221]" name="Morocco" pageId="4" pageNumber="293">Maroc</collectingCountry>
