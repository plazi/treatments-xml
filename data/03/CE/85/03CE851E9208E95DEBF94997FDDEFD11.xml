<emphasis bold="true" box="[151,495,1410,1437]" pageId="35" pageNumber="36">
<taxonomicName authority="Mah, 2022" authorityName="Mah" authorityYear="2022" box="[151,421,1410,1437]" class="Asteroidea" family="Goniasteridae" genus="Bathyceramaster" kingdom="Animalia" order="Valvatida" pageId="35" pageNumber="36" phylum="Echinodermata" rank="species" species="teres" status="n. sp.">
<emphasis bold="true" box="[151,421,1410,1437]" italics="true" pageId="35" pageNumber="36">Bathyceramaster teres</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[428,495,1411,1437]" pageId="35" pageNumber="36" rank="species">n. sp.</taxonomicNameLabel>
</emphasis>
