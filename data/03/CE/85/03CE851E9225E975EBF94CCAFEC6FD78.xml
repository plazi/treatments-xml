<emphasis bold="true" box="[151,456,223,249]" pageId="14" pageNumber="15">
<emphasis bold="true" box="[151,281,223,249]" italics="true" pageId="14" pageNumber="15">Freyastera</emphasis>
<bibRefCitation author="Downey, M. E." box="[289,456,223,249]" pageId="14" pageNumber="15" pagination="1 - 57" refId="ref46093" refString="Downey, M. E. (1986) Revision of the Atlantic Brisingida (Echinodermata: Asteroidea), with description of a new genus and family. Smithsonian Contributions to Zoology, 435, 1 - 57." type="journal article" year="1986">Downey 1986</bibRefCitation>
