<taxonomicName authority="Mah, 2022" authorityName="Mah" authorityYear="2022" box="[151,418,968,995]" class="Asteroidea" family="Goniasteridae" genus="Atheraster" kingdom="Animalia" order="Valvatida" pageId="27" pageNumber="28" phylum="Echinodermata" rank="species" species="symphonia" status="n. gen.">
<emphasis bold="true" box="[151,418,968,995]" italics="true" pageId="27" pageNumber="28">Atheraster symphonia</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[425,507,969,995]" pageId="27" pageNumber="28" rank="genus">n. gen.</taxonomicNameLabel>
