<keyLead box="[136,1451,1735,1757]" pageId="13" pageNumber="14">- Perigonial chambers aggregated in cushions or embedded in groups on dorsal surface of thallus or on short branches ..................3</keyLead>
</paragraph>
</keyStep>
<keyStep pageId="13" pageNumber="14">
<paragraph blockId="13.[136,1452,1707,2074]" pageId="13" pageNumber="14">
<keyLead pageId="13" pageNumber="14">
