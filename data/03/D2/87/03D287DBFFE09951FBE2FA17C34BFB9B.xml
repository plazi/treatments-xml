genus:
</emphasis>
<taxonomicName box="[302,423,1580,1606]" class="Arachnida" family="Assamiidae" genus="Filopalpus" kingdom="Animalia" order="Opiliones" pageId="2" pageNumber="223" phylum="Arthropoda" rank="genus" status="gen. nov.">
