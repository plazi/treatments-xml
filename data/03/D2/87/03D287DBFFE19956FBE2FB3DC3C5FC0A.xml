</taxonomicName>
<emphasis bold="true" box="[453,543,187,213]" pageId="4" pageNumber="225">
<taxonomicNameLabel box="[453,543,187,213]" pageId="4" pageNumber="225" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
and of 
<taxonomicName box="[627,714,188,213]" class="Arachnida" family="Assamiidae" genus="Filopalpus" kingdom="Animalia" order="Opiliones" pageId="4" pageNumber="225" phylum="Arthropoda" rank="species" species="niger" status="sp. nov.">
<emphasis box="[627,714,188,213]" italics="true" pageId="4" pageNumber="225">F. niger</emphasis>
</taxonomicName>
<emphasis bold="true" box="[721,811,187,213]" pageId="4" pageNumber="225">
<taxonomicNameLabel box="[721,811,187,213]" pageId="4" pageNumber="225" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
are unknown):
</paragraph>
</subSubSection>
