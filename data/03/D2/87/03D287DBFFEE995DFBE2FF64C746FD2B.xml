<taxonomicName box="[347,507,1325,1349]" class="Arachnida" family="Assamiidae" genus="Filopalpus" kingdom="Animalia" order="Opiliones" pageId="13" pageNumber="234" phylum="Arthropoda" rank="species" species="bale" status="sp. nov.">
