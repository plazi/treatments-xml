was formerly included in 
<taxonomicName box="[2064,2194,1796,1829]" class="Mammalia" family="Talpidae" genus="Uropsilus" kingdom="Animalia" order="Soricomorpha" pageId="2" pageNumber="597" phylum="Chordata" rank="species" species="gracilis">U. gracilis</taxonomicName>
