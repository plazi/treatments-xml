</subSubSection>
<subSubSection box="[1407,2121,2533,2566]" pageId="24" pageNumber="619" type="activity">
<paragraph blockId="24.[1407,2612,2060,2726]" box="[1407,2121,2533,2566]" pageId="24" pageNumber="619">
<emphasis bold="true" box="[1407,1642,2533,2566]" pageId="24" pageNumber="619">Activity patterns.</emphasis>
