<subSubSection pageId="22" pageNumber="617" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6678227" ID-Zenodo-Dep="6678227" httpUri="https://zenodo.org/record/6678227/files/figure.png" inLine="true" pageId="22" pageNumber="617" startId="22.[2029,2201,496,521]" targetBox="[1414,2005,300,714]" targetPageId="22">
<paragraph blockId="22.[2027,2623,299,717]" pageId="22" pageNumber="617">
<emphasis bold="true" box="[2029,2205,496,521]" pageId="22" pageNumber="617">Distribution.</emphasis>
E Nepal, Bhutan, NE India, and SW China (W Yunnan).
</paragraph>
</caption>
</subSubSection>
<subSubSection pageId="22" pageNumber="617" type="description">
<paragraph blockId="22.[2027,2623,299,717]" pageId="22" pageNumber="617">
<emphasis bold="true" box="[2029,2310,566,599]" pageId="22" pageNumber="617">Descriptive notes.</emphasis>
Head-body 128-135 mm, tail 5-9 mm, hindfoot 15-16 mm; weight 44-72 g. Tail is short and club-shaped. Dental formula is I 3/3, C
</paragraph>
<paragraph blockId="22.[1417,2622,725,1115]" box="[1421,1817,725,758]" pageId="22" pageNumber="617">1/1,P4/4,M 3/3 (x2) = 44.</paragraph>
</subSubSection>
<subSubSection box="[1418,2620,764,797]" pageId="22" pageNumber="617" type="biology_ecology">
<paragraph blockId="22.[1417,2622,725,1115]" box="[1418,2620,764,797]" pageId="22" pageNumber="617">
<emphasis bold="true" box="[1418,1529,764,797]" pageId="22" pageNumber="617">Habitat.</emphasis>
Subtropical and tropical forests in hills and plains up to elevations of ¢.2700 m.
</paragraph>
</subSubSection>
<subSubSection box="[1418,1919,804,837]" pageId="22" pageNumber="617" type="food_feeding">
<paragraph blockId="22.[1417,2622,725,1115]" box="[1418,1919,804,837]" pageId="22" pageNumber="617">
<emphasis bold="true" box="[1418,1680,804,837]" pageId="22" pageNumber="617">Food and Feeding.</emphasis>
No information.
</paragraph>
</subSubSection>
<subSubSection box="[1418,1792,844,877]" pageId="22" pageNumber="617" type="breeding">
