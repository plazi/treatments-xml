<subSubSection box="[199,944,2017,2043]" pageId="6" pageNumber="295" type="etymology">
<paragraph blockId="6.[151,1437,973,2043]" box="[199,944,2017,2043]" pageId="6" pageNumber="295">
<emphasis bold="true" box="[199,334,2017,2043]" pageId="6" pageNumber="295">Etymology.</emphasis>
