<paragraph blockId="21.[151,1436,1616,1823]" pageId="21" pageNumber="172">
<emphasis bold="true" box="[199,392,1688,1715]" pageId="21" pageNumber="172">Natural history.</emphasis>
<taxonomicName authorityName="Lesson" authorityYear="1830" box="[401,631,1688,1714]" class="Anthozoa" family="Actiniidae" genus="Phymactis" kingdom="Animalia" order="Actiniaria" pageId="21" pageNumber="172" phylum="Cnidaria" rank="species" species="papillosa">
<emphasis box="[401,631,1688,1714]" italics="true" pageId="21" pageNumber="172">Phymactis papillosa</emphasis>
