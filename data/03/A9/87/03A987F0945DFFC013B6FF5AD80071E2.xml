<subSubSection pageId="21" pageNumber="172" type="distribution">
<paragraph blockId="21.[151,1436,417,660]" pageId="21" pageNumber="172">
<emphasis bold="true" box="[199,353,561,587]" pageId="21" pageNumber="172">Distribution.</emphasis>
<collectingRegion box="[361,442,562,588]" country="El Salvador" name="La Paz" pageId="21" pageNumber="172">La Paz</collectingRegion>
, Sebastián Vizcaíno Bay, Punta Abreojos, Tecolote, 
<collectingRegion box="[1038,1259,562,588]" country="Mexico" name="Baja California Sur" pageId="21" pageNumber="172">Baja California Sur</collectingRegion>
and Puerto Peñasco, 
<collectingRegion box="[231,310,598,624]" country="Mexico" name="Sonora" pageId="21" pageNumber="172">Sonora</collectingRegion>
(
<bibRefCitation author="Daly, M." box="[328,465,598,624]" pageId="21" pageNumber="172" pagination="377 - 390" refId="ref12886" refString="Daly, M. (2004 a) Anatomy and Taxonomy of three species of sea anemones (Cnidaria: Anthozoa: Actiniidae) from the Gulf of California, including Isoaulactinia hespervolita Daly, n. sp. Pacific Science, 3, 377 - 390. https: // doi. org / 10.1353 / psc. 2004.0030" type="journal article" year="2004">Daly 2004a</bibRefCitation>
; 
<bibRefCitation author="Barragan, Y. &amp; Sanchez, C. &amp; Rodriguez, E." box="[479,720,598,624]" pageId="21" pageNumber="172" pagination="501 - 549" refId="ref12499" refString="Barragan, Y., Sanchez, C. &amp; Rodriguez, E. (2019) First inventory of sea anemones (Cnidaria: Actiniaria) from La Paz Bay, southern Gulf of California (Mexico). Zootaxa, 4559 (3), 501 - 549. https: // doi. org / 10.11646 / zootaxa. 4559.3.4" type="journal article" year="2019">
Barragán 
<emphasis box="[591,643,598,624]" italics="true" pageId="21" pageNumber="172">et al</emphasis>
. 2019
</bibRefCitation>
). This is the first record for Playa Esmeralda, 
<collectingRegion box="[1255,1432,598,624]" country="Mexico" name="Baja California" pageId="21" pageNumber="172">Baja California</collectingRegion>
, Cerritos, El Conejo and San Juanico, 
<collectingRegion box="[571,791,634,660]" country="Mexico" name="Baja California Sur" pageId="21" pageNumber="172">Baja California Sur</collectingRegion>
.
</paragraph>
