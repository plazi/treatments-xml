conductor, 
<emphasis box="[902,953,1981,2005]" italics="true" pageId="13" pageNumber="436">Eb—</emphasis>
base of embolus, 
<emphasis box="[1139,1196,1982,2005]" italics="true" pageId="13" pageNumber="436">Em—</emphasis>
