<taxonomicName authorityName="Nunes et al." authorityYear="2020" baseAuthorityName="Dallas" baseAuthorityYear="1851" box="[742,915,258,285]" class="Insecta" family="Pentatomidae" genus="Hypoxys" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hemiptera" pageId="17" pageNumber="518" phylum="Arthropoda" rank="species" species="triangularis">
