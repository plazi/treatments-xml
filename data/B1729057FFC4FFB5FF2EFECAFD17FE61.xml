Glotov
</taxonomicName>
, 
<taxonomicNameLabel id="109C4028FFC5FFB5FCD0FEB5FC5CFEA1" box="[856,916,272,298]" pageId="5" pageNumber="184" rank="species">sp. n.</taxonomicNameLabel>
is similar to 
<taxonomicName id="FEDB5AC2FFC5FFB5FBACFEB5FEEFFEC2" authority="Pace, 2003" authorityName="Pace" authorityYear="2003" class="Insecta" family="Staphylinidae" genus="Gyrophaena" kingdom="Animalia" order="Coleoptera" pageId="5" pageNumber="184" phylum="Arthropoda" rank="species" species="simplicitatis">
<emphasis id="0BAFFD53FFC5FFB5FBACFEB5FB18FEA2" box="[1060,1232,271,298]" italics="true" pageId="5" pageNumber="184">G. simplicitatis</emphasis>
<bibRefCitation id="5D4A5CB0FFC5FFB5FF26FE95FEEFFEC2" author="Pace, R." box="[174,295,303,330]" pageId="5" pageNumber="184" pagination="621 - 660" refId="ref4270" refString="Pace, R. Gyrophaenini della Cina (Coleoptera, Staphylinidae) // Revue Suisse de zoologie. - 2003. - 110. - P. 621 - 660." type="book chapter" year="2003">Pace, 2003</bibRefCitation>
</taxonomicName>
and allied species (
<taxonomicName id="FEDB5AC2FFC5FFB5FE77FE95FCABFEC1" authority="Eppelsheim, 1887" authorityName="Eppelsheim" authorityYear="1887" box="[511,867,303,330]" class="Insecta" family="Staphylinidae" genus="Gyrophaena" kingdom="Animalia" order="Coleoptera" pageId="5" pageNumber="184" phylum="Arthropoda" rank="species" species="fusicornis">
