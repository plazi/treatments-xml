</subSubSection>
<subSubSection id="FC8E653B874AB1101EE750E5F5A1F8E5" box="[1470,2613,1783,1816]" pageId="5" pageNumber="198" type="activity">
<paragraph id="B42B36B0874AB1101EE750E5F5A1F8E5" blockId="5.[1470,2680,719,2171]" box="[1470,2613,1783,1816]" pageId="5" pageNumber="198">
<emphasis id="86E0EAA2874AB1101EE750E5F93EF8E5" bold="true" box="[1470,1706,1783,1816]" pageId="5" pageNumber="198">Activity patterns.</emphasis>
