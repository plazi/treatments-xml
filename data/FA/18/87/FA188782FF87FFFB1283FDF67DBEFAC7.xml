<emphasis box="[1265,1353,1301,1323]" italics="true" pageId="16" pageNumber="517">P. inflexa</emphasis>
</taxonomicName>
<emphasis bold="true" box="[1360,1436,1301,1322]" pageId="16" pageNumber="517">
<taxonomicNameLabel box="[1360,1436,1301,1322]" pageId="16" pageNumber="517" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
</keyLead>
</paragraph>
</keyStep>
