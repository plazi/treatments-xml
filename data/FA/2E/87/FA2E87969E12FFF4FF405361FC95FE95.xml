, ♀ (paratype of 
<taxonomicName authority="Gusenleitner, 2006" authorityName="Gusenleitner" authorityYear="2006" box="[939,1322,1973,1997]" class="Insecta" family="Eumenidae" genus="Calligaster" kingdom="Animalia" order="Hymenoptera" pageId="7" pageNumber="131" phylum="Arthropoda" rank="species" species="zetteli">
