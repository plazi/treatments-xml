<taxonomicName authority="van der Vecht, 1963" authorityName="van der Vecht. The" authorityYear="1963" box="[346,775,1973,1997]" class="Insecta" family="Eumenidae" genus="Pseudozumia" kingdom="Animalia" order="Hymenoptera" pageId="7" pageNumber="131" phylum="Arthropoda" rank="species" species="gracilis">
