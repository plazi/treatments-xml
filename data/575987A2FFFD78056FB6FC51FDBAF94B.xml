Genus 
<taxonomicName id="18F04D37FFFD78056FCCFC51FDDBFC34" authority="Halstead, 1980" authorityName="Halstead" authorityYear="1980" box="[237,628,978,1005]" class="Insecta" family="Silvanidae" genus="Austronausibius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="1" pageNumber="138" phylum="Arthropoda" rank="genus">
<emphasis id="ED84EAA6FFFD78056FCCFC51FE1BFC35" bold="true" box="[237,436,978,1005]" italics="true" pageId="1" pageNumber="138">Austronausibius</emphasis>
<bibRefCitation id="BB614B45FFFD78056E9DFC50FDDBFC34" author="Halstead, D. G. H." box="[444,628,978,1005]" pageId="1" pageNumber="138" pagination="271 - 374" refId="ref5109" refString="Halstead, D. G. H. (1980) A revision of the genus Oryzaephilus Ganglbauer, including descriptions of related genera (Coleoptera: Silvanidae). Zoological Journal of the Linnean Society, 69, 271 - 374. https: // doi. org / 10.1111 / j. 1096 - 3642.1980. tb 01126. x" type="journal article" year="1980">Halstead, 1980</bibRefCitation>
