<subSubSection id="48D355CA8FE1FE6F48A753EFFC3BFA26" pageId="431" pageNumber="432" type="type_taxon">
<paragraph id="007606418FE1FE6F48A753EFFCD0FB2A" blockId="431.[151,1436,1218,1495]" box="[151,885,1218,1243]" pageId="431" pageNumber="432">
<emphasis id="32BDDA538FE1FE6F48A753EFFE83FB2B" bold="true" box="[151,294,1219,1243]" pageId="431" pageNumber="432">
<typeStatus id="DF72B8E38FE1FE6F48A753EFFF77FB2B" box="[151,210,1219,1243]" pageId="431" pageNumber="432">Type</typeStatus>
genus:
</emphasis>
<taxonomicName id="C7C97DC28FE1FE6F491D53EFFDC4FB2A" authority="Olmi, 2010" authorityName="Olmi" authorityYear="2010" box="[301,609,1218,1243]" class="Insecta" family="Dryinidae" genus="Ponomarenkoa" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="431" pageNumber="432" phylum="Arthropoda" rank="genus">
<emphasis id="32BDDA538FE1FE6F491D53EFFE72FB2B" box="[301,471,1219,1243]" italics="true" pageId="431" pageNumber="432">Ponomarenkoa</emphasis>
Olmi, 2010
</taxonomicName>
, by original designation.
</paragraph>
<paragraph id="007606418FE1FE6F48F753CAFA39FAD2" blockId="431.[151,1436,1218,1495]" pageId="431" pageNumber="432">
<emphasis id="32BDDA538FE1FE6F48F753CAFEE4FB0F" bold="true" box="[199,321,1254,1279]" pageId="431" pageNumber="432">Diagnosis.</emphasis>
<emphasis id="32BDDA538FE1FE6F497953CAFE27FB0E" box="[329,386,1254,1278]" italics="true" pageId="431" pageNumber="432">Male</emphasis>
(
<figureCitation id="98F21AC48FE1FE6F49A453CAFD96FB0E" box="[404,563,1254,1278]" captionStart="PLATE 137" captionStartId="432.[151,233,1981,2004]" captionTargetBox="[356,1229,203,1934]" captionTargetId="figure-41@432.[347,1240,175,1960]" captionTargetPageId="432" captionText="PLATE 137. Ponomarenkoa ellenbergeri sp. nov. A. Holotype. Length 2.7 mm. B. Paratype. Length 2.8 mm. C. Head in ventral view, holotype." figureDoi="http://doi.org/10.5281/zenodo.5278854" httpUri="https://zenodo.org/record/5278854/files/figure.png" pageId="431" pageNumber="432">Plate 137A–C</figureCitation>
): fully winged; occipital carina complete; antennae 10-segmented; fore wing with three cells enclosed by pigmented veins (costal, median and submedian); tibial spurs 1/2/2. 
<emphasis id="32BDDA538FE1FE6F4CFA5227FABBFAD3" box="[1226,1310,1291,1315]" italics="true" pageId="431" pageNumber="432">Female</emphasis>
: unknown.
</paragraph>
<paragraph id="007606418FE1FE6F48F75202FD70FAB6" blockId="431.[151,1436,1218,1495]" box="[199,725,1326,1351]" pageId="431" pageNumber="432">
<emphasis id="32BDDA538FE1FE6F48F75202FEC5FAB7" bold="true" box="[199,352,1326,1351]" pageId="431" pageNumber="432">Distribution.</emphasis>
Palaearctic and 
<collectingRegion id="C20DC8A38FE1FE6F4A285202FDD6FAB6" box="[536,627,1326,1350]" country="Democratic Republic of the Congo" name="Orientale" pageId="431" pageNumber="432">Oriental</collectingRegion>
regions.
</paragraph>
<paragraph id="007606418FE1FE6F48F7527FFE2BFA9A" blockId="431.[151,1436,1218,1495]" box="[199,398,1362,1387]" pageId="431" pageNumber="432">
<emphasis id="32BDDA538FE1FE6F48F7527FFEB4FA9B" bold="true" box="[199,273,1363,1387]" pageId="431" pageNumber="432">Hosts.</emphasis>
Unknown.
</paragraph>
<paragraph id="007606418FE1FE6F48F7525BFC0AFA7E" blockId="431.[151,1436,1218,1495]" box="[199,943,1398,1423]" pageId="431" pageNumber="432">
<emphasis id="32BDDA538FE1FE6F48F7525BFEC8FA7F" bold="true" box="[199,365,1398,1423]" pageId="431" pageNumber="432">World species</emphasis>
: two species are known, one in the 
<collectingRegion id="C20DC8A38FE1FE6F4ACD525AFC0EFA7E" box="[765,939,1398,1422]" country="Democratic Republic of the Congo" name="Orientale" pageId="431" pageNumber="432">Oriental region</collectingRegion>
.
</paragraph>
<paragraph id="007606418FE1FE6F48F752B7FE0AFA42" blockId="431.[151,1436,1218,1495]" box="[199,431,1434,1459]" pageId="431" pageNumber="432">
<emphasis id="32BDDA538FE1FE6F48F752B7FECEFA43" bold="true" box="[199,363,1435,1459]" pageId="431" pageNumber="432">World genera</emphasis>
. One.
</paragraph>
<paragraph id="007606418FE1FE6F48F75293FC3BFA26" blockId="431.[151,1436,1218,1495]" box="[199,926,1470,1495]" pageId="431" pageNumber="432">
<emphasis id="32BDDA538FE1FE6F48F75293FE9EFA27" bold="true" box="[199,315,1471,1495]" pageId="431" pageNumber="432">Remarks.</emphasis>
<taxonomicName id="C7C97DC28FE1FE6F49725292FDA9FA26" authorityName="Olmi" authorityYear="2010" box="[322,524,1470,1494]" class="Insecta" family="Dryinidae" kingdom="Animalia" order="Hymenoptera" pageId="431" pageNumber="432" phylum="Arthropoda" rank="subFamily" subFamily="Ponomarenkoinae">Ponomarenkoinae</taxonomicName>
are only known as fossils in amber.
</paragraph>
