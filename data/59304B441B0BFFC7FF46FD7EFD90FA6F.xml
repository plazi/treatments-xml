<subSubSection id="9983A9D91B0BFFC7FCA1FEBCFB32FCE1" pageId="21" pageNumber="532" type="distribution">
<caption id="85E6AADA1B0BFFC7FCA1FEBCFB32FCE1" ID-DOI="http://doi.org/10.5281/zenodo.6588306" ID-Zenodo-Dep="6588306" httpUri="https://zenodo.org/record/6588306/files/figure.png" inLine="true" pageId="21" pageNumber="532" targetBox="[206,797,447,861]" targetPageId="21">
<paragraph id="D126FA521B0BFFC7FCA1FEBCFB32FCE1" blockId="21.[821,1414,441,868]" pageId="21" pageNumber="532">
<emphasis id="E3ED26401B0BFFC7FCA1FEBCFC75FD32" bold="true" box="[821,997,717,750]" pageId="21" pageNumber="532">Distribution.</emphasis>
