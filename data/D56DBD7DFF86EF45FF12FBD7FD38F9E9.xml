: 
<emphasis id="6FB0D079FF86EF45FE08FB78FE51FB50" bold="true" box="[397,484,1229,1256]" pageId="46" pageNumber="47">
<collectingRegion id="9F00C289FF86EF45FE08FB78FE51FB50" box="[397,484,1229,1256]" country="Brazil" name="Parana" pageId="46" pageNumber="47">Paraná</collectingRegion>
