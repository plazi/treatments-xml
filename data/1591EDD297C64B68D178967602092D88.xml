<subSubSection id="C495535B34B9DDFA9BA68DDA947DB220" pageId="null" pageNumber="410" type="vernacular_names">
<paragraph id="96A2FF22F4F210323299A89792A4D3F9" pageId="null" pageNumber="410">Himbeere</paragraph>
</subSubSection>
</title>
<subSubSection id="95369F8112A6096C668880E025630D44" pageId="null" pageNumber="410" type="description">
<paragraph id="FE3D82165DBE71A9E5ABFF3FF87941CC" pageId="null" pageNumber="410">
<normalizedToken id="7A2CBFB7332BD49BC0F6130AAB3FB23E" originalValue="Sommergrüner" pageId="null" pageNumber="410">Sommergruener</normalizedToken>
Strauch. 
<normalizedToken id="78D81E3DDA2406B4D77951B584F49D29" originalValue="Schößling" pageId="null" pageNumber="410">Schoessling</normalizedToken>
aufrecht, rund, anfangs blau bereift, 
<normalizedToken id="8952CC9A10F6988DD54C12856C61BE0B" originalValue="spärlich" pageId="null" pageNumber="410">spaerlich</normalizedToken>
bis reichlich mit kleinen, bis 1 mm hohen, kegel- oder 
<normalizedToken id="B9B3B4F43943A21E77A59A62586AD8FF" originalValue="nadelförmigen" pageId="null" pageNumber="410">nadelfoermigen</normalizedToken>
, meist dunkelroten Stacheln besetzt. 
<emphasis id="FEFE329AD8FE2B74AECCE1D8C87101D9" italics="true" pageId="null" pageNumber="410">
<normalizedToken id="C08D13F9D297BCD8C5FDFD7D149A95C7" originalValue="Blätter" pageId="null" pageNumber="410">Blaetter</normalizedToken>
gefiedert
</emphasis>
, 7- 
<emphasis id="E5A5F2F2CC112CA0F091373E8F4FEEC6" italics="true" pageId="null" pageNumber="410">
oder 5 
<normalizedToken id="2F261836B9F8950D7ADF755C829CB081" originalValue="zählig" pageId="null" pageNumber="410">zaehlig</normalizedToken>
, selten nur 3 
<normalizedToken id="3A7D5083687D78FA64B3A21C0D432E62" originalValue="zählig" pageId="null" pageNumber="410">zaehlig</normalizedToken>
, mit 
<normalizedToken id="463A54EE2A2582405A5B655DC498D2F9" originalValue="endständigem" pageId="null" pageNumber="410">endstaendigem</normalizedToken>
Teilblatt
</emphasis>
, unterseits 
<normalizedToken id="B40BA99288C9F105D898A7AAC987A0F6" originalValue="weiß" pageId="null" pageNumber="410">weiss</normalizedToken>
, dicht filzig behaart, doppelt 
<normalizedToken id="4EE7204DF2EBC76DC6FD047AB05BDE55" originalValue="gezähnt" pageId="null" pageNumber="410">gezaehnt</normalizedToken>
; 
<normalizedToken id="8FAC7F6CE483F959FB8287AE341FBA8F" originalValue="Zähne" pageId="null" pageNumber="410">Zaehne</normalizedToken>
<normalizedToken id="758E2660F7DC6C28E958D07E2FB848D8" originalValue="allmählich" pageId="null" pageNumber="410">allmaehlich</normalizedToken>
zugespitzt oder stumpf und mit aufgesetzter Spitze; Endteilblatt oval, selten lanzettlich, am Grunde gelegentlich 
<normalizedToken id="0B08ECEEA01F5EAD344CFA6AC00977CA" originalValue="herzförmig" pageId="null" pageNumber="410">herzfoermig</normalizedToken>
. 
<normalizedToken id="5B2AE3690C9BE5CA01387AE0C3C5C7FC" originalValue="Blütenstand" pageId="null" pageNumber="410">Bluetenstand</normalizedToken>
rispig, 
<normalizedToken id="6E860CECD8F38661A35C78A726C1636D" originalValue="beblättert" pageId="null" pageNumber="410">beblaettert</normalizedToken>
. 
<normalizedToken id="E210A6A1BBBC9998B594004287E5DFC0" originalValue="Kelchblätter" pageId="null" pageNumber="410">Kelchblaetter</normalizedToken>
nach der 
<normalizedToken id="CDA911875A3A1489C5CCDEE3D21665B4" originalValue="Blüte" pageId="null" pageNumber="410">Bluete</normalizedToken>
abstehend oder 
<normalizedToken id="FB33FE56C53780F47829DB9151AA3044" originalValue="zurückgebogen" pageId="null" pageNumber="410">zurueckgebogen</normalizedToken>
. 
<normalizedToken id="E2680D59E836707F6EC07CA7A9545673" originalValue="Kronblätter" pageId="null" pageNumber="410">Kronblaetter</normalizedToken>
klein (etwa 0,5 cm lang), schmal oval, 
<normalizedToken id="78CDAE716170789451D385CCCA889AA4" originalValue="weiß" pageId="null" pageNumber="410">weiss</normalizedToken>
. 
<normalizedToken id="A876AF90CE60D0FB0BF7E0FFBEC68AF4" originalValue="Staubblätter" pageId="null" pageNumber="410">Staubblaetter</normalizedToken>
<normalizedToken id="2B84926095D303B3AC92B36DA05F9619" originalValue="kürzer" pageId="null" pageNumber="410">kuerzer</normalizedToken>
als die Griffel. 
<emphasis id="9D7E73E89DB1B8A96A8FF5159A87D895" italics="true" pageId="null" pageNumber="410">Reife Frucht rot</emphasis>
, 
<emphasis id="CF010B6128058C52F049007B29DB4E5D" italics="true" pageId="null" pageNumber="410">
<pageBreakToken id="CB58078C47F50C4A70F735F11FA9C533" pageId="null" pageNumber="410">sich</pageBreakToken>
vom 
<normalizedToken id="8AFEDC36FCA56976072AFC351B9E6457" originalValue="kegelförmigen" pageId="null" pageNumber="410">kegelfoermigen</normalizedToken>
<normalizedToken id="0129E3D305412B53831B1E5F48AEDE53" originalValue="Fruchtträger" pageId="null" pageNumber="410">Fruchttraeger</normalizedToken>
<normalizedToken id="0DC29337EEA834691EE0C5702B4C6A01" originalValue="lösend" pageId="null" pageNumber="410">loesend</normalizedToken>
, daher hohl
</emphasis>
(bei allen andern Arten unserer Flora Frucht mit dem 
<normalizedToken id="E0825FF0B06FB41385C511F5385A700F" originalValue="Fruchtträger" pageId="null" pageNumber="410">Fruchttraeger</normalizedToken>
abfallend). - 
<normalizedToken id="8514E3CC6C3F36073B63A88CBD5D729F" originalValue="Blüte" pageId="null" pageNumber="410">Bluete</normalizedToken>
: 
<normalizedToken id="A36ABA7687B7DC5FB62C5A415BD414CC" originalValue="Früher" pageId="null" pageNumber="410">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="FAA7904C665DF50470867012FACF502F" pageId="null" pageNumber="410">
<emphasis id="C05FDBCB7E5587BCCABA07149B1DD6AD" italics="true" pageId="null" pageNumber="410">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D8F1C53B5FC82E3FD73858F9EBA75726" italics="true" pageId="null" pageNumber="410">14:</emphasis>
Alle Angaben 
<normalizedToken id="D14DD2768C4D8412120BC300D4DCDBD1" originalValue="übereinstimmend" pageId="null" pageNumber="410">uebereinstimmend</normalizedToken>
(die zahlreichen Autoren von 
<normalizedToken id="9D7806F1A8BDC0139376DB8A733FC167" originalValue="Löve" pageId="null" pageNumber="410">Loeve</normalizedToken>
und 
<normalizedToken id="62784A5FA93595E48515ECE42279D64F" originalValue="Löve" pageId="null" pageNumber="410">Loeve</normalizedToken>
1961 zusammengestellt); sexuell normal (Gustafsson 1947). 
<emphasis id="FD9F12A3143551B27FF6B9EB4B790988" italics="true" pageId="null" pageNumber="410">2n</emphasis>
= 
<emphasis id="8E557FE05F243D04018E87B2A196B0F8" italics="true" pageId="null" pageNumber="410">21</emphasis>
, 
<emphasis id="02D253D0B3ABBF7E5480054B5BB3D755" italics="true" pageId="null" pageNumber="410">28:</emphasis>
<normalizedToken id="8B616FCB22A25AD72184D14ABFD031E1" originalValue="Gartenvarietäten" pageId="null" pageNumber="410">Gartenvarietaeten</normalizedToken>
; zytogenetische Untersuchungen von Pratt et al. (1958).
</paragraph>
<paragraph id="E338CF11668695695C030AB8089C569A" pageId="null" pageNumber="410">
<emphasis id="90E2454ADCBD23126523917F45DE8BAB" italics="true" pageId="null" pageNumber="410">Standort.</emphasis>
Kollin, montan, subalpin, selten alpin. 
<normalizedToken id="9BD1A34F4A1020580F55589059D8112C" originalValue="Nährstoffreiche" pageId="null" pageNumber="410">Naehrstoffreiche</normalizedToken>
, nicht trockene 
<normalizedToken id="B7A146A754280000A3B4723F9EFB1690" originalValue="Böden" pageId="null" pageNumber="410">Boeden</normalizedToken>
. 
<normalizedToken id="910A825B56FEDF8C29AE4DA0127BA53E" originalValue="Waldschläge" pageId="null" pageNumber="410">Waldschlaege</normalizedToken>
, gefestigte Schutthalden, Schluchten, Steinhaufen, Mauern.
</paragraph>
<paragraph id="BB9BC1F86273534FF8D4F1E019B0AA3B" pageId="null" pageNumber="410">
<emphasis id="BAC0C1EFB9965F0D0BD1E2DF1950F0F0" italics="true" pageId="null" pageNumber="410">Verbreitung. Eurosibirische Pflanze:</emphasis>
In Europa (ohne Island) und Sibirien 
<normalizedToken id="C39DBAAC224F3C59A2D4C08F1EE25158" originalValue="nordwärts" pageId="null" pageNumber="410">nordwaerts</normalizedToken>
bis 70° NB; 
<normalizedToken id="20C3E608B15EC41A82F2A0D1CE008C2F" originalValue="Südgrenze" pageId="null" pageNumber="410">Suedgrenze</normalizedToken>
durch Mittelspanien, Sizilien, Griechenland, Kaukasus, zentralasiatische Gebirge; 
<normalizedToken id="93DD58FE83F4CCF9875899E49C464FF3" originalValue="ostwärts" pageId="null" pageNumber="410">ostwaerts</normalizedToken>
bis ins Gebiet des Jenissei. In Ostasien und Nordamerika nahe verwandte Sippen. Verbreitungskarte von 
<taxonomicName id="ACBEC5B30563949A4844F18D2805A9CA" class="Magnoliopsida" family="Rosaceae" genus="Rubus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="410" phylum="Tracheophyta" rank="species" species="idaeus">
<emphasis id="D0825C4FF48C55DE5322EB9B1F18B597" italics="true" pageId="null" pageNumber="410">R. Idaeus</emphasis>
</taxonomicName>
s. 1. von Meusel et al. (1965). - Im Gebiet verbreitet und 
<normalizedToken id="969EAB2E5A1B8298CE464066BC70B8DA" originalValue="häufig" pageId="null" pageNumber="410">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
