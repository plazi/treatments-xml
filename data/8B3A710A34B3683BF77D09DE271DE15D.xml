<taxonomicName id="3DAB7B299985BF4AD93DAEF839452F6C" authority="L." class="Magnoliopsida" family="Lamiaceae" genus="Lamium" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="125" phylum="Tracheophyta" rank="species" species="maculatum">
