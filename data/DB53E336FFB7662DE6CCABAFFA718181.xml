<taxonomicName id="94FA29A3FFB7662AE753AA42FD94877B" authority="Greuter &amp; Burdet" authorityName="Greuter &amp; Burdet (Greuter &amp; Raus" authorityYear="1984" box="[279,590,1816,1842]" class="Magnoliopsida" family="Brassicaceae" genus="Fourraea" kingdom="Plantae" order="Brassicales" pageId="3" pageNumber="44" phylum="Tracheophyta" rank="genus">
