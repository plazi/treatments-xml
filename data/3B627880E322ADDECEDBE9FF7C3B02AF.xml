<subSubSection id="9DE800BC5C3F79B431B0A1C637848A29" pageId="null" pageNumber="340" type="description">
<paragraph id="E1747BA4BA46C954EB0229E780B11248" pageId="null" pageNumber="340">
Unterscheidet sich von 
<taxonomicName id="531A8FD444EE758BDD58A282FD5E8C69" class="Liliopsida" family="Poaceae" genus="Poa" kingdom="Plantae" order="Poales" pageId="null" pageNumber="340" phylum="Tracheophyta" rank="species" species="hybrida">
<emphasis id="B871456753D05F4B71DE0FED88228119" italics="true" pageId="null" pageNumber="340">P. hybrida</emphasis>
</taxonomicName>
(Nr. 16) durch folgende Merkmale: 
<emphasis id="921A7586708EA702258F909609D349D8" italics="true" pageId="null" pageNumber="340">
Oft kurze, oberirdische 
<normalizedToken id="4976954956A2C8B5E68AF2EF298E1C4D" originalValue="Ausläufer" pageId="null" pageNumber="340">Auslaeufer</normalizedToken>
vorhanden; alle 
<normalizedToken id="18D24A35B459BB0A52EA638C443EA89D" originalValue="Blätter" pageId="null" pageNumber="340">Blaetter</normalizedToken>
mit kurzer, 
<normalizedToken id="3FE62503A9E563A65F9878243E38125F" originalValue="kapuzenförmiger" pageId="null" pageNumber="340">kapuzenfoermiger</normalizedToken>
Spitze
</emphasis>
(wie 
<taxonomicName id="A9D91186E8E3CF8F74F8F28BBAD0AC08" authority="Nr." authorityName="Nr." class="Liliopsida" family="Poaceae" genus="Poa" kingdom="Plantae" order="Poales" pageId="null" pageNumber="340" phylum="Tracheophyta" rank="species" species="chaixii">
<emphasis id="E52F44E2A3A4028F3E6634D526FA44EC" italics="true" pageId="null" pageNumber="340">P. Chaixii</emphasis>
, Nr.
</taxonomicName>
17). 
<emphasis id="314BB5613114DCBA40DB8632CD500A14" italics="true" pageId="null" pageNumber="340">
<normalizedToken id="7076719C672F899CCC38F636DB1DF280" originalValue="Hüllspelzen" pageId="null" pageNumber="340">Huellspelzen</normalizedToken>
auf Kiel und Seitennerven rauh. -
</emphasis>
<normalizedToken id="00897ED1333128B10211E2A1D73C6FB5" originalValue="Blüte" pageId="null" pageNumber="340">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="D7B24082E414E31C7BF3E1D98CFAA398" pageId="null" pageNumber="340">
<emphasis id="C5F2CDCEF1006EDD92731AA0D634ACE9" italics="true" pageId="null" pageNumber="340">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="67440319C2AD13E26599DFC90174B3FE" italics="true" pageId="null" pageNumber="340">14:</emphasis>
Material aus Skandinavien (
<normalizedToken id="259590E82BFFA3B58E63BCE9C9BE4184" originalValue="Löve" pageId="null" pageNumber="340">Loeve</normalizedToken>
und 
<normalizedToken id="A4FCC319CB3D78B4D076FF48F7461156" originalValue="Löve" pageId="null" pageNumber="340">Loeve</normalizedToken>
1942b). 
<taxonomicName id="17CE3DD282B07E083A3B2C98C95A03CB" class="Liliopsida" family="Poaceae" genus="Poa" kingdom="Plantae" order="Poales" pageId="null" pageNumber="340" phylum="Tracheophyta" rank="species" species="remota">
<emphasis id="439377CC94A275BEE101C72F3B2007F9" italics="true" pageId="null" pageNumber="340">P. remota</emphasis>
</taxonomicName>
ist normal sexuell (
<normalizedToken id="72DD4BDBB3EE2ED2CDDF35C50DF5D9D0" originalValue="Almgård" pageId="null" pageNumber="340">Almgard</normalizedToken>
1960).
</paragraph>
<paragraph id="2B9D95D587A220FDBF6CA2FA45A13713" pageId="null" pageNumber="340">
<emphasis id="44707140B56AF0901B8F2F326B9DBE8B" italics="true" pageId="null" pageNumber="340">Standort.</emphasis>
Montan, seltener kollin und subalpin. Nasse, 
<normalizedToken id="DEEE5A5883C2B0BFCBF2DD6B801B04FF" originalValue="ständig" pageId="null" pageNumber="340">staendig</normalizedToken>
durchsickerte, humose 
<normalizedToken id="E01D246A8A28571AC6EA3A30F89B8BC2" originalValue="Böden" pageId="null" pageNumber="340">Boeden</normalizedToken>
in Mulden und 
<normalizedToken id="BB697287B2BBB71BB5CFD9DA8D342CF1" originalValue="Geländeeinschnitten" pageId="null" pageNumber="340">Gelaendeeinschnitten</normalizedToken>
(
<normalizedToken id="C7D8220D061E89018122719CDEDA41AD" originalValue="Gräben" pageId="null" pageNumber="340">Graeben</normalizedToken>
, Tobel). 
<normalizedToken id="E256E0945778736E89F27D2C32533EDD" originalValue="Schluchtwälder" pageId="null" pageNumber="340">Schluchtwaelder</normalizedToken>
, 
<normalizedToken id="D356F92AEBE1CB6DFF6818FF949BC560" originalValue="Bacheschenwälder" pageId="null" pageNumber="340">Bacheschenwaelder</normalizedToken>
.
</paragraph>
<paragraph id="C91A3F03A5B0C2E40E62F761BEE72AA1" pageId="null" pageNumber="340">
<emphasis id="3B64DDF51163098AA0891CDFF98D4EFC" italics="true" pageId="null" pageNumber="340">Verbreitung. Eurosibirische Pflanze:</emphasis>
<normalizedToken id="B86BC368EF1678FBFF535ED60E802F76" originalValue="Nordwärts" pageId="null" pageNumber="340">Nordwaerts</normalizedToken>
bis Mittelskandinavien, 
<normalizedToken id="6E3B44A278CE406AF6C375211529009F" originalValue="Südfinnland" pageId="null" pageNumber="340">Suedfinnland</normalizedToken>
, Baltikum, Norddeutschland, west- und 
<normalizedToken id="BEFCA180B310291202F8CE1D82BCC8AA" originalValue="südwärts" pageId="null" pageNumber="340">suedwaerts</normalizedToken>
bis Rhein, Alpen und Burgenland; Karpaten; Mittel- und 
<normalizedToken id="D1B905148A6CF876AAC83AA0736C5F1C" originalValue="Südrußland" pageId="null" pageNumber="340">Suedrussland</normalizedToken>
, Kaukasus; Sibirien (40-50° NB), 
<normalizedToken id="DC93AFB55E14A9F668FEF58392057091" originalValue="ostwärts" pageId="null" pageNumber="340">ostwaerts</normalizedToken>
bis Baikalseegebiet; Zentralasien und Mongolei. Verbreitungskarte von Meusel (1964). - Im Gebiet: Bremgartenwald bei Bern, Sihlwald bei 
<normalizedToken id="D89B0871DCA235616CFA80E05CDFA576" originalValue="Zürich" pageId="null" pageNumber="340">Zuerich</normalizedToken>
, Schwyz (
<normalizedToken id="6A9C6DFFC58BDC770AC35132C82952C6" originalValue="Wägital" pageId="null" pageNumber="340">Waegital</normalizedToken>
), St.Gallen (Murgtal, Wengital im Speergebiet, Wattwil im Toggenburg, Voralpsee bei Grabs), Appenzell (
<normalizedToken id="0FA7C19337068598E9D944E366FB2C1C" originalValue="Weißbad" pageId="null" pageNumber="340">Weissbad</normalizedToken>
), 
<normalizedToken id="0729D032AD4D7DFEE13F750055C246AB" originalValue="Südschwarzwald" pageId="null" pageNumber="340">Suedschwarzwald</normalizedToken>
, Baar (mehrfach), an der Wutach (Schaffhausen) (
<normalizedToken id="07C7F16DBD831A44F6A5022719D75CEF" originalValue="Bächtold" pageId="null" pageNumber="340">Baechtold</normalizedToken>
in lit. 1965), deutsches Bodenseegebiet; Unterengadin, 
<normalizedToken id="876B6CA8E3B01029259C1EDA8B71AB2D" originalValue="Münstertal" pageId="null" pageNumber="340">Muenstertal</normalizedToken>
; vereinzelt und selten; Verbreitung bleibt festzustellen.
</paragraph>
<paragraph id="421C7842709110BF6B36BEC9A82FED07" pageId="null" pageNumber="340">
<emphasis id="B6A0F052C1301E6F118C00D5DDF1FCCB" italics="true" pageId="null" pageNumber="340">Bemerkungen.</emphasis>
Die Populationen von 
<taxonomicName id="830234CA6F87569C5E049FC2F6C2553B" class="Liliopsida" family="Poaceae" genus="Poa" kingdom="Plantae" order="Poales" pageId="null" pageNumber="340" phylum="Tracheophyta" rank="species" species="remota">
<emphasis id="E66DF92E18A36ABB944A73E84FFD3EE8" italics="true" pageId="null" pageNumber="340">P. remota</emphasis>
</taxonomicName>
sind auffallend einheitlich.
</paragraph>
</subSubSection>
