<subSubSection id="810D2D24312002E605BEC47459659444" pageId="null" pageNumber="707" type="description">
<paragraph id="D511899F892F08F1FB890F0EC14CDCEB" pageId="null" pageNumber="707">
Unterscheidet sich von 
<taxonomicName id="6CFB86605FE84020512C7963C81DF08A" class="Magnoliopsida" family="Malvaceae" genus="Althaea" kingdom="Plantae" order="Malvales" pageId="null" pageNumber="707" phylum="Tracheophyta" rank="species" species="officinalis">
<emphasis id="D476500745737ABEC680CB52230ED322" italics="true" pageId="null" pageNumber="707">A. officinalis</emphasis>
</taxonomicName>
durch folgende Merkmale: 1 
<normalizedToken id="12F188CC0801360E72AB7D7EBFB685B7" originalValue="jährig" pageId="null" pageNumber="707">jaehrig</normalizedToken>
bis ausdauernd, bis 3 m hoch, zerstreut 
<emphasis id="331ABD39D47FB5FDAB6CD0F08BF108B4" italics="true" pageId="null" pageNumber="707">
mit borstigen Haaren besetzt; 
<normalizedToken id="B0B0F7A97DE4F46DC8D07707D1BB1D16" originalValue="Außenkelchblätter" pageId="null" pageNumber="707">Aussenkelchblaetter</normalizedToken>
breit 3eckig; 
<normalizedToken id="ECA0454626121C82B9E3E492D78C51EA" originalValue="Kronblätter" pageId="null" pageNumber="707">Kronblaetter</normalizedToken>
3-5 cm lang, 3-4mal so lang wie der Kelch.
</emphasis>
- 
<normalizedToken id="1A94F15A288E26A6A61441032F1A4BF6" originalValue="Blüte" pageId="null" pageNumber="707">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="965B360F34754E41C66D40FFBD9B5DA1" pageId="null" pageNumber="707">
<emphasis id="32D82417F876863E38D721D411D9755E" italics="true" pageId="null" pageNumber="707">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="DF658CC2A0D1C5E7CEFF69990DBB2142" italics="true" pageId="null" pageNumber="707">42:</emphasis>
Material aus botanischen 
<normalizedToken id="F3C7CC7CAC7F03C3C19F05E6421DE686" originalValue="Gärten" pageId="null" pageNumber="707">Gaerten</normalizedToken>
(Skovsted 1935Skovsted 1941).
</paragraph>
<paragraph id="8E316DC34C17F861C037E1879D007404" pageId="null" pageNumber="707">
<emphasis id="B1E9BF0292134F490C840F88338D471B" italics="true" pageId="null" pageNumber="707">Standort.</emphasis>
Kollin. Trockene 
<normalizedToken id="408E9FF2397DC080303B387C025D3266" originalValue="Böden" pageId="null" pageNumber="707">Boeden</normalizedToken>
in warmen Lagen. Weinberge, 
<normalizedToken id="7B1EFD5AAD41A95C62D10CEA7804D63C" originalValue="Äcker" pageId="null" pageNumber="707">Aecker</normalizedToken>
, Ruderalstellen.
</paragraph>
<paragraph id="7320AC5D478B1F89E45E1E2A7EE182F4" pageId="null" pageNumber="707">
<emphasis id="B7B198AC7600258269DEA53C84972D45" italics="true" pageId="null" pageNumber="707">Verbreitung.</emphasis>
<normalizedToken id="9546834A8CC09BE036686D4DAECA1557" originalValue="Ursprünglich" pageId="null" pageNumber="707">Urspruenglich</normalizedToken>
<emphasis id="725DE1B79772C73DA4144DF305F18156" italics="true" pageId="null" pageNumber="707">asiatische Pflanze:</emphasis>
<normalizedToken id="2E7FC7B164CBC6A0AEA35F66E0677497" originalValue="Westwärts" pageId="null" pageNumber="707">Westwaerts</normalizedToken>
bis ins 
<normalizedToken id="EC4427DF5E50228D8934592E41009CA3" originalValue="östliche" pageId="null" pageNumber="707">oestliche</normalizedToken>
Mittelmeergebiet, 
<normalizedToken id="5A3922177B54B14C678C5A142DD1C5B4" originalValue="ostwärts" pageId="null" pageNumber="707">ostwaerts</normalizedToken>
bis China. - Im Gebiet als alte Gartenpflanze selten verwildert und nur 
<normalizedToken id="61DF8812C35968FC6AC1AE473CF80887" originalValue="unbeständig" pageId="null" pageNumber="707">unbestaendig</normalizedToken>
.
</paragraph>
<paragraph id="1F1E3BC261615C7610440711B67C8B77" pageId="null" pageNumber="707">
<emphasis id="25E18C983EDF0C2C99ACFD7FB3AD215A" italics="true" pageId="null" pageNumber="707">
Bemerkungen. 
<taxonomicName id="66C743667A436870A2AEA7D79591488A" class="Magnoliopsida" family="Malvaceae" genus="Alcea" kingdom="Plantae" order="Malvales" pageId="null" pageNumber="707" phylum="Tracheophyta" rank="species" species="rosea">A. rosea</taxonomicName>
</emphasis>
ist mit Sicherheit in Westeuropa erst seit dem 16. Jahrhundert nachgewiesen.
</paragraph>
</subSubSection>
