<emphasis bold="true" box="[151,315,1944,1968]" pageId="3" pageNumber="66">FIGURES 1–5.</emphasis>
<taxonomicName authority="Zhang &amp; Sasan &amp; O’Kennon &amp; Kranz, 2022" authorityName="Zhang &amp; Sasan &amp; O’Kennon &amp; Kranz" authorityYear="2022" box="[322,456,1945,1969]" class="Insecta" family="Cynipidae" genus="Druon" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="66" phylum="Arthropoda" rank="species" species="laceyi" status="sp. nov.">
