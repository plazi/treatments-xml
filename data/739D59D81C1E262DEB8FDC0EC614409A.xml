<taxonomicName id="A2644394B91BCBB60C8340840C204682" authority="Pugsley" class="Magnoliopsida" family="Orobanchaceae" genus="Euphrasia" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="245" phylum="Tracheophyta" rank="species" species="cisalpina">
