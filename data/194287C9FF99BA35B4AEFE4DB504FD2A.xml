<subSubSection id="D9F16554FF99BA35B1A8F562B86AFDD1" box="[1466,2636,514,543]" pageId="37" pageNumber="656" type="activity">
<paragraph id="915436DFFF99BA35B1A8F562B86AFDD1" blockId="37.[1466,2673,274,745]" box="[1466,2636,514,543]" pageId="37" pageNumber="656">
<emphasis id="A39FEACDFF99BA35B1A8F562B483FDD1" bold="true" box="[1466,1701,514,543]" pageId="37" pageNumber="656">Activity patterns.</emphasis>
