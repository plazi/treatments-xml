<taxonomicName id="B88C4D6870D6FF30FB31E9D48F7EF85C" authorityName="Brues" authorityYear="1939" box="[1237,1397,1921,1945]" class="Insecta" family="Formicidae" genus="Ctenobethylus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="168" pageNumber="169" phylum="Arthropoda" rank="genus">
<emphasis id="4DF8EAF970D6FF30FB31E9D48F7EF85C" box="[1237,1397,1921,1945]" italics="true" pageId="168" pageNumber="169">Ctenobethylus</emphasis>
</taxonomicName>
by 
<bibRefCitation id="1B1D4B1A70D6FF30FF73E9F08B4DF878" author="Dlussky, G. M." box="[151,326,1957,1981]" pageId="168" pageNumber="169" pagination="616 - 627" refId="ref110477" refString="Dlussky, G. M. (1997) Genera of ants from Baltic Amber. Paleontological Journal, 31 (6), 616 - 627." type="journal article" year="1997">Dlussky (1997)</bibRefCitation>
