<bibRefCitation id="1B1D4B1A70D6FF30FC85E9D48E2FF85C" author="Shattuck, S. O." box="[865,1060,1921,1945]" pageId="168" pageNumber="169" pagination="13 - 18" refId="ref112320" refString="Shattuck, S. O. (1992 a) Review of the dolichoderine ant genus Iridomyrme x Mayr with descriptions of three new genera (Hymenoptera: Formicidae). Journal of the Australian Entomological Society, 31, 13 - 18." type="journal article" year="1992">
<taxonomicName id="B88C4D6870D6FF30FC85E9D489C8F85C" authority="Heterick &amp; Shattuck, 2011" authorityName="Heterick &amp; Shattuck" authorityYear="2011" box="[865,963,1921,1945]" genus="Shattuck" pageId="168" pageNumber="170" rank="genus" status="gen. n.">Shattuck</taxonomicName>
