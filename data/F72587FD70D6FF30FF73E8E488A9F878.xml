<taxonomicName id="B88C4D6870D6FF30FD40E9D7893BF85C" authorityName="Heterick &amp; Shattuck" authorityYear="2011" baseAuthorityName="Heterick &amp; Shattuck" baseAuthorityYear="2011" box="[676,816,1922,1945]" class="Insecta" family="Formicidae" genus="Liometopum" kingdom="Animalia" order="Hymenoptera" pageId="168" pageNumber="169" phylum="Arthropoda" rank="genus">
