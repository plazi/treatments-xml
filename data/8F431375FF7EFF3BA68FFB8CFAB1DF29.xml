</heading>
</paragraph>
<paragraph id="0755A263FF7EFF34A7ADFB13FCA9D917" blockId="231.[189,879,1276,1303]" box="[189,879,1276,1303]" pageId="231" pageNumber="232">
<taxonomicName id="C0EAD9E0FF7EFF34A7ADFB13FD8AD916" authority="(Fage, 1946)" baseAuthorityName="Fage" baseAuthorityYear="1946" box="[189,588,1276,1303]" class="Arachnida" family="Charinidae" genus="Weygoldtia" kingdom="Animalia" order="Amblypygi" pageId="231" pageNumber="232" phylum="Arthropoda" rank="species" species="davidovi">
<emphasis id="359E7E71FF7EFF34A7ADFB13FE6AD917" box="[189,428,1276,1302]" italics="true" pageId="231" pageNumber="232">Weygoldtia davidovi</emphasis>
(
<bibRefCitation id="637BDF92FF7EFF34A6ACFB13FD85D916" author="Fage L." box="[444,579,1276,1303]" firstAuthor="Fage" journalOrPublisher="Bulletin du Museum national d'histoire naturelle, Paris" pageId="231" pageNumber="232" pagination="256 - 267" part="2" refId="ref148108" refString="Fage L. 1946 a. Complement a la faune des arachnides de Madagascar. Bulletin du Museum national d'histoire naturelle, Paris 2: 256 - 267." title="Complement a la faune des arachnides de Madagascar" type="journal article" year="1946">Fage, 1946</bibRefCitation>
