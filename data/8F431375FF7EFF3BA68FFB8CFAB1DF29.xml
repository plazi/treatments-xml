<emphasis id="359E7E71FF71FF3BA5E4FD93FCCADE94" box="[756,780,636,661]" italics="true" pageId="232" pageNumber="233">sc</emphasis>
trichobothria and seven or eight 
<emphasis id="359E7E71FF71FF3BA380FD93FB62DE97" box="[1168,1188,636,662]" italics="true" pageId="232" pageNumber="233">sf</emphasis>
trichobothria...... ....................................................................................................... 
<taxonomicName id="C0EAD9E0FF71FF3BA4F8FD70FAB0DEBA" authority="(Fage, 1946)" baseAuthorityName="Fage" baseAuthorityYear="1946" box="[1000,1398,671,699]" class="Arachnida" family="Charinidae" genus="Weygoldtia" kingdom="Animalia" order="Amblypygi" pageId="232" pageNumber="233" phylum="Arthropoda" rank="species" species="davidovi">
<emphasis id="359E7E71FF71FF3BA4F8FD70FB1FDEBB" bold="true" box="[1000,1241,671,698]" italics="true" pageId="232" pageNumber="233">Weygoldtia davidovi</emphasis>
(
<bibRefCitation id="637BDF92FF71FF3BA3F9FD4FFAA8DEBA" author="Fage L." box="[1257,1390,672,699]" firstAuthor="Fage" journalOrPublisher="Bulletin du Museum national d'histoire naturelle, Paris" pageId="232" pageNumber="233" pagination="256 - 267" part="2" refId="ref148108" refString="Fage L. 1946 a. Complement a la faune des arachnides de Madagascar. Bulletin du Museum national d'histoire naturelle, Paris 2: 256 - 267." title="Complement a la faune des arachnides de Madagascar" type="journal article" year="1946">Fage, 1946</bibRefCitation>
