<subSubSection id="11B51789F189B5CEC92F07B3F882C1EF" pageId="null" pageNumber="482" type="description">
<paragraph id="BEFF3052F84951F27191CB0D2A962D62" pageId="null" pageNumber="482">
Unterscheidet sich von 
<taxonomicName id="A9854150891B80A969D28356CA05F3A5" class="Dothideomycetes" family="Metacapnodiaceae" genus="Antennaria" kingdom="Fungi" order="Capnodiales" pageId="null" pageNumber="482" phylum="Ascomycota" rank="genus">
<emphasis id="55AB3E4458E8A69A9406CA8CD60ECCBC" italics="true" pageId="null" pageNumber="482">Antennaria</emphasis>
</taxonomicName>
(S. 479) durch folgende Merkmale: 
<emphasis id="50C39E47ED242967AA9A7FB20D43CDAB" italics="true" pageId="null" pageNumber="482">
<normalizedToken id="1E2F1C6844B1BAE9C175E9085BA62D7E" originalValue="Gesamtblütenstand" pageId="null" pageNumber="482">Gesamtbluetenstand</normalizedToken>
von 5
</emphasis>
- 
<emphasis id="09FCC450382F34047C262F69A30E4C98" italics="true" pageId="null" pageNumber="482">
15 
<normalizedToken id="CBE18C930FBF3E726897AC67017182CB" originalValue="sternförmig" pageId="null" pageNumber="482">sternfoermig</normalizedToken>
ausgebreiteten, dicht 
<normalizedToken id="98BD9291D168C93A951F3B55D1E57913" originalValue="weißfilzig" pageId="null" pageNumber="482">weissfilzig</normalizedToken>
behaarten, lanzettlichen 
<normalizedToken id="1C14E603389E47D7C7EBFB56A67CDC03" originalValue="Blättern" pageId="null" pageNumber="482">Blaettern</normalizedToken>
umgeben; Pflanzen 
<normalizedToken id="D627B49F1CA20822B519B7136247043C" originalValue="einhäusig" pageId="null" pageNumber="482">einhaeusig</normalizedToken>
;
</emphasis>
<normalizedToken id="868C906248B87F90300874C66C2CCA72" originalValue="äußere" pageId="null" pageNumber="482">aeussere</normalizedToken>
<normalizedToken id="9E837D876E694C5E9BA387A9AC551CE5" originalValue="Blüten" pageId="null" pageNumber="482">Blueten</normalizedToken>
der 
<normalizedToken id="31606F1AE753CBB2CCB3DA05A7671448" originalValue="Köpfe" pageId="null" pageNumber="482">Koepfe</normalizedToken>
oder 
<normalizedToken id="7CBEDBBE713091CA288F0D5D93C73684" originalValue="äußere" pageId="null" pageNumber="482">aeussere</normalizedToken>
<normalizedToken id="ED5E1E1AEC27C5C609977C88B6964DCD" originalValue="Köpfe" pageId="null" pageNumber="482">Koepfe</normalizedToken>
des 
<normalizedToken id="78E266F268895EAA5A6B21A5AF38BAF1" originalValue="Gesamtblütenstandes" pageId="null" pageNumber="482">Gesamtbluetenstandes</normalizedToken>
wie bei den ♀ Pflanzen von 
<taxonomicName id="3FD120FA7E848396E7BEE048997B71E2" class="Dothideomycetes" family="Metacapnodiaceae" genus="Antennaria" kingdom="Fungi" order="Capnodiales" pageId="null" pageNumber="482" phylum="Ascomycota" rank="genus">
<emphasis id="AE7DC8C6FF7DDD602032BA3F17C5DFE1" italics="true" pageId="null" pageNumber="482">Antennaria</emphasis>
</taxonomicName>
(♀, 
<normalizedToken id="BECB65868E107C06D8B503D467D6D2BF" originalValue="fadenförmig" pageId="null" pageNumber="482">fadenfoermig</normalizedToken>
), innere 
<normalizedToken id="8FFC01658EEE0EA7332AC2709E00192B" originalValue="Blüten" pageId="null" pageNumber="482">Blueten</normalizedToken>
wie bei den ♂ Pflanzen von 
<taxonomicName id="44DABAAA321390F4F46EFEFA03E8FBF7" class="Dothideomycetes" family="Metacapnodiaceae" genus="Antennaria" kingdom="Fungi" order="Capnodiales" pageId="null" pageNumber="482" phylum="Ascomycota" rank="genus">
<emphasis id="FC04490909113D516DFEFB5F6135E0CD" italics="true" pageId="null" pageNumber="482">Antennaria</emphasis>
</taxonomicName>
(scheinbar ⚥, aber 
<emphasis id="C1341CC0BC6087129ECBE91AA5BD5EC4" italics="true" pageId="null" pageNumber="482">nur der Pollen fertil</emphasis>
, 
<normalizedToken id="89B08F5BF6FE1C865606F4A10609CDBB" originalValue="röhrenförmig" pageId="null" pageNumber="482">roehrenfoermig</normalizedToken>
), bisweilen auch ganz ungeschlechtlich (aber mit 
<normalizedToken id="A953F84C8CC874CBF1E8381E1C56E18E" originalValue="Honigdrüsen" pageId="null" pageNumber="482">Honigdruesen</normalizedToken>
).
</paragraph>
<paragraph id="B0CDD9B73550398BCBC96DD609623265" pageId="null" pageNumber="482">
Die Gattung 
<taxonomicName id="510EC40CF229F12D820C0912E1A0ABC2" class="Magnoliopsida" family="Asteraceae" genus="Leontopodium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="482" phylum="Tracheophyta" rank="genus">
<emphasis id="B306015C5CDBAA0D17A9B282ECB2BC12" italics="true" pageId="null" pageNumber="482">Leontopodium</emphasis>
</taxonomicName>
<normalizedToken id="AE1C937FA60B0BD1505D03645E3FC6E1" originalValue="umfaßt" pageId="null" pageNumber="482">umfasst</normalizedToken>
etwa 
<emphasis id="6B0A927904761FECC7CFC0F13886CBF3" italics="true" pageId="null" pageNumber="482">35 Arten</emphasis>
und ist 
<normalizedToken id="4C1082BDAFD756D00138C7C4FA346DDE" originalValue="hauptsächlich" pageId="null" pageNumber="482">hauptsaechlich</normalizedToken>
in 
<emphasis id="669ACD2048D8CB8D14434D53927782FB" italics="true" pageId="null" pageNumber="482">zentral- und ostasiatischen Gebirgen und Steppen</emphasis>
verbreitet. Monographische Bearbeitung von Handel-Mazzetti (1927). 
<emphasis id="75CB1CC1BC9D8BAFAB4F1BAAD74A23B3" italics="true" pageId="null" pageNumber="482">Chromosomengrundzahl:</emphasis>
n = 13.
</paragraph>
</subSubSection>
