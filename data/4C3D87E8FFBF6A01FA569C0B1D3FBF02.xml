<collectingCountry id="BC83766EFFBE6A01FCB994041DA7B94C" box="[837,935,605,638]" name="Taiwan" pageId="69" pageNumber="827">Taiwan</collectingCountry>
at ¢. 
<quantity id="036C9B1BFFBE6A01FC1A94041A53B94C" box="[998,1107,605,638]" metricMagnitude="3" metricUnit="m" metricValue="1.8" pageId="69" pageNumber="827" unit="m" value="1800.0">1800 m</quantity>
