<taxonomicName id="03944D7DFFBE6A01FC7494DD1A23B997" box="[904,1059,644,677]" class="Insecta" family="Scarabaeidae" genus="Coleoptera" kingdom="Animalia" order="Coleoptera" pageId="69" pageNumber="827" phylum="Arthropoda" rank="order">Coleoptera</taxonomicName>
, 
<taxonomicName id="03944D7DFFBE6A01FBCA94DD1AE2B997" box="[1078,1250,644,677]" class="Insecta" kingdom="Animalia" order="Lepidoptera" pageId="69" pageNumber="827" phylum="Arthropoda" rank="order">Lepidoptera</taxonomicName>
, and 
<taxonomicName id="03944D7DFFBE6A01FF8B94E91EE1B9FF" box="[119,225,688,717]" class="Insecta" kingdom="Animalia" order="Diptera" pageId="69" pageNumber="827" phylum="Arthropoda" rank="order">Diptera</taxonomicName>
.
</paragraph>
</subSubSection>
