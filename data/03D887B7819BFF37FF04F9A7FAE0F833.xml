<emphasis id="B905EAB3819BFF37FF31F97BFEC6F937" bold="true" box="[189,373,1739,1765]" pageId="180" pageNumber="181">Distribution:—</emphasis>
<collectingCountry id="F3667631819BFF37FEF9F97CFE57F934" box="[373,484,1740,1766]" name="Myanmar" pageId="180" pageNumber="181">Myanmar</collectingCountry>
