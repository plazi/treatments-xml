<bibRefCitation id="96794B084F3BFF97058AFAAAFD995330" author="Bott R" box="[402,519,1342,1364]" pageId="22" pageNumber="1290" pagination="209 - 352" refId="ref29250" refString="Bott R. 1955. Die Susswasserkrabben von Africa und ihre Stammesgeschichte. Annales du Musee Royal du Congo Belge serie 3: 209 - 352." type="journal article" year="1955">Bott, 1955</bibRefCitation>
)
</taxonomicName>
stat. nov., 
<taxonomicName id="35E84D7A4F3BFF970691FAAAFC945330" authority="Cumberlidge &amp; Daniels, 2022" authorityName="Cumberlidge &amp; Daniels" authorityYear="2022" box="[649,778,1343,1364]" class="Malacostraca" family="Potamonautidae" genus="Nesonautes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="22" pageNumber="1290" phylum="Arthropoda" rank="genus" status="gen. nov.">
<emphasis id="C09CEAEB4F3BFF970691FAAAFC945330" box="[649,778,1343,1364]" italics="true" pageId="22" pageNumber="1290">Nesonautes</emphasis>
</taxonomicName>
<taxonomicNameLabel id="DBAF57904F3BFF9704BBFACBFE9A5317" box="[163,260,1374,1395]" pageId="22" pageNumber="1290" rank="genus">gen. nov.</taxonomicNameLabel>
and 
<taxonomicName id="35E84D7A4F3BFF970524FAC8FE675316" authority="Cumberlidge &amp; Daniels, 2022" authorityName="Cumberlidge &amp; Daniels" authorityYear="2022" box="[316,505,1373,1394]" class="Malacostraca" family="Potamonautidae" genus="Occidensonautes" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="22" pageNumber="1290" phylum="Arthropoda" rank="genus" status="gen. nov.">
