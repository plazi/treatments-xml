<taxonomicName id="3D0A6F7786DE5F399C1A0746501C412F" authority="L." class="Liliopsida" family="Colchicaceae" genus="Colchicum" kingdom="Plantae" order="Liliales" pageId="null" pageNumber="547" phylum="Tracheophyta" rank="species" species="autumnale">
Colchicum 
<normalizedToken id="6C05C70C0322954B1E8CA6168F7C7A50" originalValue="autumnále" pageId="null" pageNumber="547">autumnale</normalizedToken>
<authorityName id="0F1FB2AE4462E7AE952B44BA78FBB1B5" pageId="null" pageNumber="547">L.</authorityName>
</taxonomicName>
</paragraph>
