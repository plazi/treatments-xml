<subSubSection id="8C8E6575FF9C6A23FA8F92911757BFDB" box="[1395,2391,1224,1257]" pageId="103" pageNumber="861" type="activity">
<paragraph id="C42B36FEFF9C6A23FA8F92911757BFDB" blockId="103.[1395,2606,711,1454]" box="[1395,2391,1224,1257]" pageId="103" pageNumber="861">
<emphasis id="F6E0EAECFF9C6A23FA8F9291185FBFDB" bold="true" box="[1395,1631,1224,1257]" pageId="103" pageNumber="861">Activity patterns.</emphasis>
