<taxonomicName authorityName="Koslowsky" authorityYear="1898" box="[270,400,519,545]" class="Reptilia" family="Liolaemidae" genus="Liolaemus" kingdom="Animalia" order="Squamata" pageId="47" pageNumber="48" phylum="Chordata" rank="species" species="boulengeri">
