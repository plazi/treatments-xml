<taxonomicName authorityName="Cabrera &amp; Bee de Speroni" authorityYear="1986" box="[1190,1436,1635,1660]" class="Reptilia" family="Liolaemidae" genus="Ceiolaemus" kingdom="Animalia" order="Squamata" pageId="46" pageNumber="47" phylum="Chordata" rank="subSpecies" species="anomalus" subSpecies="ditadai">
<emphasis box="[1190,1436,1635,1660]" italics="true" pageId="46" pageNumber="47">L. anomalus ditadai</emphasis>
</taxonomicName>
should be given full species status (see above comments for 
<taxonomicName authorityName="Laurent" authorityYear="1984" box="[859,1004,1675,1700]" class="Reptilia" family="Liolaemidae" genus="Ceiolaemus" kingdom="Animalia" order="Squamata" pageId="46" pageNumber="47" phylum="Chordata" rank="species" species="anomalus">
<emphasis box="[859,1004,1675,1700]" italics="true" pageId="46" pageNumber="47">L. anomalus</emphasis>
</taxonomicName>
).
</paragraph>
