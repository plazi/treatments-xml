<emphasis bold="true" box="[151,324,1063,1089]" pageId="44" pageNumber="45">
Group 
<taxonomicName authorityName="Valladares et al." authorityYear="2002" box="[241,324,1063,1089]" class="Reptilia" family="Liolaemidae" genus="Liolaemus" kingdom="Animalia" order="Squamata" pageId="44" pageNumber="45" phylum="Chordata" rank="species" species="reichei">
<emphasis bold="true" box="[241,324,1063,1089]" italics="true" pageId="44" pageNumber="45">reichei</emphasis>
</taxonomicName>
