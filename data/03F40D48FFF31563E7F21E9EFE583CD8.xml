<figureCitation id="1366A0DBFFF31562E7F21F7AFEA93C2C" box="[151,271,1807,1833]" captionStart="FIGURE 2" captionStartId="11.[151,250,1716,1740]" captionTargetBox="[152,1434,182,1693]" captionTargetId="figure-17@11.[151,1435,181,1693]" captionTargetPageId="11" captionText="FIGURE 2. A–C. Pristonesia querfil sp. nov.; D–F. Pristonesia sicril sp. nov.; G–I. Pristonesia tainatril sp. nov.. A, D, G. Habitus, lateral view; B, E, H. Head, dorsal view; C, F, I. Mesosoma, dorsal view. Scale bars = 100 µm." figureDoi="http://doi.org/10.5281/zenodo.6411089" httpUri="https://zenodo.org/record/6411089/files/figure.png" pageId="8" pageNumber="329">Figs 2D–F</figureCitation>
, 
<figureCitation id="1366A0DBFFF31562E67F1F7BFEFA3C2C" box="[282,348,1806,1833]" captionStart="FIGURE 5" captionStartId="14.[151,250,1930,1954]" captionTargetBox="[172,1421,359,1891]" captionTargetId="figure-102@14.[152,1436,345,1907]" captionTargetPageId="14" captionText="FIGURE 5. A–C. Pristonesia sicril sp. nov.; D–F. Pristonesia tainatril sp. nov.; G–I. Pristonesia uvenil sp. nov.. A, D, G. Hypopygium, external view; B, E, H. Genitalia, dorsal view; C, F, I. Genitalia, ventral view. Black = cupula; dark grey = ventral valvae; light grey = apical membranous bubble. Scale bars = 100 µm." figureDoi="http://doi.org/10.5281/zenodo.6410670" httpUri="https://zenodo.org/record/6410670/files/figure.png" pageId="8" pageNumber="329">5A–C</figureCitation>
