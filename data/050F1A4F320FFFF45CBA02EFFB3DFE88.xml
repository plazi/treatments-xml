T y p e s p e c i e s: 
<taxonomicName id="4AA6D0DA320FFFF75DA102A8FCDDFD29" authority="Fallen, 1817" authorityName="Fallen" authorityYear="1817" box="[437,809,721,747]" class="Insecta" family="Syrphidae" genus="Eristalis" kingdom="Animalia" order="Diptera" pageId="1" pageNumber="402" phylum="Arthropoda" rank="species" species="scutellatus">
