<taxonomicName id="4C114D4C6B2FFFB8FC37718BFCB481F4" authority="Lahille" authorityName="Lahille" authorityYear="1912" class="Mammalia" family="Phocoenidae" genus="Phocaena" kingdom="Animalia" order="Cetacea" pageId="3" pageNumber="542" phylum="Chordata" rank="species" species="dioptrica">Phocaena dioptrica Lahille, 1912</taxonomicName>
