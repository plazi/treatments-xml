<collectingRegion id="0650F81CFFC66A79FA0D91A3192BB321" box="[1521,1835,2042,2067]" country="Madagascar" name="Fianarantsoa" pageId="61" pageNumber="819">Fianarantsoa Province</collectingRegion>
.
</paragraph>
</subSubSection>
<subSubSection id="8C8E6575FFC66A79FA899E421405B30E" box="[1397,2565,2075,2108]" pageId="61" pageNumber="819" type="activity">
<paragraph id="C42B36FEFFC66A79FA899E421405B30E" blockId="61.[1397,2607,1522,2304]" box="[1397,2565,2075,2108]" pageId="61" pageNumber="819">
