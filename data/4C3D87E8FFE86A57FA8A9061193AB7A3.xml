<taxonomicName id="03944D7DFFE86A57F8259139166BBC4B" baseAuthorityName="Temminck" baseAuthorityYear="1838" box="[2009,2155,1888,1913]" class="Mammalia" family="Vespertilionidae" genus="Pipistrellus" kingdom="Animalia" order="Chiroptera" pageId="19" pageNumber="777" phylum="Chordata" rank="species" species="abramus">P. abramus</taxonomicName>
, 
<taxonomicName id="03944D7DFFE86A57F7819139171DBC4B" baseAuthorityName="Gray" baseAuthorityYear="1838" box="[2173,2333,1888,1913]" class="Mammalia" family="Vespertilionidae" genus="Pipistrellus" kingdom="Animalia" order="Chiroptera" pageId="19" pageNumber="777" phylum="Chordata" rank="species" species="javanicus">P. javanicus</taxonomicName>
, and 
<taxonomicName id="03944D7DFFE86A57F68D9139142ABC4B" baseAuthorityName="Gray" baseAuthorityYear="1838" box="[2417,2602,1888,1913]" class="Mammalia" family="Vespertilionidae" genus="Pipistrellus" kingdom="Animalia" order="Chiroptera" pageId="19" pageNumber="777" phylum="Chordata" rank="species" species="coromandra">P. coromandra</taxonomicName>
in Asia rather than western 
<taxonomicName id="03944D7DFFE86A57F6A3912617EABC92" authorityName="Kaup" authorityYear="1829" box="[2399,2538,1919,1952]" class="Mammalia" family="Vespertilionidae" genus="Pipistrellus" kingdom="Animalia" order="Chiroptera" pageId="19" pageNumber="777" phylum="Chordata" rank="genus">Pipistrellus</taxonomicName>
that are closer geographically. Monotypic.
</subSubSection>
</paragraph>
