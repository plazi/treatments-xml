1860. 
<taxonomicName id="8DDC4D70FFFFFFBEFC289E206DA67F18" authority="REUSS" authorityName="REUSS" box="[898,1195,612,634]" class="Nodosariata" family="Nodosariidae" genus="Frondicularia" kingdom="Chromista" order="Nodosariida" pageId="18" pageNumber="32" phylum="Foraminifera" rank="species" species="goldfussi">
<emphasis id="78A8EAE1FFFFFFBEFC289E206D6B7F18" box="[898,1126,612,633]" italics="true" pageId="18" pageNumber="32">Frondicularia goldfussi</emphasis>
