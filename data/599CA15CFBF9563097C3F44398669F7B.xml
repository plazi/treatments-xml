<taxonomicName id="CDB3DD68E5AF31A8AF41A8F8508E8DB3" class="Pinopsida" family="Pinaceae" genus="Abies" kingdom="Plantae" lsidName="Abies guatemalensis" order="Pinales" pageId="0" pageNumber="55" phylum="Tracheophyta" rank="species" species="guatemalensis">
<emphasis id="F34F98DF0FB6844E9DD25DC137216EE0" italics="true" pageId="0" pageNumber="55">Abies guatemalensis</emphasis>
