mixed forest, putatively associated with 
<taxonomicName id="61CF66631D94D818BD2B73454B33AC15" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" lsidName="Quercus laurina" order="Fagales" pageId="0" pageNumber="55" phylum="Tracheophyta" rank="species" species="laurina">
<emphasis id="8A26799EB9AF637A85677242B84DE0E4" italics="true" pageId="0" pageNumber="55">Quercus laurina</emphasis>
