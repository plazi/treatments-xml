, 
<taxonomicName id="84A0B87FBE4D2179E75C2C954C92BB26" class="Pinopsida" family="Pinaceae" genus="Pinus" kingdom="Plantae" lsidName="Pinus pseudostrobus" order="Pinales" pageId="0" pageNumber="55" phylum="Tracheophyta" rank="species" species="pseudostrobus">
<emphasis id="CC81F6427D67DDF7A54935AF1353D92F" italics="true" pageId="0" pageNumber="55">Pinus pseudostrobus</emphasis>
