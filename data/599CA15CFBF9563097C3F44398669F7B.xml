<normalizedToken id="12E1A4354269DA860312C0B1A1F9CE0D" originalValue="µm">µm</normalizedToken>
). 
<emphasis id="1E896151B1A5C86923D1776A0BE52CFD" bold="true" pageId="0" pageNumber="55">Hymenophoral trama</emphasis>
boletoid; hyphae cylindrical 3-15 
<normalizedToken id="D07B6F76097C614AE52EB876978863C7" originalValue="µm">µm</normalizedToken>
