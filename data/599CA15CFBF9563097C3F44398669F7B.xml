<taxonomicName id="7B4646EA103B6D6290973C15B01AA1AA" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" lsidName="Quercus laurina" order="Fagales" pageId="0" pageNumber="55" phylum="Tracheophyta" rank="species" species="laurina">
<emphasis id="C78B4976F6EED6F21C70815FCD113CE8" italics="true" pageId="0" pageNumber="55">Quercus laurina</emphasis>
