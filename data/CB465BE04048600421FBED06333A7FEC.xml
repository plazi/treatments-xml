<subSubSection id="C08B3DEA2DBA8E637A6922C0C06874E2" pageId="null" pageNumber="590" type="description">
<paragraph id="7191BC759770230A6F9CF7FB365501EB" pageId="null" pageNumber="590">
1- bis 
<normalizedToken id="0BDD3BCE9F1D39CCBB1F4BF2A3361CE5" originalValue="mehrjährig" pageId="null" pageNumber="590">mehrjaehrig</normalizedToken>
. 
<normalizedToken id="8C29E416EBB5C94939F2C80AC38F646B" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
in mehreren Reihen, 
<emphasis id="A9CD95E61993010C0BA6642A5426EAFD" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="D7EB7A5EF463F6E3F92D731F41604F88" originalValue="fadenförmig" pageId="null" pageNumber="590">fadenfoermig</normalizedToken>
</emphasis>
. Boden des 
<normalizedToken id="EA442CCF355B923F43BCD9092DA76918" originalValue="Blütenkopfes" pageId="null" pageNumber="590">Bluetenkopfes</normalizedToken>
kahl. 
<normalizedToken id="A0569C62C185FFE35EFFCE4B0C3100F7" originalValue="Äußere" pageId="null" pageNumber="590">Aeussere</normalizedToken>
<normalizedToken id="44B56E6F61084C4079419FD21EBF6ED8" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
gelb, 
<emphasis id="A1C35C4B4DB15F3FBB3273A11E2C0AD9" italics="true" pageId="null" pageNumber="590">die innern oft braun oder rot</emphasis>
. 
<normalizedToken id="C835C1C8C4347863D87536F7B6EF5174" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
zylindrisch, kantig, 
<normalizedToken id="871153B7F8E17676E124817CCBDE45A4" originalValue="ungeschnäbelt" pageId="null" pageNumber="590">ungeschnaebelt</normalizedToken>
. 
<emphasis id="0005C01F6DC3AA3743E9674F22DC15E5" italics="true" pageId="null" pageNumber="590">
<taxonomicName id="7650CBF7AD64AFB3976CE9DE383448CB" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
aus einem Kranz kurzer Borsten und oft noch einzelnen 
<normalizedToken id="51945C99DAB9CE471121F5E5F6D9BE51" originalValue="längeren" pageId="null" pageNumber="590">laengeren</normalizedToken>
Borsten bestehend
</emphasis>
.
</paragraph>
<paragraph id="5154BD3D5BDCAB7086BEA2FAFCCAA32D" pageId="null" pageNumber="590">
Die Gattung 
<taxonomicName id="18EE5B3122A8B0E476ECB77BE4410BBA" class="Magnoliopsida" family="Asteraceae" genus="Tolpis" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="genus">
<emphasis id="8F4925A1BB5762A3DCF649DFC38C4C4A" italics="true" pageId="null" pageNumber="590">Tolpis</emphasis>
</taxonomicName>
<normalizedToken id="08A7B81756B105EF8276B6A0B69C4CF5" originalValue="umfaßt" pageId="null" pageNumber="590">umfasst</normalizedToken>
etwa 
<emphasis id="D42F79147A7766671965084ACEB00735" italics="true" pageId="null" pageNumber="590">20 Arten</emphasis>
, die vor allem 
<emphasis id="9235E06CE0133AA8A7FF5D7535AA13E0" italics="true" pageId="null" pageNumber="590">im Mittelmeergebiet verbreitet</emphasis>
sind.
</paragraph>
