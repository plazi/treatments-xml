<subSubSection id="7BE6D5A6AB4ED753A2227C60F21F1A25" pageId="null" pageNumber="147" type="description">
<paragraph id="A6855DA880829C2996E16FA979A8A7A0" pageId="null" pageNumber="147">
Unterscheidet sich von 
<taxonomicName id="516E0CA9B1CBB9D257B5E699E9AA2C4A" class="Magnoliopsida" family="Brassicaceae" genus="Capsella" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="147" phylum="Tracheophyta" rank="species" species="bursa-pastoris">
<emphasis id="4B2121E15AB608D17C150A972FD2B55A" italics="true" pageId="null" pageNumber="147">C. Bursa-pastoris</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale; 
<normalizedToken id="B6208E87AC6A3F15F32876795A9F439E" originalValue="Kelchblätter" pageId="null" pageNumber="147">Kelchblaetter</normalizedToken>
<normalizedToken id="48756C821E9AA0891169C19991E10505" originalValue="rötlich" pageId="null" pageNumber="147">roetlich</normalizedToken>
; 
<emphasis id="A8C7CD1073695AF3712BC2B240BA5CFB" italics="true" pageId="null" pageNumber="147">
<normalizedToken id="3B6B327D7FB7FA297508ADB5C044C593" originalValue="Kronblätter" pageId="null" pageNumber="147">Kronblaetter</normalizedToken>
1,5-2 mm lang, oft 
<normalizedToken id="D5228A5A9E894DB1527A9626DB2403EC" originalValue="rötlich" pageId="null" pageNumber="147">roetlich</normalizedToken>
;
</emphasis>
Fruchtstiele fast waagrecht abstehend; 
<emphasis id="145C07D013974D604A3ECDB973B4624C" italics="true" pageId="null" pageNumber="147">
<normalizedToken id="953DCFEB662706901B330D3A6F9BA2CD" originalValue="Früchte" pageId="null" pageNumber="147">Fruechte</normalizedToken>
4-6 mm lang, mit etwas konkaven seitlichen 
<normalizedToken id="CFC2040DEAC45FE7CBCE53FACCE225B0" originalValue="Rändern" pageId="null" pageNumber="147">Raendern</normalizedToken>
; Griffel 0,2-0,3 mm lang;
</emphasis>
Samen 0,7-0,8 mm lang. - 
<normalizedToken id="32B658D847708DE89D69F04B6DF24EA3" originalValue="Blüte" pageId="null" pageNumber="147">Bluete</normalizedToken>
: 
<normalizedToken id="F95C1243BB6A66B55BF631C2BB048C90" originalValue="Frühling" pageId="null" pageNumber="147">Fruehling</normalizedToken>
bis Herbst.
</paragraph>
<paragraph id="4CFEEFB858A65FBE43E1DC4EB0E787C3" pageId="null" pageNumber="147">
<emphasis id="7EC44D4B2A85E440672E915C5632E27A" italics="true" pageId="null" pageNumber="147">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="8987818A7A7BDFE1D20F0A8FD943A837" italics="true" pageId="null" pageNumber="147">16:</emphasis>
Material aus den USA (Hill 1927), aus dem Mittelmeergebiet (Shull 1937), aus Italien (Negodi 1950).
</paragraph>
<paragraph id="967C497400A4CCB7AE992FCACA95005D" pageId="null" pageNumber="147">
<emphasis id="F2EEE676D37E508F4E3AC894005CF8EB" italics="true" pageId="null" pageNumber="147">Standort.</emphasis>
Kollin, seltener montan. 
<normalizedToken id="C06B6CA15742794A4F26C715B16D4675" originalValue="Nährstoffreiche" pageId="null" pageNumber="147">Naehrstoffreiche</normalizedToken>
, lehmige 
<normalizedToken id="AC0EA170429CF4970ADDF1273EDEA697" originalValue="Böden" pageId="null" pageNumber="147">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="24D1B5BB0BB2336F1A6DFA4CF4E82A81" originalValue="Äcker" pageId="null" pageNumber="147">Aecker</normalizedToken>
, Felder, Wege, 
<normalizedToken id="DC1217C9B5B946060438F77EC4F10F74" originalValue="Schuttplätze" pageId="null" pageNumber="147">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="D6B19491049C612E163874209BD2F331" pageId="null" pageNumber="147">
<emphasis id="F876019B91556A50071B559180B122B6" italics="true" pageId="null" pageNumber="147">Verbreitung.</emphasis>
<normalizedToken id="BEA8B31917149B7337C129271A1379E2" originalValue="Ursprünglich" pageId="null" pageNumber="147">Urspruenglich</normalizedToken>
<emphasis id="D1F9141D964E4D0655D96E8A8FF4CABF" italics="true" pageId="null" pageNumber="147">mediterrane Pflanze</emphasis>
, heute 
<normalizedToken id="333FD1139843375CAFAFEEC003060B9A" originalValue="über" pageId="null" pageNumber="147">ueber</normalizedToken>
die warm 
<normalizedToken id="098C26D8F2B00A0AC07C365CFA6E9B25" originalValue="gemäßigten" pageId="null" pageNumber="147">gemaessigten</normalizedToken>
Gebiete der ganzen Erde verbreitet. - Im Gebiet im 
<normalizedToken id="83AF1315E89E0B985BB4D79F3A9FC24A" originalValue="südlichen" pageId="null" pageNumber="147">suedlichen</normalizedToken>
und westlichen Teil zerstreut, sonst gelegentlich adventiv.
</paragraph>
</subSubSection>
