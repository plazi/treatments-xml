<subSubSection id="40BDAFD0E0DF0555E2A9EE27E94DE538" pageId="null" pageNumber="199" type="vernacular_names">
<paragraph id="F1DF2DC06E71648DFC4C69DFB87C7219" pageId="null" pageNumber="199">Behaartes Schaumkraut, Vielstengliges Schaumkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="9EDC5900D56E8CDBE4D5D877345161A2" pageId="null" pageNumber="199" type="description">
<paragraph id="08AA364C8FC250C3094074E7B417883E" pageId="null" pageNumber="199">
1-2 
<normalizedToken id="6BC413F2FCE9BF96A1AE3EB702B5CCD0" originalValue="jährig" pageId="null" pageNumber="199">jaehrig</normalizedToken>
, mit Pfahlwurzel; 5-30 cm hoch. Stengel aufrecht, meist am Grunde verzweigt, kantig, 
<emphasis id="0ECB6439182AD27234587EACB9704447" italics="true" pageId="null" pageNumber="199">meist kahl.</emphasis>
<normalizedToken id="66A3A0E993325143F25C975D049CC3B5" originalValue="Grundständige" pageId="null" pageNumber="199">Grundstaendige</normalizedToken>
<normalizedToken id="308B811C048742C5AB569AF6BF5D38E0" originalValue="Blätter" pageId="null" pageNumber="199">Blaetter</normalizedToken>
rosettenartig angeordnet, gestielt, mit 4-8 seitlichen 
<normalizedToken id="C5B70CBB8E8DE6ADEC2A45AF9CCF49C3" originalValue="Teilblättern" pageId="null" pageNumber="199">Teilblaettern</normalizedToken>
und etwas 
<normalizedToken id="F77B634281122D735C6CAAC1C630B36E" originalValue="größerem" pageId="null" pageNumber="199">groesserem</normalizedToken>
, rundlichem bis 
<normalizedToken id="F6155DB5FCADDD6B954C17C0EEDFA133" originalValue="nierenförmigem" pageId="null" pageNumber="199">nierenfoermigem</normalizedToken>
oder eckigem Endteilblatt, 
<emphasis id="1F908DE38C5019227BFE70BC605DBD1F" italics="true" pageId="null" pageNumber="199">
zur Fruchtzeit vorhanden. 
<normalizedToken id="17627F5DFEDAC728A0E58D98E98E0B18" originalValue="Stengelblätter" pageId="null" pageNumber="199">Stengelblaetter</normalizedToken>
2-4
</emphasis>
, gefiedert, mit schmalen oder breiten 
<normalizedToken id="32B588BC879F6FCE4420EF5DEDF1B838" originalValue="Teilblättern" pageId="null" pageNumber="199">Teilblaettern</normalizedToken>
, den Stengel nicht umfassend, 
<emphasis id="1880EE21521E816B67307A870A92E82C" italics="true" pageId="null" pageNumber="199">
besonders am Blattstiel und an den 
<normalizedToken id="6FD8900B42589039C2C0C1A0E7E032AC" originalValue="Rändern" pageId="null" pageNumber="199">Raendern</normalizedToken>
mit einzelnen 0,5-0,8 mm langen Haaren.
</emphasis>
<normalizedToken id="9A2FE3E5909712E68EEDD18DD8B2F369" originalValue="Kelchblätter" pageId="null" pageNumber="199">Kelchblaetter</normalizedToken>
1,5-2 mm lang, meist kahl. 
<normalizedToken id="C25D7DF24C815155CB815F6CD826C6F0" originalValue="Kronblätter" pageId="null" pageNumber="199">Kronblaetter</normalizedToken>
2,5-3,5 mm lang, 
<normalizedToken id="FCA4067698D2B7441CF9ADF251288F64" originalValue="weiß" pageId="null" pageNumber="199">weiss</normalizedToken>
, selten nicht vorhanden. 
<emphasis id="CF170E3C9E1680BB62597E95DBBC241C" italics="true" pageId="null" pageNumber="199">
<normalizedToken id="3D10D8E1C83CC285DF1EE8FEC5685F6E" originalValue="Staubblätter" pageId="null" pageNumber="199">Staubblaetter</normalizedToken>
oft nur 4
</emphasis>
(bei den andern Arten der Gattung meist 6). Staubbeutel gelb. 
<emphasis id="5BA2DD83DFE3252133D1018ACB5E964B" italics="true" pageId="null" pageNumber="199">Fruchtstiele</emphasis>
<normalizedToken id="882070AFF5A944D26710CDD5E62DA570" originalValue="½" pageId="null" pageNumber="199">1/2</normalizedToken>
-⅔ 
<emphasis id="9540C4C1E2F48DD5F006249E682BA83E" italics="true" pageId="null" pageNumber="199">
so lang wie die 
<normalizedToken id="A66A300258EC97DC0AACBC75F8E11D97" originalValue="Früchte" pageId="null" pageNumber="199">Fruechte</normalizedToken>
.
</emphasis>
<normalizedToken id="FC25723E139D78429D57DB012916B744" originalValue="Früchte" pageId="null" pageNumber="199">Fruechte</normalizedToken>
18-25 mm lang und ca. 1 nun dick. 
<emphasis id="A7D7859ACC873EBE9E5ACCDE745C50BD" italics="true" pageId="null" pageNumber="199">Griffel an der Frucht 0,3-0,5 mm lang.</emphasis>
- 
<normalizedToken id="F83160E6F50BD46937CB8C5086299269" originalValue="Blüte" pageId="null" pageNumber="199">Bluete</normalizedToken>
: 
<normalizedToken id="72FBF3BB166DC163DEB1C35581EB9699" originalValue="Frühling" pageId="null" pageNumber="199">Fruehling</normalizedToken>
, oft ein 2. Mal im Herbst.
</paragraph>
<paragraph id="5C298F06F275F1753228A3D1DE9C7DE5" pageId="null" pageNumber="199">
<emphasis id="1D5FDEF824D56C71BE45E6D61FBB40AD" italics="true" pageId="null" pageNumber="199">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5C59956012DB1B3BADBFA25256C733D2" italics="true" pageId="null" pageNumber="199">16:</emphasis>
Material von verschiedenen Stellen aus Europa (Manton 1932, Banach-Pogan 1955. 
<normalizedToken id="31C9E5E46C271EB00CB18A9DE18CA702" originalValue="Löve" pageId="null" pageNumber="199">Loeve</normalizedToken>
und 
<normalizedToken id="BDB5FFB55C57F1D37DEFA3AB4AE1BB21" originalValue="Löve" pageId="null" pageNumber="199">Loeve</normalizedToken>
1956b, 
<normalizedToken id="4968C2A2D2F68D042BCF5BE28CB80FA0" originalValue="Lövkvist" pageId="null" pageNumber="199">Loevkvist</normalizedToken>
1957, Larsen 1960a, Gadella und Kliphuis 1966), aus Neuseeland (Pritchard 1957), aus Kanada (Mulligan 1965), aus Australien (Thurling 1968).
</paragraph>
<paragraph id="426407A7F40904254C5688E1338F2DDB" pageId="null" pageNumber="199">
<emphasis id="9D08F75FD917A5DEC828C4AA0C9CA9CB" italics="true" pageId="null" pageNumber="199">Standort.</emphasis>
Kollin und montan, selten subalpin. Offene, lockere, ziemlich feuchte, 
<normalizedToken id="98C612FE478D768472BA37F71958C79E" originalValue="nährstoffreiche" pageId="null" pageNumber="199">naehrstoffreiche</normalizedToken>
<normalizedToken id="7326C6AAE6C2FD36C994F4C77C3E1609" originalValue="Böden" pageId="null" pageNumber="199">Boeden</normalizedToken>
. 
<normalizedToken id="51E8965DCD13BE485FA8A253F3D5D565" originalValue="Gärten" pageId="null" pageNumber="199">Gaerten</normalizedToken>
, 
<normalizedToken id="900738B6F0D06A08F11361F8426033E7" originalValue="Äcker" pageId="null" pageNumber="199">Aecker</normalizedToken>
, Weinberge, Schuttstellen.
</paragraph>
<paragraph id="A4733D4C26FABB709AC182D791CE5F8D" pageId="null" pageNumber="199">
<emphasis id="0CBB2E7BDF043E59D8D5D02A7CD12E84" italics="true" pageId="null" pageNumber="199">Verbreitung.</emphasis>
<normalizedToken id="010978B1B810B941BDC10494E716A725" originalValue="Ursprünglich" pageId="null" pageNumber="199">Urspruenglich</normalizedToken>
<emphasis id="3A18C3BE6170C2B64B7932E5382200DC" italics="true" pageId="null" pageNumber="199">
<normalizedToken id="BD1AD4A8F5561EF2F733C325DD47CF7B" originalValue="westeuropäisch-mediterrane" pageId="null" pageNumber="199">westeuropaeisch-mediterrane</normalizedToken>
Pflanze
</emphasis>
, heute 
<normalizedToken id="74A580FD21EDDE452782F8D430A7EAE1" originalValue="über" pageId="null" pageNumber="199">ueber</normalizedToken>
die ganze Erde verschleppt. - Im Gebiet ziemlich verbreitet und 
<normalizedToken id="5928B6BE0266D956EBE4D5AE04504CF3" originalValue="häufig" pageId="null" pageNumber="199">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
