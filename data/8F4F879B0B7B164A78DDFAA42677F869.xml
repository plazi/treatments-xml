<taxonomicName id="C0E64D0E0B7B164A78E1FAA42591FA28" authority="Martius ex Colla (1833: 416)" authorityName="Martius ex Colla" authorityPageNumber="416" authorityYear="1833" box="[180,715,1382,1409]" class="Magnoliopsida" family="Malvaceae" genus="Sida" kingdom="Plantae" order="Malvales" pageId="11" pageNumber="116" phylum="Tracheophyta" rank="species" species="nemorensis">
<emphasis id="3592EA9F0B7B164A78E1FAA4262EFA29" bold="true" box="[180,372,1382,1409]" italics="true" pageId="11" pageNumber="116">Sida nemorensis</emphasis>
Martius ex 
<bibRefCitation id="63774B7C0B7B164A7A55FAA42591FA28" author="Colla, L. A." box="[512,715,1382,1409]" pageId="11" pageNumber="116" refId="ref18398" refString="Colla, L. A. (1833) Herbarium Pedemontanum, Vol. 1. Augustae Taurinorum: Ex Typis Regiis, Torino, 566 pp." type="book" year="1833">Colla (1833: 416)</bibRefCitation>
</taxonomicName>
(
<figureCitation id="9FDD2A080B7B164A7A8EFAA42413FA28" box="[731,841,1382,1409]" captionStart="FIGURE 5" captionStartId="12.[136,229,2030,2052]" captionTargetBox="[315,1294,482,1962]" captionTargetId="figure-118@12.[258,1329,425,2006]" captionTargetPageId="12" captionText="FIGURE 5. Distribution map of Sida glaziovii, S. paradoxa, S. linifolia, S. nemorensis, S. planicaulis, S. potentilloides and S. rubifolia in Rio Grande do Sul state, Brazil." figureDoi="http://doi.org/10.5281/zenodo.6415497" httpUri="https://zenodo.org/record/6415497/files/figure.png" pageId="11" pageNumber="116">Figures 5</figureCitation>
, 
<figureCitation id="9FDD2A080B7B164A7B02FAA424C4FA29" box="[855,926,1382,1408]" captionStart="FIGURE 6" captionStartId="13.[136,229,1920,1942]" captionTargetBox="[190,1398,190,1896]" captionTargetId="figure-17@13.[190,1398,190,1896]" captionTargetPageId="13" captionText="FIGURE 6. A–D. Sida nemorensis. A. Flower. B. Branch with leaves and flowers. C. Leaves and schizocarps. D. Calyx and mericarps. E–J. Sida paradoxa. E. Flower. F. Branch with leaves and stipules. G. Abaxial surface of leaf. H. Habit. I–J. Schizocarps. K–P. Sida planicaulis. K. Flowers. L. Adaxial surface of leaf. M. Abaxial surface of leaf. N. Branch with distichous leaves arrangement. O. Schizocarps. P. Branch with flowers and schizocarps. PhotographsA–B by Amaury Junior, C–P by Martin Grings (C–D from Krapovickas &amp; Cristóbal 38480, HAS)." figureDoi="http://doi.org/10.5281/zenodo.6415499" httpUri="https://zenodo.org/record/6415499/files/figure.png" pageId="11" pageNumber="116">6A–D</figureCitation>
, 
<figureCitation id="9FDD2A080B7B164A7BFEFAA4248CFA29" box="[939,982,1382,1408]" captionStart="FIGURE 14" captionStartId="26.[136,229,1957,1979]" captionTargetBox="[196,1391,245,1933]" captionTargetId="figure-54@26.[196,1391,245,1933]" captionTargetPageId="26" captionText="FIGURE 14. Mericarps. A. Sida anomala. B. Sida confusa. C. Sida farroupilhensis. D. Sida glaziovii. E. Sida cerradoensis. F. Sida cordifolia. G. Sida dubia. H. Sida linifolia. I. Sida lonchitis. J. Sida nemorensis. K. Sida paradoxa. L. Sida planicaulis. M. Sida potentilloides.N. Sida reitzii. O. Sida regnellii. P. Sida rhombifolia.Q. Sida riedelii. R. Sida rubifolia.S. Sida spinosa.T. Sida tuberculata. U. Sida urens. V. Sida viarum. Photographs by Martin Grings." figureDoi="http://doi.org/10.5281/zenodo.6415519" httpUri="https://zenodo.org/record/6415519/files/figure.png" pageId="11" pageNumber="116">14J</figureCitation>
).
</paragraph>
