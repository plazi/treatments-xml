<subSubSection id="1D04C03130664C2A27BC7DB6C9C96B71" pageId="null" pageNumber="322" type="description">
<paragraph id="77D1C622C29DE9DA2B8B8F2564E47E6A" pageId="null" pageNumber="322">
10-60 cm hoch. Stengel knickig aufsteigend. Blattrand mit 1 Reihe ca. 0,1 mm langer 
<normalizedToken id="30DF3EB18BA6FE3D4EBC612F33DCB6AB" originalValue="Drüsen" pageId="null" pageNumber="322">Druesen</normalizedToken>
; 
<emphasis id="D08C0BC3416E388F718D874CF254624F" italics="true" pageId="null" pageNumber="322">Blattscheiden kahl.</emphasis>
Rispe bis 20 cm lang; 
<normalizedToken id="227884871FC8DE0A9092007766C70893" originalValue="Rispenäste" pageId="null" pageNumber="322">Rispenaeste</normalizedToken>
ohne oder mit nur 1 
<normalizedToken id="7D07F40F3A55C0C8F5DE1965ED206E14" originalValue="grundständigen" pageId="null" pageNumber="322">grundstaendigen</normalizedToken>
Zweig. 
<normalizedToken id="11BD4D7FF1E75BEB94C616A303E29837" originalValue="Ährchen" pageId="null" pageNumber="322">Aehrchen</normalizedToken>
bis 
<normalizedToken id="B9DC760307D0D6EE9068A6D443EE7EDB" originalValue="über" pageId="null" pageNumber="322">ueber</normalizedToken>
10 mm lang, 
<emphasis id="F5F1A6E4DEE13E68241B23A354542B99" italics="true" pageId="null" pageNumber="322">
die meisten mit 
<normalizedToken id="4239945FF7041495046D361D7CB1DE31" originalValue="ungefähr" pageId="null" pageNumber="322">ungefaehr</normalizedToken>
20 
<normalizedToken id="7508382295C07874D671897A720A6DEA" originalValue="Blüten" pageId="null" pageNumber="322">Blueten</normalizedToken>
;
</emphasis>
die 
<normalizedToken id="979A5892DB0A86578A5ED597DB2C8809" originalValue="seitenständigen" pageId="null" pageNumber="322">seitenstaendigen</normalizedToken>
<normalizedToken id="8CFB283D373141243DDCB0A2D2FC9B93" originalValue="Ährchen" pageId="null" pageNumber="322">Aehrchen</normalizedToken>
2-8mal so lang wie ihre Stiele. 
<normalizedToken id="E5F1A30D53D247B4C97045BC60413B0F" originalValue="Hüllspelzen" pageId="null" pageNumber="322">Huellspelzen</normalizedToken>
<normalizedToken id="740AA1390713D5F943EE448E73CA7CFF" originalValue="ungefähr" pageId="null" pageNumber="322">ungefaehr</normalizedToken>
gleich lang. 
<emphasis id="8947F1F5D59E15F695DD1C1D7F126C30" italics="true" pageId="null" pageNumber="322">Deckspelzen an der Spitze wenig ausgerandet, in der Ausrandung oft mit kleiner, stachliger Spitze. -</emphasis>
<normalizedToken id="54F83260DD17909DAE35D9511EA6E92C" originalValue="Blüte" pageId="null" pageNumber="322">Bluete</normalizedToken>
: 
<normalizedToken id="79CE7F3FBE09A31A08E1CFFFA4FF7669" originalValue="Später" pageId="null" pageNumber="322">Spaeter</normalizedToken>
<normalizedToken id="CC35926E417A3934FEEE8B6C8B9B48F9" originalValue="Frühling" pageId="null" pageNumber="322">Fruehling</normalizedToken>
bis Herbst.
</paragraph>
<paragraph id="236C572C03ADB1B8C75F6196F1729FDE" pageId="null" pageNumber="322">
<emphasis id="4B05829D62C9BE2326EC6ABD5724D441" italics="true" pageId="null" pageNumber="322">
<pageBreakToken id="6DB248294D5142F58C498CECBA7CCD33" pageId="null" pageNumber="322">Zytologische</pageBreakToken>
Angaben. 2n = 20:
</emphasis>
Ohne Herkunftsangabe des Materials (Avdulov 1931), aus den USA (Gould 1960). 
<emphasis id="C58FD39B51C3BA67BDAEC1940C1481B4" italics="true" pageId="null" pageNumber="322">2n</emphasis>
= 
<emphasis id="F94CCD187DB55F744BB0B962BB4CFC26" italics="true" pageId="null" pageNumber="322">40:</emphasis>
Material aus Japan (Ono und Tateoka 1953).
</paragraph>
<paragraph id="50E9CD60304B7366B4B588EABDD6E273" pageId="null" pageNumber="322">
<emphasis id="D7E752F100EA4454838D16DB097CDE73" italics="true" pageId="null" pageNumber="322">Standort.</emphasis>
Wie 
<taxonomicName id="96187AE9406B374EBAFE9ABFF0016277" class="Liliopsida" family="Poaceae" genus="Eragrostis" kingdom="Plantae" order="Poales" pageId="null" pageNumber="322" phylum="Tracheophyta" rank="species" species="pilosa">
<emphasis id="43857AD96845FD238F3E998E2E262DF4" italics="true" pageId="null" pageNumber="322">E. pilosa</emphasis>
</taxonomicName>
(Nr. 3).
</paragraph>
<paragraph id="3EFD9AD9006F44EDC5BE7396C83DA6B4" pageId="null" pageNumber="322">
<emphasis id="1A4C398C21E3B3E412B5C573FFDB930F" italics="true" pageId="null" pageNumber="322">Verbreitung.</emphasis>
<normalizedToken id="C23B35F6C114A616734A941EC7800207" originalValue="Ursprünglich" pageId="null" pageNumber="322">Urspruenglich</normalizedToken>
vielleicht 
<emphasis id="23C1F53558BD400ED25D7A5B1A63365D" italics="true" pageId="null" pageNumber="322">mediterrane Pflanze</emphasis>
, heute in warmen und trockenen Gebieten der ganzen Welt. - Im Gebiet selten und nur adventiv.
</paragraph>
</subSubSection>
