(
<figureCitation box="[159,271,1739,1765]" captionStart="FIGURE 3" captionStartId="4.[151,250,1716,1740]" captionTargetBox="[160,1427,713,1683]" captionTargetId="figure-211@4.[151,1436,705,1693]" captionTargetPageId="4" captionText="FIGURE 3. Sulcolotis ovalis Liu et Wang sp. n.: a) dorsal habitus; b. lateral habitus; c. frontal habitus; d. tegmen, ventral view; e. tegmen, lateral view; f. penis; g. part of abdomen, male." figureDoi="http://doi.org/10.5281/zenodo.6876475" httpUri="https://zenodo.org/record/6876475/files/figure.png" pageId="3" pageNumber="78">Figs 3a–g</figureCitation>
