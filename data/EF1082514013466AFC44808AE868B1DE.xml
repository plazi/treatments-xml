<emphasis id="55CDEF554013466DFC3D83C9EDC9B69B" box="[1000,1268,1761,1783]" italics="true" pageId="11" pageNumber="1263">Haustorius algeriensis</emphasis>
Mulot, 1968
</taxonomicName>
; 
