<subSubSection id="4EEC9F69267C2372C3074E83C3A6223B" pageId="null" pageNumber="71" type="description">
<paragraph id="713E23343BE5C5600C62AB4005DE891D" pageId="null" pageNumber="71">
1 
<normalizedToken id="68A4ADB2F0B3AB3EB0015032BF48118A" originalValue="jährig" pageId="null" pageNumber="71">jaehrig</normalizedToken>
oder ausdauernd, bis 50 cm lang. 
<emphasis id="D8F92A536EF75C722DE3CA7A0A6DD8FE" italics="true" pageId="null" pageNumber="71">
Ohne 
<normalizedToken id="DC1F5E1A88C5DB9977D1A3243C4A4201" originalValue="Schwimmblätter" pageId="null" pageNumber="71">Schwimmblaetter</normalizedToken>
.
</emphasis>
Untergetauchte 
<normalizedToken id="F60373F4E015C9979B147857A1DD709D" originalValue="Blätter" pageId="null" pageNumber="71">Blaetter</normalizedToken>
wie bei 
<taxonomicName id="B9A947F822A3E1544E23725676DC94FC" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="71" phylum="Tracheophyta" rank="species" species="peltatus">
<emphasis id="A6F2F0ECA276DF3A7A9FE7DBEFF7D888" italics="true" pageId="null" pageNumber="71">R. peltatus</emphasis>
</taxonomicName>
(Nr. 1b). 
<normalizedToken id="5403D1BA31205BEDDB0D337B643A3A16" originalValue="Schwimmblätter" pageId="null" pageNumber="71">Schwimmblaetter</normalizedToken>
an Material aus dem Gebiet nicht bekannt, sonst wie bei 
<emphasis id="A8724EAF28D8DE036B2D722CBA68E5F1" italics="true" pageId="null" pageNumber="71">
R. aqnatilis. 
<normalizedToken id="CBAA1CB0FC026A8DB8F6211B40719EDB" originalValue="Blüten-" pageId="null" pageNumber="71">Blueten-</normalizedToken>
und Fruchtstiele sehr lang, 2
</emphasis>
<normalizedToken id="6B2802B678C428BE1B78575DFC4F9D53" originalValue="½" pageId="null" pageNumber="71">1/2</normalizedToken>
<emphasis id="2887D04B2BB541147430A64756F8E2B2" italics="true" pageId="null" pageNumber="71">
-5mal so lang wie das 
<normalizedToken id="52773DCDF1E0FCBE66A68154BB235DED" originalValue="gegenüberstehende" pageId="null" pageNumber="71">gegenueberstehende</normalizedToken>
untergetauchte Blatt.
</emphasis>
<normalizedToken id="871665B8D7834E24E1436CFA631E6817" originalValue="Blüten" pageId="null" pageNumber="71">Blueten</normalizedToken>
und 
<normalizedToken id="8148883FD65E57D369CC19DC19E80EF1" originalValue="Früchtchen" pageId="null" pageNumber="71">Fruechtchen</normalizedToken>
wie bei 
<taxonomicName id="1E04D4E4E3703B2FDEEB001C254B5C12" class="Magnoliopsida" family="Ranunculaceae" genus="Ranunculus" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="71" phylum="Tracheophyta" rank="species" species="trichophyllus">
<emphasis id="99BA07ED017774B247A904DCE7B84786" italics="true" pageId="null" pageNumber="71">R. trichophyllus</emphasis>
</taxonomicName>
(Nr. 1f), 
<emphasis id="213AC3DBBA9A4F8CD8D132240A114CF0" italics="true" pageId="null" pageNumber="71">
<normalizedToken id="14CEB13F78FE86F58F938FAD26A7AA7F" originalValue="Früchtchen" pageId="null" pageNumber="71">Fruechtchen</normalizedToken>
jedoch
</emphasis>
(
<emphasis id="C7649996B33CFF8E9FEEB965001B294A" italics="true" pageId="null" pageNumber="71">auch unreif</emphasis>
) 
<emphasis id="1704E407C7029F8C7C9DE69547EFEEE4" italics="true" pageId="null" pageNumber="71">kahl</emphasis>
und mit 8-10 undeutlichen, oft unterbrochenen Querrippen. 
<normalizedToken id="F6E81528A939B09F6DACB2FED9E44043" originalValue="Blütenboden" pageId="null" pageNumber="71">Bluetenboden</normalizedToken>
<normalizedToken id="E6EF3537488EE2C081E721681A7E4E36" originalValue="eiförmig" pageId="null" pageNumber="71">eifoermig</normalizedToken>
, behaart.
</paragraph>
<paragraph id="5F4F4A4C9C3FFB6126B4FD66D84B1C16" pageId="null" pageNumber="71">
<emphasis id="6AB2668CDE7178B0D92EF84DA8CA5177" italics="true" pageId="null" pageNumber="71">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0425245C5E85F4D132739BA93AF94FE0" italics="true" pageId="null" pageNumber="71">32:</emphasis>
Material aus 
<normalizedToken id="5184CD11AD26E15A088971A5830435FD" originalValue="Dänemark" pageId="null" pageNumber="71">Daenemark</normalizedToken>
; keine 
<normalizedToken id="7E50D0ABA110476D7C50923CF39491B0" originalValue="Störungen" pageId="null" pageNumber="71">Stoerungen</normalizedToken>
in der Pollenmeiose (Bocher 1938a, 
<normalizedToken id="CE16A78CD8C2952694591A18329C6302" originalValue="Sörensen" pageId="null" pageNumber="71">Soerensen</normalizedToken>
1955), aus England, Finnland und 
<normalizedToken id="78D2B140EA982561739DEE80D8D2B9DD" originalValue="Österreich" pageId="null" pageNumber="71">Oesterreich</normalizedToken>
(Cook 1962Cook 1966), aus Holland (Gadella und Kliphuis 1968), aus Polen (Turla 1969).
</paragraph>
<paragraph id="06F625C96A061AED527297C2D413A8FD" pageId="null" pageNumber="71">
<emphasis id="2E06B8F945F65CB81F32E9E1F65A809D" italics="true" pageId="null" pageNumber="71">
<pageBreakToken id="A1E621D4C974FC931373A98C142943B7" pageId="null" pageNumber="71">Standort</pageBreakToken>
.
</emphasis>
Kollin. Salzhaltiges, stehendes Wasser.
</paragraph>
<paragraph id="EA53520DB532168D99C6599DD67112E3" pageId="null" pageNumber="71">
<emphasis id="0F23CC087D8C43139758E3A00D5BD830" italics="true" pageId="null" pageNumber="71">
Verbreitung. 
<normalizedToken id="D9482FF9B61C0A438BF5DC2EE28CD780" originalValue="Westeuropäische" pageId="null" pageNumber="71">Westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="79A5CB11190563240238BA08C2B8E73E" originalValue="Küstengebiete" pageId="null" pageNumber="71">Kuestengebiete</normalizedToken>
und Salzstellen des Binnenlandes von Portugal bis Westund Norddeutschland, Shetlandinseln, Schweden, Finnland; 
<normalizedToken id="A23CADCC657A2DC278FA755737A8FD85" originalValue="Süditalien" pageId="null" pageNumber="71">Sueditalien</normalizedToken>
, Nordafrika. - Im Gebiet: Charrat bei Martigny im Rhonetal; ist nach Becherer (in 
<normalizedToken id="814C90C88633C34B463DAA6B35036DF6" originalValue="«Fortschritte»" pageId="null" pageNumber="71">&quot;Fortschritte&quot;</normalizedToken>
1962) und Desfayes (1966) dort nicht mehr vorhanden.
</paragraph>
</subSubSection>
