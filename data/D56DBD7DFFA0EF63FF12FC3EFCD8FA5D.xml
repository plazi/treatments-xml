<collectingCountry id="25D34CFBFFA0EF63FDA9FC42FDC0FBA9" box="[556,629,1015,1041]" name="Brazil" pageId="8" pageNumber="9">Brazil</collectingCountry>
: 
<collectingRegion id="9F00C289FFA0EF63FDFAFC42FCADFBA9" box="[639,792,1015,1041]" country="Brazil" name="Minas Gerais" pageId="8" pageNumber="9">Minas Gerais</collectingRegion>
, 
<emphasis id="6FB0D079FFA0EF63FCA6FC43FCCFFBA9" bold="true" box="[803,890,1014,1041]" pageId="8" pageNumber="9">
<collectingRegion id="9F00C289FFA0EF63FCA6FC43FCCFFBA9" box="[803,890,1014,1041]" country="Brazil" name="Parana" pageId="8" pageNumber="9">Paraná</collectingRegion>
</emphasis>
