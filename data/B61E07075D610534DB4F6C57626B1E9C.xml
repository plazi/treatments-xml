<subSubSection id="794B3BC60544C20A032DC7C24A7BE57C" pageId="null" pageNumber="832" type="description">
<paragraph id="4213B665C74AAD34AEAA6BB55EE725C6" pageId="null" pageNumber="832">
Unterscheidet sich von 
<taxonomicName id="F761B858AED34E014702D2527805D357" class="Magnoliopsida" family="Caryophyllaceae" genus="Minuartia" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="832" phylum="Tracheophyta" rank="species" species="mutabilis">
<emphasis id="2A52E05888787209D25B3A3CF94ECD5A" italics="true" pageId="null" pageNumber="832">M. mutabilis</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="5F89FA4E8A1933B96D3600ECBE332B49" italics="true" pageId="null" pageNumber="832">
1-2 
<normalizedToken id="990676D312EB581C0C68EA93AD74D7A4" originalValue="jährig" pageId="null" pageNumber="832">jaehrig</normalizedToken>
</emphasis>
, nur mit wenigen Stengeln; 10-30 cm hoch; 
<normalizedToken id="A48ABBFE93D15836ACBFEBCA4D18505B" originalValue="Kelchblätter" pageId="null" pageNumber="832">Kelchblaetter</normalizedToken>
4-6 mm lang; 
<emphasis id="E469000260F9DC48DABC4DCFEDA00887" italics="true" pageId="null" pageNumber="832">
<normalizedToken id="5C0D10A892F50BC684469C4F7C470730" originalValue="Kronblätter" pageId="null" pageNumber="832">Kronblaetter</normalizedToken>
</emphasis>
⅓- 
<normalizedToken id="047B249DEAD0F8E1B556E9FE6D74474B" originalValue="½" pageId="null" pageNumber="832">1/2</normalizedToken>
<emphasis id="D08D9616E1D29ADE37DE9F8779B50D2B" italics="true" pageId="null" pageNumber="832">
so lang wie die 
<normalizedToken id="53D53059AAF63EB00E84369018D7DE06" originalValue="Kelchblätter" pageId="null" pageNumber="832">Kelchblaetter</normalizedToken>
;
</emphasis>
Kapsel wenig 
<normalizedToken id="B23C8C1AF13C117968EFF8CDBFFB065B" originalValue="kürzer" pageId="null" pageNumber="832">kuerzer</normalizedToken>
als die 
<normalizedToken id="59E3D0BF8B666CF9FFBB1976E8C0A447" originalValue="Kelchblätter" pageId="null" pageNumber="832">Kelchblaetter</normalizedToken>
. - 
<normalizedToken id="0BDA12FB32C9DA02BD524590D0E0FB27" originalValue="Blüte" pageId="null" pageNumber="832">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="E39D736188375182383A15D6B2CE6E07" pageId="null" pageNumber="832">
<emphasis id="608811BD573020B9CAA7A342F13FDEC2" italics="true" pageId="null" pageNumber="832">
<pageBreakToken id="EFA7E47B14E2F99F0250DD6E50AF57DD" pageId="null" pageNumber="832">Zytologische</pageBreakToken>
Angaben. 2n = 30:
</emphasis>
Material aus dem Wallis (Favarger 1962a).
</paragraph>
<paragraph id="178585500DAA24A3BADA2867E33BD765" pageId="null" pageNumber="832">
<emphasis id="32F20EF2910E7D3E745E3591BC69C979" italics="true" pageId="null" pageNumber="832">Standort.</emphasis>
Kollin, montan und subalpin. Offene, lockere, trockene, kalkhaltige 
<normalizedToken id="9AE239A2B173DEFC5EDA01C8DBC94141" originalValue="Böden" pageId="null" pageNumber="832">Boeden</normalizedToken>
in warmen Lagen. Trockenrasen, Felsen, Mauern, Felsschutt, 
<normalizedToken id="3AC9FEBAD9FEED02228C60D1FE694760" originalValue="Äcker" pageId="null" pageNumber="832">Aecker</normalizedToken>
.
</paragraph>
<paragraph id="CE302D9B925FAA2CA48D84CC3095A547" pageId="null" pageNumber="832">
<emphasis id="7155869F45892C51E6307E450A6C6CE9" italics="true" pageId="null" pageNumber="832">
Verbreitung. 
<normalizedToken id="C21A22F2C57AD13FA4EDC7F67B2C1CA5" originalValue="Südeuropäische" pageId="null" pageNumber="832">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="89952A7093ACC0798FEB8F7DE842A785" originalValue="Südeuropa" pageId="null" pageNumber="832">Suedeuropa</normalizedToken>
(von Nordostspanien bis zur Balkanhalbinsel), 
<normalizedToken id="C9F91AF0AAC830E4BF6392812E8CDA0E" originalValue="nordwärts" pageId="null" pageNumber="832">nordwaerts</normalizedToken>
bis Burgund, Main, 
<normalizedToken id="17C62E94A3AFDDCA997A160FC5568C47" originalValue="Mähren" pageId="null" pageNumber="832">Maehren</normalizedToken>
. - Im Gebiet: Oberrheinische Tiefebene (von Basel 
<normalizedToken id="5855C110950C52F1774CB427DBF6D1C2" originalValue="nordwärts" pageId="null" pageNumber="832">nordwaerts</normalizedToken>
), 
<normalizedToken id="5B46EDFAF9D93BB82C3A79CDCC19E0B1" originalValue="Südjura" pageId="null" pageNumber="832">Suedjura</normalizedToken>
(
<normalizedToken id="4762048B40AFAD6108BE1608A423B964" originalValue="nordostwärts" pageId="null" pageNumber="832">nordostwaerts</normalizedToken>
bis Bielersee), Ins (Bern), Savoyen, Genferseegebiet, Wallis, Aostatal, 
<normalizedToken id="7EE7D77862BE7908115EA8A5DE38AFC2" originalValue="Südtessin" pageId="null" pageNumber="832">Suedtessin</normalizedToken>
, Comerseegebiet, Vintschgau (von Glurns 
<normalizedToken id="726B61BD06B6EDE9E97315B691C5D884" originalValue="südwärts" pageId="null" pageNumber="832">suedwaerts</normalizedToken>
); nicht 
<normalizedToken id="D4B4B383411F18F960E0A1168EAC044E" originalValue="häufig" pageId="null" pageNumber="832">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="C5389C79F8C87AF9AAF6FB67DA5E62F9" pageId="null" pageNumber="832">
<emphasis id="D22E1352535D6273041CD85BF8952195" italics="true" pageId="null" pageNumber="832">Bemerkungen.</emphasis>
Neuerdings wird von McNeill (in Heywood 1963) der Name 
<taxonomicName id="265BEC38534E9359F2F89C44426955FE" authority="(Scop.) McNeill" authorityName="McNeill" baseAuthorityName="Scop." class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="null" pageNumber="832" phylum="Tracheophyta" rank="species" species="rubra">
<emphasis id="D1FC0A63FD83AA39612AAD2A4FF5531D" italics="true" pageId="null" pageNumber="832">M. rubra</emphasis>
(Scop.) McNeill
</taxonomicName>
vorgeschlagen.
</paragraph>
</subSubSection>
