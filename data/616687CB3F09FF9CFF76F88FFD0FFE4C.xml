<treatmentCitationGroup id="C9DF11F33F09FF9EFF76F8C8FC6AF887" box="[151,906,1870,1894]" pageId="60" pageNumber="61">
<treatmentCitation id="686E10CC3F09FF9EFF76F8C8FDCEF887" ID-DOI="http://doi.org/10.5281/zenodo.3913174" ID-Zenodo-Dep="3913174" LSID="urn:lsid:zoobank.org:act:C7BC417A-B3F3-419C-A487-0DEF517479A5" author="Linnaeus, C." box="[151,558,1870,1894]" httpUri="http://treatment.plazi.org/id/ACAB471AC9EE923F31D3B40F8AAB9E37" page="263" pageId="60" pageNumber="61" year="1758">
<taxonomicName id="2ECF4D5E3F09FF9EFF76F8C8FDCEF887" authority="Linnaeus, 1758: 263" authorityName="Linnaeus" authorityPageNumber="263" authorityYear="1758" box="[151,558,1870,1894]" class="Actinopterygii" family="Gobiidae" genus="Gobius" kingdom="Animalia" order="Perciformes" pageId="60" pageNumber="61" phylum="Chordata" rank="species" species="paganellus">
<emphasis id="DBBBEACF3F09FF9EFF76F8C8FEB6F887" box="[151,342,1870,1894]" italics="true" pageId="60" pageNumber="61">Gobius paganellus</emphasis>
<bibRefCitation id="8D5E4B2C3F09FF9EFEBDF8C8FDCEF887" author="Linnaeus, C." box="[348,558,1870,1894]" pageId="60" pageNumber="61" refId="ref60330" refString="Linnaeus, C. (1758) Systema naturae per regna tria naturae, secundum classes, ordines, genera, species, cum characteribus, differentiis, synonymis, locis. Tomus I. Editio decima, reformata. Impensis Direct. Laurentii Salvii, Holmiae, ii + 824 pp. https: // doi. org / 10.5962 / bhl. title. 542" type="book" year="1758">Linnaeus, 1758: 263</bibRefCitation>
