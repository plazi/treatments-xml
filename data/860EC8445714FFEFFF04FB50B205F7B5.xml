— W &amp; S 
<collectingCountry id="76B039C25714FFEFFD0FF77EBAC9F70A" box="[697,757,2254,2283]" name="Iran" pageId="3" pageNumber="174">Iran</collectingCountry>
, S 
<collectingCountry id="76B039C25714FFEFFCABF77EBBF5F70A" box="[797,969,2254,2283]" name="Afghanistan" pageId="3" pageNumber="174">Afghanistan</collectingCountry>
, and S 
<collectingCountry id="76B039C25714FFEFFB87F77EBC9BF70A" box="[1073,1191,2254,2283]" name="Pakistan" pageId="3" pageNumber="174">Pakistan</collectingCountry>
