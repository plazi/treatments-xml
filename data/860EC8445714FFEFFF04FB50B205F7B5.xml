<emphasis id="3CD3A5405714FFEFFCA3FA3EBB8CFA4E" bold="true" box="[789,944,1422,1455]" pageId="3" pageNumber="174">Taxonomy.</emphasis>
<taxonomicName id="C9A702D15714FFEFFC09FA3EBBB5FA39" authority="Thomas, 1903" authorityName="Thomas" authorityYear="1903" class="Mammalia" family="Rhinopomatidae" genus="Rhinopoma" kingdom="Animalia" order="Chiroptera" pageId="3" pageNumber="174" phylum="Chordata" rank="species" species="muscatellum">Rhinopoma muscatellum Thomas, 1903</taxonomicName>
