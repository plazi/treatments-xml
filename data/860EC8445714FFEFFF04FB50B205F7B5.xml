<materialsCitation id="BECF730F5714FFEFFC2AFA0FBBF8FA1F" ID-GBIF-Occurrence="3802899301" pageId="3" pageNumber="174">
“Wadi Bani Ruha,” 
<collectingCountry id="76B039C25714FFEFFB03FA0FBD25FA39" box="[1205,1305,1471,1496]" name="Oman" pageId="3" pageNumber="174">Muscat</collectingCountry>
, Arabia (
<collectingCountry id="76B039C25714FFEFFCE0FA51BB8AFA1F" box="[854,950,1505,1534]" name="Oman" pageId="3" pageNumber="174">Oman</collectingCountry>
