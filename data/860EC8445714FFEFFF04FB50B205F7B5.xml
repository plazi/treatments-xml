<caption id="5AD829DA5714FFEFFF1AF7E1BAEEF6D9" ID-DOI="http://doi.org/10.5281/zenodo.6421041" ID-Zenodo-Dep="6421041" httpUri="https://zenodo.org/record/6421041/files/figure.png" inLine="true" pageId="3" pageNumber="174" targetBox="[172,764,1428,1842]" targetPageId="3">
