<bibRefCitation id="5B297ED8FF3586F1DB37C681FD3F79F6" author="Radcliffe, L." box="[546,728,1193,1219]" pageId="227" pageNumber="228" pagination="105 - 140" refId="ref298180" refString="Radcliffe, L. (1912) Description of a new family, two new genera, and twenty-nine new species of anacanthine fishes from the Philippine Islands and contiguous waters. Proceedings of the United States National Museum, 43, 105 - 140, pls. 22 - 31. http: // dx. doi. org / 10.5479 / si. 00963801.43 - 1924.105" type="journal article" year="1912">Radcliffe, 1912</bibRefCitation>
