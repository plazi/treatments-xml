<taxonomicName id="F8B878AAFF3486F0DA3FC57EFB767A5E" authority="Iwamoto, 1974: 509" authorityName="Iwamoto" authorityPageNumber="509" authorityYear="1974" box="[810,1169,1877,1899]" class="Actinopterygii" family="Macrouridae" genus="Kuronezumia" kingdom="Animalia" order="Gadiformes" pageId="226" pageNumber="227" phylum="Chordata" rank="genus">
