Key to species of 
<taxonomicName id="F8B878AAFF3586F1D86FC7D5FDC27B22" authorityName="Iwamoto" authorityYear="1974" box="[378,549,1533,1559]" class="Actinopterygii" family="Macrouridae" genus="Kuronezumia" kingdom="Animalia" order="Gadiformes" pageId="227" pageNumber="228" phylum="Chordata" rank="genus">
