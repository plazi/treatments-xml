<taxonomicName id="F8B878AAFF3486F0DC42C57EFAF47AB9" authority="Iwamoto, 1974" authorityName="Iwamoto" authorityYear="1974" class="Actinopterygii" family="Macrouridae" genus="Nezumia" kingdom="Animalia" order="Gadiformes" pageId="226" pageNumber="227" phylum="Chordata" rank="species" species="bubonis" subGenus="Kuronezumia">
<emphasis id="0DCCDF3BFF3486F0DC42C57EFBB37AB9" italics="true" pageId="226" pageNumber="227">Nezumia (Kuronezumia) bubonis</emphasis>
Iwamoto, 1974
</taxonomicName>
