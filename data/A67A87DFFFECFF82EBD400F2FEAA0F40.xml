<taxonomicName id="E9D34D4AFFEAFF80E8B7048AFE0A0981" authority="Saba &amp; Iwao &amp; Fujita, 2012" authorityName="Saba &amp; Iwao &amp; Fujita" authorityYear="2012" box="[217,462,2025,2047]" class="Asteroidea" family="Asterinidae" genus="Disasterina" kingdom="Animalia" order="Valvatida" pageId="5" pageNumber="26" phylum="Echinodermata" rank="subSpecies" species="isasterina" status="sp. nov." subSpecies="akajimaensis">
<emphasis id="1CA7EADBFFEAFF80E8B7048AFE0A0981" box="[217,462,2025,2047]" italics="true" pageId="5" pageNumber="26">D isasterina akajimaensis</emphasis>
</taxonomicName>
