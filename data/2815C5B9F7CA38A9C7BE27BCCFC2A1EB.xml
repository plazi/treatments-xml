<subSubSection id="DF3DEB6670486C9DFECA556D545922FD" pageId="null" pageNumber="547" type="description">
<paragraph id="8A07C0ED6439AB934BA1ACB6776522C0" pageId="null" pageNumber="547">
Oft nur 2 
<normalizedToken id="5C560C7D4AC33FA8BFB348E9467F6521" originalValue="jährig" pageId="null" pageNumber="547">jaehrig</normalizedToken>
; 20-60 cm hoch. Stengel aufrecht, 
<emphasis id="513A79056198326BDDF433445B98D6EA" italics="true" pageId="null" pageNumber="547">
oft auf der ganzen 
<normalizedToken id="66D1B002B4315E5C99E059468890A443" originalValue="Länge" pageId="null" pageNumber="547">Laenge</normalizedToken>
verzweigt, im untern Teil dicht abstehend behaart
</emphasis>
(
<emphasis id="B6F4CE1AC3DC899F669B3953E53CD83C" italics="true" pageId="null" pageNumber="547">Haare 1-2 mm lang</emphasis>
). 
<normalizedToken id="D4012E245EFE266A5A4EF6F6310C45F1" originalValue="Grundständige" pageId="null" pageNumber="547">Grundstaendige</normalizedToken>
<normalizedToken id="BFE8F67EA2B5CCEEB4A5DEB3BD2B180A" originalValue="Blätter" pageId="null" pageNumber="547">Blaetter</normalizedToken>
meist gefiedert, Endteilblatt 
<normalizedToken id="AEF7AED08F5E8698666D9FB615366BB0" originalValue="1½-2½" pageId="null" pageNumber="547">11/2-21/2</normalizedToken>
mal so lang wie breit; 
<normalizedToken id="CAFC06A46DB34EE62F9747DA85E32C43" originalValue="stengelständige" pageId="null" pageNumber="547">stengelstaendige</normalizedToken>
<normalizedToken id="56B2DF6E7F7CC24B88385CCA722DFD6E" originalValue="Blätter" pageId="null" pageNumber="547">Blaetter</normalizedToken>
mit 5-13 
<normalizedToken id="E49D9EEB1C14CFC4D042434A20EA615E" originalValue="Teilblättern" pageId="null" pageNumber="547">Teilblaettern</normalizedToken>
, 
<emphasis id="CFC6C8FB66336617310483D74DD97136" italics="true" pageId="null" pageNumber="547">unterseits dicht abstehend behaart</emphasis>
(
<emphasis id="C7FBE24C3DB581EE32C7622A52886E11" italics="true" pageId="null" pageNumber="547">Haare 1-2 mm lang</emphasis>
), oberseits fast kahl oder abstehend behaart, 3-7 je Stengel, ziemlich 
<normalizedToken id="0E79A78CED69B64747FCAB672CAD2926" originalValue="gleichmäßig" pageId="null" pageNumber="547">gleichmaessig</normalizedToken>
auf den Stengel verteilt; 
<normalizedToken id="F33FB6ED5A0B44DA76D694EF00CBC1D1" originalValue="Teilblätter" pageId="null" pageNumber="547">Teilblaetter</normalizedToken>
der obern 
<normalizedToken id="3E51E43324F42077D9570413F93A80B0" originalValue="Stengelblätter" pageId="null" pageNumber="547">Stengelblaetter</normalizedToken>
spitz, schmal lanzettlich, das 
<normalizedToken id="73B9919A4A35BF89E3159D3F8AEEA709" originalValue="endständige" pageId="null" pageNumber="547">endstaendige</normalizedToken>
nur wenig 
<normalizedToken id="4C1792473F1379293B4387463A99E21A" originalValue="länger" pageId="null" pageNumber="547">laenger</normalizedToken>
und wenig breiter als die seitlichen. 
<normalizedToken id="4EF74D1D7B24438080CAE5E5F603B223" originalValue="Hüllblätter" pageId="null" pageNumber="547">Huellblaetter</normalizedToken>
meist bis auf 
<normalizedToken id="37501113A3820E5F7D7DACB0F6A77D3E" originalValue="¼" pageId="null" pageNumber="547">1/4</normalizedToken>
-⅕ geteilt, mit spitzen Zipfeln. Kelch 10-13 mm lang, 3-5 mm dick, dicht anliegend bis abstehend behaart (Haare 0,7-1,2 mm lang), meist bleich. Krone gelb, meist mit roter Schiffchenspitze; Fahne 4-5 mm breit. - 
<normalizedToken id="ADDBCE7F44D3A14424AC91F5EC02364B" originalValue="Blüte" pageId="null" pageNumber="547">Bluete</normalizedToken>
: 
<normalizedToken id="F028B2E4261DD83D38A59756DD187897" originalValue="Später" pageId="null" pageNumber="547">Spaeter</normalizedToken>
<normalizedToken id="2E9E772DC399575C99EED411CA1EB8FB" originalValue="Frühling" pageId="null" pageNumber="547">Fruehling</normalizedToken>
, Sommer und Herbst.
</paragraph>
<paragraph id="C6CF8A806E1550AC123EEB4A9857B58E" pageId="null" pageNumber="547">
<emphasis id="02CAA5F9E082C4D9E480DECB3B799D47" italics="true" pageId="null" pageNumber="547">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B150C000DABFBB028A6CBD0261458106" italics="true" pageId="null" pageNumber="547">12:</emphasis>
Material aus Ungarn (Larsen 1955, Baksay 1956).
</paragraph>
<paragraph id="BE26C80E75CF485CCF80FF3A1D1F7FF3" pageId="null" pageNumber="547">
<emphasis id="ECD40E0C72F4E4ABE85C4B5A32C1C934" italics="true" pageId="null" pageNumber="547">Standort.</emphasis>
Kollin, montan und subalpin. Trockene, lockere, sandige 
<normalizedToken id="FB9ABAB4BC7874A63CDDB2A3A866FD4A" originalValue="Böden" pageId="null" pageNumber="547">Boeden</normalizedToken>
in warmen Lagen. Felsensteppen, lichte 
<normalizedToken id="BF62487CAC01A7DB5A6575323A0BB1B9" originalValue="Föhrenwälder" pageId="null" pageNumber="547">Foehrenwaelder</normalizedToken>
.
</paragraph>
<paragraph id="3D017F0E6FCEC3A7EB37C84F2093D9B5" pageId="null" pageNumber="547">
<emphasis id="5F0A0D5A1533B9429EDE1BB760F89EFA" italics="true" pageId="null" pageNumber="547">
Verbreitung. 
<normalizedToken id="AAF880A9542C7116A6EBE08480D9C619" originalValue="Osteuropäische" pageId="null" pageNumber="547">Osteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Von 
<normalizedToken id="438C015334EF89C3CAA3E24C0EFC11C5" originalValue="Rußland" pageId="null" pageNumber="547">Russland</normalizedToken>
<normalizedToken id="9992EFFD0DBC658D1B52D9A1E7AE3900" originalValue="westwärts" pageId="null" pageNumber="547">westwaerts</normalizedToken>
bis Mittelpolen, Schlesien, 
<normalizedToken id="676C387C2466452C0258FD177E06EC31" originalValue="Mähren" pageId="null" pageNumber="547">Maehren</normalizedToken>
, 
<normalizedToken id="F714F1C674515B1EB93DFC5EBC731578" originalValue="Oberösterreich" pageId="null" pageNumber="547">Oberoesterreich</normalizedToken>
, Wallis, Rhonetal, Norditalien, Istrien. - Im Gebiet: Savoyen, Wallis (Martigny bis Visp), Aostatal, unteres Valsesia, Unterengadin (?).
</paragraph>
</subSubSection>
