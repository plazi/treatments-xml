<taxonomicName authorityName="Von Poellnitz" authorityYear="1934" class="Magnoliopsida" family="Crassulaceae" genus="Kalanchoe" kingdom="Plantae" order="Saxifragales" pageId="8" pageNumber="53" phylum="Tracheophyta" rank="species" species="blossfeldiana">
<emphasis italics="true" pageId="8" pageNumber="53">K. blossfeldiana</emphasis>
