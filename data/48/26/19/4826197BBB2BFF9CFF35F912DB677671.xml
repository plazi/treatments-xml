(left), 
<taxonomicName box="[815,924,1102,1123]" class="Magnoliopsida" family="Crassulaceae" genus="Kalanchoe" isHybrid="true" kingdom="Plantae" order="Saxifragales" pageId="8" pageNumber="53" phylum="Tracheophyta" rank="species" species="trageri">
<emphasis box="[815,831,1102,1123]" italics="true" pageId="8" pageNumber="53">K</emphasis>
. × 
<emphasis box="[857,924,1102,1123]" italics="true" pageId="8" pageNumber="53">trageri</emphasis>
