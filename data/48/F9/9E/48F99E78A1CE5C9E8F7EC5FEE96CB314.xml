<paragraph pageId="0" pageNumber="153">
China • 1♂; Zhejiang, Lishui; 
<geoCoordinate degrees="28" direction="north" minutes="37.56" orientation="latitude" precision="9" value="28.626">28°37.56'N</geoCoordinate>
, 
