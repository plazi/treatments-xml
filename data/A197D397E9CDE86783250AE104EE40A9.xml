<subSubSection id="A25F67D49EACF4359809A74CB20D50BD" pageId="null" pageNumber="634" type="description">
<paragraph id="8DE28BEB0D8CACF41C5CC4450A0BCE66" pageId="null" pageNumber="634">
Unterscheidet sich von 
<taxonomicName id="47A16A7720F8EC0ED80FDA3410B50E09" class="Magnoliopsida" family="Oxalidaceae" genus="Oxalis" kingdom="Plantae" order="Oxalidales" pageId="null" pageNumber="634" phylum="Tracheophyta" rank="species" species="corniculata">
<emphasis id="5DC6DF6705AE09E24B32115EFC90D210" italics="true" pageId="null" pageNumber="634">O. corniculata</emphasis>
</taxonomicName>
(Nr. 2) durch folgende Merkmale: Ausdauernd, mit 
<normalizedToken id="DBADFE16F24602096B6AE68BD82A9DD8" originalValue="dünnen" pageId="null" pageNumber="634">duennen</normalizedToken>
unterirdischen, im Herbst knollig anschwellenden 
<normalizedToken id="7811B2913476884F254F4E90F8B9E616" originalValue="Ausläufern" pageId="null" pageNumber="634">Auslaeufern</normalizedToken>
; 15-30 cm hoch; 
<emphasis id="F9015A2960076A7DA705522C9D4AD4BF" italics="true" pageId="null" pageNumber="634">Stengel meist aufrecht</emphasis>
, nicht wurzelnd; 
<emphasis id="8069BCEC2579E6612BA543F962040CFA" italics="true" pageId="null" pageNumber="634">
gegliederte Haare am Stengel, am Blattstielgrund und oft an den 
<normalizedToken id="276AA3ED5B8957C2A63A68764C701BF5" originalValue="Früchten" pageId="null" pageNumber="634">Fruechten</normalizedToken>
;
</emphasis>
<normalizedToken id="29E422823419A636FA68266936D34BAE" originalValue="Blätter" pageId="null" pageNumber="634">Blaetter</normalizedToken>
<emphasis id="E6DE8AC76A36271367ED9C1849FA5D01" italics="true" pageId="null" pageNumber="634">
<normalizedToken id="25B6F022742C3BE16DABC4230608468A" originalValue="±" pageId="null" pageNumber="634">+/-</normalizedToken>
</emphasis>
<normalizedToken id="63460C9369EDD1FEAFDE2AF914337632" originalValue="gegenständig" pageId="null" pageNumber="634">gegenstaendig</normalizedToken>
oder 
<normalizedToken id="655D57FD5D3F0C7B5CAA9433BC703B7A" originalValue="quirlständig" pageId="null" pageNumber="634">quirlstaendig</normalizedToken>
; 
<normalizedToken id="F64522D0566BCD492132D54A6386F0CF" originalValue="Teilblätter" pageId="null" pageNumber="634">Teilblaetter</normalizedToken>
bis auf 
<normalizedToken id="75388FA30569873500CD9978E703327B" originalValue="höchstens" pageId="null" pageNumber="634">hoechstens</normalizedToken>
<normalizedToken id="DBEA59B67CC6BE6B472AB8BB060AF213" originalValue="¾" pageId="null" pageNumber="634">3/4</normalizedToken>
ausgerandet; Stiel des 
<normalizedToken id="F49B706CF8B3E1655D584A4546FB7D55" originalValue="Blütenstandes" pageId="null" pageNumber="634">Bluetenstandes</normalizedToken>
am Grunde knotig verdickt; 
<normalizedToken id="BF57922CCA04B0808115A0D1F3629FF0" originalValue="Blütenstiele" pageId="null" pageNumber="634">Bluetenstiele</normalizedToken>
nach dem 
<normalizedToken id="704D3B3FFA123EA43CD7EDACD4BCDF9E" originalValue="Verblühen" pageId="null" pageNumber="634">Verbluehen</normalizedToken>
aufrecht; 
<normalizedToken id="04646FA021BCB1BD066F5D6455ED728B" originalValue="Kronblätter" pageId="null" pageNumber="634">Kronblaetter</normalizedToken>
vorn abgerundet; 
<emphasis id="248420C03AFB4DE399391F6E8E8EF7FA" italics="true" pageId="null" pageNumber="634">Frucht 8-15 mm lang, oft kahl.</emphasis>
<normalizedToken id="F32B32CBE9D302767839F03D86502B8A" originalValue="Blüte" pageId="null" pageNumber="634">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="6B4D6EE1D683A492839F6B8BB033C3AB" pageId="null" pageNumber="634">
<emphasis id="2A91025138483E99B484A2DC364C6C17" italics="true" pageId="null" pageNumber="634">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="DC6E84D69D1760BCE0E4327830475556" italics="true" pageId="null" pageNumber="634">18</emphasis>
und 
<emphasis id="FEBDE24A50162AB8E12C555F47F422B2" italics="true" pageId="null" pageNumber="634">18-24:</emphasis>
Material aus Nordamerika (Eiten 1963). 
<emphasis id="63B8EE707DCADB378FD146FBA07E1818" italics="true" pageId="null" pageNumber="634">2n</emphasis>
= 
<emphasis id="A887DBAB5A2C0D8FE2CF978E0E2A49C7" italics="true" pageId="null" pageNumber="634">24:</emphasis>
Material aus Schleswig-Holstein (Wulff 1937b), aus Polen (Skalinska et al. 1959), aus Holland (Gadella und Kliphuis 1966).
</paragraph>
<paragraph id="D2CD47D71A3372C6CE0DF6A6CDAB37DA" pageId="null" pageNumber="634">
<emphasis id="6AD714958773BF13B4F05D0CF376AFFD" italics="true" pageId="null" pageNumber="634">Standort.</emphasis>
Kollin, seltener montan. Lockere, 
<normalizedToken id="B35ECAB051E2B950F0B96DFEBCA307E6" originalValue="nährstoffreiche" pageId="null" pageNumber="634">naehrstoffreiche</normalizedToken>
, lehmige 
<normalizedToken id="12FEDA8A08EFD60658535DAAC436C358" originalValue="Böden" pageId="null" pageNumber="634">Boeden</normalizedToken>
in 
<normalizedToken id="5ED8A59DD2688C11C5C9A93AE0F580CB" originalValue="wärmeren" pageId="null" pageNumber="634">waermeren</normalizedToken>
Lagen. Gartenbeete, 
<normalizedToken id="78FBDF848AF09D064C8872E019169811" originalValue="Schuttplätze" pageId="null" pageNumber="634">Schuttplaetze</normalizedToken>
, 
<normalizedToken id="A0887F28F8F1DFD0330A62B5AA6E2E76" originalValue="Äcker" pageId="null" pageNumber="634">Aecker</normalizedToken>
. 
<emphasis id="E4BB2AEE2055B831C9B383679EE9A440" italics="true" pageId="null" pageNumber="634">Polygono-Chenopodion polyspermi</emphasis>
W. Koch 1926.
</paragraph>
<paragraph id="6735C51192744A1FE7DFAFF5C679279A" pageId="null" pageNumber="634">
<emphasis id="7D4A7F84CAEDA4352F7DCDFC38C9E93B" italics="true" pageId="null" pageNumber="634">Verbreitung.</emphasis>
<normalizedToken id="4B25A8FE4779909536AE3E61B24FE759" originalValue="Ursprünglich" pageId="null" pageNumber="634">Urspruenglich</normalizedToken>
<emphasis id="26F937170DDB78005E42A444399A83C5" italics="true" pageId="null" pageNumber="634">nordamerikanisch-ostasiatische Pflanze;</emphasis>
heute fast 
<normalizedToken id="EDA4EB90C070C7156B0C60987AFA2230" originalValue="über" pageId="null" pageNumber="634">ueber</normalizedToken>
die ganze Erde verschleppt. - Im Gebiet verbreitet und 
<normalizedToken id="7575D533372091DAEF6DE6CF31D1DBFC" originalValue="häufig" pageId="null" pageNumber="634">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="76F1D6DECF9BC614318B5D67C832EF25" pageId="null" pageNumber="634">
<emphasis id="96D5D1AB4D2D1914820BD34C0E9DEE0B" italics="true" pageId="null" pageNumber="634">Bemerkungen.</emphasis>
Die 
<normalizedToken id="B7A9094D2D9101E8E650B16A8F04DE40" originalValue="Identität" pageId="null" pageNumber="634">Identitaet</normalizedToken>
des Namens 
<emphasis id="5C9F5C07CD8E7D359092F5D18759649F" italics="true" pageId="null" pageNumber="634">O. strida</emphasis>
ist umstritten. Der Name wird in Amerika 
<normalizedToken id="B2A1F1D9954D0C12DF4D344D0959D542" originalValue="für" pageId="null" pageNumber="634">fuer</normalizedToken>
<taxonomicName id="C7B718D7A9A65BAC84DA4E56165B7E27" authority="Jacq." authorityName="Jacq." class="Magnoliopsida" family="Oxalidaceae" genus="Oxalis" kingdom="Plantae" order="Oxalidales" pageId="null" pageNumber="634" phylum="Tracheophyta" rank="species" species="dillenii">
<emphasis id="94341EB24CDC4796073852B5CF47CB9F" italics="true" pageId="null" pageNumber="634">O. Dillenii</emphasis>
Jacq.
</taxonomicName>
gebraucht und ist deshalb als 
<emphasis id="BC4D19EC2E847504FF4EFB49FA0EF5CA" italics="true" pageId="null" pageNumber="634">Nomen ambiguum</emphasis>
fallenzulassen.
</paragraph>
</subSubSection>
