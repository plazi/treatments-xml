<quantity id="2E379B383F7DFFEAFE65FEA4FE30FEDD" box="[388,464,290,317]" metricMagnitude="-2" metricUnit="m" metricValue="5.3" pageId="72" pageNumber="73" unit="cm" value="5.3">5.3 cm</quantity>
