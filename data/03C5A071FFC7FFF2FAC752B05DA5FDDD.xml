<subSubSection id="C37642ECFFC7FFF3F861536E5247F299" pageId="42" pageNumber="594" type="reference_group">
<paragraph id="8BD31167FFC7FFF3F861536E53F2F43F" blockId="42.[2013,2607,2919,3341]" pageId="42" pageNumber="594">
<emphasis id="B918CD75FFC7FFF3F861536E5219F410" bold="true" box="[2013,2168,2919,2948]" pageId="42" pageNumber="594">Taxonomy.</emphasis>
<taxonomicName id="4C6C6AE4FFC7FFF3F73F536E5047F410" authority="Desmarest" authorityName="Desmarest" box="[2179,2598,2919,2948]" class="Mammalia" family="Echimyidae" genus="Echimys" kingdom="Animalia" order="Rodentia" pageId="42" pageNumber="594" phylum="Chordata" rank="species" species="didelphoides">Echimys didelphoides Desmarest</taxonomicName>
