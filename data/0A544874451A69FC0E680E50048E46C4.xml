<subSubSection id="FF40CE597394CCE8D845E1629670D999" pageId="null" pageNumber="440" type="nomenclature">
<paragraph id="69C0EC5B7D28D92CC220738E09BB49B9" pageId="null" pageNumber="440">
<pageBreakToken id="F552D4BDE992F7DC9EBC89AAE44F04E2" pageId="null" pageNumber="440" start="start">Artengruppe</pageBreakToken>
der 
<taxonomicName id="7780C544FF967AE0919EBEA7E68798EE" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Centaurea" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="440" phylum="Tracheophyta" rank="species" species="montana">
Centaurea 
<normalizedToken id="75BE2D281493C312FCF86835A9442AB0" originalValue="montána" pageId="null" pageNumber="440">montana</normalizedToken>
<authorityName id="3D2C5EEDCBF0D1D824BD244A7B47FDDE" pageId="null" pageNumber="440">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="8CE8380B3B43C88527C47FE18CFF8ACF" pageId="null" pageNumber="440" type="vernacular_names">
<paragraph id="03A932C98CFCE5ADA026CF74A6274361" pageId="null" pageNumber="440">Berg-Flockenblume</paragraph>
</subSubSection>
</title>
<subSubSection id="2C73C0E3787DA4DA5B811FF6F1C84094" pageId="null" pageNumber="440" type="description">
<paragraph id="D9A73FF50BE2016562C97D45A686F2AB" pageId="null" pageNumber="440">
<emphasis id="78CD52AED0F2814AF8D3A965724495F1" italics="true" pageId="null" pageNumber="440">Ausdauernd</emphasis>
, selten mit 
<normalizedToken id="2CBEEC474BF499444DC4C5F499879E60" originalValue="Ausläufern" pageId="null" pageNumber="440">Auslaeufern</normalizedToken>
; zerstreut behaart bis dicht 
<normalizedToken id="C729E5CF305C2F9265055FAAAC1D84D0" originalValue="weißfilzig" pageId="null" pageNumber="440">weissfilzig</normalizedToken>
behaart. Stengel aufrecht, 
<emphasis id="2D83873D6C8F7F1C127BC1DF8A006073" italics="true" pageId="null" pageNumber="440">meist nicht verzweigt</emphasis>
, kantig, mit oder ohne mehrzellige Haare. 
<normalizedToken id="50EC08555B4060E90314765334717FB0" originalValue="Blätter" pageId="null" pageNumber="440">Blaetter</normalizedToken>
oval bis schmal lanzettlich, ganzrandig, seltener die untern weit buchtig 
<normalizedToken id="A392AFDAFE090E207BE85BC990B8C3C0" originalValue="gezähnt" pageId="null" pageNumber="440">gezaehnt</normalizedToken>
bis fiederteilig, die untern kurz gestielt, die obern sitzend 
<emphasis id="E195E19F2252C0F3DA83CC28D31DDA82" italics="true" pageId="null" pageNumber="440">
und meist am Stengel herablaufend. 
<normalizedToken id="168C1E5DB6B73741E81DE130C1F69274" originalValue="Hülle" pageId="null" pageNumber="440">Huelle</normalizedToken>
der 
<normalizedToken id="0410B270645FFDC2C0CD04FA61DC6CD0" originalValue="blühenden" pageId="null" pageNumber="440">bluehenden</normalizedToken>
<normalizedToken id="710792E1B50C970B66FAA1CFE56F422D" originalValue="Köpfe" pageId="null" pageNumber="440">Koepfe</normalizedToken>
1,5
</emphasis>
- 
<emphasis id="7483B259ABD405CF1A9DF315EC354626" italics="true" pageId="null" pageNumber="440">2,5 cm lang und 1</emphasis>
- 
<emphasis id="8275E9E1BBC1FE063318AF47357AF6EB" italics="true" pageId="null" pageNumber="440">2 cm dick.</emphasis>
<normalizedToken id="DB8D6B9374D2050589AE8156ED3F8DBD" originalValue="Hüllblätter" pageId="null" pageNumber="440">Huellblaetter</normalizedToken>
<normalizedToken id="04FC979D1518149B79E60DDDA2A155B8" originalValue="grün" pageId="null" pageNumber="440">gruen</normalizedToken>
, 2,5-4 mm breit, mit 
<normalizedToken id="17FAF63668E0E9C21C638EE8C83DE66D" originalValue="Anhängsel" pageId="null" pageNumber="440">Anhaengsel</normalizedToken>
; 
<normalizedToken id="0C430B690A34037DA7FCE76F5886A023" originalValue="Anhängsel" pageId="null" pageNumber="440">Anhaengsel</normalizedToken>
schwarz, dunkelbraun oder bleich, 3eckig, 
<emphasis id="9BEAB3D71D237AE7D4186D9CD90AEFDF" italics="true" pageId="null" pageNumber="440">
beiderseits an den 
<normalizedToken id="0235BBD61B834999AEA391818118D16C" originalValue="Rändern" pageId="null" pageNumber="440">Raendern</normalizedToken>
des 
<normalizedToken id="A26B6C87203947E5971CF3EFB956BE0A" originalValue="Hüllblattes" pageId="null" pageNumber="440">Huellblattes</normalizedToken>
weit herablaufend, 
<normalizedToken id="96B5DCCC67362887F78C7771831EB689" originalValue="kammförmig" pageId="null" pageNumber="440">kammfoermig</normalizedToken>
gefranst
</emphasis>
, den 
<normalizedToken id="428AEE3C649EFBD2E36B53B197C15FEC" originalValue="übrigen" pageId="null" pageNumber="440">uebrigen</normalizedToken>
Teil der 
<normalizedToken id="4746007BEADD507CFBC239CD391339DD" originalValue="Hüllblätter" pageId="null" pageNumber="440">Huellblaetter</normalizedToken>
nicht deckend. 
<emphasis id="A4D78F9454A5DC80D711264CBDC0CE8B" italics="true" pageId="null" pageNumber="440">
Borsten der 
<normalizedToken id="63AE243A8D02B4C9B2C793D2DD605BBF" originalValue="Spreublätter" pageId="null" pageNumber="440">Spreublaetter</normalizedToken>
mit verzweigter Spitze
</emphasis>
(12fache 
<normalizedToken id="E05A370A1D0C7E98634B5FB5A158DD3B" originalValue="Vergrößerung" pageId="null" pageNumber="440">Vergroesserung</normalizedToken>
!). Innere Kronen der 
<normalizedToken id="B47EEA441BEAB1D54EF1D80DA8DB90BD" originalValue="Köpfe" pageId="null" pageNumber="440">Koepfe</normalizedToken>
rotviolett, 
<emphasis id="43FFC77FFB1FF7BCBF5518FB1FB50425" italics="true" pageId="null" pageNumber="440">
die 
<normalizedToken id="28A0015CAE60ED9FFBF0151C60A77EAA" originalValue="randständigen" pageId="null" pageNumber="440">randstaendigen</normalizedToken>
sehr 
<normalizedToken id="117613369B6D17A66FEF6380BD881E14" originalValue="verlängert" pageId="null" pageNumber="440">verlaengert</normalizedToken>
, blau
</emphasis>
(selten rosa oder 
<normalizedToken id="2ECDFB5513999BC5948E33955061516A" originalValue="weiß" pageId="null" pageNumber="440">weiss</normalizedToken>
). 
<emphasis id="EE86B627D6177155789395D10A447287" italics="true" pageId="null" pageNumber="440">
<normalizedToken id="9FF8137A3F270E0B849D9E176DA02087" originalValue="Früchte" pageId="null" pageNumber="440">Fruechte</normalizedToken>
4,5
</emphasis>
- 
<emphasis id="91D578C155B03D338B65C325832CA504" italics="true" pageId="null" pageNumber="440">5,5 mm lang</emphasis>
, gelblich, 
<emphasis id="5FB3A5E0DE02BA6B4C264477A1D31E86" italics="true" pageId="null" pageNumber="440">
am Grunde mit einem 
<normalizedToken id="70221C08F5AC5D4A4CD24E7F932D62B0" originalValue="Haarbüschel" pageId="null" pageNumber="440">Haarbueschel</normalizedToken>
</emphasis>
(Haare bis 1 mm lang). 
<taxonomicName id="1782589881AC1FA758BC0B1477648AFF" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="440" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
<normalizedToken id="6EF5B01BE56F0C74FFE2CA758C9BE72C" originalValue="bräunlich" pageId="null" pageNumber="440">braeunlich</normalizedToken>
, aus etwa 1 mm langen Borsten bestehend.
</paragraph>
<paragraph id="B22637C70E5C315B2A0BF750A73CA082" pageId="null" pageNumber="440">
Die Artengruppe der 
<taxonomicName id="E1C3D61FDCE2019330459697B9B5B1BA" class="Magnoliopsida" family="Asteraceae" genus="Centaurea" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="440" phylum="Tracheophyta" rank="species" species="montana">
<emphasis id="7BDA459E5946349AF69EAA294393F733" italics="true" pageId="null" pageNumber="440">C. montana</emphasis>
</taxonomicName>
<normalizedToken id="56838E87EFA80FCE2F0AEB81E1030398" originalValue="umfaßt" pageId="null" pageNumber="440">umfasst</normalizedToken>
etwa 
<emphasis id="0C803F3D23F8360B45D3FA007D1A1536" italics="true" pageId="null" pageNumber="440">8 Arten</emphasis>
und ist vorwiegend in 
<emphasis id="F6BC74CACBDF8CCF7713468ADA8600B3" italics="true" pageId="null" pageNumber="440">
<normalizedToken id="60CF9773E1C382893404BC753F7125D5" originalValue="süd-" pageId="null" pageNumber="440">sued-</normalizedToken>
und 
<normalizedToken id="82038977717806084E37661A12BE8B8B" originalValue="mitteleuropäischen" pageId="null" pageNumber="440">mitteleuropaeischen</normalizedToken>
Gebirgen verbreitet; Zentrum wahrscheinlich im Kaukasus. Chromosomengrundzahl:
</emphasis>
n = 11.
</paragraph>
<paragraph id="C765E868F43FCB4955E9117521F91070" pageId="null" pageNumber="440">
<table id="26EEEBADAF240DFA381D47A91885356B" frame="void" pageId="null" pageNumber="440" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="86D55D254BE2DE857027C06269F86833" pageId="null" pageNumber="440">
<tr id="BF7E22F8F1D42A7E0FC7D85692B4DBD6" pageId="null" pageNumber="440">
<td id="61AED40699A71DA9781778671B0EED86" align="left" pageId="null" pageNumber="440" valign="top">
1. Fransen der mittleren 
<normalizedToken id="35F4DA9233C92D19DCD0492E3AAECC47" originalValue="Hüllblätter" pageId="null" pageNumber="440">Huellblaetter</normalizedToken>
<normalizedToken id="5D68BB097ECE1A0492C004E852FD9A4F" originalValue="unregelmäßig" pageId="null" pageNumber="440">unregelmaessig</normalizedToken>
, jederseits 5-9, schwarz, kaum so lang wie die Breite des schwarzen ungeteilten 
<normalizedToken id="172A2F0918427E4FB965380FB8AD8728" originalValue="Hüllblattrandes" pageId="null" pageNumber="440">Huellblattrandes</normalizedToken>
; 
<normalizedToken id="7155E70967AD00FD0709C71C6DCE71E9" originalValue="Blätter" pageId="null" pageNumber="440">Blaetter</normalizedToken>
und Stengel mit 
<normalizedToken id="974BEF4880B424F55DE71E357EEF7B14" originalValue="weißfilziger" pageId="null" pageNumber="440">weissfilziger</normalizedToken>
Behaarung und mit mehrzelligen Haaren
</td>
<td id="0279E6DAFE98C0CD581605CBAF3F8DEE" align="left" pageId="null" pageNumber="440" valign="bottom">
<taxonomicName id="8E147204289792932750B56700B1515F" class="Magnoliopsida" family="Asteraceae" genus="Centaurea" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="440" phylum="Tracheophyta" rank="species" species="montana">
<italic id="515E934163D50EBFFCE1E42A6E8C20B6" pageId="null" pageNumber="440">C. montana</italic>
</taxonomicName>
(Nr. 2a)
</td>
</tr>
<tr id="2F79E08C14D37DC2AD3A44C6E1FFA4D7" pageId="null" pageNumber="440">
<td id="3ED8DCE097B1B7ED6A0410E3018966A9" align="left" pageId="null" pageNumber="440" valign="top">
1*. Fransen der mittleren 
<normalizedToken id="85CA1800E3AD538E3CAB0648FD5D3BDB" originalValue="Hüllblätter" pageId="null" pageNumber="440">Huellblaetter</normalizedToken>
<normalizedToken id="0CC018F6C39CE58A62B97E39E411BF49" originalValue="regelmäßig" pageId="null" pageNumber="440">regelmaessig</normalizedToken>
, jederseits 9-15, dunkelbraun oder bleich, 
<normalizedToken id="F23F81E64A5A08DCCC8615D15C3A1EA0" originalValue="länger" pageId="null" pageNumber="440">laenger</normalizedToken>
als die Breite des ungeteilten 
<normalizedToken id="FF9E4E0F4F643DA8C607B459D8C86704" originalValue="Hüllblattrandes" pageId="null" pageNumber="440">Huellblattrandes</normalizedToken>
; 
<normalizedToken id="3906852D4D1D54DB40C09AEB7F4122D1" originalValue="Blätter" pageId="null" pageNumber="440">Blaetter</normalizedToken>
und Stengel nur mit 
<normalizedToken id="0650418FEF7909884D308EC600348ACE" originalValue="weißfilziger" pageId="null" pageNumber="440">weissfilziger</normalizedToken>
Behaarung (ohne mehrzellige Haare).
</td>
</tr>
<tr id="DDBA708AFEF99D7011381E32937AC55D" pageId="null" pageNumber="440">
<td id="CC974729194FCA6BF04575ED2326AE79" align="left" pageId="null" pageNumber="440" valign="top">
2. 
<normalizedToken id="D556FF3ED5FC1EA8A9503B53713B6B9B" originalValue="Blätter" pageId="null" pageNumber="440">Blaetter</normalizedToken>
am Stengel deutlich herablaufend; Fransen der mittleren 
<normalizedToken id="DDA913338AD0E5E7E5F665E0AD799ED4" originalValue="Hüllblätter" pageId="null" pageNumber="440">Huellblaetter</normalizedToken>
kaum 
<normalizedToken id="D295D93FE1181633153520B781F364A9" originalValue="länger" pageId="null" pageNumber="440">laenger</normalizedToken>
als 2 mm
</td>
<td id="BBAA10E2D1DE52C0739753321626688E" align="left" pageId="null" pageNumber="440" valign="bottom">
<taxonomicName id="B1C9AFC66C94FBDFD1D98DD3E9CA440C" class="Magnoliopsida" family="Asteraceae" genus="Centaurea" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="440" phylum="Tracheophyta" rank="species" species="triumfettii">
<italic id="111BFD6A00F36F470252BEF3B1A70CDE" pageId="null" pageNumber="440">C. Triumfettii</italic>
</taxonomicName>
(Nr. 2b)
</td>
</tr>
<tr id="C92BD73DE20F1014D4A74119920B6EA1" pageId="null" pageNumber="440">
<td id="6146C900FDC76A3B2E958AD82BB8ECE9" align="left" pageId="null" pageNumber="440" valign="top">
2*. 
<normalizedToken id="22957F9AF11AC95D1FE20690F16FF2C1" originalValue="Blätter" pageId="null" pageNumber="440">Blaetter</normalizedToken>
am Stengel kaum herablaufend; Fransen der mittleren 
<normalizedToken id="DC90FEC01718E72FC6AF5E82256224F6" originalValue="Hüllblätter" pageId="null" pageNumber="440">Huellblaetter</normalizedToken>
2-4 mm lang
</td>
<td id="E3B9EC104D62E9EB78C4D809AF3304B7" align="left" pageId="null" pageNumber="440" valign="bottom">
<taxonomicName id="3DCB347CCE7EC772EDA02EE8B45C505D" class="Magnoliopsida" family="Asteraceae" genus="Centaurea" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="440" phylum="Tracheophyta" rank="species" species="seusana">
<italic id="69C54B358F6F46231445C0027E06B872" pageId="null" pageNumber="440">C. seusana</italic>
</taxonomicName>
(Nr. 2c)
</td>
</tr>
