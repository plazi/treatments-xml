<quantity id="93505C95B8406D1AFC5F351EFB83D098" box="[985,1059,1130,1154]" metricMagnitude="-2" metricUnit="m" metricValue="7.5184" pageId="9" pageNumber="8" unit="in" value="2.96">2.96 in</quantity>
<emphasis id="66DC2D62B8406D1AFBAC351FFB1FD098" box="[1066,1215,1130,1154]" italics="true" pageId="9" pageNumber="8">
<taxonomicName id="93A88AF3B8406D1AFBAC351FFB1BD098" baseAuthorityName="KovarIk" baseAuthorityYear="1998" box="[1066,1211,1130,1154]" class="Arachnida" family="Buthidae" genus="Reddyanus" kingdom="Animalia" order="Scorpiones" pageId="9" pageNumber="8" phylum="Arthropoda" rank="species" species="krasenskyi">R. krasenskyi</taxonomicName>
