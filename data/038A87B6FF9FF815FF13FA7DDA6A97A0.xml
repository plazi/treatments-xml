<taxonomicName id="4C234D23FF9FF814FF13FA7DDD4692A3" authority="Burmeister, 1842" authorityName="Burmeister" authorityYear="1842" box="[151,542,1503,1530]" class="Insecta" family="Cetoniidae" genus="Charadronota" kingdom="Animalia" order="Coleoptera" pageId="26" pageNumber="177" phylum="Arthropoda" rank="genus">
<emphasis id="B957EAB2FF9FF814FF13FA7DDD4692A3" bold="true" box="[151,542,1503,1530]" pageId="26" pageNumber="177">
