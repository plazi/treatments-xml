<subSubSection id="E387FC65C90E595F2472243DE221DA34" pageId="null" pageNumber="725" type="description">
<paragraph id="0833190033388B7DA0591A98C608F85E" pageId="null" pageNumber="725">
Stengel im obern Teil ohne Sternhaare. 
<normalizedToken id="9C1AEC97FEC9FFFD689D80EA3DE8B980" originalValue="Blätter" pageId="null" pageNumber="725">Blaetter</normalizedToken>
am Rande nach unten gerollt, ohne Sternhaare, 
<emphasis id="4661EB48C849358D05DDE67A095D37F7" italics="true" pageId="null" pageNumber="725">am Rande und auf Ober- und Unterseite mit zahlreichen Borstenhaaren.</emphasis>
<normalizedToken id="5BCB23E40CCCC323AF802D16FA80BE79" originalValue="Blütenstand" pageId="null" pageNumber="725">Bluetenstand</normalizedToken>
5-15 
<normalizedToken id="2E2EF19084C3AE55048D35D8BE2C6E90" originalValue="blütig" pageId="null" pageNumber="725">bluetig</normalizedToken>
. 
<normalizedToken id="501A273E313CFD1F8146E76867AB78AF" originalValue="Blütenstiele" pageId="null" pageNumber="725">Bluetenstiele</normalizedToken>
ohne 
<normalizedToken id="1BCE25D037D2A3B9896DEAB525A91FE9" originalValue="Drüsenhaare" pageId="null" pageNumber="725">Druesenhaare</normalizedToken>
. 
<emphasis id="C7E6C82136C6937A4E2F5977A7826B33" italics="true" pageId="null" pageNumber="725">
<normalizedToken id="7773923AAFFD9BFBEE00FFEEC345D69A" originalValue="Kronblätter" pageId="null" pageNumber="725">Kronblaetter</normalizedToken>
3-6 mm lang.
</emphasis>
Staubbeutel 0,3-0,45 mm lang. Frucht 3,5-5 mm lang. - 
<normalizedToken id="FE641B6E86D203E3EBF5C1A8DE128EF4" originalValue="Blüte" pageId="null" pageNumber="725">Bluete</normalizedToken>
: 
<normalizedToken id="86603D2E520A3B118366274D7195C2E8" originalValue="Später" pageId="null" pageNumber="725">Spaeter</normalizedToken>
<normalizedToken id="DB922AB9704DCC256BDE19B4CAD35C55" originalValue="Frühling" pageId="null" pageNumber="725">Fruehling</normalizedToken>
und 
<normalizedToken id="EBF3381462F0BF7858A854C2C791056B" originalValue="früher" pageId="null" pageNumber="725">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="EF1AC0E8F001F61FDE812AD4E8F1B513" pageId="null" pageNumber="725">
<emphasis id="BFA35216F1D59F8B7139C7BE8B2A1E6A" italics="true" pageId="null" pageNumber="725">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="2AA8F3488788D0C2DA4A408E73664768" italics="true" pageId="null" pageNumber="725">20:</emphasis>
Material aus 
<normalizedToken id="5CF02FBB8F327068E0B363B32E2E3B07" originalValue="Südfrankreich" pageId="null" pageNumber="725">Suedfrankreich</normalizedToken>
(Guinochet und Logeois 1962).
</paragraph>
<paragraph id="20B647FCEFCE1F08D9A26B27E9EF4373" pageId="null" pageNumber="725">
<emphasis id="5249C8703DFB7F4980B668BB92855924" italics="true" pageId="null" pageNumber="725">
<pageBreakToken id="CCCB9ACFB42A4603C5DA82B9F3CE7BE3" pageId="null" pageNumber="725">Standort</pageBreakToken>
.
</emphasis>
Kollin und montan. Trockene, steinige, kalkreiche Stellen in warmen Lagen. Felsensteppen, Trockenwiesen.
</paragraph>
<paragraph id="13E58AEC4BE0C66F3613DD5C92BC7B17" pageId="null" pageNumber="725">
<emphasis id="2A2F2172030A42DA43BF5BEDBD614AEB" italics="true" pageId="null" pageNumber="725">
Verbreitung. 
<normalizedToken id="5793A97AFDA7268BFA143A760BEC641A" originalValue="Südeuropäische" pageId="null" pageNumber="725">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="1E103014413171DD96E7DF5A2D95D475" originalValue="Nordwärts" pageId="null" pageNumber="725">Nordwaerts</normalizedToken>
bis 
<normalizedToken id="3E774F2B3C920DAA1D072A5265EF967F" originalValue="Pyrenäen" pageId="null" pageNumber="725">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="7A229F662C8C6F8E30B4F48690207E9A" originalValue="Südfrankreich" pageId="null" pageNumber="725">Suedfrankreich</normalizedToken>
, Alpen, Dalmatien, 
<normalizedToken id="B1C1BEE6B1E0F4A576FA6BD9D6EB8CB0" originalValue="westwärts" pageId="null" pageNumber="725">westwaerts</normalizedToken>
bis Ostspanien; 
<normalizedToken id="1CAAF5019B9C9CBB4005718E919BB95E" originalValue="ostwärts" pageId="null" pageNumber="725">ostwaerts</normalizedToken>
bis Montenegro; 
<normalizedToken id="97589D63FD5C5C1D7BA62AE8DF3165EB" originalValue="südwärts" pageId="null" pageNumber="725">suedwaerts</normalizedToken>
bis in die Abruzzen. - Im Gebiet: Savoyen (Maurienne, Herb. ETH), Aostatal (Cogne, 
<normalizedToken id="7302AF2D266B0E8ED6A1806BAA686EB3" originalValue="Rhêmes" pageId="null" pageNumber="725">Rhemes</normalizedToken>
), Valsesia (Losine, San Pietro di Cividate, Pian di Borno), Luganerseegebiet (
<normalizedToken id="C374E701F40431ED66905ED0BA6E7FC2" originalValue="Fuß" pageId="null" pageNumber="725">Fuss</normalizedToken>
des S. Salvatore, Herb. ETH), Comerseegebiet (
<normalizedToken id="E392550D4626F3AF79512AE7556DB3BC" originalValue="nordwärts" pageId="null" pageNumber="725">nordwaerts</normalizedToken>
bis Griante und zur Grigna), 
<normalizedToken id="CC33528913C3C82DF465FFF2C335B565" originalValue="Südwestufer" pageId="null" pageNumber="725">Suedwestufer</normalizedToken>
des Iseosees.
</paragraph>
</subSubSection>
