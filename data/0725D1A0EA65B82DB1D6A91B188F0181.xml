<subSubSection id="7B4B52C5B87B79E0C610CFF0FB4DF478" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="DC7E60FD75484CF79A238E219D747683" pageId="null" pageNumber="590">Ruten-Lattich</paragraph>
</subSubSection>
</title>
<subSubSection id="8D2FDA585CF73A10712D1BAABB54F4B5" pageId="null" pageNumber="590" type="description">
<paragraph id="CFAC033424C1BF8B9BD11DBB0DFD59A6" pageId="null" pageNumber="590">
2 
<normalizedToken id="D2811244F78CE8ED08412C8D8233B68D" originalValue="jährig" pageId="null" pageNumber="590">jaehrig</normalizedToken>
, mit holziger Pfahlwurzel; 30-60 cm hoch. Stengel aufrecht, kahl, mit zahlreichen, rutenartigen Seitenzweigen. 
<normalizedToken id="0AD827096D652C0FFEB561E10F49C6E0" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
kahl, 
<normalizedToken id="82651C478A267DCFB3CF19E3B5E83671" originalValue="graugrün" pageId="null" pageNumber="590">graugruen</normalizedToken>
, fiederteilig, mit lanzettlichen Abschnitten; Sten- 
<pageBreakToken id="777C40D93B11B45A1040F4FDA014B168" pageId="null" pageNumber="590">
<normalizedToken id="19412B8E4846218CEC2BB7526D079D9B" originalValue="gelblätter" pageId="null" pageNumber="590">gelblaetter</normalizedToken>
</pageBreakToken>
sitzend, 
<emphasis id="BD1410E5945F6C20841DB8E9ACC5FD27" italics="true" pageId="null" pageNumber="590">am Grunde mit 2 schmal lanzettlichen, 1</emphasis>
- 
<emphasis id="A5B43BDBD19B12911C9837C970766251" italics="true" pageId="null" pageNumber="590">3,5 cm langen Zipfeln am Stengel herablaufend</emphasis>
(
<emphasis id="57AA8D148965AEECA087038A9DF10D00" italics="true" pageId="null" pageNumber="590">Zipfel mit dem Stengel verwachsen</emphasis>
)
<emphasis id="82012E1D701F07008619A81365FE426F" italics="true" pageId="null" pageNumber="590">;</emphasis>
die obersten schmal lanzettlich, ganzrandig. 
<normalizedToken id="B55EF893847B309E6CD67399D63AAFD8" originalValue="Blütenköpfe" pageId="null" pageNumber="590">Bluetenkoepfe</normalizedToken>
in einer schmalen Rispe (an den einzelnen 
<normalizedToken id="7EF16B6066CF95D8B6F5720C00AF3134" originalValue="Ästen" pageId="null" pageNumber="590">Aesten</normalizedToken>
in einer 
<emphasis id="FFE06A60AA257178D73ABE899C7BA566" italics="true" pageId="null" pageNumber="590">
lockeren 
<normalizedToken id="C5206F289DFD701A2BED597D541E9151" originalValue="Ähre" pageId="null" pageNumber="590">Aehre</normalizedToken>
</emphasis>
), 
<emphasis id="76DA43B235037EA206AE08932F4D33C7" italics="true" pageId="null" pageNumber="590">
5 
<normalizedToken id="F1CCDA2F3A2872F5F02EA398A7685440" originalValue="blütig" pageId="null" pageNumber="590">bluetig</normalizedToken>
.
</emphasis>
<normalizedToken id="80545748FADF28384E2097E7FEDB86D1" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
bis 20 mm lang. Krone hellgelb, an der 
<normalizedToken id="340AEE83EA77DBF450E95A1A651DD7D7" originalValue="Außenseite" pageId="null" pageNumber="590">Aussenseite</normalizedToken>
der Zunge 
<normalizedToken id="D40BC29E87C815DF75CAF3FF4A10D233" originalValue="rötlich" pageId="null" pageNumber="590">roetlich</normalizedToken>
(getrocknet meist schmutzigblau), 1-2 cm lang. 
<emphasis id="6F799610FBB92835F9AEDB1504EE9B2E" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="66B6BA057C4462D74FC1C2179C126F4D" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
</emphasis>
(
<emphasis id="A96554847D09679D0E7526530C3A23B5" italics="true" pageId="null" pageNumber="590">mit Schnabel</emphasis>
) 
<emphasis id="FA46C8971B98AA94CCB5EFCBE71A6FD8" italics="true" pageId="null" pageNumber="590">ca. 12 mm lang</emphasis>
, schwarz, 
<normalizedToken id="455EC59E02F70D151852996B8266ABA0" originalValue="feinhöckerig" pageId="null" pageNumber="590">feinhoeckerig</normalizedToken>
, beiderseits mit je 5-8 
<normalizedToken id="78164521371EAEE205ECFCD439975E49" originalValue="Längsrippen" pageId="null" pageNumber="590">Laengsrippen</normalizedToken>
; 
<emphasis id="D63F88E0D65284CBD9F00B707615728F" italics="true" pageId="null" pageNumber="590">
Schnabel schwarz, 
<normalizedToken id="7A13FCDDE3B7007DF16874EE4AA724FE" originalValue="feinhöckerig" pageId="null" pageNumber="590">feinhoeckerig</normalizedToken>
</emphasis>
, etwa so lang wie der Rest der Frucht. - 
<normalizedToken id="88B6BBA49B78197460AD79467026C975" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="A7D1551DA64B533FB545EAE15AED552A" pageId="null" pageNumber="590">
<emphasis id="6C316293BF4BF192E776B39DF18E32CE" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="CC9C64D5045E66C5CF5105AB26AB468C" italics="true" pageId="null" pageNumber="590">18:</emphasis>
Material aus der 
<normalizedToken id="1F45638536A82DC46053BF9159093012" originalValue="Türkei" pageId="null" pageNumber="590">Tuerkei</normalizedToken>
und botanischen 
<normalizedToken id="CB78C70BA5BAAC9D85CB70CFE641C8DF" originalValue="Gärten" pageId="null" pageNumber="590">Gaerten</normalizedToken>
(Babcock et al. 1937), aus der Slowakei (Majovsky et al. 1970).
</paragraph>
<paragraph id="A48CF0BF5D827112B9A8DAE9CD98956F" pageId="null" pageNumber="590">
<emphasis id="D616272B742F14F85664C0CF99F0601C" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Kollin und montan. Trockene, steinige 
<normalizedToken id="64F5869A02865C3F342854FF0AD37CC1" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
in warmen Lagen. Trockenrasen, 
<normalizedToken id="8BBEC83A6662AAE158669CBD1E004471" originalValue="Wegränder" pageId="null" pageNumber="590">Wegraender</normalizedToken>
, Brachen, buschige 
<normalizedToken id="A485DC8CEC57C5275E7CAD4A2C1730D6" originalValue="Hänge" pageId="null" pageNumber="590">Haenge</normalizedToken>
.
</paragraph>
<paragraph id="E52B87F4E2B4E8F6C71EBDFAC42F9F0A" pageId="null" pageNumber="590">
<emphasis id="EE8E6A94655EB3148BA3A88AD381A9F5" italics="true" pageId="null" pageNumber="590">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="125D1ECDE73CEFA1296D97186F77BC94" originalValue="Nordwärts" pageId="null" pageNumber="590">Nordwaerts</normalizedToken>
bis Mittelfrankreich, Wallis, Norditalien, Krain, 
<normalizedToken id="3E5D640D9B306922D9004D9E49BC74A1" originalValue="Niederösterreich" pageId="null" pageNumber="590">Niederoesterreich</normalizedToken>
, Sachsen, Tschechoslowakei, Ungarn, 
<normalizedToken id="AF619DCF63D605E3CB94B2DA6F2B2E89" originalValue="Rumänien" pageId="null" pageNumber="590">Rumaenien</normalizedToken>
, 
<normalizedToken id="E95548E2DE82079E191FFAF673AA1BA9" originalValue="Südrußland" pageId="null" pageNumber="590">Suedrussland</normalizedToken>
; 
<normalizedToken id="F5056B6673400D8F80331C609664143C" originalValue="südwärts" pageId="null" pageNumber="590">suedwaerts</normalizedToken>
bis Nordafrika, Arabien, Persien. - Im Gebiet: Savoyen (Tarentaise, Maurienne), 
<normalizedToken id="8F896E2410B98D73382B05AFBADB6E78" originalValue="Dép" pageId="null" pageNumber="590">Dep</normalizedToken>
. Ain (Rhonetal), Wallis (zwischen St-Maurice und 
<normalizedToken id="CA8A40086056D41CDD7961714CC704B2" originalValue="Mörel" pageId="null" pageNumber="590">Moerel</normalizedToken>
), Aostatal (Ivrea bis La Salle), ziemlich selten; gelegentlich auch adventiv.
</paragraph>
</subSubSection>
