<subSubSection id="B67088067AB599D44A09BB9331DC71CD" pageId="null" pageNumber="60" type="description">
<paragraph id="1131DFC67F8BB1607BE8B24F00C95372" pageId="null" pageNumber="60">
<emphasis id="514E056239E00F11977C2E4114F87619" italics="true" pageId="null" pageNumber="60">Bis 8 m hoch, windend und kletternd, mit verholzten Stengeln.</emphasis>
<normalizedToken id="3F940053D3A4CF6ED2E56484725EA8C9" originalValue="Blätter" pageId="null" pageNumber="60">Blaetter</normalizedToken>
lang gestielt, gefiedert, mit 3 oder 5 lang gestielten 
<normalizedToken id="137CD237B0D12B131FBCE8C79C16C076" originalValue="Teilblättern" pageId="null" pageNumber="60">Teilblaettern</normalizedToken>
; Stiele der 
<normalizedToken id="B051890AEE256095F1B35BB140FF2E48" originalValue="Teilblätter" pageId="null" pageNumber="60">Teilblaetter</normalizedToken>
oft hin und her gebogen. 
<normalizedToken id="F14C15C1B1A70EE3B9DDD650700C9D9F" originalValue="Teilblätter" pageId="null" pageNumber="60">Teilblaetter</normalizedToken>
breit lanzettlich, bis 10 cm lang, nicht weniger als 2mal so lang wie breit, am Grunde oft 
<normalizedToken id="DDD41A300320B2CB185F5195F42E85B6" originalValue="herzförmig" pageId="null" pageNumber="60">herzfoermig</normalizedToken>
, grob, 
<normalizedToken id="DA4B9B51B018DE9A759D6727D8E982ED" originalValue="unregelmäßig" pageId="null" pageNumber="60">unregelmaessig</normalizedToken>
und asymmetrisch 
<emphasis id="4D0C475BF3FEEF090B2F6F0061F1FC14" italics="true" pageId="null" pageNumber="60">
<normalizedToken id="BA8FC93F3A7B74E464152BA8F1671042" originalValue="gezähnt" pageId="null" pageNumber="60">gezaehnt</normalizedToken>
bis
</emphasis>
<normalizedToken id="0ED17576573147290312ECFC71930A0B" originalValue="±" pageId="null" pageNumber="60">+/-</normalizedToken>
<emphasis id="A5757640FB5735802D1C4FD6D8309D31" italics="true" pageId="null" pageNumber="60">tief geteilt</emphasis>
, einzelne auch ganzrandig. 
<normalizedToken id="A53E7FAB06EF9F4ECD3D870F42AF0413" originalValue="Blütenstände" pageId="null" pageNumber="60">Bluetenstaende</normalizedToken>
<normalizedToken id="6ED4FE1E9095C7C906636897FBF8AA74" originalValue="endständig" pageId="null" pageNumber="60">endstaendig</normalizedToken>
und in Blattachseln, 
<emphasis id="31FBA42824119BC94EF84FAF7596736E" italics="true" pageId="null" pageNumber="60">
<normalizedToken id="37A436D5C53FC241E13C438CDF64D09D" originalValue="vielblütig" pageId="null" pageNumber="60">vielbluetig</normalizedToken>
, rispig.
</emphasis>
<normalizedToken id="128479D3B9F23C8EE2ADB7CC9204D0DA" originalValue="Blüten" pageId="null" pageNumber="60">Blueten</normalizedToken>
abstehend; 
<emphasis id="B31D2716FAD39021E41EAA9CF1D3050F" italics="true" pageId="null" pageNumber="60">Durchmesser</emphasis>
(
<emphasis id="4F5CEFDC70776F1C431BDA84C9289A09" italics="true" pageId="null" pageNumber="60">ausgebreitet</emphasis>
) 
<emphasis id="29419F2ACF2919ED84D94C1459EE4E3B" italics="true" pageId="null" pageNumber="60">bis 2,5 cm</emphasis>
. 
<normalizedToken id="83319832F9193FFDF9C85E019009FAE7" originalValue="Perigonblätter" pageId="null" pageNumber="60">Perigonblaetter</normalizedToken>
oval, bis 1,5 cm lang, abstehend, 
<emphasis id="7BE2153A4BF2FA0AD87D3871CF104021" italics="true" pageId="null" pageNumber="60">
<normalizedToken id="1F03BDE2240F94B785A17A6FCF368395" originalValue="weiß" pageId="null" pageNumber="60">weiss</normalizedToken>
</emphasis>
oder 
<normalizedToken id="B31A65FF2CC6465DEDF9A6D2DE86DA13" originalValue="außerseits" pageId="null" pageNumber="60">ausserseits</normalizedToken>
<normalizedToken id="302D0852CA88974DAED4F81CA4C8A436" originalValue="grünlich" pageId="null" pageNumber="60">gruenlich</normalizedToken>
, 
<emphasis id="D6355AD308C937E64866F105399F9EC1" italics="true" pageId="null" pageNumber="60">
<normalizedToken id="0D6FAC66FAF63C42BCD635C2F5C7E775" originalValue="überall" pageId="null" pageNumber="60">ueberall</normalizedToken>
dicht flaumig behaart
</emphasis>
. 
<normalizedToken id="161016236CE13965CE11F842E98DFF81" originalValue="Honigblätter" pageId="null" pageNumber="60">Honigblaetter</normalizedToken>
keine. 
<normalizedToken id="8FE66C8814718C1C83A587E94BCE24D3" originalValue="Staubfäden" pageId="null" pageNumber="60">Staubfaeden</normalizedToken>
kahl; 
<emphasis id="8DEEC74A33822604C1316382862473E2" italics="true" pageId="null" pageNumber="60">Staubbeutel 1-2 mm lang;</emphasis>
<normalizedToken id="BCF7E890BE30996E7D378276BC1623BF" originalValue="Früchtchen" pageId="null" pageNumber="60">Fruechtchen</normalizedToken>
mit bis 3 cm langem, abstehend behaartem Griffel. - 
<normalizedToken id="1FBE46CEA711C1029752687ECC63D683" originalValue="Blüte" pageId="null" pageNumber="60">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="0636FE96E80D4C686422FD5AD4C86868" pageId="null" pageNumber="60">
<emphasis id="30D77C023BD4AF5EC476105031D4E025" italics="true" pageId="null" pageNumber="60">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="84343DA441286CE60478E567CDAA2357" italics="true" pageId="null" pageNumber="60">16</emphasis>
(s. unter Gattung).
</paragraph>
<paragraph id="4C26AD0AEE7B7C90CEEE28BA51C4DA0F" pageId="null" pageNumber="60">
<emphasis id="D150AB4ED195940437D32A47791D7CD2" italics="true" pageId="null" pageNumber="60">Standort.</emphasis>
Kollin und montan, selten subalpin. Frische, 
<normalizedToken id="EED31A43943D734040D95312514BE0A8" originalValue="nährstoffreiche" pageId="null" pageNumber="60">naehrstoffreiche</normalizedToken>
<normalizedToken id="696D5D2BA424EE3E41955A98B272B4FA" originalValue="Böden" pageId="null" pageNumber="60">Boeden</normalizedToken>
. 
<normalizedToken id="04588612A98652FC4C68E1CC97254F61" originalValue="Auenwälder" pageId="null" pageNumber="60">Auenwaelder</normalizedToken>
, 
<normalizedToken id="B3A8A735AD3CF7060066BF2E468BD1B4" originalValue="Waldschläge" pageId="null" pageNumber="60">Waldschlaege</normalizedToken>
, Hecken.
</paragraph>
<paragraph id="D7098A136C3D2C0037CE75B074672EDB" pageId="null" pageNumber="60">
<emphasis id="1AFEE00D5BC596E9A9D6067593DDD352" italics="true" pageId="null" pageNumber="60">
Verbreitung. 
<normalizedToken id="7A1BDAB24E9AE9F3E5DD8BAB9B05BE52" originalValue="Europäische" pageId="null" pageNumber="60">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="DADFFC21812D4D38053FD0F95EBAA905" originalValue="Nordwärts" pageId="null" pageNumber="60">Nordwaerts</normalizedToken>
bis England, Norddeutschland, 
<normalizedToken id="F20FDA1F0F9156B110686C4F7F257151" originalValue="Österreich" pageId="null" pageNumber="60">Oesterreich</normalizedToken>
, Donaubecken, Krim, 
<normalizedToken id="64C580B97D7B4E2A5ADAB01496F65E0B" originalValue="südwärts" pageId="null" pageNumber="60">suedwaerts</normalizedToken>
bis 
<normalizedToken id="A09E1BAD05D49E1709482DEF0052FAA4" originalValue="Südspanien" pageId="null" pageNumber="60">Suedspanien</normalizedToken>
, Sizilien, Peloponnes, Kleinasien; 
<normalizedToken id="83AB8FE1DC7EBE8F8BFE67BD0BDD38A7" originalValue="ostwärts" pageId="null" pageNumber="60">ostwaerts</normalizedToken>
bis in den Kaukasus. Verbreitungskarte von Meusel (1965). - Im Gebiet verbreitet und 
<normalizedToken id="B912B8976A679BD11722BA5EF7773D92" originalValue="häufig" pageId="null" pageNumber="60">haeufig</normalizedToken>
, kommt in einigen zentralalpinen 
<normalizedToken id="A28A0E43D104760209A3847A4B7DC3DF" originalValue="Tälern" pageId="null" pageNumber="60">Taelern</normalizedToken>
nicht vor.
</paragraph>
</subSubSection>
