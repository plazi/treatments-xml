<subSubSection id="AC9F793B6D72AFCC4DDD23B16C0106FE" pageId="null" pageNumber="137" type="vernacular_names">
<paragraph id="A4C7A9FA4FE144F1938E835083770E18" pageId="null" pageNumber="137">Berg-Kalaminthe, Winter-Bohnenkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="43AC69D7CACE5DDC7897F500FFA945BD" pageId="null" pageNumber="137" type="description">
<paragraph id="2D2008B4047D803AD89870F56E6A66C8" pageId="null" pageNumber="137">
<emphasis id="2771FD281B6D728BB408867AC435C95B" italics="true" pageId="null" pageNumber="137">Ausdauernd, mit im untern Teil verholztem Stengel;</emphasis>
stark aromatisch riechend (
<normalizedToken id="0A1FEC6155A8883419FE070ACE2B9A05" originalValue="ähnlich" pageId="null" pageNumber="137">aehnlich</normalizedToken>
wie 
<taxonomicName id="0A7F4C0FA3CF517EDA1DBC3593708F35" authority="Nr." authorityName="Nr." class="Magnoliopsida" family="Lamiaceae" genus="Satureja" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="137" phylum="Tracheophyta" rank="species" species="hortensis">
<emphasis id="72A32374B3609E6927C19D91DEE7CB1B" italics="true" pageId="null" pageNumber="137">S. hortensis</emphasis>
Nr.
</taxonomicName>
1); 10-40 cm hoch. Stengel aufsteigend bis aufrecht, verzweigt, im obern Teil sehr kurz und 
<normalizedToken id="323532FB00EDEF8EAEB1A24573C0464A" originalValue="rückwärts" pageId="null" pageNumber="137">rueckwaerts</normalizedToken>
anliegend behaart. 
<normalizedToken id="443C9402F840E48498D477E6A06497A0" originalValue="Blätter" pageId="null" pageNumber="137">Blaetter</normalizedToken>
wie 
<taxonomicName id="97E0B4A935A6F369ABC21EA4FC9A2E5E" class="Magnoliopsida" family="Lamiaceae" genus="Satureja" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="137" phylum="Tracheophyta" rank="species" species="hortensis">
<emphasis id="05A86DD868D7B99BF43DA91B21061B60" italics="true" pageId="null" pageNumber="137">S. hortensis</emphasis>
</taxonomicName>
(Nr. 1), aber lederig und kaum gestielt. 
<normalizedToken id="DDD6D3D02F3E81B76CC724340F5456ED" originalValue="Blüten" pageId="null" pageNumber="137">Blueten</normalizedToken>
kurz gestielt, zu 1-7 in doldenartigen, gestielten 
<normalizedToken id="C7C64BF478912F6FABF5F9EBD3AB088E" originalValue="Teilblütenständen" pageId="null" pageNumber="137">Teilbluetenstaenden</normalizedToken>
, in den Achseln der obersten 
<normalizedToken id="FD8564A6ADF89DC5EE44F7EDA147B6DC" originalValue="Blätter" pageId="null" pageNumber="137">Blaetter</normalizedToken>
, einseitswendig. Kelch eng 
<normalizedToken id="69FDE65FE13CA0BEBE6D815D4D516D3A" originalValue="glockenförmig" pageId="null" pageNumber="137">glockenfoermig</normalizedToken>
, 10nervig, 3,5-5 mm lang, etwa bis auf ⅔ in 5 etwas ungleiche (die obern 
<normalizedToken id="D3719756BEBB47AF169459319448D5EE" originalValue="kürzer" pageId="null" pageNumber="137">kuerzer</normalizedToken>
als die untern), schmale, lang zugespitzte 
<normalizedToken id="071A3573DA15B19013D2E10307A0FF08" originalValue="Zähne" pageId="null" pageNumber="137">Zaehne</normalizedToken>
geteilt; 
<emphasis id="EE2D3C4E32D3C1183CE09E3ADA6E0104" italics="true" pageId="null" pageNumber="137">
<normalizedToken id="8F9B277C7B784288EBFF55E40536062D" originalValue="Kelchröhre" pageId="null" pageNumber="137">Kelchroehre</normalizedToken>
innen lang behaart
</emphasis>
(
<emphasis id="45430376C2C5A15AA34D15B862374213" italics="true" pageId="null" pageNumber="137">
<normalizedToken id="D67849C49C162041F2290F0274D540AE" originalValue="bärtiger" pageId="null" pageNumber="137">baertiger</normalizedToken>
Schlund
</emphasis>
). 
<emphasis id="BD0F3750C92DA24019613E8687F494EF" italics="true" pageId="null" pageNumber="137">Krone 0,6</emphasis>
- 
<emphasis id="955405FFB4C577A5CB387A88B05F56E9" italics="true" pageId="null" pageNumber="137">
1 cm lang, 
<normalizedToken id="9C94B4F2C2C24E473B95A691099711CC" originalValue="weiß" pageId="null" pageNumber="137">weiss</normalizedToken>
, rosa oder violett.
</emphasis>
<normalizedToken id="2D2D551997E8584E33D77AA134A5BA59" originalValue="Griffeläste" pageId="null" pageNumber="137">Griffelaeste</normalizedToken>
<normalizedToken id="5A3F21EA005BF95C052581DAB9C7068C" originalValue="±" pageId="null" pageNumber="137">+/-</normalizedToken>
gleich lang. - 
<normalizedToken id="287908700960CDEA033DB2E76F0E07A4" originalValue="Blüte" pageId="null" pageNumber="137">Bluete</normalizedToken>
: 
<normalizedToken id="649FA1073816AD24A90B4A9A6F5437CA" originalValue="Später" pageId="null" pageNumber="137">Spaeter</normalizedToken>
Sommer und Herbst.
</paragraph>
<paragraph id="C3BB0A6B842059A4A79D5F857E1044ED" pageId="null" pageNumber="137">
<emphasis id="CC188702E28BF1C5E72FFB95EDF7C2B0" italics="true" pageId="null" pageNumber="137">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="01883776BA47D48AF15D66ED41799567" italics="true" pageId="null" pageNumber="137">30:</emphasis>
Material aus botanischem Garten (Vaarama 1947).
</paragraph>
<paragraph id="F27ED00F91189C3152D2B582C56B588C" pageId="null" pageNumber="137">
<emphasis id="0F05B0659CD5040441EB973F57943B2D" italics="true" pageId="null" pageNumber="137">Standort.</emphasis>
Kollin. Trockene, steinige, kalkreiche 
<normalizedToken id="A5AC574FAA3F0AFD3F26E0A863D5CD2A" originalValue="Böden" pageId="null" pageNumber="137">Boeden</normalizedToken>
in warmen Lagen. Felsige 
<normalizedToken id="FDD4C736F7F36943735C4050E41E005F" originalValue="Hänge" pageId="null" pageNumber="137">Haenge</normalizedToken>
; selten 
<normalizedToken id="4A0F112639157AAF471D1B8FD88330F5" originalValue="Schuttplätze" pageId="null" pageNumber="137">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="1878E740F0D014B90DAC9B4F3E096087" pageId="null" pageNumber="137">
<emphasis id="FA25C978BCC95A9FA56A87DF0404EFD6" italics="true" pageId="null" pageNumber="137">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="562E19B8F21086969EBEB119E1220B34" originalValue="Nordwärts" pageId="null" pageNumber="137">Nordwaerts</normalizedToken>
bis Gironde, 
<normalizedToken id="BFE726C82540CB51D1B8465F3286ADDD" originalValue="südlicher" pageId="null" pageNumber="137">suedlicher</normalizedToken>
Jura, 
<normalizedToken id="B33507A9D3CFE5454A0CB025407998ED" originalValue="Alpensüdfuß" pageId="null" pageNumber="137">Alpensuedfuss</normalizedToken>
; 
<normalizedToken id="4D36F33869C0AF561816331A5D9BDAAC" originalValue="ostwärts" pageId="null" pageNumber="137">ostwaerts</normalizedToken>
bis Dongebiet, Kaukasus; Algerien. - Im Gebiet: Valle 
<normalizedToken id="72929A444C3A12F2E50CE32056AB8B56" originalValue="d’Ossola" pageId="null" pageNumber="137">d'Ossola</normalizedToken>
(alte Angaben), Comerseegebiet (z. B. Resegone, Valle 
<normalizedToken id="D832EC7466B3F7B41F9232A8923E34A2" originalValue="d’Intelvi" pageId="null" pageNumber="137">d'Intelvi</normalizedToken>
, Assina), Bergamasker Alpen (Valle Seriana), 
<normalizedToken id="8E3C9A9FF5B96B133547B92310FAF1A4" originalValue="Dép" pageId="null" pageNumber="137">Dep</normalizedToken>
. Ain (Umgebung von Belley), 
<normalizedToken id="00849B7CEF7E14CC950EA197383CB4D3" originalValue="Salève" pageId="null" pageNumber="137">Saleve</normalizedToken>
.
</paragraph>
</subSubSection>
