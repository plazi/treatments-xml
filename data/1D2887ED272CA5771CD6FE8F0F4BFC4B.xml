in a small triangular amber piece (length about 
<quantity id="52799B1E272CA5721E6CFE33090AFE40" box="[532,600,403,425]" metricMagnitude="-2" metricUnit="m" metricValue="1.1" pageId="1" pageNumber="320" unit="mm" value="11.0">11 mm</quantity>
and width 
<quantity id="52799B1E272CA5721EBCFE330852FE40" box="[708,768,403,425]" metricMagnitude="-3" metricUnit="m" metricValue="7.0" pageId="1" pageNumber="320" unit="mm" value="7.0">7 mm</quantity>
