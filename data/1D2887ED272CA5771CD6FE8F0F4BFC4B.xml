<materialsCitation id="25E93CA6272CA5721C9BFED80859FE40" ID-GBIF-Occurrence="3751797301" collectionCode="SIZK, UA" location="Rovno" pageId="1" pageNumber="320" specimenCode="SIZK UA-51" specimenCount="1" stateProvince="Rivne" typeStatus="holotype">
