. In association with scleractinians, 
<taxonomicName id="2EF86FE5FFDFFFBBFD33FBC8FB61FB7B" authority="Veron &amp; Pichon, 1980" authorityName="Veron &amp; Pichon" authorityYear="1980" box="[655,1152,1146,1172]" class="Anthozoa" family="Euphylliidae" genus="Euphyllia" kingdom="Animalia" order="Scleractinia" pageId="15" pageNumber="100" phylum="Cnidaria" rank="species" species="ancora">
