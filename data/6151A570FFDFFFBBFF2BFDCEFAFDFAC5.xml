<collectingCountry id="91EF54F6FFDFFFBBFB74FC56FAEBFC10" box="[1224,1290,997,1023]" name="Japan" pageId="15" pageNumber="100">Japan</collectingCountry>
(
<geoCoordinate id="8CCC72A1FFDFFFBBFAA3FC56FA79FC10" box="[1311,1432,997,1023]" degrees="26" direction="north" minutes="20.2" orientation="latitude" pageId="15" pageNumber="100" precision="92" value="26.336666">26º20.2'N</geoCoordinate>
