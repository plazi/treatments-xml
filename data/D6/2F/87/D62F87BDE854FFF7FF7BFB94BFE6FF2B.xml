<keyLead box="[151,1436,1337,1359]" pageId="1" pageNumber="592">3. Second hind tarsomere 3.0–3.6 × as long as wide............................................................ 4</keyLead>
</paragraph>
<paragraph blockId="1.[151,1437,1161,2034]" box="[151,1436,1367,1389]" pageId="1" pageNumber="592">
<keyLead box="[151,1436,1367,1389]" pageId="1" pageNumber="592">- Second hind tarsomere less than 3.0 × as long as wide........................................................ 5</keyLead>
</paragraph>
</keyStep>
<keyStep pageId="1" pageNumber="592">
<paragraph blockId="1.[151,1437,1161,2034]" pageId="1" pageNumber="592">
<keyLead pageId="1" pageNumber="592">
