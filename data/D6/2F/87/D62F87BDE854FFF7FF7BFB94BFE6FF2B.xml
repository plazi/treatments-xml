<figureCitation box="[551,629,1455,1477]" captionStart="FIGURE 1" captionStartId="2.[151,250,1955,1979]" captionTargetBox="[151,1436,437,1932]" captionTargetId="figure-167@2.[151,1436,437,1932]" captionTargetPageId="2" captionText="FIGURE 1. Lycorina sehgali sp. nov., holotype, female A) habitus, lateral view; B) head, anterior view; C) head, dorsal view; D) head &amp; mesosoma, oblique view; E) head &amp; mesosoma, lateral view; F) mesosoma, dorsal view." figureDoi="http://doi.org/10.5281/zenodo.6854124" httpUri="https://zenodo.org/record/6854124/files/figure.png" pageId="1" pageNumber="592">Figs 1B</figureCitation>
