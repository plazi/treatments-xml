<figureCitation box="[1258,1339,1689,1711]" captionStart="FIGURE 4" captionStartId="5.[151,250,1936,1960]" captionTargetBox="[151,1436,417,1912]" captionTargetId="figure-141@5.[151,1436,417,1912]" captionTargetPageId="5" captionText="FIGURE 4. Lycorina ruficornis Kasparyan, female A) habitus, lateral view; B) head, anterior view; C) head, dorsal view; D) mesosoma, dorsal view; E) metasoma, dorsal view; F) wings." figureDoi="http://doi.org/10.5281/zenodo.6854130" httpUri="https://zenodo.org/record/6854130/files/figure.png" pageId="1" pageNumber="592">Figs 4A</figureCitation>
