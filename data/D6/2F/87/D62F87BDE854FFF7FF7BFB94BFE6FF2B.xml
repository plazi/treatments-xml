<figureCitation box="[1392,1425,1689,1711]" captionStart="FIGURE 6" captionStartId="7.[151,250,1700,1724]" captionTargetBox="[151,1436,181,1676]" captionTargetId="figure-19@7.[151,1436,181,1676]" captionTargetPageId="7" captionText="FIGURE 6. Lycorina triangulifera Holmgren, female A) habitus, lateral view; B) head, anterior view; C) head, dorsal view; D) head &amp; mesosoma, lateral view; E) propodeum, dorsal view; F) metasoma, dorsal view." figureDoi="http://doi.org/10.5281/zenodo.6854134" httpUri="https://zenodo.org/record/6854134/files/figure.png" pageId="1" pageNumber="592">6A</figureCitation>
