<figureCitation box="[639,672,1455,1476]" captionStart="FIGURE 3" captionStartId="4.[151,250,1972,1996]" captionTargetBox="[166,1421,703,1949]" captionTargetId="figure-272@4.[166,1421,703,1949]" captionTargetPageId="4" captionText="FIGURE 3. Lycorina sehgali sp. nov., holotype, female A) head &amp; fore leg, anterior view; B) hind legs, lateral view; C) ovipositor &amp; sheath, lateral view." figureDoi="http://doi.org/10.5281/zenodo.6854128" httpUri="https://zenodo.org/record/6854128/files/figure.png" pageId="1" pageNumber="592">3A</figureCitation>
