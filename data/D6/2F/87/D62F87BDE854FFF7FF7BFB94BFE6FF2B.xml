<figureCitation box="[1350,1382,1689,1711]" captionStart="FIGURE 5" captionStartId="6.[151,250,1700,1724]" captionTargetBox="[151,1436,181,1676]" captionTargetId="figure-27@6.[151,1436,181,1676]" captionTargetPageId="6" captionText="FIGURE 5. Lycorina spilonotae Chao, female A) habitus, lateral view; B) head, anterior view; C) head, dorsal view; D) head &amp; mesosoma, lateral view; E) propodeum, dorsal view; F) metasoma, dorsal view." figureDoi="http://doi.org/10.5281/zenodo.6854132" httpUri="https://zenodo.org/record/6854132/files/figure.png" pageId="1" pageNumber="592">5A</figureCitation>
