<bibRefCitation id="EF9844B4732BFFA19021FCC0F403FCE1" author="Chemsak JA &amp; Linsley EG" box="[309,628,768,795]" pageId="6" pageNumber="5" pagination="216 - 226" refId="ref14348" refString="Chemsak JA, Linsley EG. 1964. Descriptions and records of Hesperophanini, with keys to the species of Anatinomma and Amphelictus (Coleoptera, Cerambycidae). Journal of the Kansas Entomological Society 37 (3): 216 - 226." type="journal article" year="1964">Chemsak and Linsley (1964)</bibRefCitation>
described 
<taxonomicName id="4C0942C6732BFFA193F9FCC0F5ABFCE0" authorityName="Chemsak and Linsley" authorityYear="1964" box="[749,988,768,794]" class="Insecta" family="Cerambycidae" genus="Anatinomma" kingdom="Animalia" order="Coleoptera" pageId="6" pageNumber="5" phylum="Arthropoda" rank="species" species="insulare">
