<subSubSection id="9270CBA5FF5C1EC6E0C0EFF5F79292D7" pageId="null" pageNumber="726" type="description">
<paragraph id="2C8D72EF5BB706350139CE0D569E7FA9" pageId="null" pageNumber="726">
<emphasis id="CDD764DCD4ADEB1FF9D976B310BBA26B" italics="true" pageId="null" pageNumber="726">
<normalizedToken id="4148CE1BB9F58858BC96F394AEE7EB95" originalValue="Blätter" pageId="null" pageNumber="726">Blaetter</normalizedToken>
nicht lederig, 3-5mal so lang wie breit
</emphasis>
, 0,4-0,9 cm breit, 
<emphasis id="4F9F3F9A96334B838BD3BF695948773F" italics="true" pageId="null" pageNumber="726">am Rande flach</emphasis>
, oberseits mit wenigen bis zahlreichen 0,3-0,8 mm langen, nach vorn gerichteten Borstenhaaren, 
<emphasis id="ED24AB46963673FB487742427C6AC2E4" italics="true" pageId="null" pageNumber="726">unterseits zudem mit einzelnen Sternhaaren</emphasis>
(Strahlen nach allen Seiten gerichtet, 0,2-0,6 mm lang). 
<emphasis id="FF247897826264CB45A7A19AD8E1C2B7" italics="true" pageId="null" pageNumber="726">
<normalizedToken id="66E25E6228FC1AD7406EC5A4CD9C68E6" originalValue="Kelchblätter" pageId="null" pageNumber="726">Kelchblaetter</normalizedToken>
5-8 mm lang, auf den Nerven mit 0,3-1 mm langen Borstenhaaren zwischen den Nerven mit einzelnen kleinen Sternhaaren.
</emphasis>
<normalizedToken id="4AC2397B7550ECC1D8ED63A39E8D695D" originalValue="Kronblätter" pageId="null" pageNumber="726">Kronblaetter</normalizedToken>
8-12 mm lang. Staubbeutel 0,4-0,6 mm lang. - 
<normalizedToken id="0A00AA1A34F0361F51CB5342527D04E0" originalValue="Blüte" pageId="null" pageNumber="726">Bluete</normalizedToken>
: 
<normalizedToken id="E243DC23B980541369F3733D84236E7B" originalValue="Später" pageId="null" pageNumber="726">Spaeter</normalizedToken>
<normalizedToken id="11BE80A71AD26556DBF5E7CD2BDCEEB2" originalValue="Frühling" pageId="null" pageNumber="726">Fruehling</normalizedToken>
und 
<normalizedToken id="2BC8A94FDA3C944A6D828BA7F8983FF8" originalValue="früher" pageId="null" pageNumber="726">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="691CE88B0D7C4DA780E2028247E5C034" pageId="null" pageNumber="726">
<emphasis id="F81AD3A70484AAC8C95AFA772E18FB82" italics="true" pageId="null" pageNumber="726">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B4CBC62F930282C41AD7CFA8490CC45F" italics="true" pageId="null" pageNumber="726">20:</emphasis>
Material von Interlaken (Rohner 1954), aus 
<normalizedToken id="3B789033C39309C34C66F40848F785F4" originalValue="Dänemark" pageId="null" pageNumber="726">Daenemark</normalizedToken>
und von Donaueschingen (Proctor 1955).
</paragraph>
<paragraph id="FC158B68BFD9A246CC4933313444BD37" pageId="null" pageNumber="726">
<emphasis id="CFD86D2C25F6884DD39E28946C788E03" italics="true" pageId="null" pageNumber="726">Standort.</emphasis>
Kollin und montan. Ziemlich trockene, oft kalkhaltige 
<normalizedToken id="95B30DDFD91D4A951F02048763903978" originalValue="Böden" pageId="null" pageNumber="726">Boeden</normalizedToken>
. Trockene, magere Wiesen, 
<normalizedToken id="85964836983A9A59B09E0AEBC262D32D" originalValue="Gebüsche" pageId="null" pageNumber="726">Gebuesche</normalizedToken>
.
</paragraph>
<paragraph id="3D9C05584AE6D64E67720C7579E5F30D" pageId="null" pageNumber="726">
<emphasis id="079F84FF0229D9C726F479D3DA7249F0" italics="true" pageId="null" pageNumber="726">
Verbreitung. 
<normalizedToken id="78C6F2E51FB20535E13396395562EF41" originalValue="Mitteleuropäische" pageId="null" pageNumber="726">Mitteleuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="580C653DF39E29761523BD0AFE98F640" originalValue="Nordwärts" pageId="null" pageNumber="726">Nordwaerts</normalizedToken>
bis Schweden; 
<normalizedToken id="ABDB71F765E1FBA339C6A4B53CD959BD" originalValue="südwärts" pageId="null" pageNumber="726">suedwaerts</normalizedToken>
bis 
<normalizedToken id="EA30A316EDEFFB531E5006EA590C9548" originalValue="Pyrenäen" pageId="null" pageNumber="726">Pyrenaeen</normalizedToken>
(?), Alpen. - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="89E434563048417D7E7D1CCAC5B05346" originalValue="häufig" pageId="null" pageNumber="726">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
