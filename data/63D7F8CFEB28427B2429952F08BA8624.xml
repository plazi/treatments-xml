<subSubSection id="6E2474E1F59ECAB9EEDFF015F9D90897" pageId="null" pageNumber="430" type="description">
<paragraph id="7AB9032BE533D13CEC01057292482B2C" pageId="null" pageNumber="430">
30-100 cm hoch; horstbildend. 
<normalizedToken id="9BCC76FD2EC1857599B3820637B6087C" originalValue="Blätter" pageId="null" pageNumber="430">Blaetter</normalizedToken>
5-8 mm breit, schlaff gebogen, meist 
<normalizedToken id="F84403B328569FC0AAB0B71B8A0F8FFC" originalValue="kürzer" pageId="null" pageNumber="430">kuerzer</normalizedToken>
als der Stengel, 
<emphasis id="C0E5B8E082B05E70A88D8612EA18098A" italics="true" pageId="null" pageNumber="430">
<normalizedToken id="0E3F0986426834C2920854CD9DC291D0" originalValue="gelbgrün" pageId="null" pageNumber="430">gelbgruen</normalizedToken>
.
</emphasis>
Stengel 3kantig, 
<emphasis id="7888805DD791E41B05467F146F16E189" italics="true" pageId="null" pageNumber="430">auffallend dick</emphasis>
(
<emphasis id="1F2EB69D7A7698C11C440E815E2319EF" italics="true" pageId="null" pageNumber="430">Kantenabstand im obersten Drittel 2,5-4 mm</emphasis>
); 
<emphasis id="20E92CDD516ED782E0FE70B1EF7388E5" italics="true" pageId="null" pageNumber="430">
Kanten deutlich 
<normalizedToken id="F88C37EEA9138600A62A59BA79F257B8" originalValue="geflügelt" pageId="null" pageNumber="430">gefluegelt</normalizedToken>
</emphasis>
(nur bei Nrn. 17 und 18 so!). 
<emphasis id="CE02CDE1B53D1B84A072FF249856DF82" italics="true" pageId="null" pageNumber="430">
<normalizedToken id="8E0CA180E68D14A1D39C5DFD8B6AEE7D" originalValue="Blütenstand" pageId="null" pageNumber="430">Bluetenstand</normalizedToken>
<normalizedToken id="86BEA4F3DD7C1806C6054CA2EBD1A1E4" originalValue="gelbgrün" pageId="null" pageNumber="430">gelbgruen</normalizedToken>
</emphasis>
, zylindrisch, 2-8 cm lang, 1-1,5 cm dick, aus zahlreichen 
<normalizedToken id="59DCBE6A692BD73B7459AF6E83199827" originalValue="±" pageId="null" pageNumber="430">+/-</normalizedToken>
dicht stehenden 
<normalizedToken id="518733EBCD629A34AE7A456985412790" originalValue="Ähren" pageId="null" pageNumber="430">Aehren</normalizedToken>
gebildet; alle 
<normalizedToken id="86D515AEC08E90F85DF12891AD01F59D" originalValue="Ähren" pageId="null" pageNumber="430">Aehren</normalizedToken>
unten ♀, oben ♂. Unterstes Hochblatt 
<normalizedToken id="D558B8A32FA17ABC35674B75EE7AC3B4" originalValue="fadenförmig" pageId="null" pageNumber="430">fadenfoermig</normalizedToken>
, 2-10 cm lang, abstehend. 
<normalizedToken id="49A02501DB1CEE38EFF5F42A8D1985ED" originalValue="Tragblätter" pageId="null" pageNumber="430">Tragblaetter</normalizedToken>
etwa so lang wie die reifen 
<normalizedToken id="943B370E4DBE9314965872D362D3E117" originalValue="Fruchtschläuche" pageId="null" pageNumber="430">Fruchtschlaeuche</normalizedToken>
, 
<normalizedToken id="0DCE126E8282E8B3374E184A1015FD3D" originalValue="gelbgrün" pageId="null" pageNumber="430">gelbgruen</normalizedToken>
bis hellbraun, mit 
<normalizedToken id="043972AECCFDCABE1FA7BF9E9CF53246" originalValue="hellgrünem" pageId="null" pageNumber="430">hellgruenem</normalizedToken>
Mittelnerv und grannenartiger Spitze. 
<normalizedToken id="5BE955E23C47C028E5D71377CD8E747B" originalValue="Fruchtschläuche" pageId="null" pageNumber="430">Fruchtschlaeuche</normalizedToken>
4,4-5,5 mm lang, im untersten Drittel am breitesten (2-2,4 mm), 
<emphasis id="0BC77875BDE4459C8C0A16990C928F09" italics="true" pageId="null" pageNumber="430">beiderseits mit zahlreichen</emphasis>
(
<emphasis id="9D711B9CBB7CB087931B5D0058792AD4" italics="true" pageId="null" pageNumber="430">10-16</emphasis>
) 
<emphasis id="A69C99FFCB49FC3417D1D17410DE581F" italics="true" pageId="null" pageNumber="430">deutlichen Nerven</emphasis>
(innerseits Nerven oft nur im untersten Drittel des Fruchtschlauches); 
<emphasis id="23D460805076CEA2FB58D96DDAECD1F0" italics="true" pageId="null" pageNumber="430">
<normalizedToken id="B802FB4095FD470EA6DC27B314E87A34" originalValue="Oberfläche" pageId="null" pageNumber="430">Oberflaeche</normalizedToken>
deutlich lackartig 
<normalizedToken id="1757094C039EB46431A7941A7A449DF1" originalValue="glänzend" pageId="null" pageNumber="430">glaenzend</normalizedToken>
, glatt
</emphasis>
, hellbraun, 
<normalizedToken id="4F9B13868A0926049041DD35AAC2692A" originalValue="allmählich" pageId="null" pageNumber="430">allmaehlich</normalizedToken>
in den Schnabel 
<normalizedToken id="32F375B8485AE58CFA5F4EF140939233" originalValue="verschmälert" pageId="null" pageNumber="430">verschmaelert</normalizedToken>
; Schnabel mit 
<emphasis id="E598C2EBBA7B4CA2E4ACE764027CAC96" italics="true" pageId="null" pageNumber="430">
2 innerseits und 
<normalizedToken id="7225506D750815E6C2B0B94D8868C3D3" originalValue="auβerseits" pageId="null" pageNumber="430">auβerseits</normalizedToken>
gleich tief eingeschnittenen, nicht spreizenden 
<normalizedToken id="5361DD2090CD3C84446DFA0759F8D68D" originalValue="Zähnen" pageId="null" pageNumber="430">Zaehnen</normalizedToken>
.
</emphasis>
Narben 2.
</paragraph>
<paragraph id="15B59CF16D05BA12EA685EFA27EC8AFD" pageId="null" pageNumber="430">
<emphasis id="8DB74AA95CD9F6B99A3D2CB8428BFDB0" italics="true" pageId="null" pageNumber="430">Zytologische Angaben. 2n = 60:</emphasis>
Ohne Herkunftsangabe des Materials (Tanaka aus Tischler 1950), aus der Provinz 
<normalizedToken id="A470446729D88BC754F4A061D84EDBF5" originalValue="Jaén" pageId="null" pageNumber="430">Jaen</normalizedToken>
in Spanien (Kjellqvist und 
<normalizedToken id="654A217212680D2E4FB429FCD97C1379" originalValue="Löve" pageId="null" pageNumber="430">Loeve</normalizedToken>
1963).
</paragraph>
<paragraph id="CCD3A23F1061EA9B768F44D2968640EF" pageId="null" pageNumber="430">
<emphasis id="D2BA55CEC1511D13D07999055047AFD6" italics="true" pageId="null" pageNumber="430">Standort.</emphasis>
Kollin. 
<normalizedToken id="4CAED1C23F24425252B077F2FA6E2DA3" originalValue="Wasserzügige" pageId="null" pageNumber="430">Wasserzuegige</normalizedToken>
, lehmige, kalkhaltige 
<normalizedToken id="9317E4D4952AFB517121B31061C82AFA" originalValue="Böden" pageId="null" pageNumber="430">Boeden</normalizedToken>
. Lichte 
<normalizedToken id="43B9BD8542ACDFB1209A4356C12BA5A7" originalValue="Laubmischwälder" pageId="null" pageNumber="430">Laubmischwaelder</normalizedToken>
.
</paragraph>
<paragraph id="19CE992B69971BF90EC2356F912A1E82" pageId="null" pageNumber="430">
<emphasis id="961C31C4DCF3DCD38B34D53307EB6E8D" italics="true" pageId="null" pageNumber="430">
Verbreitung. 
<normalizedToken id="1D0FCB2B401BFDC1FC3C212F4FB1A6CD" originalValue="Westeuropäisch-mediterrane" pageId="null" pageNumber="430">Westeuropaeisch-mediterrane</normalizedToken>
Pflanze:
</emphasis>
Westeuropa, 
<normalizedToken id="43EF7296CCF20DFFC103253EF3FC46C9" originalValue="nordwärts" pageId="null" pageNumber="430">nordwaerts</normalizedToken>
bis 56° NB, Ostgrenze durch Baltikum, Polen und 
<normalizedToken id="41A2BD732494A2791235F96A6657FDA8" originalValue="Rumänien" pageId="null" pageNumber="430">Rumaenien</normalizedToken>
; Nordafrika, Kleinasien, Syrien, Persien, Kaukasien. - Im ganzen Gebiet verbreitet, im Mittelland ziemlich 
<normalizedToken id="DAA81715C335180CC967C8ACC52CDA55" originalValue="häufig" pageId="null" pageNumber="430">haeufig</normalizedToken>
, sonst selten.
</paragraph>
<paragraph id="AB3176D04D345D8DF6CC7135403C472F" pageId="null" pageNumber="430">
<emphasis id="65832A58F089193BD40106568F8B6E1B" italics="true" pageId="null" pageNumber="430">Bemerkungen.</emphasis>
Siehe unter 
<taxonomicName id="760C3A9B8320818DF1F9BA3AF2EDAA03" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="430" phylum="Tracheophyta" rank="species" species="vulpina">
<emphasis id="81DAD361DBC08DA377547C0019757B25" italics="true" pageId="null" pageNumber="430">C. vulpina</emphasis>
</taxonomicName>
(Nr. 18).
</paragraph>
</subSubSection>
