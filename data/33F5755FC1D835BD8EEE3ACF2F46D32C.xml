<subSubSection id="2F65EAF0B3B1C5185D58B248E464CE38" pageId="null" pageNumber="458" type="vernacular_names">
<paragraph id="7A1E3D6627B9FD783089FDF1EA525D86" pageId="null" pageNumber="458">Tannen-Rose</paragraph>
</subSubSection>
</title>
<subSubSection id="1BDC7C87D223CD6568C7079D208CE83A" pageId="null" pageNumber="458" type="description">
<paragraph id="E459585DEFA6E28C862F6A660CB75F8D" pageId="null" pageNumber="458">
<emphasis id="FB2DFB99DF133E1EDB9F73B42424CD2D" italics="true" pageId="null" pageNumber="458">
<normalizedToken id="EDBD92F305166638F3C66106F1014B9E" originalValue="Blätter" pageId="null" pageNumber="458">Blaetter</normalizedToken>
beiderseits, nur unterseits oder unterseits nur auf den Nerven flaumig behaart
</emphasis>
, doppelt 
<normalizedToken id="1635B51AD595CAC67E6F026C789300DC" originalValue="gezähnt" pageId="null" pageNumber="458">gezaehnt</normalizedToken>
; Blattstiele stets flaumig behaart, mit 
<normalizedToken id="5FBD2D295BE1777AA2E33FD8555CDE0F" originalValue="Stieldrüsen" pageId="null" pageNumber="458">Stieldruesen</normalizedToken>
und 
<normalizedToken id="075943B6C83CF0DBA343FD6EB952AF5D" originalValue="sichelförmigen" pageId="null" pageNumber="458">sichelfoermigen</normalizedToken>
Stacheln. 
<emphasis id="BC0944EA1E6726977458616135619737" italics="true" pageId="null" pageNumber="458">
<normalizedToken id="6C30AC351E35B98C4C2E8C1CB4FC68AB" originalValue="Blütenstiele" pageId="null" pageNumber="458">Bluetenstiele</normalizedToken>
mit 
<normalizedToken id="214D108BE4597035317569BD956D748C" originalValue="Stieldrüsen" pageId="null" pageNumber="458">Stieldruesen</normalizedToken>
.
</emphasis>
<normalizedToken id="8693A64A8EF598784488621B2225458B" originalValue="Kelchblätter" pageId="null" pageNumber="458">Kelchblaetter</normalizedToken>
nach der 
<normalizedToken id="19E1EE27668F41F7D28252E20844778A" originalValue="Blüte" pageId="null" pageNumber="458">Bluete</normalizedToken>
<emphasis id="922EF2C6A980B06941DC6D85850D4EBA" italics="true" pageId="null" pageNumber="458">
<normalizedToken id="B97048E41CFB219D8F6249012C0FF362" originalValue="zurückgebogen" pageId="null" pageNumber="458">zurueckgebogen</normalizedToken>
</emphasis>
, vor der Fruchtreife abfallend.
</paragraph>
<paragraph id="D37EE02BF441071E618CB5C123263F52" pageId="null" pageNumber="458">
<emphasis id="AE90951A73A51FAFAF79A8139BAADA63" italics="true" pageId="null" pageNumber="458">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="A5415EA4F271710C982CDBFE2169FB81" pageId="null" pageNumber="458">
<emphasis id="2D4EE45C83C7FEA14DBBAB7D11448430" italics="true" pageId="null" pageNumber="458">Standort.</emphasis>
Montan und subalpin, selten kollin. 
<normalizedToken id="096244649C1D3E2DE78EEE4C2A87547A" originalValue="Nährstoffreiche" pageId="null" pageNumber="458">Naehrstoffreiche</normalizedToken>
, trockene bis frische, kalkfreie 
<normalizedToken id="D7B4D26A7DF0B78285F0A0E8B75BA5B6" originalValue="Lehmböden" pageId="null" pageNumber="458">Lehmboeden</normalizedToken>
. Lichte 
<normalizedToken id="8251A36715B6F0CF707E7E6539E8F2AD" originalValue="Buschwälder" pageId="null" pageNumber="458">Buschwaelder</normalizedToken>
, 
<normalizedToken id="093ACC003248C52FC034AF33E50273E7" originalValue="Waldränder" pageId="null" pageNumber="458">Waldraender</normalizedToken>
, Hecken.
</paragraph>
<paragraph id="39D35197B4398767B53B2D0C687E7F48" pageId="null" pageNumber="458">
<emphasis id="2A30F09263DEDF080FA08287C2822A36" italics="true" pageId="null" pageNumber="458">Verbreitung. Alpen-Pflanze:</emphasis>
Von der 
<normalizedToken id="BA4704539AEE226AA19E1B1CD87265F1" originalValue="Dauphiné" pageId="null" pageNumber="458">Dauphine</normalizedToken>
bis ins 
<normalizedToken id="F01B0FE4D40F0C2BD92F6E97934E6DDB" originalValue="Südtirol" pageId="null" pageNumber="458">Suedtirol</normalizedToken>
und Oberbayern. Angaben aus dem Schwarzwald unsicher. - Im Gebiet in den Alpen verbreitet und ziemlich 
<normalizedToken id="BF5BA0607FB20F282DF6F1361C9EC7D1" originalValue="häufig" pageId="null" pageNumber="458">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
