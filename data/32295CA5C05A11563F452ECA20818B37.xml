<subSubSection id="CFBF22DF3AC4C0A079D36B200F8B7862" pageId="null" pageNumber="552" type="description">
<paragraph id="E843CDD22383139E79DDDE1F00EFFEA0" pageId="null" pageNumber="552">
30-100 cm hoch. 
<normalizedToken id="987CA92FFFFCC4A5CF6E0E32295EE30F" originalValue="Blätter" pageId="null" pageNumber="552">Blaetter</normalizedToken>
schmal oval, 5-15 cm lang und 2-4 cm breit, etwa in der Mitte am breitesten, sitzend, im untern und obern Stengelteil deutlich 
<normalizedToken id="F745BFFA142E8ED15AA0D98C1AB023F4" originalValue="wechselständig" pageId="null" pageNumber="552">wechselstaendig</normalizedToken>
, 
<emphasis id="5E492971952072B4A114CB919BB63FE2" italics="true" pageId="null" pageNumber="552">
im mittleren Stengelteil zu 4-8 quirlartig 
<normalizedToken id="6FA891C56DE47B26FE2DB5F2E6CD4DD4" originalValue="zusammengedrängt" pageId="null" pageNumber="552">zusammengedraengt</normalizedToken>
.
</emphasis>
<normalizedToken id="FFC49FD51235E410C20852D0CBEFE0EF" originalValue="Blütenstand" pageId="null" pageNumber="552">Bluetenstand</normalizedToken>
eine 3-10 
<normalizedToken id="F41FA78472B6C0AA34A77799CFC8FA83" originalValue="blütige" pageId="null" pageNumber="552">bluetige</normalizedToken>
Traube. 
<normalizedToken id="9B6EAA8DEC06BAD9DA2CD6B83AC64D1E" originalValue="Blüten" pageId="null" pageNumber="552">Blueten</normalizedToken>
an schief 
<normalizedToken id="9E5843F037244996641E4C43CC23DBBE" originalValue="aufwärts" pageId="null" pageNumber="552">aufwaerts</normalizedToken>
gerichteten Stielen 
<emphasis id="6B78BC6CF6DBC8A7730E383D6E569081" italics="true" pageId="null" pageNumber="552">
<normalizedToken id="ECA1308E7B393004AB1A771BDB74BE54" originalValue="hängend" pageId="null" pageNumber="552">haengend</normalizedToken>
.
</emphasis>
<normalizedToken id="667D6359B93AC5A4A5281F9E996EA17E" originalValue="Perigonblätter" pageId="null" pageNumber="552">Perigonblaetter</normalizedToken>
schmal oval, gestreckt bis 7 cm lang, 
<emphasis id="9EFC927F423808ADF5D44B3D1738DB15" italics="true" pageId="null" pageNumber="552">
<normalizedToken id="CA3563B53BC14125DA5ED4A0FD3593B1" originalValue="ungefähr" pageId="null" pageNumber="552">ungefaehr</normalizedToken>
von der Mitte an 
<normalizedToken id="48ACCCAEF5E393A81B2C25EEF48969F1" originalValue="zurückgebogen" pageId="null" pageNumber="552">zurueckgebogen</normalizedToken>
</emphasis>
, hellpurpurn, mit dunklen Flecken. - 
<normalizedToken id="F51BA99CC31734CD5AA0E6F642249198" originalValue="Blüte" pageId="null" pageNumber="552">Bluete</normalizedToken>
: 
<normalizedToken id="9B35906B22525C2B564A996E93A1906B" originalValue="Früher" pageId="null" pageNumber="552">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="3403510920ECE33697CDF7C84559D603" pageId="null" pageNumber="552">
<emphasis id="AFCD7D5E175D1059B1F339723A360446" italics="true" pageId="null" pageNumber="552">Zytologische Angaben. 2n = 24:</emphasis>
Zahlreiche 
<normalizedToken id="68AD45E3890CEB166DC3355E17351E42" originalValue="übereinstimmende" pageId="null" pageNumber="552">uebereinstimmende</normalizedToken>
<normalizedToken id="D448F1E7FC9E9A053A9DBA4455A0FB7D" originalValue="Zählungen" pageId="null" pageNumber="552">Zaehlungen</normalizedToken>
aus dem weiten Verbreitungsgebiet der Art, zusammengestellt von 
<normalizedToken id="AE413CF0178FB7F1CBAA59F128584E21" originalValue="Löve" pageId="null" pageNumber="552">Loeve</normalizedToken>
und 
<normalizedToken id="A06CECDE250341880C295387A1E14278" originalValue="Löve" pageId="null" pageNumber="552">Loeve</normalizedToken>
(1961), Sorsa (1963). Einzig Fernandes (1950) fand an Material aus Portugal 1-3 
<normalizedToken id="60C606A27511B9467B653EA0E1E73EA1" originalValue="zusätzliche" pageId="null" pageNumber="552">zusaetzliche</normalizedToken>
Chromosomen. Heimans (1928) untersuchte die Embryosackentwicklung und die 
<normalizedToken id="58C721BAAEF963939059979852769188" originalValue="Befruchtungsvorgänge" pageId="null" pageNumber="552">Befruchtungsvorgaenge</normalizedToken>
.
</paragraph>
<paragraph id="2C8D7CD046080948FC4C5385262CF073" pageId="null" pageNumber="552">
<emphasis id="E3EFA018BE22830582FA30995A027AAE" italics="true" pageId="null" pageNumber="552">Standort.</emphasis>
Kollin, montan, subalpin und selten alpin (bis 2650 m). Frische bis 
<normalizedToken id="0A8B8C5452266C16A6048DF4768C9B3F" originalValue="wasserzügige" pageId="null" pageNumber="552">wasserzuegige</normalizedToken>
, meist kalkhaltige 
<normalizedToken id="D73CAFA7DBACBFC890BE34242DC78897" originalValue="Lehmböden" pageId="null" pageNumber="552">Lehmboeden</normalizedToken>
mit guter 
<normalizedToken id="4EAE1B8690D7D078889C9DDBBBC952AA" originalValue="Durchlüftung" pageId="null" pageNumber="552">Durchlueftung</normalizedToken>
. 
<normalizedToken id="5FEDC17D4A2FFBB0A5CEFE98A1FA67EC" originalValue="Laubmischwälder" pageId="null" pageNumber="552">Laubmischwaelder</normalizedToken>
, 
<normalizedToken id="2D1FCEA087CABB23BED47B45EDA13A1D" originalValue="Buchenwälder" pageId="null" pageNumber="552">Buchenwaelder</normalizedToken>
, 
<normalizedToken id="0DD097C95A29365F410EC711BBE933D8" originalValue="Schluchtwälder" pageId="null" pageNumber="552">Schluchtwaelder</normalizedToken>
, Zwergstrauchgesell-schaften, Bergwiesen.
</paragraph>
<paragraph id="5B7FEB09A898457C279D9D0116BA8057" pageId="null" pageNumber="552">
<emphasis id="C45004ED0C04E92B61145D0196F03EDF" italics="true" pageId="null" pageNumber="552">Verbreitung. Eurasiatische Pflanze:</emphasis>
Mittel- und nordspanische und portugiesische Gebirge, 
<normalizedToken id="B311DA799A7698E2BBC9697071E59BC0" originalValue="Pyrenäen" pageId="null" pageNumber="552">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="56FBE2FA8CBF6C0EDFD4C06FB949F0ED" originalValue="zentral-französische" pageId="null" pageNumber="552">zentral-franzoesische</normalizedToken>
Gebirge, 
<normalizedToken id="F8DB0F0F9D000F7FF4F6B2749DB9807C" originalValue="mitteleuropäische" pageId="null" pageNumber="552">mitteleuropaeische</normalizedToken>
Gebirge (
<normalizedToken id="968224945A17AC8E520685DB75A993B1" originalValue="nordwärts" pageId="null" pageNumber="552">nordwaerts</normalizedToken>
bis zur norddeutschen Tiefebene), 
<normalizedToken id="30BE494171176394FAA24D862376C94A" originalValue="südwärts" pageId="null" pageNumber="552">suedwaerts</normalizedToken>
bis in den Apennin und Gebirge der Balkanhalbinsel; in England und Schottland nicht 
<normalizedToken id="D32620331B59BFBABF3236BF36BB263C" originalValue="ursprünglich" pageId="null" pageNumber="552">urspruenglich</normalizedToken>
; Kaukasus; in Asien 
<normalizedToken id="208080B074D396518A7F18EACE4B0C1E" originalValue="hauptsächlich" pageId="null" pageNumber="552">hauptsaechlich</normalizedToken>
zwischen 40 und 60° NB, 
<normalizedToken id="199A76D07BB61818C77C1FBED16290DD" originalValue="ostwärts" pageId="null" pageNumber="552">ostwaerts</normalizedToken>
bis ins Baikalseegebiet. Verbreitungskarte von Meusel (1964). - Im Gebiet verbreitet, stellenweise selten, weil ausgerottet.
</paragraph>
</subSubSection>
