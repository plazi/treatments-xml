<taxonomicName id="A9DD0A2C3832B28C3A0B80B7E982C221" authority="Heynh." class="Magnoliopsida" family="Brassicaceae" genus="Arabidopsis" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="226" phylum="Tracheophyta" rank="genus">
