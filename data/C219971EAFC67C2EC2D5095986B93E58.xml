<subSubSection id="E71768C60E2598B558BB8C2BD38ABBD7" pageId="null" pageNumber="60" type="description">
<paragraph id="5D3277E94D85DCAB157A7D8CD9A8B6FB" pageId="null" pageNumber="60">
Unterscheidet sich von 
<taxonomicName id="2717BE7631614268013FBDC1D8E11CDF" class="Magnoliopsida" family="Ranunculaceae" genus="Clematis" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="60" phylum="Tracheophyta" rank="species" species="vitalba">
<emphasis id="7B54CA548B877144A291B6CBB8407C2C" italics="true" pageId="null" pageNumber="60">C. Vitalba</emphasis>
</taxonomicName>
(Nr. 4) durch folgende Merkmale: 
<emphasis id="E3FD812DE4BE34E78EED03974E1FA4A7" italics="true" pageId="null" pageNumber="60">
<normalizedToken id="FE96D36A75660D450E2FC43027CC2491" originalValue="Teilblätter" pageId="null" pageNumber="60">Teilblaetter</normalizedToken>
ganzrandig; 
<normalizedToken id="057D68F5832F94EF13359FED0F506851" originalValue="Perigonblätter" pageId="null" pageNumber="60">Perigonblaetter</normalizedToken>
nur am Rande dicht und filzig behaart; Staubbeutel 2,5-4 mm lang.
</emphasis>
- 
<normalizedToken id="0A370BCF325D83BB3DDC19F58B7F6F84" originalValue="Blüte" pageId="null" pageNumber="60">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="8B4836F36E5B1FF55193627E3FA99AC3" pageId="null" pageNumber="60">
<emphasis id="FB86DA148A8B447AEB17DDA8A17F6DAB" italics="true" pageId="null" pageNumber="60">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E40B1523A1A0BE8647152EDAF5164108" italics="true" pageId="null" pageNumber="60">16</emphasis>
(s. unter Gattung).
</paragraph>
<paragraph id="853768C086E1AA179AD3B5F7E009C91D" pageId="null" pageNumber="60">
<emphasis id="3E619AF2522FA01FD70D11E62E2B0478" italics="true" pageId="null" pageNumber="60">Standort.</emphasis>
Kollin. 
<normalizedToken id="8F3159C72CA7FDEDACA96A25935C9FC9" originalValue="Gebüsche" pageId="null" pageNumber="60">Gebuesche</normalizedToken>
, 
<normalizedToken id="38B977C80939499251FFF7824F541BA2" originalValue="Waldränder" pageId="null" pageNumber="60">Waldraender</normalizedToken>
(Flaumeichenbusch).
</paragraph>
<paragraph id="DFCD78576193BB1CD6BC821C99830926" pageId="null" pageNumber="60">
<emphasis id="952F0467E5313EEBCBBC514EA46982FB" italics="true" pageId="null" pageNumber="60">Verbreitung. Mediterrane Pflanze:</emphasis>
Ganzes Mediterrangebiet, vereinzelter Fundort in Persien. Verbreitungskarte von Meusel (1965). - Im Gebiet: 
<normalizedToken id="D388CA194577D98FA34E582AD8EBA01E" originalValue="Südlich" pageId="null" pageNumber="60">Suedlich</normalizedToken>
Lecco am Comersee bei Galbiate.
</paragraph>
