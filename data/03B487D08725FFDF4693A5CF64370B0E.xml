<emphasis id="B969EAD48727FFD84693A659643E0CFC" bold="true" box="[151,315,1663,1687]" pageId="3" pageNumber="592">FIGURES 1–5.</emphasis>
<taxonomicName id="4C1D4D458727FFD84747A65967530CFC" authority="Heffern &amp; Santos-Silva, 2022" authorityName="Heffern &amp; Santos-Silva" authorityYear="2022" box="[323,598,1663,1687]" class="Insecta" family="Cerambycidae" genus="Parmakanthion" kingdom="Animalia" order="Coleoptera" pageId="3" pageNumber="592" phylum="Arthropoda" rank="species" species="profundum" status="sp. nov.">
<emphasis id="B969EAD48727FFD84747A65967530CFC" box="[323,598,1663,1687]" italics="true" pageId="3" pageNumber="592">Parmakanthion profundum</emphasis>
</taxonomicName>
<emphasis id="B969EAD48727FFD84459A65967AA0CFC" bold="true" box="[605,687,1663,1687]" pageId="3" pageNumber="592">
<taxonomicNameLabel id="A25A57AF8727FFD84459A65967AA0CFC" box="[605,687,1663,1687]" pageId="3" pageNumber="592" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
, holotype male: 
<emphasis id="B969EAD48727FFD84559A65966770CFC" bold="true" box="[861,882,1663,1687]" pageId="3" pageNumber="592">1)</emphasis>
