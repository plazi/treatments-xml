<taxonomicName id="19A64D13B73328410919FC063E8AFC0C" box="[323,468,919,948]" class="Mammalia" family="Cebidae" genus="Cebus" kingdom="Animalia" order="Primates" pageId="22" pageNumber="412" phylum="Chordata" rank="species" species="albifrons">C. albifrons</taxonomicName>
<taxonomicName id="19A64D13B73328410987FC063D3CFC0C" authorityName="Elliot" authorityYear="1909" box="[477,610,919,948]" class="Mammalia" family="Cebidae" genus="Cebus" kingdom="Animalia" order="Primates" pageId="22" pageNumber="412" phylum="Chordata" rank="species" species="malitiosus">malitiosus</taxonomicName>
