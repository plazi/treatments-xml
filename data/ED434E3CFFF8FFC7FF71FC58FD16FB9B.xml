<heading id="3E1D4846FFF8FFC7FF71FC58FDBEFC0A" bold="true" box="[151,579,906,933]" fontSize="11" level="2" pageId="16" pageNumber="17" reason="3">
<taxonomicName id="A2EA84A9FFF8FFC7FF71FC58FDBEFC0A" authority="(Linnaeus, 1767)" baseAuthorityName="Linnaeus" baseAuthorityYear="1767" box="[151,579,906,933]" class="Insecta" family="Noctuidae" genus="Eudocima" kingdom="Animalia" order="Lepidoptera" pageId="16" pageNumber="17" phylum="Arthropoda" rank="species" species="materna">
