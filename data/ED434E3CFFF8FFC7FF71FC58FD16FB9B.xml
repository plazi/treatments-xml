<emphasis id="579E2338FFF8FFC7FF71FC58FE89FC0B" bold="true" box="[151,372,906,933]" italics="true" pageId="16" pageNumber="17">Eudocima materna</emphasis>
(
<bibRefCitation id="017B82DBFFF8FFC7FE65FC58FDC6FC0A" author="Linnaeus, C." box="[387,571,906,932]" pageId="16" pageNumber="17" pagination="533 - 1327" refId="ref38945" refString="Linnaeus, C. (1767) Systema naturae. Editio duodecima reformata. Tome 1. Part 2. L. Salvius, Stockholm, 533 - 1327." type="book chapter" year="1767">Linnaeus, 1767</bibRefCitation>
