<taxonomicName id="D3EC7092920EFFC9FF58FA7BEED1FA50" authority="Ducasse &amp; Vigneaux, 1960" authorityName="Ducasse &amp; Vigneaux" authorityYear="1960" box="[212,657,1512,1529]" class="Gymnolaemata" family="Steginoporellidae" genus="Dimorphomicropora" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cheilostomatida" pageId="9" pageNumber="522" phylum="Bryozoa" rank="species" species="voigti">
