<emphasis id="2698D703920EFFC9FDB5F986EE07F98F" bold="true" box="[569,583,1557,1574]" pageId="9" pageNumber="522">C</emphasis>
, 
<emphasis id="2698D703920EFFC9FDDEF986EE20F98F" bold="true" box="[594,608,1557,1574]" pageId="9" pageNumber="522">G</emphasis>
