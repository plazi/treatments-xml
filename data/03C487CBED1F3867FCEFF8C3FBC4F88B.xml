<emphasis id="B919EACFED033867FF4DFAFFFEE8FA8A" bold="true" box="[136,301,1329,1355]" pageId="594" pageNumber="595">FIGURE 399.</emphasis>
<taxonomicName id="4C6D4D5EED033867FEF1FAFFFDFEFA8A" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[308,571,1329,1355]" class="Maxillopoda" family="Notodelphyidae" genus="Campodelphys" kingdom="Animalia" order="Cyclopoida" pageId="594" pageNumber="595" phylum="Arthropoda" rank="species" species="bullatus" status="sp. nov.">
<emphasis id="B919EACFED033867FEF1FAFFFDFEFA8A" box="[308,571,1329,1355]" italics="true" pageId="594" pageNumber="595">Campodelphysbullatus</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A22A57B4ED033867FD86FAFFFD58FA8D" box="[579,669,1329,1356]" pageId="594" pageNumber="595" rank="species">
<emphasis id="B919EACFED033867FD86FAFFFD52FA8A" bold="true" box="[579,663,1329,1355]" pageId="594" pageNumber="595">sp. nov</emphasis>
.
</taxonomicNameLabel>
, female. A, leg 1; B, leg 2; C, leg 3; D, leg 4. Scale bars: 0.02 mm.
</paragraph>
