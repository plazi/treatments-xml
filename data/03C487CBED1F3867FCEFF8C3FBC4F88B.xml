<subSubSection id="C3776556ED033867FC9AFA74FBC4F88B" pageId="594" pageNumber="595" type="discussion">
<paragraph id="8BD236DDED033867FC9AFA74FBC4F88B" blockId="594.[810,1451,1431,1866]" pageId="594" pageNumber="595">
<emphasis id="B919EACFED033867FC9AFA74FC09FA15" bold="true" box="[863,972,1466,1492]" pageId="594" pageNumber="595">Remarks</emphasis>
. 
<taxonomicName id="4C6D4D5EED033867FC18FA77FB2DFA12" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[989,1256,1465,1491]" class="Maxillopoda" family="Notodelphyidae" genus="Campodelphys" kingdom="Animalia" order="Cyclopoida" pageId="594" pageNumber="595" phylum="Arthropoda" rank="species" species="bullatus" status="gen. et sp. nov.">
<emphasis id="B919EACFED033867FC18FA77FB2DFA12" box="[989,1256,1465,1491]" italics="true" pageId="594" pageNumber="595">Campodelphysbullatus</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A22A57B4ED033867FB37FA74FA6EFA15" box="[1266,1451,1466,1492]" pageId="594" pageNumber="595" rank="species">
<emphasis id="B919EACFED033867FB37FA74FA60FA15" bold="true" box="[1266,1445,1466,1492]" pageId="594" pageNumber="595">gen. etsp. nov</emphasis>
