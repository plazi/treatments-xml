<paragraph blockId="16.[151,1437,1807,2014]" pageId="16" pageNumber="517">
<taxonomicName authorityName=", Pit Sculpin Bailey and Bond" authorityYear="1963" box="[151,317,1808,1834]" class="Actinopterygii" family="Cottidae" genus="Cottus" kingdom="Animalia" order="Scorpaeniformes" pageId="16" pageNumber="517" phylum="Chordata" rank="species" species="pitensis">
<emphasis box="[151,317,1808,1834]" italics="true" pageId="16" pageNumber="517">Cottus pitensis</emphasis>
</taxonomicName>
