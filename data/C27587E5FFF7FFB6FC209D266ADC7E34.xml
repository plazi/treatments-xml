1950. 
<taxonomicName id="8DDC4D70FFF7FFB6FC289D876DDA7CB6" authority="NAKKADY" authorityName="NAKKADY" box="[898,1239,451,472]" class="Globothalamea" family="Anomalinidae" genus="Anomalina" kingdom="Chromista" order="Rotaliida" pageId="26" pageNumber="40" phylum="Foraminifera" rank="species" species="pseudoacuta">
