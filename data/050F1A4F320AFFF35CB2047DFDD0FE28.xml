<paragraph id="8D19AB59320AFFF25CB206BBFC7BF931" blockId="4.[166,1225,1730,1779]" pageId="4" pageNumber="405">
Fig. 2. 
<taxonomicName id="4AA6D0DA320AFFF25CF006BBFE6EF915" baseAuthorityName="Fallien" baseAuthorityYear="1817" box="[228,410,1730,1751]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="4" pageNumber="405" phylum="Arthropoda" rank="species" species="mutabilis">
