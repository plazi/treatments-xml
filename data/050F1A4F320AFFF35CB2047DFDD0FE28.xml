— male genitalia; 
<emphasis id="BFD2774B320AFFF25CB206A4FEF3F931" box="[166,263,1757,1779]" italics="true" pageId="4" pageNumber="405">
<taxonomicName id="4AA6D0DA320AFFF25CB206A4FEF0F931" box="[166,260,1757,1779]" class="Insecta" family="Syrphidae" genus="Cheilosia" kingdom="Animalia" order="Diptera" pageId="4" pageNumber="405" phylum="Arthropoda" rank="species" species="nigrips">C. nigrips</taxonomicName>
