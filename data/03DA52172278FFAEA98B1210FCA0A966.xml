(
<bibRefCitation id="EFE29EF0227BFFAEABAB1094FC85AB26" author="Wolff, D." box="[654,799,239,266]" pageId="2" pageNumber="243" pagination="123 - 126" refId="ref5614" refString="Wolff, D. 1998. Pipiza accola Violovitsh, 1985 (Diptera, Syrphidae) - Erstnachweis fur Deutschland. Drosera, 2, 123 - 126." type="journal article" year="1998">Wolff, 1998</bibRefCitation>
