<bibRefCitation id="EFE29EF0227BFFAEA9831174FEF6AB06" author="Vujic, A. &amp; Stahls, G. &amp; Acanski, J. &amp; Bartsch, H. &amp; Bygebjerg, R. &amp; Stefanovic, A." box="[166,364,271,298]" pageId="2" pageNumber="243" pagination="288 - 305" refId="ref5551" refString="Vujic, A., Stahls, G., Acanski, J., Bartsch, H., Bygebjerg, R. &amp; Stefanovic, A. 2013. Systematics of Pipizini and taxonomy of European Pipiza Fallen: molecular and morphological evidence (Diptera, Syrphidae). Zoologica Scripta, 42 (3), 288 - 305." type="journal article" year="2013">Vujić et al., 2013</bibRefCitation>
; Speight, 2017; 
<bibRefCitation id="EFE29EF0227BFFAEAB071174FD74AB06" author="Mielczarek, L." box="[546,750,271,298]" pageId="2" pageNumber="243" pagination="2009 - 2018" refId="ref4471" refString="Mielczarek, L. 2018 (2009 - 2018). List of species Syrphidae of Poland (Diptera, Syrphidae). http: // syrphidae. insects. pl / checklist. php? lang = en" type="book chapter" year="2018">Mielczarek, 2018</bibRefCitation>
); 
