<collectionCode id="ED41AE0F882DEE43FC57F8116805F83C" box="[1010,1096,2011,2037]" country="Italy" httpUri="http://grbio.org/cool/353t-cj9k" name="Museo Civico di Storia Naturale, Verona" pageId="5" pageNumber="388">MCSN</collectionCode>
