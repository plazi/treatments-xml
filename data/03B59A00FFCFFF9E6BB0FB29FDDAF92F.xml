<bibRefCitation id="EF8D56E7FFCFFF9E6AF5FA9AFDA3FAC2" author="Forel, A." box="[466,637,1364,1386]" pageId="5" pageNumber="570" pagination="421 - 425" refId="ref7184" refString="Forel, A. (1904) Dimorphisme du male chez les fourmis et quelques autres notices myrmecologiques. Annales de la Societ Entomologique de Belgique, 48, 421 - 425." type="journal article" year="1904">Forel, 1904: 424</bibRefCitation>
