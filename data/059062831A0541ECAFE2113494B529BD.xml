<subSubSection id="D9A892EE301142D1FF47BE97B85E940C" pageId="null" pageNumber="87" type="description">
<paragraph id="BE443AB5CF01E6CFB38C43EB1B964139" pageId="null" pageNumber="87">
<normalizedToken id="ED5AE3A24D7CAE7B976C3D46B62C9E41" originalValue="Mehrjährig" pageId="null" pageNumber="87">Mehrjaehrig</normalizedToken>
, 0,3-0,8 m hoch; ganze Pflanze mit 
<normalizedToken id="FEC3841D85E2D57843031D6040579B6D" originalValue="±" pageId="null" pageNumber="87">+/-</normalizedToken>
anliegenden Haaren, die meisten davon am Grunde nicht verdickt. 
<normalizedToken id="C453BC51BB0692DC0EE1FE9A8B24A240" originalValue="Blätter" pageId="null" pageNumber="87">Blaetter</normalizedToken>
bis 15 cm lang, 5-10mal so lang wie breit, nach dem Grunde 
<normalizedToken id="540A3814AB74DDC9043B9D49DBB97FB9" originalValue="verschmälert" pageId="null" pageNumber="87">verschmaelert</normalizedToken>
, mit glattem Rand. Stengel mit wenigen, kurzen 
<normalizedToken id="9E83DCEFA90056578B8BE93BA15F60BE" originalValue="seitenständigen" pageId="null" pageNumber="87">seitenstaendigen</normalizedToken>
<normalizedToken id="CBD543FD33D89A954C608A6F7F1FB18C" originalValue="Blütenständen" pageId="null" pageNumber="87">Bluetenstaenden</normalizedToken>
. Kelch bis auf 
<normalizedToken id="F43D59EE859FD38C80767345231E3934" originalValue="höchstens" pageId="null" pageNumber="87">hoechstens</normalizedToken>
⅔ der 
<normalizedToken id="4D4F616ACE3812707355E0B0CF021A87" originalValue="Länge" pageId="null" pageNumber="87">Laenge</normalizedToken>
geteilt, 
<emphasis id="8F8AFE97A14D2A7E0707F71CC6037BED" italics="true" pageId="null" pageNumber="87">
mit breit abgerundeten, 
<normalizedToken id="2B7E648838BE1031DDA981140E7B7810" originalValue="häutigen" pageId="null" pageNumber="87">haeutigen</normalizedToken>
Zipfeln
</emphasis>
(im Gebiet nur bei dieser Art so!), zur Fruchtzeit 10-15 mm lang. 
<emphasis id="E0F137CABD806ABD36EC32F0161CA15A" italics="true" pageId="null" pageNumber="87">Krone gelb;</emphasis>
<normalizedToken id="6DA63B6CBD98F109A7BE3CF8D115D2A7" originalValue="Kronröhre" pageId="null" pageNumber="87">Kronroehre</normalizedToken>
7-10 mm lang; Durchmesser der Krone 7-10 mm. - 
<normalizedToken id="54B6681C53355F9691BCE3DCDDC93FAE" originalValue="Blüte" pageId="null" pageNumber="87">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="329F9F48461E510BA7214D640FF9B803" pageId="null" pageNumber="87">
<emphasis id="AD81C65B9DF50749D74AADAF876AD7B7" italics="true" pageId="null" pageNumber="87">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D41CB880B0FF3F4AB71987801F6F70EE" italics="true" pageId="null" pageNumber="87">24:</emphasis>
Material aus botanischen 
<normalizedToken id="A98B277DB8727E3AD7B1C05195ECD201" originalValue="Gärten" pageId="null" pageNumber="87">Gaerten</normalizedToken>
(Britton 1951).
</paragraph>
<paragraph id="AEE836A65885E26D856CDF3741ADABEC" pageId="null" pageNumber="87">
<emphasis id="772D54E657B267371809EBD791274539" italics="true" pageId="null" pageNumber="87">Standort.</emphasis>
Kollin. Ruderalstellen.
</paragraph>
<paragraph id="B51B9D5CF5F3B6CF545208EFD403559A" pageId="null" pageNumber="87">
<emphasis id="BDF2D01EF1DC19AE5EDF1430030A5ED7" italics="true" pageId="null" pageNumber="87">
Verbreitung. 
<normalizedToken id="2F3DC7104EF1CF2066A04B72534E97E0" originalValue="Südosteuropäische" pageId="null" pageNumber="87">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="410F24E35D881EF57D55357E62A4870A" originalValue="Südrußland" pageId="null" pageNumber="87">Suedrussland</normalizedToken>
, 
<normalizedToken id="515DDEAB5A0FC0890B28D2F5B4D038DB" originalValue="westwärts" pageId="null" pageNumber="87">westwaerts</normalizedToken>
bis Ungarn und Bulgarien; im westlichen Mediterrangebiet teilweise 
<normalizedToken id="605F2AA536ABC790E9FE6A0F09FC98E6" originalValue="eingebürgert" pageId="null" pageNumber="87">eingebuergert</normalizedToken>
. - Im Gebiet: 
<normalizedToken id="89235117C75823597C491642D04CD292" originalValue="Elsaß" pageId="null" pageNumber="87">Elsass</normalizedToken>
(
<normalizedToken id="FCC2D661961DE17F0263A2FD93BBC7DD" originalValue="Mülhausen" pageId="null" pageNumber="87">Muelhausen</normalizedToken>
).
</paragraph>
</subSubSection>
