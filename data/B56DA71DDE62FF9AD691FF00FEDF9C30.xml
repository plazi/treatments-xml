<taxonomicName id="FAC46D88DE6CFF99D7E5F941FD57996A" authorityName="Nicolet" authorityYear="1849" box="[474,701,1774,1795]" class="Arachnida" family="Tetragnathidae" genus="Diphya" kingdom="Animalia" order="Araneae" pageId="9" pageNumber="212" phylum="Arthropoda" rank="species" species="macrophthalma">
