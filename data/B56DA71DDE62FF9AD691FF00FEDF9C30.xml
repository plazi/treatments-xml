<taxonomicName id="FAC46D88DE6CFF99D5E5F97BFBA39881" authorityName="Marusik &amp; Omelko" authorityYear="2017" box="[986,1097,1747,1769]" class="Arachnida" family="Tetragnathidae" genus="Nediphya" kingdom="Animalia" order="Araneae" pageId="9" pageNumber="212" phylum="Arthropoda" rank="species" species="lehtineni">
