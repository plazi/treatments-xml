<subSubSection id="8C8E6575FF966A29FD2692AC1A5EBE57" pageId="109" pageNumber="867" type="discussion">
<paragraph id="C42B36FEFF966A29FD2692AC1A5EBE57" blockId="109.[729,1324,1194,1616]" pageId="109" pageNumber="867">
Previously considered a race of 
<taxonomicName id="03944D7DFF966A29FB5A92AC1D03BE0C" baseAuthorityName="J. Fischer" baseAuthorityYear="1829" class="Mammalia" family="Vespertilionidae" genus="Plecotus" kingdom="Animalia" order="Chiroptera" pageId="109" pageNumber="867" phylum="Chordata" rank="species" species="austriacus">P. austriacus</taxonomicName>
, but full species status is supported by genetic analyses. Monotypic.
</paragraph>
</subSubSection>
<subSubSection id="8C8E6575FF966A29FD2593361D21BEE8" pageId="109" pageNumber="867" type="distribution">
<caption id="90EB6676FF966A29FD2593361D21BEE8" ID-DOI="http://doi.org/10.5281/zenodo.6398297" ID-Zenodo-Dep="6398297" httpUri="https://zenodo.org/record/6398297/files/figure.png" inLine="true" pageId="109" pageNumber="867" targetBox="[114,705,1199,1612]" targetPageId="109">
<paragraph id="C42B36FEFF966A29FD2593361D21BEE8" blockId="109.[729,1324,1194,1616]" pageId="109" pageNumber="867">
<emphasis id="F6E0EAECFF966A29FD2593361D85BEBE" bold="true" box="[729,901,1391,1420]" pageId="109" pageNumber="867">Distribution.</emphasis>
SW 
<collectingCountry id="BC83766EFF966A29FC2793361A78BEBE" box="[987,1144,1391,1420]" name="Kazakhstan" pageId="109" pageNumber="867">Kazakhstan</collectingCountry>
, W 
<collectingCountry id="BC83766EFF966A29FB3D93361D11BE86" name="Uzbekistan" pageId="109" pageNumber="867">Uzbekistan</collectingCountry>
, and W 
<collectingCountry id="BC83766EFF966A29FC6E93CA1A54BE86" box="[914,1108,1427,1460]" name="Turkmenistan" pageId="109" pageNumber="867">Turkmenistan</collectingCountry>
