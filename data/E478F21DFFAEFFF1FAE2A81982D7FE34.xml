<geoCoordinate id="09E525CCFFAFFFF1FE6FAE468416FEA7" box="[1050,1139,296,323]" degrees="25" direction="south" minutes="13" orientation="latitude" pageId="27" pageNumber="28" precision="925" value="-25.216667">25°13′S</geoCoordinate>
<geoCoordinate id="09E525CCFFAFFFF1FE0FAE4684B8FEA7" box="[1146,1245,296,323]" degrees="44" direction="west" minutes="33" orientation="longitude" pageId="27" pageNumber="28" precision="925" value="-44.55">44°33′W</geoCoordinate>
(
<bibRefCitation id="08403EFAFFAFFFF1FE9EAE4885F5FEA4" author="Holthuis, L. B." box="[1259,1424,294,320]" pageId="27" pageNumber="28" pagination="723 - 884" refId="ref64870" refString="Holthuis, L. B. (1974) The lobsters of the superfamily Nephropidea of the Atlantic Ocean (Crustacea: Decapoda). Biological results of the University of Miami deep-sea expeditions. Bulletin of Marine Science, 24, 723 - 884." type="journal article" year="1974">Holthuis 1974</bibRefCitation>
). 
<taxonomicName id="ABD13888FFAFFFF1FAE2AE24811BFE80" authorityName="A. Milne-Edwards" authorityYear="1880" box="[151,382,330,356]" class="Malacostraca" family="Nephropidae" genus="Nephropsis" kingdom="Animalia" order="Decapoda" pageId="27" pageNumber="28" phylum="Arthropoda" rank="species" species="agassizii">
