<taxonomicName id="ABD13888FFAFFFF1FBC6AE258274FE80" authorityName="Spence Bate" authorityYear="1888" box="[435,529,331,356]" class="Malacostraca" family="Nephropidae" genus="Nephropsis" kingdom="Animalia" order="Decapoda" pageId="27" pageNumber="28" phylum="Arthropoda" rank="species" species="rosea">
