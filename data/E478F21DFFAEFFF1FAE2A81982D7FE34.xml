<quantity id="AB29EEEEFFAFFFF1FEB1AE24853DFE81" box="[1220,1368,330,357]" metricMagnitude="3" metricUnit="m" metricValue="1.7399999999999998" metricValueMax="2.9" metricValueMin="0.58" pageId="27" pageNumber="28" unit="m" value="1740.0" valueMax="2900.0" valueMin="580.0">580–2,900 m</quantity>
