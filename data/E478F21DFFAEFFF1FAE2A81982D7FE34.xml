<collectingRegion id="AE158DE9FFAFFFF1FB49AE0081CBFE6C" box="[316,430,366,392]" country="Brazil" name="Sao Paulo" pageId="27" pageNumber="28">São Paulo</collectingRegion>
(
<bibRefCitation id="08403EFAFFAFFFF1FBC8AE0082ECFE6C" author="Serejo, C. S. &amp; Young, P. S. &amp; Cardoso, I. C. &amp; Tavares, C. &amp; Rodrigues, C. &amp; Almeida, T. C." box="[445,649,366,392]" pageId="27" pageNumber="28" pagination="133 - 184" refId="ref78011" refString="Serejo, C. S., Young, P. S., Cardoso, I. C., Tavares, C., Rodrigues, C. &amp; Almeida, T. C. (2007) Abundancia, diversidade e zonacao dos crustaceos no talude da costa central do Brasil (11 º - 22 º S) coletados pelo Programa REVIZEE / Score Central: prospeccao pesqueira. In: Costa, P. A. S., Olavo, G. &amp; Martins, A. S. (Eds.). Biodiversidade da fauna marinha profunda na costa central brasileira. Rio de Janeiro: Museu Nacional, 24, pp. 133 - 184." type="journal article" year="2007">
Serejo 
<emphasis id="5EA59F19FFAFFFF1F87BAE01822DFE6C" box="[526,584,366,392]" italics="true" pageId="27" pageNumber="28">et al.</emphasis>
2007
</bibRefCitation>
) and 
<taxonomicName id="ABD13888FFAFFFF1F8BCAE018342FE6C" authorityName="Spence Bate" authorityYear="1888" box="[713,807,367,392]" class="Malacostraca" family="Nephropidae" genus="Nephropsis" kingdom="Animalia" order="Decapoda" pageId="27" pageNumber="28" phylum="Arthropoda" rank="species" species="rosea">
