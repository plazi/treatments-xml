<treatmentCitationGroup id="AB7511C19409FFD3BA9F3E31FA98FBF9" box="[151,1285,1083,1107]" pageId="6" pageNumber="257">
<treatmentCitation id="0AC410FE9409FFD3BA9F3E31FDA5FBF9" author="Suffrian, E." box="[151,568,1083,1107]" page="258" pageId="6" pageNumber="257" year="1866">
<taxonomicName id="4C654D6C9409FFD3BA9F3E31FDA5FBF9" authority="Suffrian, 1866: 258" authorityName=", Suffrian" authorityPageNumber="258" authorityYear="1866" box="[151,568,1083,1107]" class="Insecta" family="Chrysomelidae" genus="Metallactus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="6" pageNumber="257" phylum="Arthropoda" rank="species" species="insitivus">
<emphasis id="B911EAFD9409FFD3BA9F3E31FEF4FBF9" box="[151,361,1083,1107]" italics="true" pageId="6" pageNumber="257">Metallactus insitivus</emphasis>
<bibRefCitation id="EFF44B1E9409FFD3BB783E31FDA5FBF9" author="Suffrian, E." box="[368,568,1083,1107]" pageId="6" pageNumber="257" pagination="1 - 483" refId="ref25218" refString="Suffrian, E. (1866) Zur Kenntnis der Sudamerikanischen Cryptocephalen. Linnaea Entomologica, 16, 1 - 483." type="journal article" year="1866">Suffrian, 1866: 258</bibRefCitation>
