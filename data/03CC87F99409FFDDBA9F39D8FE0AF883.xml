<treatmentCitation id="0AC410FE9409FFD3B84A3E31FC93FBF9" author="Clavareau, C. H." box="[578,782,1083,1107]" page="93" pageId="6" pageNumber="257" year="1913">
<bibRefCitation id="EFF44B1E9409FFD3B84A3E31FC93FBF9" author="Clavareau, C. H." box="[578,782,1083,1107]" pageId="6" pageNumber="257" pagination="1 - 278" refId="ref24677" refString="Clavareau, C. H. (1913) Pars 53: Chrysomelidae: Megascelinae, Megalopodinae, Clytrinae, Cryptocephalinae, Chlamydinae, Lamprosominae. In: Schenkling, S. (Ed.), Coleopterorum Catalogus. W. Junk, Berlin, pp. 1 - 278." type="book chapter" year="1913">Clavareau, 1913: 93</bibRefCitation>
</treatmentCitation>
(catalogue); 
<treatmentCitation id="0AC410FE9409FFD3B99C3E31FB1BFBF9" author="Blackwelder, R. E." box="[916,1158,1083,1107]" page="641" pageId="6" pageNumber="257" year="1946">
