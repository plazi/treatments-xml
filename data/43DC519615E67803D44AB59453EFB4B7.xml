<subSubSection id="D5FE79B55432A911D3778A87FAD02EBF" pageId="null" pageNumber="346" type="description">
<paragraph id="CA4382B30309178328EE7D8DDA725E11" pageId="null" pageNumber="346">
<emphasis id="79E56C95774D88F020B28A8D133E3190" italics="true" pageId="null" pageNumber="346">
1 
<normalizedToken id="E740E51931AA6702C2BAF4BB851954E0" originalValue="jährig" pageId="null" pageNumber="346">jaehrig</normalizedToken>
</emphasis>
, 20-40 cm hoch (im Habitus wie ein kleines 
<taxonomicName id="F5BA4117AA3311F3810C08401E7F4801" class="Liliopsida" family="Poaceae" genus="Lolium" kingdom="Plantae" order="Poales" pageId="null" pageNumber="346" phylum="Tracheophyta" rank="genus">
<emphasis id="90550D170AB53393143838EE34F47710" italics="true" pageId="null" pageNumber="346">Lolium</emphasis>
</taxonomicName>
). 
<normalizedToken id="12DEEA06D41A5D43E1964946BC1363C2" originalValue="Blätter" pageId="null" pageNumber="346">Blaetter</normalizedToken>
kurz, 
<normalizedToken id="A9CC27DBF82D7A8B7806E7BAFE011377" originalValue="borstenförmig" pageId="null" pageNumber="346">borstenfoermig</normalizedToken>
; 
<normalizedToken id="F8452A711E2A6643BF462E7E3967BCE8" originalValue="Blatthäutchen" pageId="null" pageNumber="346">Blatthaeutchen</normalizedToken>
weniger als 0,5 mm lang, gestutzt, zerschlitzt, mit 2 deutlichen, 
<normalizedToken id="16F346CC5DD6FC842D1FF85E324840CD" originalValue="aufwärts" pageId="null" pageNumber="346">aufwaerts</normalizedToken>
gerichteten Zipfeln. 
<emphasis id="E9937194BA1E57C7B2FD0B6A545A510C" italics="true" pageId="null" pageNumber="346">
<normalizedToken id="DC5CC988097683F51DA8B0617EA54A43" originalValue="Blütenstand" pageId="null" pageNumber="346">Bluetenstand</normalizedToken>
eine 2-10 cm lange, 
<normalizedToken id="55BCC323C76ED64D50486C3FF19DABB3" originalValue="ährenartige" pageId="null" pageNumber="346">aehrenartige</normalizedToken>
Traube
</emphasis>
(
<emphasis id="8C077CC2803745521ADD374E21F6C9F4" italics="true" pageId="null" pageNumber="346">
<normalizedToken id="FA078CFC241890406BCCBB9563E4D0F2" originalValue="Ährchenstiele" pageId="null" pageNumber="346">Aehrchenstiele</normalizedToken>
dicker als lang
</emphasis>
)
<emphasis id="60926F05960BC1AA4341DA9C7B906A09" italics="true" pageId="null" pageNumber="346">
; Hauptachse der Traube 2kantig und die 
<normalizedToken id="1E958B3E35F49D3B1E6EF8C120E7635D" originalValue="Ährchen" pageId="null" pageNumber="346">Aehrchen</normalizedToken>
2zeilig angeordnet.
</emphasis>
<normalizedToken id="AC46BC5CFC37D4CF87FC52B56E1385A9" originalValue="Ährchen" pageId="null" pageNumber="346">Aehrchen</normalizedToken>
5-10 mm lang. 
<emphasis id="314E1BBFF9A2754F1A28EFC901405E37" italics="true" pageId="null" pageNumber="346">
Meist beide 
<normalizedToken id="8130D1DCB3E4D801866A9A22538822AE" originalValue="Hüllspelzen" pageId="null" pageNumber="346">Huellspelzen</normalizedToken>
3nervig. Deckspelzen stumpf.
</emphasis>
- 
<normalizedToken id="444BA1EAE40A894E2598A4076814FCE9" originalValue="Blüte" pageId="null" pageNumber="346">Bluete</normalizedToken>
: 
<normalizedToken id="B71BEA1491C702172AE627DA7FDCFD17" originalValue="Später" pageId="null" pageNumber="346">Spaeter</normalizedToken>
<normalizedToken id="34B2DC01636DC51FD33EDE6AEF94A8B7" originalValue="Frühling" pageId="null" pageNumber="346">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="B486C35F3FE56E35D1BF9DB78EA89D48" pageId="null" pageNumber="346">
<emphasis id="7F044AC30D10850CC9711059775605BD" italics="true" pageId="null" pageNumber="346">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="9F90D11C6A5E71FEDB6B3C0FF950B203" pageId="null" pageNumber="346">
<emphasis id="05E10C72C477C71C3009FC42B1767832" italics="true" pageId="null" pageNumber="346">Standort.</emphasis>
Kollin. Sandige, steinige, saure, offene 
<normalizedToken id="DBD568C704582C50E8E6AB6EB2792730" originalValue="Böden" pageId="null" pageNumber="346">Boeden</normalizedToken>
in sommertrockenen Gegenden. 
<normalizedToken id="503ECC426934A17118B9D4C58B9CBAEB" originalValue="Äcker" pageId="null" pageNumber="346">Aecker</normalizedToken>
, 
<normalizedToken id="FA3BABFDD1F67584354BED78C3CCB260" originalValue="Wegränder" pageId="null" pageNumber="346">Wegraender</normalizedToken>
, 
<normalizedToken id="0413A72AD84946A2F722C38510C56023" originalValue="Böschungen" pageId="null" pageNumber="346">Boeschungen</normalizedToken>
.
</paragraph>
<paragraph id="7FBD3059A4679A27C19D85EB2B10CE17" pageId="null" pageNumber="346">
<emphasis id="A27827184E2721247D9408A3A0EE5588" italics="true" pageId="null" pageNumber="346">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="2822A63EF507894847C32CCA739F5CDE" originalValue="Südeuropa" pageId="null" pageNumber="346">Suedeuropa</normalizedToken>
<normalizedToken id="CA39B58D762FCEAF738823D19B88C48E" originalValue="nordwärts" pageId="null" pageNumber="346">nordwaerts</normalizedToken>
bis Caen, Rheinland, Tessin, Balkanhalbinsel; Nordwestafrika. - Im Gebiet: Oberrheinische Tiefebene (
<normalizedToken id="89AAFF84CC965F4029C09AA5C9226D13" originalValue="nordwärts" pageId="null" pageNumber="346">nordwaerts</normalizedToken>
bis Karlsruhe), Vogesen, 
<normalizedToken id="85DD2695B4DC04A85ACEB817D9C6E7FF" originalValue="Dép" pageId="null" pageNumber="346">Dep</normalizedToken>
. Ain, 
<normalizedToken id="3EADD704238075FCD214400D80ACD67F" originalValue="Dép" pageId="null" pageNumber="346">Dep</normalizedToken>
. Jura, 
<normalizedToken id="6A233D2E7972A696F8691B3095C1AFD7" originalValue="südliches" pageId="null" pageNumber="346">suedliches</normalizedToken>
Tessin; sehr selten.
</paragraph>
<paragraph id="FA361A0A283D63D03A57F9265523AAB4" pageId="null" pageNumber="346">
<emphasis id="89ED4A08A443978E1628C1929B684C5F" italics="true" pageId="null" pageNumber="346">Bemerkungen.</emphasis>
Wir lehnen den jetzt 
<normalizedToken id="2C8834B118C091CF8D0C0E60D3FFB126" originalValue="gültigen" pageId="null" pageNumber="346">gueltigen</normalizedToken>
Namen 
<taxonomicName id="84A945B04E910FB211EBF81AE04DF98E" authority="(Bert.) Becherer" authorityName="Becherer" baseAuthorityName="Bert." class="Liliopsida" family="Poaceae" genus="Festuca" kingdom="Plantae" order="Poales" pageId="null" pageNumber="346" phylum="Tracheophyta" rank="species" species="festucoides">
<emphasis id="1C9C421A9C0052A3179D1352B75D6815" italics="true" pageId="null" pageNumber="346">F. festucoides</emphasis>
(Bert.) Becherer
</taxonomicName>
als sprachlich wenig sinnvoll ab.
</paragraph>
</subSubSection>
