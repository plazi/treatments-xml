<figureCitation id="136D47E9554AB03005855025FD6DF030" box="[676,739,1053,1075]" captionStart="Fig" captionStartId="5.[174,207,817,839]" captionTargetBox="[206,1186,187,753]" captionTargetId="figure-339@5.[204,1201,174,762]" captionTargetPageId="5" captionText="Fig. 16–20. Yunnantettix bannanensis, male (16–17) and Y. elytratus, female (18–20): 16, 18 — head and pronotum, lateral view; 17 — body, dorsal view; 19 — head and pronotum, dorsal view; 20 — head, frontal view (16–17 after Zheng, 1995; 18–19 after Günther, 1939, with modification; 20 after Shishodia, 1991)." figureDoi="http://doi.org/10.5281/zenodo.6452365" httpUri="https://zenodo.org/record/6452365/files/figure.png" pageId="6" pageNumber="217">fig. 19</figureCitation>
