<subSubSection id="D23CC2ACFAC28F5C3B7D884F7818B759" pageId="null" pageNumber="500" type="description">
<paragraph id="3856C9EDF8377DC1E9C26A6F56F916F2" pageId="null" pageNumber="500">
Ausdauernd, mit 
<normalizedToken id="48990F24480A450EBDE1AAF8E2E011B5" originalValue="dünnem" pageId="null" pageNumber="500">duennem</normalizedToken>
, kriechendem, 
<normalizedToken id="6B30DE0CE1F4EC720397A48AF10C5A07" originalValue="mehrköpfigem" pageId="null" pageNumber="500">mehrkoepfigem</normalizedToken>
Rhizom; 30-70 cm hoch. Stengel aufrecht oder aufsteigend, kahl. 
<emphasis id="6523971AC3F3519AFA07AB1E236AEB28" italics="true" pageId="null" pageNumber="500">
<normalizedToken id="CA975339FE40E9B98CB3603041A644DD" originalValue="Blätter" pageId="null" pageNumber="500">Blaetter</normalizedToken>
stets doppelt fiederteilig;
</emphasis>
sonst wie 
<emphasis id="8E7F786A8380339237933872B4727756" italics="true" pageId="null" pageNumber="500">S. abrotanifolius</emphasis>
(Nr. 8). 
<normalizedToken id="D8EB822F43791D19681E820F92E17B35" originalValue="Blütenköpfe" pageId="null" pageNumber="500">Bluetenkoepfe</normalizedToken>
10-50, 
<emphasis id="886DFAD5E3BA83BE5C4C58BA12F439C0" italics="true" pageId="null" pageNumber="500">im Durchmesser 0,8</emphasis>
- 
<emphasis id="2628650F9EFE2278D7D79B1A77A8598A" italics="true" pageId="null" pageNumber="500">1,5 cm</emphasis>
, in einer dichten doldenartigen Traube oder Rispe, mit etwa 1 mm dickem Stiel. 
<normalizedToken id="9F8B9F777130B5160750233EC8265C32" originalValue="Hülle" pageId="null" pageNumber="500">Huelle</normalizedToken>
zylindrisch bis 
<normalizedToken id="CBCC1DE1BB60D47E8FC03A2FB4F3D9FE" originalValue="glockenförmig" pageId="null" pageNumber="500">glockenfoermig</normalizedToken>
, 5-7 mm lang, 
<normalizedToken id="9E9B2E99F80F13CA18F67CDD1133B06D" originalValue="außen" pageId="null" pageNumber="500">aussen</normalizedToken>
von wenigen, schmal lanzettlichen, ca. 3 mm langen, bewimperten 
<normalizedToken id="ECB463FAED9F327F97B72EDD2F57C90A" originalValue="Blättern" pageId="null" pageNumber="500">Blaettern</normalizedToken>
umgeben. Innere 
<normalizedToken id="D23324ED09CFCC473C6645CC41DBB61A" originalValue="Hüllblätter" pageId="null" pageNumber="500">Huellblaetter</normalizedToken>
12-15, am Rande bewimpert, sonst kahl, 
<emphasis id="1DE3594A3687CAE231EC4E4F99E4C2EE" italics="true" pageId="null" pageNumber="500">
zur Fruchtzeit 
<normalizedToken id="9FE221288571034447E5A9F03EDC3DFA" originalValue="gewölbt" pageId="null" pageNumber="500">gewoelbt</normalizedToken>
und je eine Frucht 
<normalizedToken id="DD4B888A8510D30D3A678B61E363B2E9" originalValue="umschließend" pageId="null" pageNumber="500">umschliessend</normalizedToken>
. Kronen gelb; die meist 5 
<normalizedToken id="75D33305EF5547D088D984E2AD358363" originalValue="zungenförmigen" pageId="null" pageNumber="500">zungenfoermigen</normalizedToken>
Kronen 5
</emphasis>
- 
<emphasis id="7B7C0D4BA6E755D9B4C172CF9EDACD33" italics="true" pageId="null" pageNumber="500">10 mm lang.</emphasis>
<normalizedToken id="17D32CAAA5A0E86750760A94B339D4FC" originalValue="Früchte" pageId="null" pageNumber="500">Fruechte</normalizedToken>
3-4 mm lang, 5-8rippig, kahl. 
<emphasis id="1D5126F693F521877D135C8FE46F3CBD" italics="true" pageId="null" pageNumber="500">
<taxonomicName id="8EDC57713E3BF409562E259C687A25BC" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="500" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
ca. 3 mm lang
</emphasis>
, gelblich, zur Fruchtzeit meist abgebrochen. - 
<normalizedToken id="BA89B79D020F5E39511AE34F679AFDAF" originalValue="Blüte" pageId="null" pageNumber="500">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="40062D129B5CF056C4C93C2151821F2D" pageId="null" pageNumber="500">
<emphasis id="3E5E6FC16DA8F5F1A68A7310BFAB9DB6" italics="true" pageId="null" pageNumber="500">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="EFF8F63B83B38DAD07374C6E84698DF9" italics="true" pageId="null" pageNumber="500">40:</emphasis>
Material aus botanischen 
<normalizedToken id="2F07A7F204A0370F039AFFEF1FA4DB09" originalValue="Gärten" pageId="null" pageNumber="500">Gaerten</normalizedToken>
(Afzelius 1924), von den 
<normalizedToken id="B7C56F7DCB19E24EAA129228533641B4" originalValue="Pyrenäen" pageId="null" pageNumber="500">Pyrenaeen</normalizedToken>
(
<normalizedToken id="81322957202B5A5BCEC3360CFA6A5B37" originalValue="Küpfer" pageId="null" pageNumber="500">Kuepfer</normalizedToken>
1968, Delay 1970), vom Massif Central (
<normalizedToken id="303BD5AB58E1F587E6DA25279918B8EC" originalValue="zusätzlich" pageId="null" pageNumber="500">zusaetzlich</normalizedToken>
2 B-Chromosomen; Palmblad 1965).
</paragraph>
<paragraph id="7C70661A3AC2D58CCAB1B3945048F2BF" pageId="null" pageNumber="500">
<emphasis id="58B4FA9598BAA3D8ADDD42F507743280" italics="true" pageId="null" pageNumber="500">Standort.</emphasis>
Kollin, montan und subalpin. 
<normalizedToken id="D599E2B48F2CA357B36B1DF2A2C23661" originalValue="Nährstoff-" pageId="null" pageNumber="500">Naehrstoff-</normalizedToken>
und kalkarme, sandige oder steinige 
<normalizedToken id="FE474327231A252943DC33F10FC8FD34" originalValue="Böden" pageId="null" pageNumber="500">Boeden</normalizedToken>
. 
<normalizedToken id="641ED124CDA1E9FEB1AB2325CBC54F3A" originalValue="Wälder" pageId="null" pageNumber="500">Waelder</normalizedToken>
, felsige 
<normalizedToken id="A87EAFF3AA4FBDFAC85CFD1347591E93" originalValue="Hänge" pageId="null" pageNumber="500">Haenge</normalizedToken>
.
</paragraph>
<paragraph id="17561F0293F7A968996EB83535214AA6" pageId="null" pageNumber="500">
<emphasis id="507751157916649C39AE4F5761C5AA0D" italics="true" pageId="null" pageNumber="500">
Verbreitung. 
<normalizedToken id="10B9777E95E959BB28B725D12D615EDE" originalValue="Westeuropäische" pageId="null" pageNumber="500">Westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Innerhalb der Linie: Westalpen-Sierra de Gredos in 
<normalizedToken id="677BC6820FCB636ACBAE65CB1F57615A" originalValue="Spanien-Pyrenäen-Paris-Jura" pageId="null" pageNumber="500">Spanien-Pyrenaeen-Paris-Jura</normalizedToken>
. - Im Gebiet: 
<normalizedToken id="0810FA3DA273A377BB82B41056EBDD60" originalValue="Dép" pageId="null" pageNumber="500">Dep</normalizedToken>
. Jura (zwischen la 
<normalizedToken id="F20CADBBAD30410FA632C341CC3E7725" originalValue="Ferté" pageId="null" pageNumber="500">Ferte</normalizedToken>
und 
<normalizedToken id="5E9EA81BF33D9A1A29F206526E83CC1B" originalValue="Tassinière" pageId="null" pageNumber="500">Tassiniere</normalizedToken>
); aus dem Aostatal (Cogne) eine unsichere Angabe.
</paragraph>
</subSubSection>
</treatment>
