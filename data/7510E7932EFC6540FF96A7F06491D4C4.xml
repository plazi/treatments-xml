<subSubSection id="DB27FA6FD723001E6C5A22E84D990F98" pageId="null" pageNumber="265" type="description">
<paragraph id="31E3585D9223C7BA91AF425CFE9CC907" pageId="null" pageNumber="265">
10-20 cm hoch. 
<normalizedToken id="897EE1BCD88E680A5D7774126CAA1B4E" originalValue="Blätter" pageId="null" pageNumber="265">Blaetter</normalizedToken>
bis 2 mm breit (getrocknet). 
<normalizedToken id="62D1A1E1081700E7B4FFD538F81362DA" originalValue="Kelchblätter" pageId="null" pageNumber="265">Kelchblaetter</normalizedToken>
mit bikonvexer, stumpfer Spitze. 
<emphasis id="7F40924A3B43070DDBC7A5C571DF708E" italics="true" pageId="null" pageNumber="265">
<normalizedToken id="685E8077380D38AC556D12A76185871F" originalValue="Kronblätter" pageId="null" pageNumber="265">Kronblaetter</normalizedToken>
<normalizedToken id="53197E514C39EDADBFD97BCB8A4F8516" originalValue="weiß" pageId="null" pageNumber="265">weiss</normalizedToken>
oder gelblich. 
<normalizedToken id="77DAEB40A7C3E399ABD8C43A8EA1288D" originalValue="Staubfäden" pageId="null" pageNumber="265">Staubfaeden</normalizedToken>
<normalizedToken id="FC4206579B21F153715B00D3786429E1" originalValue="überall" pageId="null" pageNumber="265">ueberall</normalizedToken>
kahl.
</emphasis>
</paragraph>
<paragraph id="B675E42A5C6AA3199BEE2865BF41830E" pageId="null" pageNumber="265">
<emphasis id="650C95439B7A9B7AD32B3E1E1E7C9960" italics="true" pageId="null" pageNumber="265">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="722D44483AA7BA3B1239CDA42D9227B1" italics="true" pageId="null" pageNumber="265">34:</emphasis>
Material aus Savoyen (Gadella und Kliphuis in 
<normalizedToken id="FB621542F6BA7655989C764C37E4B76A" originalValue="Löve" pageId="null" pageNumber="265">Loeve</normalizedToken>
1968a).
</paragraph>
<paragraph id="A3249996A61F8C823DE2B137411C2EE5" pageId="null" pageNumber="265">
<emphasis id="A43EBEA3FC8E2007B8F4F4537D1C7BFF" italics="true" pageId="null" pageNumber="265">Standort.</emphasis>
Kollin und montan. Felsspalten.
</paragraph>
<paragraph id="BA73371D6DA7AFB6FB21D28BC390A9F2" pageId="null" pageNumber="265">
<emphasis id="B714818ADE2ECD52F617BF97B07DC1BD" italics="true" pageId="null" pageNumber="265">Verbreitung. Mediterrane Pflanze:</emphasis>
Ganzes Mediterrangebiet, 
<normalizedToken id="036AD87F50FC59C2036BAC433474ACBC" originalValue="nordwärts" pageId="null" pageNumber="265">nordwaerts</normalizedToken>
bis ins Loiregebiet, Doubs; Mont 
<normalizedToken id="E62B8B8BA1BD24D9AB6AC6225028F12B" originalValue="Salève" pageId="null" pageNumber="265">Saleve</normalizedToken>
bei Genf, Norditalien, Donaubecken. - Im Gebiet: Savoyen, 
<normalizedToken id="1C4B79E0AD13338AB84843E998A188C8" originalValue="Französischer" pageId="null" pageNumber="265">Franzoesischer</normalizedToken>
Jura, Veyrier bei Genf, Vaumarcus (Neuenburg, 
<normalizedToken id="38F4AA2BFAC69BD559EA4E0AEA4B41BB" originalValue="eingebürgert" pageId="null" pageNumber="265">eingebuergert</normalizedToken>
), Aostatal; Tessin (mehrfach), Grigna, Bergamasker Alpen (Val Brembana, 
<normalizedToken id="4B7245381BFED9CA9DE8C13A62901282" originalValue="Lagod’Iseo" pageId="null" pageNumber="265">Lagod'Iseo</normalizedToken>
).
</paragraph>
