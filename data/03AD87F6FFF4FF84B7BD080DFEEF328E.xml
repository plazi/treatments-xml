<taxonomicName id="4C044D63FFF4FF84B4060A8DFEE3328E" authority="(Denis &amp; Schiffermuller, 1775)" baseAuthorityName="Denis &amp; Schiffermuller" baseAuthorityYear="1775" class="Insecta" family="Tortricidae" genus="Rhyacionia" kingdom="Animalia" order="Lepidoptera" pageId="4" pageNumber="13" phylum="Arthropoda" rank="species" species="buoliana">
