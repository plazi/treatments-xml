<taxonomicName id="4C044D63FFF4FF84B6750AADFCB432CE" authority="(Hartig, 1838)" baseAuthorityName="Hartig" baseAuthorityYear="1838" box="[366,816,911,938]" class="Insecta" family="Ichneumonidae" genus="Gregopimpla" kingdom="Animalia" order="Hymenoptera" pageId="4" pageNumber="13" phylum="Arthropoda" rank="species" species="bernuthii">
