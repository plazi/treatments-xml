<paragraph id="8B89CC67A96CAD1D0D14F9BE7498DB64" blockId="2.[120,1325,1103,3455]" box="[123,949,1585,1614]" pageId="2" pageNumber="801">
<taxonomicName id="4C36B7E4A96CAD1D0D14F9BE750CDB64" authority="Lydekker, 1911" authorityName="Lydekker" authorityYear="1911" box="[123,545,1585,1614]" class="Mammalia" family="Giraffidae" genus="Giraffa" kingdom="Animalia" order="Artiodactyla" pageId="2" pageNumber="801" phylum="Chordata" rank="subSpecies" species="camelopardalis" subSpecies="thornicrofti">G. c. thornicrofti Lydekker, 1911</taxonomicName>
<collectingCountry id="F3218CF7A96CAD1D0F42F9BE759DDB63" box="[557,688,1585,1609]" name="Zambia" pageId="2" pageNumber="801">-Zambia</collectingCountry>
(Luangwa Valley).
</paragraph>
