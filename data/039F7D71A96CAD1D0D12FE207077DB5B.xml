<taxonomicName id="4C36B7E4A96CAD1D0D14F98574A5DB08" authority="Matschie, 1898" authorityName="Matschie" authorityYear="1898" box="[123,904,1546,1579]" class="Mammalia" family="Giraffidae" genus="Giraffa" kingdom="Animalia" order="Artiodactyla" pageId="2" pageNumber="801" phylum="Chordata" rank="subSpecies" species="camelopardalis" subSpecies="tippelskirchi">
