<taxonomicName id="4C724D26935D8E00F1F3FA0FFBF7FA7D" authorityName="Dejean" authorityYear="1829" box="[974,1062,1437,1462]" class="Insecta" family="Carabidae" genus="Harpalus" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="488" phylum="Arthropoda" rank="species" species="cupreus">
<emphasis id="B906EAB7935D8E00F1F3FA0FFBF7FA7D" box="[974,1062,1437,1462]" italics="true" pageId="4" pageNumber="488">cupreus</emphasis>
</taxonomicName>
m. in Dalmatia.” and “ 
<typeStatus id="54C98807935D8E00F714FA0EFA4DFA7D" box="[1321,1436,1436,1462]" pageId="4" pageNumber="488">Lectotype</typeStatus>
of 
<taxonomicName id="4C724D26935D8E00F28BFA52FDCBFA11" authority="Dejean, 1829" authorityName="Dejean" authorityYear="1829" box="[182,538,1472,1498]" class="Insecta" family="Carabidae" genus="Harpalus" kingdom="Animalia" order="Coleoptera" pageId="4" pageNumber="488" phylum="Arthropoda" rank="species" species="cupreus">
<emphasis id="B906EAB7935D8E00F28BFA52FEAFFA11" box="[182,382,1472,1498]" italics="true" pageId="4" pageNumber="488">Harpalus cupreus</emphasis>
<bibRefCitation id="EFE34B54935D8E00F3B8FA52FDCBFA11" author="Dejean, P. F. M. A." box="[389,538,1472,1498]" pageId="4" pageNumber="488" refId="ref10732" refString="Dejean, P. F. M. A. (1829) Species general des coleopteres de la collection de M. le Comte Dejean. Tome quatrieme. Mequignon- Marvis, Paris, vii + 520 pp." type="book" year="1829">Dejean, 1829</bibRefCitation>
</taxonomicName>
desig. by 
<collectorName id="26875373935D8E00F0B0FA53FCD2FA11" box="[653,771,1472,1499]" pageId="4" pageNumber="488">J. Serrano</collectorName>
