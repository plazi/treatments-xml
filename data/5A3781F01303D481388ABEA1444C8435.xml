<subSubSection id="D1AC4835C4557F41B76E13786F6B827A" pageId="null" pageNumber="209" type="description">
<paragraph id="A4DA0D632EFDA89F669ED86943E284E7" pageId="null" pageNumber="209">
Habitus wie 
<taxonomicName id="51F61F03FBE4122D35B605A0B7176DBC" class="Liliopsida" family="Hydrocharitaceae" genus="Najas" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="209" phylum="Tracheophyta" rank="species" species="marina">
<emphasis id="A1C496A41258BB9C90FBE96320499455" italics="true" pageId="null" pageNumber="209">N. marina</emphasis>
</taxonomicName>
(Nr.3), jedoch in allen Teilen kleiner. 
<normalizedToken id="88A7480935447BA0B1120388F9E9039A" originalValue="Blätter" pageId="null" pageNumber="209">Blaetter</normalizedToken>
wie bei 
<taxonomicName id="5EEB11B5E86BACD38D547F584BB7917E" class="Liliopsida" family="Hydrocharitaceae" genus="Najas" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="209" phylum="Tracheophyta" rank="species" species="marina">
<emphasis id="26CE502862A8050AE7E89FAF95379A2B" italics="true" pageId="null" pageNumber="209">N. marina</emphasis>
</taxonomicName>
(Nr.3); 
<emphasis id="8C2FE26F341B4B98B42E94141508A85E" italics="true" pageId="null" pageNumber="209">
die Scheiden jedoch mit 3-8 feinen 
<normalizedToken id="1D0CA0EC6C82FF1CDF5183D9830234D3" originalValue="Zähnen" pageId="null" pageNumber="209">Zaehnen</normalizedToken>
. Reife Frucht 3-4 mm lang
</emphasis>
, 1-1,5 mm dick; Same von gleicher Form und mit gleicher 
<normalizedToken id="3545A1719B419FE6F1FB7A6E74324EC4" originalValue="Oberfläche" pageId="null" pageNumber="209">Oberflaeche</normalizedToken>
wie bei 
<taxonomicName id="3B35261BF7C64013197E4683A90B6FDC" class="Liliopsida" family="Hydrocharitaceae" genus="Najas" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="209" phylum="Tracheophyta" rank="species" species="marina">
<emphasis id="16309E835E522ED0E5FB4BA97768F626" italics="true" pageId="null" pageNumber="209">N. marina</emphasis>
</taxonomicName>
(Nr.3). - 
<normalizedToken id="3AE4B52B924C108D724EBC765B3DBECD" originalValue="Blüte" pageId="null" pageNumber="209">Bluete</normalizedToken>
und Frucht: 
<normalizedToken id="4531FD5564AF79F1B9CFB17B7A0B24C1" originalValue="Spätsommer" pageId="null" pageNumber="209">Spaetsommer</normalizedToken>
und Herbst.
</paragraph>
<paragraph id="DA047791F2402FDE9723177B8E70368B" pageId="null" pageNumber="209">
<emphasis id="772CCDB12A7F82E646C37DB742774EF5" italics="true" pageId="null" pageNumber="209">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="EA51D90635A8D8E84EDF633F78775C3B" pageId="null" pageNumber="209">
<emphasis id="637BC0001D1C5BCA5DCAC09D639E09F1" italics="true" pageId="null" pageNumber="209">Standort.</emphasis>
Wie 
<taxonomicName id="7AC6BA9E4F01F07A071C314C9A89B1E7" class="Liliopsida" family="Hydrocharitaceae" genus="Najas" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="209" phylum="Tracheophyta" rank="species" species="marina">
<emphasis id="0C3D574033180DB3472D4EC87F787095" italics="true" pageId="null" pageNumber="209">N. marina</emphasis>
</taxonomicName>
(Nr.3).
</paragraph>
<paragraph id="8000EBCF0BE8C62F5B98853172FDF9ED" pageId="null" pageNumber="209">
<emphasis id="F015B954CCD85E3ACEEFE7C74748D39F" italics="true" pageId="null" pageNumber="209">Verbreitung</emphasis>
(
<normalizedToken id="A09F2A5962DD10D98CCF51C653576A26" originalValue="ungenügend" pageId="null" pageNumber="209">ungenuegend</normalizedToken>
bekannt). Wahrscheinlich 
<emphasis id="6A5A7EC52ABD3CFD72EA6E5656B80E21" italics="true" pageId="null" pageNumber="209">eurasiatische Pflanze:</emphasis>
Norddeutschland, Baltikum, Mitteleuropa, 
<normalizedToken id="0A8B2A0DF51D0F641AD4189F17AB47E2" originalValue="Rußland" pageId="null" pageNumber="209">Russland</normalizedToken>
, 
<normalizedToken id="C6C522D705E1E22E8794E33C46C1172F" originalValue="Südwestasien" pageId="null" pageNumber="209">Suedwestasien</normalizedToken>
. - Im Gebiet: Savoyen, Mittelland (verschiedene Fundstellen 
<normalizedToken id="763C6580F185F747F9507C94BC53A596" originalValue="östlich" pageId="null" pageNumber="209">oestlich</normalizedToken>
des Sempachersees bis ins Bodenseegebiet).
</paragraph>
</subSubSection>
