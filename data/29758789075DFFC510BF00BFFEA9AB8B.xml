<emphasis id="93A8EA8D075EFFC512B6067EFDDBABAB" box="[392,579,1140,1166]" italics="true" pageId="38" pageNumber="61">S. shotoverigiganti</emphasis>
</taxonomicName>
<taxonomicNameLabel id="889B57F6075EFFC51177067FFD1DABAA" box="[585,645,1141,1167]" pageId="38" pageNumber="61" rank="species">n. sp.</taxonomicNameLabel>
, 
