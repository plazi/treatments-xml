</taxonomicName>
. 
<taxonomicName id="66DC4D1C075EFFC5114201FFFC9FAB2B" baseAuthorityName="Secretan" baseAuthorityYear="1964" box="[636,775,1012,1039]" class="Malacostraca" family="Erymidae" genus="Stenodactylina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Decapoda" pageId="38" pageNumber="61" phylum="Arthropoda" rank="species" species="granulifera">
