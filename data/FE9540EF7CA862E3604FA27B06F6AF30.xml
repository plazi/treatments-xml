<subSubSection id="C916B965EFC24012CAD4F566B13E938C" pageId="null" pageNumber="273" type="description">
<paragraph id="1AC58C5D79123092C5E75A2680DA37A9" pageId="null" pageNumber="273">
<emphasis id="1FBD51451748CE09073739415045CCE0" italics="true" pageId="null" pageNumber="273">
Habitus wie 
<taxonomicName id="73BE745E60B15E070146B65F29EEA35A" class="Liliopsida" family="Poaceae" genus="Phleum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="273" phylum="Tracheophyta" rank="species" species="boehmeri">Ph. Boehmeri</taxonomicName>
</emphasis>
(Nr. 2); 
<emphasis id="2F02D223D84DE5C484FE9D39B23B9F83" italics="true" pageId="null" pageNumber="273">
kurze, unterirdische 
<normalizedToken id="2DD2517FF152DD5408EDA3E4742E4D4D" originalValue="Ausläufer" pageId="null" pageNumber="273">Auslaeufer</normalizedToken>
vorhanden.
</emphasis>
<normalizedToken id="4C06F653549403D9654FF8469315AFF5" originalValue="Blätter" pageId="null" pageNumber="273">Blaetter</normalizedToken>
bis 8 mm breit, beiderseits rauh; 
<normalizedToken id="9813B79E8C7713DA5946783A57A20EB2" originalValue="Blatthäutchen" pageId="null" pageNumber="273">Blatthaeutchen</normalizedToken>
ca. 4 mm lang, gestutzt; Blattscheiden wie bei 
<emphasis id="8CA8AEF5596F0B42ACB7A232C000F6C5" italics="true" pageId="null" pageNumber="273">
<taxonomicName id="92E18928764AF6A2E9A0824AD3CC6BD9" class="Liliopsida" family="Poaceae" genus="Phleum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="273" phylum="Tracheophyta" rank="species" species="boehmeri">Ph. Boehmeri</taxonomicName>
. 
<normalizedToken id="6AA37A3180B4B3C376F29E0FFDFDC7A4" originalValue="Blütenstand" pageId="null" pageNumber="273">Bluetenstand</normalizedToken>
zylindrisch, bis 10 cm lang
</emphasis>
, oft etwas locker und unterbrochen. 
<normalizedToken id="99A358DE0FBEEB9F562D278E181A1A41" originalValue="Rispenäste" pageId="null" pageNumber="273">Rispenaeste</normalizedToken>
und Achsenfortsatz der 
<normalizedToken id="AD23F0C7BF4D984DE45F8E4E2362F4B1" originalValue="Ährchen" pageId="null" pageNumber="273">Aehrchen</normalizedToken>
wie bei 
<taxonomicName id="ED770B7E1CC5C778C632DB5BE5A9676D" class="Liliopsida" family="Poaceae" genus="Phleum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="273" phylum="Tracheophyta" rank="species" species="paniculatum">
<emphasis id="1DCB2C14EE53EE6C96302380C123A711" italics="true" pageId="null" pageNumber="273">Ph. paniculatum</emphasis>
</taxonomicName>
(Nr. 1). 
<emphasis id="05CF7A57439B10D60370C15127583974" italics="true" pageId="null" pageNumber="273">
<normalizedToken id="CE2FE5701BC62FB8CE48F6B4F8F4C5C3" originalValue="Hüllspelzen" pageId="null" pageNumber="273">Huellspelzen</normalizedToken>
</emphasis>
(mit Grannenspitze) 
<emphasis id="AC0B17B73223F23877BD0BF0FD38A263" italics="true" pageId="null" pageNumber="273">4</emphasis>
- 
<emphasis id="F2C86FF1AFD53E4787CE00855D3C03C3" italics="true" pageId="null" pageNumber="273">6, 5 mm lang</emphasis>
, 
<normalizedToken id="66FFD6441656834405D26850B8473F57" originalValue="allmählich" pageId="null" pageNumber="273">allmaehlich</normalizedToken>
in die etwa 1 mm lange, grannenartige Spitze 
<normalizedToken id="9852ED98B3B4CD211D7B1DBBF7E2EE65" originalValue="verschmälert" pageId="null" pageNumber="273">verschmaelert</normalizedToken>
, mit 
<normalizedToken id="1B72D43856CF52A3F24F07FA8383DC61" originalValue="häutigem" pageId="null" pageNumber="273">haeutigem</normalizedToken>
Rand, 
<emphasis id="B8A660DCC71315C45290529ED4E394FC" italics="true" pageId="null" pageNumber="273">auf dem Kiel mit abstehenden, 0,2</emphasis>
- 
<emphasis id="068E8B7EB860595F51EF19EEB755162C" italics="true" pageId="null" pageNumber="273">0,5 mm langen Haaren</emphasis>
, auf den Seitennerven mit 
<normalizedToken id="74057B9A911E239BD388BDE8ADCAA2C3" originalValue="kürzeren" pageId="null" pageNumber="273">kuerzeren</normalizedToken>
Haaren. Deckspelze mit undeutlicher Spitze. Vorspelze fast so lang wie die Deckspelze. - 
<normalizedToken id="774787B95DC0C0C4B1F4C3C21445F269" originalValue="Blüte" pageId="null" pageNumber="273">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="73D74C6EBA163E8883806C5992EF0407" pageId="null" pageNumber="273">
<emphasis id="EBB3E3254E4F23C6EFC6EBEB6210A7FB" italics="true" pageId="null" pageNumber="273">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="BBDF2B65BA7B3D662B497DF4AF966F9C" italics="true" pageId="null" pageNumber="273">14:</emphasis>
Material aus Versuchsanstalten (
<normalizedToken id="77570B6770EA34E874C2662A30040FED" originalValue="Müntzing" pageId="null" pageNumber="273">Muentzing</normalizedToken>
1935, 
<normalizedToken id="6EE287230CCDC99A5F3C4DD985D56D8C" originalValue="Nordenskjöld" pageId="null" pageNumber="273">Nordenskjoeld</normalizedToken>
1937), aus der Tatra (Skalinska et al. 1957).
</paragraph>
<paragraph id="976A8F3C27D8F1AE4B43531FB3BD7825" pageId="null" pageNumber="273">
<emphasis id="4BC2735E8EE3DC9DB0B28DCD3F5AB413" italics="true" pageId="null" pageNumber="273">Standort.</emphasis>
Subalpin, seltener montan und alpin. Kalkhaltige, feuchte, feinerdereiche, 
<normalizedToken id="DA09F607FAC2CC8BC1DEC3F5032CD0E2" originalValue="tiefgründige" pageId="null" pageNumber="273">tiefgruendige</normalizedToken>
<normalizedToken id="E80C19C21FCB0096803E8657EFFBF3DE" originalValue="Böden" pageId="null" pageNumber="273">Boeden</normalizedToken>
. Sonnige Weiden.
</paragraph>
<paragraph id="FD5FE24EFBC9765891CAF34226F56DF6" pageId="null" pageNumber="273">
<emphasis id="ECFF6E41C74F1CEC0596EC95E7256C85" italics="true" pageId="null" pageNumber="273">
Verbreitung. Mittel- und 
<normalizedToken id="6BC70013D4AE304DBD8AA400C225D4CF" originalValue="südeuropäische" pageId="null" pageNumber="273">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<normalizedToken id="DC00C7B7F3FFD7E36229FEA26D14E254" originalValue="östlich" pageId="null" pageNumber="273">oestlich</normalizedToken>
): Alpen (von den Seealpen bis zum Wiener Schneeberg), Jura, Karpaten, Apennin, Gebirge der Balkanhalbinsel, Kaukasus. - Im Gebiet: Alpen, Jura (
<normalizedToken id="39D78012A904CF809CBE77AC4C395036" originalValue="höhere" pageId="null" pageNumber="273">hoehere</normalizedToken>
Gipfel von Westen her bis auf den Chasseral), ziemlich 
<normalizedToken id="1F863E059CD4D63DD375D7AA88E6CE53" originalValue="häufig" pageId="null" pageNumber="273">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
