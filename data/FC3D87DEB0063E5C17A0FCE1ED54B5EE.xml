<collectingCountry id="0C837658B0063E5C14F1FC4BEB2AB5C7" box="[995,1085,943,968]" name="Austria" pageId="116" pageNumber="865">Österreich</collectingCountry>
(Gainesville, München, 
<collectingRegion id="B650F82AB0063E5C16A2FC2FEEF5B5EE" box="[432,482,971,993]" country="Austria" name="Wien" pageId="116" pageNumber="865">Wien</collectingRegion>
, Schwarz).
</paragraph>
