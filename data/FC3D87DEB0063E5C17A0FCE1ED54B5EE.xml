<emphasis id="46E0EADAB0063E5C17A0FCD0EE40B547" box="[178,343,819,841]" italics="true" pageId="116" pageNumber="865">
<taxonomicName id="B3944D4BB0063E5C17A0FCD0EFE0B546" box="[178,247,820,841]" class="Insecta" family="Ichneumonidae" genus="Cryptus" kingdom="Animalia" order="Hymenoptera" pageId="116" pageNumber="865" phylum="Arthropoda" rank="genus">Cryptus</taxonomicName>
holalpinus
</emphasis>
<bibRefCitation id="10054B39B0063E5C164EFCD0EEFCB546" author="HEINRICH G" box="[348,491,819,841]" pageId="116" pageNumber="865" pagination="235 - 290" refId="ref96026" refString="HEINRICH G. (1951): Ichneumoniden der Steiermark (Hym.). - Bonner Zool. Beitr. 2: 235 - 290." type="journal article" year="1951">HEINRICH, 1951</bibRefCitation>
