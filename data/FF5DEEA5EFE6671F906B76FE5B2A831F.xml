<subSubSection id="C994475FD9FE80A02FC0BE39EA22D4DD" pageId="null" pageNumber="590" type="description">
<paragraph id="CA14CABDB5FE2B29A2F3D31F69B1751A" pageId="null" pageNumber="590">
Ausdauernd; 15-50 cm hoch; 
<emphasis id="6AD360E011086E1275E84C22BE352740" italics="true" pageId="null" pageNumber="590">
am Grunde mit zahlreichen schwarzen Fasern 
<normalizedToken id="C29A67BC79270162BC0165937C1B4F4B" originalValue="vorjähriger" pageId="null" pageNumber="590">vorjaehriger</normalizedToken>
<normalizedToken id="4B45F45D62F106BC4F910C5077B9DA69" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
</emphasis>
(
<emphasis id="222DC0EB661804EFB9DA61D9A13CA0AC" italics="true" pageId="null" pageNumber="590">Faserschopf</emphasis>
). Stengel aufrecht, mit wenigen 
<normalizedToken id="D97505AD4A7218537926F5939A828063" originalValue="Stengelblättern" pageId="null" pageNumber="590">Stengelblaettern</normalizedToken>
. 
<normalizedToken id="FA7DAAE1BAC13DA65DBEDD2BB5C081E0" originalValue="Grundständige" pageId="null" pageNumber="590">Grundstaendige</normalizedToken>
<normalizedToken id="74CF5B9E1FA2E16245E154634D149ABA" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
grasartig. 
<emphasis id="783F24113A6E69ACB7E892CA8C4DB7F1" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="A4246FBE94F84565B9351423D7908E72" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
zur 
<normalizedToken id="08CD6EAAC06F26F6C7B2A677F2B551CF" originalValue="Blütezeit" pageId="null" pageNumber="590">Bluetezeit</normalizedToken>
2,5
</emphasis>
- 
<emphasis id="33A52289AAD775E40AE52F17EE6BD952" italics="true" pageId="null" pageNumber="590">3 cm lang.</emphasis>
<normalizedToken id="61B1975407D0AE44A8EB3E16A982EB97" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
auf der Innenseite kahl oder zerstreut und anliegend behaart, die 
<normalizedToken id="FF4814F6E6B35993AADB35F26600616A" originalValue="äußern" pageId="null" pageNumber="590">aeussern</normalizedToken>
<normalizedToken id="CF3369D2152888A0036203738AC9909B" originalValue="höchstens" pageId="null" pageNumber="590">hoechstens</normalizedToken>
halb so lang wie die innern. 
<emphasis id="6EACC870DACA3A7319A4200C2BFAF7E3" italics="true" pageId="null" pageNumber="590">Kronen 4</emphasis>
- 
<emphasis id="6ECC1489EF7AE869B1A1DF265D5F7536" italics="true" pageId="null" pageNumber="590">
5 cm lang, rosa. 
<normalizedToken id="E76DE6304B6E83FB2AB1D53CA3866808" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
10
</emphasis>
- 
<emphasis id="3A95FBED952C8ED7D3E27DA2115B015A" italics="true" pageId="null" pageNumber="590">15 mm lang</emphasis>
, kahl, 10rippig, 
<emphasis id="BAE64EF47EE89A47853D225AC163ABA4" italics="true" pageId="null" pageNumber="590">
auf den Rippen 
<normalizedToken id="0AA97ECF5A0F670EC4386F6562EAE4EA" originalValue="höckerig" pageId="null" pageNumber="590">hoeckerig</normalizedToken>
.
</emphasis>
<taxonomicName id="5472D42884E5134078F1095B84C41D93" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
<normalizedToken id="F178AC8F1B7F3FABA0E3F54A207B2ED0" originalValue="gelblichweiß" pageId="null" pageNumber="590">gelblichweiss</normalizedToken>
, etwa so lang wie die Frucht, am Grunde 
<normalizedToken id="AD17BB638287DAD97B369E1AAA01C3A2" originalValue="±" pageId="null" pageNumber="590">+/-</normalizedToken>
kahl. - 
<normalizedToken id="98162E36F7934BD961E2CA03913F9FDF" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="49AE6D594FF90B3CE23EE0C4B42408B1" pageId="null" pageNumber="590">
<emphasis id="7F6FE36D746454F2AEB679B6B8FDB278" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="4874F11EF4A28210B2C146E3AA448013" italics="true" pageId="null" pageNumber="590">14:</emphasis>
Material aus den 
<normalizedToken id="4B84F4604465C594E95618BA76330FE8" originalValue="Südostalpen" pageId="null" pageNumber="590">Suedostalpen</normalizedToken>
(Favarger 1965), aus den Ostkarpaten (Chouksanova et al. 1968).
</paragraph>
<paragraph id="431D14E0CEEB7BB0956DE41025B68B3A" pageId="null" pageNumber="590">
<emphasis id="7D85597E14D4F745235C6A7DB7986C9D" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Montan und subalpin. 
<normalizedToken id="0A4C64F87493BD76490B634C8E0FFAA4" originalValue="Mäßig" pageId="null" pageNumber="590">Maessig</normalizedToken>
<normalizedToken id="41F11A2313396B9CF260C98C45E6040D" originalValue="nährstoffreiche" pageId="null" pageNumber="590">naehrstoffreiche</normalizedToken>
, kalkhaltige 
<normalizedToken id="7F8A5260989B17FB265441F8A0020309" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
in 
<normalizedToken id="37A2C31E16FDD9E8588E61BFDEFE2D6B" originalValue="wärmeren" pageId="null" pageNumber="590">waermeren</normalizedToken>
Lagen. Wiesen.
</paragraph>
<paragraph id="12AE299883CA4A688A82FD729C0A1FD2" pageId="null" pageNumber="590">
<emphasis id="54CED6289C123A5C36688D899F60C21E" italics="true" pageId="null" pageNumber="590">
Verbreitung. Mittel- und 
<normalizedToken id="A7B7BADFECBB8FC43D8D2459B9EABBCE" originalValue="südeuropäische" pageId="null" pageNumber="590">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="4EFD3330FBB437C2FAC6676AF6F44EFC" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="EA1BD4DF3C8B5F4929207C74BE03B934" originalValue="östlich" pageId="null" pageNumber="590">oestlich</normalizedToken>
</emphasis>
)
<emphasis id="2AEFBC94903AB0B485FFE08CA62C4947" italics="true" pageId="null" pageNumber="590">:</emphasis>
Apennin (Emilia bis Abruzzen), 
<normalizedToken id="5289F2AE8D0F28B6F544AE39CD7F31DE" originalValue="Südostalpen" pageId="null" pageNumber="590">Suedostalpen</normalizedToken>
(
<normalizedToken id="D97FB73EB0F9314E754CED7A8071C071" originalValue="westwärts" pageId="null" pageNumber="590">westwaerts</normalizedToken>
bis Bergamasker Alpen), Karpaten, Gebirge der Balkanhalbinsel (
<normalizedToken id="6426BE44EDA715B35FB826FDDE4708D3" originalValue="südwärts" pageId="null" pageNumber="590">suedwaerts</normalizedToken>
bis Montenegro). - Im Gebiet: Bergamasker Alpen (Valle di Scalve).
</paragraph>
</subSubSection>
