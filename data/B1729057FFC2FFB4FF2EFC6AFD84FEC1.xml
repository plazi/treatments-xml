<collectingCountry id="41CC61D1FFC4FFB4FE32FEAAFDD2FEA2" box="[442,538,271,297]" name="Ukraine" pageId="4" pageNumber="183">Ukraine</collectingCountry>
(
<bibRefCitation id="5D4A5CB0FFC4FFB4FDA5FEAAFD02FEA2" author="Strand, A." box="[557,714,271,297]" pageId="4" pageNumber="183" pagination="39 - 40" refId="ref4388" refString="Strand, A. Gyrophaena orientalis n. sp. (Col., Staph.) // Notulae Entomologicae. - 1938. - 18. - P. 39 - 40." type="book chapter" year="1938">Strand, 1938</bibRefCitation>
