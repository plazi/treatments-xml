<bibRefCitation id="5D4A5CB0FFC4FFB4FD50FEAAFCDBFEA2" author="Strand, A." box="[728,787,271,297]" pageId="4" pageNumber="183" pagination="35 - 36" refId="ref4422" refString="Strand, A. Gyrophaena keeni Casey and G. orientalisA. Str. // Norsk Entomologisk Tidsskrift. - 1968. - 15, N 1. - P. 35 - 36." type="journal article" year="1968">1968</bibRefCitation>
