<paragraph id="39642141FFC3FFB3FF22F8A2FE1BF8B3" blockId="3.[170,1229,1799,1848]" pageId="3" pageNumber="182">
Рис. 2. 
<taxonomicName id="FEDB5AC2FFC3FFB3FF7DF8ADFE03F896" authorityName="A. Strand" authorityYear="1938" box="[245,459,1800,1821]" class="Insecta" family="Staphylinidae" genus="Gyrophaena" kingdom="Animalia" order="Coleoptera" pageId="3" pageNumber="182" phylum="Arthropoda" rank="species" species="orientalis">
