<paragraph id="BD489A0E89B0F43DC1240E36A48C652C" pageId="null" pageNumber="679">
<emphasis id="D2779054DD25D533674871AE58EF282A" italics="true" pageId="null" pageNumber="679">
<normalizedToken id="BE5DADC6C5BBAA9E7FAA0F4365360F13" originalValue="Kronblätter" pageId="null" pageNumber="679">Kronblaetter</normalizedToken>
am Grunde verwachsen, weiter oben
</emphasis>
<normalizedToken id="CACACD1DE3BAB93811303C247E1D7252" originalValue="±" pageId="null" pageNumber="679">+/-</normalizedToken>
<emphasis id="96D1F1215B2A736CDF952F68B35DEB16" italics="true" pageId="null" pageNumber="679">flach ausgebreitet, mit stumpfen Zipfeln.</emphasis>
</paragraph>
<paragraph id="9D30D09DB2E0C212C728EBB446A6E463" pageId="null" pageNumber="679">
Die Gattung 
<emphasis id="81437C29EC46FEF1E282A61C6507BDF1" italics="true" pageId="null" pageNumber="679">
<taxonomicName id="D3371223EDA5B1304B9242BB7E32222E" class="Magnoliopsida" family="Aquifoliaceae" genus="Ilex" kingdom="Plantae" order="Aquifoliales" pageId="null" pageNumber="679" phylum="Tracheophyta" rank="genus">Ilex</taxonomicName>
<normalizedToken id="A766DF7B15DB303068734DCE461C48FC" originalValue="umfaßt" pageId="null" pageNumber="679">umfasst</normalizedToken>
etwa 440 Arten und ist vor allem in den Tropen Asiens und Amerikas verbreitet;
</emphasis>
wenige Arten in den Subtropen und den 
<normalizedToken id="3004BE37F5C7AD7F7BE72E49A6EBC0F1" originalValue="gemäßigten" pageId="null" pageNumber="679">gemaessigten</normalizedToken>
Zonen der 
<normalizedToken id="8385FCCBB8D9CAD1A07D2D2A0A37013B" originalValue="südlichen" pageId="null" pageNumber="679">suedlichen</normalizedToken>
und 
<normalizedToken id="DD719BACBB82CD396CA053156A10766B" originalValue="nördlichen" pageId="null" pageNumber="679">noerdlichen</normalizedToken>
<normalizedToken id="F27E38C02B88B30E3D2C0BF28B44F4BD" originalValue="Hemisphäre" pageId="null" pageNumber="679">Hemisphaere</normalizedToken>
.
</paragraph>
