<subSubSection id="C0A113D845DA1E9940E80261BD3AE65E" pageId="null" pageNumber="422" type="description">
<paragraph id="33DF45029AE93B68C9A10A380FF69503" pageId="null" pageNumber="422">
Unterscheidet sich von 
<taxonomicName id="81483AFBF26EE62EF6E1B75E39AA4327" class="Magnoliopsida" family="Asteraceae" genus="Cirsium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="422" phylum="Tracheophyta" rank="genus">
<emphasis id="517D72E5CD5ABD25A38B8D31E1FEAC2D" italics="true" pageId="null" pageNumber="422">Cirsium</emphasis>
</taxonomicName>
(S. 412) durch folgende Merkmale: 
<normalizedToken id="A1BD8278E8235FBF478F9746B625B203" originalValue="Hüllblätter" pageId="null" pageNumber="422">Huellblaetter</normalizedToken>
<emphasis id="66D066E9737FDA5AC0F0916661DE3BC4" italics="true" pageId="null" pageNumber="422">
mit breitem, ovalem, fleischigem Grund, ohne 
<normalizedToken id="6059A7C1B8DCAE2D2525C17DC678CF0B" originalValue="Harzdrüsen" pageId="null" pageNumber="422">Harzdruesen</normalizedToken>
; 
<normalizedToken id="3E285F159D606A7DECFC08E01432BA5D" originalValue="Blütenboden" pageId="null" pageNumber="422">Bluetenboden</normalizedToken>
fleischig; 
<normalizedToken id="047F42B2536A80B70CA720BEDB825F2C" originalValue="Früchte" pageId="null" pageNumber="422">Fruechte</normalizedToken>
mit 4 
<normalizedToken id="8F6DDC2FCFC3F8F870A4EBB1852DAA4B" originalValue="Längsrippen" pageId="null" pageNumber="422">Laengsrippen</normalizedToken>
, ohne 
<normalizedToken id="30AE37F644FDF10EE7A044C1E14911E9" originalValue="kragenförmigen" pageId="null" pageNumber="422">kragenfoermigen</normalizedToken>
Ring;
</emphasis>
<taxonomicName id="A6C075B6FCC65C21B88FBA47A674805C" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="422" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
direkt auf der Frucht angewachsen.
</paragraph>
<paragraph id="1702CED064174D6903893185CBEA6B59" pageId="null" pageNumber="422">
Die Gattung 
<taxonomicName id="4821D9B6048234B4933B85EAA250F75E" class="Magnoliopsida" family="Asteraceae" genus="Cynara" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="422" phylum="Tracheophyta" rank="genus">
<emphasis id="152B0B46721FD7A2F3E7D541704B6F6D" italics="true" pageId="null" pageNumber="422">Cynara</emphasis>
</taxonomicName>
<normalizedToken id="F4FAB992EAC37ECF7C53505D21398961" originalValue="umfaßt" pageId="null" pageNumber="422">umfasst</normalizedToken>
etwa 
<emphasis id="7CDB2DB58088C259741915F145B4E776" italics="true" pageId="null" pageNumber="422">10 Arten</emphasis>
und ist vor allem im 
<emphasis id="F8A6A49A2EDA9D76AA39D3A23EAC07C8" italics="true" pageId="null" pageNumber="422">Mittelmeergebiet verbreitet</emphasis>
. Im Gebiet trifft man nur 2 kultivierte Sippen, die kaum verwildern.
</paragraph>
</subSubSection>
