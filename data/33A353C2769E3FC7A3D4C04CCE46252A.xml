<taxonomicName id="816AB66E32DDDED240FF57D3F3CDF074" authority="L." class="Magnoliopsida" family="Thymelaeaceae" genus="Daphne" kingdom="Plantae" order="Malvales" pageId="null" pageNumber="753" phylum="Tracheophyta" rank="species" species="alpina">
Daphne 
<normalizedToken id="FA0C280DEDF24FCEC171FD33D2696C9F" originalValue="alpína" pageId="null" pageNumber="753">alpina</normalizedToken>
<authorityName id="54FFF45A81CE6D8AE2EF34167FBF297C" pageId="null" pageNumber="753">L.</authorityName>
