<emphasis id="B970EAFEFFF8F616810E32B9F709F95D" bold="true" box="[2064,2220,1701,1734]" pageId="60" pageNumber="118">Taxonomy.</emphasis>
<taxonomicName id="4C044D6FFFF8F61681A232B9F7F3F975" authority="K. Andersen, 1910" authorityName="K. Andersen" authorityYear="1910" class="Mammalia" family="Pteropodidae" genus="Nyctimene" kingdom="Animalia" order="Chiroptera" pageId="60" pageNumber="118" phylum="Chordata" rank="species" species="varius">Nyctimene varius K. Andersen, 1910</taxonomicName>
