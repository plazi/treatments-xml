<collectingCountry id="F313767CFFF8F616807532CDF661F975" box="[2411,2500,1745,1774]" name="Iceland" pageId="60" pageNumber="118">Island</collectingCountry>
, 
<collectingCountry id="F313767CFFF8F61680C832CDF5FFF975" box="[2518,2650,1745,1774]" name="Indonesia" pageId="60" pageNumber="118">Moluccas</collectingCountry>
, 
<collectingCountry id="F313767CFFF8F616810F32E4F702F88E" box="[2065,2215,1784,1813]" name="Indonesia" pageId="60" pageNumber="118">Indonesia</collectingCountry>
