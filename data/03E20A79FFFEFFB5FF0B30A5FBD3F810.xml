<subSubSection id="C351E8E4FFFEFFB5FF0B3131FCCEFEE1" lastPageId="5" lastPageNumber="497" pageId="4" pageNumber="496" type="materials_examined">
<paragraph id="8BF4BB6FFFFEFFB4FF0B3131FAE4FE75" blockId="4.[151,1436,331,394]" pageId="4" pageNumber="496">
<emphasis id="B93F677DFFFEFFB4FF0B3131FE02FE99" bold="true" box="[151,386,331,357]" pageId="4" pageNumber="496">Material examined:</emphasis>
Twenty ciliate specimens were found attached with 
<specimenCount id="9D4D70E6FFFEFFB4FC593131FBCFFE99" box="[965,1103,331,357]" pageId="4" pageNumber="496" type="female">eight female</specimenCount>
<taxonomicName id="4C4BC0ECFFFEFFB4FBC93131FB7EFE9A" box="[1109,1278,331,358]" class="Adenophorea" family="Desmodoridae" genus="Desmodora" kingdom="Animalia" order="Desmodorida" pageId="4" pageNumber="496" phylum="Nematoda" rank="species" species="undetermined">
