<taxonomicName id="56EB4D5CFF8EBA22B0E4FC26B2D7F444" authorityName="Peters" authorityYear="1865" class="Mammalia" family="Molossidae" genus="Mormopterus" kingdom="Animalia" order="Chiroptera" pageId="50" pageNumber="669" phylum="Chordata" rank="genus">Mormopterus</taxonomicName>
