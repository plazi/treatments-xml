<subSubSection id="0239E29489F36ACA1B957A5AE251C1AC" pageId="null" pageNumber="565" type="description">
<paragraph id="DD516CB297E223B7BE978EDFF6C3927A" pageId="null" pageNumber="565">
30-50 cm hoch. Zwiebel lang, 
<normalizedToken id="7CEF8521076BB1BCA475CDC881453454" originalValue="dünn" pageId="null" pageNumber="565">duenn</normalizedToken>
, einem Rhizom 
<normalizedToken id="B218901CFEDBE73C16F8D0397E7EF185" originalValue="ähnlich" pageId="null" pageNumber="565">aehnlich</normalizedToken>
, von einem 
<emphasis id="BEBB8634C195E2FB3DF86570C39098DC" italics="true" pageId="null" pageNumber="565">dichten Schopf von Fasern</emphasis>
(zerfallene 
<normalizedToken id="0C93136C2D5DF39AB1E3395053C772DC" originalValue="Zwiebelhäute" pageId="null" pageNumber="565">Zwiebelhaeute</normalizedToken>
) 
<emphasis id="48767BE9448871D96CAC986D8755563C" italics="true" pageId="null" pageNumber="565">umgeben</emphasis>
. 
<normalizedToken id="67D9EB993BC83ACF0F6FAB1CEB99A61E" originalValue="Blätter" pageId="null" pageNumber="565">Blaetter</normalizedToken>
<normalizedToken id="69596078DF9DA79B32506F47B6603C7D" originalValue="grundständig" pageId="null" pageNumber="565">grundstaendig</normalizedToken>
, 
<emphasis id="1481F155EA9A5C2FDB642F057F2943B1" italics="true" pageId="null" pageNumber="565">flach, nie hohl</emphasis>
, bis 5 mm breit, glatt. 
<normalizedToken id="9833CD3212F30B2948A7303DB25ACA16" originalValue="Hüllblätter" pageId="null" pageNumber="565">Huellblaetter</normalizedToken>
den 
<normalizedToken id="AA65F1A92B2458FCF051DFD5DBE46B24" originalValue="Blütenstand" pageId="null" pageNumber="565">Bluetenstand</normalizedToken>
nicht 
<normalizedToken id="B70940F2AE8B5CC4FA09C92977D4C18F" originalValue="überragend" pageId="null" pageNumber="565">ueberragend</normalizedToken>
. 
<normalizedToken id="BF64526F784ED9837ACD40D770C0764A" originalValue="Blütenstand" pageId="null" pageNumber="565">Bluetenstand</normalizedToken>
3-10 
<normalizedToken id="C62B12E32FF62EC26C94C814D51EA862" originalValue="blütig" pageId="null" pageNumber="565">bluetig</normalizedToken>
, mit auffallend 
<normalizedToken id="08130BAF2C732BB3B1EBD41895E41A29" originalValue="großen" pageId="null" pageNumber="565">grossen</normalizedToken>
<normalizedToken id="CBC5F2B82B9D64537525D36252010825" originalValue="Blüten" pageId="null" pageNumber="565">Blueten</normalizedToken>
, nie mit Zwiebeln. Die meisten 
<normalizedToken id="475EF6E3414A6443D9E400C84BA2CEA1" originalValue="Blütenstiele" pageId="null" pageNumber="565">Bluetenstiele</normalizedToken>
nicht 
<normalizedToken id="F4DA1738CE951F3C46F9D2ADA53B8AF8" originalValue="länger" pageId="null" pageNumber="565">laenger</normalizedToken>
als die 
<normalizedToken id="B227B51F26EE4B5885F99AC5EDC9B5D9" originalValue="Perigonblätter" pageId="null" pageNumber="565">Perigonblaetter</normalizedToken>
. 
<emphasis id="34B87C42C60DE5A49504393DD4DC4C32" italics="true" pageId="null" pageNumber="565">
<normalizedToken id="ABCFAD1B9EEEFDAB4E839C4498427C74" originalValue="Perigonblätter" pageId="null" pageNumber="565">Perigonblaetter</normalizedToken>
10-15 mm lang, breit abgerundet, oft mit feiner, aufgesetzter Spitze
</emphasis>
, leuchtend rot, zusammenneigend. 
<normalizedToken id="E7E0D121194F08E1F9FF23285E73F65C" originalValue="Staubblätter" pageId="null" pageNumber="565">Staubblaetter</normalizedToken>
viel 
<normalizedToken id="00BAE223C87B6B397038E2A53A0DEB86" originalValue="kürzer" pageId="null" pageNumber="565">kuerzer</normalizedToken>
als die 
<normalizedToken id="3F61F851C34D9640BC29360E040D8760" originalValue="Perigonblätter" pageId="null" pageNumber="565">Perigonblaetter</normalizedToken>
, alle gleich, ohne seitliche 
<normalizedToken id="03C3A4EACAA51C7609A8FF639388254F" originalValue="Zähne" pageId="null" pageNumber="565">Zaehne</normalizedToken>
an der Spitze, nach dem Grunde hin wenig verbreitert. - 
<normalizedToken id="79A939A518D45AE141BB76891B0DD411" originalValue="Blüte" pageId="null" pageNumber="565">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="33A55F3FC9ACE6FEEBE96E319D0CC5BC" pageId="null" pageNumber="565">
<emphasis id="2DC687CC483CC38BCB0E832D79D023E0" italics="true" pageId="null" pageNumber="565">Zytologische Angaben. 2n = 14:</emphasis>
Material aus botanischem Garten (Levan 1932Levan 1935).
</paragraph>
<paragraph id="4D5AFBAB14647AD5337CC12F12E85FA4" pageId="null" pageNumber="565">
<emphasis id="2E1B7A447FC1A186477AE63D612D7DEA" italics="true" pageId="null" pageNumber="565">Standort.</emphasis>
Subalpin und alpin. Felsige 
<normalizedToken id="F06BA9EEB6B2F11C1E609452239E0FD5" originalValue="Hänge" pageId="null" pageNumber="565">Haenge</normalizedToken>
, 
<normalizedToken id="C794DCA587621D7D59E56EFAFEC7803B" originalValue="Geröll" pageId="null" pageNumber="565">Geroell</normalizedToken>
, nur auf Kalk.
</paragraph>
<paragraph id="3A350164DE1AC55CD45F58E07D831ED9" pageId="null" pageNumber="565">
<emphasis id="623BF459DB596161E208C399652FDA5C" italics="true" pageId="null" pageNumber="565">
Verbreitung. 
<normalizedToken id="FD22C248BD5EE245168A4A2138AFEA89" originalValue="Südwestalpen-Pflanze" pageId="null" pageNumber="565">Suedwestalpen-Pflanze</normalizedToken>
:
</emphasis>
Portugal (Alto Minho, soll dort an 
<normalizedToken id="C853DDB8942BC2509F669CDF16DEC424" originalValue="Flußufern" pageId="null" pageNumber="565">Flussufern</normalizedToken>
wachsen), Westalpen (Mont Ventoux, Gebiet der 
<normalizedToken id="78DAB6E6DC35AAF90AEF1C225A3C905C" originalValue="Isère" pageId="null" pageNumber="565">Isere</normalizedToken>
und 
<normalizedToken id="98DAA17FA9407381C2FB5C5E810109CF" originalValue="Drôme" pageId="null" pageNumber="565">Drome</normalizedToken>
, Seealpen, Kottische und Grajische Alpen). - Im Gebiet: Grajische Alpen.
</paragraph>
</subSubSection>
