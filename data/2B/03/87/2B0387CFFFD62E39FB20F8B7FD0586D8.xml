<paragraph blockId="6.[809,1421,1913,1973]" pageId="6" pageNumber="7">
<taxonomicName authority="(Wagner, 1845)" baseAuthorityName="Wagner" baseAuthorityYear="1845" class="Mammalia" family="Hipposideridae" genus="Macronycteris" kingdom="Animalia" order="Chiroptera" pageId="6" pageNumber="7" phylum="Chordata" rank="species" species="gigas">
