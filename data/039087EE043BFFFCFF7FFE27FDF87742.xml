<figureCitation id="13022A7D043BFFFCFEFCFE03FEFB730A" box="[276,304,510,536]" captionStart="FIGURES 25–30" captionStartId="16.[151,264,1943,1967]" captionTargetBox="[155,1432,181,1920]" captionTargetId="figure-32@16.[155,1432,181,1920]" captionTargetPageId="16" captionText="FIGURES 25–30. Diglyphomorphomyia spp. nov., head in frontal view, females; 25 D. albiclava, paratype; 26 D. albicoxa, paratype; 27 D. cristata, holotype; 28 D. metallica, holotype; 29 D. parva, paratype; 30 D. pedunculata, paratype." figureDoi="http://doi.org/10.5281/zenodo.6592904" httpUri="https://zenodo.org/record/6592904/files/figure.png" pageId="9" pageNumber="330">28</figureCitation>
