<figureCitation id="13022A7D043BFFFCFF7FFE03FEC3730A" box="[151,264,510,536]" captionStart="FIGURES 9–12" captionStartId="10.[151,264,1842,1866]" captionTargetBox="[151,1435,181,1819]" captionTargetId="figure-32@10.[151,1435,181,1819]" captionTargetPageId="10" captionText="FIGURES 9–12. Diglyphomorphomyia spp. nov., females; 9–10. D. metallica; 9 body in dorsal view, holotype; 10 body in lateral view, holotype; 11–12. D. parva; 11 body in lateral view, paratype; 12 body in dorsal view, paratype." figureDoi="http://doi.org/10.5281/zenodo.6592896" httpUri="https://zenodo.org/record/6592896/files/figure.png" pageId="9" pageNumber="330">Figs 9, 10</figureCitation>
