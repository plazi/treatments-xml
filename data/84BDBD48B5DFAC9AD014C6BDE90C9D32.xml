<paragraph id="2A8D19A75FEDF97436B6D43CF5AFBF2B" pageId="null" pageNumber="235">
Rauhhaarige 
<normalizedToken id="A7C4A1E760041F265C5AE14D4DB7A9A4" originalValue="Gänsekresse" pageId="null" pageNumber="235">Gaensekresse</normalizedToken>
</paragraph>
