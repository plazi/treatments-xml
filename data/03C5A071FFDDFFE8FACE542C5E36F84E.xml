<paragraph id="8BD31167FFDCFFE8FCA858605990FF16" blockId="49.[786,1010,71,132]" box="[788,1009,105,130]" pageId="49" pageNumber="601">Species Accounts</paragraph>
<subSubSection id="C37642ECFFDCFFE8FCA9592A5E06FEF7" pageId="49" pageNumber="601" type="multiple">
<caption id="DF1341EFFFDCFFE8FCA9592A5E06FEF7" ID-DOI="http://doi.org/10.5281/zenodo.6623898" ID-Zenodo-Dep="6623898" httpUri="https://zenodo.org/record/6623898/files/figure.png" inLine="true" pageId="49" pageNumber="601" startId="49.[789,961,291,316]" targetBox="[175,766,290,704]" targetPageId="49">
<paragraph id="8BD31167FFDCFFE8FCA9592A5E06FEF7" blockId="49.[789,1382,291,710]" pageId="49" pageNumber="601">Distribution. SE Brazil, (Sao Sebastiao I, off the Sao Paulo State).</paragraph>
