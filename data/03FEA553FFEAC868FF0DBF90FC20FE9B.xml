<figureCitation id="136C08C0FFEAC869FF0DBFB4FEC5F9D3" box="[151,276,1519,1545]" captionStart-0="FIGURES 31–32" captionStart-1="FIGURES 33–35" captionStart-2="FIGURES 36–37" captionStartId-0="22.[151,262,1944,1968]" captionStartId-1="23.[151,262,1472,1496]" captionStartId-2="24.[151,262,1856,1880]" captionTargetBox-0="[470,1117,181,1920]" captionTargetBox-1="[183,1402,189,1440]" captionTargetBox-2="[164,1424,191,1815]" captionTargetId-0="figure-38@22.[470,1117,181,1920]" captionTargetId-1="figure-17@23.[164,1423,181,1448]" captionTargetId-2="figure-38@24.[151,1436,181,1832]" captionTargetPageId-0="22" captionTargetPageId-1="23" captionTargetPageId-2="24" captionText-0="FIGURES 31–32. Drymeia sororcula sp. nov., ♂ habitus. 31. Lateral view. 32. Dorsal view. (paratype; Georgia, Kazbegi, Mt Kuro, heath, 2450–2500 m, 29.vi.1983.)" captionText-1="FIGURES 33–35. Drymeia sororcula sp. nov. 33. ♂ head, lateral view. 34. ♀ fore tarsomeres, posterior view. 35. ♂ sternite 5, dorsal view. Scale line 0.25 mm. (Georgia, Kazbegi, Mt Kuro, heath, 2120–2330 m, 29.vi.1983 (33, 35), Mt Koltesh, meadows, 2000–2100 m, 8.vii.1983 (34).)" captionText-2="FIGURES 36–37. Drymeia sororcula sp. nov., ♂ terminalia. 36. Cercal plate, dorsal view. 37. Hypopygium, lateral view. Scale lines 0.25 mm. (Georgia, Kazbegi, Mt Kuro, heath, 2120–2330 m, 29.vi.1983.)" figureDoi-0="http://doi.org/10.5281/zenodo.6538244" figureDoi-1="http://doi.org/10.5281/zenodo.6538250" figureDoi-2="http://doi.org/10.5281/zenodo.6538253" httpUri-0="https://zenodo.org/record/6538244/files/figure.png" httpUri-1="https://zenodo.org/record/6538250/files/figure.png" httpUri-2="https://zenodo.org/record/6538253/files/figure.png" pageId="20" pageNumber="375">Figs 31–37</figureCitation>
