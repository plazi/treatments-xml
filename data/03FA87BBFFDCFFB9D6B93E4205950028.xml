<bibRefCitation id="EFC24B5CFFDCFFB9D329393F059C037D" author="Silvestri, F." box="[1287,1429,1050,1072]" pageId="6" pageNumber="266" pagination="1 - 12" refId="ref6358" refString="Silvestri, F. (1895) Viaggio del dottor Alfredo Borelli nella Repubblica Argentina e nel Paraguay. XIV. Chilopodi e Diplopodi. Bollettino del musei di zoologia e di anatomia comparata della Reale Universita di Torino, 10 (203), 1 - 12. https: // doi. org / 10.5962 / bhl. part. 8048" type="journal article" year="1895">Silvestri, 1895</bibRefCitation>
