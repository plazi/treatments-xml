<bibRefCitation id="EFC24B5CFFDCFFB9D49C380703360275" author="Schubart, O." box="[690,831,1314,1336]" pageId="6" pageNumber="266" pagination="23 - 32" refId="ref6273" refString="Schubart, O. (1958) &quot; Leptodesmidae &quot; Brasileiras. VI: Especies novas do Estado do Rio Grande do Sul (Diplopoda, Proterosper- mophora). Revista brasileira de biologia, 18 (1), 23 - 32." type="journal article" year="1958">Schubart 1958</bibRefCitation>
, fig. 4).................... 
<taxonomicName id="4C534D2EFFDCFFB9D2AA380605950275" authority="(Schubart, 1958)" authorityName="" baseAuthorityName="Schubart" baseAuthorityYear="1958" box="[1156,1436,1314,1336]" class="Diplopoda" family="Chelodesmidae" genus="Sandalodesmus" kingdom="Animalia" order="Polydesmida" pageId="6" pageNumber="266" phylum="Arthropoda" rank="species" species="repandus">
<emphasis id="B927EABFFFDCFFB9D2AA380604FD027A" box="[1156,1268,1314,1336]" italics="true" pageId="6" pageNumber="266">S. repandus</emphasis>
(
<bibRefCitation id="EFC24B5CFFDCFFB9D32F3807059C0275" author="Schubart, O." box="[1281,1429,1314,1336]" pageId="6" pageNumber="266" pagination="23 - 32" refId="ref6273" refString="Schubart, O. (1958) &quot; Leptodesmidae &quot; Brasileiras. VI: Especies novas do Estado do Rio Grande do Sul (Diplopoda, Proterosper- mophora). Revista brasileira de biologia, 18 (1), 23 - 32." type="journal article" year="1958">Schubart, 1958</bibRefCitation>
)
</taxonomicName>
</keyLead>
</paragraph>
</keyStep>
