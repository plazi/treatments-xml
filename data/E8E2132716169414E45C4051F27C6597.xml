<subSubSection id="012C1F61CA6217CC685538BE848FD9E6" pageId="null" pageNumber="601" type="vernacular_names">
<paragraph id="6C010326497BFD7E75C5C1CE0829AEA5" pageId="null" pageNumber="601">Rauhhaarige Platterbse</paragraph>
</subSubSection>
</title>
<subSubSection id="A11A1A8DA81B3B55285FE30C3972AF34" pageId="null" pageNumber="601" type="description">
<paragraph id="97466C2306E4C45D46C0728BFC302D69" pageId="null" pageNumber="601">
1-2 
<normalizedToken id="587D5E750406345B9BBE8AFB058A52DC" originalValue="jährig" pageId="null" pageNumber="601">jaehrig</normalizedToken>
; 25-100 cm hoch. Stengel aufsteigend, aufrecht oder kletternd, meist am Grunde verzweigt, 
<normalizedToken id="263154D0C111D6F319237B7746F7F3F4" originalValue="geflügelt" pageId="null" pageNumber="601">gefluegelt</normalizedToken>
(
<normalizedToken id="D83F63C8474C266BAB585BEE3F31730C" originalValue="Flügel" pageId="null" pageNumber="601">Fluegel</normalizedToken>
0,5-1,5 mm breit), kahl. 
<normalizedToken id="5AF29AA61DFD69183EFE3352826597C0" originalValue="Blätter" pageId="null" pageNumber="601">Blaetter</normalizedToken>
mit 2 
<normalizedToken id="93B421241B694086D0DA431D13E0EEBD" originalValue="Teilblättern" pageId="null" pageNumber="601">Teilblaettern</normalizedToken>
und grannenartiger Spitze (unterste 
<normalizedToken id="7F68330A167A71E95F8239EE5CE4BE9D" originalValue="Blätter" pageId="null" pageNumber="601">Blaetter</normalizedToken>
) oder verzweigter Ranke; 
<emphasis id="1085D5A32456EB7E3DA3C538A570DEA0" italics="true" pageId="null" pageNumber="601">
Blattstiel schmal 
<normalizedToken id="2E67FD1D7A480EC792EB384AF528C463" originalValue="geflügelt" pageId="null" pageNumber="601">gefluegelt</normalizedToken>
</emphasis>
, 1-2 mm breit; 
<normalizedToken id="3A86BA3BE1D193E1D0DDC5342BA3EDCD" originalValue="Teilblätter" pageId="null" pageNumber="601">Teilblaetter</normalizedToken>
2-7 cm lang und 5-10mal so lang wie breit, 
<emphasis id="AB65F2F9E9C3EE6180171245F0C864E1" italics="true" pageId="null" pageNumber="601">netznervig</emphasis>
, kahl oder zerstreut behaart; 
<normalizedToken id="A0851B0BA4AFF86011D7CD30D70B7B31" originalValue="Nebenblätter" pageId="null" pageNumber="601">Nebenblaetter</normalizedToken>
⅙- 
<normalizedToken id="CDA55B4BD21ECCC050D03B02AAAA030F" originalValue="¼" pageId="null" pageNumber="601">1/4</normalizedToken>
so lang wie die 
<normalizedToken id="BF0D998BC54625BCA386AA8B723E3CC9" originalValue="Teilblätter" pageId="null" pageNumber="601">Teilblaetter</normalizedToken>
. 
<normalizedToken id="43D0DC57393E495691D01CE416436689" originalValue="Blütenstand" pageId="null" pageNumber="601">Bluetenstand</normalizedToken>
1-3 
<normalizedToken id="BE17989F87EC8938E63F6E17FE625D9D" originalValue="blütig" pageId="null" pageNumber="601">bluetig</normalizedToken>
. Stiel des 
<normalizedToken id="3506915B661BA0115373C63B34AD084C" originalValue="Blütenstandes" pageId="null" pageNumber="601">Bluetenstandes</normalizedToken>
6-10mal so lang wie der 
<normalizedToken id="46B6138F5C87C28FBCAA216FC80D4F7A" originalValue="nächststehende" pageId="null" pageNumber="601">naechststehende</normalizedToken>
Blattstiel. Kelch kahl bis zerstreut behaart; 
<normalizedToken id="84618358B2C00E74201E4B88389247B5" originalValue="Kelchzähne" pageId="null" pageNumber="601">Kelchzaehne</normalizedToken>
fast gleich lang, 1- 
<normalizedToken id="55B560DD66351E6EA8E0C271B175C979" originalValue="1¼" pageId="null" pageNumber="601">11/4</normalizedToken>
mal so lang wie die 
<normalizedToken id="3BEC264114D7EDB09D5F9070B5E520C4" originalValue="Kelchröhre" pageId="null" pageNumber="601">Kelchroehre</normalizedToken>
. Krone 0,8-1,5 cm lang, violettblau (beim Welken blau). Frucht 2,5-4 cm lang und 
<emphasis id="3026A20A7805E26FB6C255E7AEFAAC43" italics="true" pageId="null" pageNumber="601">0,6-0,8 cm breit, rauhhaarig</emphasis>
(
<emphasis id="E40EBB8929D2CAC6ECBA68487A723CAB" italics="true" pageId="null" pageNumber="601">
Haare auf 
<normalizedToken id="DEE8E137F3C5D39FE8852240B2FDC51D" originalValue="Knötchen" pageId="null" pageNumber="601">Knoetchen</normalizedToken>
</emphasis>
), 4-8samig. Samen etwa 4 mm lang, warzig. - 
<normalizedToken id="CC6BBB1CD39F05AA21313F53EC487593" originalValue="Blüte" pageId="null" pageNumber="601">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="D6231DAB37E1A07F1A6F63808612A8B7" pageId="null" pageNumber="601">
<emphasis id="8B35A3B4B2F5C06B5E77BD950AEE26B0" italics="true" pageId="null" pageNumber="601">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="ADB3C841895D179192CA094948841EBB" italics="true" pageId="null" pageNumber="601">14:</emphasis>
Material unbekannter Herkunft und aus botanischen 
<normalizedToken id="37F3D3980C34275B76E014547072E197" originalValue="Gärten" pageId="null" pageNumber="601">Gaerten</normalizedToken>
(Simonet 1932, Senn 1938a), aus den USA (Sciple und Johnston 1963), aus Frankreich und Portugal (Brunsberg 1965), aus Afghanistan (Podlech und Dieterle 1969).
</paragraph>
<paragraph id="0F8670B0A6DE5362B309500A9A26D729" pageId="null" pageNumber="601">
<emphasis id="26C04ABFE3D65B451D03E73AEF4661D4" italics="true" pageId="null" pageNumber="601">Standort.</emphasis>
Kollin, seltener montan. Lockere, 
<normalizedToken id="40F9A4CA71C645217F234656A584626C" originalValue="nährstoffreiche" pageId="null" pageNumber="601">naehrstoffreiche</normalizedToken>
, meist kalkhaltige, lehmige 
<normalizedToken id="28F677515F7C869BFE08021DA9F9D7C6" originalValue="Böden" pageId="null" pageNumber="601">Boeden</normalizedToken>
in warmen Lagen. Getreidefelder, 
<normalizedToken id="EC1B42855A6546AFF0258F5A8B5EA53E" originalValue="Äcker" pageId="null" pageNumber="601">Aecker</normalizedToken>
, 
<normalizedToken id="98566D94B887E6B059B74C64C1BEE3C5" originalValue="Schuttplätze" pageId="null" pageNumber="601">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="0DEDBE037C439D3A46EBF379EB7C4146" pageId="null" pageNumber="601">
<emphasis id="B1992C344D46D1F3ED32AB1BF8C8DA7E" italics="true" pageId="null" pageNumber="601">
Verbreitung. 
<normalizedToken id="2E931C689776155ED422900E87D6AB82" originalValue="Südeuropäisch-westasiatische" pageId="null" pageNumber="601">Suedeuropaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="0382CDFB9DBE042E4562C29FE57E2BA4" originalValue="Nordwärts" pageId="null" pageNumber="601">Nordwaerts</normalizedToken>
vereinzelt bis Eifel, Maintal, Alpen, 
<normalizedToken id="4877A4A1541121C2EA69B74C3F0EE96D" originalValue="Südpolen" pageId="null" pageNumber="601">Suedpolen</normalizedToken>
, Ukraine; Kaukasus, Transkaukasien. - Im Gebiet zerstreut, ziemlich selten (Alpen und Alpenvorland sehrselten), meist nur 
<normalizedToken id="F758C9E040FEB9CBCE20C8FA937B03D5" originalValue="unbeständig" pageId="null" pageNumber="601">unbestaendig</normalizedToken>
oder adventiv.
</paragraph>
</subSubSection>
