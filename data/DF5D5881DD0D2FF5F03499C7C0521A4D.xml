<subSubSection id="C01AEFB8F4B62E452A2E724EF357DE0F" pageId="null" pageNumber="573" type="description">
<paragraph id="CC58BE3D9F5E8C097AFA6FF43FF5F843" pageId="null" pageNumber="573">
Meist ausdauernde 
<normalizedToken id="58DC77A6E164238BB3A6543C427BE207" originalValue="Kräuter" pageId="null" pageNumber="573">Kraeuter</normalizedToken>
, selten 
<normalizedToken id="6C124295E534DF145DCFA9D685E736F4" originalValue="Sträucher" pageId="null" pageNumber="573">Straeucher</normalizedToken>
. 
<normalizedToken id="F953AEF139C1733BD178E192E31245F5" originalValue="Blätter" pageId="null" pageNumber="573">Blaetter</normalizedToken>
gefiedert, mit Endteilblatt und 
<normalizedToken id="636EE5317DD5C227EFBD386F09B87621" originalValue="Nebenblättern" pageId="null" pageNumber="573">Nebenblaettern</normalizedToken>
; 
<normalizedToken id="22CA558DE605EA09495A46C94095D2A5" originalValue="Teilblätter" pageId="null" pageNumber="573">Teilblaetter</normalizedToken>
ganzrandig, oval oder lanzettlich. 
<normalizedToken id="55550301889642916FBAF09981834A97" originalValue="Blüten" pageId="null" pageNumber="573">Blueten</normalizedToken>
aufrecht oder nach unten gebogen, in gestielten 
<normalizedToken id="D9A7603AC7BC91377EB7AD0C17AE39B1" originalValue="Ähren" pageId="null" pageNumber="573">Aehren</normalizedToken>
oder Trauben, die in den Achseln von 
<normalizedToken id="9A0496DA07F408A4E435E1F9CF359F55" originalValue="Blättern" pageId="null" pageNumber="573">Blaettern</normalizedToken>
stehen. 
<normalizedToken id="D71EFBB21D753B9C0A415DF096D3016F" originalValue="Blütenstiele" pageId="null" pageNumber="573">Bluetenstiele</normalizedToken>
meist 
<normalizedToken id="95D764C480EC081DCF63D1E92D7158F6" originalValue="kürzer" pageId="null" pageNumber="573">kuerzer</normalizedToken>
als der Kelch. Kelch 
<normalizedToken id="CE53104F6903A3B1A84189D416B08E2D" originalValue="glockenförmig" pageId="null" pageNumber="573">glockenfoermig</normalizedToken>
, mit 5 
<emphasis id="9E12CE265B665E11DCCD89899ACAFAEF" italics="true" pageId="null" pageNumber="573">schmal 3eckigen</emphasis>
, gleichartigen 
<normalizedToken id="89FC2708A54D63A09296A1E10769219F" originalValue="Zähnen" pageId="null" pageNumber="573">Zaehnen</normalizedToken>
. Krone purpurn, rosa, 
<normalizedToken id="D08B4FDA70B0C55F3D0107F2C0474783" originalValue="weiß" pageId="null" pageNumber="573">weiss</normalizedToken>
oder gelb; Schiffchen etwas 
<normalizedToken id="E76ED0D6D8B850579B6A76B4EFB1E9A4" originalValue="aufwärts" pageId="null" pageNumber="573">aufwaerts</normalizedToken>
<normalizedToken id="8360EB2675114AA6A489E991D04A1386" originalValue="gekrümmt" pageId="null" pageNumber="573">gekruemmt</normalizedToken>
, vorn abgerundet, 
<emphasis id="F41CF17C512400A19D978CA39AAC7743" italics="true" pageId="null" pageNumber="573">
<normalizedToken id="3189FA95296F28C02306959F1ABAC6E1" originalValue="länger" pageId="null" pageNumber="573">laenger</normalizedToken>
als die 
<normalizedToken id="B2978EBA1678894017CA56AFD1B636F1" originalValue="Flügel" pageId="null" pageNumber="573">Fluegel</normalizedToken>
.
</emphasis>
Oberstes Staubblatt frei. Frucht im Kelch fast ungestielt, gerade, flach, 
<emphasis id="097133B7820AF6BB478C02C4539142D1" italics="true" pageId="null" pageNumber="573">
mehrsamig, zwischen den Samen 
<normalizedToken id="4BF004D560CAB70D074B49153EEBC316" originalValue="eingeschnürt" pageId="null" pageNumber="573">eingeschnuert</normalizedToken>
und zur Fruchtzeit in einzelne, scheibenartige Glieder zerfallend.
</emphasis>
Samen 
<normalizedToken id="8277D6C42F48905E472A23DBC8B526FB" originalValue="linsenförmig" pageId="null" pageNumber="573">linsenfoermig</normalizedToken>
.
</paragraph>
<paragraph id="B29FC1941F16501C578AF482558F29DF" pageId="null" pageNumber="573">
Die Gattung 
<taxonomicName id="9E694D21359762311AA74DD70425AE32" class="Magnoliopsida" family="Fabaceae" genus="Hedysarum" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="573" phylum="Tracheophyta" rank="genus">
<emphasis id="FBD1E694DB8524E37B509AF05D487F4B" italics="true" pageId="null" pageNumber="573">Hedysarum</emphasis>
</taxonomicName>
<normalizedToken id="BBF3B7D181630201C87627D4977B9C12" originalValue="umfaßt" pageId="null" pageNumber="573">umfasst</normalizedToken>
<emphasis id="F43274088A55FA6604AFEF23FD295480" italics="true" pageId="null" pageNumber="573">ca. 160, vorwiegend zentralasiatische und mediterrane Arten. Chromosomengrundzahlen</emphasis>
n = 7 und 8.
</paragraph>
</subSubSection>
