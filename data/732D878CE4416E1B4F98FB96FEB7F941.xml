</paragraph>
<paragraph id="FB3B369AE4416E1B4FC8FA6EFD8DFA69" blockId="100.[151,1436,1389,1666]" box="[199,571,1425,1450]" pageId="100" pageNumber="101">
<emphasis id="C9F0EA88E4416E1B4FC8FA6EFE2CFA69" bold="true" box="[199,410,1425,1450]" pageId="100" pageNumber="101">Floral visitations:</emphasis>
