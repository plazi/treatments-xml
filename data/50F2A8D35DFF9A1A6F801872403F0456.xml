<subSubSection id="5C70BAA3288E0C51CDF09243FE2B1F33" pageId="null" pageNumber="648" type="description">
<paragraph id="ED172443D8297571C19F5AE61F2DD8D1" pageId="null" pageNumber="648">
Unterscheidet sich von 
<taxonomicName id="CF043C93B2E5539A70E7E8041E6CDC69" class="Magnoliopsida" family="Polygalaceae" genus="Polygala" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="648" phylum="Tracheophyta" rank="species" species="vulgaris">
<emphasis id="99D669929B730197E277FDEA411921CC" italics="true" pageId="null" pageNumber="648">P. vulgaris</emphasis>
</taxonomicName>
(Nr. 2g) durch folgende Merkmale: Pflanze oft niederhegend und ausgebreitet; 
<emphasis id="C3D45ED4C50CB924E781D8A41D70CA7A" italics="true" pageId="null" pageNumber="648">
<normalizedToken id="66415D8064FCD759C9663415829F970D" originalValue="Tragblätter" pageId="null" pageNumber="648">Tragblaetter</normalizedToken>
1-1,8 mm lang;
</emphasis>
oberstes Kelchblatt 2-3 mm lang; 
<normalizedToken id="8F4F7CC5F7545A94A792C097A198F7DC" originalValue="Flügel" pageId="null" pageNumber="648">Fluegel</normalizedToken>
5,5 bis 7,5 mm lang und 2,7-4 mm breit; 
<emphasis id="E2B05A6A5AAD27542B1E7BD5C0806B56" italics="true" pageId="null" pageNumber="648">Fransen der untern Kronzipfel 10-13; Frucht 4-5 mm lang, 1</emphasis>
⅕- 
<emphasis id="BCCE255CCC4D1DAD9CEEDBF69B7FDCF1" italics="true" pageId="null" pageNumber="648">1</emphasis>
<normalizedToken id="A83B8E5EFB14CD527A68B946571B7FBC" originalValue="½" pageId="null" pageNumber="648">1/2</normalizedToken>
<emphasis id="B7DECD37FCF8A2665BFE68F591722FE7" italics="true" pageId="null" pageNumber="648">mal so breit und</emphasis>
⅘- 
<emphasis id="43E19306F000B97C60288996B0EEBECD" italics="true" pageId="null" pageNumber="648">
1mal so lang wie die 
<normalizedToken id="9A7E749C750725855480987C0849AD5D" originalValue="Flügel" pageId="null" pageNumber="648">Fluegel</normalizedToken>
;
</emphasis>
Samen 2,2-2,8 mm lang. - 
<normalizedToken id="711A11F8FFAE5696861F8516C8FDC0EC" originalValue="Blüte" pageId="null" pageNumber="648">Bluete</normalizedToken>
: 
<normalizedToken id="455002562C417CB9797B1DEC06878EC5" originalValue="Später" pageId="null" pageNumber="648">Spaeter</normalizedToken>
<normalizedToken id="68E55661E9913640C95460E93DFB9302" originalValue="Frühling" pageId="null" pageNumber="648">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="26BD547749E79542136E6EFFEEDDA792" pageId="null" pageNumber="648">
<emphasis id="4A49ED1E3BA58C3C293D2160D351B865" italics="true" pageId="null" pageNumber="648">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="561148043F381E0EB1AB04D32EF26226" pageId="null" pageNumber="648">
<emphasis id="E145B4376D6041B0089ACDEC7CFAC109" italics="true" pageId="null" pageNumber="648">Standort.</emphasis>
Kollin und montan. Kalkarme, saure, stickstoffarme 
<normalizedToken id="E7843877C609466A6FE82F157F891583" originalValue="Böden" pageId="null" pageNumber="648">Boeden</normalizedToken>
. Weiden, 
<normalizedToken id="5139FAB6CD2DA97494F857C4532B0CF9" originalValue="Waldränder" pageId="null" pageNumber="648">Waldraender</normalizedToken>
. 
<emphasis id="9E41B838F06FBA2D050B4A4FB2F66CC3" italics="true" pageId="null" pageNumber="648">Nardus-</emphasis>
und 
<taxonomicName id="67C191EE0D831E6469FCA4220AD79609" class="Magnoliopsida" family="Ericaceae" genus="Calluna" kingdom="Plantae" order="Ericales" pageId="null" pageNumber="648" phylum="Tracheophyta" rank="genus">
<emphasis id="615682EAB67A4466501F6A5F4EECD953" italics="true" pageId="null" pageNumber="648">Calluna</emphasis>
</taxonomicName>
gesellschaften.
</paragraph>
<paragraph id="9D06F11B7E8C14B1C550EB29D004D8DA" pageId="null" pageNumber="648">
<emphasis id="18A1EAA3AF06C1985883CA0F6E9948F0" italics="true" pageId="null" pageNumber="648">Verbreitung.</emphasis>
Wahrscheinlich 
<emphasis id="067DCC71415F6737E04FDC739EEF3612" italics="true" pageId="null" pageNumber="648">
<normalizedToken id="D6AB4108E0A84A6FF64F90CFAA18986B" originalValue="westeuropäische" pageId="null" pageNumber="648">westeuropaeische</normalizedToken>
Pflanze
</emphasis>
(genaue Verbreitung 
<normalizedToken id="C123C08301D5E9DD445D3A3A791064E9" originalValue="muß" pageId="null" pageNumber="648">muss</normalizedToken>
festgestellt werden): 
<normalizedToken id="747CFD4CD79DBFFF97E9BF96003C7C2E" originalValue="Großbritannien" pageId="null" pageNumber="648">Grossbritannien</normalizedToken>
, Frankreich, Belgien, Deutschland, Polen, Alpen. - Im Gebiet wahrscheinlich ziemlich verbreitet (z. B. Nordschweiz, Alpenvorland, Hinterrhein, 
<normalizedToken id="9827F31703E489F22EFFDC3112E7CFEC" originalValue="Alpensüdseite" pageId="null" pageNumber="648">Alpensuedseite</normalizedToken>
).
</paragraph>
</subSubSection>
