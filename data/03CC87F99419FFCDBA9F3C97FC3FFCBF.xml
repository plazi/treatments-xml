<taxonomicName id="4C654D6C9418FFC2B8123BBDFD6CFE7A" authority="Sassi, 2022" authorityName="Sassi" authorityYear="2022" box="[538,753,439,465]" class="Insecta" family="Chrysomelidae" genus="Metallactus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="23" pageNumber="274" phylum="Arthropoda" rank="species" species="geiseri" status="sp. nov.">
<emphasis id="B911EAFD9418FFC2B8123BBDFD6CFE7A" box="[538,753,439,465]" italics="true" pageId="23" pageNumber="274">Metallactus geiseri</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A22257869418FFC2B8F03BBDFCD2FE7B" box="[760,847,439,465]" pageId="23" pageNumber="274" rank="species">sp. nov.</taxonomicNameLabel>
<typeStatus id="54DE884D9418FFC2B95D3BB6FC7EFE65" box="[853,995,444,463]" pageId="23" pageNumber="274">PARATYPUS</typeStatus>
