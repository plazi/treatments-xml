<paragraph pageId="0" pageNumber="27">
<taxonomicName authorityName="Mita &amp; Shaw" authorityYear="2020" class="Insecta" family="Proteaceae" genus="Dinapsis" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Dinapsis albicauda" order="Hymenoptera" pageId="0" pageNumber="27" phylum="Arthropoda" rank="species" species="albicauda">
