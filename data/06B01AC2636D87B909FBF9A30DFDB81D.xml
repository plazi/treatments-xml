<subSubSection id="C6385E4E1543DC20B0B4D5A57BBD48D2" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="530D730DF9E95642EDA1A910C39FE18B" pageId="null" pageNumber="590">Alpen-Pippau</paragraph>
</subSubSection>
</title>
<subSubSection id="E1C4E88CBFB4984464306C3EFB219882" pageId="null" pageNumber="590" type="description">
<paragraph id="11058B8825B8B55007F2924B6E00C9BA" pageId="null" pageNumber="590">
Ausdauernd, mit dunkler, holziger Pfahlwurzel; 
<emphasis id="271D9E76A9D8C2F036BBDECBCBF97146" italics="true" pageId="null" pageNumber="590">10</emphasis>
- 
<emphasis id="215F6433C8F6CC8F65040D89E9A9BA4F" italics="true" pageId="null" pageNumber="590">30 cm hoch.</emphasis>
Stengel aufrecht, 
<emphasis id="AA1897631AFBE0453F8C94AAA427FBA9" italics="true" pageId="null" pageNumber="590">meist unverzweigt</emphasis>
, 1-, seltener 2-5 
<normalizedToken id="302ABB6F32E83193C5F61A26D94CF7DB" originalValue="köpfig" pageId="null" pageNumber="590">koepfig</normalizedToken>
, besonders im obern Teil dicht, 
<normalizedToken id="D6CA2E333871730ED16A93E607B55E9D" originalValue="weiß" pageId="null" pageNumber="590">weiss</normalizedToken>
bis gelblich und kraus behaart, nur im untern Teil entfernt 
<normalizedToken id="9701E3CBA5DEF42C1193F003B2DB7E1F" originalValue="beblättert" pageId="null" pageNumber="590">beblaettert</normalizedToken>
. 
<normalizedToken id="B7DFC0147224C48EC96E90EF18DBCABA" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
mit 
<normalizedToken id="B58593D634751A9D7CCADF7A20D263C3" originalValue="drüsigen" pageId="null" pageNumber="590">druesigen</normalizedToken>
oder 
<normalizedToken id="CA71DDA37BC17F504E74B30AA9D004B4" originalValue="drüsenlosen" pageId="null" pageNumber="590">druesenlosen</normalizedToken>
, kurzen, gelben und kurzen, 
<normalizedToken id="91C090DDA9E4CD52065E56768BD9E1D6" originalValue="weißen" pageId="null" pageNumber="590">weissen</normalizedToken>
, krausen Haaren, im 
<normalizedToken id="A4424F7C1F70E60796497E53AD73C821" originalValue="Umriß" pageId="null" pageNumber="590">Umriss</normalizedToken>
schmal oval bis lanzettlich, 
<emphasis id="A58BB57F6A641B147AC69BAE89B2780F" italics="true" pageId="null" pageNumber="590">
die 
<normalizedToken id="F17C8F1E7727AF618583947263C89B7A" originalValue="grundständigen" pageId="null" pageNumber="590">grundstaendigen</normalizedToken>
buchtig 
<normalizedToken id="FDD6152E78AA7ECB754611082E84E6D7" originalValue="gezähnt" pageId="null" pageNumber="590">gezaehnt</normalizedToken>
bis fiederteilig
</emphasis>
, 
<normalizedToken id="8ED59545598ACFED3F103CE7DF4CEE64" originalValue="allmählich" pageId="null" pageNumber="590">allmaehlich</normalizedToken>
in den 
<normalizedToken id="10F23D960D778FBF13360E1B7D75F810" originalValue="geflügelten" pageId="null" pageNumber="590">gefluegelten</normalizedToken>
Stiel 
<normalizedToken id="C5351E970767BAF8F87FE604C0139B3F" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
, die 
<normalizedToken id="F0CCD6DD6E34855C4E85A3D575954FA7" originalValue="stengelständigen" pageId="null" pageNumber="590">stengelstaendigen</normalizedToken>
meist ganzrandig und kleiner, mit 
<emphasis id="EBC4C7C466BEE37BA7F60F8641C924F2" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="BE1723D5EFAD777E3468DA4C7827BCE1" originalValue="verschmälertem" pageId="null" pageNumber="590">verschmaelertem</normalizedToken>
</emphasis>
, 
<emphasis id="F574A1FE5865860460DE4FD1F9774A07" italics="true" pageId="null" pageNumber="590">abgerundetem Grunde sitzend</emphasis>
und den Stengel teilweise umfassend. 
<normalizedToken id="816E230651D9843C6D3E39AA0532C579" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
<normalizedToken id="AEFB20DDF53804A5744264D5E02BC5F9" originalValue="glockenförmig" pageId="null" pageNumber="590">glockenfoermig</normalizedToken>
, 12-16 mm lang, dicht, kurz und 
<normalizedToken id="CF6B51A5E1B7443ACAB1AF410B706374" originalValue="weiß" pageId="null" pageNumber="590">weiss</normalizedToken>
behaart und zerstreut, dunkel, 
<normalizedToken id="B24482A2BFE25DE7A9E78195876759DC" originalValue="drüsig" pageId="null" pageNumber="590">druesig</normalizedToken>
oder 
<normalizedToken id="DCAD51670E413682D0FE1FC9488C2EC4" originalValue="drüsenlos" pageId="null" pageNumber="590">druesenlos</normalizedToken>
behaart; 
<normalizedToken id="544F13E3183A87C32712494C946D7535" originalValue="äußere" pageId="null" pageNumber="590">aeussere</normalizedToken>
<normalizedToken id="E6D9F23E5D730CD8707D37B376B26BA8" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
<normalizedToken id="128EEF947D31B79ED804293FDF5A1822" originalValue="½" pageId="null" pageNumber="590">1/2</normalizedToken>
-⅔ so lang wie die innern, am Rande 
<normalizedToken id="178B60FCEE61019C644F4AAF4479B6D3" originalValue="höchstens" pageId="null" pageNumber="590">hoechstens</normalizedToken>
gegen die Spitze kraus behaart, 
<emphasis id="44AA1C7C6A57E0477129022ED31AC7C2" italics="true" pageId="null" pageNumber="590">Innenseite der innern kurz behaart.</emphasis>
Boden des 
<normalizedToken id="46367BCDF569A02AEB535350541D4858" originalValue="Blütenkopfes" pageId="null" pageNumber="590">Bluetenkopfes</normalizedToken>
kurz behaart. Kronen gelb, die 
<normalizedToken id="17C72907DDF3EEFB5D02526CEB29ADE3" originalValue="äußern" pageId="null" pageNumber="590">aeussern</normalizedToken>
17-23 mm lang, 
<emphasis id="3E068DA7DF71A8BDD03C63D1BF0D0657" italics="true" pageId="null" pageNumber="590">
mit 
<normalizedToken id="1835A682D4AE906D2BB651956C2D3CF0" originalValue="außen" pageId="null" pageNumber="590">aussen</normalizedToken>
kurz behaarter 
<normalizedToken id="6CA7F1910941F8DFF5E61903DACEE071" originalValue="Kronröhre" pageId="null" pageNumber="590">Kronroehre</normalizedToken>
. 
<normalizedToken id="CE9724B447D386D25964AEEFB464F128" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
ungleich 10
</emphasis>
- 
<emphasis id="1F055ED137E9A151DCDDE05F3C322CFC" italics="true" pageId="null" pageNumber="590">12rippig</emphasis>
, 7-11 mm lang, 
<emphasis id="357F8EE57B24D9EF8020E36CC0E40815" italics="true" pageId="null" pageNumber="590">
nach oben 
<normalizedToken id="B109DF013F40927CD717223635E50100" originalValue="allmählich" pageId="null" pageNumber="590">allmaehlich</normalizedToken>
<normalizedToken id="0C800B3CA73E6A2D4AA9484FC4AF4749" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
oder undeutlich 
<normalizedToken id="553AAF078378886CDEE1A10A4F48BBF5" originalValue="geschnäbelt" pageId="null" pageNumber="590">geschnaebelt</normalizedToken>
. 
<taxonomicName id="4DACBD8D4D9BAFB4BCD06376EEA02B5D" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
<normalizedToken id="59608BED42C11F4446049F0D70A44045" originalValue="weiß" pageId="null" pageNumber="590">weiss</normalizedToken>
</emphasis>
, 2-4reihig, 5-8 mm lang. - 
<normalizedToken id="4A8F0E85C31DAE7FA6961A4BBB1F183A" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: 
<normalizedToken id="0D132CA3D4033940B2199ABFC1B79193" originalValue="Später" pageId="null" pageNumber="590">Spaeter</normalizedToken>
<normalizedToken id="359A583CBE32688556FABC506EBB639D" originalValue="Frühling" pageId="null" pageNumber="590">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="AF40E99F47AD1F331B13B3B17785D1C6" pageId="null" pageNumber="590">
<emphasis id="1D011926F58E56D4E380165B968B52E5" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="07A3D3681798048EC0FF08700E8FD5D7" italics="true" pageId="null" pageNumber="590">8:</emphasis>
Material aus botanischen 
<normalizedToken id="9C0E0E711C77B2BE9967FF6DAB666524" originalValue="Gärten" pageId="null" pageNumber="590">Gaerten</normalizedToken>
(Babcock 1947).
</paragraph>
<paragraph id="9133B8FDD2F9D7EB4DF79E8DAE52CB62" pageId="null" pageNumber="590">
<emphasis id="C7ECD6BFC9A298036D97103234F08275" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Subalpin, selten kollin, montan und alpin. 
<normalizedToken id="5A87DF29F36E89169945A5D1B320A800" originalValue="Mäßig" pageId="null" pageNumber="590">Maessig</normalizedToken>
trockene, 
<normalizedToken id="1CDDFE4915A948FF80407621097EE991" originalValue="flachgründige" pageId="null" pageNumber="590">flachgruendige</normalizedToken>
, kalkreiche 
<normalizedToken id="012769AE481C2DA6C0BF27909B475B5F" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
. 
<normalizedToken id="70EE9561FE121DE10930134387C5F4AD" originalValue="Föhrenwälder" pageId="null" pageNumber="590">Foehrenwaelder</normalizedToken>
, Schutthalden, 
<normalizedToken id="6CD7B766A3DEAD0B8D58731ED494FD21" originalValue="lückige" pageId="null" pageNumber="590">lueckige</normalizedToken>
Rasen.
</paragraph>
<paragraph id="3117B260D9ECE7DF41D85B9CE7690E9E" pageId="null" pageNumber="590">
<emphasis id="2FD63237BB8DDD2C57DDD87027246F80" italics="true" pageId="null" pageNumber="590">
Verbreitung. Mittel- und 
<normalizedToken id="6DD47FED6CFCD174220DA13CFD567138" originalValue="südeuropäische" pageId="null" pageNumber="590">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="B10C53F461593884E2F181D8BA8A2FB1" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="7C30B8B56686049D0474BFEE10F285FA" originalValue="östlich" pageId="null" pageNumber="590">oestlich</normalizedToken>
</emphasis>
)
<emphasis id="8532E1218A3896C1DF327DECF24B4D15" italics="true" pageId="null" pageNumber="590">:</emphasis>
Alpen (
<normalizedToken id="3043B178589EA02287A9598F9F2001FA" originalValue="östlich" pageId="null" pageNumber="590">oestlich</normalizedToken>
des Oberwallis und des Aostatals), Nordapennin, Gebirge der Balkanhalbinsel (
<normalizedToken id="9BEA9A99CA6690ED0E9A4A8B9EADC01F" originalValue="südwärts" pageId="null" pageNumber="590">suedwaerts</normalizedToken>
bis Montenegro und Serbien), westliche Karpaten, Kleinasien (bithynischer Olymp). - Im Gebiet: Alpen und 
<normalizedToken id="F628528A7519C4D54117140A281C1614" originalValue="nördliches" pageId="null" pageNumber="590">noerdliches</normalizedToken>
Alpenvorland (
<normalizedToken id="25CCE71935FE7A173C15720E3ED99A0E" originalValue="westwärts" pageId="null" pageNumber="590">westwaerts</normalizedToken>
bis Ollomont im Aostatal, Binntal, Rosenlaui und Gegend des Pilatus), Nordschweiz (Schaffhausen, Irchel, Steckborn, 
<normalizedToken id="4E62A1AC9D0BC3E7168389F365274C63" originalValue="Trüllikon" pageId="null" pageNumber="590">Truellikon</normalizedToken>
), Baar, 
<normalizedToken id="586A35B1D29D157D7C3D0B915152C65F" originalValue="südwestliche" pageId="null" pageNumber="590">suedwestliche</normalizedToken>
Alb.
</paragraph>
</subSubSection>
