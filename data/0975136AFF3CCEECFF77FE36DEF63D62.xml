<emphasis id="B3A87E6EFF3CCEECFF77FD3DDA513F28" bold="true" box="[136,258,748,774]" pageId="177" pageNumber="178">Diagnosis.</emphasis>
Males of 
<taxonomicName id="46DCD9FFFF3CCEECFE5FFD3CD9073F28" authorityName="Rios-Tamayo &amp; Goloboff" authorityYear="2018" box="[416,596,748,775]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="177" pageNumber="178" phylum="Arthropoda" rank="species" species="cordobensis">
<emphasis id="B3A87E6EFF3CCEECFE5FFD3CD9073F28" box="[416,596,748,775]" italics="true" pageId="177" pageNumber="178">A. cordobensis</emphasis>
</taxonomicName>
(
<bibRefCitation id="E54DDF8DFF3CCEECFD8EFD3CDA333F05" author="Rios-Tamayo, D. &amp; Goloboff, P. A." pageId="177" pageNumber="178" pagination="1 - 83" refId="ref140496" refString="Rios-Tamayo, D. &amp; Goloboff, P. A. (2018) Taxonomic revision and morphology of the trapdoor spider genus Actinopus (Mygalomorphae: Actinopodidae) in Argentina. Bulletin of the American Museum of Natural History, 419, 1 - 83. https: // doi. org / 10.1206 / 0003 - 0090 - 419.1.1" type="journal article" year="2018">Ríos-Tamayo &amp; Goloboff, 2018</bibRefCitation>
, fig. 15 D–F) resemble those of 
<taxonomicName id="46DCD9FFFF3CCEECFD0DFCC3DBA13F7E" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="177" pageNumber="178" phylum="Arthropoda" rank="species" species="itacolomi">
<emphasis id="B3A87E6EFF3CCEECFD0DFCC3DBA13F7E" italics="true" pageId="177" pageNumber="178">A. itacolomi</emphasis>
</taxonomicName>
(
<figureCitation id="19E7BEF9FF3CCEECFEFDFCE7DA333F7F" box="[258,352,822,849]" captionStart="FIGURE 153" captionStartId="169.[136,235,1379,1403]" captionTargetBox="[161,1413,198,1341]" captionTargetId="figure-264@169.[151,1436,189,1355]" captionTargetPageId="169" captionText="FIGURE 153. Actinopus itacolomi sp. nov., male: A–C IBSP: A. Copulatory bulb, prolateral; B. Copulatory bulb, dorsal; C. Copulatory bulb, retrolateral. PA-Paraembolic apophysis; BTA-Basal Tegular Apophysis; PAc-Prolateral Accessory keel; PI- Prolateral Inferior keel; PS-Prolateral Superior keel; Arrows: Serrated area. Paratype, female: D UFMG 18876: D. Spermathecae, dorsal view. Scales lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.5597563" httpUri="https://zenodo.org/record/5597563/files/figure.png" pageId="177" pageNumber="178">Fig. 153</figureCitation>
A–C), 
<taxonomicName id="46DCD9FFFF3CCEECFE4CFCE7D9033F7E" authorityName="C. L. Koch" authorityYear="1842" box="[435,592,822,848]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="177" pageNumber="178" phylum="Arthropoda" rank="species" species="longipalpis">
<emphasis id="B3A87E6EFF3CCEECFE4CFCE7D9033F7E" box="[435,592,822,848]" italics="true" pageId="177" pageNumber="178">A. longipalpis</emphasis>
</taxonomicName>
(
<figureCitation id="19E7BEF9FF3CCEECFD9FFCE7D9EC3F7F" box="[608,703,822,849]" captionStart="FIGURE 156" captionStartId="172.[136,235,1679,1703]" captionTargetBox="[188,1382,198,1643]" captionTargetId="figure-114@172.[151,1435,189,1655]" captionTargetPageId="172" captionText="FIGURE 156. Actinopus longipalpis C. L. Koch, 1842, holotype, male: A–E ZMB 2107: A. Copulatory bulb, prolateral; B. Copulatory bulb, dorsal; C. Copulatory bulb, retrolateral. PA-Paraembolic apophysis; BTA-Basal Tegular Apophysis; PAc- Prolateral Accessory keel; PI-Prolateral Inferior keel; PS-Prolateral Superior keel. D. Rastellum, dorsal; E. Rastellum, ventral. Scales lines: A–C: 1 mm; D–E: 0.5 mm." figureDoi="http://doi.org/10.5281/zenodo.5597571" httpUri="https://zenodo.org/record/5597571/files/figure.png" pageId="177" pageNumber="178">Fig. 156</figureCitation>
A–C), 
<taxonomicName id="46DCD9FFFF3CCEECFF77FC8ADBB93F5A" authorityName="Rios-Tamayo &amp; Goloboff" authorityYear="2018" box="[136,234,859,885]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="177" pageNumber="178" phylum="Arthropoda" rank="species" species="ariasi">
<emphasis id="B3A87E6EFF3CCEECFF77FC8ADBB93F5A" box="[136,234,859,885]" italics="true" pageId="177" pageNumber="178">A. ariasi</emphasis>
</taxonomicName>
(
<bibRefCitation id="E54DDF8DFF3CCEECFF04FC8AD93E3F5B" author="Rios-Tamayo, D. &amp; Goloboff, P. A." box="[251,621,858,885]" pageId="177" pageNumber="178" pagination="1 - 83" refId="ref140496" refString="Rios-Tamayo, D. &amp; Goloboff, P. A. (2018) Taxonomic revision and morphology of the trapdoor spider genus Actinopus (Mygalomorphae: Actinopodidae) in Argentina. Bulletin of the American Museum of Natural History, 419, 1 - 83. https: // doi. org / 10.1206 / 0003 - 0090 - 419.1.1" type="journal article" year="2018">Ríos-Tamayo &amp; Goloboff, 2018</bibRefCitation>
, fig. 12 D–F) and 
<taxonomicName id="46DCD9FFFF3CCEECFF48FC51DA4B3FB7" authorityName="Rios-Tamayo &amp; Goloboff" authorityYear="2018" box="[183,280,895,922]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="177" pageNumber="178" phylum="Arthropoda" rank="species" species="coylei">
<emphasis id="B3A87E6EFF3CCEECFF48FC51DA4B3FB7" box="[183,280,895,922]" italics="true" pageId="177" pageNumber="178">A. coylei</emphasis>
</taxonomicName>
(
<bibRefCitation id="E54DDF8DFF3CCEECFED9FCAED9DC3FB7" author="Rios-Tamayo, D. &amp; Goloboff, P. A." box="[294,655,895,921]" pageId="177" pageNumber="178" pagination="1 - 83" refId="ref140496" refString="Rios-Tamayo, D. &amp; Goloboff, P. A. (2018) Taxonomic revision and morphology of the trapdoor spider genus Actinopus (Mygalomorphae: Actinopodidae) in Argentina. Bulletin of the American Museum of Natural History, 419, 1 - 83. https: // doi. org / 10.1206 / 0003 - 0090 - 419.1.1" type="journal article" year="2018">Ríos-Tamayo &amp; Goloboff, 2018</bibRefCitation>
, fig. 16 D–F), by the PA continuous to PAc. They differ from those of 
<taxonomicName id="46DCD9FFFF3CCEECFF57FC18DA783FCC" box="[168,299,968,995]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="177" pageNumber="178" phylum="Arthropoda" rank="species" species="itacolomi">
<emphasis id="B3A87E6EFF3CCEECFF57FC18DA783FCC" box="[168,299,968,995]" italics="true" pageId="177" pageNumber="178">A itacolomi</emphasis>
</taxonomicName>
, 
<taxonomicName id="46DCD9FFFF3CCEECFEC5FC18DA8B3FCC" authorityName="C. L. Koch" authorityYear="1842" box="[314,472,968,995]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="177" pageNumber="178" phylum="Arthropoda" rank="species" species="longipalpis">
<emphasis id="B3A87E6EFF3CCEECFEC5FC18DA8B3FCC" box="[314,472,968,995]" italics="true" pageId="177" pageNumber="178">A. longipalpis</emphasis>
</taxonomicName>
and 
<taxonomicName id="46DCD9FFFF3CCEECFDEEFC18D9CA3FCC" box="[529,665,968,995]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="177" pageNumber="178" phylum="Arthropoda" rank="species" species="pindapoy">
<emphasis id="B3A87E6EFF3CCEECFDEEFC18D9CA3FCC" box="[529,665,968,995]" italics="true" pageId="177" pageNumber="178">A. pindapoy</emphasis>
</taxonomicName>
