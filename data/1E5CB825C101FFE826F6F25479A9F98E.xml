<taxonomicName id="51F572B0C101FFE824FFF31F7A84FA3D" authority="Staudinger, 1892" authorityName="Staudinger" authorityYear="1892" box="[670,981,1395,1420]" class="Insecta" family="Noctuidae" genus="Gynaephila" kingdom="Animalia" order="Lepidoptera" pageId="1" pageNumber="592" phylum="Arthropoda" rank="genus">
