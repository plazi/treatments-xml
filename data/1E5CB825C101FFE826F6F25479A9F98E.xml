Staudinger, 1892
</taxonomicName>
with 
<taxonomicName id="51F572B0C101FFE82273F31F7DAAFA3A" authority="Walker, 1866" authorityName="Walker" authorityYear="1866" box="[1042,1275,1395,1419]" class="Insecta" family="Noctuidae" genus="Naarda" kingdom="Animalia" order="Lepidoptera" pageId="1" pageNumber="592" phylum="Arthropoda" rank="genus">
