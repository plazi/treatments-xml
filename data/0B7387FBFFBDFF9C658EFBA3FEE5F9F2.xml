<emphasis id="B1AEEAFFFFBDFF9C645CFB74FED4FB61" bold="true" box="[113,261,1195,1218]" pageId="13" pageNumber="230">
<typeStatus id="5C61884FFFBDFF9C645CFB74FF78FB61" box="[113,169,1195,1218]" pageId="13" pageNumber="230">Type</typeStatus>
species.
</emphasis>
<taxonomicName id="44DA4D6EFFBDFF9C6521FB74FE73FB61" authority="Fouquè, 2015" authorityName="Fouquè" authorityYear="2015" box="[268,418,1195,1218]" genus="Pseudochillus" pageId="13" pageNumber="226" rank="genus" status="gen. nov.">
<emphasis id="B1AEEAFFFFBDFF9C6521FB74FE73FB61" box="[268,418,1195,1218]" italics="true" pageId="13" pageNumber="230">Pseudochillus</emphasis>
</taxonomicName>
<taxonomicName id="44DA4D6EFFBDFF9C6585FB74FCD6FB61" authority="Fouquè, 2015" authorityName="Fouquè" authorityYear="2015" box="[424,775,1195,1218]" genus="Pseudochillus" pageId="13" pageNumber="230" rank="species" species="palawanus" status="sp. nov." subGenus="Micropseudochillus">
(
<emphasis id="B1AEEAFFFFBDFF9C659CFB74FD55FB61" box="[433,644,1195,1218]" italics="true" pageId="13" pageNumber="230">Micropseudochillus</emphasis>
) 
<emphasis id="B1AEEAFFFFBDFF9C66BEFB74FCD6FB61" box="[659,775,1195,1218]" italics="true" pageId="13" pageNumber="230">palawanus</emphasis>
</taxonomicName>
<taxonomicNameLabel id="AA9D5784FFBDFF9C6720FB74FCB3FB61" box="[781,866,1195,1218]" pageId="13" pageNumber="230" rank="species">sp. nov.</taxonomicNameLabel>
