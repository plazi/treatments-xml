</subSubSection>
<subSubSection id="D9F16554FFA3BA0FB70DF4B0B1E9FBA8" pageId="31" pageNumber="650" type="distribution">
<caption id="C5946657FFA3BA0FB70DF4B0B1E9FBA8" ID-DOI="http://doi.org/10.5281/zenodo.6567822" ID-Zenodo-Dep="6567822" httpUri="https://zenodo.org/record/6567822/files/figure.png" inLine="true" pageId="31" pageNumber="650" targetBox="[183,774,867,1281]" targetPageId="31">
<paragraph id="915436DFFFA3BA0FB70DF4B0B1E9FBA8" blockId="31.[798,1393,861,1285]" pageId="31" pageNumber="650">
<emphasis id="A39FEACDFFA3BA0FB70DF4B0B1E8FC3F" bold="true" box="[799,974,976,1009]" pageId="31" pageNumber="650">Distribution.</emphasis>
Malay Peninsula (extreme S 
<collectingCountry id="E9FC764FFFA3BA0FB70DF497B1B8FBD6" box="[799,926,1015,1048]" name="Thailand" pageId="31" pageNumber="650">Thailand</collectingCountry>
in Hala Bala Forest and Peninsular 
<collectingCountry id="E9FC764FFFA3BA0FB77CF37EB1C2FBF1" box="[878,996,1054,1087]" name="Malaysia" pageId="31" pageNumber="650">Malaysia</collectingCountry>
