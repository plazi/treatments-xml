<bibRefCitation id="9201C5E2FF94414DFF5A26114BFDFE9F" author="Burmeister, H. C. C." box="[241,433,289,315]" pageId="14" pageNumber="415" refId="ref25735" refString="Burmeister, H. C. C. (1839) Handbuch der Entomologie. Zweiter Band. Besondere Entomologie. Zweite Abtheilung. Kaukerfe. Gymnognatha. Zweite Halfte. Vulgo Neuroptera). Theodor Johann Christian Friedrich Enslin, Berlin, xii + 294 pp. [pp. i - xii + 757 - 1050. [BotN ref  1771]" type="book" year="1839">Burmeister, 1839</bibRefCitation>
