<subSubSection id="BE8AEB98FF94414DFF6C27A74FD5FE25" pageId="14" pageNumber="415" type="discussion">
<paragraph id="F62FB813FF94414DFF6C27A74FD5FE25" blockId="14.[151,1437,151,385]" pageId="14" pageNumber="415">
<emphasis id="C4E46401FF94414DFF6C27A74B49FF15" bold="true" box="[199,261,151,177]" pageId="14" pageNumber="415">Note.</emphasis>
The genus 
<taxonomicName id="3190C390FF94414DFE2D27A74B9CFF15" authority="Lefebvre, 1842" authorityName="Lefebvre" authorityYear="1842" box="[390,464,151,177]" class="Insecta" family="Ascalaphidae" genus="Hybris" higherTaxonomySource="GBIF" kingdom="Animalia" order="Neuroptera" pageId="14" pageNumber="415" phylum="Arthropoda" rank="genus">
<emphasis id="C4E46401FF94414DFE2D27A74B9CFF15" box="[390,464,151,177]" italics="true" pageId="14" pageNumber="415">Hybris</emphasis>
</taxonomicName>
was originally described by 
<bibRefCitation id="9201C5E2FF94414DFCA427A7498FFF15" author="Lefebvre, A." box="[783,963,151,177]" pageId="14" pageNumber="415" pagination="1 - 10" refId="ref26888" refString="Lefebvre, A. (1842) Le genre Ascalaphus Fabr. Guerin-Meneville, 4, 1 - 10. [BotN ref  3666]" type="journal article" year="1842">Lefèbvre (1842)</bibRefCitation>
, with 
<taxonomicName id="3190C390FF94414DFBA327A74FD0FF15" authority="Burmeister, 1839" authorityName="Burmeister" authorityYear="1839" box="[1032,1436,151,177]" class="Insecta" family="Ascalaphidae" genus="Ascalaphus" kingdom="Animalia" order="Neuroptera" pageId="14" pageNumber="415" phylum="Arthropoda" rank="species" species="javana">
<emphasis id="C4E46401FF94414DFBA327A74E9BFF14" box="[1032,1239,151,177]" italics="true" pageId="14" pageNumber="415">Ascalaphus javana</emphasis>
<bibRefCitation id="9201C5E2FF94414DFB7427A74FD0FF15" author="Burmeister, H. C. C." box="[1247,1436,151,177]" pageId="14" pageNumber="415" refId="ref25735" refString="Burmeister, H. C. C. (1839) Handbuch der Entomologie. Zweiter Band. Besondere Entomologie. Zweite Abtheilung. Kaukerfe. Gymnognatha. Zweite Halfte. Vulgo Neuroptera). Theodor Johann Christian Friedrich Enslin, Berlin, xii + 294 pp. [pp. i - xii + 757 - 1050. [BotN ref  1771]" type="book" year="1839">Burmeister, 1839</bibRefCitation>
</taxonomicName>
as the 
<typeStatus id="292B06B1FF94414DFF76278A4B40FF70" box="[221,268,186,212]" pageId="14" pageNumber="415">type</typeStatus>
species, but later recognized as a junior homonym of a bird genus (
<taxonomicName id="3190C390FF94414DFC4127894E69FF77" authorityName="Linnaeus" authorityYear="1758" box="[1002,1061,185,211]" class="Aves" kingdom="Animalia" pageId="14" pageNumber="415" phylum="Chordata" rank="class">Aves</taxonomicName>
), 
<taxonomicName id="3190C390FF94414DFB9327894F6CFF77" authority="Nitzsch, 1833" authorityName="Nitzsch" authorityYear="1833" box="[1080,1312,185,211]" class="Insecta" family="Ascalaphidae" genus="Hybris" higherTaxonomySource="GBIF" kingdom="Animalia" order="Neuroptera" pageId="14" pageNumber="415" phylum="Arthropoda" rank="genus">
<emphasis id="C4E46401FF94414DFB9327894ECEFF77" box="[1080,1154,185,211]" italics="true" pageId="14" pageNumber="415">Hybris</emphasis>
<bibRefCitation id="9201C5E2FF94414DFB2227894F6CFF77" author="Nitzsch, C. L." box="[1161,1312,185,211]" pageId="14" pageNumber="415" refId="ref28102" refString="Nitzsch, C. L. (1833) Pterylographiae avium pars prior. Typis expressum Gebaueriis, Halae, 52 pp. [Notes: Neuropterida related parts: (1) Hybris Nitzsch, 1833, BotN ref  4542: 16, (Aves), a senior homonym of Hybris Lefebvre, 1842, [BotN ref  3666: 7 (Insecta: Neuroptera: Ascalaphidae), BotN ref  4542]" type="book" year="1833">Nitzsch, 1833</bibRefCitation>
</taxonomicName>
by 
<bibRefCitation id="9201C5E2FF94414DFAE227894B06FF52" author="Oswald, J. D. &amp; Penny, N. D." pageId="14" pageNumber="415" pagination="1 - 94" refId="ref28351" refString="Oswald, J. D. &amp; Penny, N. D. (1991) Genus-group names of the Neuroptera, Megaloptera and Raphidioptera of the world. Occasional Papers of the California Academy of Sciences, 147, 1 - 94. [BotN ref  7138] https: // doi. org / 10.5962 / bhl. part. 3428" type="journal article" year="1991">Oswald &amp; Penny (1991)</bibRefCitation>
