<taxonomicName id="3190C390FF97414EFEB220B34835F83F" authority="(Westwood)" baseAuthorityName="Westwood" baseAuthorityYear="1847" box="[281,633,1923,1947]" class="Insecta" family="Ascalaphidae" genus="Glyptobasis" kingdom="Animalia" order="Neuroptera" pageId="13" pageNumber="414" phylum="Arthropoda" rank="species" species="dentifera">
