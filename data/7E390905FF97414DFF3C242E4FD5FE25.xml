<taxonomicName id="3190C390FF94414DFAA527CF4BF5FE9F" authority="(Burmeister, 1839)" baseAuthorityName="Burmeister" baseAuthorityYear="1839" class="Insecta" family="Ascalaphidae" genus="Ascalohybris" kingdom="Animalia" order="Neuroptera" pageId="14" pageNumber="415" phylum="Arthropoda" rank="species" species="javana">
<emphasis id="C4E46401FF94414DFAA527CF4AADFE9F" italics="true" pageId="14" pageNumber="415">Ascalohybris javana</emphasis>
