<taxonomicName id="46224D42191190C464EC924FBC1E988A" authority="Koch" class="Magnoliopsida" family="Asteraceae" genus="Senecio" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="507" phylum="Tracheophyta" rank="species" species="subalpinus">
