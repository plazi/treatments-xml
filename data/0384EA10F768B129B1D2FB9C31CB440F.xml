<bibRefCitation id="EFBC26F7F768B129B39CFB0C31AC464F" author="Sundevall, C. J." box="[729,917,1266,1293]" pageId="29" pageNumber="550" pagination="96 - 111" refId="ref29984" refString="Sundevall, C. J. (1850) Foglar fran sodra Afrika. Ofversigt af Kongliga Vetenskaps-akademiens forhandlingar, 7 (4), 96 - 111." type="journal article" year="1850">Sundevall, 1850</bibRefCitation>
