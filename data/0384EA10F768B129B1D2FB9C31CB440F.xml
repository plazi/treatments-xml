<taxonomicName id="4C2D2085F768B129B322FAE831104673" authority="Sundevall." authorityName="Sundevall." box="[615,809,1303,1329]" class="Aves" family="Zosteropidae" genus="Zosterops" higherTaxonomySource="GBIF" kingdom="Animalia" order="Passeriformes" pageId="29" pageNumber="550" phylum="Chordata" rank="species" species="virens">
