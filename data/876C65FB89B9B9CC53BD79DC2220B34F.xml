<subSubSection id="F00EA2CAB1BF8E32416E080369CA5127" pageId="null" pageNumber="721" type="description">
<paragraph id="8BF1D03C0A64DD4B8B5429B9351D9873" pageId="null" pageNumber="721">
<normalizedToken id="450D4CCE07EF457DA9B023C7A14D427A" originalValue="Sträucher" pageId="null" pageNumber="721">Straeucher</normalizedToken>
mit aufrechten 
<normalizedToken id="E101DFFDABA313CB1F98BA21ECF3F4E1" originalValue="Ästen" pageId="null" pageNumber="721">Aesten</normalizedToken>
. 
<normalizedToken id="D71245FF8E5B668C513D1EABD2FD8472" originalValue="Blätter" pageId="null" pageNumber="721">Blaetter</normalizedToken>
klein, schmal oval oder schmal lanzettlich, 
<normalizedToken id="36E6815BFB3FFCBCFB13D979E20D05A7" originalValue="±" pageId="null" pageNumber="721">+/-</normalizedToken>
flach. 
<normalizedToken id="AED791A59A91913ADFB3625DA76E3FE8" originalValue="Blüten" pageId="null" pageNumber="721">Blueten</normalizedToken>
in 
<normalizedToken id="05FD2130D5DD6BA8D948F9B1F06CD66A" originalValue="endständigen" pageId="null" pageNumber="721">endstaendigen</normalizedToken>
, oft verzweigten Trauben. Kelch- und 
<normalizedToken id="F95B55EB4BE794DE8A884CAD2637419F" originalValue="Kronblätter" pageId="null" pageNumber="721">Kronblaetter</normalizedToken>
meist 5, selten 4. 
<normalizedToken id="2EDB93B24037291FA28FF7CA71A844AE" originalValue="Staubblätter" pageId="null" pageNumber="721">Staubblaetter</normalizedToken>
10, die 
<normalizedToken id="DC04A8CFEF179684061407F0E577E262" originalValue="äußern" pageId="null" pageNumber="721">aeussern</normalizedToken>
<normalizedToken id="D18B8F751460325237DA316F66C8F57B" originalValue="länger" pageId="null" pageNumber="721">laenger</normalizedToken>
als die innern, mit nach innen gewendeten Staubbeuteln, 
<emphasis id="D839A96BC0707427094C92116D2E7869" italics="true" pageId="null" pageNumber="721">
bis 
<normalizedToken id="AEBD1D42CC1E5234F3AA79B5FC6438C2" originalValue="über" pageId="null" pageNumber="721">ueber</normalizedToken>
die Mitte verwachsen.
</emphasis>
Frucht 1 
<normalizedToken id="836AC6A9D996ADF47934E3456B772B05" originalValue="fächerig" pageId="null" pageNumber="721">faecherig</normalizedToken>
, aus 3 
<normalizedToken id="77EFFDE1D55A7D16953AFE00A622D387" originalValue="Fruchtblättern" pageId="null" pageNumber="721">Fruchtblaettern</normalizedToken>
, hoch 
<normalizedToken id="9894545457E15E889101655D96854187" originalValue="pyramidenförmig" pageId="null" pageNumber="721">pyramidenfoermig</normalizedToken>
, mit vielen Samenanlagen; Narben einen sitzenden Kopf bildend (kein Griffel!). Samen nur am Scheitel behaart, 
<emphasis id="B38446BE1D9C97D28ADB6C0A4E85E9D1" italics="true" pageId="null" pageNumber="721">Haarschopf auf einem Stiel.</emphasis>
</paragraph>
<paragraph id="A82ECF9308400B3D9BF22CC5597D4674" pageId="null" pageNumber="721">
Die Gattung 
<taxonomicName id="19CFB671C1A99370D08CEA12580E815E" class="Magnoliopsida" family="Tamaricaceae" genus="Myricaria" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="721" phylum="Tracheophyta" rank="genus">
<emphasis id="EB9873CA25C0557415DFA41CA92897FA" italics="true" pageId="null" pageNumber="721">Myricaria</emphasis>
</taxonomicName>
<normalizedToken id="901C82310E260657D7B7B2286CB65615" originalValue="umfaßt" pageId="null" pageNumber="721">umfasst</normalizedToken>
<emphasis id="00EF00D5F79BD5E147749B7D9D6D3EA5" italics="true" pageId="null" pageNumber="721">10 Arten; Hauptverbreitung in Zentralasien.</emphasis>
</paragraph>
