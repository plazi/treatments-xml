<paragraph id="8BD98973363A1518FF2C9DD2FE42F930" blockId="4.[151,1437,1685,1745]" pageId="4" pageNumber="291">
<emphasis id="B9125561363A1518FF2C9DD2FE89F94C" bold="true" box="[151,276,1685,1709]" pageId="4" pageNumber="291">FIGURE 6.</emphasis>
<taxonomicName id="4C66F2F0363A1518FEA79DD2FDDAF94C" authority="Wu, 1948" authorityName="Wu" authorityYear="1948" box="[284,583,1685,1709]" class="Insecta" family="Perlidae" genus="Claassenia" kingdom="Animalia" order="Plecoptera" pageId="4" pageNumber="291" phylum="Arthropoda" rank="species" species="magna">
