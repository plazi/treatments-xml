<materialsCitation id="EDAC0636FFB8EF7BFEDCFD07FF57FC80" collectionCode="OSF" collectorName="ParNa Iguacu. The &amp; de Janeiro" country="Peru" county="Rio de Janeiro" location="Firstly" municipality="We" pageId="16" pageNumber="17" specimenCount="1" typeStatus="holotype">
<location id="581B5AB0FFB8EF7BFEDCFD07FE16FD74" LSID="urn:lsid:plazi:treatment:D56DBD7DFFB8EF7BFF12FE4BFDF8FCE4:581B5AB0FFB8EF7BFEDCFD07FE16FD74" box="[345,419,690,716]" country="Peru" county="Rio de Janeiro" municipality="We" name="Firstly" pageId="16" pageNumber="17">Firstly</location>
