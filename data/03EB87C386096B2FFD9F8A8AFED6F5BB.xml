<taxonomicName id="4C424D5686096B2FFD988B00FC1FF807" authority="Yoo, 1994" authorityName="Yoo" authorityYear="1994" box="[576,901,1908,1948]" class="Gastropoda" family="Elasmonematidae" genus="Kyndalynia" higherTaxonomySource="GBIF" kingdom="Animalia" order="Vetigastropoda" pageId="27" pageNumber="90" phylum="Mollusca" rank="species" species="inflata" status="n.sp.">
<emphasis id="B936EAC786096B2FFD988B00FC1FF807" box="[576,901,1908,1948]" italics="true" pageId="27" pageNumber="90">Kyndalynia inflata</emphasis>
</taxonomicName>
