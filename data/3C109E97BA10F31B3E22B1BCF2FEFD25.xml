<subSubSection id="CC0B3D82C8705EDAE92215B2106B5713" pageId="null" pageNumber="880" type="description">
<paragraph id="2C5C3C49411F49A24A52E6F8435761BF" pageId="null" pageNumber="880">
Unterscheidet sich von der Gattung 
<taxonomicName id="DBBAF34E457883C712483BFBFDF90778" class="Magnoliopsida" family="Apiaceae" genus="Berula" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="880" phylum="Tracheophyta" rank="genus">
<emphasis id="7E13E1E2549033AEC42F05DAA6777115" italics="true" pageId="null" pageNumber="880">Berula</emphasis>
</taxonomicName>
(S. 879) durch folgende Merkmale: 
<emphasis id="7528C6074D5674698D999A8D90093EB7" italics="true" pageId="null" pageNumber="880">
Dolden 1. Ordnung 
<normalizedToken id="7740AAA366016F5B751B8B3A4296302A" originalValue="endständig" pageId="null" pageNumber="880">endstaendig</normalizedToken>
; 
<normalizedToken id="4C7755D39299F4D736AAD6DB64DA5301" originalValue="Hochblätter" pageId="null" pageNumber="880">Hochblaetter</normalizedToken>
1. Ordnung meist ganzrandig, selten 
<normalizedToken id="E6B7093B63D79D52DA7E67226BFC6941" originalValue="gezähnt" pageId="null" pageNumber="880">gezaehnt</normalizedToken>
; Frucht mit 
<normalizedToken id="A3E9206E94D441312285C3E4F4A703BA" originalValue="großen" pageId="null" pageNumber="880">grossen</normalizedToken>
, stumpfen Hauptrippen.
</emphasis>
</paragraph>
<paragraph id="4CDFBBE51347A152A1B26F9953045B48" pageId="null" pageNumber="880">
Die Gattung 
<emphasis id="4F05510E4B3C6ED7AFB06D9A782D4CA0" italics="true" pageId="null" pageNumber="880">
<taxonomicName id="C1EFAA63E49B7CC972C5093CC4F2FA7B" class="Magnoliopsida" family="Apiaceae" genus="Sium" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="880" phylum="Tracheophyta" rank="genus">Sium</taxonomicName>
<normalizedToken id="052E9CB1EDD4CAA6E8EC12F1C30C8226" originalValue="umfaßt" pageId="null" pageNumber="880">umfasst</normalizedToken>
wenige Arten in Eurasien und Nordamerika;
</emphasis>
in Europa nur 
<emphasis id="262378DBA48D42EE30716EFF0718DECE" italics="true" pageId="null" pageNumber="880">
<taxonomicName id="C8AC0BD3AA337D364FA2FF90AEF49023" class="Magnoliopsida" family="Apiaceae" genus="Laserpitium" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="880" phylum="Tracheophyta" rank="species" species="latifolium">S. latifolium</taxonomicName>
.
</emphasis>
</paragraph>
