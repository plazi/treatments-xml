<subSubSection id="098F0B0049552B19B49FB10697D124DA" pageId="null" pageNumber="627" type="description">
<paragraph id="3CEEBC9A337808BD7DFDEB13CAF32A50" pageId="null" pageNumber="627">
Knollen kugelig oder 
<normalizedToken id="329408CEA018B851B6E7506D0235DFF9" originalValue="eiförmig" pageId="null" pageNumber="627">eifoermig</normalizedToken>
. Stengel 10-40 cm hoch, 
<normalizedToken id="A5B64FD9E506563E31169C61758816ED" originalValue="beblättert" pageId="null" pageNumber="627">beblaettert</normalizedToken>
. Untere 
<normalizedToken id="6D0727071465C1F11CF8145868D942AD" originalValue="Blätter" pageId="null" pageNumber="627">Blaetter</normalizedToken>
schmal oval, etwa in der Mitte am breitesten. 3-8 cm lang, 3-6mal so lang wie breit, 
<emphasis id="592E59D5842C87E7E477B4D795A5B519" italics="true" pageId="null" pageNumber="627">stumpf</emphasis>
, obere den Stengel scheidenartig umfassend, ohne abstehende Spreite. 
<normalizedToken id="D9A19D8D179BD40C7159D30ED8031F7C" originalValue="Blütenstand" pageId="null" pageNumber="627">Bluetenstand</normalizedToken>
5-10 cm lang, zylindrisch, 
<normalizedToken id="B821D53DCFE84211C812CD247DF6978C" originalValue="lockerblütig" pageId="null" pageNumber="627">lockerbluetig</normalizedToken>
. 
<normalizedToken id="5636DE36D6A2A5BD6EF4E158D92BA774" originalValue="Tragblätter" pageId="null" pageNumber="627">Tragblaetter</normalizedToken>
<normalizedToken id="1B57FF5E4978715B512F4A9BDC6A002B" originalValue="häutig" pageId="null" pageNumber="627">haeutig</normalizedToken>
, lanzettlich, so lang oder wenig 
<normalizedToken id="2DB240168C6734BFAC014F4D9F6D3DB1" originalValue="länger" pageId="null" pageNumber="627">laenger</normalizedToken>
als der Fruchtknoten, oft rot oder lila. 
<normalizedToken id="22AE1D7ACC85CB9B1C07052F9CE2CD10" originalValue="Blüten" pageId="null" pageNumber="627">Blueten</normalizedToken>
: Alle 5 
<normalizedToken id="0F984F2CAAE836030F9E2BC05FBF6C1C" originalValue="Perigonblätter" pageId="null" pageNumber="627">Perigonblaetter</normalizedToken>
helmartig zusammenneigend, rot oder lila bis 
<normalizedToken id="46308F0CBC5AC264BAA2A4921E3BEB53" originalValue="weiß" pageId="null" pageNumber="627">weiss</normalizedToken>
, mit dunklen (meist 
<normalizedToken id="13E7A173A7DD24572726BF517206D275" originalValue="grünen" pageId="null" pageNumber="627">gruenen</normalizedToken>
) Nerven; 
<emphasis id="0E162DE83333500225D9C57DF6A5488E" italics="true" pageId="null" pageNumber="627">Lippe breiter als lang</emphasis>
(10-20 mm breit und etwa ⅔ so lang), 
<normalizedToken id="D07D525779EB7601B030F02417F828A2" originalValue="sattelförmig" pageId="null" pageNumber="627">sattelfoermig</normalizedToken>
, rot, lila oder 
<normalizedToken id="96C33D44E09E47FFC59A3812C4567C31" originalValue="weiß" pageId="null" pageNumber="627">weiss</normalizedToken>
, mit dunklen Flecken, bis auf ⅘ 3teilig, Mittelabschnitt oft ausgerandet; alle Abschnitte breit, stumpf, vorn mit 
<normalizedToken id="C4E7858C1371C270EC483F3C06D5AD3D" originalValue="unregelmäßig" pageId="null" pageNumber="627">unregelmaessig</normalizedToken>
geschweiftem Rand; Sporn zylindrisch bis 
<normalizedToken id="45B068A083F214304558E86EC78AA192" originalValue="keulenförmig" pageId="null" pageNumber="627">keulenfoermig</normalizedToken>
, gerade, 
<normalizedToken id="A1AC925067ECE0E0935F107610F6996A" originalValue="±" pageId="null" pageNumber="627">+/-</normalizedToken>
<emphasis id="D44A93982FD60744A9B3425442DB1BC3" italics="true" pageId="null" pageNumber="627">
horizontal oder 
<normalizedToken id="3007B806C8E3490E79E62E2D8C2E72ED" originalValue="aufwärts" pageId="null" pageNumber="627">aufwaerts</normalizedToken>
gerichtet
</emphasis>
, 
<normalizedToken id="15D17B97C3E3ADCD5C502105DEEC3C30" originalValue="kürzer" pageId="null" pageNumber="627">kuerzer</normalizedToken>
als der Fruchtknoten. - 
<normalizedToken id="DF147D40A7783EE83FA6B98151FA558C" originalValue="Blüte" pageId="null" pageNumber="627">Bluete</normalizedToken>
: 
<normalizedToken id="1D156C6B4954C6E022EA9C368E6404F9" originalValue="Später" pageId="null" pageNumber="627">Spaeter</normalizedToken>
<normalizedToken id="3B781A25077C92499C46F84076908CA8" originalValue="Frühling" pageId="null" pageNumber="627">Fruehling</normalizedToken>
und 
<normalizedToken id="A73D88C31FC9CD293691432CAF48801A" originalValue="früher" pageId="null" pageNumber="627">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="D6748F403122FBB11E8BB17213B61628" pageId="null" pageNumber="627">
<emphasis id="F074678F27263986F02396FE669D644A" italics="true" pageId="null" pageNumber="627">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="617049B06E445F0473440991C47AE7A0" italics="true" pageId="null" pageNumber="627">36:</emphasis>
Material von verschiedenen Fundstellen im Norden 
<normalizedToken id="578F073E537CE831BEF7D4F8736200AE" originalValue="Zürichs" pageId="null" pageNumber="627">Zuerichs</normalizedToken>
und aus dem Comerseegebiet; in Meiosen stets n = 18, 2n in Wurzelspitzen nebst 36 auch 35, 37, 65 (Heusser 1938). Material aus 
<normalizedToken id="030075BDE0397D5388F00F58AEAF0EBB" originalValue="Dänemark" pageId="null" pageNumber="627">Daenemark</normalizedToken>
(Hagerup 1938), aus Polen (Skalinska et al. 1957), aus Holland (Kliphuis 1963).
</paragraph>
<paragraph id="75A757EB580E495D5EB8621FF5E2A841" pageId="null" pageNumber="627">
<emphasis id="2A5160D2BB41DE9C25186A42374A05ED" italics="true" pageId="null" pageNumber="627">Standort.</emphasis>
Kollin und montan. 
<normalizedToken id="8EA3DD6556664663817A68E5E854160A" originalValue="Tiefgründige" pageId="null" pageNumber="627">Tiefgruendige</normalizedToken>
, kalkhaltige bis schwach saure, lockere, humose, trockene bis feuchte 
<normalizedToken id="66148BDA7486FC9CC058DBA4BE90D669" originalValue="Böden" pageId="null" pageNumber="627">Boeden</normalizedToken>
. 
<normalizedToken id="7FBF2A1DBE7E047362FE79F445D68312" originalValue="Ungedüngte" pageId="null" pageNumber="627">Ungeduengte</normalizedToken>
Wiesen (besonders Mesobrometen).
</paragraph>
<paragraph id="03D74EFEAFADF79ABE2283740114E059" pageId="null" pageNumber="627">
<emphasis id="90FD33FCCCFFEDBEFA2F41211CB1671E" italics="true" pageId="null" pageNumber="627">
Verbreitung. 
<normalizedToken id="7CD62FCFF9015E3E553219ACFA8C6258" originalValue="Europäische" pageId="null" pageNumber="627">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="CE90C4185490AA33BDCF9F8708FF1D2E" originalValue="Nordwärts" pageId="null" pageNumber="627">Nordwaerts</normalizedToken>
bis England. 
<normalizedToken id="F53F4ACC9930D166BDB48D54677B1937" originalValue="Südskandinavien" pageId="null" pageNumber="627">Suedskandinavien</normalizedToken>
, Baltikum, 
<normalizedToken id="CF398250BF42F0B4315ABBC4D498E4BD" originalValue="ostwärts" pageId="null" pageNumber="627">ostwaerts</normalizedToken>
bis ins Wolga-Don-Gebiet (?); (im Mediterrangebiet und 
<normalizedToken id="52E571500F948D037A24BA2F42AF90FD" originalValue="ostwärts" pageId="null" pageNumber="627">ostwaerts</normalizedToken>
bis ans Schwarze Meer und aus Nordafrika die nah verwandte 
<taxonomicName id="0C975DCA750159D4AF1BD954395EF8CE" authority="Lois" authorityName="Lois" class="Liliopsida" family="Poaceae" genus="Melica" kingdom="Plantae" order="Poales" pageId="null" pageNumber="627" phylum="Tracheophyta" rank="species" species="picta">
<emphasis id="B072DCE1001E1EF9CFDB2612DB8F0033" italics="true" pageId="null" pageNumber="627">O. picta</emphasis>
Lois
</taxonomicName>
, angegeben). Verbreitungskarte von Meusel (1964). - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="32705359142B9D1B2475081A02D4B5AF" originalValue="häufig" pageId="null" pageNumber="627">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
