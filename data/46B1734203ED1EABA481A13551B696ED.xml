Kleine 
<taxonomicName id="83DEAE8D42B90AD37719150A1119EB83" class="Liliopsida" family="Orchidaceae" genus="Orchis" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="627" phylum="Tracheophyta" rank="genus">Orchis</taxonomicName>
