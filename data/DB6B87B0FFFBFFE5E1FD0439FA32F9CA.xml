<paragraph id="537D36A6FFFBFFE5E3B60439FA32F9CA" blockId="3.[151,1437,151,2013]" pageId="3" pageNumber="28">
[TL: c 
<emphasis id="61B6EAB4FFFBFFE5E3E90439FD5DFBBF" box="[723,766,1123,1148]" italics="true" pageId="3" pageNumber="28">irca</emphasis>
‘Guberli’, 
<emphasis id="61B6EAB4FFFBFFE5E2470439FABDFBBE" box="[893,1310,1123,1149]" italics="true" pageId="3" pageNumber="28">promontorium uralensium australium</emphasis>
(Guberlya, Southern Urals, 
<collectingRegion id="9106F844FFFBFFE5E07104DDFDBCFB62" box="[331,543,1159,1185]" country="Russia" name="Orenburg" pageId="3" pageNumber="28">Orenburg Province</collectingRegion>
, 
<collectingCountry id="2BD57636FFFBFFE5E31004DDFCA1FB62" box="[554,770,1158,1185]" name="Russia" pageId="3" pageNumber="28">Russian Federation</collectingCountry>
)] separated from 
<taxonomicName id="94C24D25FFFBFFE5E2F804DDFB95FB62" baseAuthorityName="Denis &amp; Schiffermuller" baseAuthorityYear="1775" box="[962,1078,1159,1185]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="phoebe">
<emphasis id="61B6EAB4FFFBFFE5E2F804DDFB95FB62" box="[962,1078,1159,1185]" italics="true" pageId="3" pageNumber="28">M. phoebe</emphasis>
</taxonomicName>
simultaneously by 
<bibRefCitation id="37534B57FFFBFFE5E43704DDFF40FB06" author="Russell, P. J. C. &amp; Gascoigne-Pees, M. &amp; Pateman, J. E. &amp; Tennent, W. J." pageId="3" pageNumber="28" pagination="263 - 268" refId="ref10748" refString="Russell, P. J. C., Gascoigne-Pees, M., Pateman, J. E. &amp; Tennent, W. J. (2005) Melitaea emipunica (Verity, 1919) stat. nov.: a hitherto unrecognised butterfly species from Europe (Lepidoptera: Nymphalidae). Entomologist's Gazette, 56, 263 - 268." type="journal article" year="2005">
Russell 
<emphasis id="61B6EAB4FFFBFFE5E45F04DDFA3EFB62" box="[1381,1437,1159,1185]" italics="true" pageId="3" pageNumber="28">et al.</emphasis>
(2005)
</bibRefCitation>
, under the name 
<taxonomicName id="94C24D25FFFBFFE5E09804F1FD3CFB06" authority="Verity 1919" authorityName="Verity" authorityYear="1919" box="[418,671,1195,1221]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="emipunica">
<emphasis id="61B6EAB4FFFBFFE5E09804F1FDB7FB07" box="[418,532,1195,1220]" italics="true" pageId="3" pageNumber="28">emipunica</emphasis>
<bibRefCitation id="37534B57FFFBFFE5E32104F1FD3CFB06" author="Verity, R." box="[539,671,1195,1221]" pageId="3" pageNumber="28" pagination="26 - 31" refId="ref11898" refString="Verity, R. (1919) Seasonal Polymorphism and Races of some European Grypocera and Rhopalocera. Entomologist's Record and Journal of Variation 31 (2), 26 - 31, (3), 43 - 48, (5), 87 - 89, (7), 121 - 129, (10), 178 - 184, (11), 193 - 201." type="journal article" year="1919">Verity 1919</bibRefCitation>
</taxonomicName>
, and 
<bibRefCitation id="37534B57FFFBFFE5E3E004F1FC0FFB06" author="Varga, Z. &amp; Szabo, S. &amp; Kozma, P." box="[730,940,1194,1221]" pageId="3" pageNumber="28" pagination="65 - 68" refId="ref11796" refString="Varga, Z., Szabo, S. &amp; Kozma, P. (2005) Melitaea ogygia kovacsi Varga 1967 (Lepidoptera: Nymphalidae) in the Pannonian region: taxonomy, bionomy, conservation biology. In: Kuhn, E., Feldmann, R., Thomas, J. &amp; Settele, J. (Eds.), Studies on the Ecology and Conservation of Butterflies in Europe, 1: general concepts and case studies, pp. 65 - 68. [Conference Proceedings, UFZ Leipzig - Halle, December 2005]" type="proceedings paper" year="2005">
Varga 
<emphasis id="61B6EAB4FFFBFFE5E21B04F1FCF1FB06" box="[801,850,1195,1221]" italics="true" pageId="3" pageNumber="28">et al</emphasis>
. (2005)
</bibRefCitation>
, under the name 
<taxonomicName id="94C24D25FFFBFFE5E55104F1FA23FB06" authority="Fruhstorfer, 1908" authorityName="Fruhstorfer" authorityYear="1908" box="[1131,1408,1195,1221]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="ogygia">
<emphasis id="61B6EAB4FFFBFFE5E55104F1FB15FB07" box="[1131,1206,1195,1220]" italics="true" pageId="3" pageNumber="28">ogygia</emphasis>
<bibRefCitation id="37534B57FFFBFFE5E58704F1FA23FB06" author="Fruhstorfer, H." box="[1213,1408,1195,1221]" pageId="3" pageNumber="28" pagination="310" refId="ref9058" refString="Fruhstorfer, H. (1908) Neue Argynnis und Melitaea. Internationale Entomologische Zeitschrift, 1, 310." type="journal article" year="1908">Fruhstorfer, 1908</bibRefCitation>
</taxonomicName>
. A 
<typeStatus id="8C798804FFFBFFE5E1AD0495FF58FB2A" box="[151,251,1231,1257]" pageId="3" pageNumber="28">lectotype</typeStatus>
(
<figureCitation id="CBF92A23FFFBFFE5E0310495FE04FB2A" box="[267,423,1231,1257]" captionStart="FIGURES 7–11" captionStartId="4.[151,264,1857,1881]" captionTargetBox="[152,1436,560,1833]" captionTargetId="figure-219@4.[151,1436,560,1833]" captionTargetPageId="4" captionText="FIGURES 7–11. 7, Lectotype of Melitaea phoebe sibina Alphéraky, 1881. 8, Melitaea phoebe ab. tatara Krulikovsky, 1891. 9, Lectotype of Melitaea phoebe ornata Christoph, 1893. 10, Lectotype of Melitaea phoebe uralensis Krulikovsky, 1897 (= ufensis Krulikovsky 1902). 11, Lectotype of Melitaea phoebe var. tungusa Herz, 1899. Figs 7, 9, 11 © V.A. Lukhtanov. Figs 8, 10 © expired. A = upperside, B = underside, C = labels on specimen pin." figureDoi="http://doi.org/10.5281/zenodo.6577635" httpUri="https://zenodo.org/record/6577635/files/figure.png" pageId="3" pageNumber="28">Figs 9A, B, C</figureCitation>
) selected by Lvovsky (Anikin 
<emphasis id="61B6EAB4FFFBFFE5E3C50495FC8CFB2A" box="[767,815,1231,1257]" italics="true" pageId="3" pageNumber="28">et al</emphasis>
. 2017: 521) demonstrates clearly the wing and antennal characteristics of 
<taxonomicName id="94C24D25FFFBFFE5E06104A9FE68FACF" authorityName="Christoph" authorityYear="1893" box="[347,459,1267,1292]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="ornata">
<emphasis id="61B6EAB4FFFBFFE5E06104A9FE68FACF" box="[347,459,1267,1292]" italics="true" pageId="3" pageNumber="28">M. ornata</emphasis>
</taxonomicName>
. Unfortunately 
<bibRefCitation id="37534B57FFFBFFE5E34604A9FBA4FACD" author="Van Oorschot, H. &amp; Coutsis, J. G." box="[636,1031,1267,1294]" pageId="3" pageNumber="28" refId="ref11693" refString="Van Oorschot, H. &amp; Coutsis, J. G. (2014) The genus Melitaea Fabricius, 1807 (Lepidoptera, Nymphalidae, Nymphalinae) Taxonomy and systematics with special reference to the male genitalia. Tshikolovets publications, Pardubice, Czech Republic, 360 pp." type="book" year="2014">van Oorschot &amp; Coutsis (2014: 60)</bibRefCitation>
referred to ‘ 
<specimenCount id="45C4FD2FFFFBFFE5E5AB04A9FB5FFACE" box="[1169,1276,1267,1293]" pageId="3" pageNumber="28" type="male">two male</specimenCount>
syntypes’ and placed the taxon 
<taxonomicName id="94C24D25FFFBFFE5E074054DFE34FAF3" authorityName="Christoph" authorityYear="1893" box="[334,407,1303,1328]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="ornata">
<emphasis id="61B6EAB4FFFBFFE5E074054DFE34FAF3" box="[334,407,1303,1328]" italics="true" pageId="3" pageNumber="28">ornata</emphasis>
</taxonomicName>
as a subspecies of 
<taxonomicName id="94C24D25FFFBFFE5E35E054DFD75FAF2" baseAuthorityName="Denis &amp; Schiffermuller" baseAuthorityYear="1775" box="[612,726,1303,1329]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="phoebe">
<emphasis id="61B6EAB4FFFBFFE5E35E054DFD75FAF2" box="[612,726,1303,1329]" italics="true" pageId="3" pageNumber="28">M. phoebe</emphasis>
</taxonomicName>
. Their figures (Plate 13, figs 2 &amp; 3), purporting to be ‘ 
<specimenCount id="45C4FD2FFFFBFFE5E424054DFA95FAF2" box="[1310,1334,1303,1329]" pageId="3" pageNumber="28" type="male">♂</specimenCount>
<typeStatus id="8C798804FFFBFFE5E406054DFA3FFAF2" box="[1340,1436,1303,1329]" pageId="3" pageNumber="28">syntypes</typeStatus>
from Zoologisches Museum der Humboldt Universität, Berlin’ are clearly females; all the figured specimens show the characters typical of 
<taxonomicName id="94C24D25FFFBFFE5E0880505FD80FABB" authorityName="Christoph" authorityYear="1893" box="[434,547,1375,1400]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="ornata">
<emphasis id="61B6EAB4FFFBFFE5E0880505FD80FABB" box="[434,547,1375,1400]" italics="true" pageId="3" pageNumber="28">M. ornata</emphasis>
</taxonomicName>
. Most authors now accept this taxon to be a species distinct from 
<taxonomicName id="94C24D25FFFBFFE5E41F0505FA3FFABA" baseAuthorityName="Denis &amp; Schiffermuller" baseAuthorityYear="1775" box="[1317,1436,1375,1401]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="phoebe">
<emphasis id="61B6EAB4FFFBFFE5E41F0505FA3FFABA" box="[1317,1436,1375,1401]" italics="true" pageId="3" pageNumber="28">M. phoebe</emphasis>
</taxonomicName>
(
<bibRefCitation id="37534B57FFFBFFE5E1A405D9FE05FA5E" author="Tshikolovets, V. V." box="[158,422,1411,1437]" pageId="3" pageNumber="28" refId="ref11624" refString="Tshikolovets, V. V. (2011) Butterflies of Europe &amp; the Mediterranean area. Tshikolovets Publications, Pardubice, Czech Republic, 544 pp." type="book" year="2011">Tshikolovets 2011: 498</bibRefCitation>
; 
<bibRefCitation id="37534B57FFFBFFE5E08905D9FD45FA5D" author="Lafranchis, T. &amp; Jutzeler, D. &amp; Guillosson, J-Y. &amp; Kan, P. &amp; Kan, B." box="[435,742,1410,1438]" pageId="3" pageNumber="28" refId="ref10054" refString="Lafranchis, T., Jutzeler, D., Guillosson, J-Y., Kan, P. &amp; Kan, B. (2015) La Vie des Papillons, Ecologie, Biologie et Comportement des Rhopaloceres de France. Diatheo, Paris, 751 pp." type="book" year="2015">
Lafranchis 
<emphasis id="61B6EAB4FFFBFFE5E30B05D9FDC1FA5E" box="[561,610,1411,1437]" italics="true" pageId="3" pageNumber="28">et al</emphasis>
. 2015: 468
</bibRefCitation>
). Some authors have used different names for the species (see 
<bibRefCitation id="37534B57FFFBFFE5E1AD05FDFE00FA01" author="Russell, PJ &amp; Tennent, W. J." box="[151,419,1447,1474]" pageId="3" pageNumber="28" pagination="27 - 56" refId="ref10922" refString="Russell, PJ. C. &amp; Tennent, W. J. (2016) A synonymic list of names associated with western Palaearctic Melitaea phoebe (Denis &amp; Schiffermuller, 1775) species group taxa M. phoebe; M. punica Oberthur, 1876; M. ornata Christoph, 1893) (Lepidoptera, Nymphalidae). Nota Lepidopterologica, 39 (1), 27 - 56. https: // doi. org / 10.3897 / nl. 39.5929" type="journal article" year="2016">Russell &amp; Tennent 2016</bibRefCitation>
), whilst others continue to consider all 
<taxonomicName id="94C24D25FFFBFFE5E27105FDFC1DFA02" baseAuthorityName="Denis &amp; Schiffermuller" baseAuthorityYear="1775" box="[843,958,1447,1473]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="phoebe">
<emphasis id="61B6EAB4FFFBFFE5E27105FDFC1DFA02" box="[843,958,1447,1473]" italics="true" pageId="3" pageNumber="28">M. phoebe</emphasis>
</taxonomicName>
group taxa to be conspecific (
<bibRefCitation id="37534B57FFFBFFE5E43F05FDFEA9FA26" author="Kudrna, O. &amp; Pennstorfer, J &amp; Lux, K." pageId="3" pageNumber="28" refId="ref10020" refString="Kudrna, O., Pennstorfer, J &amp; Lux, K. (2015) Distribution Atlas of European Butterflies and Skippers. Wissenschsftlicher PEKS, Schwanfeld, Germany, 632 pp." type="book" year="2015">
Kudrna 
<emphasis id="61B6EAB4FFFBFFE5E46505FDFA2DFA02" box="[1375,1422,1447,1473]" italics="true" pageId="3" pageNumber="28">et al</emphasis>
., 2015: 379
</bibRefCitation>
). However, a large set of molecular and morphological data unequivocally indicate that 
<taxonomicName id="94C24D25FFFBFFE5E5E30591FAE4FA27" authorityName="Christoph" authorityYear="1893" box="[1241,1351,1483,1508]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="ornata">
<emphasis id="61B6EAB4FFFBFFE5E5E30591FAE4FA27" box="[1241,1351,1483,1508]" italics="true" pageId="3" pageNumber="28">M. ornata</emphasis>
</taxonomicName>
and 
<taxonomicName id="94C24D25FFFBFFE5E4440591FF45F9CA" baseAuthorityName="Denis &amp; Schiffermuller" baseAuthorityYear="1775" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="28" phylum="Arthropoda" rank="species" species="phoebe">
<emphasis id="61B6EAB4FFFBFFE5E4440591FF45F9CA" italics="true" pageId="3" pageNumber="28">M. phoebe</emphasis>
</taxonomicName>
are different species, which are found sympatrically in a number of localities (
<bibRefCitation id="37534B57FFFBFFE5E57B05B5FB59F9CA" author="Toth, J. P. &amp; Bereczki, J. &amp; Varga, Z. &amp; Rota, J. &amp; Sramko, G. &amp; Wahlberg, N." box="[1089,1274,1519,1545]" pageId="3" pageNumber="28" pagination="749 - 757" refId="ref11329" refString="Toth, J. P., Bereczki, J., Varga, Z., Rota, J., Sramko, G. &amp; Wahlberg, N. (2014) Relationships within the Melitaea phoebe species group (Lepidoptera: Nymphalidae): new insights from molecular and morphometric information. Systematic Entomology, 39, 749 - 757. https: // doi. org / 10.1111 / syen. 12083" type="journal article" year="2014">
Tóth 
<emphasis id="61B6EAB4FFFBFFE5E54705B5FB17F9CA" box="[1149,1204,1519,1545]" italics="true" pageId="3" pageNumber="28">et al.</emphasis>
, 2014
</bibRefCitation>
, 
<bibRefCitation id="37534B57FFFBFFE5E43F05B5FA9DF9CA" author="Toth, J. P. &amp; Varga, Z. &amp; Bereczki, J." box="[1285,1342,1519,1545]" pageId="3" pageNumber="28" pagination="106 - 115" refId="ref11405" refString="Toth, J. P., Varga, Z. &amp; Bereczki, J. (2016) Long-term survival and diversification of an endemic Melitaea species in mountains of Iran and adjacent areas. Journal of Zoological Systematics and Evolutionary Research, 54 (2), 106 - 115. https: // doi. org / 10.1111 / jzs. 12122" type="journal article" year="2016">2016</bibRefCitation>
, 
