<taxonomicName id="3A9D48BFD1CA148246DFCC1814272CA5" authority="De la Soie" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="394" phylum="Tracheophyta" rank="species" species="alpicola">
