<taxonomicName id="4C054F89D715FFDF80C6FD3888BF5D89" baseAuthorityName="Linnaeus" baseAuthorityYear="1758" box="[458,677,724,750]" class="Insecta" family="Ichneumonidae" genus="Rhyssa" kingdom="Animalia" order="Hymenoptera" pageId="3" pageNumber="30" phylum="Arthropoda" rank="species" species="persuasoria">
<emphasis id="B971E818D715FFDF80C6FD3888BF5D89" box="[458,677,724,750]" italics="true" pageId="3" pageNumber="30">Rhyssa persuasoria</emphasis>
</taxonomicName>
.
</paragraph>
