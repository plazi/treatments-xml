<subSubSection id="3AE5EDC18AD54B13AF83D83107F3F25A" pageId="null" pageNumber="108" type="description">
<paragraph id="F11E4B5DF0EEC840249EAE0626573961" pageId="null" pageNumber="108">
Blattstiel 2-7 cm lang, 
<emphasis id="6874AA60961B174132CF3B7049A668F2" italics="true" pageId="null" pageNumber="108">
mit 
<normalizedToken id="B62CF5F95F0E4B7C0DBD561E6673B6F7" originalValue="groβen" pageId="null" pageNumber="108">groβen</normalizedToken>
, hell- bis dunkelbraunen Spreuschuppen
</emphasis>
; Blattspreite im 
<normalizedToken id="08B9BBB03CCC0A5D95938DAE08F9933A" originalValue="Umriß" pageId="null" pageNumber="108">Umriss</normalizedToken>
<emphasis id="5FACAB5A1C66BBDC72B7B542DF168291" italics="true" pageId="null" pageNumber="108">schmal lanzettlich</emphasis>
, bis 50 cm lang, 
<emphasis id="21D6CC95ACD07B2EF49C89993F8A09D5" italics="true" pageId="null" pageNumber="108">8 -10mal so lang wie breit</emphasis>
, kurz zugespitzt, 
<emphasis id="9D401D2B67872EF28FFABB0CECE110EC" italics="true" pageId="null" pageNumber="108">
nach dem Grunde 
<normalizedToken id="87DF96066601242D57E95146039E1E96" originalValue="allmählich" pageId="null" pageNumber="108">allmaehlich</normalizedToken>
<normalizedToken id="CB35E68A132AC3E3F4C194B39C818DA2" originalValue="verschmälert" pageId="null" pageNumber="108">verschmaelert</normalizedToken>
</emphasis>
(bis auf 2 cm Breite), derb lederig, starr, 
<normalizedToken id="40429085B55D7F276AAD67E42D0364CD" originalValue="dunkelgrün" pageId="null" pageNumber="108">dunkelgruen</normalizedToken>
, 
<normalizedToken id="8478710E2295D9E9795341721960CA77" originalValue="grün" pageId="null" pageNumber="108">gruen</normalizedToken>
<normalizedToken id="BB942CF5ADD790E47D0AC5183CCA25D7" originalValue="überwinternd" pageId="null" pageNumber="108">ueberwinternd</normalizedToken>
, oberseits 
<normalizedToken id="E58569B0820B33648174511365A4DF71" originalValue="glänzend" pageId="null" pageNumber="108">glaenzend</normalizedToken>
, unterseits mit hellbraunen, haarartigen Spreuschuppen besetzt, 
<emphasis id="6ADA35D72BB42DD7A47CB2FBE4D35AF1" italics="true" pageId="null" pageNumber="108">1fach gefiedert;</emphasis>
Fiedern sich fast 
<normalizedToken id="A546869F085A2E5F000D9DA3588C34A8" originalValue="berührend" pageId="null" pageNumber="108">beruehrend</normalizedToken>
, kurz gestielt, die untern kurz 3eckig und an der Basis beiderseits mit 
<normalizedToken id="754539EDAF7F00C80FFB67BDCC300553" originalValue="vergrößertem" pageId="null" pageNumber="108">vergroessertem</normalizedToken>
Zahn, die mittleren und obern lanzettlich, bis 1 cm breit, 
<normalizedToken id="68EB9EED2E797BA8F10311412015EEE7" originalValue="sichelförmig" pageId="null" pageNumber="108">sichelfoermig</normalizedToken>
<normalizedToken id="9361213E1D91DC8AE4CC8BE76D57FD8C" originalValue="vorwärts" pageId="null" pageNumber="108">vorwaerts</normalizedToken>
gebogen, an der Basis nur noch am vorderen Rande mit spitzem, 
<normalizedToken id="F7B0552B2A37FD633E4BC91AC2FEF804" originalValue="vergrößertem" pageId="null" pageNumber="108">vergroessertem</normalizedToken>
Zahn, oft alle 
<emphasis id="54BA4D7EAF2F21B4390C1E4B2B2C9320" italics="true" pageId="null" pageNumber="108">
doppelt 
<normalizedToken id="33A0D5E15904B6224526268360151C08" originalValue="gezähnt" pageId="null" pageNumber="108">gezaehnt</normalizedToken>
;
</emphasis>
<normalizedToken id="54EEE6DEA235415A00EB668EF9E19571" originalValue="große" pageId="null" pageNumber="108">grosse</normalizedToken>
<normalizedToken id="FC3F6AF027C9F188709A9F3827E2F413" originalValue="Zähne" pageId="null" pageNumber="108">Zaehne</normalizedToken>
mit 
<emphasis id="253F363A745FA5CE039DE75B38A09EE4" italics="true" pageId="null" pageNumber="108">Grannenspitzen</emphasis>
und dazwischen kleineren Stachelspitzen, Sori in 2 Reihen auf jeder Fieder, 
<normalizedToken id="6036E4D1E4D50F659E1F5DC64DA29805" originalValue="groß" pageId="null" pageNumber="108">gross</normalizedToken>
, im Durchmesser etwa 1,5 mm, oft einander 
<normalizedToken id="EF8D2DB0B71D8A632D00813A9914BB4F" originalValue="berührend" pageId="null" pageNumber="108">beruehrend</normalizedToken>
. - Sporenreife: 
<normalizedToken id="C2E71AC128E19A5B4179030A6C934FF3" originalValue="Spätsommer" pageId="null" pageNumber="108">Spaetsommer</normalizedToken>
und Herbst.
</paragraph>
<paragraph id="17CD8098C9038B36D0F0370931C5C2A9" pageId="null" pageNumber="108">
<emphasis id="DAFF02C6C425930F7CCC19E41E99BE50" italics="true" pageId="null" pageNumber="108">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="60EFEBE101C2F5F6B5564518183D0100" italics="true" pageId="null" pageNumber="108">82:</emphasis>
Material aus der Schweiz, Schottland und Irland (Manton 1950), aus Island (
<normalizedToken id="AEF322A45C8018CDA1E40E06C1333BED" originalValue="Löve" pageId="null" pageNumber="108">Loeve</normalizedToken>
und 
<normalizedToken id="5A378FD31DC424B8F7E97BF1201004AE" originalValue="Löve" pageId="null" pageNumber="108">Loeve</normalizedToken>
1961a), aus Kanada (Britton 1964), aus den USA (Washington) (
<normalizedToken id="F4795AAE29BAD8C2D1ABB6E4A5C95EAB" originalValue="Löve" pageId="null" pageNumber="108">Loeve</normalizedToken>
und Solbrig 1964), aus Ungarn (Vida 1966).
</paragraph>
<paragraph id="1A127C34F64D6BC724A20FB89BABABDA" pageId="null" pageNumber="108">
<emphasis id="77ED4B7A7CCFECACAEDDC7D12A47E402" italics="true" pageId="null" pageNumber="108">Standort.</emphasis>
Montan und subalpin, seltener alpin. Besonders auf kalkhaltiger, seltener auf kalkfreier Unterlage; in schattigen Lagen mit lange dauernder Schneebedeckung. 
<normalizedToken id="8B52CFD0D33B637F11E34D3A3C02CA36" originalValue="Blockschuttwälder" pageId="null" pageNumber="108">Blockschuttwaelder</normalizedToken>
, Schutthalden, 
<normalizedToken id="70B4D782FF5E121558E7B63A7712783C" originalValue="Felsblöcke" pageId="null" pageNumber="108">Felsbloecke</normalizedToken>
, seltener an Felsen.
</paragraph>
<paragraph id="D1EC0C67E35497255753E5956C0A0005" pageId="null" pageNumber="108">
<emphasis id="E789819CD81A631023FAE702DF4F1381" italics="true" pageId="null" pageNumber="108">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
Nordgrenze durch Island, Nordskandinavien, 
<normalizedToken id="8C1E7FFEA82AE1C87471C191C50A9B62" originalValue="Nordrußland" pageId="null" pageNumber="108">Nordrussland</normalizedToken>
; 
<normalizedToken id="93C2A963215DF97FC35F340C207CE59F" originalValue="Südgrenze" pageId="null" pageNumber="108">Suedgrenze</normalizedToken>
durch Sierra Nevada, Sizilien, Kleinasien, Kaukasus; zentralasiatische Gebirge; isolierte Fundstellen in 
<normalizedToken id="F513E49362920226FBD58D9178C19CCC" originalValue="Südsibirien" pageId="null" pageNumber="108">Suedsibirien</normalizedToken>
und Ostasien; Nordamerika (zerstreut zwischen 35 und 60° NB); 
<normalizedToken id="D48DE67D5EC925D2DAEA1ADFFE620997" originalValue="Grönland" pageId="null" pageNumber="108">Groenland</normalizedToken>
. Verbreitungskarten von 
<normalizedToken id="2DF29738CCB42E91582C6F2ECE5B37FA" originalValue="Hultén" pageId="null" pageNumber="108">Hulten</normalizedToken>
(1958) und Meusel (1964). - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="AB1A03C2DEFC22532CB42574F85479F5" originalValue="häufig" pageId="null" pageNumber="108">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
