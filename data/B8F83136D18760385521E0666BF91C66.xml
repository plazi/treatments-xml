<subSubSection id="F0396BCE11121219E7B7DEB85F198953" pageId="null" pageNumber="620" type="description">
<paragraph id="680AA0E46C5E442DE649979675B86F5A" pageId="null" pageNumber="620">
Die beiden seitlichen, 
<normalizedToken id="FD324EDF95DEF0449EE8C36C4FB8819A" originalValue="äußern" pageId="null" pageNumber="620">aeussern</normalizedToken>
<normalizedToken id="9F10A55D06047534E6245BF2EAE79696" originalValue="Perigonblätter" pageId="null" pageNumber="620">Perigonblaetter</normalizedToken>
etwa doppelt so lang wie breit; 
<emphasis id="D5A69B36B56A38B783F117440D973325" italics="true" pageId="null" pageNumber="620">
<normalizedToken id="116EFF2E07CD923CF69F818E2D82A472" originalValue="Fächer" pageId="null" pageNumber="620">Faecher</normalizedToken>
der Staubbeutel nach unten spreizend, kleinster Zwischenraum zwischen den 
<normalizedToken id="86A6E93CC2F43F7F2B487F2916C4FC5D" originalValue="Fächern" pageId="null" pageNumber="620">Faechern</normalizedToken>
2-3 mm; 
<taxonomicName id="F9C691CD683A6C1F01E6F0C81B4F1A83" class="Liliopsida" family="Orchidaceae" genus="Sporn" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="620" phylum="Tracheophyta" rank="species" species="gegen">Sporn gegen</taxonomicName>
die Spitze hin deutlich verdickt, 
<normalizedToken id="2E031E9FA4B389A132B0215E84712489" originalValue="keulenförmig" pageId="null" pageNumber="620">keulenfoermig</normalizedToken>
, stumpf.
</emphasis>
- 
<normalizedToken id="1A10871C5127B19891751BD6D945D075" originalValue="Blüte" pageId="null" pageNumber="620">Bluete</normalizedToken>
: 
<normalizedToken id="A27D4C55A8610FD4BB0F04C74E29AC2B" originalValue="Später" pageId="null" pageNumber="620">Spaeter</normalizedToken>
<normalizedToken id="5C6862FDEF80DEE1F02A1AC05A931D63" originalValue="Frühling" pageId="null" pageNumber="620">Fruehling</normalizedToken>
und 
<normalizedToken id="C6665807C956D5333FF70DD203DC2D9F" originalValue="früher" pageId="null" pageNumber="620">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="78C96ACED3017DC42C87F578E4EA55FF" pageId="null" pageNumber="620">
<emphasis id="09B911DCF538DAFEA1E24A045BB66700" italics="true" pageId="null" pageNumber="620">Zytologische Angaben. 2n = 42:</emphasis>
Material aus 
<normalizedToken id="C4BE21C70B15DF3F7024ED208F2A5876" originalValue="Südschweden" pageId="null" pageNumber="620">Suedschweden</normalizedToken>
; Embryosackentwicklung normal (Afzelius 1922), aus England (Richardson 1934), aus dem Norden des Kantons 
<normalizedToken id="E0A897AD1C3FBA5478217B2C30D44654" originalValue="Zürich" pageId="null" pageNumber="620">Zuerich</normalizedToken>
(Heusser 1938), aus Skandinavien (mit apomiktischer Fortpflanzung) (Hagerup 1947), aus Polen (Skalinska et al. 1957), aus Holland (Kliphuis 1963).
</paragraph>
<paragraph id="9209DB426DC3B7A26160D568F75A1F1B" pageId="null" pageNumber="620">
<emphasis id="339826951A0B6CF9FF80133BCFC790F3" italics="true" pageId="null" pageNumber="620">
<pageBreakToken id="C13BA3DBB5AD4635843ACF19ACF992D4" pageId="null" pageNumber="620">Standort</pageBreakToken>
.
</emphasis>
Kollin und montan, seltener subalpin. Kalkhaltige, feuchte bis nasse 
<normalizedToken id="0D94BBF2C4130E223AA211BBADEE7F3B" originalValue="Böden" pageId="null" pageNumber="620">Boeden</normalizedToken>
. Schattige Waldwiesen, lichte 
<normalizedToken id="6D41027F642AF162CF64F4C20C9D1651" originalValue="Laubwälder" pageId="null" pageNumber="620">Laubwaelder</normalizedToken>
, Quellfluren, Flachmoore.
</paragraph>
<paragraph id="0E3826BAAAA29C37190973EFE8A2E585" pageId="null" pageNumber="620">
<emphasis id="D4E7525B946B8065EA8DCA8789EE82FD" italics="true" pageId="null" pageNumber="620">
Verbreitung. 
<normalizedToken id="64086A40596E04ABB9D828932937C35B" originalValue="Europäische" pageId="null" pageNumber="620">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="E74CB6AF2CBE5B78CAD78212A4ED90BD" originalValue="Nordwärts" pageId="null" pageNumber="620">Nordwaerts</normalizedToken>
bis Schottland, Mittelskandinavien, Baltikum, 
<normalizedToken id="5445935A24BB02CD1F49B846CAD251F7" originalValue="Mittelrußland" pageId="null" pageNumber="620">Mittelrussland</normalizedToken>
; 
<normalizedToken id="184BE9841ADB7B8DA28863B30797E16B" originalValue="südwärts" pageId="null" pageNumber="620">suedwaerts</normalizedToken>
bis 
<normalizedToken id="952960E8D01B9A9CE7D3138E5F0EEB02" originalValue="Südeuropa" pageId="null" pageNumber="620">Suedeuropa</normalizedToken>
, Kleinasien, Kaukasus. Die sibirischen und ostasiatischen Pflanzen werden in der Flora URRS als eigene Arten abgetrennt. - Im Gebiet verbreitet, nicht 
<normalizedToken id="61DA6648884DF28758EBED9288D4291D" originalValue="häufig" pageId="null" pageNumber="620">haeufig</normalizedToken>
(seltener als 
<taxonomicName id="FFA560C19BBD38A8E205378CEE7E6099" authority="Nr." authorityName="Nr." class="Liliopsida" family="Orchidaceae" genus="Platanthera" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="620" phylum="Tracheophyta" rank="species" species="bifolia">
<emphasis id="9759B14C33EA34F6FF657A1711BF2C26" italics="true" pageId="null" pageNumber="620">P. bifolia</emphasis>
, Nr.
</taxonomicName>
1).
</paragraph>
</subSubSection>
