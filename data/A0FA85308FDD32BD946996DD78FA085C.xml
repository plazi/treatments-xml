<subSubSection id="D3DB5732C7A50B0E290A66BD049BFE5B" pageId="null" pageNumber="759" type="description">
<paragraph id="29D307584134D7063098C458A3FFB265" pageId="null" pageNumber="759">
Unterscheidet sich durch folgende Merkmale von 
<taxonomicName id="ED4118257E18BBE814860F5BB841C470" class="Magnoliopsida" family="Lythraceae" genus="Lythrum" kingdom="Plantae" order="Myrtales" pageId="null" pageNumber="759" phylum="Tracheophyta" rank="species" species="salicaria">
<emphasis id="609391479CAAA56AEFE6AE1802CBEE08" italics="true" pageId="null" pageNumber="759">
<authorityName id="446F6C1A5B82FE71A352EE620918BED2" pageId="null" pageNumber="759">L.</authorityName>
Salicaria
</emphasis>
</taxonomicName>
(Nr. 1): 
<emphasis id="77F592857D11D31E32F8467D06EDD000" italics="true" pageId="null" pageNumber="759">
Pflanze 
<normalizedToken id="2A48FE0227B716D579F1DDD0C86BACE4" originalValue="vollständig" pageId="null" pageNumber="759">vollstaendig</normalizedToken>
kahl;
</emphasis>
<normalizedToken id="39349578595072A663670400B8826A39" originalValue="Blätter" pageId="null" pageNumber="759">Blaetter</normalizedToken>
meist sehr schmal lanzettlich, 6-20mal so lang wie breit, 
<emphasis id="2C2FDAD1AA665CCBA16593A2A9ADC5FC" italics="true" pageId="null" pageNumber="759">
gegen den Grund hin 
<normalizedToken id="360EF3602A9ADE3648441B9A000451D5" originalValue="allmählich" pageId="null" pageNumber="759">allmaehlich</normalizedToken>
<normalizedToken id="CB27188914E15759CD1510C5ED0E9A7A" originalValue="verschmälert" pageId="null" pageNumber="759">verschmaelert</normalizedToken>
</emphasis>
, meist alle bis hinauf zum 
<normalizedToken id="A4BE083B77A4C99CA47E37A85EE27686" originalValue="Blütenstand" pageId="null" pageNumber="759">Bluetenstand</normalizedToken>
<normalizedToken id="7DEB9F31B1F9A72F26E8EC231D6BA7A5" originalValue="gegenständig" pageId="null" pageNumber="759">gegenstaendig</normalizedToken>
; die meisten 
<normalizedToken id="7169610AD467EF376DF4EB6E51FDC128" originalValue="Blüten" pageId="null" pageNumber="759">Blueten</normalizedToken>
mit 2-4 mm langen Stielen; 
<emphasis id="A2F154AA88F568769691CAE25E84D745" italics="true" pageId="null" pageNumber="759">
Kelchrippen kahl; 
<normalizedToken id="CA064578238120EF323A54477AEBD2A4" originalValue="Zwischenzähne" pageId="null" pageNumber="759">Zwischenzaehne</normalizedToken>
etwa so lang wie die 
<normalizedToken id="476E2C68E091F52EB91596BC08996408" originalValue="Kelchzähne" pageId="null" pageNumber="759">Kelchzaehne</normalizedToken>
;
</emphasis>
<normalizedToken id="A9B03DE82622C62D7E1C996AED187C16" originalValue="Kronblätter" pageId="null" pageNumber="759">Kronblaetter</normalizedToken>
6-10 mm lang. - 
<normalizedToken id="E845DC15CF1F3105FD7D43848E49DBA9" originalValue="Blüte" pageId="null" pageNumber="759">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="287576E627910FDD5CCA3B663BB2C92E" pageId="null" pageNumber="759">
<emphasis id="91EC361344ACC7C39BC434C3E9D037DB" italics="true" pageId="null" pageNumber="759">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="949422FED1436B7243BD642F2573B5E6" italics="true" pageId="null" pageNumber="759">30:</emphasis>
Material aus botanischem Garten (La Cour aus Darlington und Wylie 1955).
</paragraph>
<paragraph id="04436AE13C4D07245AF294850E9646F5" pageId="null" pageNumber="759">
<emphasis id="9A323BF37489FDED004FA8E0FB36E86D" italics="true" pageId="null" pageNumber="759">Standort.</emphasis>
Wie 
<taxonomicName id="BF67B266016A3D4B5B742C441C12DD66" class="Magnoliopsida" family="Lythraceae" genus="Lythrum" kingdom="Plantae" order="Myrtales" pageId="null" pageNumber="759" phylum="Tracheophyta" rank="species" species="salicaria">
<emphasis id="FE7D445A56CC2FE77C07EE131E66085C" italics="true" pageId="null" pageNumber="759">
<authorityName id="1E6E1E26B62FC4A95A9990F74EFF88ED" pageId="null" pageNumber="759">L.</authorityName>
Salicaria
</emphasis>
</taxonomicName>
(Nr. 1), zudem in 
<normalizedToken id="B34DEAA1CD6593A36C9D5FE6343E8C32" originalValue="Auenwäldern" pageId="null" pageNumber="759">Auenwaeldern</normalizedToken>
.
</paragraph>
<paragraph id="E51E954B880626732456B34AEDE9BE90" pageId="null" pageNumber="759">
<emphasis id="482EAE6E3601AE2044A9AE9FEADD160A" italics="true" pageId="null" pageNumber="759">
Verbreitung. 
<normalizedToken id="E5983BA63F2BFC95282F24EFAE09BC60" originalValue="Osteuropäisch-asiatische" pageId="null" pageNumber="759">Osteuropaeisch-asiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="FDE7E96C18A06C32FA0D00FB6D31B8A3" originalValue="Westwärts" pageId="null" pageNumber="759">Westwaerts</normalizedToken>
bis in die Lombardei; 
<normalizedToken id="A2F3C48416517C2B6659A41F4D7B97F6" originalValue="nordwärts" pageId="null" pageNumber="759">nordwaerts</normalizedToken>
bis 
<normalizedToken id="0170DC7600224C9B77154D16E2B2BDA0" originalValue="Oberösterreich" pageId="null" pageNumber="759">Oberoesterreich</normalizedToken>
, 
<normalizedToken id="15CE726E075CD1832A13BE3C5FC332BB" originalValue="Böhmen" pageId="null" pageNumber="759">Boehmen</normalizedToken>
, Litauen, in Sibirien bis 56° NB; 
<normalizedToken id="935DA229D66D882ECB41090097F2C611" originalValue="ostwärts" pageId="null" pageNumber="759">ostwaerts</normalizedToken>
bis zum Baikalsee; 
<normalizedToken id="F7D7C4CFFA2DB69A462F9A8E89A90CF7" originalValue="südwärts" pageId="null" pageNumber="759">suedwaerts</normalizedToken>
bis Montenegro, Thessalien, Kleinasien (Erzurum), Kaukasus, Karakul, Dsungarei. - Im Gebiet: Comersee (Val Intelvi, Belaggio), Veltlin (Val Malenco).
</paragraph>
</subSubSection>
