<quantity id="036C9B1BFFC36A7CFC9592081DD0BF40" box="[873,976,1105,1138]" metricMagnitude="3" metricUnit="m" metricValue="1.5" pageId="56" pageNumber="814" unit="m" value="1500.0">1500 m</quantity>
.
</paragraph>
</subSubSection>
