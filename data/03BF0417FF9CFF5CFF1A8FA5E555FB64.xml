<emphasis id="B9626913FF9CFF5CFE148C76E52CFCFC" box="[409,614,835,861]" italics="true" pageId="77" pageNumber="78">Minitiron bellairsi</emphasis>
(
<bibRefCitation id="EF87C8F0FF9CFF5CFDF98C71E5ADFCFC" author="Just, J." box="[628,743,835,861]" pageId="77" pageNumber="78" pagination="259 - 263" refId="ref49585" refString="Just, J. (1981) Tiron bellairsi sp. n. (Amphipoda, Synopiidae) from coral sand in Barbados, with notes on behaviour. Zoologica Scripta, 10, 259 - 263. https: // doi. org / 10.1111 / j. 1463 - 6409.1981. tb 00502. x" type="journal article" year="1981">Just, 1981</bibRefCitation>
)
</taxonomicName>
<emphasis id="B9626913FF9CFF5CFD788C71E43FFCFC" bold="true" box="[757,885,835,861]" pageId="77" pageNumber="78">
<taxonomicNameLabel id="A251D468FF9CFF5CFD788C71E43FFCFC" box="[757,885,835,861]" pageId="77" pageNumber="78" rank="species">comb. nov.</taxonomicNameLabel>
</emphasis>
; 
<taxonomicName id="4C16CE82FF9CFF5CFC0F8C76E3E6FCFC" authority="(Ledoyer, 1979)" authorityName="Just" authorityYear="2022" baseAuthorityName="Ledoyer" baseAuthorityYear="1979" box="[898,1196,835,861]" class="Malacostraca" family="Synopiidae" genus="Minitiron" kingdom="Animalia" order="Amphipoda" pageId="77" pageNumber="78" phylum="Arthropoda" rank="species" species="caecus" status="comb. nov.">
