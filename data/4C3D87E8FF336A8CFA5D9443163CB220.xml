<subSubSection id="8C8E6575FF336A8CFA5A9091191CBDDB" box="[1446,1820,1736,1769]" pageId="200" pageNumber="962" type="breeding">
<paragraph id="C42B36FEFF336A8CFA5A9091191CBDDB" blockId="200.[1444,2655,1103,2322]" box="[1446,1820,1736,1769]" pageId="200" pageNumber="962">
<emphasis id="F6E0EAECFF336A8CFA5A9091182DBDDB" bold="true" box="[1446,1581,1736,1769]" pageId="200" pageNumber="962">Breeding.</emphasis>
