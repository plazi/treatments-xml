<subSubSection id="89AF63024B5233B3EF8199B251A2FBBC" pageId="null" pageNumber="111" type="description">
<paragraph id="F555C2B11378FEDD8B5FB07C572C40D7" pageId="null" pageNumber="111">
<emphasis id="F6DED969D199552E689DFD092F898E68" italics="true" pageId="null" pageNumber="111">
<normalizedToken id="DCD0E202FB41C3898C3E2C469AB316AC" originalValue="Blätter" pageId="null" pageNumber="111">Blaetter</normalizedToken>
schmal lanzettlich und ganzrandig oder fiederteilig und mit schmalen Abschnitten.
</emphasis>
Kelch 
<normalizedToken id="64699A05AEFFCB336C4B90FABF1D4EB2" originalValue="röhrenförmig" pageId="null" pageNumber="111">roehrenfoermig</normalizedToken>
, gerade, 15nervig, 21ippig (3 
<normalizedToken id="5825384B0B323283F84632F7FD0C0C7D" originalValue="zähnige" pageId="null" pageNumber="111">zaehnige</normalizedToken>
Oberlippe und 2 
<normalizedToken id="77F1DE5B0A55684C518615CD3F100044" originalValue="zähnige" pageId="null" pageNumber="111">zaehnige</normalizedToken>
Unterlippe); 
<normalizedToken id="6F5C61AB984000D49496045DF8A3CCD7" originalValue="Kelchröhre" pageId="null" pageNumber="111">Kelchroehre</normalizedToken>
innen nicht 
<normalizedToken id="01870C35C91D7FA06BCAD4AD4D51B383" originalValue="bärtig" pageId="null" pageNumber="111">baertig</normalizedToken>
behaart; 
<emphasis id="1DAEBDF2B80F157522AE45E40C05400B" italics="true" pageId="null" pageNumber="111">
mittlerer Zahn der Oberlippe bedeutend breiter als die 
<normalizedToken id="4285AB1F98B4B6559900504A434AA176" originalValue="übrigen" pageId="null" pageNumber="111">uebrigen</normalizedToken>
<normalizedToken id="71BECD7CF411EF51C354FDAE34A664DE" originalValue="Zähne" pageId="null" pageNumber="111">Zaehne</normalizedToken>
.
</emphasis>
Krone mit am Grunde enger, oben sich erweiternder 
<normalizedToken id="F87200CFDE9430785E9CA6A156691776" originalValue="Röhre" pageId="null" pageNumber="111">Roehre</normalizedToken>
und 21ippigem Rand; Oberlippe 
<normalizedToken id="7C52AD67322CD34C1B2ABF4DE478ED75" originalValue="helmförmig" pageId="null" pageNumber="111">helmfoermig</normalizedToken>
<normalizedToken id="10C8D56F7CAD0266CAEE34EB3A09EB9F" originalValue="gewölbt" pageId="null" pageNumber="111">gewoelbt</normalizedToken>
, von der Seite gesehen 
<emphasis id="927754345FFECB500DFDBB1ECF56398E" italics="true" pageId="null" pageNumber="111">
<normalizedToken id="2ABA20D096CA0FB58FAC4EA83FA63308" originalValue="sichelförmig" pageId="null" pageNumber="111">sichelfoermig</normalizedToken>
</emphasis>
, ganzrandig, behaart; Unterlippe 3teilig, mit 
<normalizedToken id="A81C6FC4ADADBF5D25C4A14F2D4A86F4" originalValue="größerem" pageId="null" pageNumber="111">groesserem</normalizedToken>
, ausgerandetem Mittelabschnitt. 
<normalizedToken id="4BE5A17AC613C0AD0AA618D9326732BF" originalValue="Staubblätter" pageId="null" pageNumber="111">Staubblaetter</normalizedToken>
4, unter der Oberlippe aufsteigend, mit 
<normalizedToken id="C82505BE6551319AFA5389824E9E7142" originalValue="bärtig" pageId="null" pageNumber="111">baertig</normalizedToken>
behaarten, spreizenden 
<normalizedToken id="6CFC9EA1679D373831BBDA526AFDC483" originalValue="Staubbeutelhälften" pageId="null" pageNumber="111">Staubbeutelhaelften</normalizedToken>
(im Gebiet noch bei Arten der Gattung 
<taxonomicName id="EEEA3759ABF2666D2EC6501C9EC319DA" class="Magnoliopsida" family="Lamiaceae" genus="Lamium" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="111" phylum="Tracheophyta" rank="genus">
<emphasis id="C3685607F310EC5E96F7523AD8D8A84C" italics="true" pageId="null" pageNumber="111">Lamium</emphasis>
</taxonomicName>
<normalizedToken id="CC30C989B913019CD99C1A2C73159134" originalValue="bärtig" pageId="null" pageNumber="111">baertig</normalizedToken>
behaarte 
<normalizedToken id="ECD2D6B3865FDF40F9ECE5ADFDAD7B8D" originalValue="Staubbeutelhälften" pageId="null" pageNumber="111">Staubbeutelhaelften</normalizedToken>
); 
<normalizedToken id="3194529051D861626C87F10142645A60" originalValue="Griffeläste" pageId="null" pageNumber="111">Griffelaeste</normalizedToken>
kurz, 
<normalizedToken id="61AF4999139BBE9E1B39B578184F4F41" originalValue="±" pageId="null" pageNumber="111">+/-</normalizedToken>
gleich lang. 
<normalizedToken id="326D2DF394C0409E70F1A662225D21D3" originalValue="Teilfrüchte" pageId="null" pageNumber="111">Teilfruechte</normalizedToken>
<normalizedToken id="D3B7E922DDCFB5D9C74DED0AFBDE15B9" originalValue="eiförmig" pageId="null" pageNumber="111">eifoermig</normalizedToken>
, etwas 3kantig, glatt.
</paragraph>
<paragraph id="3A1A97D262ED68F3AE347264A7C2007A" pageId="null" pageNumber="111">
Die Gattung 
<emphasis id="5D51289131F8C67D4D53DB7C504D6130" italics="true" pageId="null" pageNumber="111">
<taxonomicName id="9DCF90A5F4077DF68E84FBEA8677E40E" class="Magnoliopsida" family="Lamiaceae" genus="Dracocephalum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="111" phylum="Tracheophyta" rank="genus">Dracocephalum</taxonomicName>
<normalizedToken id="A6F5CC598911D74FD760A7C139362C1D" originalValue="umfaßt" pageId="null" pageNumber="111">umfasst</normalizedToken>
etwa 40 meist zentralasiatische Arten.
</emphasis>
</paragraph>
