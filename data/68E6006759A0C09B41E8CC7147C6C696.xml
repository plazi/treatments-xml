<subSubSection id="5CD71F7F5183BC3FEB0018C2DB4FA736" pageId="null" pageNumber="598" type="description">
<paragraph id="658A28CAE2C0116BC36AD701AD9445E1" pageId="null" pageNumber="598">
Die Gattung 
<normalizedToken id="1EE512E3179B559622AD997115A37503" originalValue="umfaßt" pageId="null" pageNumber="598">umfasst</normalizedToken>
<emphasis id="105942B570BA893448984CC8787AD103" italics="true" pageId="null" pageNumber="598">
1 Art, 
<taxonomicName id="E1AB4997BE62DD14AE892A4A104816A6" class="Liliopsida" family="Orchidaceae" genus="Limodorum" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="598" phylum="Tracheophyta" rank="species" species="abortivum">
<authorityName id="4362820BD194D57F1ACEE7198BF7E984" pageId="null" pageNumber="598">L.</authorityName>
abortivum
</taxonomicName>
</emphasis>
, die saprophytisch 
<normalizedToken id="4C57DFF1754FB8100951F81DAB59D913" originalValue="wächst" pageId="null" pageNumber="598">waechst</normalizedToken>
; oft wird von 
<taxonomicName id="C2910002CB3EF7FFD85B927C2CD2A10C" class="Liliopsida" family="Orchidaceae" genus="Limodorum" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="598" phylum="Tracheophyta" rank="species" species="abortivum">
<emphasis id="A0D35CBC944458CD777A4EF66297AA49" italics="true" pageId="null" pageNumber="598">
<authorityName id="2D8A7122C2A5CB854DCD1C90AEDBA169" pageId="null" pageNumber="598">L.</authorityName>
abortivum
</emphasis>
</taxonomicName>
eine weitere Art, 
<taxonomicName id="22FE7BEEF0BD9F02AC497D60F78590C4" authority="Batt." authorityName="Batt." class="Liliopsida" family="Orchidaceae" genus="Limodorum" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="598" phylum="Tracheophyta" rank="species" species="trabutianum">
<emphasis id="BBFB8816FC8D77ED67BEDE79DB4E4B8D" italics="true" pageId="null" pageNumber="598">
<authorityName id="F35059CB158CA966259E3A381353202F" pageId="null" pageNumber="598">L.</authorityName>
Trabutianum
</emphasis>
Batt.
</taxonomicName>
, abgetrennt (Ferlan 1958). 
<taxonomicName id="E7DAE153FF7AF3897DDF1A6FF589B839" class="Liliopsida" family="Orchidaceae" genus="Limodorum" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="598" phylum="Tracheophyta" rank="species" species="trabutianum">
<emphasis id="21F6DF5E2A31613F53747E387D9DC460" italics="true" pageId="null" pageNumber="598">
<authorityName id="6A9A78B483ACFB13AC301D709B1A9380" pageId="null" pageNumber="598">L.</authorityName>
Trabutianum
</emphasis>
</taxonomicName>
hat eine westmediterrane Verbreitung (Iberische Halbinsel, Nordafrika). Die Gattung 
<taxonomicName id="FF62916796BF48F4E0180217C503FB93" class="Liliopsida" family="Orchidaceae" genus="Limodorum" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="598" phylum="Tracheophyta" rank="genus">
<emphasis id="3258E9E89E3529222F71761CFC1B0C04" italics="true" pageId="null" pageNumber="598">Limodorum</emphasis>
</taxonomicName>
ist isoliert; nach den 
<normalizedToken id="EF4C229CB15856A9AE10D2577693D8EA" originalValue="Blütenmerkmalen" pageId="null" pageNumber="598">Bluetenmerkmalen</normalizedToken>
steht sie der Gattung 
<taxonomicName id="33F4FCD614171627F9BFD1AE28E64EF5" class="Liliopsida" family="Orchidaceae" genus="Cephalanthera" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="598" phylum="Tracheophyta" rank="genus">
<emphasis id="432E6A5D023FE3D460B5A9B141016831" italics="true" pageId="null" pageNumber="598">Cephalanthera</emphasis>
</taxonomicName>
am 
<normalizedToken id="3F253ED60289A9E6F472501F721949DB" originalValue="nächsten" pageId="null" pageNumber="598">naechsten</normalizedToken>
. Die Gattungsmerkmale sind in der Artdiagnose enthalten.
</paragraph>
