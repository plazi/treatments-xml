<subSubSection id="8718C2AE7B20EA8B0B85643B801297E0" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="0BCB8D9355B80B32D829FCAD9AF2F70B" pageId="null" pageNumber="590">Blaue Rasselblume</paragraph>
</subSubSection>
</title>
<subSubSection id="9A18CE982F205795CBDD49C09A8ABB58" pageId="null" pageNumber="590" type="description">
<paragraph id="52EB7D050B5C710417D688B4B007167C" pageId="null" pageNumber="590">
Ausdauernd, mit Rhizom; 40-80 cm hoch, behaart. Stengel gerillt, aufrecht, meist verzweigt. 
<normalizedToken id="4382B6BCE883E6B384FC96CBCE386D33" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
schmal lanzettlich, 3nervig, 
<emphasis id="E074344A336CF3946E48250CD0268F71" italics="true" pageId="null" pageNumber="590">
die untern mit wenigen, langen, schmalen, 
<normalizedToken id="3B40BAD3891B71F9B91C8D46D621465B" originalValue="sichelförmig" pageId="null" pageNumber="590">sichelfoermig</normalizedToken>
nach vorn gebogenen 
<normalizedToken id="2325002A5EA795241CE960CC149E5972" originalValue="Zähnen" pageId="null" pageNumber="590">Zaehnen</normalizedToken>
</emphasis>
, in einen Stiel 
<normalizedToken id="0D1BDFBDE6910D432AAC97A7A17D4467" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
; die obern ganzrandig und sitzend. 
<normalizedToken id="72233137AFD096824C079D510591B784" originalValue="Köpfe" pageId="null" pageNumber="590">Koepfe</normalizedToken>
im Durchmesser 3-6 cm. 
<normalizedToken id="4E490BFC080098236101562A7987A4AA" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
etwa 2 cm lang. 
<normalizedToken id="8E1CC4DA1F7464DBBABE9F2FBE840B3D" originalValue="Äußere" pageId="null" pageNumber="590">Aeussere</normalizedToken>
<normalizedToken id="83637D984B2AE1D0F0B0B7B97418ED8F" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
oval, 
<normalizedToken id="ED5CB04685CAD60875107B41A651DA9E" originalValue="braunhäutig" pageId="null" pageNumber="590">braunhaeutig</normalizedToken>
; innere 
<normalizedToken id="BBD4BA647E42E818DCA84F6D10223F33" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
aus einem schmal lanzettlichen, 
<normalizedToken id="77D50E5317A25C66853730E5375F41B6" originalValue="weißen" pageId="null" pageNumber="590">weissen</normalizedToken>
untern Teil und einem ovalen, braunen, 
<normalizedToken id="27C25BA63B44FA58A4F957BB18F54449" originalValue="häutigen" pageId="null" pageNumber="590">haeutigen</normalizedToken>
obern Teil bestehend. 
<emphasis id="9820B135436D1B2ED522825795394900" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="2D5F562111E9C979D84D14402D5E5C3C" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
blau
</emphasis>
. 
<normalizedToken id="C668D91A1B580455B531DC2FEC76D98D" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
3-4 mm lang. 
<taxonomicName id="C2B89F8F4D27ADEF3D1E83368796D798" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
etwa so lang wie die Frucht. - 
<normalizedToken id="F25610B2B97468EBBD1A5D07D9F047EB" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="10F2526B614BACBCE7948F87E3075FB6" pageId="null" pageNumber="590">
<emphasis id="70E770934B01A501FC0B4E445653AED7" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A600B1324FA50476D12334879CE8E2AF" italics="true" pageId="null" pageNumber="590">18:</emphasis>
Material aus Westfrankreich (Delay 1967), aus den 
<normalizedToken id="5337CA83AFBCD013ACFB9F00E30592AD" originalValue="Südwestalpen" pageId="null" pageNumber="590">Suedwestalpen</normalizedToken>
(Delay 1968). Marchal (1920) 
<normalizedToken id="B9C8A9FD8CC64B58C6D244566CA39C8D" originalValue="zählte" pageId="null" pageNumber="590">zaehlte</normalizedToken>
<emphasis id="4B4A7DAADA4B9AF8E432321AF55586A2" italics="true" pageId="null" pageNumber="590">2n</emphasis>
= 
<emphasis id="4BBFBB823657674CC342C1DE511D16C6" italics="true" pageId="null" pageNumber="590">16</emphasis>
.
</paragraph>
<paragraph id="83B7F4A25EBCC44DEAFE106EDD0DCCB9" pageId="null" pageNumber="590">
<emphasis id="1DF85C7BA57BE8FE095AFF7A8FC936FA" italics="true" pageId="null" pageNumber="590">Standort</emphasis>
. Kollin. Trockenwiesen, Felsensteppen.
</paragraph>
<paragraph id="0F590E71DC18CC733EA8D025A34D2987" pageId="null" pageNumber="590">
<emphasis id="D2AB466DAAD392FA94B8F341E28CB5EF" italics="true" pageId="null" pageNumber="590">
Verbreitung. 
<normalizedToken id="D5EBF3622E04D2026793C23B9EBD64B2" originalValue="Südwesteuropäische" pageId="null" pageNumber="590">Suedwesteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Iberische Halbinsel, 
<normalizedToken id="B12444D4010715C2B4C671F5318097DA" originalValue="Südfrankreich" pageId="null" pageNumber="590">Suedfrankreich</normalizedToken>
, Ligurien, Piemont. - Im Gebiet: 
<normalizedToken id="229716C59380BFC91D92B717BA192F3B" originalValue="Dép" pageId="null" pageNumber="590">Dep</normalizedToken>
. Ain (
<normalizedToken id="D73769B7C2EC49EFE78E419175817EE3" originalValue="südlicher" pageId="null" pageNumber="590">suedlicher</normalizedToken>
Teil); eingeschleppt bei Chancy (Genf); gelegentlich auch in 
<normalizedToken id="397C669237B235516E746B53AA046884" originalValue="Gärten" pageId="null" pageNumber="590">Gaerten</normalizedToken>
angepflanzt.
</paragraph>
</subSubSection>
