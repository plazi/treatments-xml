<subSubSection id="D9F16554FFA8BA04B3FFFC25B44BF478" pageId="20" pageNumber="639" type="distribution">
<caption id="C5946657FFA8BA04B3FFFC25B44BF478" ID-DOI="http://doi.org/10.5281/zenodo.6418485" ID-Zenodo-Dep="6418485" httpUri="https://zenodo.org/record/6418485/files/figure.png" inLine="true" pageId="20" pageNumber="639" targetBox="[1414,2005,2539,2955]" targetPageId="20">
<paragraph id="915436DFFFA8BA04B3FFFC25B44BF478" blockId="20.[2023,2623,2534,2958]" lastBlockId="20.[1416,2625,2973,3471]" pageId="20" pageNumber="639">
