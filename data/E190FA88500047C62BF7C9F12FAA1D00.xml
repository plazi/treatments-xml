<subSubSection id="F4548514FF74CFB69811993764CC98E0" pageId="null" pageNumber="184" type="description">
<paragraph id="EA3F985B1CA9E6480C68940FE6329BB4" pageId="null" pageNumber="184">
1 
<emphasis id="97CFB7F396C20552AFF5978A66893D1A" italics="true" pageId="null" pageNumber="184">-</emphasis>
2 
<normalizedToken id="ACB204BC609CAF0704174417A4D30A78" originalValue="jährig" pageId="null" pageNumber="184">jaehrig</normalizedToken>
, mit Pfahlwurzel; 30 
<emphasis id="5363FF332E26F7193AC42328F0BE0E9D" italics="true" pageId="null" pageNumber="184">-</emphasis>
100 cm hoch. Stengel aufrecht, verzweigt, im untern Teil mit zahlreichen, 
<normalizedToken id="14E42B7C159E96CB4050570AA731712C" originalValue="rückwärts" pageId="null" pageNumber="184">rueckwaerts</normalizedToken>
gerichteten, 0,2 
<emphasis id="C14936CE4830A32FF5279C3C3DA2B300" italics="true" pageId="null" pageNumber="184">-</emphasis>
1 mm langen Haaren. Untere 
<normalizedToken id="193C781FB326174FAC54F2554722E266" originalValue="Blätter" pageId="null" pageNumber="184">Blaetter</normalizedToken>
gestielt, bis fast oder ganz zum Mittelnerv fiederteilig, jederseits mit 1 
<emphasis id="8FE440258828281A12D540A39F27EA39" italics="true" pageId="null" pageNumber="184">-</emphasis>
5 
<normalizedToken id="3FDE0F29404C64615B0ED1288F75AF32" originalValue="±" pageId="null" pageNumber="184">+/-</normalizedToken>
senkrecht abstehenden Abschnitten (End- 
<pageBreakToken id="1927712AAAE4F740E6DB8A9257C60701" pageId="null" pageNumber="184">
<normalizedToken id="612BF359FE4FFFB9B218684EF700B4FB" originalValue="schmälertem" pageId="null" pageNumber="184">schmaelertem</normalizedToken>
</pageBreakToken>
Grunde sitzend, schmal oval bis lanzettlich, wenig tief 
<normalizedToken id="D9645FEDAE3DD4606E99CDE4771A8078" originalValue="gezähnt" pageId="null" pageNumber="184">gezaehnt</normalizedToken>
bis ganzrandig. 
<normalizedToken id="442B2FCA002D365899EFF92C4609292C" originalValue="Blütenstiele" pageId="null" pageNumber="184">Bluetenstiele</normalizedToken>
etwas 
<normalizedToken id="8AA3EB8EF410EB0FD470050F574E760D" originalValue="kürzer" pageId="null" pageNumber="184">kuerzer</normalizedToken>
als die 
<normalizedToken id="79FB07F11C55F067685FA4E7E300DB9F" originalValue="Kelchblätter" pageId="null" pageNumber="184">Kelchblaetter</normalizedToken>
. 
<normalizedToken id="E957A3906DD683423F2BFEB698683EAB" originalValue="Kelchblätter" pageId="null" pageNumber="184">Kelchblaetter</normalizedToken>
<normalizedToken id="1D216E8BE5627CA17A22D0AF039128C7" originalValue="±" pageId="null" pageNumber="184">+/-</normalizedToken>
aufrecht, 3 
<emphasis id="6797EE951DD21DCF83135CE8B65D5C29" italics="true" pageId="null" pageNumber="184">-</emphasis>
4 mm lang, kahl oder zerstreut behaart. 
<normalizedToken id="59DA446096F84039B0AF6C237F0114A9" originalValue="Kronblätter" pageId="null" pageNumber="184">Kronblaetter</normalizedToken>
ziemlich lang gestielt, 6-8 mm lang, 
<normalizedToken id="53C591787ACD01FD89BB16F996FE6BFF" originalValue="blaßgelb" pageId="null" pageNumber="184">blassgelb</normalizedToken>
. Fruchtstiele 2,5 bis 4 mm lang, 
<emphasis id="E45D1FFC23A874494945EAE93EEC478A" italics="true" pageId="null" pageNumber="184">
fast so dick wie die 
<normalizedToken id="37A477D2836C851185866F08ACBDEE3D" originalValue="Früchte" pageId="null" pageNumber="184">Fruechte</normalizedToken>
. 
<normalizedToken id="C20E9F38D0F259C2C220025E8B48E572" originalValue="Früchte" pageId="null" pageNumber="184">Fruechte</normalizedToken>
aufrecht, dem Stengel
</emphasis>
<normalizedToken id="74F1DED88E1B94E445D48C228B3CFBCC" originalValue="±" pageId="null" pageNumber="184">+/-</normalizedToken>
<emphasis id="0AAC83B70E568CE4C2EC7C6EAECB7965" italics="true" pageId="null" pageNumber="184">anliegend, 0,8-1,5 cm lang und 1-1,5 mm dick</emphasis>
, 6 
<emphasis id="645E43AD22824E7640EF2A100ABA44E9" italics="true" pageId="null" pageNumber="184">-</emphasis>
12samig, kahl oder kurz behaart; 
<emphasis id="86661B41747661363D64B094B0986D67" italics="true" pageId="null" pageNumber="184">Schnabel 4-7 mm lang</emphasis>
, mit 0 
<emphasis id="7C0AB6096999A98F28A70FBF574EF0EE" italics="true" pageId="null" pageNumber="184">-</emphasis>
2 Samen, von der 
<normalizedToken id="4DF5B4FE19556F043B2B73F4204AC845" originalValue="übrigen" pageId="null" pageNumber="184">uebrigen</normalizedToken>
Frucht kaum abgesetzt. Samen 0,75 
<emphasis id="4272704C014E825D1EA03D5888F83856" italics="true" pageId="null" pageNumber="184">-</emphasis>
1,2 mm lang. - 
<normalizedToken id="D19B249EA6A3BB600DD591A4314D2A1A" originalValue="Blüte" pageId="null" pageNumber="184">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="12CCD5F240B68A14DD5802F4A188D210" pageId="null" pageNumber="184">
<emphasis id="EC21945EDF1E23A9D6231C11A28C40A4" italics="true" pageId="null" pageNumber="184">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="F7D9396E39DFE7996ADE70F40D538D08" italics="true" pageId="null" pageNumber="184">14:</emphasis>
Material aus Kalifornien (Heiser und Whitaker 1948). 
<emphasis id="E6C226F28006F592977B288D2F762C53" italics="true" pageId="null" pageNumber="184">2n</emphasis>
= 
<emphasis id="222F0A66062E91302A42D30303C2AF02" italics="true" pageId="null" pageNumber="184">14</emphasis>
und 
<emphasis id="930A2A54ABACDCB34C89C5FE87538F20" italics="true" pageId="null" pageNumber="184">16:</emphasis>
Material aus Spanien (Baez-Mayor 1934).
</paragraph>
<paragraph id="BEF64D522A52A82460B026B464B3F1AF" pageId="null" pageNumber="184">
<emphasis id="DFB1DC7B4A0C8E97B21B3FB407F03E27" italics="true" pageId="null" pageNumber="184">Standort.</emphasis>
Kollin und montan. Trockene, 
<normalizedToken id="34127D861ECC5F828347BECBEFAD370B" originalValue="nährstoffreiche" pageId="null" pageNumber="184">naehrstoffreiche</normalizedToken>
<normalizedToken id="8D5E02EB0C7FDE55BD30FD5EB89CCF06" originalValue="Böden" pageId="null" pageNumber="184">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="06CB3A974A0A36CBE2A38425F1E94DFC" originalValue="Wegränder" pageId="null" pageNumber="184">Wegraender</normalizedToken>
, 
<normalizedToken id="E86BD638018220A5F13A9127427E7A02" originalValue="Schuttplätze" pageId="null" pageNumber="184">Schuttplaetze</normalizedToken>
, 
<normalizedToken id="F1E26227F91B91B689168549C8306039" originalValue="Äcker" pageId="null" pageNumber="184">Aecker</normalizedToken>
.
</paragraph>
<paragraph id="AC8F025FE58F09840B95C4F7E33809EA" pageId="null" pageNumber="184">
<emphasis id="F01C771C23EDF5E7609BC597D189E26F" italics="true" pageId="null" pageNumber="184">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="778ABD0C9E0C6C50B92FB7D896E5D2C2" originalValue="Südeuropa" pageId="null" pageNumber="184">Suedeuropa</normalizedToken>
(
<normalizedToken id="4044772F0A2877BAF5787D1EAFC21FB3" originalValue="nordwärts" pageId="null" pageNumber="184">nordwaerts</normalizedToken>
bis Oberrheinische Tiefebene); Kanaren; Nordwestafrika; Kleinasien. - Im Gebiet besonders auf der 
<normalizedToken id="6FBA32C18B4B876E4B685C7CF666E834" originalValue="Alpensüdseite" pageId="null" pageNumber="184">Alpensuedseite</normalizedToken>
, in der Gegend von Belfort und in der Oberrheinischen Tiefebene (z.B. Huningue), sonst selten; wahrscheinlich 
<normalizedToken id="A79B7FE7F5991F086A983A19F2C4B92D" originalValue="überall" pageId="null" pageNumber="184">ueberall</normalizedToken>
nur verschleppt.
</paragraph>
