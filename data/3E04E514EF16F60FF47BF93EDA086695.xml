<paragraph id="10710F1A53B3C99EFA7DEEBDB9645D62" pageId="null" pageNumber="336">
<normalizedToken id="F611B3F5D911B8AD0146EFFFE64F3949" originalValue="Krönchen-Nüßlisalat" pageId="null" pageNumber="336">Kroenchen-Nuesslisalat</normalizedToken>
</paragraph>
