<subSubSection id="1AF40D63164671E3E8F2C08CEBB3195D" pageId="null" pageNumber="849" type="vernacular_names">
<paragraph id="CD304C6730A0E0F35C64FF0499DEB2E4" pageId="null" pageNumber="849">Ufer-Hirschsprung</paragraph>
</subSubSection>
</title>
<subSubSection id="79884022DBB2EFF8BA2106C925B936EE" pageId="null" pageNumber="849" type="description">
<paragraph id="8607FDBD20546AB9D91CB9634CFB889A" pageId="null" pageNumber="849">
1 
<normalizedToken id="CB9C4FC7D4D3E1D71CD629777F2183BC" originalValue="jährig" pageId="null" pageNumber="849">jaehrig</normalizedToken>
, mit 
<normalizedToken id="07A51A2568A0488636CE386D66E37C96" originalValue="dünner" pageId="null" pageNumber="849">duenner</normalizedToken>
Pfahlwurzel; 2-25 cm hoch. Stengel niederliegend bis aufsteigend, verzweigt, kahl. 
<normalizedToken id="04F3A775DCBBC17C877899164FB0F3F7" originalValue="Blätter" pageId="null" pageNumber="849">Blaetter</normalizedToken>
mit der 
<normalizedToken id="A0356686C7CA278257494612FBD92150" originalValue="größten" pageId="null" pageNumber="849">groessten</normalizedToken>
Breite im vordersten Drittel, bis 2 cm lang. 
<emphasis id="9EFA10C46A283A65E7A7D0E8B938D492" italics="true" pageId="null" pageNumber="849">4</emphasis>
- 
<emphasis id="4BABACBA6356FD22CAB4CD2DA37CD9E6" italics="true" pageId="null" pageNumber="849">15mal so lang wie breit</emphasis>
, kahl. 
<normalizedToken id="EC2862128F8DBEA2086101210C687996" originalValue="Nebenblätter" pageId="null" pageNumber="849">Nebenblaetter</normalizedToken>
<normalizedToken id="73FE9EACF1767A525628F39DF3A4E6AF" originalValue="unregelmäßig" pageId="null" pageNumber="849">unregelmaessig</normalizedToken>
und fein 
<normalizedToken id="46509EB4512CBA670E5DE53B50F96F3D" originalValue="gezähnt" pageId="null" pageNumber="849">gezaehnt</normalizedToken>
, 1-3 mm lang. 
<normalizedToken id="76DF03DC6718E9ACA3064111B517091E" originalValue="Blütenstiele" pageId="null" pageNumber="849">Bluetenstiele</normalizedToken>
fast so lang bis wenig 
<normalizedToken id="BCEFCA0FFE4E0F1EFF96176F6E3066D4" originalValue="länger" pageId="null" pageNumber="849">laenger</normalizedToken>
als die 
<normalizedToken id="35D3924E777A41AFAC034370EF1617DB" originalValue="nächststehenden" pageId="null" pageNumber="849">naechststehenden</normalizedToken>
<normalizedToken id="2867EE917A82BF048B137251B0AA5858" originalValue="trockenhäutigen" pageId="null" pageNumber="849">trockenhaeutigen</normalizedToken>
<normalizedToken id="35D013CF726273F9BCDF61E526B51C30" originalValue="Blätter" pageId="null" pageNumber="849">Blaetter</normalizedToken>
. 
<normalizedToken id="C7321992A3FDF24585D9518FAA8B91E1" originalValue="Kelchblätter" pageId="null" pageNumber="849">Kelchblaetter</normalizedToken>
etwa 1 mm lang, kahl. 
<normalizedToken id="1347B8AE4DDA428919DACF966F0FD1A9" originalValue="Kronblätter" pageId="null" pageNumber="849">Kronblaetter</normalizedToken>
etwas 
<normalizedToken id="CA034D164404BE9ED214C2D5AAF2ADCA" originalValue="kürzer" pageId="null" pageNumber="849">kuerzer</normalizedToken>
als die 
<normalizedToken id="4FA4B8CCE88E23FFA3D5CEF62748A107" originalValue="Kelchblätter" pageId="null" pageNumber="849">Kelchblaetter</normalizedToken>
, 
<normalizedToken id="73E7A87436705A84A57DF7D749CBA8A2" originalValue="weiß" pageId="null" pageNumber="849">weiss</normalizedToken>
. Frucht 1-1,5 mm lang. - 
<normalizedToken id="BD3FA414D1B5FFE90E2AB6C083696F6F" originalValue="Blüte" pageId="null" pageNumber="849">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="B34848E4B540A4CA63E28A7CC4F38FDB" pageId="null" pageNumber="849">
<emphasis id="0EC6035F2390CC087B3E69953D0BDADD" italics="true" pageId="null" pageNumber="849">Zytologische Angaben. 2n ca. 16:</emphasis>
Ohne Herkunftsangabe des Materials (
<normalizedToken id="58F9A2E7F54929D082F4642C2BAA8244" originalValue="Rocén" pageId="null" pageNumber="849">Rocen</normalizedToken>
1927). 
<emphasis id="4F172AAC3D7F53A694B8313F08D7BCDC" italics="true" pageId="null" pageNumber="849">2n</emphasis>
= 
<emphasis id="522355A380EE0F392C3F59499565FB43" italics="true" pageId="null" pageNumber="849">18:</emphasis>
Material aus 
<normalizedToken id="468D5DCD6AAAB1E5747D2E97ADDD0C86" originalValue="Großbritannien" pageId="null" pageNumber="849">Grossbritannien</normalizedToken>
und Portugal (Blackburn und Morton 1957). 
<emphasis id="8A34B912FDF68F199257C9C0E0E4A1D0" italics="true" pageId="null" pageNumber="849">2n</emphasis>
= 
<emphasis id="12CBA86AC23C4817F357CF0DDBBB78C2" italics="true" pageId="null" pageNumber="849">32:</emphasis>
Material aus Portugal (Rodrigues aus 
<normalizedToken id="59B8A8234B6DEBB42E3BD7CDB8AE143E" originalValue="Löve" pageId="null" pageNumber="849">Loeve</normalizedToken>
und 
<normalizedToken id="75E80A74CE30391C324EF8DA1C9A53C9" originalValue="Löve" pageId="null" pageNumber="849">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="A72D47B624A504BA59EE05D4D9D169BB" pageId="null" pageNumber="849">
<emphasis id="A225D9EEC5B9B2C173BBDECD8002A8EE" italics="true" pageId="null" pageNumber="849">Standort.</emphasis>
Kollin. Offene, feuchte, kalkarme, saure, kiesige und sandige 
<normalizedToken id="1EC8CB7FB63BF707FD3D4C6BD9FF629F" originalValue="Böden" pageId="null" pageNumber="849">Boeden</normalizedToken>
in warmen Lagen. Ufer, 
<normalizedToken id="87067B2C68378E20990BACC5DB7795AD" originalValue="Äcker" pageId="null" pageNumber="849">Aecker</normalizedToken>
, 
<normalizedToken id="262C79CFD2426FEC41BFF97CE9FE8078" originalValue="Wegränder" pageId="null" pageNumber="849">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="E4E7D063C5C5100DDA397DCABDFD3EF8" pageId="null" pageNumber="849">
<emphasis id="711C6F3EB0719CF58309E997516A7EDE" italics="true" pageId="null" pageNumber="849">
Verbreitung. 
<normalizedToken id="AC0201AC8258D27E8BF94CCA7359FBCF" originalValue="Westeuropäisch-mediterrane" pageId="null" pageNumber="849">Westeuropaeisch-mediterrane</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="5C18E3396770E13AF012EC5EA0CAE60B" originalValue="Südeuropa" pageId="null" pageNumber="849">Suedeuropa</normalizedToken>
, 
<normalizedToken id="6BEF7E6260701FFA0998D0FDB43C8E15" originalValue="nordwärts" pageId="null" pageNumber="849">nordwaerts</normalizedToken>
vereinzelt bis 
<normalizedToken id="71F3EE778C39B92C92CF651CD6FEB02F" originalValue="Südengland" pageId="null" pageNumber="849">Suedengland</normalizedToken>
, Skandinavien, Schlesien; Kleinasien; Syrien; Nordafrika, Abessinien; in Amerika und 
<normalizedToken id="D88D58E820644A10179176E8E03282B1" originalValue="Südafrika" pageId="null" pageNumber="849">Suedafrika</normalizedToken>
eingeschleppt. Verbreitungskarte von Meusel (1964). - Im Gebiet: Vogesen, Oberrheinische Tiefebene (
<normalizedToken id="C15E144DA48475EFB3007879F6FC3A99" originalValue="früher" pageId="null" pageNumber="849">frueher</normalizedToken>
auch bei Basel), westlicher Schwarzwald, Gebiet von Belfort, 
<normalizedToken id="A9695DD4013DC3CB53D7E70DDE6911E9" originalValue="Dép" pageId="null" pageNumber="849">Dep</normalizedToken>
. Ain (besonders Dombes); ziemlich selten und 
<normalizedToken id="E7650FEF594FB933C932585ACAE3FB90" originalValue="unbeständig" pageId="null" pageNumber="849">unbestaendig</normalizedToken>
, selten adventiv.
</paragraph>
</subSubSection>
