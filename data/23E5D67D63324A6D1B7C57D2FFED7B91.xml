<subSubSection id="D60CEF8DE829BDA2F44171E5AB89CBB8" pageId="null" pageNumber="195" type="description">
<paragraph id="B5A779AB9D1ECDC4E9A777ABE196DF24" pageId="null" pageNumber="195">
5-15 cm hoch. Stengel meist bis zur Mitte niederliegend. 
<normalizedToken id="815BC56D79B4A2F0CA372A9279B4DE02" originalValue="Blätter" pageId="null" pageNumber="195">Blaetter</normalizedToken>
bis 1,5 cm lang, 1-1⅔mal so lang wie breit. 
<normalizedToken id="AB714CB527DA3433A5175B14FE1F6FC8" originalValue="Blüten" pageId="null" pageNumber="195">Blueten</normalizedToken>
bis 20 je Stengel. 
<emphasis id="5EF5FEF51AA85BCC9527EAE56217AE28" italics="true" pageId="null" pageNumber="195">
Kelch und 
<normalizedToken id="338AFFB6DB1060557F9C7CB21477463D" originalValue="Blütenstiele" pageId="null" pageNumber="195">Bluetenstiele</normalizedToken>
mit mehrzelligen 
<normalizedToken id="84EACB558594965F42234C10299754B6" originalValue="Drüsenhaaren" pageId="null" pageNumber="195">Druesenhaaren</normalizedToken>
</emphasis>
(
<emphasis id="B7A0DB5753C057A04AD33B0728C59B4D" italics="true" pageId="null" pageNumber="195">
Haare etwa so lang wie die Dicke der 
<normalizedToken id="7FF4EDFFE95F4134D37F91037AE3661E" originalValue="Blütenstiele" pageId="null" pageNumber="195">Bluetenstiele</normalizedToken>
</emphasis>
)
<emphasis id="333526F962ADA6A1E12DDD29D11EF7AF" italics="true" pageId="null" pageNumber="195">. Krone im Durchmesser 6</emphasis>
- 
<emphasis id="46C2594DCDEF6B85B7C0EC571BC49AB9" italics="true" pageId="null" pageNumber="195">8 mm, blau, dunkler geadert.</emphasis>
- 
<normalizedToken id="6384ECEDD0390231A91AC951D29A8907" originalValue="Blüte" pageId="null" pageNumber="195">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="DFBFFC8AB262219406464BD4614DAF02" pageId="null" pageNumber="195">
<emphasis id="04627A8EF843E131806FD19D83D1F3A9" italics="true" pageId="null" pageNumber="195">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="3E47665EF1E34E0B76AD5AA03FD41522" italics="true" pageId="null" pageNumber="195">14:</emphasis>
Material aus botanischen 
<normalizedToken id="3F0A5D426B2437C484FB67EEF1965A1E" originalValue="Gärten" pageId="null" pageNumber="195">Gaerten</normalizedToken>
(Hofelich 1935) und aus 
<normalizedToken id="1C561CA0BC0AE95527D5AB1493C250B3" originalValue="Großbritannien" pageId="null" pageNumber="195">Grossbritannien</normalizedToken>
(Rutland 1941).
</paragraph>
<paragraph id="AFE9DD5C00BEBD156F50C9EC031E9370" pageId="null" pageNumber="195">
<emphasis id="D5A1CA8C2DD700078BAE392D803B15CD" italics="true" pageId="null" pageNumber="195">
<pageBreakToken id="A85137E00A9C649774C2762E1A66C938" pageId="null" pageNumber="195">Standort</pageBreakToken>
.
</emphasis>
Subalpin, seltener montan oder alpin. Quellige, 
<normalizedToken id="8931A659D83959430CAAB6AB0092845B" originalValue="nährstoffreiche" pageId="null" pageNumber="195">naehrstoffreiche</normalizedToken>
, stickstoffhaltige, neutrale bis schwach saure, oft lange vom Schnee bedeckte 
<normalizedToken id="912B18349227F3D3E59C7B86EDF9F670" originalValue="Böden" pageId="null" pageNumber="195">Boeden</normalizedToken>
mit 
<normalizedToken id="0662AF384133C62841ED51CB099D18A9" originalValue="gleichmäßig" pageId="null" pageNumber="195">gleichmaessig</normalizedToken>
tiefen Temperaturen. Quellfluren, 
<normalizedToken id="939712ABCFF2DDB6FC8073729906000B" originalValue="Lägerstellen" pageId="null" pageNumber="195">Laegerstellen</normalizedToken>
. 
<emphasis id="4A66A4B72C8B633EC730E7ACD7CD2A43" italics="true" pageId="null" pageNumber="195">Rumicion alpini</emphasis>
(
<normalizedToken id="EC7E20F94917CC5C940938AF1ECE604F" originalValue="Rübel" pageId="null" pageNumber="195">Ruebel</normalizedToken>
1933) Klika 1944.
</paragraph>
<paragraph id="9330D882B91654EC0D4DD353472A120B" pageId="null" pageNumber="195">
<emphasis id="902061893FA98270B793AAF2DE5E9DF2" italics="true" pageId="null" pageNumber="195">Verbreitung. Arktisch-alpine Pflanze:</emphasis>
<normalizedToken id="4CD83B8F9F93C7EEB88ECA59521950A1" originalValue="Großbritannien" pageId="null" pageNumber="195">Grossbritannien</normalizedToken>
, Skandinavien, 
<normalizedToken id="02909ABB6339FCFB444110C4B3A507FE" originalValue="Pyrenäen" pageId="null" pageNumber="195">Pyrenaeen</normalizedToken>
, Alpen, Jura, Apennin, Karpaten; asiatische, nord-und 
<normalizedToken id="5E7347AA20173ED261AA783113F94E00" originalValue="südamerikanische" pageId="null" pageNumber="195">suedamerikanische</normalizedToken>
Gebirge. - Im Gebiet: Alpen, 
<normalizedToken id="8A234300EE6FFEC90F33E880C2D96F79" originalValue="südlicher" pageId="null" pageNumber="195">suedlicher</normalizedToken>
Jura, Hochvogesen; ziemlich 
<normalizedToken id="9B5CA6686B177575CE70C925EC928B6D" originalValue="häufig" pageId="null" pageNumber="195">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="20DA0EDF9EBB6E4745EE39792B34D7CC" pageId="null" pageNumber="195">
<emphasis id="5DF9B67692F96389F72E15E0A15E609F" italics="true" pageId="null" pageNumber="195">Bemerkungen.</emphasis>
<normalizedToken id="C9B445DB33152EEBFDFCB6441E0056F5" originalValue="Über" pageId="null" pageNumber="195">Ueber</normalizedToken>
die Nomenklatur der Arts. Hylander (1945, S. 280).
</paragraph>
</subSubSection>
