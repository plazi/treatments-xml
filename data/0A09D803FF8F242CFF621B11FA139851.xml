<figureCitation id="1A9B7590FF8F242CFDD71A60FDB39E08" box="[546,573,850,871]" captionStart="FIGURE 9" captionStartId="10.[151,250,1892,1916]" captionTargetBox="[256,1332,181,1869]" captionTargetId="figure-19@10.[256,1332,181,1869]" captionTargetPageId="10" captionText="FIGURE 9A–F. Acanthocyrtus pallidus sp. nov., antennae and head; A, chaetotaxy (mac and elongated sens) of left Ant III–I (dorsal view, from left to right), respectively; B, chaetotaxy of clypeus (dorsal view); C, labral papillae (ventral view); D, head dorsal chaetotaxy and eyes (dorsal view, left side); E, labial papillae E (ventral view, right side); F, complete postlabial chaetotaxy (ventral view, right side)." figureDoi="http://doi.org/10.5281/zenodo.6410957" httpUri="https://zenodo.org/record/6410957/files/figure.png" pageId="15" pageNumber="356">9C</figureCitation>
