<paragraph id="5D1336F5FFFBBD3EF4A1BB9E6079F84B" blockId="5.[136,1452,1447,2086]" box="[189,1082,1987,2014]" pageId="5" pageNumber="31">
<emphasis id="6FD8EAE7FFFBBD3EF4A1BB9E650BF848" bold="true" box="[189,328,1988,2014]" pageId="5" pageNumber="31">Etymology:</emphasis>
