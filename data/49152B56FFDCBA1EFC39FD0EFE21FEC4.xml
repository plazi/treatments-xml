<heading id="9A4B2D2CFFDCBA1CFC39FD0EFB7EFD64" bold="true" box="[996,1267,701,725]" centered="true" fontSize="10" level="2" pageId="61" pageNumber="952" reason="2">
<emphasis id="F3C84652FFDCBA1CFC39FD0EFB7EFD64" bold="true" box="[996,1267,701,725]" pageId="61" pageNumber="952">
<taxonomicName id="06BCE1C3FFDCBA1CFC39FD0EFBE1FD64" authority="Schubart &amp; Ng, 2020" authorityName="Schubart &amp; Ng" authorityYear="2020" box="[996,1132,701,725]" class="Malacostraca" family="Sesarmidae" genus="Contusarma" kingdom="Animalia" order="Decapoda" pageId="61" pageNumber="952" phylum="Arthropoda" rank="genus" status="new genus">
