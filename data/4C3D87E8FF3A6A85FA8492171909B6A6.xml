<collectingCountry id="BC83766EFF3A6A85F82790DD1635BD97" box="[2011,2101,1668,1701]" name="Russia" pageId="193" pageNumber="955">Russia</collectingCountry>
(including 
<collectingRegion id="0650F81CFF3A6A85F71990DD1761BD97" box="[2277,2401,1668,1701]" country="Russia" name="Sakhalin" pageId="193" pageNumber="955">Sakhalin</collectingRegion>
I), N 
<collectingCountry id="BC83766EFF3A6A85F64790DD1B9ABDFE" name="Mongolia" pageId="193" pageNumber="955">Mongolia</collectingCountry>
