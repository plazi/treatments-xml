<taxonomicName authorityName="Kang &amp; Whitfield &amp; Owens &amp; Chen" authorityYear="2022" baseAuthorityName="Dabek &amp; Whitfield" baseAuthorityYear="2020" class="Insecta" family="Braconidae" genus="Neocardiochiles" higherTaxonomySource="GBIF" kingdom="Animalia" lsidName="Neocardiochiles kidonoi" order="Hymenoptera" pageId="0" pageNumber="41" phylum="Arthropoda" rank="species" species="kidonoi">Neocardiochiles kidonoi</taxonomicName>
