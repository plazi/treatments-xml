<subSubSection id="08D5527AC3EF44461587C415B109D332" pageId="null" pageNumber="725" type="description">
<paragraph id="A47218DEB8FAE326F4DE10463247B446" pageId="null" pageNumber="725">
Unterscheidet sich von 
<taxonomicName id="1E27721D3A77775C04114CCB812AC8F2" class="Magnoliopsida" family="Polygonaceae" genus="Rumex" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="725" phylum="Tracheophyta" rank="species" species="alpinus">
<emphasis id="68F56CA9A01B2B07E8646B6FB0977FAE" italics="true" pageId="null" pageNumber="725">R. alpinus</emphasis>
</taxonomicName>
(Nr.5) durch folgende Merkmale: 
<emphasis id="3764CFC3139E38EAA37A42C6438C7D62" italics="true" pageId="null" pageNumber="725">
<normalizedToken id="9B67CE5C42557AB6B237B1729ED71D66" originalValue="Grundständige" pageId="null" pageNumber="725">Grundstaendige</normalizedToken>
<normalizedToken id="5B129162C46347A1D8B67F9A0A05C44C" originalValue="Blätter" pageId="null" pageNumber="725">Blaetter</normalizedToken>
oval, bis 35 cm lang, 2
</emphasis>
<normalizedToken id="02696A97D108BE3D804D7FD4949B9D68" originalValue="½" pageId="null" pageNumber="725">1/2</normalizedToken>
<emphasis id="9E16C3488CBD40AD63FB96FFFDF98B7A" italics="true" pageId="null" pageNumber="725">-4</emphasis>
<normalizedToken id="15CF249A5B20DEC5C6C600CF6F7A0D0B" originalValue="½" pageId="null" pageNumber="725">1/2</normalizedToken>
<emphasis id="50B6094023E6A5B696C75D1571B49540" italics="true" pageId="null" pageNumber="725">
mal so lang wie breit, in den Stiel 
<normalizedToken id="A8FF82BC674B5138AEF9CFFF06EE624D" originalValue="verschmälert" pageId="null" pageNumber="725">verschmaelert</normalizedToken>
oder abgerundet.
</emphasis>
Innere 
<normalizedToken id="B7991E9C53BFA66CE11DC5CD3E1D2AC7" originalValue="Perigonblätter" pageId="null" pageNumber="725">Perigonblaetter</normalizedToken>
4,5-6 mm lang, 
<emphasis id="2BC2E240CBC6D4E79024B8C7E3141367" italics="true" pageId="null" pageNumber="725">stets deutlich breiter als lang</emphasis>
(6-8 mm breit). Frucht braun, matt, 2,5-3 mm lang. - 
<normalizedToken id="35ABA61D7046968B6AFFAE7329B23F25" originalValue="Blüte" pageId="null" pageNumber="725">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="0691939450BD6B3746DAFF475331F39E" pageId="null" pageNumber="725">
<emphasis id="0C080AC4D81C39692F09626155E6BC31" italics="true" pageId="null" pageNumber="725">Zytologische Angaben. 2n = 60:</emphasis>
Material aus Skandinavien (
<normalizedToken id="D74ABFF3EA3DD1528028250281192E5C" originalValue="Löve" pageId="null" pageNumber="725">Loeve</normalizedToken>
1942), aus Island (
<normalizedToken id="14C97281EB2B4C0A4B55EBD1EFC5F21E" originalValue="Löve" pageId="null" pageNumber="725">Loeve</normalizedToken>
und 
<normalizedToken id="9361396896C004D64D645A235E60798F" originalValue="Löve" pageId="null" pageNumber="725">Loeve</normalizedToken>
1956b), aus Kanada (Mulligan 1959). 
<emphasis id="1DD503D0244EF6B37D8481D4A0FB62D8" italics="true" pageId="null" pageNumber="725">2n = 80:</emphasis>
Material aus Japan (Kihara und Ono 1926).
</paragraph>
<paragraph id="D48896382F459C9395B70C658865D847" pageId="null" pageNumber="725">
<emphasis id="C898FF30431E0F07FF03A4707E1D6229" italics="true" pageId="null" pageNumber="725">Standort.</emphasis>
Kollin und montan. 
<normalizedToken id="D4BF38B1B5FEFE413A5944A6802E869D" originalValue="Nährstoffreiche" pageId="null" pageNumber="725">Naehrstoffreiche</normalizedToken>
<normalizedToken id="13B66D85B2C853A1367EB7E36F58439D" originalValue="Böden" pageId="null" pageNumber="725">Boeden</normalizedToken>
an 
<normalizedToken id="DEE52458F09CBA420283C415D318E7D8" originalValue="Gräben" pageId="null" pageNumber="725">Graeben</normalizedToken>
und 
<normalizedToken id="F3B364569AFD0A37F3902FFF50690F2F" originalValue="Wegrändern" pageId="null" pageNumber="725">Wegraendern</normalizedToken>
.
</paragraph>
<paragraph id="38B4C17E5B1D9666A4141209115D8FDF" pageId="null" pageNumber="725">
<emphasis id="9F8920FB47F4A93F299B9CB844E8F5B8" italics="true" pageId="null" pageNumber="725">Verbreitung. Eurosibirische Pflanze:</emphasis>
<normalizedToken id="CB37F03DC03E10B07DE2EB7BAF6DC0E4" originalValue="Nördliches" pageId="null" pageNumber="725">Noerdliches</normalizedToken>
<taxonomicName id="76397BA0D67B761A5EDE28D2FDF3FE1D" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="725" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
(Island, 
<normalizedToken id="0EAD0BD0047A6326D8D2C5242F18F65A" originalValue="nördliches" pageId="null" pageNumber="725">noerdliches</normalizedToken>
<normalizedToken id="A246733E512840C044BA5BA9EE1CA44A" originalValue="Großbritannien" pageId="null" pageNumber="725">Grossbritannien</normalizedToken>
, Norddeutschland, Skandinavien, Finnland, 
<normalizedToken id="FEEABF59F09C519BC48E51412D955630" originalValue="nördliches" pageId="null" pageNumber="725">noerdliches</normalizedToken>
<normalizedToken id="E031D363AB93A5F32E2D2F2EA8BB62ED" originalValue="Rußland" pageId="null" pageNumber="725">Russland</normalizedToken>
), weiter 
<normalizedToken id="1D22CD0208E74A88E4FE39F7334F214D" originalValue="südlich" pageId="null" pageNumber="725">suedlich</normalizedToken>
nur adventiv; Kaukasus, durch das 
<normalizedToken id="0CE034F348A780F35981CAF8E98860EF" originalValue="nördliche" pageId="null" pageNumber="725">noerdliche</normalizedToken>
Asien bis Ostasien; auch aus Nordamerika angegeben (eingeschleppt). - Im Gebiet adventiv bei 
<normalizedToken id="C42F2887BDD5A3DFC571815C62947C4D" originalValue="Zürich" pageId="null" pageNumber="725">Zuerich</normalizedToken>
und Buchs (St.Galler Rheintal), Savoyen (mehrfach).
</paragraph>
</subSubSection>
