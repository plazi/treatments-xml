<paragraph id="8927369C073CFF93FF97F52F69FE4CED" blockId="16.[99,1303,2608,3468]" box="[100,753,2774,2799]" pageId="16" pageNumber="249">
<taxonomicName id="4E984D1F073CFF93FF97F52F69154CED" authority="Merriam, 1895" authorityName="Merriam" authorityYear="1895" box="[100,538,2774,2799]" class="Mammalia" family="Geomyidae" genus="Heterogeomys" higherTaxonomySource="GBIF" kingdom="Animalia" order="Rodentia" pageId="16" pageNumber="249" phylum="Chordata" rank="subSpecies" species="cherrier" subSpecies="costaricensis">H. c. costaricensis Merriam, 1895</taxonomicName>
