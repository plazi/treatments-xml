<paragraph id="8927369C073CFF93FF97F5006F0D4D14" blockId="16.[99,1303,2608,3468]" box="[100,1026,2809,2838]" pageId="16" pageNumber="249">
<taxonomicName id="4E984D1F073CFF93FF97F500692B4D14" baseAuthorityName="J. A. Allen" baseAuthorityYear="1910" box="[100,548,2809,2838]" class="Mammalia" family="Geomyidae" genus="Orthogeomys" kingdom="Animalia" order="Rodentia" pageId="16" pageNumber="249" phylum="Chordata" rank="species" species="matagalpae">H. c. matagalpae J. A. Allen, 1910</taxonomicName>
