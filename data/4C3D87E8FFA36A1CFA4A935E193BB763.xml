<taxonomicName id="03944D7DFFA36A1CF7EB900E172ABD46" box="[2071,2346,1623,1652]" class="Mammalia" family="Vespertilionidae" genus="Eptesicus" kingdom="Animalia" order="Chiroptera" pageId="88" pageNumber="846" phylum="Chordata" rank="genus">Eptesicus ulapesensis</taxonomicName>
