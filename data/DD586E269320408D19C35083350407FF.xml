<subSubSection id="F7A7753C57EEB5E2B34390FC5BEC9049" pageId="null" pageNumber="479" type="description">
<paragraph id="909480347FA5540458FDB841B87D4586" pageId="null" pageNumber="479">
Strauch bis 2 m hoch. Zweige kahl, hin und her gebogen, lang, 
<normalizedToken id="A0DEBC90481E058D19FFE119806A4303" originalValue="überhängend" pageId="null" pageNumber="479">ueberhaengend</normalizedToken>
. 
<normalizedToken id="341D951A889BC76CBB90E3FE76550EF9" originalValue="Blätter" pageId="null" pageNumber="479">Blaetter</normalizedToken>
oval bis breit lanzettlich, 3-6 cm lang, 2-3mal so lang wie breit, am Grunde oft asymmetrisch, doppelt 
<normalizedToken id="A0BEBF84FBA048528232A20970528EAF" originalValue="gezähnt" pageId="null" pageNumber="479">gezaehnt</normalizedToken>
, oberseits 
<normalizedToken id="C10F3517F6D62717145A54B85BC137E3" originalValue="dunkelgrün" pageId="null" pageNumber="479">dunkelgruen</normalizedToken>
und meist kahl, unterseits 
<normalizedToken id="ADB11659597FD437F9585FD777C9CC2D" originalValue="blaugrün" pageId="null" pageNumber="479">blaugruen</normalizedToken>
, zerstreut behaart; Blattstiel 
<pageBreakToken id="EEE033B97DDBC245568A9FEDA08BD77C" pageId="null" pageNumber="479">bis</pageBreakToken>
1 cm lang. 
<emphasis id="9D3957BA4F595D9D041075A3EE5B7AED" italics="true" pageId="null" pageNumber="479">
<normalizedToken id="95E7D922646B57B5319A9CE13DAC25AA" originalValue="Blüten" pageId="null" pageNumber="479">Blueten</normalizedToken>
in 
<normalizedToken id="B9626E2B20572ECA9B1234B06D7ABD7F" originalValue="büscheligen" pageId="null" pageNumber="479">buescheligen</normalizedToken>
, halbkugeligen, 
<normalizedToken id="2729B3C46E657ED1BC353B1D43546159" originalValue="vielblütigen" pageId="null" pageNumber="479">vielbluetigen</normalizedToken>
, doldenartigen Trauben auf kurzen Seitentrieben 
<normalizedToken id="8C235E519D3894F289532695ED595FE9" originalValue="längs" pageId="null" pageNumber="479">laengs</normalizedToken>
der Zweige. Die meisten 
<normalizedToken id="E48F93833E3AF2DBF2DC34930BCE350D" originalValue="Blütenstiele" pageId="null" pageNumber="479">Bluetenstiele</normalizedToken>
wenigstens 1 an lang, kahl
</emphasis>
, Kelch 
<normalizedToken id="85AF7F2CB269EBCDE0617B8C051660C4" originalValue="außerseits" pageId="null" pageNumber="479">ausserseits</normalizedToken>
kahl; Kelchzipfel ca. 2 mm lang, 
<normalizedToken id="DE95CF3A3AEF49235F39CC642837B2C6" originalValue="rückwärts" pageId="null" pageNumber="479">rueckwaerts</normalizedToken>
gerichtet, innerseits bewimpert. 
<normalizedToken id="22C26529F93EF0AD77F0F5F1CB383618" originalValue="Kronblätter" pageId="null" pageNumber="479">Kronblaetter</normalizedToken>
rundlich, im Durchmesser 4-6 mm, 
<normalizedToken id="FC7335A447C0DB3B7D270B482400401B" originalValue="weiß" pageId="null" pageNumber="479">weiss</normalizedToken>
. - 
<normalizedToken id="77DD012139344613AD9DE3D913814701" originalValue="Blüte" pageId="null" pageNumber="479">Bluete</normalizedToken>
: 
<normalizedToken id="93AD4AABDA4EEE39B26F2A9C7C520BA1" originalValue="Frühling" pageId="null" pageNumber="479">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="467AB435064950D1D9E3F7D207165314" pageId="null" pageNumber="479">
<emphasis id="5424B2163C5F5FF0EE371F17683CE494" italics="true" pageId="null" pageNumber="479">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="012D5993E96ED7AA2F4A11CC53FDC08A" italics="true" pageId="null" pageNumber="479">36:</emphasis>
Material aus botanischen 
<normalizedToken id="8D93E89D063963374528741D4EB48DC2" originalValue="Gärten" pageId="null" pageNumber="479">Gaerten</normalizedToken>
(Sax 1936).
</paragraph>
<paragraph id="63C0871BC0070E77F8BE491C70E30A2F" pageId="null" pageNumber="479">
<emphasis id="1382AC691E9014301F45E8BB0779E4BD" italics="true" pageId="null" pageNumber="479">Standort.</emphasis>
Kollin. 
<normalizedToken id="843E85ED3F81F5D16C27C8A9B248C613" originalValue="Schuttplätze" pageId="null" pageNumber="479">Schuttplaetze</normalizedToken>
, 
<normalizedToken id="44AFB5E8CD00ED93CC777F4443B4764D" originalValue="Gebüsche" pageId="null" pageNumber="479">Gebuesche</normalizedToken>
.
</paragraph>
<paragraph id="81F9C3D7C9F9383F862E4E3E2DF3FE03" pageId="null" pageNumber="479">
<emphasis id="FAE5A217AC2567FE94D0F094BB84592D" italics="true" pageId="null" pageNumber="479">
Verbreitung. 
<normalizedToken id="3779BEA50101EDE8A4345DFCA9B8D2C1" originalValue="Südosteuropäisch-asiatische" pageId="null" pageNumber="479">Suedosteuropaeisch-asiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="68522F1E88424C49997CB3F3FD4C6804" originalValue="Südostalpen" pageId="null" pageNumber="479">Suedostalpen</normalizedToken>
(von Friaul 
<normalizedToken id="946DAA5CC368EFC6D1877AF5129DA304" originalValue="ostwärts" pageId="null" pageNumber="479">ostwaerts</normalizedToken>
), Gebirge der Balkanhalbinsel, Karpaten; Sibirien, Zentral- und Ostasien (
<normalizedToken id="27462C60777C81DC1B6B0CA6FBDE33A6" originalValue="ostwärts" pageId="null" pageNumber="479">ostwaerts</normalizedToken>
bis Japan). - Im Gebiet selten, verwilderte Gartenpflanze.
</paragraph>
</subSubSection>
