<subSubSection id="E48973422A29EAA71E812FF2FA54DF89" pageId="null" pageNumber="282" type="description">
<paragraph id="AFF31A81D395789B94D7214E2EC5AF7A" pageId="null" pageNumber="282">
Unterscheidet sich durch folgende Merkmale von 
<taxonomicName id="CBADC8F607028B58B593E2C41AD74047" class="Liliopsida" family="Poaceae" genus="Melica" kingdom="Plantae" order="Poales" pageId="null" pageNumber="282" phylum="Tracheophyta" rank="species" species="ciliata">
<emphasis id="EF8E1A51D18D101C04D3F86847638DEE" italics="true" pageId="null" pageNumber="282">M. ciliata</emphasis>
</taxonomicName>
(Nr. 1): Stengel oft 
<normalizedToken id="D4F5DE15F1C79056F7A376E1D1E314F0" originalValue="überhängend" pageId="null" pageNumber="282">ueberhaengend</normalizedToken>
oder an der Spitze nickend; 
<emphasis id="95D23E50259A4E105CB26126664AC1B2" italics="true" pageId="null" pageNumber="282">
Blattscheiden der untersten 
<normalizedToken id="4D18913A6EB1C364213948712F8829E3" originalValue="Stengelblätter" pageId="null" pageNumber="282">Stengelblaetter</normalizedToken>
abstehend flaumig behaart;
</emphasis>
Blattspreiten 
<normalizedToken id="EE038FE819ED30F6143028A298B048F9" originalValue="±" pageId="null" pageNumber="282">+/-</normalizedToken>
schlaff, meist flach, 
<emphasis id="CAE30E6EAB89B3A0C100C1AF223E490A" italics="true" pageId="null" pageNumber="282">
unterseits mit scharf vortretendem Kiel; 
<normalizedToken id="EF45BC168EF66DC79A527CBCDFF8F9A6" originalValue="Blütenstand" pageId="null" pageNumber="282">Bluetenstand</normalizedToken>
allseitswendig, dicht
</emphasis>
(
<emphasis id="44B0E48E8EA5AD0874BB41FD6D637671" italics="true" pageId="null" pageNumber="282">
<normalizedToken id="7467A52AA53E9929C050829947C027A0" originalValue="Blütenstandsachse" pageId="null" pageNumber="282">Bluetenstandsachse</normalizedToken>
meist verdeckt
</emphasis>
)
<emphasis id="9BC08B9FAEEFE58F076C200A8616B69B" italics="true" pageId="null" pageNumber="282">
; unterhalb des 
<normalizedToken id="341D1DE2DEE1329BF837C8C7D8BEC967" originalValue="Blütenstandes" pageId="null" pageNumber="282">Bluetenstandes</normalizedToken>
mit 2 oder 3
</emphasis>
(
<emphasis id="02925CF9A20048AAA5ACD8309362579C" italics="true" pageId="null" pageNumber="282">selten 1 oder 4</emphasis>
) 
<emphasis id="7EB3EEF6C5921AA7BC3CC603457B33F8" italics="true" pageId="null" pageNumber="282">
0,05-0,2 mm langen Schuppen, die keine 
<normalizedToken id="E3303E694D588A641D3CB7E30EB8F5F8" originalValue="Rispenäste" pageId="null" pageNumber="282">Rispenaeste</normalizedToken>
tragen; untere 
<normalizedToken id="062987FE62383D1EB3C7D5A16DD5C6E5" originalValue="Hüllspelze" pageId="null" pageNumber="282">Huellspelze</normalizedToken>
nur
</emphasis>
⅓-⅔ 
<emphasis id="2A66812027A06AFB5CC59757C1C8B648" italics="true" pageId="null" pageNumber="282">
so lang wie die obere 
<normalizedToken id="35D2FCBE132078506B2D6299165F21C1" originalValue="Hüllspelze" pageId="null" pageNumber="282">Huellspelze</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="1CF9B59E970253FFA8CE72351EA36C9D" originalValue="Blüte" pageId="null" pageNumber="282">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="DE5A2FDA8DBD0A4DB32032407095BBC1" pageId="null" pageNumber="282">
<emphasis id="1BC9756BD99CB7EC3AEBF0882F38AAAB" italics="true" pageId="null" pageNumber="282">Zytologische Angaben. 2n ca. 30</emphasis>
(Doulat aus 
<normalizedToken id="3B474BE719000D27FCD4FF9550DBF6B1" originalValue="Löve" pageId="null" pageNumber="282">Loeve</normalizedToken>
und 
<normalizedToken id="FBED63C524FDDD5A401330C29924EDBA" originalValue="Löve" pageId="null" pageNumber="282">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="96EDEBE74D49CB3C47D8D8402F58061D" pageId="null" pageNumber="282">
<emphasis id="D7BCE627E9BDFE9B6B3B63E772D16557" italics="true" pageId="null" pageNumber="282">Standort.</emphasis>
Kollin und montan, selten subalpin. Trockene, steinige 
<normalizedToken id="11D79428E6DFF48176A3EC3250A543CC" originalValue="Böden" pageId="null" pageNumber="282">Boeden</normalizedToken>
in niederschlagsarmen Gegenden. Trokkenwiesen, 
<taxonomicName id="7DD355BA6828E6F591160CDCE6F10BCA" class="Magnoliopsida" family="Berberidaceae" genus="Berberis" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="282" phylum="Tracheophyta" rank="genus">
<emphasis id="529C5C7F780DFDCF1ED2C0E0B34BCA73" italics="true" pageId="null" pageNumber="282">Berberis</emphasis>
</taxonomicName>
<normalizedToken id="E308AAA802F976480215F3E0E3460952" originalValue="gebüsch" pageId="null" pageNumber="282">gebuesch</normalizedToken>
.
</paragraph>
<paragraph id="2336ECF307BF333A2A1BF9329F186FB5" pageId="null" pageNumber="282">
<emphasis id="3C53E251FD2DB44C978E1F1F4FC29B21" italics="true" pageId="null" pageNumber="282">
Verbreitung. 
<normalizedToken id="40C02DC3E9C84667DCFD2306F34C7663" originalValue="Osteuropäisch-westasiatische" pageId="null" pageNumber="282">Osteuropaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="A5ADA1698FE95C45A92561728AFAF723" originalValue="Westwärts" pageId="null" pageNumber="282">Westwaerts</normalizedToken>
einzelne Fundstellen durch Mitteleuropa bis ins Gebiet der Loire und Korsika; 
<normalizedToken id="E2AF4BD25DAC61E718123B60908D91FE" originalValue="ostwärts" pageId="null" pageNumber="282">ostwaerts</normalizedToken>
bis in das Tienschangebirge und in den Altai. Verbreitungskarte von Meusel (1964). - Im Gebiet: Vogesen, 
<normalizedToken id="7ADED2F685750A465F5F503A28EBE57F" originalValue="Elsaß" pageId="null" pageNumber="282">Elsass</normalizedToken>
, Hegau, Wallis (Zermatt), Unterengadin (Guarda bis Martinsbruck), 
<normalizedToken id="BE7EF27CC1040A97E928DA3F7BC31484" originalValue="Münstertal" pageId="null" pageNumber="282">Muenstertal</normalizedToken>
, Puschlav, Veltlin (bei Sondrio), Bormio, Ortlergebiet (Cles), oberer Vintschgau (Taufers bis 
<normalizedToken id="C7474531C64872EC186DB16A311808E8" originalValue="Göflau" pageId="null" pageNumber="282">Goeflau</normalizedToken>
).
</paragraph>
<paragraph id="8CCDDBC962795805C0FE370E96B45F7A" pageId="null" pageNumber="282">
<emphasis id="7198855285294EA9D42AB2AB58F60EA4" italics="true" pageId="null" pageNumber="282">Bemerkungen.</emphasis>
Siehe unter 
<taxonomicName id="54F31803424C4CD4E2C476C30B80F13C" class="Liliopsida" family="Poaceae" genus="Melica" kingdom="Plantae" order="Poales" pageId="null" pageNumber="282" phylum="Tracheophyta" rank="species" species="ciliata">
<emphasis id="087E7B34F76AE18BDC4E7AAAF7AF3F66" italics="true" pageId="null" pageNumber="282">M. ciliata</emphasis>
</taxonomicName>
(Nr. 1).
</paragraph>
</subSubSection>
