<quantity id="4CEC9B51C67AA208FA9EF9F8FA0C45CF" box="[1382,1507,1634,1673]" metricMagnitude="2" metricUnit="m" metricValue="1.52" pageId="12" pageNumber="239" unit="m" value="152.0">152 m</quantity>
