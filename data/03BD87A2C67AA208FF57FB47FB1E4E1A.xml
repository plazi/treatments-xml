“Akanti [= Hkamti], upper Chindwin River, Upper 
<collectingCountry id="F3037624C67AA208FA05F9B4F96F4513" box="[1533,1664,1582,1621]" name="Myanmar" pageId="12" pageNumber="239">Burma</collectingCountry>
