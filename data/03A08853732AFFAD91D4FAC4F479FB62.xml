<collectionCode id="ED18A1807327FFAD93B4FE2BF490FDFF" box="[672,743,491,517]" country="USA" httpUri="http://grbio.org/cool/jekt-x82m" name="Florida State Collection of Arthropods, The Museum of Entomology" pageId="10" pageNumber="9" type="Museum">FSCA</collectionCode>
