</date>
, 
<collectorName id="26FC5C937327FFAD9093FE2BF79DFDFF" box="[391,490,491,517]" pageId="10" pageNumber="9">Skillman</collectorName>
and 
<collectorName id="26FC5C937327FFAD9335FE2BF41BFDFF" box="[545,620,491,517]" pageId="10" pageNumber="9">Limon</collectorName>
