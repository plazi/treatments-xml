</paragraph>
<paragraph id="8927369C0738FF97FF95FEB16A024793" blockId="20.[98,1307,293,1314]" pageId="20" pageNumber="253">
<taxonomicName id="4E984D1F0738FF97FF95FEB16AEB476B" authority="Merriam, 1892" authorityName="Merriam" authorityYear="1892" baseAuthorityName="Merriam" baseAuthorityYear="1892" box="[102,484,328,361]" class="Mammalia" family="Geomyidae" genus="Cratogeomys" kingdom="Animalia" order="Rodentia" pageId="20" pageNumber="253" phylum="Chordata" rank="subSpecies" species="fumosus" subSpecies="fumosus">C.f.fumosusMerriam,1892—WMichoacanandadjacentportionsofJaliscoandColima,Mexico.</taxonomicName>
</paragraph>
<paragraph id="8927369C0738FF97FF95FE62680F47E2" blockId="20.[98,1307,293,1314]" pageId="20" pageNumber="253">
