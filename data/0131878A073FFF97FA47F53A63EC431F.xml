</paragraph>
<paragraph id="8927369C0738FF97FF95FE1368404405" blockId="20.[98,1307,293,1314]" box="[102,847,490,519]" pageId="20" pageNumber="253">
<taxonomicName id="4E984D1F0738FF97FF95FE136AFC4405" authority="Goldman, 1939" authorityName="Goldman" authorityYear="1939" baseAuthorityName="Goldman" baseAuthorityYear="1939" box="[102,499,490,519]" class="Mammalia" family="Geomyidae" genus="Cratogeomys" kingdom="Animalia" order="Rodentia" pageId="20" pageNumber="253" phylum="Chordata" rank="subSpecies" species="fumosus" subSpecies="imparilis">C.f.imparilisGoldman,1939—CMichoacan,Mexico.</taxonomicName>
