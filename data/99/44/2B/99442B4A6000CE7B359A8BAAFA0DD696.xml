<figureCitation box="[733,760,602,624]" captionStart="FIGURES 39–40" captionStartId="13.[151,264,1900,1924]" captionTargetBox="[205,1382,209,1864]" captionTargetId="figure-15@13.[195,1393,199,1876]" captionTargetPageId="13" captionText="FIGURES 39–40. Lethierium cedricolum (Dlabola, 1989), male, Timhadit. 39—face; 40—head and pronotum, dorsal view. Out of scale." pageId="2" pageNumber="519">39</figureCitation>
