<paragraph blockId="18.[151,520,1424,1487]" box="[151,463,1460,1487]" pageId="18" pageNumber="535">
(
<figureCitation box="[159,288,1460,1486]" captionStart="FIGURES 16–19" captionStartId="8.[151,264,1521,1545]" captionTargetBox="[151,1433,273,1498]" captionTargetId="figure-86@8.[151,1435,273,1500]" captionTargetPageId="8" captionText="FIGURES 16–19. Lethierium carinatum sp. nov., female paratype, Bou Naceur. 16—dorsal view; 17—lateral view; 18—frontal view; 19—caudal view. Scale bar—1 mm." figureDoi="http://doi.org/10.5281/zenodo.6691465" httpUri="https://zenodo.org/record/6691465/files/figure.png" pageId="18" pageNumber="535">Figs 16–19</figureCitation>
, 
<figureCitation box="[300,372,1460,1487]" captionStart-0="FIGURES 53–55" captionStart-1="FIGURES 56–63" captionStartId-0="16.[151,264,1566,1590]" captionStartId-1="17.[151,264,1697,1721]" captionTargetBox-0="[161,1429,191,1534]" captionTargetBox-1="[161,1425,532,1642]" captionTargetId-0="figure-28@16.[151,1436,181,1542]" captionTargetId-1="figure-160@17.[151,1436,524,1655]" captionTargetPageId-0="16" captionTargetPageId-1="17" captionText-0="FIGURES 53–55. Lethierium carinatum sp. nov., female paratype, Bou Naceur. 53—face; 54—eye, scapus, pedicel, and paranotal lobe, frontal view; 55—head and pronotum, dorsal view. Out of scale." captionText-1="FIGURES 56–63. Lethierium carinatum sp. nov., holotype, male genitalia. 56—pygofer, lateral view; 57—anal tube, lateral view; 58—anal tube, dorsal view; 59—penis and connective, lateral view; 60—connective, caudal view; 61—penis, ventral view; 62—style, lateral view; 63—style, dorsal view. Out of scale." figureDoi-0="http://doi.org/10.5281/zenodo.6691503" figureDoi-1="http://doi.org/10.5281/zenodo.6691509" httpUri-0="https://zenodo.org/record/6691503/files/figure.png" httpUri-1="https://zenodo.org/record/6691509/files/figure.png" pageId="18" pageNumber="535">53–63</figureCitation>
, 
<figureCitation box="[384,455,1460,1487]" captionStart="FIGURES 64–70" captionStartId="18.[151,264,1215,1239]" captionTargetBox="[160,1427,187,1184]" captionTargetId="figure-28@18.[151,1436,181,1192]" captionTargetPageId="18" captionText="FIGURES 64–70. Lethierium spp., female. 64—L. cedricolum (Dlabola, 1989), Ras el ma, sternite VII, dorsal view; 65—same, ventral view; 66—L. reiberi (Lethierry, 1878), Mékalis, sternite VII, dorsal view; 67—L. juniperi (Bergevin, 1915), Aïn Kerma, sternite VII, dorsal view; 68—same, ventral view; 69—L. carinatum sp. nov., paratype, Bou Naceur, anal tube, dorsal view; 70—L. carinatum sp. nov., paratype, Bou Naceur, sternite VII, dorsal view." figureDoi="http://doi.org/10.5281/zenodo.6691513" httpUri="https://zenodo.org/record/6691513/files/figure.png" pageId="18" pageNumber="535">69, 70</figureCitation>
