<collectingRegion box="[652,718,618,644]" country="Algeria" name="Tiaret" pageId="6" pageNumber="523">Tiaret</collectingRegion>
in central north 
<collectingCountry box="[907,991,618,644]" name="Algeria" pageId="6" pageNumber="523">Algeria</collectingCountry>
and the 
<typeStatus box="[1091,1139,619,645]" pageId="6" pageNumber="523">type</typeStatus>
series was collected from 
<taxonomicName box="[151,383,654,680]" class="Pinopsida" family="Cupressaceae" genus="Juniperus" kingdom="Plantae" order="Pinales" pageId="6" pageNumber="523" phylum="Tracheophyta" rank="species" species="oxycedrus">
<emphasis box="[151,383,654,680]" italics="true" pageId="6" pageNumber="523">Juniperus oxycedrus</emphasis>
</taxonomicName>
L. (
<taxonomicName box="[430,586,654,680]" class="Pinopsida" family="Cupressaceae" kingdom="Plantae" order="Pinales" pageId="6" pageNumber="523" phylum="Tracheophyta" rank="family">Cupressaceae</taxonomicName>
) at 
<quantity box="[629,717,654,681]" metricMagnitude="3" metricUnit="m" metricValue="1.1" pageId="6" pageNumber="523" unit="m" value="1100.0">1100 m</quantity>
. a.s.l. (
<bibRefCitation author="Bergevin" box="[795,967,654,681]" pageId="6" pageNumber="523" pagination="71 - 77" refId="ref8660" refString="Bergevin, de E. (1915) Description de deux espece nouvelles d' Hysteropterum (Hemipt., Issidae) de l'Afrique du Nord. Bulletin de la Societe d'Histoire Naturelle de l'Afrique du Nord, 7, 71 - 77." type="journal article" year="1915">Bergevin 1915</bibRefCitation>
