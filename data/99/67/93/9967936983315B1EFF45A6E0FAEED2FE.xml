<collectingCountry box="[725,879,1975,2001]" name="India" pageId="5" pageNumber="125">Lakshadweep</collectingCountry>
Sea, 
<collectingCountry box="[940,998,1975,2001]" name="India" pageId="5" pageNumber="125">India</collectingCountry>
</paragraph>
</subSubSection>
<subSubSection box="[199,1368,2011,2038]" pageId="5" pageNumber="125" type="etymology">
<paragraph blockId="5.[151,1437,1615,2038]" box="[199,1368,2011,2038]" pageId="5" pageNumber="125">
<emphasis bold="true" box="[199,328,2012,2038]" pageId="5" pageNumber="125">Etymology</emphasis>
: The species is named 
<taxonomicName authorityName="Augustina &amp; Sreeram &amp; Sukumaran &amp; Jose" authorityYear="2022" box="[588,705,2011,2037]" class="Myxini" family="Myxinidae" genus="Eptatretus" kingdom="Animalia" order="Myxiniformes" pageId="5" pageNumber="125" phylum="Chordata" rank="species" species="wadgensis">
<emphasis box="[588,705,2011,2037]" italics="true" pageId="5" pageNumber="125">wadgensis</emphasis>
</taxonomicName>
alluding to the geographical region where it was collected.
</paragraph>
</subSubSection>
