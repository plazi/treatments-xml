<subSubSection id="7352CE7610F77FA6D96CAD321EEEA30B" pageId="null" pageNumber="532" type="nomenclature">
<paragraph id="016F03F3DCA4E7F2E066F111ED5C0A35" pageId="null" pageNumber="532">
<taxonomicName id="EDB6CFF45B5C46DA9CF921F481310A7B" authority="(L.) Bartal." class="Magnoliopsida" family="Fabaceae" genus="Medicago" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="532" phylum="Tracheophyta" rank="species" species="orbicularis">
Medicago 
<normalizedToken id="1BD34E8CB9D7EC2899A8ED4AD503E44C" originalValue="orbiculáris" pageId="null" pageNumber="532">orbicularis</normalizedToken>
(
<authorityName id="86AD0B534270583F6717022273875146" pageId="null" pageNumber="532">L.</authorityName>
) Bartal.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="90D65F986AC0D515E62D56C83D5426CF" pageId="null" pageNumber="532" type="vernacular_names">
<paragraph id="08699F712B8BCE29B35E5DE236D7B6EC" pageId="null" pageNumber="532">Scheiben-Schneckenklee</paragraph>
</subSubSection>
</title>
<subSubSection id="C78F1892E91BEA18C4E03A278E5F2B38" pageId="null" pageNumber="532" type="description">
<paragraph id="160DA00DFFA1CCD5FCE01DE16B5EFE04" pageId="null" pageNumber="532">
1 
<normalizedToken id="538A2E553C3F95A9C7F5A9C2611D65F4" originalValue="jährig" pageId="null" pageNumber="532">jaehrig</normalizedToken>
; 10-30 cm hoch. Stengel niederliegend oder aufsteigend, verzweigt, kahl oder mit einzelnen Haaren. 
<normalizedToken id="FD75D33828C4A06EDF5E4CCC90A900A9" originalValue="Teilblätter" pageId="null" pageNumber="532">Teilblaetter</normalizedToken>
1-2mal so lang wie breit, meist kahl. 
<emphasis id="D6B01D99154BCDBFEDDB5D559EAB4950" italics="true" pageId="null" pageNumber="532">
<normalizedToken id="D276ED28383D9A0A2527E15EA3587021" originalValue="Nebenblätter" pageId="null" pageNumber="532">Nebenblaetter</normalizedToken>
fast bis zum Mittelnerv 
<normalizedToken id="671B865D126997B1C958C2C623D9F825" originalValue="kammförmig" pageId="null" pageNumber="532">kammfoermig</normalizedToken>
geteilt.
</emphasis>
<normalizedToken id="1892AB73823774B656B87A1DF5B218D2" originalValue="Blütenstand" pageId="null" pageNumber="532">Bluetenstand</normalizedToken>
1-3 
<normalizedToken id="5DEA6F31962190A02DDA1110A611414F" originalValue="blütig" pageId="null" pageNumber="532">bluetig</normalizedToken>
. 
<emphasis id="801F70AD3BFF4B81A0FFBBBAA0184375" italics="true" pageId="null" pageNumber="532">Krone 3,5-5 mm lang</emphasis>
, gelb. 
<emphasis id="B3FC31675FC6A367D5002E55D6859CDD" italics="true" pageId="null" pageNumber="532">Frucht mit 3-7 schraubenartigen Windungen</emphasis>
, 
<normalizedToken id="7BE24164E9D7698A2763431026410C8D" originalValue="scheibenförmig" pageId="null" pageNumber="532">scheibenfoermig</normalizedToken>
bis korkzieherartig, mit 
<normalizedToken id="51AC0F2151F1550BB2507A0F00C32412" originalValue="Zwischenräumen" pageId="null" pageNumber="532">Zwischenraeumen</normalizedToken>
zwischen den Windungen, 5-10 mm hoch, 
<emphasis id="B41D438B29627D1616755BCD2E52CB26" italics="true" pageId="null" pageNumber="532">10-18 mm im Durchmesser, ohne Stacheln</emphasis>
, kahl oder 
<normalizedToken id="F672B450141650B1EA2BCC6DA18DBD20" originalValue="drüsig" pageId="null" pageNumber="532">druesig</normalizedToken>
behaart. - 
<normalizedToken id="9C1521402598F6A30C59ECB866C6DFD4" originalValue="Blüte" pageId="null" pageNumber="532">Bluete</normalizedToken>
: 
<normalizedToken id="9D8A23887C261C17A0EB3BC9B311F3AA" originalValue="Später" pageId="null" pageNumber="532">Spaeter</normalizedToken>
<normalizedToken id="AF0AEFFB415F9D09ABE04AA5F82884FA" originalValue="Frühling" pageId="null" pageNumber="532">Fruehling</normalizedToken>
und 
<normalizedToken id="847BCFC3ED4C1D92173A794DAB6C370E" originalValue="früher" pageId="null" pageNumber="532">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="199D7D1CC5A89F986F5CE3011FAB794E" pageId="null" pageNumber="532">
<emphasis id="38A6E40118B95C8FC89ED5B56A86776D" italics="true" pageId="null" pageNumber="532">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D4B320E3A027AF381023EF0BCF859DAB" italics="true" pageId="null" pageNumber="532">16:</emphasis>
Material aus dem Mittelmeergebiet und botanischen 
<normalizedToken id="50B7F9D3CD88A59981373F3794415A79" originalValue="Gärten" pageId="null" pageNumber="532">Gaerten</normalizedToken>
(Ghimpu 1928, Fryver 1930, Larsen 1955b, Heyn 1956, Oldemeyer 1956, Clement 1962, Mariani 1963), aus Australien (Simon und Simon 1965).
</paragraph>
<paragraph id="76CC78C67FA5E79517C7A0AF7231DF1B" pageId="null" pageNumber="532">
<emphasis id="B71BBFC2C4AFFAE49FB0C98F13FD8109" italics="true" pageId="null" pageNumber="532">Standort.</emphasis>
Kollin. Trockene, lockere 
<normalizedToken id="40C1AA32DAD8914A70007A022D740633" originalValue="Böden" pageId="null" pageNumber="532">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="AA5750A296107A57F864912FC66D9670" originalValue="Äcker" pageId="null" pageNumber="532">Aecker</normalizedToken>
, Weinberge, 
<normalizedToken id="2B090EA9AEDE060B0652C065424544A7" originalValue="Schuttplätze" pageId="null" pageNumber="532">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="D8673CC1439022210EBD0A9586C12295" pageId="null" pageNumber="532">
<emphasis id="F8606A49023D3FE3D85A3C4B667B9A27" italics="true" pageId="null" pageNumber="532">
Verbreitung. 
<normalizedToken id="3A018602074D1CCE99BE0EBF1C2957D5" originalValue="Mediterran-südwestasiatische" pageId="null" pageNumber="532">Mediterran-suedwestasiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="92F20DB37987DC61FDDFB6A4355D697F" originalValue="Südeuropa" pageId="null" pageNumber="532">Suedeuropa</normalizedToken>
(
<normalizedToken id="92D50FD451E17DDE88C835CDC4A255A3" originalValue="nordwärts" pageId="null" pageNumber="532">nordwaerts</normalizedToken>
bis Mittelfrankreich, Alpen, Donaubecken, 
<normalizedToken id="38EC845A8A839CDA8585E4E713F8D6FF" originalValue="Südrußland" pageId="null" pageNumber="532">Suedrussland</normalizedToken>
); 
<normalizedToken id="BBBD441525C097E5FD8F50BB5A2398F0" originalValue="Südwestasien" pageId="null" pageNumber="532">Suedwestasien</normalizedToken>
(
<normalizedToken id="3D8CB0331AF6ACA63945B4CB2654C920" originalValue="ostwärts" pageId="null" pageNumber="532">ostwaerts</normalizedToken>
bis Westhimalaja); Nord- und Ostafrika; Kanaren. - Im Gebiet vielleicht nur eingeschleppt: Savoyen (Maurienne), Aostatal (Aosta), Bergamasker Alpen (Valtesse, Bergamo, Predore); auch sonst gelegentlich adventiv.
</paragraph>
</subSubSection>
