<typeStatus id="8D228851FFF8FF88FC8361BEFC42FA60" box="[887,931,1500,1521]" pageId="9" pageNumber="1226">type</typeStatus>
locality in the Qinling 
<collectingRegion id="905DF811FFF8FF88FEF2619BFEDAF99E" box="[262,315,1529,1551]" country="Myanmar" name="Shan" pageId="9" pageNumber="1226">Shan</collectingRegion>
