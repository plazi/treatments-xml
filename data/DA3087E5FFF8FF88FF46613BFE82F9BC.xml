<geoCoordinate id="37AD5034FFF8FF88FE9C61C2FE5BFA27" box="[360,442,1440,1462]" degrees="103" direction="east" minutes="46" orientation="longitude" pageId="9" pageNumber="1226" precision="925" value="103.76667">103°46'E</geoCoordinate>
