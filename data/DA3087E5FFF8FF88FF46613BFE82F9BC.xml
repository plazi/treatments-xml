<quantity id="95619B16FFF8FF88FE3361C2FDEEFA24" box="[455,527,1440,1461]" metricMagnitude="3" metricUnit="m" metricValue="2.7" pageId="9" pageNumber="1226" unit="m" value="2700.0">2700 m</quantity>
