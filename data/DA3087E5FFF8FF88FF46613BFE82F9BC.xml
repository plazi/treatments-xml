<collectingRegion id="905DF811FFF8FF88FEB2619BFE79F99E" box="[326,408,1529,1551]" country="China" name="Shaanxi" pageId="9" pageNumber="1226">Shaanxi</collectingRegion>
(
<bibRefCitation id="36084B02FFF8FF88FE53619BFDA9F99E" author="SMETANA A" box="[423,584,1529,1551]" pageId="9" pageNumber="1226" pagination="53 - 57" refId="ref4258" refString="SMETANA A. (2001): A new species of Deinopteroloma JANSSON, 1946 from China, with comments on D. chiangi SMETANA, 1990 from Taiwan (Coleoptera: Staphylinidae: Omaliinae). - Koleopterologische Rundschau 71: 53 - 57." type="journal article" year="2001">SMETANA 2001</bibRefCitation>
