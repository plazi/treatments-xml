<subSubSection id="B2D6B2DC4132E9366B9DD2E0FB7426F9" box="[199,1187,1159,1184]" pageId="26" pageNumber="27" type="etymology">
<paragraph id="FA73E1574132E9366B9DD2E0FB7426F9" blockId="26.[151,1436,151,1871]" box="[199,1187,1159,1184]" pageId="26" pageNumber="27">
<emphasis id="C8B83D454132E9366B9DD2E0FE9126C6" bold="true" box="[199,326,1160,1184]" pageId="26" pageNumber="27">Etymology</emphasis>
. The species is named after the strongly suspected host plant, 
<taxonomicName id="3DCC9AD44132E93668A5D2E0FB4C26C6" box="[1023,1179,1160,1184]" class="Pinopsida" family="Pinaceae" genus="Pinus" kingdom="Plantae" order="Pinales" pageId="26" pageNumber="27" phylum="Tracheophyta" rank="species" species="sibirica">
