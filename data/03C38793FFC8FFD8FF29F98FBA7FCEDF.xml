<taxonomicName id="4C6A4D06FFCFFFD9FD94F892BDD6C892" box="[565,739,1919,1940]" class="Magnoliopsida" family="Urticaceae" genus="Urtica" kingdom="Plantae" order="Rosales" pageId="28" pageNumber="249" phylum="Tracheophyta" rank="species" species="laetevirens">
