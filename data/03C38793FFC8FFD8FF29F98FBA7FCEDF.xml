<taxonomicName id="4C6A4D06FFCFFFD9FCFAF892BC82C892" box="[859,951,1919,1940]" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="28" pageNumber="249" phylum="Tracheophyta" rank="species" species="undetermined">
