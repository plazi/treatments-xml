<subSubSection id="60816A6559B504E02B87745688452869" pageId="null" pageNumber="589" type="description">
<paragraph id="5536AC977DB4EE35DE1E53F7F156DC5C" pageId="null" pageNumber="589">
<normalizedToken id="1D7A1F53FE1D3EE76777E300AE1A60BF" originalValue="Teilblätter" pageId="null" pageNumber="589">Teilblaetter</normalizedToken>
2-3mal so lang wie breit, 
<emphasis id="D9BC5AE9C6A824DD97F50EB767DFC902" italics="true" pageId="null" pageNumber="589">
auch die obern vorn deutlich ausgerandet; Haare kaum 
<normalizedToken id="822F319D46DF800C5C68D02CAC636A01" originalValue="über" pageId="null" pageNumber="589">ueber</normalizedToken>
1 mm lang; 
<normalizedToken id="5CC5E5CFA470E73AFC2C35C2BA918AB2" originalValue="Nebenblätter" pageId="null" pageNumber="589">Nebenblaetter</normalizedToken>
</emphasis>
<normalizedToken id="BE3D4AC5551AFA26F18A7B82F247D11D" originalValue="¼-½" pageId="null" pageNumber="589">1/4-1/2</normalizedToken>
<emphasis id="5A6891E9B9735AD67920F03A9A1A6E58" italics="true" pageId="null" pageNumber="589">
so lang wie die untern 
<normalizedToken id="031220AC7EF86BF20454639A6F08D4B0" originalValue="Teilblätter" pageId="null" pageNumber="589">Teilblaetter</normalizedToken>
, nur mit kleiner 
<normalizedToken id="783F6D6C252DFE6A722E5FE71B9F5343" originalValue="Nektardrüse" pageId="null" pageNumber="589">Nektardruese</normalizedToken>
</emphasis>
(
<emphasis id="D7948BF8FEC16CC7510B7FEE450E4AA4" italics="true" pageId="null" pageNumber="589">kaum</emphasis>
⅙ 
<emphasis id="4C2CC49F6CED3EF47300C8525610CE51" italics="true" pageId="null" pageNumber="589">
der 
<normalizedToken id="DB354AE2E0905551CE00096290C56F1B" originalValue="Nebenblattfläche" pageId="null" pageNumber="589">Nebenblattflaeche</normalizedToken>
bedeckend
</emphasis>
), die untern am Grunde 
<normalizedToken id="8D03EB3661B7C65BF7F8F50439CD9ACA" originalValue="gezähnt" pageId="null" pageNumber="589">gezaehnt</normalizedToken>
. 
<emphasis id="BD815169FB970E528E81C278E04C758F" italics="true" pageId="null" pageNumber="589">
<normalizedToken id="12325B9A702CEC8B80E2EFEADFA15214" originalValue="Blüten" pageId="null" pageNumber="589">Blueten</normalizedToken>
einzeln in den Blattachseln. Kelch 0,8-1 cm lang. Krone 1,8-3 cm lang, gelb, mit 
<normalizedToken id="6F1CC7E203F54E66827AF02738FBF544" originalValue="außen" pageId="null" pageNumber="589">aussen</normalizedToken>
rot 
<normalizedToken id="475C6D0B078FF41CE2CF58E0CC14A319" originalValue="überlaufener" pageId="null" pageNumber="589">ueberlaufener</normalizedToken>
Fahne.
</emphasis>
- 
<normalizedToken id="D13618F902210FCAA7D37454C7BC89F9" originalValue="Blüte" pageId="null" pageNumber="589">Bluete</normalizedToken>
: 
<normalizedToken id="F8E321AE04D8FB7E0E29EF57E4078283" originalValue="Frühling" pageId="null" pageNumber="589">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="6870B004BCEC47268274BAF1993641D8" pageId="null" pageNumber="589">
<emphasis id="9E6BCD7D4EE3CBA2BDF71F2C0FB40CAA" italics="true" pageId="null" pageNumber="589">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="D83B48CFE316245EF00F6ABDF6D0B1B3" italics="true" pageId="null" pageNumber="589">12:</emphasis>
Material unbekannter Herkunft (Sveshnikova 1927, Heitz 1931b).
</paragraph>
<paragraph id="8852971610A7ED31C55AA199C8F11255" pageId="null" pageNumber="589">
<emphasis id="2BA5F1B8016F6668AC8C0AAD4584C880" italics="true" pageId="null" pageNumber="589">Standort.</emphasis>
Kollin und montan. Lockere 
<normalizedToken id="951313763E8DAD3DF03A834A11D38933" originalValue="Böden" pageId="null" pageNumber="589">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="309D213C929D8B1E1C350CF38389BB17" originalValue="Äcker" pageId="null" pageNumber="589">Aecker</normalizedToken>
, Getreidefelder, 
<normalizedToken id="53A97D9353D2FA7DAC2820A0909E5922" originalValue="Schuttplätze" pageId="null" pageNumber="589">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="6AA97FE5B562E41D3094F0AFC1D1A139" pageId="null" pageNumber="589">
<emphasis id="B7DD4ADB75064409EE73E90ACE0F3F34" italics="true" pageId="null" pageNumber="589">
Verbreitung. 
<normalizedToken id="621247985687D9A77D006B3F36569CD6" originalValue="Südeuropäische" pageId="null" pageNumber="589">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="C58E1D956494C29E0C78FA8ED2F4BF79" originalValue="Nordwärts" pageId="null" pageNumber="589">Nordwaerts</normalizedToken>
bis Mittelfrankreich, Poebene, Donaubecken. - Im Gebiet kaum einheimisch, gelegentlich eingeschleppt oder adventiv.
</paragraph>
</subSubSection>
</treatment>
