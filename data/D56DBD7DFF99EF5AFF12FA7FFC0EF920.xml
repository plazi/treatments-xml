<taxonomicName id="9AC477E8FF99EF5AFF5DFA7FFD4EFA5C" authority="Brunner von Wattenwyl, 1878" authorityName="Brunner von Wattenwyl" authorityYear="1878" box="[216,763,1482,1508]" class="Insecta" family="Tettigoniidae" kingdom="Animalia" order="Orthoptera" pageId="49" pageNumber="50" phylum="Arthropoda" rank="tribe" tribe="Steirodontini">
Steirodontini 
<bibRefCitation id="3955719AFF99EF5AFE06FA7FFD4EFA5C" author="Brunner von Wattenwyl, C." box="[387,763,1482,1508]" pageId="49" pageNumber="50" pagination="1 - 401" refId="ref29469" refString="Brunner von Wattenwyl, C. (1878) Monographie der Phaneropteriden. Verhandlungen der Kaiserlich-Koniglichen Zoologisch- Botanischen Gesellschaft in Wien, 28, 1 - 401." type="journal article" year="1878">Brunner von Wattenwyl, 1878</bibRefCitation>
