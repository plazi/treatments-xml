<subSubSection id="F04136D7F0D6A51C0DE35C8DDC56F1E0" pageId="null" pageNumber="723" type="description">
<paragraph id="D4251335D0175B526DFD2F0C06B3C04A" pageId="null" pageNumber="723">
Unterscheidet sich von 
<emphasis id="715CA1B9B6B7E3D228D0CEFB272826A9" italics="true" pageId="null" pageNumber="723">
R. 
<taxonomicName id="2D09051CE42544E8F8696DC74C569BD6" class="Magnoliopsida" family="Polygonaceae" genus="Acetosa" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="723" phylum="Tracheophyta" rank="genus">Acetosa</taxonomicName>
</emphasis>
(Nr.4a) durch folgende Merkmale: 
<emphasis id="C3382A12F085153789C133A2A0D97BD8" italics="true" pageId="null" pageNumber="723">
<normalizedToken id="093A371D036D8599A49677953FE521A3" originalValue="Grundständige" pageId="null" pageNumber="723">Grundstaendige</normalizedToken>
<normalizedToken id="12501A099046B207F6E711145A386757" originalValue="Blätter" pageId="null" pageNumber="723">Blaetter</normalizedToken>
und untere 
<normalizedToken id="E1177E4921E55E9CAB115E5C125ECF25" originalValue="Stengelblätter" pageId="null" pageNumber="723">Stengelblaetter</normalizedToken>
4-14 mal so lang wie breit; 
<normalizedToken id="F355F98CB3F931C906EC010480AC0715" originalValue="Seitenäste" pageId="null" pageNumber="723">Seitenaeste</normalizedToken>
des 
<normalizedToken id="4117C627765BB13B1158409F4093B256" originalValue="Gesamtblütenstandes" pageId="null" pageNumber="723">Gesamtbluetenstandes</normalizedToken>
reich verzweigt.
</emphasis>
- 
<normalizedToken id="BB49F5469B77C322A3167960C21A62DA" originalValue="Blüte" pageId="null" pageNumber="723">Bluete</normalizedToken>
: Sommer (
<normalizedToken id="F1349CF6003C39C856F4FB025B9D7655" originalValue="später" pageId="null" pageNumber="723">spaeter</normalizedToken>
als 
<emphasis id="478428731163FBAC848E4287C12B19EE" italics="true" pageId="null" pageNumber="723">
R. 
<taxonomicName id="16CD9B594EEFAE94D03B877318211043" class="Magnoliopsida" family="Polygonaceae" genus="Acetosa" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="723" phylum="Tracheophyta" rank="genus">Acetosa</taxonomicName>
</emphasis>
).
</paragraph>
<paragraph id="1AB04A9C3432684AE1E42BA656D7F574" pageId="null" pageNumber="723">
<emphasis id="D604486417C7CBEC83D3BAFA0175A56A" italics="true" pageId="null" pageNumber="723">Zytologische Angaben. 2n = 14</emphasis>
(♀), 
<emphasis id="F3C08237CC41270EC1C8CE399E541892" italics="true" pageId="null" pageNumber="723">15</emphasis>
(♂): Siehe unter Artengruppe.
</paragraph>
<paragraph id="37805B0C678596179FDB53296D8683A7" pageId="null" pageNumber="723">
<emphasis id="43D15D299C09F393A7F171AA084BC761" italics="true" pageId="null" pageNumber="723">Standort.</emphasis>
Kollin. Trockene, 
<normalizedToken id="57B579FA7C725A5BDBD784338EA84513" originalValue="nährstoffreiche" pageId="null" pageNumber="723">naehrstoffreiche</normalizedToken>
, offene 
<normalizedToken id="2804302C57574EE591406021F267FD94" originalValue="Böden" pageId="null" pageNumber="723">Boeden</normalizedToken>
. Unkrautgesellschaften an Wegen, Bahnanlagen, seltener in Wiesengesellschaften.
</paragraph>
<paragraph id="2492DAC9960838035C4278A9C02577F6" pageId="null" pageNumber="723">
<emphasis id="CC4B5E1E2EAEABEE740A3D68803B4DF0" italics="true" pageId="null" pageNumber="723">Verbreitung. Eurosibirische Pflanze:</emphasis>
<normalizedToken id="2EA961A147323A6CECDD73D26AB163FA" originalValue="Westwärts" pageId="null" pageNumber="723">Westwaerts</normalizedToken>
bis Mitteleuropa (Rheingebiet), 
<normalizedToken id="5C2D482C1BA5C95EB9A83103B278C380" originalValue="nordwärts" pageId="null" pageNumber="723">nordwaerts</normalizedToken>
bis ca. 70° NB (Skandinavien), 
<normalizedToken id="52CC223518244D13A6B087B31DA7C5A6" originalValue="südwärts" pageId="null" pageNumber="723">suedwaerts</normalizedToken>
bis auf die Balkanhalbinsel, 
<normalizedToken id="E677E7E55B70A221662AF45BF974BD90" originalValue="ostwärts" pageId="null" pageNumber="723">ostwaerts</normalizedToken>
durch Asien zwischen 45 und 70° NB bis Ostsibirien. Verbreitungskarte von Meusel (1964). - Im Gebiet vielfach festgestellt und in Ausbreitung begriffen.
</paragraph>
</subSubSection>
