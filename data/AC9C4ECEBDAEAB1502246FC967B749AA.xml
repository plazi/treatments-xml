<paragraph id="B20B275152913E29C1A724B3A64D10FA" pageId="0" pageNumber="1">
<emphasis id="65883E63EEBBC137D3EEA1F318F6B0B5" bold="true" pageId="0" pageNumber="1">
(Fig. 
<figureCitation id="E024CDBB52AA1F7363921104229F1B1C" captionStart="Figure 83" captionStartId="F83" captionText="Figure 83. Distribution of S. wightii." figureDoi="10.3897/phytokeys.198.79514.figure83" httpUri="https://binary.pensoft.net/fig/689776" pageId="0" pageNumber="1">83</figureCitation>
