<subSubSection id="9849D80634CE13679820BEF0784167E9" pageId="null" pageNumber="166" type="description">
<paragraph id="F5C2C9A1CECA6BAC28D197F3F85754A1" pageId="null" pageNumber="166">
Die Gattung 
<taxonomicName id="0D0F8430510775780328FEAE1E598DCD" class="Magnoliopsida" family="Brassicaceae" genus="Erophila" higherTaxonomySource="GBIF" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="166" phylum="Tracheophyta" rank="genus">
<emphasis id="2D7547B5E3CE99458F66B3296790D280" italics="true" pageId="null" pageNumber="166">Erophila</emphasis>
</taxonomicName>
, deren Abtrennung von 
<taxonomicName id="BAB03D765007FF8FD26E4D73672D9269" class="Magnoliopsida" family="Brassicaceae" genus="Draba" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="166" phylum="Tracheophyta" rank="genus">
<emphasis id="1DE124E7462FF5EDB960380BB3BECEAA" italics="true" pageId="null" pageNumber="166">Draba</emphasis>
</taxonomicName>
kaum gerechtfertigt ist, 
<normalizedToken id="6F848D916F8D92D99E416ABDA640B692" originalValue="umfaßt" pageId="null" pageNumber="166">umfasst</normalizedToken>
einzig die Artengruppe der 
<taxonomicName id="AE46147B5899949FEE2CE4C2AF4C11CD" class="Magnoliopsida" family="Brassicaceae" genus="Erophila" higherTaxonomySource="GBIF" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="166" phylum="Tracheophyta" rank="species" species="verna">
<emphasis id="29F08E1C68D6D426A0F03B19405469DF" italics="true" pageId="null" pageNumber="166">E. verna</emphasis>
</taxonomicName>
und unterscheidet sich von 
<taxonomicName id="C4D17FD4A98C4880A10F6E6767F58CFA" class="Magnoliopsida" family="Brassicaceae" genus="Draba" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="166" phylum="Tracheophyta" rank="genus">
<emphasis id="D148CE68122C84765A6EA1D449C2747D" italics="true" pageId="null" pageNumber="166">Draba</emphasis>
</taxonomicName>
nur durch die 
<emphasis id="9C6011176E4CCB89654A3AAD8B23D1B9" italics="true" pageId="null" pageNumber="166">
2teiligen 
<normalizedToken id="29A68B2AB67E5807AA2B66D0A81F83C5" originalValue="Kronblätter" pageId="null" pageNumber="166">Kronblaetter</normalizedToken>
</emphasis>
(bei allen andern Gattungen unserer Flora, 
<normalizedToken id="3FA7682BE26E30406AED061FE428016D" originalValue="außer" pageId="null" pageNumber="166">ausser</normalizedToken>
<taxonomicName id="A7B27914D016F4F05423797B344652A2" class="Magnoliopsida" family="Brassicaceae" genus="Berteroa" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="166" phylum="Tracheophyta" rank="genus">
<emphasis id="6EDC5B29D8EE676D195FE81111428CEB" italics="true" pageId="null" pageNumber="166">Berteroa</emphasis>
</taxonomicName>
, sind die 
<normalizedToken id="095EA351135E0235262421ED999DE6AE" originalValue="Kronblätter" pageId="null" pageNumber="166">Kronblaetter</normalizedToken>
vorn gerundet oder ausgerandet).
</paragraph>
