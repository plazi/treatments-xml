</paragraph>
</subSubSection>
<subSubSection id="D9F16554FF9BBA37B1BFF272B504FAFD" box="[1453,1826,1298,1331]" pageId="39" pageNumber="658" type="breeding">
<paragraph id="915436DFFF9BBA37B1BFF272B504FAFD" blockId="39.[1450,2660,277,2324]" box="[1453,1826,1298,1331]" pageId="39" pageNumber="658">
<emphasis id="A39FEACDFF9BBA37B1BFF272B415FAFD" bold="true" box="[1453,1587,1298,1331]" pageId="39" pageNumber="658">Breeding.</emphasis>
No information.
