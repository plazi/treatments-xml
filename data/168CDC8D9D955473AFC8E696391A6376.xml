</tr>
<tr id="E1C1CA5C1F9E2EA07EFA1719EE81694B" pageId="0" pageNumber="93">
<td id="5F1385E5F92450D1722966A6B8BC9A5E" colspan="1" pageId="0" pageNumber="93" rowspan="1">
<taxonomicName id="B7632A3ABF573145BC26596E0157E996" genus="S." lsidName="S. annulus" pageId="0" pageNumber="93" rank="species" species="annulus">
<emphasis id="7D05A26BDA6E1FAF3AD0ADA800B4F09B" italics="true" pageId="0" pageNumber="93">S. annulus</emphasis>
