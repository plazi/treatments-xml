<emphasis id="E58B7D44B45750C7B4685AA395E909E7" italics="true" pageId="0" pageNumber="93">S. baishanzuensis</emphasis>
</taxonomicName>
</td>
<td id="763DA5715AADF2547DABB93071ECCE5A" colspan="1" pageId="0" pageNumber="93" rowspan="1">Median vittae with little pigmentation; lateral vittae with stripe pigmentation</td>
<td id="D20A8F1C5042DC9D4BC1C4F7F015DF02" colspan="1" pageId="0" pageNumber="93" rowspan="1">Anal point straight and parallel-sided</td>
<td id="DAADB7A6B103D9C8F1AD927C3B989326" colspan="1" pageId="0" pageNumber="93" rowspan="1">Entire femur of P2 pale; femur of P3 brown</td>
</tr>
<tr id="EB62A167A3ADF6E29A9C41E6A84F61BF" pageId="0" pageNumber="93">
<td id="304C1C3F5CFDC82CA15F719876565673" colspan="1" pageId="0" pageNumber="93" rowspan="1">
<taxonomicName id="F3BC7FC7D4946EDF59DE250FA6D73DEA" genus="S." lsidName="S. gibbus" pageId="0" pageNumber="93" rank="species" species="gibbus">
<emphasis id="BD8E987543019C96C6C590011BF2480B" italics="true" pageId="0" pageNumber="93">S. gibbus</emphasis>
</taxonomicName>
</td>
<td id="2A144CD33331C005DE5AABB421B9278B" colspan="1" pageId="0" pageNumber="93" rowspan="1">Thorax without pigmentation</td>
<td id="3796399DF97D1E0D9F5D6F7990EA5653" colspan="1" pageId="0" pageNumber="93" rowspan="1">Apex parallel-sided to slightly bulbous</td>
<td id="44E26D3C3A7A90EB936F051BDBC288E1" colspan="1" pageId="0" pageNumber="93" rowspan="1">Nearly 1/2 to entire femur of P2; basal 0.12-0.30 femur of P3 dark brown;</td>
</tr>
<tr id="7AD463A1D625F26CDA321D79AE8EFC7B" pageId="0" pageNumber="93">
<td id="13CED6C291A22286D220490DC94537DD" colspan="1" pageId="0" pageNumber="93" rowspan="1">
<taxonomicName id="11D1EBF38264C7383C6D36A76A40747A" genus="S." lsidName="S. xianjuensis" pageId="0" pageNumber="93" rank="species" species="xianjuensis">
<emphasis id="F8C300713F2447B3588C1E2EB8932733" italics="true" pageId="0" pageNumber="93">S. xianjuensis</emphasis>
</taxonomicName>
</td>
<td id="55DC7AC095B3F9B3F88190681F46858A" colspan="1" pageId="0" pageNumber="93" rowspan="1">Thorax without median vittae; lateral vittae with stripe pigmentation</td>
<td id="C18D50BFE7F16E116282ABFDE014E133" colspan="1" pageId="0" pageNumber="93" rowspan="1">Apex of anal point swollen and rounded</td>
<td id="5BDA0A856616C2580D2BD61953A2B8C7" colspan="1" pageId="0" pageNumber="93" rowspan="1">Apical 1/4 of P2 and P3 brown</td>
</tr>
</table>
</paragraph>
</subSubSection>
<subSubSection id="97828012CAC924F7A6F7EA4F15C8B168" pageId="0" pageNumber="93" type="distribution">
<paragraph id="C206922F7C27D5B32529DD375DD298E4" pageId="0" pageNumber="93">Distribution.</paragraph>
<paragraph id="C433D1D86077C8C5AAA8C4DCE777F92A" pageId="0" pageNumber="93">The species is currently known only from Zhejiang Province in Oriental China.</paragraph>
</subSubSection>
