<taxonomicName id="1487E6C93BE502C19550A2E36462E2B5" authority="Wulfen" class="Magnoliopsida" family="Primulaceae" genus="Androsace" kingdom="Plantae" order="Ericales" pageId="null" pageNumber="931" phylum="Tracheophyta" rank="species" species="chamaejasme">
Androsace 
<normalizedToken id="4947A365A2237D5A9F3903882EB7CD15" originalValue="Chamaejásme" pageId="null" pageNumber="931">Chamaejasme</normalizedToken>
Wulfen
