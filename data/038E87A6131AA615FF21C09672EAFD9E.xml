<paragraph id="8B9836B0131AA615FF21C0B0735EFF1E" blockId="28.[192,598,227,251]" box="[192,598,227,251]" pageId="28" pageNumber="27">
(
<figureCitation id="131C2A35131AA615FF28C0B070A9FF1E" box="[201,417,227,251]" captionStart="Figure 62-73" captionStartId="13.[192,275,1563,1585]" captionTargetBox="[198,1435,196,1530]" captionTargetId="figure-178@13.[193,1444,192,1539]" captionTargetPageId="13" captionText="Figure 62-73. Pseudonascus, Dyscophellus, and Nascus (from BRAZIL: Rondônia, unless noted otherwise; dorsum and venter of same specimens). 62, 65) P. paulliniae male, Fazenda Rancho Grande, 16 Nov 1994. 63, 66) D. ramon male, COSTA RICA: Puntarenas Prov.; Playa Herradura, 20 Sep 1987. 64, 67) N. salon salon male, Fazenda Rancho Grande, 5 Dec 1991. 68, 71) P. paulliniae female, 5 km S of Cacaulândia, 12 Apr 1995. 69, 72) D. porsena male, Fazenda Rancho Grande, 16 Nov 1994. 70, 73) D. ramon female, COSTA RICA: Puntarenas Prov.; 1.1 km N Tarcoles, 20 Sep 1987." figureDoi="http://doi.org/10.5281/zenodo.4532833" httpUri="https://zenodo.org/record/4532833/files/figure.png" pageId="28" pageNumber="27">Fig. 62, 65, 68, 71</figureCitation>
, 
<figureCitation id="131C2A35131AA615FE4DC0B070D3FF1E" box="[428,475,227,251]" captionStart="Figure 117-120" captionStartId="30.[192,276,1157,1179]" captionTargetBox="[195,1440,191,1146]" captionTargetId="figure-251@30.[192,1446,190,1152]" captionTargetPageId="30" captionText="Figure 117-120. Male genitalia of Pseudonascus and Nascus (from BRAZIL: Rondônia). Structures shown are lateral, dorsal, and ventral views of tegumen, uncus, gnathos, and associated structures; lateral internal view of right valva; lateral view of aedeagus and associated structures; and ventral view of transtilla and juxta. 117) P. paulliniae (GTA 2460). 118) N. phocus (GTA 3534). 119) N. broteas (GTA 7211). 120) N. salon salon (GTA 1725)." figureDoi="http://doi.org/10.5281/zenodo.4532861" httpUri="https://zenodo.org/record/4532861/files/figure.png" pageId="28" pageNumber="27">117</figureCitation>
, 
<figureCitation id="131C2A35131AA615FE06C0B0731EFF1E" box="[487,534,227,251]" captionStart="Figure 121-124" captionStartId="31.[192,276,1003,1025]" captionTargetBox="[194,1444,200,969]" captionTargetId="figure-256@31.[190,1446,192,977]" captionTargetPageId="31" captionText="Figure 121-124. Female genitalia (ventral view) of Pseudonascus and Nascus (from BRAZIL: Rondônia, unless otherwise noted). 121) N. salon salon (GTA 7229). 122) N. broteas (GTA 7228). 123) N. phocus, COSTA RICA (GTA 7230). 124) P. paulliniae (GTA 7233)." figureDoi="http://doi.org/10.5281/zenodo.4532863" httpUri="https://zenodo.org/record/4532863/files/figure.png" pageId="28" pageNumber="27">124</figureCitation>
, 
<figureCitation id="131C2A35131AA615FDC0C0B07346FF1E" box="[545,590,227,251]" captionStart="Figure 125-130" captionStartId="32.[192,276,1641,1663]" captionTargetBox="[222,1441,235,1620]" captionTargetId="figure-21@32.[195,1443,234,1635]" captionTargetPageId="32" captionText="Figure 125-130. Phenology of some night skippers from central Rondônia, Brazil. 125-126) Bungalotis species. 127) Dyscophellus species. 128) Salatis salatisand Sarmientoia similis. 129) Nicephellus nicephorus and Euriphellus euribates. 130) Pseudonascus paulliniae and Nascus species." figureDoi="http://doi.org/10.5281/zenodo.4532867" httpUri="https://zenodo.org/record/4532867/files/figure.png" pageId="28" pageNumber="27">130</figureCitation>
)
</paragraph>
<paragraph id="8B9836B0131AA615FF21C1707322FEDE" blockId="28.[192,736,291,347]" box="[192,554,291,315]" pageId="28" pageNumber="27">
<taxonomicName id="4C274D33131AA615FF21C1707322FEDE" authority="Sepp, [1842]" authorityName="Sepp" authorityYear="1842" box="[192,554,291,315]" class="Insecta" family="Papilionidae" genus="Papilio" kingdom="Animalia" order="Lepidoptera" pageId="28" pageNumber="27" phylum="Arthropoda" rank="species" species="paulliniae">
<emphasis id="B953EAA2131AA615FF21C170709DFEDE" box="[192,405,291,315]" italics="true" pageId="28" pageNumber="27">Papilio paulliniae</emphasis>
Sepp, [1842]
</taxonomicName>
</paragraph>
<paragraph id="8B9836B0131AA615FF21C11773E8FEBE" blockId="28.[192,736,291,347]" box="[192,736,323,347]" pageId="28" pageNumber="27">
<taxonomicName id="4C274D33131AA615FF21C117734EFEBE" authority="(Sepp, [1842])" baseAuthorityName="Sepp" baseAuthorityYear="1842" box="[192,582,323,347]" class="Insecta" family="Hesperiidae" genus="Nascus" kingdom="Animalia" order="Lepidoptera" pageId="28" pageNumber="27" phylum="Arthropoda" rank="species" species="paulliniae">
<emphasis id="B953EAA2131AA615FF21C1177090FEBE" box="[192,408,323,347]" italics="true" pageId="28" pageNumber="27">Nascus paulliniae</emphasis>
(Sepp, [1842])
</taxonomicName>
: 
<bibRefCitation id="EFB64B41131AA615FDACC11773E8FEBE" author="Evans, W. H." box="[589,736,323,347]" pageId="28" pageNumber="27" refId="ref19451" refString="Evans, W. H. 1952. A Catalogue of the American Hesperiidae in the British Museum. Part II (Groups B, C, D), Pyrginae. Section I. British Museum (Natural History); London. 178 p." type="book" year="1952">Evans, 1952</bibRefCitation>
</paragraph>
<paragraph id="8B9836B0131AA615FF11C1D073D2FDFE" blockId="28.[192,1441,387,635]" pageId="28" pageNumber="27">
<taxonomicName id="4C274D33131AA615FF11C1D0732AFE7E" authorityName="Austin" authorityYear="2008" baseAuthorityName="Sepp" baseAuthorityYear="1842" box="[240,546,387,411]" class="Insecta" family="Hesperiidae" genus="Pseudonascus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="28" pageNumber="27" phylum="Arthropoda" rank="species" species="paulliniae">
<emphasis id="B953EAA2131AA615FF11C1D0732AFE7E" box="[240,546,387,411]" italics="true" pageId="28" pageNumber="27">Pseudonascus paulliniae</emphasis>
</taxonomicName>
<materialsCitation id="3B4F3CED131AA615FDC8C1D073DEFDFE" location="Central America" pageId="28" pageNumber="27" specimenCount="1" stateProvince="Rondonia">
shows little variation in color and pattern in central 
<collectingRegion id="49E3F852131AA615FB4CC1D0742EFE7E" box="[1197,1318,387,411]" country="Brazil" name="Rondonia" pageId="28" pageNumber="27">Rondônia</collectingRegion>
, but some individuals have more broadly rounded wings than others (male mean FW length = 
<quantity id="4CDF9B55131AA615FB50C1F07411FE5E" box="[1201,1305,419,443]" metricMagnitude="-2" metricUnit="m" metricValue="2.23" pageId="28" pageNumber="27" unit="mm" value="22.3">22.3 mm</quantity>
[20.7-23.4, n = 10]; female mean FW length = 
<quantity id="4CDF9B55131AA615FD65C19073FAFE3E" box="[644,754,451,475]" metricMagnitude="-2" metricUnit="m" metricValue="2.45" pageId="28" pageNumber="27" unit="mm" value="24.5">24.5 mm</quantity>
[21.6-26.2, n = 3]). The genitalia (
<figureCitation id="131C2A35131AA615FB4AC190741DFE3E" box="[1195,1301,451,475]" captionStart="Figure 117-120" captionStartId="30.[192,276,1157,1179]" captionTargetBox="[195,1440,191,1146]" captionTargetId="figure-251@30.[192,1446,190,1152]" captionTargetPageId="30" captionText="Figure 117-120. Male genitalia of Pseudonascus and Nascus (from BRAZIL: Rondônia). Structures shown are lateral, dorsal, and ventral views of tegumen, uncus, gnathos, and associated structures; lateral internal view of right valva; lateral view of aedeagus and associated structures; and ventral view of transtilla and juxta. 117) P. paulliniae (GTA 2460). 118) N. phocus (GTA 3534). 119) N. broteas (GTA 7211). 120) N. salon salon (GTA 1725)." figureDoi="http://doi.org/10.5281/zenodo.4532861" httpUri="https://zenodo.org/record/4532861/files/figure.png" pageId="28" pageNumber="27">Fig. 117</figureCitation>
, 
<figureCitation id="131C2A35131AA615FAC5C1907459FE3E" box="[1316,1361,451,475]" captionStart="Figure 121-124" captionStartId="31.[192,276,1003,1025]" captionTargetBox="[194,1444,200,969]" captionTargetId="figure-256@31.[190,1446,192,977]" captionTargetPageId="31" captionText="Figure 121-124. Female genitalia (ventral view) of Pseudonascus and Nascus (from BRAZIL: Rondônia, unless otherwise noted). 121) N. salon salon (GTA 7229). 122) N. broteas (GTA 7228). 123) N. phocus, COSTA RICA (GTA 7230). 124) P. paulliniae (GTA 7233)." figureDoi="http://doi.org/10.5281/zenodo.4532863" httpUri="https://zenodo.org/record/4532863/files/figure.png" pageId="28" pageNumber="27">124</figureCitation>
) were described above in the generic description. Those of both sexes from 
<collectingRegion id="49E3F852131AA615FC13C1B0756FFE1E" box="[1010,1127,483,507]" country="Brazil" name="Rondonia" pageId="28" pageNumber="27">Rondônia</collectingRegion>
do not differ from those of individuals examined from 
<location id="8EF8606B131AA615FDE8C25073DEFDFE" LSID="urn:lsid:plazi:treatment:038E87A6131AA615FF21C09672EAFD9E:8EF8606B131AA615FDE8C25073DEFDFE" box="[521,726,515,539]" name="Central America" pageId="28" pageNumber="27" stateProvince="Rondonia">Central America</location>
</materialsCitation>
.
</paragraph>
</subSubSection>
<subSubSection id="C33D653B131AA615FF11C27072EAFD9E" pageId="28" pageNumber="27" type="reference_group">
<paragraph id="8B9836B0131AA615FF11C27072EAFD9E" blockId="28.[192,1441,387,635]" pageId="28" pageNumber="27">
<taxonomicName id="4C274D33131AA615FF11C2707314FDDE" authorityName="Austin" authorityYear="2008" baseAuthorityName="Sepp" baseAuthorityYear="1842" box="[240,540,547,571]" class="Insecta" family="Hesperiidae" genus="Pseudonascus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="28" pageNumber="27" phylum="Arthropoda" rank="species" species="paulliniae">
<emphasis id="B953EAA2131AA615FF11C2707314FDDE" box="[240,540,547,571]" italics="true" pageId="28" pageNumber="27">Pseudonascus paulliniae</emphasis>
</taxonomicName>
is common at Cacaulândia, with records for most of the year (none in January and March; 
<figureCitation id="131C2A35131AA615FE67C21070E6FDBE" box="[390,494,579,603]" captionStart="Figure 125-130" captionStartId="32.[192,276,1641,1663]" captionTargetBox="[222,1441,235,1620]" captionTargetId="figure-21@32.[195,1443,234,1635]" captionTargetPageId="32" captionText="Figure 125-130. Phenology of some night skippers from central Rondônia, Brazil. 125-126) Bungalotis species. 127) Dyscophellus species. 128) Salatis salatisand Sarmientoia similis. 129) Nicephellus nicephorus and Euriphellus euribates. 130) Pseudonascus paulliniae and Nascus species." figureDoi="http://doi.org/10.5281/zenodo.4532867" httpUri="https://zenodo.org/record/4532867/files/figure.png" pageId="28" pageNumber="27">Fig. 130</figureCitation>
). This species ranges from southern 
<collectingCountry id="F3307620131AA615FC52C2107502FDBE" box="[947,1034,579,603]" name="Mexico" pageId="28" pageNumber="27">Mexico</collectingCountry>
to 
<collectingCountry id="F3307620131AA615FBD0C2107581FDBE" box="[1073,1161,579,603]" name="Bolivia" pageId="28" pageNumber="27">Bolivia</collectingCountry>
and 
<collectingCountry id="F3307620131AA615FB27C210741AFDBE" box="[1222,1298,579,603]" name="Brazil" pageId="28" pageNumber="27">Brazil</collectingCountry>
(
<bibRefCitation id="EFB64B41131AA615FAC0C21071F6FD9E" author="Hoffmann, C. C." pageId="28" pageNumber="27" pagination="237 - 294" refId="ref19661" refString="Hoffmann, C. C. 1941. Catalogo sistematico y zoogeografico de los Lepidopteros Mexicanos. Segunda Parte. Hesperioidea. Anales del Instituto de Biologia, Universidad Nacional de Mexico 12: 237 - 294." type="journal article" year="1941">Hoffmann 1941</bibRefCitation>
, 
<bibRefCitation id="EFB64B41131AA615FEE8C2377091FD9E" author="Evans, W. H." box="[265,409,611,635]" pageId="28" pageNumber="27" refId="ref19451" refString="Evans, W. H. 1952. A Catalogue of the American Hesperiidae in the British Museum. Part II (Groups B, C, D), Pyrginae. Section I. British Museum (Natural History); London. 178 p." type="book" year="1952">Evans 1952</bibRefCitation>
, de la Maza and de la Maza 1985, Warren 2000).
</paragraph>
</subSubSection>
