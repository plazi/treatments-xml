<subSubSection id="C31E6567FF8AF66481173FC1F5ADF307" pageId="78" pageNumber="136" type="reference_group">
<paragraph id="8BBB36ECFF8AF66481173FC1F5A7F3D6" blockId="78.[2057,2653,3037,3464]" pageId="78" pageNumber="136">
<emphasis id="B970EAFEFF8AF66481173FC1F705F465" bold="true" box="[2057,2208,3037,3070]" pageId="78" pageNumber="136">Taxonomy.</emphasis>
Pleropus 
<taxonomicName id="4C044D6FFF8AF664803E3FC1F5F6F465" authority="Peters, 1862" authorityName="Peters" authorityYear="1862" box="[2336,2643,3037,3070]" class="Dothideomycetes" family="Pteropodidae" genus="Pteropus" kingdom="Fungi" order="Chiroptera" pageId="78" pageNumber="136" phylum="Ascomycota" rank="species" species="scapulatus">scapulatus Peters, 1862</taxonomicName>
