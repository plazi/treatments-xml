<taxonomicName id="03944D7DFFFC6A43FC609F121DF7B25E" authorityName="Thomas" authorityYear="1911" box="[924,1015,2379,2412]" class="Mammalia" family="Vespertilionidae" genus="Nyctalus" kingdom="Animalia" order="Chiroptera" pageId="7" pageNumber="765" phylum="Chordata" rank="species" species="aviator">aviator</taxonomicName>
and N. 
<taxonomicName id="03944D7DFFFC6A43FB979F121AEEB25E" baseAuthorityName="Schreber" baseAuthorityYear="1780" box="[1131,1262,2379,2412]" class="Mammalia" family="Vespertilionidae" genus="Nyctalus" kingdom="Animalia" order="Chiroptera" pageId="7" pageNumber="765" phylum="Chordata" rank="species" species="lasiopterus">lasiopterus</taxonomicName>
are togethersister to N. 
<taxonomicName id="03944D7DFFFC6A43FC099F2B1A52B2A1" authorityName="Schreber" authorityYear="1774" box="[1013,1106,2418,2451]" class="Mammalia" family="Vespertilionidae" genus="Nyctalus" kingdom="Animalia" order="Chiroptera" pageId="7" pageNumber="765" phylum="Chordata" rank="species" species="noctula">noctula</taxonomicName>
, all three sharing the same diploid number. Monotypic.
</paragraph>
</subSubSection>
