<subSubSection id="8C8E6575FFFC6A43FD2F9E8D1B13B288" pageId="7" pageNumber="765" type="discussion">
<paragraph id="C42B36FEFFFC6A43FD2F9E8D1B13B288" blockId="7.[721,1316,2185,2609]" pageId="7" pageNumber="765">
<taxonomicName id="03944D7DFFFC6A43FD2F9E8D1DA6B3C7" authorityName="Bowditch" authorityYear="1825" box="[723,934,2260,2293]" class="Mammalia" family="Vespertilionidae" genus="Nyctalus" kingdom="Animalia" order="Chiroptera" pageId="7" pageNumber="765" phylum="Chordata" rank="species" species="aviator">Nyctalus aviator</taxonomicName>
is sometimes included within N. 
<taxonomicName id="03944D7DFFFC6A43FCDB9EA51DABB22F" baseAuthorityName="Schreber" baseAuthorityYear="1780" box="[807,939,2300,2333]" class="Mammalia" family="Vespertilionidae" genus="Nyctalus" kingdom="Animalia" order="Chiroptera" pageId="7" pageNumber="765" phylum="Chordata" rank="species" species="lasiopterus">lasiopterus</taxonomicName>
