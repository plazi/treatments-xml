<taxonomicName id="A549B3C0DAA27B1BDA627A036248B714" authority="(L.) DC." class="Insecta" family="Melolonthidae" genus="Diplotaxis" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="193" phylum="Arthropoda" rank="species" species="tenuifolia">
<pageBreakToken id="6EF694AB045C16A4964155D309A1949D" pageId="null" pageNumber="193" start="start">Diplotaxis</pageBreakToken>
tenuifolia (
<authorityName id="25A88273BBD57FDCC43D81564B10ADA6" pageId="null" pageNumber="193">L.</authorityName>
) DC.
</taxonomicName>
</paragraph>
