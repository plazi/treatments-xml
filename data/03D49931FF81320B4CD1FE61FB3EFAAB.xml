<collectingCountry id="F36A68B7FF81320B4EA6FB10FCE3FB58" box="[721,789,1177,1199]" name="Poland" pageId="6" pageNumber="97">Poland</collectingCountry>
and 
<collectingRegion id="49B9E6C5FF81320B4F32FB10FC4EFB58" box="[837,952,1177,1199]" country="Ukraine" name="L'viv" pageId="6" pageNumber="97">Lviv Region</collectingRegion>
(
<collectingCountry id="F36A68B7FF81320B4FB2FB10FBEFFB58" box="[965,1049,1177,1199]" name="Ukraine" pageId="6" pageNumber="97">Ukraine</collectingCountry>
). Parasite of moor frog, 
<taxonomicName id="4C7D53A4FF81320B4D53FB3EFE6AFB3C" authorityName="Nicolsson" authorityYear="1842" box="[292,412,1206,1228]" class="Amphibia" family="Ranidae" genus="Rana" kingdom="Animalia" order="Anura" pageId="6" pageNumber="97" phylum="Chordata" rank="species" species="arvalis">
<emphasis id="B909F435FF81320B4D53FB3EFE6AFB3C" box="[292,412,1206,1228]" italics="true" pageId="6" pageNumber="97">Rana arvalis</emphasis>
</taxonomicName>
............................................................................................ 
