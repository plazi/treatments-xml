<subSubSection id="86EA479600DDA8B62F046BB1D6309CB8" pageId="null" pageNumber="590" type="description">
<paragraph id="201A908F0F9304E2257374788AB077A9" pageId="null" pageNumber="590">
Unterscheidet sich von 
<taxonomicName id="D76B9113B46AE82D8218B760215488F7" class="Gymnolaemata" family="Cymuloporidae" genus="Crepis" kingdom="Animalia" order="Cheilostomatida" pageId="null" pageNumber="590" phylum="Bryozoa" rank="species" species="capillaris">
<emphasis id="A708215824B8A9BB71AE134E0276263C" italics="true" pageId="null" pageNumber="590">C. capillaris</emphasis>
</taxonomicName>
(Nr. 17) durch folgende Merkmale: Stengel oft kahl; 
<emphasis id="644ED2D1FF2905C12CBC36896F63F205" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="2FAF1C52C752173B9E76C6ECF16EB3FE" originalValue="Köpfe" pageId="null" pageNumber="590">Koepfe</normalizedToken>
vor dem 
<normalizedToken id="388F459A11BD4CFA883B3B849D5CCC25" originalValue="Aufblühen" pageId="null" pageNumber="590">Aufbluehen</normalizedToken>
nickend
</emphasis>
(
<emphasis id="021E6DCFF0764388F32C9B4D80BD0F9F" italics="true" pageId="null" pageNumber="590">
im Gebiet bei allen andern Arten 
<normalizedToken id="49421ADF75536980A8AA4B17E8185DFE" originalValue="außer" pageId="null" pageNumber="590">ausser</normalizedToken>
<taxonomicName id="C709D9D9CC5D9862F9C392D26DF6860A" authority="Nr." authorityName="Nr." class="Magnoliopsida" family="Asteraceae" genus="Aposeris" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="foetida">C. foetida Nr.</taxonomicName>
22 aufrecht
</emphasis>
)
<emphasis id="4E469AB08637580A54DD88CBEC2D215D" italics="true" pageId="null" pageNumber="590">;</emphasis>
Boden des 
<normalizedToken id="2E499BF9275B573808249F8B7A07E668" originalValue="Blütenkopfes" pageId="null" pageNumber="590">Bluetenkopfes</normalizedToken>
zerstreut behaart; 
<emphasis id="57D9ED96F678BFE21685296F9B1C90B4" italics="true" pageId="null" pageNumber="590">Kronen 5</emphasis>
- 
<emphasis id="7CD5CB64517272443449C327A3F6E765" italics="true" pageId="null" pageNumber="590">8 mm lang;</emphasis>
innere 
<normalizedToken id="4630535485A2DDD9D788BCB122DD9A63" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
oft mit kurzem Schnabel. - 
<normalizedToken id="C72A648F457623AEC8124682CC6DA6B2" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: 
<normalizedToken id="87F6C7885A8969CDC18A5EE704B6B2C1" originalValue="Später" pageId="null" pageNumber="590">Spaeter</normalizedToken>
<normalizedToken id="DD2F191F20C3CBA889C539E09F245BDA" originalValue="Frühling" pageId="null" pageNumber="590">Fruehling</normalizedToken>
und 
<normalizedToken id="C4CE5532AC311FB054AE23F5D86ABDEA" originalValue="früher" pageId="null" pageNumber="590">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="2C864746388CDE9F6E49AEC5DF19974D" pageId="null" pageNumber="590">
<emphasis id="58B69A21A6BDD50EEA864C5978BE4A54" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="1E51B97F59B7EC5F8A0F5C71729AA6B7" italics="true" pageId="null" pageNumber="590">8:</emphasis>
Material aus botanischem Garten (Babcock 1947, Wagenaar 1969).
</paragraph>
<paragraph id="C5703B41B97F441C1A39155B964FD524" pageId="null" pageNumber="590">
<emphasis id="B5720FB10051094755B9A006CC27F799" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Kollin. Trockene, sandige 
<normalizedToken id="7ED54ACDBB11F54BB2E03562EDBB1148" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
in warmen Lagen. Trockenrasen, 
<normalizedToken id="7236F2AE939A227A9B6509498D299123" originalValue="Wegränder" pageId="null" pageNumber="590">Wegraender</normalizedToken>
, Felder.
</paragraph>
<paragraph id="B71DE16A908AF0594110556C9E236A57" pageId="null" pageNumber="590">
<emphasis id="C07E7323F39C0618A1BEE5127F79FE56" italics="true" pageId="null" pageNumber="590">
<pageBreakToken id="101F6B1A44C01DF354A118A75CFA3C32" pageId="null" pageNumber="590">Verbreitung</pageBreakToken>
. 
<normalizedToken id="754D34E2E55F287869B2765642BC4169" originalValue="Südosteuropäische" pageId="null" pageNumber="590">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
West- und 
<normalizedToken id="567F6925BCA682C9FBA383388430786C" originalValue="nordwärts" pageId="null" pageNumber="590">nordwaerts</normalizedToken>
bis Kalabrien, Westalpen, 
<normalizedToken id="20DE47922AA96F6A13E6CEDA4A96A972" originalValue="Südalpen" pageId="null" pageNumber="590">Suedalpen</normalizedToken>
, Kroatien, 
<normalizedToken id="ABD6A9D675BABD362784D11737AAB274" originalValue="Südbulgarien" pageId="null" pageNumber="590">Suedbulgarien</normalizedToken>
; 
<normalizedToken id="3A1BCDC752598C7AC2D978890AACA351" originalValue="ostwärts" pageId="null" pageNumber="590">ostwaerts</normalizedToken>
bis Thrazien und nordwestliches Kleinasien. - Im Gebiet: Gegend von Biella, Valsesia (Valsabbiola), Bergamasker Alpen (Val San Martino); sonst selten adventiv.
</paragraph>
</subSubSection>
