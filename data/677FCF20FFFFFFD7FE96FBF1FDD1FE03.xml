<collectingCountry id="97C13EA6FFFCFFD7FECCFE7AFECBFE03" box="[304,373,412,435]" name="Brazil" pageId="38" pageNumber="313">Brazil</collectingCountry>
: 
<collectingRegion id="2D12B0D4FFFCFFD7FE83FE7AFE03FE03" box="[383,445,412,435]" country="Brazil" name="Bahia" pageId="38" pageNumber="313">Bahia</collectingRegion>
(
<bibRefCitation id="8B4703C7FFFCFFD7FE31FE7AFDDAFE03" author="SPAETH" box="[461,612,412,435]" firstAuthor="SPAETH" pageId="38" pageNumber="313" pagination="183 - 187" refId="ref51295" refString="SPAETH F. 1931 b: Wissenschaftliche Ergebnise der Swedischen Entomologischen Reisen des Herrn Dr. A. Roman in Amazonas und Bahia 1914 - 15 und 1923 - 24. Cassidinae. Entomologisk Tidskrift 53: 183 - 187." type="journal article" year="1931" yearSuffix="b">SPAETH 1931b</bibRefCitation>
).
</paragraph>
