<subSubSection id="1A3EF6DB4E231E1F4EAF6B65ADD5E313" pageId="null" pageNumber="458" type="description">
<paragraph id="27D5C7CF23140BC37D134135E96961AF" pageId="null" pageNumber="458">
<emphasis id="FB5D277E78C4DBD607DCD463D6DA8B05" italics="true" pageId="null" pageNumber="458">
<normalizedToken id="0D5F743D92037344C40E012F386D1CD4" originalValue="Blätter" pageId="null" pageNumber="458">Blaetter</normalizedToken>
<normalizedToken id="ABCB0FEDF6D6F6249B2CF3DACEE56BD4" originalValue="überall" pageId="null" pageNumber="458">ueberall</normalizedToken>
oder wenigstens auf den Nerven der Blattunterseite flaumig behaart
</emphasis>
, meist 1fach, seltener doppelt 
<normalizedToken id="8B0EE0F1B2F9A819B80B0AE78E16002B" originalValue="gezähnt" pageId="null" pageNumber="458">gezaehnt</normalizedToken>
; Blattstiele stets behaart, mit 
<normalizedToken id="9340F4BD66BD411981C1B87A0D2EDD6D" originalValue="Stieldrüsen" pageId="null" pageNumber="458">Stieldruesen</normalizedToken>
und 
<normalizedToken id="0166AE941D38C6EAD15195931B39DBB3" originalValue="sichelförmigen" pageId="null" pageNumber="458">sichelfoermigen</normalizedToken>
Stacheln. 
<normalizedToken id="47D5DF5E8006D82515D6B02519DDD79C" originalValue="Blütenstiele" pageId="null" pageNumber="458">Bluetenstiele</normalizedToken>
kahl. 
<normalizedToken id="94411DB70E0E79960A307B51613BA744" originalValue="Kelchblätter" pageId="null" pageNumber="458">Kelchblaetter</normalizedToken>
nach der 
<normalizedToken id="8507B7927010E3453689AF40797FB28E" originalValue="Blüte" pageId="null" pageNumber="458">Bluete</normalizedToken>
<emphasis id="62A9A11AE2E77E82B73BD4666790C547" italics="true" pageId="null" pageNumber="458">abstehend oder aufgerichtet</emphasis>
, bis zur Fruchtreife bleibend.
</paragraph>
<paragraph id="25ABD6B6F4CB42B6A9D12C27A3D43203" pageId="null" pageNumber="458">
<emphasis id="AC27C2477FF7E2EA304427279315A4B1" italics="true" pageId="null" pageNumber="458">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="C5DA5604E288CA2931AE9FC682EA1451" italics="true" pageId="null" pageNumber="458">28:</emphasis>
Material aus botanischen 
<normalizedToken id="2886B9A4F074B93FDF009D823C341B45" originalValue="Gärten" pageId="null" pageNumber="458">Gaerten</normalizedToken>
; 14 univalente und 14 bivalente Chromosomen (Hurst 1931). 
<emphasis id="F1CE98A501E3F47E898B7C5237929E25" italics="true" pageId="null" pageNumber="458">2n</emphasis>
= 
<emphasis id="170C5ADDCD65547D8862F12960E21117" italics="true" pageId="null" pageNumber="458">35:</emphasis>
Material aus botanischen 
<normalizedToken id="06B0D2B572B63901C0D88B2E2026DC0A" originalValue="Gärten" pageId="null" pageNumber="458">Gaerten</normalizedToken>
; 21 univalente und 14 bivalente Chromosomen (
<normalizedToken id="CA2636B2380B518AE5B1FF690F715658" originalValue="Täckholm" pageId="null" pageNumber="458">Taeckholm</normalizedToken>
1920 
<normalizedToken id="2A618E25012D6B2AA7CCC2E85EA692B4" originalValue="Täckholm" pageId="null" pageNumber="458">Taeckholm</normalizedToken>
1922, Blackburn und Harrison 1921, Hurst 1925, Hurst 1928, Hurst 1931). Beide Chromosomenzahlen 
<normalizedToken id="B482133274D0F7A0E245359C6735BC5F" originalValue="können" pageId="null" pageNumber="458">koennen</normalizedToken>
sich auch auf 
<taxonomicName id="FF316E8219E5CDE6436CE66B5B22170D" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="458" phylum="Tracheophyta" rank="species" species="vosagiaca">
<emphasis id="3CA91B4E73DCB8AC130647474BF9CAFA" italics="true" pageId="null" pageNumber="458">R. vosagiaca</emphasis>
</taxonomicName>
(Nr. 12e) beziehen, da die beiden Arten nicht unterschieden wurden. Material von 
<taxonomicName id="F88EB49E4A21C35D7DB87E3FFF828709" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="458" phylum="Tracheophyta" rank="species" species="coriifolia">
<emphasis id="DC0366DCD42FDAC03C92DED32953AB04" italics="true" pageId="null" pageNumber="458">R. coriifolia</emphasis>
</taxonomicName>
aus Island: 
<emphasis id="75A44324791742438713FD04A99B1C3D" italics="true" pageId="null" pageNumber="458">2n</emphasis>
= 
<emphasis id="4E51BBF22E579381FD2339F462BD1F3E" italics="true" pageId="null" pageNumber="458">35</emphasis>
(
<normalizedToken id="06F22506474B79A49DDE200010979138" originalValue="Löve" pageId="null" pageNumber="458">Loeve</normalizedToken>
und 
<normalizedToken id="D69FAAB0B3B51E99EF22E2AD4D8FA468" originalValue="Löve" pageId="null" pageNumber="458">Loeve</normalizedToken>
1956b).
</paragraph>
<paragraph id="83D5D6D741024C433145DCD89AB9D2A2" pageId="null" pageNumber="458">
<emphasis id="DEA664676F5E982FD96AF5F9D1C511A8" italics="true" pageId="null" pageNumber="458">Standort.</emphasis>
Montan und subalpin. Trockene, 
<normalizedToken id="D506D404D0C58C6894426D6DE06C751E" originalValue="nährstoffreiche" pageId="null" pageNumber="458">naehrstoffreiche</normalizedToken>
<normalizedToken id="75A5EF25B587A465C24DA9190E9E5226" originalValue="Böden" pageId="null" pageNumber="458">Boeden</normalizedToken>
in sonniger Lage. Lichtes 
<normalizedToken id="990628F61F022147B5D44ADB59A9A8F5" originalValue="Gebüsch" pageId="null" pageNumber="458">Gebuesch</normalizedToken>
(
<emphasis id="73A996A88E892CD3FA3CFE8BA00B10FD" italics="true" pageId="null" pageNumber="458">Berberis-</emphasis>
und 
<taxonomicName id="078A0B114BB17EDD9366289E72B8A478" class="Magnoliopsida" family="Betulaceae" genus="Corylus" kingdom="Plantae" order="Fagales" pageId="null" pageNumber="458" phylum="Tracheophyta" rank="genus">
<emphasis id="464FBBB42A7BBD107333DB9861F77061" italics="true" pageId="null" pageNumber="458">Corylus</emphasis>
</taxonomicName>
busch).
</paragraph>
<paragraph id="B8D1B7A0AF1C19565A7340DB8535BE37" pageId="null" pageNumber="458">
<emphasis id="ABF662C6AA5A4736F9CAEF95CE592515" italics="true" pageId="null" pageNumber="458">
Verbreitung. 
<normalizedToken id="35F11A9B0EB2BCF86E5382CA727EAFF0" originalValue="Europäische" pageId="null" pageNumber="458">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="E267233ACBCD596C25081DBE532A8F1A" originalValue="Nordwärts" pageId="null" pageNumber="458">Nordwaerts</normalizedToken>
bis Island, in Skandinavien bis 67° NB, Finnland (Ladogasee), 
<normalizedToken id="7718FE5AF2F2F38FC7447445DC5FBB44" originalValue="ostwärts" pageId="null" pageNumber="458">ostwaerts</normalizedToken>
bis an den Ural; 
<normalizedToken id="0DF257C544770D7B11DC5AB63D1DA8AC" originalValue="südwärts" pageId="null" pageNumber="458">suedwaerts</normalizedToken>
bis in die 
<normalizedToken id="B4C5C5278B67E05F5FA4D7813926A934" originalValue="Pyrenäen" pageId="null" pageNumber="458">Pyrenaeen</normalizedToken>
, Apennin, Sizilien, Griechenland, 
<normalizedToken id="DDF8B15ED9DD3B5E3F5A2EB2143AE47E" originalValue="ostwärts" pageId="null" pageNumber="458">ostwaerts</normalizedToken>
bis in den Kaukasus. - Im Gebiet verbreitet und 
<normalizedToken id="30EBEDB2CDBE3B9BA45E65E03FFCDD5F" originalValue="häufig" pageId="null" pageNumber="458">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="B3F48D8582E6B7D8209C4D4187455437" pageId="null" pageNumber="458">
<emphasis id="DD16E372BCE6565C1D9030F36A99F604" italics="true" pageId="null" pageNumber="458">Bemerkungen.</emphasis>
In Flora Europaea 
<emphasis id="D1F0B0EF1FE6A8143960F3B742F8B03C" italics="true" pageId="null" pageNumber="458">2</emphasis>
(1968) wird der Name 
<taxonomicName id="0276DBDD054F5020C45B7A96894CB1C9" authority="Sm." authorityName="Sm." class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="458" phylum="Tracheophyta" rank="species" species="caesia">
<emphasis id="5570479C96473341DA5DFF44521A19B3" italics="true" pageId="null" pageNumber="458">R. caesia</emphasis>
Sm.
</taxonomicName>
verwendet.
</paragraph>
</subSubSection>
