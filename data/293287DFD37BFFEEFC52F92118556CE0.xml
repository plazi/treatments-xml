; hauteur = 
<quantity id="66639B2CD37AFFEEFD33FBCC199C6E20" metricMagnitude="-4" metricUnit="m" metricValue="2.7" metricValueMax="2.9" metricValueMin="2.5" pageId="5" pageNumber="149" unit="mm" value="0.27" valueMax="0.29" valueMin="0.25">0,25 à 0,29 mm</quantity>
