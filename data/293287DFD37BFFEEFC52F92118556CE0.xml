<quantity id="66639B2CD37AFFEEFE00FBAC18836E20" box="[391,489,1089,1113]" metricMagnitude="-4" metricUnit="m" metricValue="2.1" pageId="5" pageNumber="149" unit="mm" value="0.21">0,21 mm</quantity>
