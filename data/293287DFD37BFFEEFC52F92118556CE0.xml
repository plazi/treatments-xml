; hauteur = 
<quantity id="66639B2CD37AFFEEFF10FBEC199C6E60" box="[151,246,1025,1049]" metricMagnitude="-4" metricUnit="m" metricValue="2.9" pageId="5" pageNumber="149" unit="mm" value="0.29">0,29 mm</quantity>
;
</paragraph>
