<subSubSection id="9983A9D91B08FFC4FD49FE2FFB02FBDA" pageId="22" pageNumber="533" type="reference_group">
<paragraph id="D126FA521B08FFC4FD49FE2FFBC3FCB5" blockId="22.[731,1328,606,1030]" pageId="22" pageNumber="533">
<emphasis id="E3ED26401B08FFC4FD49FE2FFCE8FDA7" bold="true" box="[733,888,606,635]" pageId="22" pageNumber="533">Taxonomy.</emphasis>
<taxonomicName id="169981D11B08FFC4FC1DFE2FFC13FD7F" authorityName="Contreras" authorityYear="1995" class="Mammalia" family="Ctenomyidae" genus="Ctenomys" kingdom="Animalia" order="Rodentia" pageId="22" pageNumber="533" phylum="Chordata" rank="species" species="osvaldoreigi">Ctenomys osvaldoreigi J. R. Contreras, 1995</taxonomicName>
, 
<materialsCitation id="61F1F00F1B08FFC4FC01FEF7FC26FCB5" ID-GBIF-Occurrence="3798388307" pageId="22" pageNumber="533">“Estancia San Luis, Ruta Provincial 20, 10 kilometros al oeste del Rio Yuspe, en el extremo sudeste del Departamento Cruz del Eje, Provincia de Cordoba, 31°24’ S, 64°48’ W, aproximadamente a 2000 metros,”</materialsCitation>
Argentina.
</paragraph>
<paragraph id="D126FA521B08FFC4FD75FF1FFB02FBDA" blockId="22.[731,1328,606,1030]" pageId="22" pageNumber="533">
<taxonomicName id="169981D11B08FFC4FD75FF1FFC63FC53" authorityName="Contreras" authorityYear="1995" box="[737,1011,878,911]" class="Mammalia" family="Ctenomyidae" genus="Ctenomys" kingdom="Animalia" order="Rodentia" pageId="22" pageNumber="533" phylum="Chordata" rank="species" species="osvaldoreigi">Ctenomys osvaldoreigi</taxonomicName>
is not classified in any species group. Chromosomal complementis 2n = 52 and FN = 56, and sperm 1s simple asymmetric. Monotypic.
</paragraph>
</subSubSection>
<subSubSection id="9983A9D91B08FFC4FFE8F87CFF33FB84" pageId="22" pageNumber="533" type="distribution">
<caption id="85E6AADA1B08FFC4FFE8F87CFF33FB84" ID-DOI="http://doi.org/10.5281/zenodo.6588316" ID-Zenodo-Dep="6588316" httpUri="https://zenodo.org/record/6588316/files/figure.png" inLine="true" pageId="22" pageNumber="533" targetBox="[119,710,613,1026]" targetPageId="22">
