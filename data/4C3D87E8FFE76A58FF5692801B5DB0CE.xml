<subSubSection id="8C8E6575FFE76A58FF549C9F1F47B03C" pageId="28" pageNumber="786" type="activity">
<paragraph id="C42B36FEFFE76A58FF549C9F1F47B03C" blockId="28.[168,1375,1814,3068]" pageId="28" pageNumber="786">
<emphasis id="F6E0EAECFFE76A58FF549C9F1F97B1D5" bold="true" box="[168,407,2758,2791]" pageId="28" pageNumber="786">Activity patterns.</emphasis>
