<paragraph id="3A7AFF44BAD11DFB5652D8285C9F7193" pageId="null" pageNumber="909">
<normalizedToken id="E202A270AC9A6096A7B0B61CE4764B06" originalValue="Schmalblättrige" pageId="null" pageNumber="909">Schmalblaettrige</normalizedToken>
oder Polei-Andromeda
</paragraph>
</subSubSection>
</title>
<subSubSection id="100DB797F51A1C85B63E60D1CE97FDEB" pageId="null" pageNumber="909" type="description">
<paragraph id="70FD85DB1A13BBD440874155D3E2E167" pageId="null" pageNumber="909">
<emphasis id="E8EBCC302089270D2AFE256CB2526C2A" italics="true" pageId="null" pageNumber="909">
<normalizedToken id="476293C56B2564C0ED7CD2FD7910D8E6" originalValue="Blätter" pageId="null" pageNumber="909">Blaetter</normalizedToken>
1-5 cm lang, 5-15mal so lang wie breit
</emphasis>
(der eingerollte Rand nicht mitgemessen), 
<emphasis id="CF7CAAA7B073784EA39CE3B7264607A5" italics="true" pageId="null" pageNumber="909">
oberseits mit tiefer 
<normalizedToken id="6D505E412507055CFDA318C33837C6AA" originalValue="Längsfurche" pageId="null" pageNumber="909">Laengsfurche</normalizedToken>
, unterseits mit auf der 
<normalizedToken id="E4DC9F96BAAEB9ABB6A3CC72AC90AD96" originalValue="Oberfläche" pageId="null" pageNumber="909">Oberflaeche</normalizedToken>
liegendem Mittelnerv, 
<normalizedToken id="E1D055618338433C43FC2640A9F87E02" originalValue="hellblaugrün" pageId="null" pageNumber="909">hellblaugruen</normalizedToken>
, fein zugespitzt.
</emphasis>
<normalizedToken id="92E84270DA85A501296B3B97B9398CB9" originalValue="Blüten" pageId="null" pageNumber="909">Blueten</normalizedToken>
zu 2-8 beisammen. 
<normalizedToken id="66BD90E6F8DA107BBC43562304AF0F4C" originalValue="Blütenstiele" pageId="null" pageNumber="909">Bluetenstiele</normalizedToken>
2-4mal so lang wie die 
<normalizedToken id="9339C540F3B70704279B2EB58DC149B1" originalValue="Blüten" pageId="null" pageNumber="909">Blueten</normalizedToken>
. Kelch bis auf ⅓ 5teilig. 
<emphasis id="4C16964700A069B6326609F7A98B8016" italics="true" pageId="null" pageNumber="909">Krone 5-8 mm lang</emphasis>
, 
<normalizedToken id="F014E944029A4B189FE14A705F0D412D" originalValue="eiförmig" pageId="null" pageNumber="909">eifoermig</normalizedToken>
. 
<emphasis id="FFCDFC250856CA0D01B9399F727F1587" italics="true" pageId="null" pageNumber="909">
<normalizedToken id="6454996F6641F9B57ADC8028029DE0D2" originalValue="Staubfäden" pageId="null" pageNumber="909">Staubfaeden</normalizedToken>
abstehend und lang behaart.
</emphasis>
- 
<normalizedToken id="67060C1E84F5DE2840D903639E094A0A" originalValue="Blüte" pageId="null" pageNumber="909">Bluete</normalizedToken>
: 
<normalizedToken id="BF3E6BD651C2D24FA139A4BBA01D4FED" originalValue="Früher" pageId="null" pageNumber="909">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="45C8C4097C513F3BEF43ADB175C7C744" pageId="null" pageNumber="909">
<emphasis id="31518AF5518C69BB060689782447E0E0" italics="true" pageId="null" pageNumber="909">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="3A27D79111583F14F9A4CB780CE9FD42" italics="true" pageId="null" pageNumber="909">48:</emphasis>
Material aus 
<normalizedToken id="A708C7E111CC761E2A3A682B721A045E" originalValue="Dänemark" pageId="null" pageNumber="909">Daenemark</normalizedToken>
(Hagerup 1928), aus Finnland (Sorsa 1963), aus Alaska (Johnson und Packer 1968).
</paragraph>
<paragraph id="0FDD9336DFE60E2829D77429B36D2FF4" pageId="null" pageNumber="909">
<emphasis id="968ED65BD2F33161CE6BB3518F67B762" italics="true" pageId="null" pageNumber="909">Standort.</emphasis>
Ivollin, montan und subalpin. Nasse, saure, 
<normalizedToken id="715BC1B4352DC4AD5798C061FB3713ED" originalValue="nährstoffarme" pageId="null" pageNumber="909">naehrstoffarme</normalizedToken>
<normalizedToken id="E566F3C7393F7B24C7C29B7349AAA4F0" originalValue="Böden" pageId="null" pageNumber="909">Boeden</normalizedToken>
. Auf 
<normalizedToken id="3B4DF4C871B017A86EEDFC2D6BF8535F" originalValue="Bülten" pageId="null" pageNumber="909">Buelten</normalizedToken>
aus 
<taxonomicName id="CB0D7A056468A3392D19DA9D10447494" class="Sphagnopsida" family="Sphagnaceae" genus="Sphagnum" kingdom="Plantae" order="Sphagnales" pageId="null" pageNumber="909" phylum="Bryophyta" rank="genus">
<emphasis id="F78ED26121D3C31121463FFF42EC945F" italics="true" pageId="null" pageNumber="909">Sphagnum</emphasis>
</taxonomicName>
moosen in Hochmooren.
</paragraph>
<paragraph id="D5851F337C5405A05152970400FDFEAF" pageId="null" pageNumber="909">
<emphasis id="449747329A02F1ED5647613BDB6BD973" italics="true" pageId="null" pageNumber="909">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
<normalizedToken id="74E0E3501FECE1093FE26DC563E15F78" originalValue="Nordwärts" pageId="null" pageNumber="909">Nordwaerts</normalizedToken>
bis Schottland, Nordkap (71° NB), 
<normalizedToken id="2E5BBFA223622D77B1546B6F9D4A5559" originalValue="Nordrußland" pageId="null" pageNumber="909">Nordrussland</normalizedToken>
, in Asien 
<normalizedToken id="B2B5ECBE62F410DBB092F6D2136B21D5" originalValue="nordwärts" pageId="null" pageNumber="909">nordwaerts</normalizedToken>
bis ca. 65° NB; 
<normalizedToken id="BD9DC82806249C40C0BF132C8E1B0B1C" originalValue="südwärts" pageId="null" pageNumber="909">suedwaerts</normalizedToken>
bis 
<normalizedToken id="FA91D4B5480A93BCA76B52F88E0FFAE6" originalValue="Pyrenäen" pageId="null" pageNumber="909">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="42B8B609FE5F9A61ABC0D386E233D364" originalValue="Südalpen" pageId="null" pageNumber="909">Suedalpen</normalizedToken>
(Norditalien), Karpaten, 
<normalizedToken id="1855248BE3AB07A135E29515AE09CF5F" originalValue="Zentralrußland" pageId="null" pageNumber="909">Zentralrussland</normalizedToken>
, in Asien 
<normalizedToken id="20D53978E88AF3AA740CA7342A8EA013" originalValue="südwärts" pageId="null" pageNumber="909">suedwaerts</normalizedToken>
bis ca. 50° NB (Altai, Mongolei); 
<normalizedToken id="D18D04ED9551845B12301768448FFBA1" originalValue="ostwärts" pageId="null" pageNumber="909">ostwaerts</normalizedToken>
bis Japan und Tschuktschen-Halbinsel; in Nordamerika von den arktischen Gebieten 
<normalizedToken id="1EA1FA1AB27C48D0202E8E58FC85171D" originalValue="südwärts" pageId="null" pageNumber="909">suedwaerts</normalizedToken>
bis Indiana, Pennsylvanien und New Jersey; 
<normalizedToken id="BEBA5FF003A87DB0F9E00E0B154A1799" originalValue="Grönland" pageId="null" pageNumber="909">Groenland</normalizedToken>
. - Im Gebiet zerstreut und ziemlich selten; der Meliorationen wegen viele Fundorte 
<normalizedToken id="816D9EF2DE1068AE638F51E83052DDAE" originalValue="zerstört" pageId="null" pageNumber="909">zerstoert</normalizedToken>
.
</paragraph>
</subSubSection>
