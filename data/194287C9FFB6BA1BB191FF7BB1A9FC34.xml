<taxonomicName id="56EB4D5CFFB6BA1AB376FA43BA0AF2F2" baseAuthorityName="Wagner" baseAuthorityYear="1843" box="[1892,2092,3363,3388]" class="Mammalia" family="Molossidae" genus="Eumops" kingdom="Animalia" order="Chiroptera" pageId="10" pageNumber="629" phylum="Chordata" rank="species" species="glaucinus">Eumops glaucinus</taxonomicName>
