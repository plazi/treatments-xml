<taxonomicName id="56EB4D5CFFB6BA1ABD91FA43B487F2AD" authority="Dwarf Bonneted Bat" authorityName="Dwarf Bonneted Bat" class="Mammalia" family="Molossidae" genus="Eumops" kingdom="Animalia" order="Chiroptera" pageId="10" pageNumber="629" phylum="Chordata" rank="genus">Eumops Dwarf Bonneted Bat</taxonomicName>
(
<taxonomicName id="56EB4D5CFFB6BA1AB2A0FA2AB5BEF2AD" authorityName="Thomas" authorityYear="1924" box="[1714,1944,3402,3427]" class="Mammalia" family="Molossidae" genus="Eumops" kingdom="Animalia" order="Chiroptera" pageId="10" pageNumber="629" phylum="Chordata" rank="species" species="patagonicus">Eumops patagonicus</taxonomicName>
