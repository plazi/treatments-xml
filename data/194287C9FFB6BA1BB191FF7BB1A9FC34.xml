<taxonomicName id="56EB4D5CFFB6BA1ABCF2FA2ABBABF2AD" baseAuthorityName="Schinz" baseAuthorityYear="1821" box="[2272,2445,3402,3427]" class="Mammalia" family="Molossidae" genus="Eumops" kingdom="Animalia" order="Chiroptera" pageId="10" pageNumber="637" phylum="Chordata" rank="species" species="perotis">Eumops perotis</taxonomicName>
