<paragraph id="6937E6AA1AB1A40A37855CF5A9E288DA" pageId="null" pageNumber="790">
<taxonomicName id="C15C4F444D2FE0D932F99F4334ECEA10" authority="L." class="Magnoliopsida" family="Caryophyllaceae" genus="Saponaria" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="790" phylum="Tracheophyta" rank="species" species="lutea">
