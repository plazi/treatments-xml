<subSubSection id="C2051E1BE287B6833594A7D9E671B4EA" pageId="null" pageNumber="83" type="description">
<paragraph id="027C90C8DEED15F961E48073F76B681E" pageId="null" pageNumber="83">
<emphasis id="209DE65BEE86B0AEFC054A43B45B67C0" italics="true" pageId="null" pageNumber="83">
1 
<normalizedToken id="7083CEC12C36D6AE7B5CFD02E5F7C803" originalValue="jährig" pageId="null" pageNumber="83">jaehrig</normalizedToken>
;
</emphasis>
5-30 cm hoch, 
<emphasis id="920D6D39134B46229DB16AA99BC5F7FE" italics="true" pageId="null" pageNumber="83">wollig behaart.</emphasis>
Kein Rhizom. 
<normalizedToken id="6CB2D6D85DE9B4E486E63B6F54306238" originalValue="Grundständige" pageId="null" pageNumber="83">Grundstaendige</normalizedToken>
<normalizedToken id="1430BFEB4065940BFA490DE687A1BC04" originalValue="Blätter" pageId="null" pageNumber="83">Blaetter</normalizedToken>
wenig tief, 
<normalizedToken id="1760AE3739FBB5509B8311699CA7F8DE" originalValue="höchstens" pageId="null" pageNumber="83">hoechstens</normalizedToken>
bis auf ⅓ 3teilig; Abschnitte grob 
<normalizedToken id="BDF3E89988A5C6871C72376C3491A70A" originalValue="gezähnt" pageId="null" pageNumber="83">gezaehnt</normalizedToken>
. Stengel mehrere, 
<emphasis id="E4EE46928AFD2BA9DC7B665C91121302" italics="true" pageId="null" pageNumber="83">niederliegend oder schief aufsteigend.</emphasis>
<normalizedToken id="7D1FF4A900799C07C516EF2F8CC8EF98" originalValue="Stengelblätter" pageId="null" pageNumber="83">Stengelblaetter</normalizedToken>
gestielt, untere wie die 
<normalizedToken id="29EA3CC825610BB51EA6E4C441BD68CC" originalValue="grundständigen" pageId="null" pageNumber="83">grundstaendigen</normalizedToken>
<normalizedToken id="221C63ED1D56D643AFE8DAB4024477B5" originalValue="Blätter" pageId="null" pageNumber="83">Blaetter</normalizedToken>
, obere mit 
<normalizedToken id="3FB0B8DFFC49D455B971FF39B9C605FF" originalValue="schmäleren" pageId="null" pageNumber="83">schmaeleren</normalizedToken>
, lanzettlichen Abschnitten. 
<normalizedToken id="1EA801B6033201A946237A472456EFE7" originalValue="Blütenstiele" pageId="null" pageNumber="83">Bluetenstiele</normalizedToken>
meist zahlreich, den 
<normalizedToken id="4674906D52F19D9DD88C7A0C8D333BB0" originalValue="Stengelblättern" pageId="null" pageNumber="83">Stengelblaettern</normalizedToken>
<normalizedToken id="9C7C68CD6D1A3C52B4785B52ED80EDF0" originalValue="gegenüber" pageId="null" pageNumber="83">gegenueber</normalizedToken>
, 
<emphasis id="C9C90C6157AB12E7E357EA9955DDBA49" italics="true" pageId="null" pageNumber="83">
diese nicht 
<normalizedToken id="D0EEB34B1DD6E57C9929D0D886AD7050" originalValue="überragend" pageId="null" pageNumber="83">ueberragend</normalizedToken>
. 
<normalizedToken id="CC99F32AB56E61F0CF00DD317C2D6CCD" originalValue="Blüten" pageId="null" pageNumber="83">Blueten</normalizedToken>
klein, im Durchmesser 0,4-0,6 cm
</emphasis>
, hellgelb. 
<normalizedToken id="B280175C05A15E89BF6A03177CB2878B" originalValue="Kelchblätter" pageId="null" pageNumber="83">Kelchblaetter</normalizedToken>
etwas 
<normalizedToken id="018AB853E8FC67FB704B92ABE8A8EE61" originalValue="kürzer" pageId="null" pageNumber="83">kuerzer</normalizedToken>
als die 
<normalizedToken id="756371DC89FA46809CE3674AA52B1E36" originalValue="Kronblätter" pageId="null" pageNumber="83">Kronblaetter</normalizedToken>
, den 
<normalizedToken id="34E5F26C6694A5F0221F869C7B59B319" originalValue="Kronblättern" pageId="null" pageNumber="83">Kronblaettern</normalizedToken>
nicht anliegend. 
<normalizedToken id="73F8FFE69C85D9108671F0942FAC18C3" originalValue="Früchtchen" pageId="null" pageNumber="83">Fruechtchen</normalizedToken>
rundlich, Durchmesser 2-2,5 mm, flach, berandet, 
<emphasis id="2CE5786EDD47C48555BB2F3466083D07" italics="true" pageId="null" pageNumber="83">
innerhalb des Randes beidseitig mit 
<normalizedToken id="6833C8388DFF5A1DD11C8B09A0404615" originalValue="Höckern" pageId="null" pageNumber="83">Hoeckern</normalizedToken>
dicht besetzt, die auf der Spitze eine hakig gebogene Borste tragen;
</emphasis>
Schnabel 0,5-0,7 mm lang, breit angesetzt, etwas gebogen. 
<normalizedToken id="8580C76E24CEB169E1A2A7B4C646F68F" originalValue="Blütenboden" pageId="null" pageNumber="83">Bluetenboden</normalizedToken>
kahl. - 
<normalizedToken id="1B047588CA49B6CC5435B1E1B043D9D5" originalValue="Blüte" pageId="null" pageNumber="83">Bluete</normalizedToken>
: 
<normalizedToken id="4CA091C7A3069E78243A36981C4F8B04" originalValue="Später" pageId="null" pageNumber="83">Spaeter</normalizedToken>
<normalizedToken id="EEA9A2B0EA87C51301BA31C7528A6990" originalValue="Frühling" pageId="null" pageNumber="83">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="63D5989A35F16BE74F24E0597BBED67E" pageId="null" pageNumber="83">
<emphasis id="E8F9D9CCCA50CAD489DD685857E4A592" italics="true" pageId="null" pageNumber="83">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="EC7930B6EF594682704077D99317C602" italics="true" pageId="null" pageNumber="83">14:</emphasis>
Material von 4 Fundstellen in Portugal. Keine 
<normalizedToken id="22A0C7318CF435703EC891BA70EC4689" originalValue="äußern" pageId="null" pageNumber="83">aeussern</normalizedToken>
morphologischen Unterschiede zwischen Pflanzen mit 14 und 28 Chromosomen (Neves 1944). 
<emphasis id="434213EA2EF782E40D6FDD6FE722C0DF" italics="true" pageId="null" pageNumber="83">2n</emphasis>
= 
<emphasis id="C051614FBFD7AAE6AD96F55E8A30E8EE" italics="true" pageId="null" pageNumber="83">28:</emphasis>
Material aus botanischen 
<normalizedToken id="50545FB1E841FEB867FB5D9ADF1E745B" originalValue="Gärten" pageId="null" pageNumber="83">Gaerten</normalizedToken>
(Langlet 1927Langlet 1932, Larter 1932, Neves 1944).
</paragraph>
<paragraph id="DAE9066F06DFDD7BA17C02E4BFABCF2D" pageId="null" pageNumber="83">
<emphasis id="30BBE24D20B890FCBCC660587EC21AA2" italics="true" pageId="null" pageNumber="83">Standort.</emphasis>
Kollin. Trockene, kalkarme 
<normalizedToken id="FB8ED161FFF2CAD58626B0226497C394" originalValue="Böden" pageId="null" pageNumber="83">Boeden</normalizedToken>
. Schuttstellen.
</paragraph>
<paragraph id="7E611737F3DC524A1617DA1EEB1B95EE" pageId="null" pageNumber="83">
<emphasis id="10B5A6014A924FAD5E48A950DC899309" italics="true" pageId="null" pageNumber="83">Verbreitung. Mediterrane Pflanze:</emphasis>
Ganzes Mittelmeergebiet, der atlantischen 
<normalizedToken id="BB777406A9A5C620842E2F7A1736F906" originalValue="Küste" pageId="null" pageNumber="83">Kueste</normalizedToken>
entlang 
<normalizedToken id="012AB6A8E08238FAC369245C42F1D979" originalValue="nordwärts" pageId="null" pageNumber="83">nordwaerts</normalizedToken>
bis 
<normalizedToken id="A64BE6A9AC9B2E35D1847C50359F55EE" originalValue="Südengland" pageId="null" pageNumber="83">Suedengland</normalizedToken>
. Verschleppt nach Nordamerika, Australien, Neuseeland. - Im Gebiet gelegentlich adventiv (mehrfach angegeben aus den Bergamasker Alpen).
</paragraph>
</subSubSection>
