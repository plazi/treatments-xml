<subSubSection id="752D9EF6A1BD21BDBAE303C1F2B6F8C3" pageId="null" pageNumber="12" type="description">
<paragraph id="64CC003132BD9931582F0031B7A11120" pageId="null" pageNumber="12">
<normalizedToken id="7BF9A454DE551AA1A93560D5343B2E44" originalValue="Blätter" pageId="null" pageNumber="12">Blaetter</normalizedToken>
<normalizedToken id="500D5D4B3DDA7F0B182FDA9FFD6385CA" originalValue="sommergrün" pageId="null" pageNumber="12">sommergruen</normalizedToken>
, meist ungeteilt. 
<emphasis id="913D6CA6614D39E326880C2984AD9A0D" italics="true" pageId="null" pageNumber="12">
<normalizedToken id="947107C5562B7CFE23FF24508FDF9041" originalValue="Blüten" pageId="null" pageNumber="12">Blueten</normalizedToken>
in dichten Rispen
</emphasis>
, ⚥. Kelch 
<normalizedToken id="B66771D57FD1FF17E53900209F5F0459" originalValue="glockenförmig" pageId="null" pageNumber="12">glockenfoermig</normalizedToken>
, 
<normalizedToken id="182F5E455C79FD52CE43BAE3542BC83B" originalValue="unregelmäßig" pageId="null" pageNumber="12">unregelmaessig</normalizedToken>
4teilig. Krone mit 
<normalizedToken id="880D4088F701EC7BCCD481479F315C23" originalValue="Röhre" pageId="null" pageNumber="12">Roehre</normalizedToken>
und ausgebreitetem, 4teiligem Rand, 
<emphasis id="E539285B530272F0CD5BD6EE252B163F" italics="true" pageId="null" pageNumber="12">
lila, violett oder 
<normalizedToken id="F02BCBD595DDB064CD1A63DACB48DFD8" originalValue="weiß" pageId="null" pageNumber="12">weiss</normalizedToken>
. Frucht eine 4samige, 
<normalizedToken id="44526B038CD38CF1EAE4CD80D252269D" originalValue="spindelförmige" pageId="null" pageNumber="12">spindelfoermige</normalizedToken>
Kapsel
</emphasis>
.
</paragraph>
<paragraph id="2B614AD37543C52EBF3D15803F1520D6" pageId="null" pageNumber="12">
Die Gattung 
<taxonomicName id="15A69F8A99AAAD2FD3EC76479034CBAA" class="Magnoliopsida" family="Oleaceae" genus="Syringa" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="12" phylum="Tracheophyta" rank="genus">
<emphasis id="C610E1126AFF30B34A4BBC1EEAB61AA7" italics="true" pageId="null" pageNumber="12">Syringa</emphasis>
</taxonomicName>
<normalizedToken id="ABC6ADD53B786ADF9ED7A75CF7F2A843" originalValue="umfaßt" pageId="null" pageNumber="12">umfasst</normalizedToken>
etwa 
<emphasis id="768492F5A4F24C46FFD3FAD6A8A9D708" italics="true" pageId="null" pageNumber="12">
30 Arten und hat 
<normalizedToken id="AE234B12F26A2A2BDC0177AEF274BB91" originalValue="osteuropäisch-asiatische" pageId="null" pageNumber="12">osteuropaeisch-asiatische</normalizedToken>
Verbreitung. Chromosomengrundzahlen:
</emphasis>
n = 22, 23, 24.
</paragraph>
