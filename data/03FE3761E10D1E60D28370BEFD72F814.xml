<emphasis id="B9235A65E10D1E60D283770EFE97FBB4" bold="true" box="[136,265,1124,1150]" pageId="4" pageNumber="278">Etymology</emphasis>
. 
<taxonomicName id="4C57FDF4E10D1E60D31C770EFEF6FBB4" box="[279,360,1124,1150]" class="Sordariomycetes" family="Pestalotiopsidaceae" genus="Pseudopestalotiopsis" kingdom="Fungi" order="Amphisphaeriales" pageId="4" pageNumber="278" phylum="Ascomycota" rank="species" species="celtidis">
