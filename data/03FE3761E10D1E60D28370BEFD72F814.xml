</taxonomicName>
refers to the host plant (
<taxonomicName id="4C57FDF4E10D1E60D071770EFC85FBB4" box="[634,795,1124,1150]" class="Magnoliopsida" family="Cannabaceae" genus="Celtis" kingdom="Plantae" order="Rosales" pageId="4" pageNumber="278" phylum="Tracheophyta" rank="species" species="sinensis">
