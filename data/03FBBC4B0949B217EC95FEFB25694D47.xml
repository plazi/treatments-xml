<caption id="DF2D5DD50949B217EC95FA16236F4FCB" ID-DOI="http://doi.org/10.5281/zenodo.6541635" ID-Zenodo-Dep="6541635" box="[151,868,1482,1506]" httpUri="https://zenodo.org/record/6541635/files/figure.png" pageId="29" pageNumber="480" startId="29.[151,250,1482,1506]" targetBox="[153,1434,741,1458]" targetPageId="29">
<paragraph id="8BED0D5D0949B217EC95FA16236F4FCB" blockId="29.[151,868,1482,1506]" box="[151,868,1482,1506]" pageId="29" pageNumber="480">
<emphasis id="B926D14F0949B217EC95FA16212B4FCB" bold="true" box="[151,288,1482,1506]" pageId="29" pageNumber="480">FIGURE 34.</emphasis>
<taxonomicName id="4C5276DE0949B217ED24FA1721C44FCB" baseAuthorityName="Boulenger" baseAuthorityYear="1888" box="[294,463,1482,1506]" class="Actinopterygii" family="Gobiidae" genus="Awaous" kingdom="Animalia" order="Perciformes" pageId="29" pageNumber="480" phylum="Chordata" rank="species" species="jayakari">
