<taxonomicName id="4C096BDAFFCEFFAB653BFEB9C045FE0C" box="[1148,1310,367,393]" class="Arachnida" family="Halacaridae" genus="Agauopsis" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trombidiformes" pageId="2" pageNumber="303" phylum="Arthropoda" rank="species" species="brevipalpus">
