<taxonomicName id="4C096BDAFFCEFFAB62F5FEB9C147FE0C" authorityName="Bartsch &amp; Chatterjee" authorityYear="2001" box="[946,1052,367,393]" class="Arachnida" family="Halacaridae" genus="Agauopsis" higherTaxonomySource="GBIF" kingdom="Animalia" order="Trombidiformes" pageId="2" pageNumber="303" phylum="Arthropoda" rank="species" species="arabia">
