<paragraph id="A4A453C90227076034531DC043F4A25A" pageId="null" pageNumber="193">
<taxonomicName id="FE39EB680D2948D1E604CC28BBD9227E" authority="(L.) DC." class="Insecta" family="Melolonthidae" genus="Diplotaxis" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="193" phylum="Arthropoda" rank="species" species="muralis">
Diplotaxis 
<normalizedToken id="B501242191EF2BC0A7B18036B56EABC3" originalValue="murális" pageId="null" pageNumber="193">muralis</normalizedToken>
(
<authorityName id="319A6AB70995C4A8EB5D4A4EF66DBB3F" pageId="null" pageNumber="193">L.</authorityName>
) DC.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="6EFF9D1AB29DC15717F61744D67D4C7B" pageId="null" pageNumber="193" type="vernacular_names">
<paragraph id="DBB6B8DBA4FF679BDAB2A09DE01310C8" pageId="null" pageNumber="193">Mauer-Doppelsame</paragraph>
</subSubSection>
</title>
<subSubSection id="B522AAD7503BF117E0CB22E09AEB742F" pageId="null" pageNumber="193" type="description">
<paragraph id="315A6D5926DA1B34EAC1772FC12A840B" pageId="null" pageNumber="193">
1-2jahrig, mit Pfahlwurzel; 10-40 cm hoch. Stengel nicht verholzt, aufsteigend, nur im untersten Teil verzweigt, meist etwas 
<normalizedToken id="2F3D63F77031EE5A815AD3BD698F7BA9" originalValue="rückwärts" pageId="null" pageNumber="193">rueckwaerts</normalizedToken>
abstehend behaart (Haare ca. 0,5 mm lang). 
<normalizedToken id="AFA2AEE6D63E33EF93EBA4D4E2403367" originalValue="Blätter" pageId="null" pageNumber="193">Blaetter</normalizedToken>
am Grunde und am Stengel (meist nicht 
<normalizedToken id="0DD201954AF9CEC0EEBFA66D110EEF44" originalValue="über" pageId="null" pageNumber="193">ueber</normalizedToken>
⅓ des fruchtenden Stengels hinauf), kurz gestielt, meist kahl, wenig tief fiederteilig oder buchtig 
<normalizedToken id="C8B862BA4D7E2DCBC799A4AD2F5C11D7" originalValue="gezähnt" pageId="null" pageNumber="193">gezaehnt</normalizedToken>
; 
<normalizedToken id="B16D1E306CD85D9E95A20FABA0E40914" originalValue="Zähne" pageId="null" pageNumber="193">Zaehne</normalizedToken>
und Abschnitte 
<normalizedToken id="7F0A1B4A2357D0C50951DD6476166262" originalValue="schräg" pageId="null" pageNumber="193">schraeg</normalizedToken>
nach vorn gerichtet, 
<emphasis id="1AF2BC77CABDD3DF40090AC3E3CB53DC" italics="true" pageId="null" pageNumber="193">
<normalizedToken id="73EF676676AEC66D3E876B0B9B8230D1" originalValue="höchstens" pageId="null" pageNumber="193">hoechstens</normalizedToken>
3mal so lang wie breit. 
<normalizedToken id="49DED6F9F8249D74545F5B28786E2FC6" originalValue="Blütenstiele" pageId="null" pageNumber="193">Bluetenstiele</normalizedToken>
1
</emphasis>
- 
<emphasis id="2EC362BC29E2E9714A1A5C9D66F4A0A5" italics="true" pageId="null" pageNumber="193">
2mal so lang wie der Kelch. 
<normalizedToken id="ED7C79B4EB17954922B29222C57931D6" originalValue="Kelchblätter" pageId="null" pageNumber="193">Kelchblaetter</normalizedToken>
</emphasis>
<normalizedToken id="A177A8B5DAB8D831C88A9624BE912B58" originalValue="±" pageId="null" pageNumber="193">+/-</normalizedToken>
<emphasis id="0E11A690FB3F60B5351A29AD45F29733" italics="true" pageId="null" pageNumber="193">abstehend, 3</emphasis>
- 
<emphasis id="2F940ACAE3D3935881E0C88372BA26D6" italics="true" pageId="null" pageNumber="193">4 mm lang</emphasis>
, meist mit einzelnen Haaren. 
<emphasis id="92F385B8090BD378D863456CEAEF4522" italics="true" pageId="null" pageNumber="193">
<normalizedToken id="BCB1AB25F4C8317566492FE6F5492D4A" originalValue="Kronblätter" pageId="null" pageNumber="193">Kronblaetter</normalizedToken>
kurz gestielt, 4
</emphasis>
- 
<emphasis id="CAA1A2DBF9E7853651DCEAD38F9F0ECE" italics="true" pageId="null" pageNumber="193">8 mm lang</emphasis>
, schwefelgelb (nach dem 
<normalizedToken id="87615CBC0DBCF09D2A6809D399A13F20" originalValue="Verblühen" pageId="null" pageNumber="193">Verbluehen</normalizedToken>
oft violett werdend). Fruchtstiele 0,5-2 cm lang. 
<normalizedToken id="59C4384CF68E017A7767C162BC9F39D4" originalValue="Früchte" pageId="null" pageNumber="193">Fruechte</normalizedToken>
aufrecht abstehend, 2-4,5 cm lang und 1,3-2,5 mm dick, mit 1-2,5 mm langem Schnabel. Samen ca. 1 mm lang. - 
<normalizedToken id="D58F69C0EBA12F0FD85AF3DD3A93B857" originalValue="Blüte" pageId="null" pageNumber="193">Bluete</normalizedToken>
: 
<normalizedToken id="362CC90B18683B3C9EB7AC1437AD7A94" originalValue="Später" pageId="null" pageNumber="193">Spaeter</normalizedToken>
<normalizedToken id="B753217731FE13D9EA6CA4046317720C" originalValue="Frühling" pageId="null" pageNumber="193">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="92B88AB373002CE618BECCE71CABE13C" pageId="null" pageNumber="193">
<emphasis id="653CCE7CDF54F084C48DABAE56D8A953" italics="true" pageId="null" pageNumber="193">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E13E6041A692CDE9AE56C38E7CF370A5" italics="true" pageId="null" pageNumber="193">44:</emphasis>
Material von zahlreichen nicht 
<normalizedToken id="FF05F65DD90BA4C6A166364B9798844E" originalValue="näher" pageId="null" pageNumber="193">naeher</normalizedToken>
bezeichneten Fundstellen (
<normalizedToken id="4F5A66D168A3C6C9D31C3845C20457EE" originalValue="Lübbert" pageId="null" pageNumber="193">Luebbert</normalizedToken>
1951). 
<normalizedToken id="AFCB03A19BFE8D344837F49BC4604E89" originalValue="Ältere" pageId="null" pageNumber="193">Aeltere</normalizedToken>
Angaben (2n = 18, 22 und 42) sind zweifelhaft.
</paragraph>
<paragraph id="633B552CAFB78CB5837F03C7508007D6" pageId="null" pageNumber="193">
<emphasis id="7CABBB305E99C5F92059A599EF8BC59B" italics="true" pageId="null" pageNumber="193">Standort.</emphasis>
Kollin, seltener montan. Offene, lockere, 
<normalizedToken id="9D602F4A6F17CD9F02FF856D28809CDF" originalValue="nährstoffreiche" pageId="null" pageNumber="193">naehrstoffreiche</normalizedToken>
<normalizedToken id="42DC1E243181CA91777CEE06C8A50F0A" originalValue="Böden" pageId="null" pageNumber="193">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="44480EAC0FA655DBEFA5F86B803A573B" originalValue="Äcker" pageId="null" pageNumber="193">Aecker</normalizedToken>
, Weinberge, 
<normalizedToken id="AA3C98F5EBE1BB8C0F9A6FA037173076" originalValue="Wegränder" pageId="null" pageNumber="193">Wegraender</normalizedToken>
, Mauern.
</paragraph>
<paragraph id="BF1800A412D5D83F5FAED93795FA196E" pageId="null" pageNumber="193">
<emphasis id="114AA111F03CD34D499950F342B22303" italics="true" pageId="null" pageNumber="193">Verbreitung.</emphasis>
<normalizedToken id="24363B778C9F41CBFE69AC0F367426C3" originalValue="Ursprünglich" pageId="null" pageNumber="193">Urspruenglich</normalizedToken>
<emphasis id="B7A021D516D9D2D581A0A6D66701DB09" italics="true" pageId="null" pageNumber="193">mediterrane Pflanze</emphasis>
, heute 
<normalizedToken id="E0D22B6A61A681CF5D4AB5A6B4649A7B" originalValue="über" pageId="null" pageNumber="193">ueber</normalizedToken>
weite Gebiete der Erde verschleppt. - Im Gebiet in den 
<normalizedToken id="ABD359E74AC56F8E722A7089AE7BDD0B" originalValue="wärmeren" pageId="null" pageNumber="193">waermeren</normalizedToken>
Gegenden, sonst 
<normalizedToken id="9E6B18B57654EF9EEE2E76F54E8950C4" originalValue="öfters" pageId="null" pageNumber="193">oefters</normalizedToken>
verschleppt.
</paragraph>
<paragraph id="41D509FEA6680B19B2C41775328338F0" pageId="null" pageNumber="193">
<emphasis id="CB46674F3C21B6B95BD7FD2D40E83A76" italics="true" pageId="null" pageNumber="193">Bemerkungen.</emphasis>
<normalizedToken id="16C015FE1CA83E21A77DA394DD39047A" originalValue="Lübbert" pageId="null" pageNumber="193">Luebbert</normalizedToken>
(1951) wies nach, 
<normalizedToken id="6ACFB1AA49DFF288359B56CEFE75548E" originalValue="daß" pageId="null" pageNumber="193">dass</normalizedToken>
oft zu beobachtende 
<normalizedToken id="E71CF988FBA9FF387614157B8A29AE0E" originalValue="Größenunterschiede" pageId="null" pageNumber="193">Groessenunterschiede</normalizedToken>
innerhalb der Art nur durch den Standort bedingt sind.
</paragraph>
</subSubSection>
