<specimenCount id="54A262FDFF8AC10FBAC7226BFBC3FC9A" box="[1019,1038,791,818]" pageId="4" pageNumber="5" type="male">♂</specimenCount>
, YS20256 
<specimenCount id="54A262FDFF8AC10FBDB1226BFB56FC9A" box="[1165,1179,791,818]" pageId="4" pageNumber="5" type="female">♀</specimenCount>
