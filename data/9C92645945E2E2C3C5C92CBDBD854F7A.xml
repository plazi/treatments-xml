<subSubSection id="32BCD5DB15FBC75B4A018C7CB670CE81" pageId="null" pageNumber="603" type="description">
<paragraph id="591233FF281FD820B6192B90C0A9DEDC" lastPageNumber="602" pageId="null" pageNumber="603">
<normalizedToken id="743CFE4C2D36F7495869BBD68FF3980A" originalValue="Blütenstand" pageId="null" pageNumber="603">Bluetenstand</normalizedToken>
wie bei 
<taxonomicName id="83C49034D894D9FC0DD4CBFD333BF30E" class="Liliopsida" family="Orchidaceae" genus="Ophrys" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="603" phylum="Tracheophyta" rank="species" species="fuciflora">
<emphasis id="86D5FD47B3626D4DCC93C924CDB38B77" italics="true" pageId="null" pageNumber="603">O. fuciflora</emphasis>
</taxonomicName>
(Nr. 1). 
<normalizedToken id="04B807CFD86D799A25FF40A0D01562C5" originalValue="Blüten" pageId="null" pageNumber="603">Blueten</normalizedToken>
: 
<normalizedToken id="A97731498266214EA53B1B391555D592" originalValue="Äußere" pageId="null" pageNumber="603">Aeussere</normalizedToken>
3 
<normalizedToken id="45D4558E88D55BB8E26E2EE7488FFC3B" originalValue="Perigonblätter" pageId="null" pageNumber="603">Perigonblaetter</normalizedToken>
<normalizedToken id="7CF4BBD5753030EF91B562541B555928" originalValue="ähnlich" pageId="null" pageNumber="603">aehnlich</normalizedToken>
denen von 
<emphasis id="8D7B0AEFCED767F2EBF80398DCB92700" italics="true" pageId="null" pageNumber="603">
<taxonomicName id="EEF2185A99EB8C788F4CE203F2A1D15F" class="Liliopsida" family="Orchidaceae" genus="Ophrys" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="603" phylum="Tracheophyta" rank="species" species="fuciflora">O. fuciflora</taxonomicName>
;
</emphasis>
die 2 seitlichen, innern 
<normalizedToken id="EFA31C1CCA3CAE195B8E30E7904B22D6" originalValue="Perigonblätter" pageId="null" pageNumber="603">Perigonblaetter</normalizedToken>
<emphasis id="1A616D7398C6FED0DF5737ACC6147B57" italics="true" pageId="null" pageNumber="603">
<normalizedToken id="EEDB8EC83F7A8302A08A59AFAFE0F24D" originalValue="fadenförmig" pageId="null" pageNumber="603">fadenfoermig</normalizedToken>
</emphasis>
, 
<normalizedToken id="625FF9919C4D5971EB020EB018BBA005" originalValue="¼" pageId="null" pageNumber="603">1/4</normalizedToken>
-⅛ 
<emphasis id="B24CCCE5A1BDBDE4D733FACA638A6A27" italics="true" pageId="null" pageNumber="603">
so lang wie die 
<normalizedToken id="4C883C0B485BCD62E9C7733FE9F2975E" originalValue="äuβern" pageId="null" pageNumber="603">aeuβern</normalizedToken>
</emphasis>
<emphasis id="F5A95C45E9FD3F36047363954BBA1E7F" italics="true" pageId="null" pageNumber="602">
<pageBreakToken id="DFC8BB8E8C9FBA3A5FA5B4C85A591DBA" pageId="null" pageNumber="602" start="start">
<normalizedToken id="1813FC1FA8302A0CEBBF0E93657826B3" originalValue="Perigonblätter" pageId="null" pageNumber="602">Perigonblaetter</normalizedToken>
</pageBreakToken>
, 
<normalizedToken id="8C998AEF5FB37C23C7FB0910AE921484" originalValue="grün" pageId="null" pageNumber="602">gruen</normalizedToken>
; Lippe
</emphasis>
⅔- 
<normalizedToken id="EEF36974FB8979017436AB34B2F5F111" originalValue="¾" pageId="null" pageNumber="602">3/4</normalizedToken>
<emphasis id="E3B3ED68AFC501E0022B60E9CCDF0727" italics="true" pageId="null" pageNumber="602">
so lang wie die 
<normalizedToken id="41C84B595ED0D7A1D1F669C3656C9F4C" originalValue="äuβeren" pageId="null" pageNumber="602">aeuβeren</normalizedToken>
<normalizedToken id="A03ABB3315DA33DA54DC1F95928E0D47" originalValue="Perigonblätter" pageId="null" pageNumber="602">Perigonblaetter</normalizedToken>
, etwa 1
</emphasis>
<normalizedToken id="13EB082875C9E951E8A15A728558A4B4" originalValue="½" pageId="null" pageNumber="602">1/2</normalizedToken>
<emphasis id="CA50678C18A3752E1D02A5C49E38E338" italics="true" pageId="null" pageNumber="602">mal so lang wie breit</emphasis>
, 3teilig, Seitenabschnitte und unterster Teil des Mittelabschnittes 
<normalizedToken id="213B849448B566C69C14F09556019F2A" originalValue="rückwärts" pageId="null" pageNumber="602">rueckwaerts</normalizedToken>
gebogen, 
<emphasis id="F72DC9140BE1C7C27D8FE13B6BD651B8" italics="true" pageId="null" pageNumber="602">
Mittelabschnitte mit 
<normalizedToken id="32D30D9D9AE0BAFA045AFAF2F15AA3E6" originalValue="rückwärts" pageId="null" pageNumber="602">rueckwaerts</normalizedToken>
oder 
<normalizedToken id="EB9F059ED9615C5CA4DA521FDFAE3DF3" originalValue="abwärts" pageId="null" pageNumber="602">abwaerts</normalizedToken>
gerichtetem, 
<normalizedToken id="309EEE6E494B08A2B9CCA244D93278F5" originalValue="gelbgrünem" pageId="null" pageNumber="602">gelbgruenem</normalizedToken>
, 
<normalizedToken id="25FE4258409197BD7CBF36E49D08FAC5" originalValue="lappenförmigem" pageId="null" pageNumber="602">lappenfoermigem</normalizedToken>
<normalizedToken id="14E97318DE63C12FAE683ED87ABF7481" originalValue="Anhängsel" pageId="null" pageNumber="602">Anhaengsel</normalizedToken>
</emphasis>
(
<emphasis id="149DF95E599ED5C2DA6CCFDBC5C6B445" italics="true" pageId="null" pageNumber="602">
<normalizedToken id="26F0593CC7CF364F495A164EE174FADC" originalValue="Anhängsel" pageId="null" pageNumber="602">Anhaengsel</normalizedToken>
etwa doppelt so lang wie breit
</emphasis>
), 
<emphasis id="FDA715AF692E738782E8EB6DFFC60E8F" italics="true" pageId="null" pageNumber="602">braun</emphasis>
, mit meist gelben Linien und Flecken, samtig, 
<normalizedToken id="214DEF8ADB54CEF1B9BC52881632D44D" originalValue="über" pageId="null" pageNumber="602">ueber</normalizedToken>
den Seitenabschnitten und am Grunde mit je 2 
<normalizedToken id="DD6F368551ACE98E99482BF2DD1B50D6" originalValue="Höckern" pageId="null" pageNumber="602">Hoeckern</normalizedToken>
. - 
<normalizedToken id="296C653317C9C8D1B588C2B1E7CDD3A5" originalValue="Blüte" pageId="null" pageNumber="602">Bluete</normalizedToken>
: 
<normalizedToken id="C03DBB162F29FEE94BA0B82F0418B5BA" originalValue="Früher" pageId="null" pageNumber="602">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="BCEB0A32CF1EAF8119BD376D19DE8693" pageId="null" pageNumber="602">
<emphasis id="5C8777AEEACC5E6ED39F477AB435B9DD" italics="true" pageId="null" pageNumber="602">Zytologische Angaben. 2n = 36:</emphasis>
Material aus Glattfelden (
<normalizedToken id="F9EE8183A681F20220BB8B3036F2E8C0" originalValue="Zürich" pageId="null" pageNumber="602">Zuerich</normalizedToken>
) (Heusser 1938); ohne Herkunftsangabe (Barber 1942), aus Holland (Kliphuis 1963, Gadella und Kliphuis 1963).
</paragraph>
<paragraph id="F29E353BD2DE16E81FE3BA7E84BF81C2" pageId="null" pageNumber="602">
<emphasis id="E769263C19893FD223D0A7B5830752AD" italics="true" pageId="null" pageNumber="602">Standort.</emphasis>
Kollin und montan. Trockene, kalkhaltige, lockere humose 
<normalizedToken id="B6D45C328464CF4DBB08B1A77A64AFEE" originalValue="Böden" pageId="null" pageNumber="602">Boeden</normalizedToken>
. Besonders in Trespen-Halbtrockenwiesen (wie 
<taxonomicName id="A25F24816D81968A1CFC1997CB5E1D57" class="Liliopsida" family="Orchidaceae" genus="Ophrys" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="602" phylum="Tracheophyta" rank="species" species="fuciflora">
<emphasis id="4B136BDCB34FB7FAC55BD230D091444A" italics="true" pageId="null" pageNumber="602">O. fuciflora</emphasis>
</taxonomicName>
), zudem in lichten 
<normalizedToken id="950F076941BC28FA5DE5031710A5B39C" originalValue="Föhrenwäldern" pageId="null" pageNumber="602">Foehrenwaeldern</normalizedToken>
; selten auf schweren, mergeligen, wechselfeuchten 
<normalizedToken id="0CE81F0B9E3E81F81650AAD1139E5DCE" originalValue="Böden" pageId="null" pageNumber="602">Boeden</normalizedToken>
an steilen 
<normalizedToken id="1D1EBCC02A0888CD31027EFA486D0A64" originalValue="Hängen" pageId="null" pageNumber="602">Haengen</normalizedToken>
im 
<taxonomicName id="3D015F2A3ADAE537DAA7691A68D6F76E" authority="Scherrer 1925" authorityName="Scherrer" authorityYear="1925" class="Liliopsida" family="Poaceae" genus="Molinietum" higherTaxonomySource="GBIF" kingdom="Plantae" order="Poales" pageId="null" pageNumber="602" phylum="Tracheophyta" rank="species" species="litoralis">
<emphasis id="45AF4FAC002EBBA959FCC494B2FFB895" italics="true" pageId="null" pageNumber="602">Molinietum litoralis</emphasis>
Scherrer 1925
</taxonomicName>
.
</paragraph>
<paragraph id="452266BA67BD7EDC4441D06D2151F947" pageId="null" pageNumber="602">
<emphasis id="7A6DDB3BD98824DFAA3B9DF6827727BF" italics="true" pageId="null" pageNumber="602">Verbreitung. Mediterrane Pflanze:</emphasis>
Allgemeine Verbreitung wie 
<taxonomicName id="A18EB42BB0F6108A20AE2397F49E3717" class="Liliopsida" family="Orchidaceae" genus="Ophrys" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="602" phylum="Tracheophyta" rank="species" species="fuciflora">
<emphasis id="589175CFCDAA6C941EB40139D0449698" italics="true" pageId="null" pageNumber="602">O. fuciflora</emphasis>
</taxonomicName>
(Nr. 1), jedoch 
<normalizedToken id="32DCAE23741B69B16B6DF218804534F5" originalValue="nordwärts" pageId="null" pageNumber="602">nordwaerts</normalizedToken>
bis Nordengland, 
<normalizedToken id="02D61672FB20CD743BD9DDF71DE9E632" originalValue="ostwärts" pageId="null" pageNumber="602">ostwaerts</normalizedToken>
bis Nordpersien, 
<normalizedToken id="FD4F1A1E70EE83E330DFFA05E91CCB4C" originalValue="südwärts" pageId="null" pageNumber="602">suedwaerts</normalizedToken>
bis Nordwestafrika. Verbreitungskarte von Meusel (1964). - Im Gebiet verbreitet, aber selten.
</paragraph>
<paragraph id="9D5FB511774071EA9CD26FE1DE246AFD" pageId="null" pageNumber="603">
<emphasis id="9A91C67613A09B2C56F58F95BB70031E" italics="true" pageId="null" pageNumber="603">
<pageBreakToken id="D699268F1612C9D5EAD7A779C35D3A89" pageId="null" pageNumber="603">Bemerkungen</pageBreakToken>
.
</emphasis>
Die ssp. 
<emphasis id="E2F008D705984B6C20833B4B6702C385" italics="true" pageId="null" pageNumber="603">Botteroni</emphasis>
(Chodat) A. et G. unterscheidet sich vom Typus durch 
<normalizedToken id="A20975CD374501C9B1CD79F6D06DAF0B" originalValue="größere" pageId="null" pageNumber="603">groessere</normalizedToken>
, innere 
<normalizedToken id="9306F209D1DEFBB680587FCEF3D6297F" originalValue="Perigonblätter" pageId="null" pageNumber="603">Perigonblaetter</normalizedToken>
; sie sind etwa ⅔ so lang und fast so breit wie die 
<normalizedToken id="8A14BA85054104CFC709294568B919A8" originalValue="äußern" pageId="null" pageNumber="603">aeussern</normalizedToken>
<normalizedToken id="F2DC5829AA0F20B690FFF859CCDAA2FA" originalValue="Perigonblätter" pageId="null" pageNumber="603">Perigonblaetter</normalizedToken>
. Die Sippe ist nach Keller und Schlechter (1928) auf die Schweiz 
<normalizedToken id="3DB6AF18D349B1AC3755D534DCA1DC86" originalValue="beschränkt" pageId="null" pageNumber="603">beschraenkt</normalizedToken>
, wird von Oberdorfer (1962) und Bertsch (1962) auch aus 
<normalizedToken id="C37A184198EB1F18C63940D8BD5C2622" originalValue="Süddeutschland" pageId="null" pageNumber="603">Sueddeutschland</normalizedToken>
, von Issler et al. (1965) aus dem Sundgau angegeben; sie sollte untersucht werden.
</paragraph>
</subSubSection>
