<emphasis id="B978B332687FFFB5FF2F0BC327D59950" bold="true" box="[189,1221,755,784]" italics="true" pageId="5" pageNumber="182">
Notes on 
<taxonomicName id="4C0C14A3687FFFB5FEAB0BC42097994F" authority="(Fowler, 1899)" baseAuthorityName="Fowler" baseAuthorityYear="1899" box="[313,903,755,784]" class="Insecta" family="Cicadellidae" genus="Platygonia" kingdom="Animalia" order="Hemiptera" pageId="5" pageNumber="182" phylum="Arthropoda" rank="species" species="undecimmaculata">
Platygonia undecimmaculata (
<bibRefCitation id="EF9D12D1687FFFB5FD5C0BC4206C994F" author="Fowler W. W." box="[718,892,755,784]" pageId="5" pageNumber="182" pagination="249 - 256" refId="ref3918" refString="Fowler W. W. 1899. Order Rhynchota. Suborder Hemiptera-Homoptera. Biologia Centrali-Americana 2: 249 - 256, pl. 16. https: // doi. org / 10.5962 / bhl. title. 730" type="journal article" year="1899">Fowler, 1899</bibRefCitation>
)
</taxonomicName>
, reinstated combination
</emphasis>
</paragraph>
</subSubSection>
<subSubSection id="C3163CAB687FFFB6FF2F0A1E22E19B93" lastPageId="6" lastPageNumber="183" pageId="5" pageNumber="182" type="discussion">
<paragraph id="8BB36F20687FFFB6FF2F0A1E22E19B93" blockId="5.[188,1400,808,1045]" lastBlockId="6.[188,1400,265,467]" lastPageId="6" lastPageNumber="183" pageId="5" pageNumber="182">
<taxonomicName id="4C0C14A3687FFFB5FF2F0A1E21089902" authorityName="Fowler" authorityYear="1899" box="[189,536,808,834]" class="Insecta" family="Cicadellidae" genus="Tettigonia" kingdom="Animalia" order="Hemiptera" pageId="5" pageNumber="182" phylum="Arthropoda" rank="species" species="undecimmaculata">
<emphasis id="B978B332687FFFB5FF2F0A1E21089902" box="[189,536,808,834]" italics="true" pageId="5" pageNumber="182">Tettigonia undecimmaculata</emphasis>
</taxonomicName>
was described by 
<bibRefCitation id="EF9D12D1687FFFB5FCB30A1F20C59902" author="Fowler W. W." box="[801,981,808,834]" pageId="5" pageNumber="182" pagination="249 - 256" refId="ref3918" refString="Fowler W. W. 1899. Order Rhynchota. Suborder Hemiptera-Homoptera. Biologia Centrali-Americana 2: 249 - 256, pl. 16. https: // doi. org / 10.5962 / bhl. title. 730" type="journal article" year="1899">Fowler (1899)</bibRefCitation>
(
<figureCitation id="133773A5687FFFB5FC600A1F27549902" box="[1010,1092,808,834]" captionStart="Figs 7–8" captionStartId="5.[189,242,1958,1984]" captionTargetBox="[270,1319,1129,1916]" captionTargetId="figure-246@5.[264,1323,1123,1919]" captionTargetPageId="5" captionText="Figs 7–8. Platygonia undecimmaculata (Fowler, 1899), holotype, ♀. 7. Original illustration provided by Fowler (1899: tab. xvi, fig. 21). 8. Body, in dorsal view, from Wilson et al. (2009)." figureDoi="http://doi.org/10.5281/zenodo.6402878" httpUri="https://zenodo.org/record/6402878/files/figure.png" pageId="5" pageNumber="182">Fig. 7</figureCitation>
) based on 
<specimenCount id="9D0AA4A9687FFFB5FB7B0A1F26679902" box="[1257,1399,808,834]" pageId="5" pageNumber="182" type="female">one female</specimenCount>
(
<typeStatus id="54B7D182687FFFB5FF570A7C223F9926" box="[197,303,843,870]" pageId="5" pageNumber="182">holotype</typeStatus>
) (
<figureCitation id="133773A5687FFFB5FEDB0A7C22809925" box="[329,400,843,869]" captionStart="Figs 7–8" captionStartId="5.[189,242,1958,1984]" captionTargetBox="[270,1319,1129,1916]" captionTargetId="figure-246@5.[264,1323,1123,1919]" captionTargetPageId="5" captionText="Figs 7–8. Platygonia undecimmaculata (Fowler, 1899), holotype, ♀. 7. Original illustration provided by Fowler (1899: tab. xvi, fig. 21). 8. Body, in dorsal view, from Wilson et al. (2009)." figureDoi="http://doi.org/10.5281/zenodo.6402878" httpUri="https://zenodo.org/record/6402878/files/figure.png" pageId="5" pageNumber="182">Fig. 8</figureCitation>
) from the Province of 
<collectingRegion id="49C8A1C2687FFFB5FD310A7C20159925" box="[675,773,843,869]" country="Panama" name="Chiriqui" pageId="5" pageNumber="182">Chiriquí</collectingRegion>
, 
<collectingCountry id="F31B2FB0687FFFB5FC860A7C20619925" box="[788,881,843,869]" name="Panama" pageId="5" pageNumber="182">Panama</collectingCountry>
(
<bibRefCitation id="EF9D12D1687FFFB5FC100A7C27089926" author="Young D. A." box="[898,1048,843,870]" pageId="5" pageNumber="182" pagination="161 - 199" refId="ref4612" refString="Young D. A. 1965. Cicadelline types in the British Museum (Natural History) (Homoptera: Cicadellidae). Bulletin of the British Museum (Natural History), Entomology 17: 161 - 199. https: // doi. org / 10.5962 / bhl. part. 14810" type="journal article" year="1965">Young 1965</bibRefCitation>
). 
<bibRefCitation id="EF9D12D1687FFFB5FBBC0A7C27FF9926" author="Melichar L." box="[1070,1263,843,870]" pageId="5" pageNumber="182" pagination="329 - 410" refId="ref4201" refString="Melichar L. 1925. Monographie der Cicadellinen. II. Annales Historico-Naturales Musei Nationalis Hungarici 22: 329 - 410." type="journal article" year="1925">Melichar (1925)</bibRefCitation>
transferred 
<taxonomicName id="4C0C14A3687FFFB5FF2C0A5822BC99C8" authorityName="Fowler" authorityYear="1899" box="[190,428,878,905]" class="Insecta" family="Cicadellidae" genus="Tettigonia" kingdom="Animalia" order="Hemiptera" pageId="5" pageNumber="182" phylum="Arthropoda" rank="species" species="undecimmaculata">
<emphasis id="B978B332687FFFB5FF2C0A5823DD99C8" box="[190,205,879,904]" italics="true" pageId="5" pageNumber="182">T</emphasis>
. 
<emphasis id="B978B332687FFFB5FF490A5922BC99C8" box="[219,428,878,904]" italics="true" pageId="5" pageNumber="182">undecimmaculata</emphasis>
</taxonomicName>
to 
<taxonomicName id="4C0C14A3687FFFB5FE5D0A59214099C8" authorityName="Melichar" authorityYear="1925" box="[463,592,878,904]" class="Insecta" family="Cicadellidae" genus="Platygonia" kingdom="Animalia" order="Hemiptera" pageId="5" pageNumber="182" phylum="Arthropoda" rank="genus">
<emphasis id="B978B332687FFFB5FE5D0A59214099C8" box="[463,592,878,904]" italics="true" pageId="5" pageNumber="182">Platygonia</emphasis>
</taxonomicName>
. 
<bibRefCitation id="EF9D12D1687FFFB5FDCC0A58205899C9" author="Young D. A." box="[606,840,878,905]" pageId="5" pageNumber="182" pagination="1 - 1135" refId="ref4716" refString="Young D. A. 1977. Taxonomic study of the Cicadellinae (Homoptera: Cicadellidae). Part 2. New World Cicadellini and the genus Cicadella. Bulletin of the North Carolina Agricultural Experiment Station 239: 1 - 1135." type="journal article" year="1977">Young (1977: 1105)</bibRefCitation>
studied the 
<typeStatus id="54B7D182687FFFB5FC470A59272C99C8" box="[981,1084,878,904]" pageId="5" pageNumber="182">holotype</typeStatus>
and stated that this species was “possibly correctly placed in 
<taxonomicName id="4C0C14A3687FFFB5FDC90AA621CC99EB" authorityName="Melichar" authorityYear="1925" box="[603,732,913,939]" class="Insecta" family="Cicadellidae" genus="Platygonia" kingdom="Animalia" order="Hemiptera" pageId="5" pageNumber="182" phylum="Arthropoda" rank="genus">
<emphasis id="B978B332687FFFB5FDC90AA621CC99EB" box="[603,732,913,939]" italics="true" pageId="5" pageNumber="182">Platygonia</emphasis>
</taxonomicName>
as Melichar decided.” Nevertheless, 
<bibRefCitation id="EF9D12D1687FFFB5FB320AA5265799EB" author="Young D. A." box="[1184,1351,913,940]" pageId="5" pageNumber="182" pagination="1 - 1135" refId="ref4716" refString="Young D. A. 1977. Taxonomic study of the Cicadellinae (Homoptera: Cicadellidae). Part 2. New World Cicadellini and the genus Cicadella. Bulletin of the North Carolina Agricultural Experiment Station 239: 1 - 1135." type="journal article" year="1977">Young (1977)</bibRefCitation>
did not formally include 
<taxonomicName id="4C0C14A3687FFFB5FE2B0A8221B9998E" authorityName="Fowler" authorityYear="1899" box="[441,681,948,975]" class="Insecta" family="Cicadellidae" genus="Tettigonia" kingdom="Animalia" order="Hemiptera" pageId="5" pageNumber="182" phylum="Arthropoda" rank="species" species="undecimmaculata">
<emphasis id="B978B332687FFFB5FE2B0A8222D8998E" box="[441,456,949,974]" italics="true" pageId="5" pageNumber="182">T</emphasis>
. 
<emphasis id="B978B332687FFFB5FE4A0A8321B9998E" box="[472,681,948,974]" italics="true" pageId="5" pageNumber="182">undecimmaculata</emphasis>
</taxonomicName>
in 
<taxonomicName id="4C0C14A3687FFFB5FD400A832041998E" authorityName="Melichar" authorityYear="1925" box="[722,849,948,974]" class="Insecta" family="Cicadellidae" genus="Platygonia" kingdom="Animalia" order="Hemiptera" pageId="5" pageNumber="182" phylum="Arthropoda" rank="genus">
<emphasis id="B978B332687FFFB5FD400A832041998E" box="[722,849,948,974]" italics="true" pageId="5" pageNumber="182">Platygonia</emphasis>
</taxonomicName>
, preferring to treat it as a species of uncertain position. This action was followed by 
<bibRefCitation id="EF9D12D1687FFFB5FD1C0AEF20B299B2" author="McKamey S. H." box="[654,930,984,1010]" pageId="5" pageNumber="182" pagination="1 - 394" refId="ref4002" refString="McKamey S. H. 2007. Taxonomic catalogue of the leafhoppers (Membracoidea). Part 1. Cicadellinae. Memoirs of the American Entomological Institute 78: 1 - 394." type="journal article" year="2007">McKamey (2007: 343)</bibRefCitation>
, who, however, misspelled the specific name (“ 
<emphasis id="B978B332687FFFB5FEB30ACC22EA9E55" box="[289,506,1019,1045]" italics="true" pageId="5" pageNumber="182">unidecimmaculata</emphasis>
”). The species reappeared as a member of 
<taxonomicName id="4C0C14A3687FFFB5FBB10ACC27B49E55" authorityName="Melichar" authorityYear="1925" box="[1059,1188,1019,1045]" class="Insecta" family="Cicadellidae" genus="Platygonia" kingdom="Animalia" order="Hemiptera" pageId="5" pageNumber="182" phylum="Arthropoda" rank="genus">
<emphasis id="B978B332687FFFB5FBB10ACC27B49E55" box="[1059,1188,1019,1045]" italics="true" pageId="5" pageNumber="182">Platygonia</emphasis>
</taxonomicName>
in 
<bibRefCitation id="EF9D12D1687FFFB6FB470ACC221F9B63" author="Wilson M. R. &amp; Turner J. A. &amp; McKamey S. H." lastPageId="6" lastPageNumber="183" pageId="5" pageNumber="182" refId="ref4554" refString="Wilson M. R., Turner J. A. &amp; McKamey S. H. 2009. Sharpshooter leafhoppers of the World (Hemiptera: Cicadellidae subfamily Cicadellinae). National Museum Wales. Available from http: // naturalhistory. museumwales. ac. uk / Sharpshooters [accessed 10 Nov. 2021]." type="url" year="2009">
Wilson 
<emphasis id="B978B332687FFFB5FAA40ACB26679E55" box="[1334,1399,1019,1045]" italics="true" pageId="5" pageNumber="182">et al.</emphasis>
(2009)
</bibRefCitation>
. Based on the triangular crown of the 
<typeStatus id="54B7D182687CFFB6FD4B083E20539B63" box="[729,835,265,291]" pageId="6" pageNumber="183">holotype</typeStatus>
, which is strongly produced anteriorly (
<figureCitation id="133773A5687CFFB6FA8C083E26779B63" box="[1310,1383,265,291]" captionStart="Figs 7–8" captionStartId="5.[189,242,1958,1984]" captionTargetBox="[270,1319,1129,1916]" captionTargetId="figure-246@5.[264,1323,1123,1919]" captionTargetPageId="5" captionText="Figs 7–8. Platygonia undecimmaculata (Fowler, 1899), holotype, ♀. 7. Original illustration provided by Fowler (1899: tab. xvi, fig. 21). 8. Body, in dorsal view, from Wilson et al. (2009)." figureDoi="http://doi.org/10.5281/zenodo.6402878" httpUri="https://zenodo.org/record/6402878/files/figure.png" pageId="6" pageNumber="183">Fig. 8</figureCitation>
), it appears to us that the inclusion of 
<taxonomicName id="4C0C14A3687CFFB6FDFD081A204F9B06" authorityName="Fowler" authorityYear="1899" box="[623,863,300,327]" class="Insecta" family="Cicadellidae" genus="Tettigonia" kingdom="Animalia" order="Hemiptera" pageId="6" pageNumber="183" phylum="Arthropoda" rank="species" species="undecimmaculata">
<emphasis id="B978B332687CFFB6FDFD081A216E9B06" box="[623,638,301,326]" italics="true" pageId="6" pageNumber="183">T</emphasis>
. 
<emphasis id="B978B332687CFFB6FD1C081B204F9B06" box="[654,863,300,326]" italics="true" pageId="6" pageNumber="183">undecimmaculata</emphasis>
</taxonomicName>
in 
<taxonomicName id="4C0C14A3687CFFB6FC14081B27179B06" authorityName="Melichar" authorityYear="1925" box="[902,1031,300,326]" class="Insecta" family="Cicadellidae" genus="Platygonia" kingdom="Animalia" order="Hemiptera" pageId="6" pageNumber="183" phylum="Arthropoda" rank="genus">
<emphasis id="B978B332687CFFB6FC14081B27179B06" box="[902,1031,300,326]" italics="true" pageId="6" pageNumber="183">Platygonia</emphasis>
</taxonomicName>
might be correct. Accordingly, we have tentatively included the species in our key. Likewise, based on the color pattern of the 
<typeStatus id="54B7D182687CFFB6FA83087826689B29" box="[1297,1400,335,361]" pageId="6" pageNumber="183">holotype</typeStatus>
(see 
<bibRefCitation id="EF9D12D1687CFFB6FF66084522C59BCD" author="Wilson M. R. &amp; Turner J. A. &amp; McKamey S. H." box="[244,469,370,397]" pageId="6" pageNumber="183" refId="ref4554" refString="Wilson M. R., Turner J. A. &amp; McKamey S. H. 2009. Sharpshooter leafhoppers of the World (Hemiptera: Cicadellidae subfamily Cicadellinae). National Museum Wales. Available from http: // naturalhistory. museumwales. ac. uk / Sharpshooters [accessed 10 Nov. 2021]." type="url" year="2009">
Wilson 
<emphasis id="B978B332687CFFB6FEC00844229E9BCC" box="[338,398,370,396]" italics="true" pageId="6" pageNumber="183">et al.</emphasis>
2009
</bibRefCitation>
), which has no abdomen, hind wings, and metathorax (
<bibRefCitation id="EF9D12D1687CFFB6FBFA084427ED9BCD" author="Young D. A." box="[1128,1277,370,397]" pageId="6" pageNumber="183" pagination="161 - 199" refId="ref4612" refString="Young D. A. 1965. Cicadelline types in the British Museum (Natural History) (Homoptera: Cicadellidae). Bulletin of the British Museum (Natural History), Entomology 17: 161 - 199. https: // doi. org / 10.5962 / bhl. part. 14810" type="journal article" year="1965">Young 1965</bibRefCitation>
), we have attempted to include 
<taxonomicName id="4C0C14A3687CFFB6FE2508A022EB9BF0" baseAuthorityName="Distant" baseAuthorityYear="1908" box="[439,507,407,432]" class="Insecta" family="Cicadellidae" genus="Platygonia" kingdom="Animalia" order="Hemiptera" pageId="6" pageNumber="183" phylum="Arthropoda" rank="species" species="zea">
<emphasis id="B978B332687CFFB6FE2508A022EB9BF0" box="[439,507,407,432]" italics="true" pageId="6" pageNumber="183">P. zea</emphasis>
</taxonomicName>
(
<collectingCountry id="F31B2FB0687CFFB6FD9808A1217F9BF1" box="[522,623,406,433]" name="Ecuador" pageId="6" pageNumber="183">Ecuador</collectingCountry>
) in the key; the latter species was not included in 
<bibRefCitation id="EF9D12D1687CFFB6FB5208A126679BF0" author="Young D. A." box="[1216,1399,406,432]" pageId="6" pageNumber="183" pagination="1 - 1135" refId="ref4716" refString="Young D. A. 1977. Taxonomic study of the Cicadellinae (Homoptera: Cicadellidae). Part 2. New World Cicadellini and the genus Cicadella. Bulletin of the North Carolina Agricultural Experiment Station 239: 1 - 1135." type="journal article" year="1977">Young’s (1977)</bibRefCitation>
key to 
<taxonomicName id="4C0C14A3687CFFB6FE9F088E22E19B93" box="[269,497,441,467]" class="Insecta" family="Cicadellidae" genus="Platygonia" kingdom="Animalia" order="Hemiptera" pageId="6" pageNumber="183" phylum="Arthropoda" rank="species" species="undetermined">
<emphasis id="B978B332687CFFB6FE9F088E229E9B93" box="[269,398,441,467]" italics="true" pageId="6" pageNumber="183">Platygonia</emphasis>
species.
</taxonomicName>
</paragraph>
