<subSubSection id="9CACE5E4B51A381F35649DF71C33E04F" pageId="null" pageNumber="484" type="description">
<paragraph id="508C3F09C3D7AE3C2AC6FF89188DDED9" pageId="null" pageNumber="484">
30-70 cm hoch; 
<emphasis id="91B4F99481DA1B453443F8C4C5699B39" italics="true" pageId="null" pageNumber="484">
horstbildend, mit 
<normalizedToken id="C80BDDB3A440E007A618EC0151A59AF1" originalValue="kräftigem" pageId="null" pageNumber="484">kraeftigem</normalizedToken>
Rhizom.
</emphasis>
<normalizedToken id="28255D51C365EB59A60DFC982E293287" originalValue="Grundständige" pageId="null" pageNumber="484">Grundstaendige</normalizedToken>
Scheiden braun. 
<normalizedToken id="04F222D1E41EB7C956065F71710FB8C4" originalValue="Blätter" pageId="null" pageNumber="484">Blaetter</normalizedToken>
3-8 mm breit, flach, etwa 
<normalizedToken id="BCD035E23AF2030063C95C0439E515A4" originalValue="½" pageId="null" pageNumber="484">1/2</normalizedToken>
so lang wie der Stengel (
<normalizedToken id="855FA69CF3B910DECDED8E04CF076C08" originalValue="überwinterte" pageId="null" pageNumber="484">ueberwinterte</normalizedToken>
<normalizedToken id="9CC0D132DD74D87DE544FE30557EAD7D" originalValue="Blätter" pageId="null" pageNumber="484">Blaetter</normalizedToken>
so lang oder 
<normalizedToken id="D23076F457384D7F714D370E15F8BFAC" originalValue="länger" pageId="null" pageNumber="484">laenger</normalizedToken>
als der Stengel). Stengel 3kantig, oben stark rauh, steif aufrecht. 
<normalizedToken id="EB201B6CC08414716571909D3AB27B40" originalValue="Blütenstand" pageId="null" pageNumber="484">Bluetenstand</normalizedToken>
5-15 cm lang, aus 1-2 seitlichen, 
<normalizedToken id="253B4ECAFC6D551CC41E8C31D371345C" originalValue="eiförmigen" pageId="null" pageNumber="484">eifoermigen</normalizedToken>
oder zylindrischen, mehr als 6 
<normalizedToken id="F906D0F64C570A1123FF4004B5E3ACE8" originalValue="blütigen" pageId="null" pageNumber="484">bluetigen</normalizedToken>
, 1,5-2,5 cm langen und 1 cm dicken, 1-5 cm lang gestielten, aufrechten, 
<normalizedToken id="4BF6C2F0E44020BFCAE7803881FC494E" originalValue="dichtfrüchtigen" pageId="null" pageNumber="484">dichtfruechtigen</normalizedToken>
♀ 
<normalizedToken id="743A6E591FCEF9EE792AA957AB362081" originalValue="Ähren" pageId="null" pageNumber="484">Aehren</normalizedToken>
und 1 
<normalizedToken id="CB9585522CA15E6CCF7FAE85E8BF0848" originalValue="endständigen" pageId="null" pageNumber="484">endstaendigen</normalizedToken>
♂ 
<normalizedToken id="11F21F065399C837B0AE53EDD7FD0F3C" originalValue="Ähre" pageId="null" pageNumber="484">Aehre</normalizedToken>
; unterste ♀ 
<normalizedToken id="8BA51F8DC817F48B1F874C30EDF5EDF5" originalValue="Ähre" pageId="null" pageNumber="484">Aehre</normalizedToken>
nach unten 
<normalizedToken id="9A7C2C0009680F84E10545CC0D7CD941" originalValue="abgerückt" pageId="null" pageNumber="484">abgerueckt</normalizedToken>
. 
<normalizedToken id="8C0BC5E96FDD6E539993D3C6393DC778" originalValue="Hochblätter" pageId="null" pageNumber="484">Hochblaetter</normalizedToken>
<normalizedToken id="7ADFAB6B743CB92333C58319E200AB40" originalValue="blattähnlich" pageId="null" pageNumber="484">blattaehnlich</normalizedToken>
, meist nur 
<emphasis id="6B8323C19D999A391E0F5CA642BA5E46" italics="true" pageId="null" pageNumber="484">
den Grund der 
<normalizedToken id="41757202C6BE83EA543F89AD154BF6D4" originalValue="zugehörigen" pageId="null" pageNumber="484">zugehoerigen</normalizedToken>
<normalizedToken id="C38F424199A2E36638CECF0BAC050B41" originalValue="Ähre" pageId="null" pageNumber="484">Aehre</normalizedToken>
erreichend;
</emphasis>
Scheide 2-3 cm lang. 
<normalizedToken id="AA6F876CB4B4228BF94919CA254EF69B" originalValue="Tragblätter" pageId="null" pageNumber="484">Tragblaetter</normalizedToken>
etwa so lang wie die 
<normalizedToken id="9EDCEA94EADC2F2A985965B5FFFA8A17" originalValue="Fruchtschläuche" pageId="null" pageNumber="484">Fruchtschlaeuche</normalizedToken>
, 
<emphasis id="21549E767487DA71BF45DCFED041B71B" italics="true" pageId="null" pageNumber="484">oval</emphasis>
, mit grannenartiger Spitze, 
<emphasis id="8F16246EB527477A27E42E383654A5EC" italics="true" pageId="null" pageNumber="484">braun</emphasis>
, mit hellem Mittelnerv. 
<emphasis id="DC7352336DDECC1AC754BC1C81095D68" italics="true" pageId="null" pageNumber="484">
<normalizedToken id="2734B1FED3641B73E10378EB981A983E" originalValue="Fruchtschläuche" pageId="null" pageNumber="484">Fruchtschlaeuche</normalizedToken>
5-6 mm lang
</emphasis>
, 
<normalizedToken id="F74B290002474DF9D0C4F561E2EEA492" originalValue="über" pageId="null" pageNumber="484">ueber</normalizedToken>
der Mitte am breitesten (2,2-2,8 mm), 
<emphasis id="DF3AAA46BA0F5ED5AA0F6982E1E93311" italics="true" pageId="null" pageNumber="484">im Querschnitt rundlich</emphasis>
, mit 
<emphasis id="30DC9E6C1CFE02DEC1A943C119B3CACC" italics="true" pageId="null" pageNumber="484">
<normalizedToken id="A66B92CD6F645195D63B1946C1082F64" originalValue="±" pageId="null" pageNumber="484">+/-</normalizedToken>
</emphasis>
deutlichen Nerven, zerstreut borstig behaart, oft auch ganz kahl, braun, matt, 
<normalizedToken id="32FFB4FE76BF94DFD3B2A84E5AED6767" originalValue="allmählich" pageId="null" pageNumber="484">allmaehlich</normalizedToken>
in den kurzen 2 
<normalizedToken id="A8EC99C52627B8611C60FBF3085A38E1" originalValue="zähnigen" pageId="null" pageNumber="484">zaehnigen</normalizedToken>
Schnabel 
<normalizedToken id="879ED0EABAB53DC2DA31A6CBE5C6E281" originalValue="verschmälert" pageId="null" pageNumber="484">verschmaelert</normalizedToken>
; 
<emphasis id="0DE8D18447F14F311982783A3A1B8FD8" italics="true" pageId="null" pageNumber="484">
Schnabel bis 1 mm lang; 
<normalizedToken id="A0F0DCA1F96F85F35655065E95FD8787" originalValue="Zähne" pageId="null" pageNumber="484">Zaehne</normalizedToken>
0,3-0,5 mm lang
</emphasis>
, gerade. Narben 3.
</paragraph>
<paragraph id="B3188E6FFC1D3EDDB400E4E943745A7B" pageId="null" pageNumber="484">
<emphasis id="999DF84816FDE2F74E9367688F4E6B6E" italics="true" pageId="null" pageNumber="484">Zytologische Angaben. 2n = 56:</emphasis>
Ohne Herkunftsangabe des Materials (Tanaka aus Tischler 1950).
</paragraph>
<paragraph id="2AC8483E78415EB2F47E5BB286E8FE5E" pageId="null" pageNumber="484">
<emphasis id="91E13513210C1E671E4F3F85BE1D9FB6" italics="true" pageId="null" pageNumber="484">Standort.</emphasis>
Kollin und montan. Steinige, trockene 
<normalizedToken id="81519FAFA73E4B102981129B928D1B3E" originalValue="Hänge" pageId="null" pageNumber="484">Haenge</normalizedToken>
.
</paragraph>
<paragraph id="CE981D88BA24AE6DB2B10CA72A836B34" pageId="null" pageNumber="484">
<emphasis id="8F016992F3E49A076ABF2D0F1F210006" italics="true" pageId="null" pageNumber="484">
Verbreitung. 
<normalizedToken id="FF450B9B06F868C4E9AAD05B5AA58199" originalValue="Südeuropäische" pageId="null" pageNumber="484">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Nordspanien, 
<normalizedToken id="DB7CE03E442AB6FCD125359734E7B31D" originalValue="Süd-" pageId="null" pageNumber="484">Sued-</normalizedToken>
und Ostfrankreich; 
<normalizedToken id="500F8DBBCAC43941083B2436416372C4" originalValue="Böhmen" pageId="null" pageNumber="484">Boehmen</normalizedToken>
, Ungarn, Serbien, 
<normalizedToken id="57905C6F71FB2E50F88BB130936BE6F8" originalValue="Südrußland" pageId="null" pageNumber="484">Suedrussland</normalizedToken>
, Kaukasus, Kleinasien. - Im Gebiet: 
<normalizedToken id="2CA85BBA9FC4C4D87CDE785A765FCAD1" originalValue="Dép" pageId="null" pageNumber="484">Dep</normalizedToken>
. Ain (Tenay, Montagne de Parves).
</paragraph>
</subSubSection>
