<taxonomicName id="4C01EE8FFFB8F77DF021FB8AED8DD462" box="[638,1013,1126,1150]" class="Insecta" family="Lycidae" genus="Helcophorus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="3" pageNumber="87" phylum="Arthropoda" rank="species" species="ekaterinae" status="sp. nov." subGenus="Thibeteros">
