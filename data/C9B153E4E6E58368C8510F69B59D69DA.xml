<subSubSection id="4FCD3171DD4F53A6FD4DF45793D25CF5" pageId="null" pageNumber="556" type="description">
<paragraph id="76AC43ACA93798C5E3988EF8F4196CD5" pageId="null" pageNumber="556">
<emphasis id="B548A2EE0EFECB9F54DCE60A1396DE3B" italics="true" pageId="null" pageNumber="556">
<normalizedToken id="7C1FBB700AF756AE821D899198C592C4" originalValue="Sträucher" pageId="null" pageNumber="556">Straeucher</normalizedToken>
.
</emphasis>
<normalizedToken id="CB71F24872E0F324B6E35E060CDCD1DC" originalValue="Blätter" pageId="null" pageNumber="556">Blaetter</normalizedToken>
gefiedert, mit Endteilblatt und kleinen, freien 
<normalizedToken id="FD9364E702C5934FB94615D9DB3924F6" originalValue="Nebenblättern" pageId="null" pageNumber="556">Nebenblaettern</normalizedToken>
. 
<normalizedToken id="7721F7819A676242B8519E2ED81FD222" originalValue="Teilblätter" pageId="null" pageNumber="556">Teilblaetter</normalizedToken>
ganzrandig, meist oval. 
<normalizedToken id="87C038B4EEF9CB0FD400C973D40C9856" originalValue="Blüten" pageId="null" pageNumber="556">Blueten</normalizedToken>
in 
<normalizedToken id="B1554B0DF21BCDEFA95F90785247A908" originalValue="wenigblütigen" pageId="null" pageNumber="556">wenigbluetigen</normalizedToken>
, lockeren, aufrechten Trauben, die in den Achseln von 
<normalizedToken id="9EE9B75794558612549CD91BF288FAD5" originalValue="Blättern" pageId="null" pageNumber="556">Blaettern</normalizedToken>
stehen. 
<normalizedToken id="4F84C4D8568BA70B0A10CFC27EC3F95E" originalValue="Blütenstiele" pageId="null" pageNumber="556">Bluetenstiele</normalizedToken>
wenig 
<normalizedToken id="5CD5B6C65323E50DBE888728D7894697" originalValue="kürzer" pageId="null" pageNumber="556">kuerzer</normalizedToken>
bis wenig 
<normalizedToken id="D06A18BD04D3AF5C5660C0412A7BBA31" originalValue="länger" pageId="null" pageNumber="556">laenger</normalizedToken>
als der Kelch. Kelch 
<normalizedToken id="ADB415F2165F60B37A32722EF7C00BD9" originalValue="glockenförmig" pageId="null" pageNumber="556">glockenfoermig</normalizedToken>
, mit 5 etwas ungleichen, kurzen 
<normalizedToken id="3249B15BF3AE0D907F27E8956C949D77" originalValue="Zähnen" pageId="null" pageNumber="556">Zaehnen</normalizedToken>
(die 3 untern 
<normalizedToken id="D0F4972FA9FE648FC82F14C6823AAAA4" originalValue="schmäler" pageId="null" pageNumber="556">schmaeler</normalizedToken>
und wenig 
<normalizedToken id="179B2A4BE229A94AA4B4FC882209BB03" originalValue="länger" pageId="null" pageNumber="556">laenger</normalizedToken>
). Krone meist gelb; Fahne etwas 
<normalizedToken id="0310627E653EAE76F886077C4848953B" originalValue="länger" pageId="null" pageNumber="556">laenger</normalizedToken>
als 
<normalizedToken id="BF3C0ABDA8DCD828E8154A68C11A18B3" originalValue="Flügel" pageId="null" pageNumber="556">Fluegel</normalizedToken>
und Schiffchen; Schiffchen 
<normalizedToken id="7555F0BD56139B735B3AD5DDA3B45453" originalValue="länger" pageId="null" pageNumber="556">laenger</normalizedToken>
oder 
<normalizedToken id="9501A17D9AC3A4D7681E7C0A218BE8EE" originalValue="kürzer" pageId="null" pageNumber="556">kuerzer</normalizedToken>
als die 
<normalizedToken id="F89160B95AA7CB329F0677AD984B4611" originalValue="Flügel" pageId="null" pageNumber="556">Fluegel</normalizedToken>
, etwas 
<normalizedToken id="5FC8235402A23922BF17DC7216B69861" originalValue="aufwärts" pageId="null" pageNumber="556">aufwaerts</normalizedToken>
gebogen, stumpf. Oberster Staubfaden meist frei. Frucht im Kelch gestielt, 
<emphasis id="FFC37727D5E5C3019347BF3CADBD50C4" italics="true" pageId="null" pageNumber="556">bauchig aufgeblasen</emphasis>
, vielsamig.
</paragraph>
<paragraph id="52016CD30A05340D96269319F87A03FB" pageId="null" pageNumber="556">
Die Gattung 
<taxonomicName id="DFB1CA7BEC27794082204DE63ED2026A" class="Magnoliopsida" family="Fabaceae" genus="Colutea" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="556" phylum="Tracheophyta" rank="genus">
<emphasis id="819E088096CBF4F2236E85E077F27035" italics="true" pageId="null" pageNumber="556">Colutea</emphasis>
</taxonomicName>
<normalizedToken id="7080DBAD74E8F26197D3DFB03AEAD5F4" originalValue="umfaßt" pageId="null" pageNumber="556">umfasst</normalizedToken>
nach Browicz (1963) 26 Arten und ist in 
<normalizedToken id="8C815A67EC4E249AA7DCD2A05D0A1A99" originalValue="Südeuropa" pageId="null" pageNumber="556">Suedeuropa</normalizedToken>
, Nordwest- und Ostafrika sowie besonders in 
<normalizedToken id="76361CD60E99586D0C46FF0F96E09755" originalValue="Südwest-" pageId="null" pageNumber="556">Suedwest-</normalizedToken>
und Zentralasien verbreitet. Neben der einheimischen 
<taxonomicName id="6E5F120E1D18056841AD115C09E27E91" class="Magnoliopsida" family="Fabaceae" genus="Colutea" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="556" phylum="Tracheophyta" rank="species" species="arborescens">
<emphasis id="753326BB017D360503C671CBEA331F4D" italics="true" pageId="null" pageNumber="556">C. arborescens</emphasis>
</taxonomicName>
werden weitere Arten und Bastarde gelegentlich in 
<normalizedToken id="CD0C43D09A31537CA8A7D023E105A674" originalValue="Gärten" pageId="null" pageNumber="556">Gaerten</normalizedToken>
angepflanzt, so etwa 
<taxonomicName id="D7A19E37DEA3BDEF5BF8F011F58BDFFD" authority="Miller" authorityName="Miller" class="Magnoliopsida" family="Fabaceae" genus="Colutea" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="556" phylum="Tracheophyta" rank="species" species="orientalis">
<emphasis id="4049CA966CFABDDFA903F988EB7B21DE" italics="true" pageId="null" pageNumber="556">C. orientalis</emphasis>
Miller
</taxonomicName>
mit 
<normalizedToken id="88D28A8A07EC4821D9FEF6A00F91FB3C" originalValue="höchstens" pageId="null" pageNumber="556">hoechstens</normalizedToken>
1,5 cm langen 
<normalizedToken id="59FBD300E8AA41B6720F16C55BA37A46" originalValue="Teilblättern" pageId="null" pageNumber="556">Teilblaettern</normalizedToken>
und orangeroter Krone. 
<normalizedToken id="6B971D8C8E2E6D546ED4C51DB517DBB3" originalValue="Über" pageId="null" pageNumber="556">Ueber</normalizedToken>
die Gattung besteht eine Monographie von Browicz (1963) mit morphologischen und pflanzengeographischen Angaben (Verbreitungskarten!).
</paragraph>
</subSubSection>
