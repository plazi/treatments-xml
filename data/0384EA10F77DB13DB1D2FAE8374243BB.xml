<typeStatus id="5496E5A4F77DB13CB1F3F9EC3325456F" box="[182,284,1555,1581]" pageId="8" pageNumber="529">syntypes</typeStatus>
. 
<collectingCounty id="62F3238AF77DB13CB060F9EC3368456F" box="[293,337,1555,1581]" pageId="8" pageNumber="529">The</collectingCounty>
<specimenCount id="9D2B908FF77DB13CB01DF9EC33D5456F" box="[344,492,1555,1581]" pageId="8" pageNumber="529" type="generic" typeStatus="syntypes">five syntypes</specimenCount>
