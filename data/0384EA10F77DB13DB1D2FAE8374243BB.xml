<date id="FF937DC6F77DB13CB57BF9EC372F456F" box="[1086,1302,1555,1581]" pageId="8" pageNumber="529" value="1841-11-20">
<collectingDate id="EFD7842EF77DB13CB57BF9EC372F456F" box="[1086,1302,1555,1581]" pageId="8" pageNumber="529" value="1841-11-20">20 November 1841</collectingDate>
</date>
near 
<collectingMunicipality id="6BF6C17CF77DB13CB410F9EC33314513" pageId="8" pageNumber="529">Hartebeespoort</collectingMunicipality>
; NRM 569871 [7250], an adult male collected 
<date id="FF937DC6F77DB13CB253F9C831D74513" box="[790,1006,1591,1617]" pageId="8" pageNumber="529" value="1841-11-28">
