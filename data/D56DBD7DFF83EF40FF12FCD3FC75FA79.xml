Argentina: Buenos Aires, Mendoza, Rio Negro; 
<emphasis id="6FB0D079FF83EF40FCD3FC67FC2AFC54" bold="true" box="[854,927,978,1004]" pageId="43" pageNumber="44">
<collectingCountry id="25D34CFBFF83EF40FCD3FC67FC2AFC54" box="[854,927,978,1004]" name="Brazil" pageId="43" pageNumber="44">Brazil</collectingCountry>
</emphasis>
: 
<emphasis id="6FB0D079FF83EF40FC2BFC64FBB0FC54" bold="true" box="[942,1029,977,1004]" pageId="43" pageNumber="44">
