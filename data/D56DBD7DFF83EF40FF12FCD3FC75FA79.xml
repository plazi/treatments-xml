<figureCitation id="C5FF10EEFF83EF40FEA1FC3FFEE1FC1C" box="[292,340,906,932]" captionStart="FIGURE 22" captionStartId="45.[151,250,1780,1804]" captionTargetBox="[151,1436,181,1750]" captionTargetId="figure-17@45.[151,1436,181,1756]" captionTargetPageId="45" captionText="FIGURE 22. Live specimens of Phaneropterini, Phyllopterini and Scaphurae (Phaneropterinae) from the ParNa Iguaçu. A: Anaulacomera argentina; B: A. trispinata; C: A. arlindoi; D: A. angelinae; E: Viadana piracicabae; F: Hyperphrona striolata; G: Phylloptera fosteri; H: Scaphura elegans; I: Scaphura sp. 1; A–G and I: photos by Marcos Fianco; H: photo by Pedro. G.B. Souza-Dias." figureDoi="http://doi.org/10.5281/zenodo.6550111" httpUri="https://zenodo.org/record/6550111/files/figure.png" pageId="43" pageNumber="44">22H</figureCitation>
