<figureCitation id="13072A27FFB8FFADFE2DF923DA29F922" box="[486,616,1677,1704]" captionStart="FIGURES 11–19" captionStartId="9.[151,264,1899,1923]" captionTargetBox="[155,1433,228,1875]" captionTargetId="figure-15@9.[151,1436,181,1875]" captionTargetPageId="9" captionText="FIGURES 11–19. Dorsal, lateral and front view of Pseudomicracis madagascariensis male allotype (11, 14, 17) and female from Marojejy (12, 15, 18); Pseudomicracis difficilis female (13, 16, 19)." figureDoi="http://doi.org/10.5281/zenodo.6443882" httpUri="https://zenodo.org/record/6443882/files/figure.png" pageId="6" pageNumber="331">Figs 15, 18</figureCitation>
