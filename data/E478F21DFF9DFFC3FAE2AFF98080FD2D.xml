<taxonomicName id="ABD13888FF9DFFC3F9EEAD08817FFD40" authority="(Waters, 1878) (Almeida et al. 2014)" authorityName="Almeida et al." authorityYear="2014" baseAuthorityName="Waters" baseAuthorityYear="1878" class="Gymnolaemata" family="Schizoporellidae" genus="Schizoporella" kingdom="Animalia" order="Cheilostomatida" pageId="41" pageNumber="42" phylum="Bryozoa" rank="species" species="errata">
<emphasis id="5EA59F19FF9DFFC3F9EEAD0884E5FD64" box="[923,1152,614,640]" italics="true" pageId="41" pageNumber="42">Schizoporella errata</emphasis>
(Waters, 1878) (
<bibRefCitation id="08403EFAFF9DFFC3FF4FAD088177FD40" author="Almeida, A. O. &amp; Anker, A. &amp; Mantelatto, F. L." pageId="41" pageNumber="42" pagination="110 - 120" refId="ref51914" refString="Almeida, A. O., Anker, A. &amp; Mantelatto, F. L. (2014) A new snapping species of the shrimp genus Typton Costa, 1844 (Decapoda: Palaemonidae) from the coast of Sao Paulo, southeastern Brazil. Zootaxa, 3835 (1), 110 - 120. https: // doi. org / 10.11646 / zootaxa. 3835.1.6" type="journal article" year="2014">
Almeida 
