. 
<taxonomicName id="0C8C4D49FFC7FFC8FEC7B7ECFE30B7A6" authorityName="Alba-Tercedor &amp; Mosquera" authorityYear="1999" box="[342,508,151,177]" class="Insecta" family="Caenidae" genus="Caenis" kingdom="Animalia" order="Ephemeroptera" pageId="8" pageNumber="118" phylum="Arthropoda" rank="species" species="chamie">
