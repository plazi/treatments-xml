<caption id="90EB6676FFB56A0AF7F49562183CBF46" ID-DOI="http://doi.org/10.5281/zenodo.6398109" ID-Zenodo-Dep="6398109" httpUri="https://zenodo.org/record/6398109/files/figure.png" inLine="true" pageId="78" pageNumber="836" targetBox="[1441,2032,567,980]" targetPageId="78">
<paragraph id="C42B36FEFFB56A0AF7F495621790B86E" blockId="78.[2052,2649,551,979]" box="[2056,2448,827,860]" pageId="78" pageNumber="836">
<emphasis id="F6E0EAECFFB56A0AF7F495621790B86E" bold="true" box="[2056,2448,827,860]" pageId="78" pageNumber="836">Subspecies and Distribution.</emphasis>
</paragraph>
<paragraph id="C42B36FEFFB56A0AF7F5953B190BBF17" blockId="78.[2052,2649,551,979]" lastBlockId="78.[1445,2660,991,3466]" pageId="78" pageNumber="836">
<taxonomicName id="03944D7DFFB56A0AF7F5953B1729B8B1" authority="Thomas, 1902" authorityName="Thomas" authorityYear="1902" box="[2057,2345,866,899]" class="Mammalia" family="Vespertilionidae" genus="Pharotis" kingdom="Animalia" order="Chiroptera" pageId="78" pageNumber="836" phylum="Chordata" rank="subSpecies" species="imogene" subSpecies="io">I.i.ioThomas,1902—CNepal,NEIndia(AssamandMeghalaya),N&amp;EMyanmar,China(Sichuan,Yunnan,Guizhou,Guangxi,Shaanxi,Hubei,Hunan,Jiangsu,Anhui,andJiangxi),NWThailand,N&amp;CLaos,andN&amp;CVietnam.</taxonomicName>
</paragraph>
<paragraph id="C42B36FEFFB56A0AFA599270183CBF46" blockId="78.[1445,2660,991,3466]" pageId="78" pageNumber="836">
<taxonomicName id="03944D7DFFB56A0AFA599270197CBF78" authority="Soisook et al., 2017" authorityName="Soisook et al." authorityYear="2017" box="[1445,1916,1065,1098]" class="Mammalia" family="Vespertilionidae" genus="Pharotis" kingdom="Animalia" order="Chiroptera" pageId="78" pageNumber="836" phylum="Chordata" rank="subSpecies" species="imogene" subSpecies="peninsulata">I. i. peninsulata Soisook et al., 2017</taxonomicName>
— peninsular 
<collectingCountry id="BC83766EFFB56A0AF7C0927016B9BF78" box="[2108,2233,1065,1098]" name="Thailand" pageId="78" pageNumber="836">Thailand</collectingCountry>
(
<collectingRegion id="0650F81CFFB56A0AF72D92701776BF78" box="[2257,2422,1065,1098]" country="Thailand" name="Surat Thani" pageId="78" pageNumber="836">Surat Thani</collectingRegion>
and 
<collectingRegion id="0650F81CFFB56A0AF63C9270145ABF78" box="[2496,2650,1065,1098]" country="Thailand" name="Phangnga" pageId="78" pageNumber="836">Phang Nga</collectingRegion>
provinces).
