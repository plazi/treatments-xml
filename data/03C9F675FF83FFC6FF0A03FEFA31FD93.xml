<emphasis id="B9149B71FF83FFC6FF0A03FEFF42FED4" bold="true" pageId="2" pageNumber="141">
Key to the species of 
<taxonomicName id="4C603CE0FF83FFC6FE1703FEFD78FEE8" authorityName="de Candolle" authorityYear="1822" box="[405,738,244,271]" class="Magnoliopsida" family="Passifloraceae" genus="Passiflora" kingdom="Plantae" order="Malpighiales" pageId="2" pageNumber="141" phylum="Tracheophyta" rank="section" section="Dysosmia">
<emphasis id="B9149B71FF83FFC6FE1703FEFD90FEE9" bold="true" box="[405,522,244,271]" italics="true" pageId="2" pageNumber="141">Passiflora</emphasis>
section 
<emphasis id="B9149B71FF83FFC6FDF003FEFD78FEE8" bold="true" box="[626,738,244,270]" italics="true" pageId="2" pageNumber="141">Dysosmia</emphasis>
</taxonomicName>
from Serra da Mantiqueira, southeast of Atlantic Forest, 
<collectingCountry id="F37707F3FF83FFC6FF0A0212FF49FED4" box="[136,211,280,306]" name="Brazil" pageId="2" pageNumber="141">Brazil</collectingCountry>
.
</emphasis>
</heading>
</paragraph>
