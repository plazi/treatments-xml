<geoCoordinate id="38F06AACFFA5EF66FE73FD3BFDFCFD11" box="[502,585,654,681]" degrees="0.005" direction="south" orientation="latitude" pageId="13" pageNumber="14" precision="55" value="-0.005">0.005 s</geoCoordinate>
.
</paragraph>
<paragraph id="5D7B0C6BFFA5EF66FF42FD06FDC8FD75" blockId="13.[151,1436,258,717]" box="[199,637,690,717]" pageId="13" pageNumber="14">
<emphasis id="6FB0D079FFA5EF66FF42FD06FEEAFD74" box="[199,351,690,716]" italics="true" pageId="13" pageNumber="14">Mute interval</emphasis>
