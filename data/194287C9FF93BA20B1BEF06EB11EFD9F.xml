</subSubSection>
<subSubSection id="D9F16554FF93BA3FBC1FFF37BBB1F708" pageId="47" pageNumber="666" type="distribution">
<caption id="C5946657FF93BA3FBC1FFF37BBB1F708" ID-DOI="http://doi.org/10.5281/zenodo.6567932" ID-Zenodo-Dep="6567932" httpUri="https://zenodo.org/record/6567932/files/figure.png" inLine="true" pageId="47" pageNumber="666" targetBox="[1446,2037,1998,2404]" targetPageId="47">
<paragraph id="915436DFFF93BA3FBC1FFF37BBB1F708" blockId="47.[2060,2654,1977,2404]" pageId="47" pageNumber="666">
<emphasis id="A39FEACDFF93BA3FBC1FFF37BA9BF7B6" bold="true" box="[2061,2237,2135,2168]" pageId="47" pageNumber="666">Distribution.</emphasis>
Widespread through C &amp; S 
<collectingCountry id="E9FC764FFF93BA3FBC39FFE7BAA6F76E" box="[2091,2176,2183,2208]" name="China" pageId="47" pageNumber="666">China</collectingCountry>
, 
<collectingCountry id="E9FC764FFF93BA3FBC87FFE7BAD1F76E" box="[2197,2295,2183,2208]" name="Taiwan" pageId="47" pageNumber="666">Taiwan</collectingCountry>
I, Korean Peninsula, SE Russian Far East, and 
<collectingCountry id="E9FC764FFF93BA3FBD29FFC5BBB4F708" box="[2363,2450,2213,2246]" name="Japan" pageId="47" pageNumber="666">Japan</collectingCountry>
.
</paragraph>
</caption>
