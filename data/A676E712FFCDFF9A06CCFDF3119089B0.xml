<heading id="7528E168FFCDFF9A07CCFC5E13028FD5" box="[211,319,936,959]" fontSize="10" level="3" pageId="16" pageNumber="1553" reason="5">
<emphasis id="1CAB8A16FFCDFF9A07CCFC5E13028FD5" box="[211,319,936,959]" italics="true" pageId="16" pageNumber="1553">Diagnosis</emphasis>
</heading>
