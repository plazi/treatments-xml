<geoCoordinate id="1DB61FCEAB58A660DE5874ECD0483D0D" degrees="25" direction="north" minutes="43.7" orientation="latitude" precision="92" value="25.728333">25°43.7'N</geoCoordinate>
, 
<geoCoordinate id="7A5715229FE7C37F2012722D2B0450A9" degrees="98" direction="east" minutes="34.1" orientation="longitude" precision="92" value="98.56834">98°34.1'E</geoCoordinate>
