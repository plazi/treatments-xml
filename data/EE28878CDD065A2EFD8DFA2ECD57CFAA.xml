<taxonomicName id="A1814D19DD065A2FFF7AFA5CCE12C847" authority="Hwass" authorityName="Hwass" box="[227,564,1522,1549]" class="Gastropoda" family="Conidae" genus="Conus" kingdom="Animalia" order="Neogastropoda" pageId="4" pageNumber="5" phylum="Mollusca" rank="species" species="mediterraneus">
