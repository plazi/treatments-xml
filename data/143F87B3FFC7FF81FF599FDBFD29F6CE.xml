<materialsCitation id="2CFE3CF8FFC7FF81FCBC9E66FA84FA34" ID-GBIF-Occurrence="3699972319" box="[805,1304,1402,1427]" pageId="11" pageNumber="316">
“ 
<collectingCountry id="E4817635FFC7FF81FCA99E66FC29FA34" box="[816,949,1402,1427]" name="Ethiopia" pageId="11" pageNumber="316">Abyssinia</collectingCountry>
