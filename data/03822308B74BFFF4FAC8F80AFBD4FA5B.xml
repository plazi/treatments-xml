<taxonomicName id="4C2BE99DB74BFFF5F729F28BF6BCFB1B" authorityName="Durant &amp; Guevara" authorityYear="2001" box="[2178,2423,3376,3397]" class="Mammalia" family="Leporidae" genus="Sylvilagus" kingdom="Animalia" order="Lagomorpha" pageId="12" pageNumber="119" phylum="Chordata" rank="species" species="varynaensis">Sylvilagus varynaensis</taxonomicName>
), 22. Dice's 
<taxonomicName id="4C2BE99DB74BFFF5FAE9F2E3FA56FB33" authorityName="J. A. Allen" authorityYear="1877" box="[1346,1437,3416,3437]" class="Mammalia" family="Leporidae" genus="Lepus" kingdom="Animalia" order="Lagomorpha" pageId="12" pageNumber="119" phylum="Chordata" rank="species" species="graysoni">graysoni</taxonomicName>
