(
<taxonomicName id="4C2BE99DB74BFFF5FE9DF2C4FDC2FBCA" baseAuthorityName="Bailey" baseAuthorityYear="1905" box="[310,521,3455,3476]" class="Mammalia" family="Leporidae" genus="Sylvilagus" kingdom="Animalia" order="Lagomorpha" pageId="12" pageNumber="119" phylum="Chordata" rank="species" species="robustus">Sylvilagus robustus</taxonomicName>
); 28. Manzano Mountain Cottontail (
<taxonomicName id="4C2BE99DB74BFFF5FC37F2C4FBB9FBCA" authorityName="Nelson" authorityYear="1907" box="[924,1138,3455,3476]" class="Mammalia" family="Leporidae" genus="Sylvilagus" kingdom="Animalia" order="Lagomorpha" pageId="12" pageNumber="119" phylum="Chordata" rank="species" species="cognatus">Sylvilagus cognatus</taxonomicName>
); 29. Hispid Hare (. Central American Tapeti (
<taxonomicName id="4C2BE99DB74BFFF5F9F5F28BF8C7FB1B" baseAuthorityName="J. A. Allen" baseAuthorityYear="1877" box="[1630,1804,3376,3397]" class="Mammalia" family="Leporidae" genus="Sylvilagus" kingdom="Animalia" order="Lagomorpha" pageId="12" pageNumber="119" phylum="Chordata" rank="species" species="gabbi">Sylvilagus gabbi</taxonomicName>
