<taxonomicName id="4C30F2BDFFE20F46F850F5A0C481F59F" authorityName="Monard" authorityYear="1933" box="[1984,2292,2591,2620]" class="Mammalia" family="Nesomyidae" genus="Dendromus" kingdom="Animalia" order="Rodentia" pageId="16" pageNumber="199" phylum="Chordata" rank="species" species="leucostomus">Dendromus leucostomus</taxonomicName>
is considered conspecific with 
<taxonomicName id="4C30F2BDFFE20F46F7E8F5FDC56DF5C0" baseAuthorityName="A. Smith" baseAuthorityYear="1834" box="[2168,2328,2626,2659]" class="Mammalia" family="Nesomyidae" genus="Dendromus" kingdom="Animalia" order="Rodentia" pageId="16" pageNumber="199" phylum="Chordata" rank="species" species="melanotis">D. melanotis</taxonomicName>
