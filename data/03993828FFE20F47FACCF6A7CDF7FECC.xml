</paragraph>
</subSubSection>
<subSubSection id="C32ADAB5FFE20F46F82EF502C4C2F4A2" pageId="16" pageNumber="199" type="multiple">
<caption id="DF4FD9B6FFE20F46F82EF502C4C2F4A2" ID-DOI="http://doi.org/10.5281/zenodo.6600478" ID-Zenodo-Dep="6600478" httpUri="https://zenodo.org/record/6600478/files/figure.png" inLine="true" pageId="16" pageNumber="199" targetBox="[1368,1958,2520,2932]" targetPageId="16">
