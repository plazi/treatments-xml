<paragraph id="C42B36FEFF506AEFFD0897EA1DCEB95F" blockId="171.[753,1346,273,701]" pageId="171" pageNumber="933">
Subgenus Pyzonix; 
<taxonomicName id="03944D7DFF506AEFFBE997EA1A57BAE2" baseAuthorityName="E. Geoffroy" baseAuthorityYear="1806" box="[1045,1111,435,464]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="171" pageNumber="933" phylum="Chordata" rank="species" species="ruber">ruber</taxonomicName>
