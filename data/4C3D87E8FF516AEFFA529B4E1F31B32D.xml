<taxonomicName id="03944D7DFF506AEFFD08978F1D9EBAC5" authorityName="J. A. Allen" authorityYear="1914" box="[756,926,470,503]" class="Mammalia" family="Vespertilionidae" genus="Myotis" kingdom="Animalia" order="Chiroptera" pageId="171" pageNumber="933" phylum="Chordata" rank="species" species="keaysi">Myotis keaysi</taxonomicName>
