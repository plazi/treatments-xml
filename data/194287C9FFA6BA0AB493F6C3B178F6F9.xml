<paragraph id="915436DFFFA6BA0AB46DF0D2B3D2F81D" blockId="26.[125,1333,1101,2359]" box="[127,500,1970,2003]" pageId="26" pageNumber="645">
<emphasis id="A39FEACDFFA6BA0AB46DF0D2B323F81D" bold="true" box="[127,261,1970,2003]" pageId="26" pageNumber="645">Breeding.</emphasis>
