<collectingCountry id="E9FC764FFFA6BA0AB756F409B184FC4C" box="[836,930,873,898]" name="Ghana" pageId="26" pageNumber="645">Ghana</collectingCountry>
, 
<collectingCountry id="E9FC764FFFA6BA0AB7A1F409B66CFC4C" box="[947,1098,873,898]" name="Cameroon" pageId="26" pageNumber="645">Cameroon</collectingCountry>
