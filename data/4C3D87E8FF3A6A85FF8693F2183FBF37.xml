C &amp; E Europe, from S 
<collectingCountry id="BC83766EFF3A6A85FD8D9E481CDCB31C" box="[625,732,2065,2094]" name="Sweden" pageId="193" pageNumber="955">Sweden</collectingCountry>
to N 
<collectingCountry id="BC83766EFF3A6A85FCD09E481D8DB31C" box="[812,909,2065,2094]" name="France" pageId="193" pageNumber="955">France</collectingCountry>
, 
<collectingCountry id="BC83766EFF3A6A85FC629E481A20B31C" box="[926,1056,2065,2094]" name="Germany" pageId="193" pageNumber="955">Germany</collectingCountry>
and 
<collectingCountry id="BC83766EFF3A6A85FB9B9E481ACBB31C" box="[1127,1227,2065,2094]" name="Poland" pageId="193" pageNumber="955">Poland</collectingCountry>
, and E to Yenisei River in C 
<collectingCountry id="BC83766EFF3A6A85FE639E6D1FF8B367" box="[415,504,2100,2133]" name="Russia" pageId="193" pageNumber="955">Russia</collectingCountry>
; isolated populations in 
<collectingCountry id="BC83766EFF3A6A85FCAA9E6D1DD1B367" box="[854,977,2100,2133]" name="Hungary" pageId="193" pageNumber="955">Hungary</collectingCountry>
, 
<collectingCountry id="BC83766EFF3A6A85FC1E9E6D1A62B367" box="[994,1122,2100,2133]" name="Romania" pageId="193" pageNumber="955">Romania</collectingCountry>
, 
<collectingCountry id="BC83766EFF3A6A85FB8F9E6D1AE7B367" box="[1139,1255,2100,2133]" name="Ukraine" pageId="193" pageNumber="955">Ukraine</collectingCountry>
, and N 
<collectingCountry id="BC83766EFF3A6A85FF659E031F3BB349" box="[153,315,2138,2171]" name="Kazakhstan" pageId="193" pageNumber="955">Kazakhstan</collectingCountry>
.
