<collectingCountry id="F31E761C92417723FE33FCF6FDA4BF0B" box="[461,565,806,832]" name="Brazil" pageId="17" pageNumber="170">BRAZIL</collectingCountry>
. 
<collectingRegion id="49CDF86E92417723FDBCFCF6FD19BF0B" box="[578,648,806,832]" country="Brazil" name="Bahia" pageId="17" pageNumber="170">Bahia</collectingRegion>
: Macarani, 
<emphasis id="B97DEA9E92417723FCEFFCF6FC2FBF0B" box="[785,958,806,832]" italics="true" pageId="17" pageNumber="170">Carvalho 6995</emphasis>
(
<collectionCode id="ED18AE4992417723FC2FFCF6FBB4BF0B" box="[977,1061,806,832]" country="Brazil" lsid="urn:lsid:biocol.org:col:15066" name="Universidade Federal da Bahia, Campus Universitário de Ondina" pageId="17" pageNumber="170" type="Herbarium">ALCB</collectionCode>
!, 
<collectionCode id="ED18AE4992417723FBC9FCF6FB06BF0B" box="[1079,1175,806,832]" country="Brazil" lsid="urn:lsid:biocol.org:col:15526" name="CEPEC, CEPLAC" pageId="17" pageNumber="170" type="Herbarium">CEPEC</collectionCode>
!, HUEFS!, NY, 
<collectionCode id="ED18AE4992417723FAADFCF6FA32BF0B" box="[1363,1443,806,832]" country="Brazil" name="Universidade Estadual de Santa Cruz" pageId="17" pageNumber="170" type="Herbarium">UESC</collectionCode>
!, 
<collectionCode id="ED18AE4992417723FF76FC9AFF4ABF2F" box="[136,219,842,868]" country="Brazil" httpUri="http://biocol.org/urn:lsid:biocol.org:col:15175" lsid="urn:lsid:biocol.org:col:15175" name="Universidade Federal do Paraná" pageId="17" pageNumber="170" type="Herbarium">UPCB</collectionCode>
!).
</paragraph>
<paragraph id="8BB6368C92417723FF43FCBEFDE1BFE7" blockId="17.[136,1452,158,1480]" pageId="17" pageNumber="170">
<emphasis id="B97DEA9E92417723FF43FCBEFE25BFC3" bold="true" box="[189,436,878,904]" pageId="17" pageNumber="170">Additional material:</emphasis>
— 
<collectingCountry id="F31E761C92417723FE2CFCBEFDABBFC3" box="[466,570,878,904]" name="Brazil" pageId="17" pageNumber="170">BRAZIL</collectingCountry>
. 
<collectingRegion id="49CDF86E92417723FDB8FCBEFD73BFC3" box="[582,738,878,904]" country="Brazil" name="Minas Gerais" pageId="17" pageNumber="170">Minas Gerais</collectingRegion>
: Santa Maria do Salto, 
<emphasis id="B97DEA9E92417723FC0EFCBFFB1DBFC3" box="[1008,1164,878,905]" italics="true" pageId="17" pageNumber="170">Amorim 5548</emphasis>
(
<collectionCode id="ED18AE4992417723FB63FCBEFB6FBFC3" box="[1181,1278,878,904]" country="Brazil" lsid="urn:lsid:biocol.org:col:15526" name="CEPEC, CEPLAC" pageId="17" pageNumber="170" type="Herbarium">CEPEC</collectionCode>
!, 
<collectionCode id="ED18AE4992417723FAF1FCBFFAADBFC2" box="[1295,1340,879,905]" country="USA" lsid="urn:lsid:biocol.org:col:15556" name="William and Lynda Steere Herbarium of the New York Botanical Garden" pageId="17" pageNumber="170" type="Herbarium">NY</collectionCode>
); 
<emphasis id="B97DEA9E92417723FAAFFCBFFF51BFE7" italics="true" pageId="17" pageNumber="170">Amorim 5845</emphasis>
(
