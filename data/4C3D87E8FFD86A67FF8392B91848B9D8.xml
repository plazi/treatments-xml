<subSubSection id="8C8E6575FFD86A67FD14905C1D2CBDDE" pageId="35" pageNumber="793" type="discussion">
<paragraph id="C42B36FEFFD86A67FD14905C1D2CBDDE" blockId="35.[739,1334,1422,1851]" pageId="35" pageNumber="793">
<taxonomicName id="03944D7DFFD86A67FD14905C1DE4BD14" baseAuthorityName="Gray" baseAuthorityYear="1841" box="[744,996,1541,1574]" class="Mammalia" family="Vespertilionidae" genus="Vespadelus" kingdom="Animalia" order="Chiroptera" pageId="35" pageNumber="793" phylum="Chordata" rank="species" species="pumilus">Vespadelus pumilus</taxonomicName>
was previously considered to include V. 
<taxonomicName id="03944D7DFFD86A67FBFD90741A71BD7C" baseAuthorityName="Thomas" baseAuthorityYear="1914" box="[1025,1137,1581,1614]" class="Mammalia" family="Vespertilionidae" genus="Vespadelus" kingdom="Animalia" order="Chiroptera" pageId="35" pageNumber="793" phylum="Chordata" rank="species" species="caurinus">caurinus</taxonomicName>
, V. 
<taxonomicName id="03944D7DFFD86A67FB5690741B2CBD7C" authorityName="Kitchener, B. Jones &amp; Caputi" authorityYear="1987" box="[1194,1324,1581,1614]" class="Mammalia" family="Vespertilionidae" genus="Eptesicus" kingdom="Animalia" order="Chiroptera" pageId="35" pageNumber="793" phylum="Chordata" rank="species" species="finlaysoni">finlaysoni</taxonomicName>
, V. 
<taxonomicName id="03944D7DFFD86A67FCFB900D1D89BD47" authorityName="Kitchener, B. Jones &amp; Caputi" authorityYear="1987" box="[775,905,1620,1653]" class="Mammalia" family="Vespertilionidae" genus="Eptesicus" kingdom="Animalia" order="Chiroptera" pageId="35" pageNumber="793" phylum="Chordata" rank="species" species="troughtoni">troughtoni</taxonomicName>
, and V. 
<taxonomicName id="03944D7DFFD86A67FC09900D1A84BD47" authorityName="G. M. Allen" authorityYear="1933" box="[1013,1156,1620,1653]" class="Mammalia" family="Vespertilionidae" genus="Eptesicus" kingdom="Animalia" order="Chiroptera" pageId="35" pageNumber="793" phylum="Chordata" rank="species" species="darlingtoni">darlingtoni</taxonomicName>
