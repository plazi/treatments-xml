, 
<bibRefCitation id="5429E9C65687336BA3F307B3DE17407B" author="Demir, Emine" journalOrPublisher="Munis Entomology &amp; Zoology" pageId="0" pageNumber="83231" pagination="280 - 286" refId="B7713154" refString="Demir, Emine, Demirsoy, Ali, 2009. Preliminary report on the Fulgoromorpha (Hemiptera) fauna of Kemaliye (Erzincan) with a new record for Turkey. Munis Entomology &amp; Zoology 4 (1): 280 - 286" title="Preliminary report on the Fulgoromorpha (Hemiptera) fauna of Kemaliye (Erzincan) with a new record for Turkey" volume="4" year="2009">Demir and Demirsoy 2009</bibRefCitation>
