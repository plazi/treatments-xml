<subSubSection id="B4A1A79DBE4246B3AB217368644A38B0" pageId="null" pageNumber="494" type="description">
<paragraph id="719937032049F852ABD3336314AEAB2E" pageId="null" pageNumber="494">
Unterscheidet sich von 
<taxonomicName id="CB76DD25606ACC14BDF9BE5ACE9133C0" class="Liliopsida" family="Araceae" genus="Arum" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="494" phylum="Tracheophyta" rank="species" species="maculatum">
<emphasis id="33B869140BC1E6D5A5B2FDA7328B8468" italics="true" pageId="null" pageNumber="494">A. maculatum</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: Bis 100 cm hoch; 
<emphasis id="745ADEE3B8AD5D3842DA7C3A360CD462" italics="true" pageId="null" pageNumber="494">
<normalizedToken id="DA35A92302286272A6563758ADF32426" originalValue="Blätter" pageId="null" pageNumber="494">Blaetter</normalizedToken>
im 
<normalizedToken id="374589C6342942A302108E0FB2383BF9" originalValue="Spätherbst" pageId="null" pageNumber="494">Spaetherbst</normalizedToken>
erscheinend, oberseits den Nerven entlang 
<normalizedToken id="02431495458964B665BD59A884D12E03" originalValue="weißlich" pageId="null" pageNumber="494">weisslich</normalizedToken>
; der nicht mit 
<normalizedToken id="5C42DF99111A5BF3B1A67F8B0F247557" originalValue="Blüten" pageId="null" pageNumber="494">Blueten</normalizedToken>
besetzte, oberste Teil der Kolbenachse meist gelb.
</emphasis>
- 
<normalizedToken id="702F00147CFA25B248081B665AA3E369" originalValue="Blüte" pageId="null" pageNumber="494">Bluete</normalizedToken>
: 
<normalizedToken id="7361DCF064500BEFCCD7B692A26F6DD2" originalValue="Frühling" pageId="null" pageNumber="494">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="89ACD9CBA4F549A0B2E5DFF6BD0E966A" pageId="null" pageNumber="494">
<emphasis id="F293DFF5A7BA7A0D6CBADDEEA6A49816" italics="true" pageId="null" pageNumber="494">Zytologische Angaben. 2n = 64:</emphasis>
(Delay aus Darlington und Wylie 1955).
</paragraph>
<paragraph id="308E550D174F1095D6B121F8E539BAD2" pageId="null" pageNumber="494">
<emphasis id="4E84A11C3F00928CD7149C2259E331C7" italics="true" pageId="null" pageNumber="494">Standort.</emphasis>
Kollin. Feuchte 
<normalizedToken id="02F40052B7BF1138404C0A8AD305AE8C" originalValue="Böden" pageId="null" pageNumber="494">Boeden</normalizedToken>
. 
<normalizedToken id="335FFEBC9F3B6E03B86DE75F5CDD64D8" originalValue="Gebüsch" pageId="null" pageNumber="494">Gebuesch</normalizedToken>
.
</paragraph>
<paragraph id="45F3A6A791FB4774C8A2A635DF17923B" pageId="null" pageNumber="494">
<emphasis id="C2921C8506B6097D3E4F87A50F2BBDB1" italics="true" pageId="null" pageNumber="494">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="FFA91D7676668036B6E5687B20B0CB22" originalValue="Nordwärts" pageId="null" pageNumber="494">Nordwaerts</normalizedToken>
bis 
<normalizedToken id="FA7997E4F1CA781686BE97FFE5F1AF18" originalValue="Südengland" pageId="null" pageNumber="494">Suedengland</normalizedToken>
, Gebiet der Seine, 
<normalizedToken id="05C65FBD62566B2F2A80EF074463074E" originalValue="Dép" pageId="null" pageNumber="494">Dep</normalizedToken>
. Ain, 
<normalizedToken id="AD08D245B9C9F71E19E017EAF9DC1CD6" originalValue="Alpensüdfuß" pageId="null" pageNumber="494">Alpensuedfuss</normalizedToken>
, 
<normalizedToken id="0593179AC0E8DB9321B93584B098DCFE" originalValue="südliche" pageId="null" pageNumber="494">suedliche</normalizedToken>
Balkanhalbinsel, Ostgrenze an der westlichen 
<normalizedToken id="AA6092390B068DBC62DDDDDB4970262B" originalValue="Schwarzmeerküste" pageId="null" pageNumber="494">Schwarzmeerkueste</normalizedToken>
; Nordwestafrika (
<normalizedToken id="CA5BF74DD17100E4B20CAB1814E15E59" originalValue="südwärts" pageId="null" pageNumber="494">suedwaerts</normalizedToken>
bis in den Atlas); Kleinasien. Verbreitungskarte von Meusel (1964). - Im Gebiet: Savoyen, 
<normalizedToken id="04617C801EE2211B5CF47BEB6CAAA8FC" originalValue="Dép" pageId="null" pageNumber="494">Dep</normalizedToken>
. Ain, Genf (Kulturrelikt), 
<normalizedToken id="475D8291C079A0BC4735DA81C12F3A5F" originalValue="südliches" pageId="null" pageNumber="494">suedliches</normalizedToken>
Tessin und angrenzende Gebiete; meist selten.
</paragraph>
</subSubSection>
