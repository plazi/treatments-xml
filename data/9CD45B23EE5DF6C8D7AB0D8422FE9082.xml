<subSubSection id="F45ECD45310D6CA4EB36C328A03190F2" pageId="null" pageNumber="393" type="description">
<paragraph id="B3F48A1F85A8A656B39DF2266CFDF573" pageId="null" pageNumber="393">
Ist 
<taxonomicName id="ACAC0E4EC0199260A698AF065DDEE0E5" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="393" phylum="Tracheophyta" rank="species" species="argentea">
<emphasis id="6FA9FA286EE484AB85597D71A6275480" italics="true" pageId="null" pageNumber="393">P. argentea</emphasis>
</taxonomicName>
(Nr. 13a) sehr 
<normalizedToken id="55B3341673CB814B61DCC04546D55816" originalValue="ähnlich" pageId="null" pageNumber="393">aehnlich</normalizedToken>
. Die 
<normalizedToken id="D20E7096A573262C7DCE55088B1F9FEC" originalValue="Teilblätter" pageId="null" pageNumber="393">Teilblaetter</normalizedToken>
von 
<emphasis id="7278923E5DE451E23E3D9A15B9D9B102" italics="true" pageId="null" pageNumber="393">
<taxonomicName id="095CE89DF0242E3B19D232681F8EA38E" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="393" phylum="Tracheophyta" rank="species" species="canescens">P. canescens</taxonomicName>
sind jedoch meist auch gegen die Basis hin fiederteilig, haben jederseits 5-9 
<normalizedToken id="3ABB8F344C76A98C96AA786576660BC8" originalValue="zahnähnliche" pageId="null" pageNumber="393">zahnaehnliche</normalizedToken>
Abschnitte
</emphasis>
, sind oberseits 
<normalizedToken id="87616FC7CFE015E8440DB7107A33C14B" originalValue="hellgrün" pageId="null" pageNumber="393">hellgruen</normalizedToken>
und unterseits nur 
<emphasis id="FD65B5C4590399BA1B93EF74283F35B0" italics="true" pageId="null" pageNumber="393">
locker filzig behaart und deshalb 
<normalizedToken id="E805D299417B596DDC852647C3B9CB1E" originalValue="graugrün" pageId="null" pageNumber="393">graugruen</normalizedToken>
; Rand flach, nicht nach unten umgebogen
</emphasis>
(nach Wolf 1908 sicherstes Unterscheidungsmerkmal 
<normalizedToken id="34668D0EC836C610C372F40538D123F7" originalValue="gegenüber" pageId="null" pageNumber="393">gegenueber</normalizedToken>
<taxonomicName id="C3C3F81ECE954938775F5801E1EAB4E7" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="393" phylum="Tracheophyta" rank="species" species="argentea">
<emphasis id="8F0B97DC87309A8325009D3C0370FAE4" italics="true" pageId="null" pageNumber="393">P. argentea</emphasis>
</taxonomicName>
). - 
<normalizedToken id="53156D4DDA93677287D175ED8C339702" originalValue="Blüte" pageId="null" pageNumber="393">Bluete</normalizedToken>
: 
<normalizedToken id="77C21C60D3649A8E1021511AC9613A17" originalValue="Frühsommer" pageId="null" pageNumber="393">Fruehsommer</normalizedToken>
.
</paragraph>
<paragraph id="07D7E15958A37B0D6C4353A3C675BA96" pageId="null" pageNumber="393">
<emphasis id="DA56955ADA10125C7A884CA002BBE723" italics="true" pageId="null" pageNumber="393">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="819D93E857DEC15410B172FBFF37A8B8" italics="true" pageId="null" pageNumber="393">42:</emphasis>
Material aus der Umgebung von Schaffhausen; Embryosack entwickelt sich aus somatischem Gewebe (Rutishauser 1943b), ohne Herkunftsangabe des Materials (Christoff und Papasowa 1943), Material aus dem 
<normalizedToken id="2FA0ED955C40B2FB1507B897E91DCF6F" originalValue="Elsaß" pageId="null" pageNumber="393">Elsass</normalizedToken>
(Gagnieu et al. 1961).
</paragraph>
<paragraph id="81F9F6251279E7061C3405824E1E7542" pageId="null" pageNumber="393">
<emphasis id="13A9E6D7A470E2981E9ABBF559363A50" italics="true" pageId="null" pageNumber="393">Standort.</emphasis>
Kollin. Trockene, sandige, steinige bis lehmige, kalkhaltige bis kalkfreie 
<normalizedToken id="C5BCFFBC6D0AB1E8DEC57C1A8FC6BE7A" originalValue="Böden" pageId="null" pageNumber="393">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="EB404D295AB3C9B94A233CEF6822A471" originalValue="Steppenähnliche" pageId="null" pageNumber="393">Steppenaehnliche</normalizedToken>
Wiesen (keine geschlossene Pflanzendecke), an Mauern und Felsen.
</paragraph>
<paragraph id="E826F8BD12E283E9743675B45BE41A78" pageId="null" pageNumber="393">
<emphasis id="5E0BD78C04806678CBDA41AC499C5D7D" italics="true" pageId="null" pageNumber="393">Verbreitung. Eurasiatische Pflanze:</emphasis>
In Europa 
<normalizedToken id="B509B95B9C7C20C0D15A1E3B12C3EB4E" originalValue="nordwärts" pageId="null" pageNumber="393">nordwaerts</normalizedToken>
bis Mittelfrankreich, Mitteldeutschland, 
<normalizedToken id="A9FDD70B3D022ECEE36E219863FE2107" originalValue="Südpolen" pageId="null" pageNumber="393">Suedpolen</normalizedToken>
, 
<normalizedToken id="8EE7A0946CFE5F12B0614E987F13D2FC" originalValue="Mittelrußland" pageId="null" pageNumber="393">Mittelrussland</normalizedToken>
; 
<normalizedToken id="15531537F3090AD477E6F85DAF2203C1" originalValue="südwärts" pageId="null" pageNumber="393">suedwaerts</normalizedToken>
bis 
<normalizedToken id="CDFAC2BE33CEAE1D9172FEDCC90A401C" originalValue="Südfrankreich" pageId="null" pageNumber="393">Suedfrankreich</normalizedToken>
, Sizilien, mittlere Balkanhalbinsel; in Asien durch Westsibirien bis in den Altai, 
<normalizedToken id="03F483003988B0139A220B87BB064DEA" originalValue="Südwestasien" pageId="null" pageNumber="393">Suedwestasien</normalizedToken>
. - Im Gebiet: Oberrheinische Tiefebene, in den Vogesen 
<normalizedToken id="3D3910F13F3C98E5446ADB97B7DFCC5B" originalValue="nordwärts" pageId="null" pageNumber="393">nordwaerts</normalizedToken>
bis ins Bruchtal, Nordschweiz, Hegau, Baar, Savoyen, Wallis, 
<normalizedToken id="755098FA77AAA6D1032613C1FB551C09" originalValue="südliches" pageId="null" pageNumber="393">suedliches</normalizedToken>
Tessin und angrenzende Gebiete, Gegend von Bergamo.
</paragraph>
<paragraph id="1A4F7A620D42AFE3B0D70F467E8F65B9" pageId="null" pageNumber="393">
<emphasis id="EFAE8A0205788267E3069ABB34B5DEEC" italics="true" pageId="null" pageNumber="393">
Bemerkungen. 
<taxonomicName id="3D7D4893C7528240D12A90EC91017B7D" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="393" phylum="Tracheophyta" rank="species" species="canescens">P. canescens</taxonomicName>
</emphasis>
ist sehr formenreich, doch sind 
<normalizedToken id="1DF2A943821315959592DEB728F313E6" originalValue="faßbare" pageId="null" pageNumber="393">fassbare</normalizedToken>
geographische Sippen nicht bekannt. Gleiche Abweichungen (Behaarung, 
<normalizedToken id="4E7E377096418F88161988D13E73A802" originalValue="Zähnung" pageId="null" pageNumber="393">Zaehnung</normalizedToken>
der mittleren und untern 
<normalizedToken id="A4CEA4A7708BABE111B5ECB7DF01CE54" originalValue="Stengelblätter" pageId="null" pageNumber="393">Stengelblaetter</normalizedToken>
) sind durch das ganze Verbreitungsgebiet der Art nebeneinander zu finden.
</paragraph>
<paragraph id="2B580A50FB3C5AEDA7309C5E0E4A9035" pageId="null" pageNumber="393">
Neuerdings wird 
<normalizedToken id="F47674A6E83B90F52880E24A23C4EB66" originalValue="für" pageId="null" pageNumber="393">fuer</normalizedToken>
<taxonomicName id="E61D9ED89AD6090735A232261C21F1E7" authority="der Name" authorityName="der Name" class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="393" phylum="Tracheophyta" rank="species" species="canescens">
<emphasis id="1BB6227E65C66F02E8EF880A20BA0929" italics="true" pageId="null" pageNumber="393">P. canescens</emphasis>
der Name
</taxonomicName>
<taxonomicName id="FEA8BEBE272F31165642FF08F04319D6" authority="Vill." authorityName="Vill." class="Magnoliopsida" family="Rosaceae" genus="Potentilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="393" phylum="Tracheophyta" rank="species" species="inclinata">
<emphasis id="E18FC5C6099E4D29BD67B5AD257499DD" italics="true" pageId="null" pageNumber="393">P. inclinata</emphasis>
Vill.
</taxonomicName>
gebraucht.
</paragraph>
</subSubSection>
