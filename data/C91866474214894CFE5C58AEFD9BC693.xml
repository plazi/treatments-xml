<subSubSection id="09AB84DA4214894CFF755D09FD9BC693" pageId="19" pageNumber="29" type="discussion">
<paragraph id="410ED7514214894CFF755D09FE91C62C" blockId="19.[227,341,1606,1632]" box="[227,341,1606,1632]" pageId="19" pageNumber="29">
<heading id="1A46603D4214894CFF755D09FE91C62C" bold="true" box="[227,341,1606,1632]" fontSize="11" level="3" pageId="19" pageNumber="29" reason="3">
<emphasis id="73C50B434214894CFF755D09FE91C62C" bold="true" box="[227,341,1606,1632]" pageId="19" pageNumber="29">Remarks</emphasis>
</heading>
</paragraph>
<paragraph id="410ED7514214894CFF755D38FD9BC693" blockId="19.[227,1437,1655,1759]" pageId="19" pageNumber="29">
<taxonomicName id="86B1ACD24214894CFF755D38FEB8C6DD" authorityName="Bockwinkel, Becker &amp; Ebbighausen" authorityYear="2009" box="[227,380,1655,1681]" class="Cephalopoda" family="Taouzitidae" genus="Darkaoceras" kingdom="Animalia" order="Ammonoidea" pageId="19" pageNumber="29" phylum="Mollusca" rank="genus">
<emphasis id="73C50B434214894CFF755D38FEB8C6DD" box="[227,380,1655,1681]" italics="true" pageId="19" pageNumber="29">Darkaoceras</emphasis>
</taxonomicName>
(with subacute venter and four umbilical lobes) is morphologically intermediate between 
<taxonomicName id="86B1ACD24214894CFF755DD2FEAAC6FB" authorityName="Becker &amp; House" authorityYear="1994" box="[227,366,1693,1719]" class="Cephalopoda" family="Taouzitidae" genus="Mzerrebites" kingdom="Animalia" order="Ammonoidea" pageId="19" pageNumber="29" phylum="Mollusca" rank="genus">
<emphasis id="73C50B434214894CFF755DD2FEAAC6FB" box="[227,366,1693,1719]" italics="true" pageId="19" pageNumber="29">Mzerrebites</emphasis>
</taxonomicName>
(with narrowly rounded venter and three umbilical lobes) and 
<taxonomicName id="86B1ACD24214894CFBC75DD1FB7BC6FB" authorityName="Korn" authorityYear="2001" box="[1105,1215,1694,1719]" class="Cephalopoda" family="Taouzitidae" genus="Taouzites" kingdom="Animalia" order="Ammonoidea" pageId="19" pageNumber="29" phylum="Mollusca" rank="genus">
<emphasis id="73C50B434214894CFBC75DD1FB7BC6FB" box="[1105,1215,1694,1719]" italics="true" pageId="19" pageNumber="29">Taouzites</emphasis>
</taxonomicName>
(with sharp venter and up to eight umbilical lobes).
</paragraph>
