<subSubSection id="935E7807D481EB28129BEF060BC08F9F" pageId="null" pageNumber="157" type="description">
<paragraph id="7EAF1939963E4658ADA7AC8700D67473" pageId="null" pageNumber="157">
<emphasis id="6A97BC21286E9291D1B743059208963F" italics="true" pageId="null" pageNumber="157">Keine Haare vorhanden.</emphasis>
<normalizedToken id="AFE3F8F7E8E97381CD6391DD7F6F419A" originalValue="Blätter" pageId="null" pageNumber="157">Blaetter</normalizedToken>
ungeteilt und ganzrandig bis 
<normalizedToken id="39B5D5C8BB2C31541DE99B69F639980C" originalValue="gezähnt" pageId="null" pageNumber="157">gezaehnt</normalizedToken>
oder fiederteilig; Endabschnitt nicht breiter als die ungeteilte Blattmitte darunter. 
<normalizedToken id="F80F010C5323ED6A8BA01829980AD232" originalValue="Kelchblätter" pageId="null" pageNumber="157">Kelchblaetter</normalizedToken>
am Grunde nicht deutlich ausgebuchtet. 
<normalizedToken id="1C02070B857669BF7654C1827F6F5CFA" originalValue="Kronblätter" pageId="null" pageNumber="157">Kronblaetter</normalizedToken>
vorn gerundet, kurz gestielt, 
<normalizedToken id="E1E35F1C50C969E4B2A4A142727D160E" originalValue="weiß" pageId="null" pageNumber="157">weiss</normalizedToken>
oder 
<normalizedToken id="1136F03B88B4E0C4B09B5983BDFF9BB5" originalValue="rötlich" pageId="null" pageNumber="157">roetlich</normalizedToken>
. 
<normalizedToken id="E53F7680A86692B0A318869B64BB1CC9" originalValue="Staubfäden" pageId="null" pageNumber="157">Staubfaeden</normalizedToken>
<normalizedToken id="C455056C582B8F5006D0132567BB558C" originalValue="ungeflügelt" pageId="null" pageNumber="157">ungefluegelt</normalizedToken>
, ohne 
<normalizedToken id="076FBD1D9E55EB8136EA945FEDA26E6E" originalValue="Zähne" pageId="null" pageNumber="157">Zaehne</normalizedToken>
. 
<normalizedToken id="168BAADB893F6F39B48E8B6CF87A421F" originalValue="Früchte" pageId="null" pageNumber="157">Fruechte</normalizedToken>
<normalizedToken id="49E0B7985D64800365E3B6252A88286D" originalValue="aufgewölbt" pageId="null" pageNumber="157">aufgewoelbt</normalizedToken>
, 
<normalizedToken id="52FD793DF7C56CA2584E7098D3FFC3D4" originalValue="eiförmig" pageId="null" pageNumber="157">eifoermig</normalizedToken>
bis kugelig, 1-2mal so lang wie dick, unberandet, 
<emphasis id="6C48B5FA221862E980F9865524B577C9" italics="true" pageId="null" pageNumber="157">8-12samig</emphasis>
(Samen in jedem Fach 2reihig angeordnet), aufklappend; 
<emphasis id="30836AE80B73C4EB8DEDB933E62E1E0A" italics="true" pageId="null" pageNumber="157">
<normalizedToken id="C73E31ABF57F46F9194AB12593984997" originalValue="Fruchtblätter" pageId="null" pageNumber="157">Fruchtblaetter</normalizedToken>
ohne Mittelnerven
</emphasis>
(nur 2 Nahtstellen).
</paragraph>
<paragraph id="0665F2ED6B573C227764FF44FE94E615" pageId="null" pageNumber="157">
Die Gattung 
<emphasis id="444EEDDC049BBB23E7D35C3EF0E24AB7" italics="true" pageId="null" pageNumber="157">
<taxonomicName id="D8FD3F09CC6FD1FB28BA50A9644DE7FE" class="Magnoliopsida" family="Brassicaceae" genus="Armoracia" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="157" phylum="Tracheophyta" rank="genus">Armoracia</taxonomicName>
<normalizedToken id="B8763B4BE15AD2974AD8040CFB708FD8" originalValue="umfaßt" pageId="null" pageNumber="157">umfasst</normalizedToken>
3 Arten mit 
<normalizedToken id="235A2584C84ADF442C2305915F30F803" originalValue="ursprünglicher" pageId="null" pageNumber="157">urspruenglicher</normalizedToken>
Verbreitung in Osteuropa und Sibirien.
</emphasis>
</paragraph>
