1931. 
<taxonomicName id="8DDC4D70FFF8FFB9FC289F666DDA7E57" authority="PLUMMER" authorityName="PLUMMER" box="[898,1239,802,824]" class="Nodosariata" family="Vaginulinidae" genus="Hemicristellaria" kingdom="Chromista" order="Vaginulinida" pageId="21" pageNumber="35" phylum="Foraminifera" rank="species" species="silicula">
