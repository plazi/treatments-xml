Key to the species of 
<taxonomicName id="4C214D77FF9DFFDEFE30FE96FCDDFEFA" authority="sect. Psyllocarpus" box="[464,875,264,293]" class="Magnoliopsida" family="Rubiaceae" genus="Psyllocarpus" kingdom="Plantae" order="Gentianales" pageId="12" pageNumber="173" phylum="Tracheophyta" rank="section" section="Psyllocarpus">Psyllocarpus sect. Psyllocarpus</taxonomicName>
