<subSubSection id="C0C833B5F75AB0D3A5657AC71465419E" pageId="null" pageNumber="120" type="description">
<paragraph id="23B0E69B1131C226E9AB9C0398F0D963" pageId="null" pageNumber="120">
Unterscheidet sich von 
<taxonomicName id="E5819C28049C97041A1151BAC9043972" class="Magnoliopsida" family="Papaveraceae" genus="Corydalis" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="120" phylum="Tracheophyta" rank="species" species="lutea">
<emphasis id="E82DC53BA901C97A800DB1DA3D5C67B3" italics="true" pageId="null" pageNumber="120">C. lutea</emphasis>
</taxonomicName>
(Nr. 4) durch folgende Merkmale: 
<emphasis id="E7BBCDE8ADBBFB884CF46D2D874EB9D7" italics="true" pageId="null" pageNumber="120">
<normalizedToken id="4657E21EDC164D0D40054381BA096B91" originalValue="Blätter" pageId="null" pageNumber="120">Blaetter</normalizedToken>
<normalizedToken id="CE82390C60DF3EA2B67D4878C9810C3F" originalValue="blaugrün" pageId="null" pageNumber="120">blaugruen</normalizedToken>
; Blattstiel gegen den Grund mit schmalem 
<normalizedToken id="84FF909648304E92F00196749B787267" originalValue="flügelartigem" pageId="null" pageNumber="120">fluegelartigem</normalizedToken>
Rand
</emphasis>
(bei allen andern Arten des Gebiets 
<normalizedToken id="6F768C91337D516090E37B71183C9B94" originalValue="ungeflügelt" pageId="null" pageNumber="120">ungefluegelt</normalizedToken>
!); 
<emphasis id="27F0BF9197138388530C21BCE1EA5F5C" italics="true" pageId="null" pageNumber="120">
<normalizedToken id="30963D7F79879678659A34DA9A5924B7" originalValue="Blüten" pageId="null" pageNumber="120">Blueten</normalizedToken>
10-15 mm lang, 
<normalizedToken id="3E5DBA4CC4D586EA32790910C905D8D8" originalValue="blaßgelb" pageId="null" pageNumber="120">blassgelb</normalizedToken>
; 
<normalizedToken id="1C89616DB61FDF17207D5A6583913F42" originalValue="Kelchblätter" pageId="null" pageNumber="120">Kelchblaetter</normalizedToken>
2-3 mm lang;
</emphasis>
Samen mit deutlich 
<normalizedToken id="5E38C4F2DE49236E6FCCCE07F4C152C3" originalValue="gekörnter" pageId="null" pageNumber="120">gekoernter</normalizedToken>
<normalizedToken id="CE4F7D7472F08CC57DA7FF66BEFAD78A" originalValue="Oberfläche" pageId="null" pageNumber="120">Oberflaeche</normalizedToken>
, 
<normalizedToken id="7188561A6474DF3D93CC088000B36E8E" originalValue="±" pageId="null" pageNumber="120">+/-</normalizedToken>
<emphasis id="F9722A7ECB0B213CE7092323725A72EA" italics="true" pageId="null" pageNumber="120">matt. -</emphasis>
<normalizedToken id="BAAAEE2AC21D323A8FCB3724AEA5A9FB" originalValue="Blüte" pageId="null" pageNumber="120">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="939FAFF9B660C55116A6E7CC3749574D" pageId="null" pageNumber="120">
<emphasis id="B491CD9C806E0FC3A62CF90A318895AF" italics="true" pageId="null" pageNumber="120">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E4C1F5F462CD8FDD1294B312272AEF00" italics="true" pageId="null" pageNumber="120">28:</emphasis>
Material aus botanischem Garten (Negodi 1940). 
<emphasis id="B3EC0B2C27AAACFFAF0C418A51B20C81" italics="true" pageId="null" pageNumber="120">2n</emphasis>
= 
<emphasis id="02826F9A27BA95A257A2E96916FA01C6" italics="true" pageId="null" pageNumber="120">32</emphasis>
(und 64): Material aus botanischem Garten (Ryberg 1960).
</paragraph>
<paragraph id="6E4ACAE7F8F9ACA62E305726677B2492" pageId="null" pageNumber="120">
<emphasis id="7C4ADF10E14F0B4147BB34E49FF09C32" italics="true" pageId="null" pageNumber="120">Standort.</emphasis>
<normalizedToken id="CC33971CEE411959EF1CAEA46920D32A" originalValue="Ähnlich" pageId="null" pageNumber="120">Aehnlich</normalizedToken>
wie 
<taxonomicName id="3CAC13C0C03B022A30FB88C3D1F0BE42" class="Magnoliopsida" family="Papaveraceae" genus="Corydalis" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="120" phylum="Tracheophyta" rank="species" species="lutea">
<emphasis id="AB2B1C35AD1DD7721C60F342890B7C51" italics="true" pageId="null" pageNumber="120">C. lutea</emphasis>
</taxonomicName>
(Nr. 4); auf Dolomit.
</paragraph>
<paragraph id="E54A03FEDB12899482745298ACD52A41" pageId="null" pageNumber="120">
<emphasis id="74B4C86F59E07760071ECD15215EE738" italics="true" pageId="null" pageNumber="120">Verbreitung. Apenninisch-illyrische Pflanze:</emphasis>
Apennin, 
<normalizedToken id="2A2DE3170E373C7A03AE8A15BD91ECE8" originalValue="Südalpen" pageId="null" pageNumber="120">Suedalpen</normalizedToken>
(vereinzelt vom Comerseegebiet 
<normalizedToken id="AF3E107D77AE918613BB3686E9DE505A" originalValue="ostwärts" pageId="null" pageNumber="120">ostwaerts</normalizedToken>
), Istrien, Gebirge der Balkanhalbinsel (
<normalizedToken id="F19014C0F768859923D690807C1677CB" originalValue="südwärts" pageId="null" pageNumber="120">suedwaerts</normalizedToken>
bis Montenegro). - Im Gebiet: Berge zwischen Corno und Lecco; Bergamasker Alpen (Resegone, Aralalta, Ornica).
</paragraph>
</subSubSection>
