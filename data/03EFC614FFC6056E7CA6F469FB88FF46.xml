<taxonomicName id="4C460C81FFC405687D89F091FCEEF95F" authority="Budashkin &amp; Bidzilya" authorityName="Budashkin &amp; Bidzilya" authorityYear="2018" box="[385,790,1757,1779]" class="Insecta" family="Coleophoridae" genus="Multicoloria" higherTaxonomySource="GBIF" kingdom="Animalia" order="Lepidoptera" pageId="3" pageNumber="118" phylum="Arthropoda" rank="species" species="jukkai" status="sp. n.">
