<subSubSection id="E61285F0D3ADC0D37B8FACCCD6798B3C" pageId="null" pageNumber="647" type="vernacular_names">
<paragraph id="3621CE95B91A5256F8F7BD5C6592A83A" pageId="null" pageNumber="647">Sumpf-Kreuzblume</paragraph>
</subSubSection>
</title>
<subSubSection id="3620A1155D1C0BBC244CC5D467EE5CA1" pageId="null" pageNumber="647" type="description">
<paragraph id="CA40F1A04C7E41D200924AADAB215BC3" pageId="null" pageNumber="647">
5-15 cm hoch. 
<emphasis id="971B19023E7F27E4E52176A7886522BC" italics="true" pageId="null" pageNumber="647">Stengel am Grunde nur kurz niederliegend</emphasis>
(meist weniger als 3 cm). Untere 
<normalizedToken id="0445C0E1827A58FD9664AA607C701594" originalValue="Blätter" pageId="null" pageNumber="647">Blaetter</normalizedToken>
<normalizedToken id="38E1A3E7728D56C21B90CCC5F978D782" originalValue="wechselständig" pageId="null" pageNumber="647">wechselstaendig</normalizedToken>
, am Ort, wo die Zweige aufsteigen, rosettenartig angeordnet, die obern 
<normalizedToken id="B9EC412D53EAB11F89A2CFC96DB652B2" originalValue="kürzer" pageId="null" pageNumber="647">kuerzer</normalizedToken>
als die untern, 
<emphasis id="DD2D6C9CAADDFE29FB280B3CAA145C1C" italics="true" pageId="null" pageNumber="647">1-2,5 cm lang</emphasis>
, oberhalb der Mitte am breitesten. 
<normalizedToken id="F6ED780F0DB485F4939FC5B2EDD12035" originalValue="Blütenstand" pageId="null" pageNumber="647">Bluetenstand</normalizedToken>
10-40 
<normalizedToken id="03DA8B72EF048A4FBC7181C0DD3A8D97" originalValue="blütig" pageId="null" pageNumber="647">bluetig</normalizedToken>
. 
<emphasis id="93DAA42AAD0F5E8DC0E66C2192D8C2F3" italics="true" pageId="null" pageNumber="647">
<normalizedToken id="E5929E6F713B17D78D7D9564CB9C1DCF" originalValue="Tragblätter" pageId="null" pageNumber="647">Tragblaetter</normalizedToken>
1-1,5 mm lang.
</emphasis>
<normalizedToken id="75EC9D870FD57AB89E917849E7FCE7F9" originalValue="Blüten" pageId="null" pageNumber="647">Blueten</normalizedToken>
blau (selten 
<normalizedToken id="C1F521E825A1EED4193AABF71D04C9AB" originalValue="rötlich" pageId="null" pageNumber="647">roetlich</normalizedToken>
oder 
<normalizedToken id="9CC01EC425EBADF2A0CD8794B9C016C0" originalValue="weiß" pageId="null" pageNumber="647">weiss</normalizedToken>
). 
<emphasis id="46396A83E91017E2BA6FEB08D699C58D" italics="true" pageId="null" pageNumber="647">
Oberstes Kelchblatt 1,7-2,3 mm lang. 
<normalizedToken id="6312F82590C510D5779556DD1D805E22" originalValue="Flügel" pageId="null" pageNumber="647">Fluegel</normalizedToken>
2,5-4,5 mm lang und 1,2-2,5 mm breit;
</emphasis>
die seitlichen Nerven nur wenig verzweigt und nur 0 bis 3 geschlossene Netzmaschen bildend. 
<emphasis id="1136619D44849434AF72FB8D9AF57916" italics="true" pageId="null" pageNumber="647">Fransen der untern Kronzipfel 8-14. Frucht 3-4 mm lang</emphasis>
, mit 0,2-0,3 mm breitem Rand. 
<emphasis id="97636D905DF1320F46A06EC1B1577521" italics="true" pageId="null" pageNumber="647">Samen 1,7-2,1 mm lang.</emphasis>
- 
<normalizedToken id="99E765151A1601ADE38F432B5909E323" originalValue="Blüte" pageId="null" pageNumber="647">Bluete</normalizedToken>
: 
<normalizedToken id="51954061C9C3AFDCF583D622D14AC862" originalValue="Später" pageId="null" pageNumber="647">Spaeter</normalizedToken>
<normalizedToken id="FD68EB72C88BB3FD23264422C6DD3F12" originalValue="Frühling" pageId="null" pageNumber="647">Fruehling</normalizedToken>
und 
<normalizedToken id="AA80262E370A63000D079BC3BED42D7A" originalValue="früher" pageId="null" pageNumber="647">frueher</normalizedToken>
Sommer, meist nochmals im Herbst.
</paragraph>
<paragraph id="795ACD7E927C8BBCCF7A14E54521C44A" pageId="null" pageNumber="647">
<emphasis id="BA75AD69C8DF8450D6B7480FF7BF34F2" italics="true" pageId="null" pageNumber="647">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="97C95631560A14946735204B08929909" italics="true" pageId="null" pageNumber="647">34:</emphasis>
Material aus der Schweiz und 
<normalizedToken id="83BAD0E84B8975B0B39787FC3953541C" originalValue="Großbritannien" pageId="null" pageNumber="647">Grossbritannien</normalizedToken>
(Glendinning 1960), aus Skandinavien (
<normalizedToken id="51787A13E229B36378A29F6BA62F5174" originalValue="Björse" pageId="null" pageNumber="647">Bjoerse</normalizedToken>
in 
<normalizedToken id="ADF0BB4D5970179FDF1EA21DECD95FA2" originalValue="Löve" pageId="null" pageNumber="647">Loeve</normalizedToken>
und 
<normalizedToken id="ABB1D6F27684ED6CD2977E1B5F4C93EA" originalValue="Löve" pageId="null" pageNumber="647">Loeve</normalizedToken>
1961), aus Finnland (Sorsa 1963).
</paragraph>
<paragraph id="377F7B57E92AD448135786CDFA710FDB" pageId="null" pageNumber="647">
<emphasis id="96775D083AED117F09179B0ECA6CBBA1" italics="true" pageId="null" pageNumber="647">Standort.</emphasis>
Kollin und montan, seltener subalpin. Meist feuchte und kalkhaltige, lehmige 
<normalizedToken id="81E4AA17B194C90FC33E8C893F3F87EB" originalValue="Böden" pageId="null" pageNumber="647">Boeden</normalizedToken>
. 
<normalizedToken id="103EC27CBB68CC34A2A894A1B5FE927B" originalValue="Ungedüngte" pageId="null" pageNumber="647">Ungeduengte</normalizedToken>
, kurzrasige Wiesen, Riedwiesen, Flachmoore.
</paragraph>
<paragraph id="5DF944031109B7A8E04F296123E5189C" pageId="null" pageNumber="647">
<emphasis id="D407224FB5C3701F8356933D61DD7B2F" italics="true" pageId="null" pageNumber="647">
Verbreitung. 
<normalizedToken id="FD3A35F464A4A7B060443A99105CB803" originalValue="Mitteleuropäische" pageId="null" pageNumber="647">Mitteleuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="16FC67A7C5C9FB0D6A74C26B6CB2A4A7" originalValue="Pyrenäen" pageId="null" pageNumber="647">Pyrenaeen</normalizedToken>
, sonst west- und 
<normalizedToken id="ECEF5F05FC9D61CFF80FAB68BA17E6E8" originalValue="nordwärts" pageId="null" pageNumber="647">nordwaerts</normalizedToken>
bis Rhone, 
<normalizedToken id="1A7B667FBD052140980C698612251FAE" originalValue="Saône" pageId="null" pageNumber="647">Saone</normalizedToken>
, Nordostfrankreich, 
<normalizedToken id="805608541AB32D52C1068BDA8980FCED" originalValue="Südengland" pageId="null" pageNumber="647">Suedengland</normalizedToken>
, 
<normalizedToken id="9791C2BEB318E7B7EEFFD50B96E0EFD6" originalValue="südliches" pageId="null" pageNumber="647">suedliches</normalizedToken>
Norwegen und Schweden, Karelien; 
<normalizedToken id="4EB713ABA7B17956BD3CE8DC93C31480" originalValue="ostwärts" pageId="null" pageNumber="647">ostwaerts</normalizedToken>
bis 
<normalizedToken id="48F506AF1BA8967528E4819BFF6870B0" originalValue="Nordrußland" pageId="null" pageNumber="647">Nordrussland</normalizedToken>
, Karpaten; 
<normalizedToken id="AA79620A8D035A707017F665E5F40F8B" originalValue="südwärts" pageId="null" pageNumber="647">suedwaerts</normalizedToken>
bis zu den Alpen. - Im Gebiet verbreitet und 
<normalizedToken id="186889E16EDE0BC9F08F39936ECBA83B" originalValue="häufig" pageId="null" pageNumber="647">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
