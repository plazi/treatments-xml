<taxonomicName id="83C9488D70D28DA776AD04C5D85E5B60" authority="(Willd.) Roem. et Schult." class="Liliopsida" family="Poaceae" genus="Trisetum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="310" phylum="Tracheophyta" rank="species" species="argenteum">
Trisetum 
<normalizedToken id="DEB6F96C2B7C15D675E3810214C22282" originalValue="argénteum" pageId="null" pageNumber="310">argenteum</normalizedToken>
(Willd.) Roem. et Schult.
</taxonomicName>
</paragraph>
