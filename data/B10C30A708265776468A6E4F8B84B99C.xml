<subSubSection id="8FE6761516E6CC5A7D9CFD2E64DE9C2A" pageId="null" pageNumber="310" type="vernacular_names">
<paragraph id="A7BA6B53FD3E18B3011BEAD8CB2825EF" pageId="null" pageNumber="310">Silber-Grannenhafer</paragraph>
</subSubSection>
</title>
<subSubSection id="B1CFE4ABC5C790EBB4294D13E4B390C9" pageId="null" pageNumber="310" type="description">
<paragraph id="0FCF224098A8F1D9E3BCF770B64D8D89" pageId="null" pageNumber="310">
Unterscheidet sich durch folgende Merkmale von 
<taxonomicName id="31EDBAE42148B5A27E05CDB359FE6AE6" class="Liliopsida" family="Poaceae" genus="Trisetum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="310" phylum="Tracheophyta" rank="species" species="distichophyllum">
<emphasis id="9E5275217D5BF31963A5FB6484EE88D9" italics="true" pageId="null" pageNumber="310">T. distichophyllum</emphasis>
</taxonomicName>
(Nr. 5): 
<emphasis id="F3CBFC79343714FF4B27386A3EACCD62" italics="true" pageId="null" pageNumber="310">
<normalizedToken id="77715A23C710244DD6EED63D6C421719" originalValue="Blätter" pageId="null" pageNumber="310">Blaetter</normalizedToken>
meist 1-1,5 mm breit, schlaff;
</emphasis>
<normalizedToken id="482CE2FA0823D4FB7D3D7F6602A921FA" originalValue="Ährchen" pageId="null" pageNumber="310">Aehrchen</normalizedToken>
gelbbraun; 
<emphasis id="064B1E786C0C40F8890E495DCD769361" italics="true" pageId="null" pageNumber="310">
untere 
<normalizedToken id="988304E2F5B34147C9CDF6FAB7E2EA34" originalValue="Hüllspelze" pageId="null" pageNumber="310">Huellspelze</normalizedToken>
1nervig, schmal
</emphasis>
(ca. 0,3 mm breit vom Kiel bis zum Rand), 
<emphasis id="BB10D500329EA16B7F3D10036F7AE092" italics="true" pageId="null" pageNumber="310">
obere 
<normalizedToken id="30E7AC11FA8FFD9AAE10C09909206496" originalValue="Hüllspelze" pageId="null" pageNumber="310">Huellspelze</normalizedToken>
5-7 mm lang; die 
<normalizedToken id="C209FCCD4AB5F86E5104497B0A28AE0A" originalValue="längsten" pageId="null" pageNumber="310">laengsten</normalizedToken>
Haare unterhalb der untersten Deckspelze etwa
</emphasis>
⅓ 
<emphasis id="AD7FFCA7A1E498F7C9802875D8B61F11" italics="true" pageId="null" pageNumber="310">so lang wie diese. -</emphasis>
<normalizedToken id="D899209BB88D0E718A0806691FB58E1C" originalValue="Blüte" pageId="null" pageNumber="310">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="D057CD484C76CB013412E6C123FD4FC2" pageId="null" pageNumber="310">
<emphasis id="A537701AFD67E33949FC0A436183D748" italics="true" pageId="null" pageNumber="310">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="C4B651BFE547E44A2533759508AF0CEA" italics="true" pageId="null" pageNumber="310">28:</emphasis>
Material von der Grigna (Favarger 1959).
</paragraph>
<paragraph id="3753942EAB61DF1A17D711E41D37893B" pageId="null" pageNumber="310">
<emphasis id="14DAF9074FD33AB08067EC7B090ABD2E" italics="true" pageId="null" pageNumber="310">Standort.</emphasis>
Wie 
<taxonomicName id="94373F03D157FCAC1D33304A6F34AE92" class="Liliopsida" family="Poaceae" genus="Trisetum" kingdom="Plantae" order="Poales" pageId="null" pageNumber="310" phylum="Tracheophyta" rank="species" species="distichophyllum">
<emphasis id="D7361FBA1CE39AB31CAF129AEBD05920" italics="true" pageId="null" pageNumber="310">T. distichophyllum</emphasis>
</taxonomicName>
(Nr. 5), zudem auf Felsgesimsen.
</paragraph>
<paragraph id="75D4390E6BE0140C3EE31278375DF45F" pageId="null" pageNumber="310">
<emphasis id="D81877E052EA06D9DB90988CD5195701" italics="true" pageId="null" pageNumber="310">
Verbreitung. 
<normalizedToken id="A08BEBF4485AB09EC7BF3B750D327075" originalValue="Südalpen-Pflanze" pageId="null" pageNumber="310">Suedalpen-Pflanze</normalizedToken>
:
</emphasis>
Durch die 
<normalizedToken id="C4CD472557064E0EE4DEAACF74F459D5" originalValue="südlichen" pageId="null" pageNumber="310">suedlichen</normalizedToken>
Kalkalpen von der Grigna 
<normalizedToken id="74E3AC4B070C1A4D9A9F897BB03DCF76" originalValue="ostwärts" pageId="null" pageNumber="310">ostwaerts</normalizedToken>
bis Krain. - Im Gebiet: Grigna, Bergamasker Alpen, Ortlergebiet (Cles), Gebiet von Meran (Lana); Angabe aus dem Tessin (Monte Generoso) unsicher.
</paragraph>
</subSubSection>
