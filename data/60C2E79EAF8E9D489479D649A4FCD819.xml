<subSubSection id="5F635EF1FF30C376E72B867ED9F32231" pageId="null" pageNumber="590" type="description">
<paragraph id="924966012F3A7EB48F8A830E397A90F6" pageId="null" pageNumber="590">
1 
<normalizedToken id="6CF701888328E07819FA17DBCE06E03B" originalValue="jährig" pageId="null" pageNumber="590">jaehrig</normalizedToken>
; 10-70 cm hoch; 
<emphasis id="C001DD42928C3E6A06A922B5FBDA739C" italics="true" pageId="null" pageNumber="590">dicht mit kleinen, gelblichen Sternhaaren bedeckt.</emphasis>
Stengel aufrecht, oft verzweigt. 
<normalizedToken id="46A049F70478E3323155751A380DC3D1" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
lanzettlich, ganzrandig bis 
<normalizedToken id="66B6CD920B8691DCA4E74368B8CE0527" originalValue="gezähnt" pageId="null" pageNumber="590">gezaehnt</normalizedToken>
, 
<normalizedToken id="B32DE4ECEB14B421D87F94383528890F" originalValue="allmählich" pageId="null" pageNumber="590">allmaehlich</normalizedToken>
in den kurzen Stiel 
<normalizedToken id="C2C053C4829A85FFDC92F4A046E7A258" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
oder mit 
<normalizedToken id="803A91F6C16AAD6185D2CC6DFA6573DB" originalValue="verschmälertem" pageId="null" pageNumber="590">verschmaelertem</normalizedToken>
Grunde sitzend. 
<normalizedToken id="D4A41EE1323C10C0D2E84B88F97179B6" originalValue="Blütenköpfe" pageId="null" pageNumber="590">Bluetenkoepfe</normalizedToken>
in einer kurzen Rispe, 
<normalizedToken id="6F07C68883576BEAA15E100C878FCD67" originalValue="vielblütig" pageId="null" pageNumber="590">vielbluetig</normalizedToken>
. 
<normalizedToken id="78B72DF70D43166C452752D637451D50" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
<normalizedToken id="38394ED7DF3BAB4FBDAC9E87D941107F" originalValue="glockenförmig" pageId="null" pageNumber="590">glockenfoermig</normalizedToken>
, ca. 10 mm lang; 
<normalizedToken id="0048E452C5E8C60E1250D340A76D57CC" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
<emphasis id="4B942DA71613D509D7C17F99175DFD95" italics="true" pageId="null" pageNumber="590">1reihig, im untern Teil verwachsen</emphasis>
, auf der Innenseite kahl. 
<emphasis id="912BD513C24B15D9FEA36593109D9DB8" italics="true" pageId="null" pageNumber="590">
Haare des 
<normalizedToken id="30AC3BF067B82C3DD34F588D7CC90F94" originalValue="Blütenbodens" pageId="null" pageNumber="590">Bluetenbodens</normalizedToken>
ca. 2 mm lang.
</emphasis>
<normalizedToken id="D0C4E72B8B99689285C87F72487EB420" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
gelb; 
<normalizedToken id="AD8149723821BF08A8186CB3F5870A79" originalValue="Kronröhre" pageId="null" pageNumber="590">Kronroehre</normalizedToken>
<normalizedToken id="9F82B2C084B8A502D0B26BBCCFD46564" originalValue="außen" pageId="null" pageNumber="590">aussen</normalizedToken>
im obern Teil behaart. 
<normalizedToken id="1817BF245AC58656F590D9F4B0229CAB" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
ca. 1 mm lang, schwarz, mit 10 
<normalizedToken id="E9CD38EEF596486524305F8BF86B5D54" originalValue="weißen" pageId="null" pageNumber="590">weissen</normalizedToken>
<normalizedToken id="78000490310B5D31F1A262871F6B4C19" originalValue="Längsrippen" pageId="null" pageNumber="590">Laengsrippen</normalizedToken>
. - 
<normalizedToken id="D36C56F4B8033CE85D3A1CE6B1E88595" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="5CD9290988D0B8A0E7B954CE298B281F" pageId="null" pageNumber="590">
<emphasis id="C25A95BF131D7D204FE7D4085A617B40" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="8EB991CC68044901BCF46257816BF92D" italics="true" pageId="null" pageNumber="590">18:</emphasis>
Material aus botanischem Garten (Stebbins et al. 1953a), von Spanien (
<normalizedToken id="0E0F36DA9259CD881E2434572FCDF6CF" originalValue="Björkqvist" pageId="null" pageNumber="590">Bjoerkqvist</normalizedToken>
et al. 1969).
</paragraph>
<paragraph id="FD99AE053252EDEE2E9177006771E72C" pageId="null" pageNumber="590">
<emphasis id="58479FC6E517150CDB12DDF83F4C3F45" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Kollin. Sandig-kiesige 
<normalizedToken id="94ACF1B3D5E6A59EBF89E1404E88CFB4" originalValue="Schuttplätze" pageId="null" pageNumber="590">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="D42E84AF13D11D881026A507EF3E01A6" pageId="null" pageNumber="590">
<emphasis id="D6AD9874EC4360D48A675C8F228CC4FA" italics="true" pageId="null" pageNumber="590">Verbreitung. Westmediterrane Pflanze:</emphasis>
Iberische Halbinsel, 
<normalizedToken id="0109738F97D8C559F8EB577B813125A2" originalValue="Südfrankreich" pageId="null" pageNumber="590">Suedfrankreich</normalizedToken>
, Italien. - Im Gebiet: 
<normalizedToken id="6821F137FC2AE4466C49CEFB2CFA6E87" originalValue="Dép" pageId="null" pageNumber="590">Dep</normalizedToken>
. Ain (
<normalizedToken id="9D53A0A722A9EAEB8A8EF6A228A17896" originalValue="Côtière" pageId="null" pageNumber="590">Cotiere</normalizedToken>
, Dombes); sonst selten adventiv.
</paragraph>
</subSubSection>
