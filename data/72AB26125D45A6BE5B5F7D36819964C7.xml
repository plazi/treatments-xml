<subSubSection id="CDC64F78FDF70FB5379897382B734B4C" pageId="null" pageNumber="592" type="description">
<paragraph id="92A176B1D1F68B4E5A1A7B0784C2B3E5" pageId="null" pageNumber="592">
<normalizedToken id="B7BC0D084E3D5E83A444EEC0CAF8D624" originalValue="Teilblätter" pageId="null" pageNumber="592">Teilblaetter</normalizedToken>
der obern 
<normalizedToken id="D48C18AB94B017D706769A2E8C9EB208" originalValue="Blätter" pageId="null" pageNumber="592">Blaetter</normalizedToken>
am Grunde 
<normalizedToken id="8387F9C797068E3E92E529C2E8A37E52" originalValue="allmählich" pageId="null" pageNumber="592">allmaehlich</normalizedToken>
<normalizedToken id="B44519074E7E94AEE8B4329C9B64A662" originalValue="keilförmig" pageId="null" pageNumber="592">keilfoermig</normalizedToken>
<normalizedToken id="C84B64213875E27963C60A2C61E7BC1C" originalValue="verschmälert" pageId="null" pageNumber="592">verschmaelert</normalizedToken>
, 
<emphasis id="E25A131EDAC5D0FECDB2D4306BD95362" italics="true" pageId="null" pageNumber="592">3-5mal so lang wie breit;</emphasis>
Kelch 14-18 mm lang, 
<normalizedToken id="236A2330B83E6B4793C6E0124E341CF4" originalValue="½" pageId="null" pageNumber="592">1/2</normalizedToken>
-⅓ so lang wie die Fahne; 
<emphasis id="0BCBEE452A9F708D750CCCE3899FBED2" italics="true" pageId="null" pageNumber="592">
<normalizedToken id="DA0348AF0CD456EB329FD17D40E9D866" originalValue="Kelchzähne" pageId="null" pageNumber="592">Kelchzaehne</normalizedToken>
deutlich 
<normalizedToken id="8C62988DFD710F860BE2F4872D31590F" originalValue="kürzer" pageId="null" pageNumber="592">kuerzer</normalizedToken>
als die 
<normalizedToken id="1D696CCB46A34A0BB75EF660369ECFD9" originalValue="Kelchröhre" pageId="null" pageNumber="592">Kelchroehre</normalizedToken>
.
</emphasis>
Krone 2,5-3 cm lang, verschiedenfarbig, 
<normalizedToken id="AE7F33E92610395018492D3059BAA383" originalValue="schräg" pageId="null" pageNumber="592">schraeg</normalizedToken>
nach oben gebogen; Fahne violett bis 
<normalizedToken id="9789D4DB44646763281599ABAAC83209" originalValue="grün" pageId="null" pageNumber="592">gruen</normalizedToken>
<normalizedToken id="BD6216B5A97DFB666A73093A59BEAF68" originalValue="überlaufen" pageId="null" pageNumber="592">ueberlaufen</normalizedToken>
, im 
<normalizedToken id="244EF5F95F80EFFEC9B9309092A73B4C" originalValue="übrigen" pageId="null" pageNumber="592">uebrigen</normalizedToken>
wie die 
<normalizedToken id="6EDE40A844361D30E88C47FBF7980DCF" originalValue="Flügel" pageId="null" pageNumber="592">Fluegel</normalizedToken>
und das Schiffchen gelb. Frucht 3,5-5 cm lang, 0,6-0,8 cm breit, kahl (jung kurz behaart). Samen 10-15 je Frucht, 3-3,5 mm lang. - 
<normalizedToken id="DCEA14843D8DA4F6CD3DD8DB3A8DCB98" originalValue="Blüte" pageId="null" pageNumber="592">Bluete</normalizedToken>
: 
<normalizedToken id="6986251E231845E74A4B1A150EC609E2" originalValue="Später" pageId="null" pageNumber="592">Spaeter</normalizedToken>
<normalizedToken id="DA24018433DC53B5AEDA6F7A427DCB4D" originalValue="Frühling" pageId="null" pageNumber="592">Fruehling</normalizedToken>
und 
<normalizedToken id="EC4BEBD3DCDB997119345E6953144676" originalValue="früher" pageId="null" pageNumber="592">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="528936EAEA1835B93C8B9025371497C4" pageId="null" pageNumber="592">
<emphasis id="DC9088F9F91795538A9448B26A9117DA" italics="true" pageId="null" pageNumber="592">
<pageBreakToken id="F99FD3C428FD0CDF78C30F2783D2F0A2" pageId="null" pageNumber="592">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="BFB14DB891EA3692082B22C6B75B32EA" italics="true" pageId="null" pageNumber="592">14:</emphasis>
Material aus der Slowakei (
<normalizedToken id="C50539460223252FCE54BE54BBAB1EEF" originalValue="Činčura" pageId="null" pageNumber="592">Cincura</normalizedToken>
1963). Die nahe verwandte 
<taxonomicName id="6500D20ADD29B1AB7C8C19756E458A6B" class="Magnoliopsida" family="Fabaceae" genus="Vicia" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="592" phylum="Tracheophyta" rank="species" sensu="stricto" species="grandiflora">
<emphasis id="7C8549BFBDD9A5324A828E1574F54EEE" italics="true" pageId="null" pageNumber="592">V. grandiflora</emphasis>
</taxonomicName>
<taxonomicNameLabel id="45325905AA284581B8314610D74673A3" pageId="null" pageNumber="592" sensu="stricto">s. str.</taxonomicNameLabel>
besitzt ebenfalls 2n = 14 (verschiedene 
<normalizedToken id="BA258A723C1CD5C0D25D5BA935A855BE" originalValue="Zählungen" pageId="null" pageNumber="592">Zaehlungen</normalizedToken>
, zusammengestellt von 
<normalizedToken id="DC4310822117F25684456592D4C56B3E" originalValue="Löve" pageId="null" pageNumber="592">Loeve</normalizedToken>
und 
<normalizedToken id="3F1AA94DB5964A618838FD792CED5BBD" originalValue="Löve" pageId="null" pageNumber="592">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="82CECD2950EF1DCA3821EE700EB31371" pageId="null" pageNumber="592">
<emphasis id="C2C2278C09BD1326D6655E9EB70824AB" italics="true" pageId="null" pageNumber="592">Standort.</emphasis>
Kollin, seltener montan. Trockene, 
<normalizedToken id="8BD823E458FA6CD4E67A760C5E804460" originalValue="nährstoffreiche" pageId="null" pageNumber="592">naehrstoffreiche</normalizedToken>
<normalizedToken id="A0852A370700610CD421BA82E891EE98" originalValue="Böden" pageId="null" pageNumber="592">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="AC0F01B43AE75CCC774396C558DE47CE" originalValue="Waldränder" pageId="null" pageNumber="592">Waldraender</normalizedToken>
, 
<normalizedToken id="09B1B1915A0545E2F9AE49A79E032094" originalValue="Gebüsche" pageId="null" pageNumber="592">Gebuesche</normalizedToken>
, Getreidefelder, 
<normalizedToken id="EF7E22E8A278646F434EC7B91258990E" originalValue="Schuttplätze" pageId="null" pageNumber="592">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="A043B85C110678B158A6F098CCA2421B" pageId="null" pageNumber="592">
<emphasis id="C2B30ABD2FC1A5EA068ED71E7BC0C232" italics="true" pageId="null" pageNumber="592">Verbreitung. Ostmediterrane Pflanze:</emphasis>
Nord- und 
<normalizedToken id="9FACFC09E03247ADCD85C1F311ADF452" originalValue="westwärts" pageId="null" pageNumber="592">westwaerts</normalizedToken>
bis Ukraine, 
<normalizedToken id="D45C5C5D10FB7AEE3E20F844F3722F8B" originalValue="Mähren" pageId="null" pageNumber="592">Maehren</normalizedToken>
, Ostalpen, Oberitalien; Kaukasus, Persien, Kleinasien. - Im Gebiet: Vintschgau (Meran), 
<normalizedToken id="F8876ECF943220A1DF5F64A1BCE9E5FE" originalValue="südliche" pageId="null" pageNumber="592">suedliche</normalizedToken>
Bergamasker Alpen; gelegentlich auch angebaut und verwildert.
</paragraph>
</subSubSection>
