<subSubSection id="90F024F1719D23863837BD4D6A6F375F" pageId="null" pageNumber="678" type="vernacular_names">
<paragraph id="F1275E0CA989B1C7DC801F9880E54015" pageId="null" pageNumber="678">Terpentin-Pistazie</paragraph>
</subSubSection>
</title>
<subSubSection id="CAE5A46FCDE7EA8F7312C01EF5A74706" pageId="null" pageNumber="678" type="description">
<paragraph id="2022717F2E426451294707B113B60D52" pageId="null" pageNumber="678">
<normalizedToken id="643CFD072F36ACE8C9F62798D9656C21" originalValue="Sommergrün" pageId="null" pageNumber="678">Sommergruen</normalizedToken>
, bis 8 m hoch. 
<normalizedToken id="9C30FEFDB79C6E1BE21BEFD193E0A8B7" originalValue="Blätter" pageId="null" pageNumber="678">Blaetter</normalizedToken>
gefiedert (mit Endteilblatt), 
<emphasis id="1E09BA51DB476397B400402220DFFF74" italics="true" pageId="null" pageNumber="678">
mit 5-13 
<normalizedToken id="D5E7A80068D2335A9BEB7B5B199653D1" originalValue="Teilblättern" pageId="null" pageNumber="678">Teilblaettern</normalizedToken>
;
</emphasis>
<normalizedToken id="9A4A1BB37525A5B120A84A28B332E3A1" originalValue="Teilblätter" pageId="null" pageNumber="678">Teilblaetter</normalizedToken>
lanzettlich, 3-6 cm lang, 2- 
<normalizedToken id="E49145A9DCC06E4A2967695B929B943E" originalValue="2½" pageId="null" pageNumber="678">21/2</normalizedToken>
mal so lang wie breit, oberseits 
<normalizedToken id="35D207B2F7F0B406B9C5358B2A2AF05E" originalValue="glänzend" pageId="null" pageNumber="678">glaenzend</normalizedToken>
, 
<emphasis id="8B732D6D6C86C97D2401246B799935AB" italics="true" pageId="null" pageNumber="678">ganzrandig</emphasis>
, am Grunde breit abgerundet, sitzend oder mit bis 2 mm langem Stiel. 
<normalizedToken id="8A37BA2B1CA61460D8B5623D3163E177" originalValue="Blütenstände" pageId="null" pageNumber="678">Bluetenstaende</normalizedToken>
bis 15 cm lang. 
<emphasis id="71982915AFC9F639DA8A583F4C480410" italics="true" pageId="null" pageNumber="678">
Frucht 
<normalizedToken id="7CB1AE701811A53363C1F6FB2ABD428F" originalValue="eiförmig" pageId="null" pageNumber="678">eifoermig</normalizedToken>
, bis 8 mm lang, rot, zur Reifezeit braun.
</emphasis>
- 
<normalizedToken id="1104C334C37F47D17A943DD01D6CD737" originalValue="Blüte" pageId="null" pageNumber="678">Bluete</normalizedToken>
: 
<normalizedToken id="FEE78642DDB852E108B69F2A151F10A8" originalValue="Später" pageId="null" pageNumber="678">Spaeter</normalizedToken>
<normalizedToken id="2260C8F024551D0189838F2FDFA5C887" originalValue="Frühling" pageId="null" pageNumber="678">Fruehling</normalizedToken>
und 
<normalizedToken id="E6B8EEB854F7D77989AAC0E2F2970A6A" originalValue="früher" pageId="null" pageNumber="678">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="8A1A223D29A5A057024F53FF4613AC0D" pageId="null" pageNumber="678">
<emphasis id="81F3C4032D172DFE11007C112AC4E837" italics="true" pageId="null" pageNumber="678">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="0BF861746E03A899ACFBF78857D325CD" pageId="null" pageNumber="678">
<emphasis id="CB02F51F3D8BA22DC19503C8A69CF4F8" italics="true" pageId="null" pageNumber="678">Standort.</emphasis>
Kollin. Meist kalkhaltige, trockene, steinige 
<normalizedToken id="4A20AB4FB25EC22D84C6597C1344F459" originalValue="Böden" pageId="null" pageNumber="678">Boeden</normalizedToken>
in 
<normalizedToken id="6391E85A9F36A5D0F82B22ABA281C0B7" originalValue="heißen" pageId="null" pageNumber="678">heissen</normalizedToken>
Lagen. Buschwald.
</paragraph>
<paragraph id="D491D84C08B2AA8F4207CA52BE3249A6" pageId="null" pageNumber="678">
<emphasis id="BA1C61CDEBC9D48BF301FB8573ABE5FB" italics="true" pageId="null" pageNumber="678">Verbreitung. Mediterrane Pflanze:</emphasis>
Ganzes Mittelmeergebiet und Kleinasien; 
<normalizedToken id="4E16F06F534EC6BE5CC32455BFC04B2C" originalValue="nordwärts" pageId="null" pageNumber="678">nordwaerts</normalizedToken>
bis Dordogne, 
<normalizedToken id="FF7F2CB15038CF34D4A15703BDEC1AE0" originalValue="südlicher" pageId="null" pageNumber="678">suedlicher</normalizedToken>
Jura (
<normalizedToken id="EBA5627065B65DB91CF67244213B1245" originalValue="Dép" pageId="null" pageNumber="678">Dep</normalizedToken>
. Ain), 
<normalizedToken id="D16F08995F3CD7AC36E30F8BD6BC0702" originalValue="Alpensüdfuß" pageId="null" pageNumber="678">Alpensuedfuss</normalizedToken>
, 
<normalizedToken id="D33B9742540B9FF58D8ED4AA12ADC5D1" originalValue="Südtirol" pageId="null" pageNumber="678">Suedtirol</normalizedToken>
(Bozen), Jugoslawien (Velebit), Mazedonien (Strymontal). - Im Gebiet: 
<normalizedToken id="BEEE9B93D0ED563BC3236C4052A3971C" originalValue="Dép" pageId="null" pageNumber="678">Dep</normalizedToken>
. Ain, Savoyen (Jura, selten bis in die Voralpen), 
<normalizedToken id="1F23C30BBE15C4E3671C96C61058A620" originalValue="Alpensüdfuß" pageId="null" pageNumber="678">Alpensuedfuss</normalizedToken>
(mehrere Angaben von Rodegher und Venanzi 1894 aus dem Gebiet von Bergamo); in milden Lagen gelegentlich Zierstrauch.
</paragraph>
</subSubSection>
