<subSubSection id="0A222F09D46B2DD419C2FB76594B3B9F" pageId="null" pageNumber="760" type="description">
<paragraph id="76772122E5D5D1C5A1644D9C6F8623B1" pageId="null" pageNumber="760">
Unterscheidet sich von 
<taxonomicName id="385354AEC5BDE7258BEE7250715B2A03" class="Magnoliopsida" family="Lythraceae" genus="Lythrum" kingdom="Plantae" order="Myrtales" pageId="null" pageNumber="760" phylum="Tracheophyta" rank="species" species="portula">
<emphasis id="1D478265440D56F77B1355265458A539" italics="true" pageId="null" pageNumber="760">P. Portula</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: Stengel meist nicht 
<normalizedToken id="3EEA4091333DE9662374D8DA93C9A44B" originalValue="über" pageId="null" pageNumber="760">ueber</normalizedToken>
10 cm lang; 
<emphasis id="F175ED77920F039261DB8469066618BF" italics="true" pageId="null" pageNumber="760">
<normalizedToken id="D24934227169E0797E597404B5735F36" originalValue="Blätter" pageId="null" pageNumber="760">Blaetter</normalizedToken>
<normalizedToken id="C638EE1001486D5F41E598A395F223C0" originalValue="wechselständig" pageId="null" pageNumber="760">wechselstaendig</normalizedToken>
, bis 1 cm lang, 4-8mal so lang wie breit; Achsenbecher 
<normalizedToken id="0AB716C4D4FCCE6FCA2B2732BDAAFFE5" originalValue="kürzer" pageId="null" pageNumber="760">kuerzer</normalizedToken>
als die 
<normalizedToken id="F87E80437C2BB48AF6B176A04F385867" originalValue="Kelchzähne" pageId="null" pageNumber="760">Kelchzaehne</normalizedToken>
; 
<normalizedToken id="B91CF9F8035D196FE1877250E16FF10D" originalValue="Staubblätter" pageId="null" pageNumber="760">Staubblaetter</normalizedToken>
2.
</emphasis>
- 
<normalizedToken id="FC84A583CBFEABB1151534B497AD6510" originalValue="Blüte" pageId="null" pageNumber="760">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="AEB647757119302D17D4540379FA32F7" pageId="null" pageNumber="760">
<emphasis id="C8E47C021B4562F575F1E965DD0F52FB" italics="true" pageId="null" pageNumber="760">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="9CC9DA1ABB766DDAA8326100D3995F39" pageId="null" pageNumber="760">
<emphasis id="641A398121BDDF121698AFB6B3562D52" italics="true" pageId="null" pageNumber="760">Standort.</emphasis>
Wie 
<taxonomicName id="713582CFCA1A26A2FC9AA18EB1E5593E" class="Magnoliopsida" family="Lythraceae" genus="Lythrum" kingdom="Plantae" order="Myrtales" pageId="null" pageNumber="760" phylum="Tracheophyta" rank="species" species="portula">
<emphasis id="197DAA7986EF057F23EC92127E68A96D" italics="true" pageId="null" pageNumber="760">P. Portula</emphasis>
</taxonomicName>
(Nr. 1), verlangt jedoch 
<normalizedToken id="550CBA3EE5C305A74237061E86476487" originalValue="höhere" pageId="null" pageNumber="760">hoehere</normalizedToken>
Sommertemperaturen.
</paragraph>
<paragraph id="1AA516AA484F0688452F4CE144B3A958" pageId="null" pageNumber="760">
<emphasis id="B213807A31152584FFED841795D199BB" italics="true" pageId="null" pageNumber="760">
Verbreitung. 
<normalizedToken id="9252AC172FF6CE737B8419BC878AB1A1" originalValue="Osteuropäisch-zentralasiatische" pageId="null" pageNumber="760">Osteuropaeisch-zentralasiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="E441AB84307E8C52A41D2BB78B73F372" originalValue="Westwärts" pageId="null" pageNumber="760">Westwaerts</normalizedToken>
bis 
<normalizedToken id="6DB7D158A8EE46A92B2EF4473E61AB6C" originalValue="Mittelrußland" pageId="null" pageNumber="760">Mittelrussland</normalizedToken>
, Ukraine, Bulgarien und Kleinasien; nach 
<normalizedToken id="7C2725B74E2AF4323E8FC82533776BC9" originalValue="Südfrankreich" pageId="null" pageNumber="760">Suedfrankreich</normalizedToken>
verschleppt. - Im Gebiet: 
<normalizedToken id="6147005B7E146FE1237409B251DB8BC1" originalValue="Dép" pageId="null" pageNumber="760">Dep</normalizedToken>
. Ain (
<normalizedToken id="3754DD19870C0959DBA0DA9D5D5CE3B7" originalValue="Glück" pageId="null" pageNumber="760">Glueck</normalizedToken>
1936).
</paragraph>
</subSubSection>
