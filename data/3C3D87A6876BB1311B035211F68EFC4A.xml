<emphasis id="86E0EAA2876BB1311B0350C6FE7EF908" bold="true" box="[90,490,1748,1781]" pageId="36" pageNumber="929">Subspecies and Distribution.</emphasis>
</paragraph>
<paragraph id="B42B36B0876BB1311B0350E9FD2CF8B9" blockId="36.[90,1300,1629,3475]" pageId="36" pageNumber="929">
<taxonomicName id="73944D33876BB1311B0350E9FE2EF8E1" authority="Gambel, 1848" authorityName="Gambel" authorityYear="1848" box="[90,442,1787,1820]" class="Mammalia" family="Heteromyidae" genus="Dipodomys" kingdom="Animalia" order="Rodentia" pageId="36" pageNumber="929" phylum="Chordata" rank="subSpecies" species="agilis" subSpecies="agilis">D.a.agilisGambel,1848—SWUSA(LosAngelesBasinandfoothillsofSanGabrielandSanBernardinoMtsofSWCalifornia).</taxonomicName>
</paragraph>
