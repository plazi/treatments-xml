<subSubSection id="A37A4551AA044E1DBC7EF74E3B36DACE" pageId="null" pageNumber="679" type="description">
<paragraph id="1CC00FCD62E338B2B867F702D7E9C1B9" pageId="null" pageNumber="679">
Bis 25 m hoch; wird selten 
<normalizedToken id="471A6BECD65F4184447B19E179C21F55" originalValue="über" pageId="null" pageNumber="679">ueber</normalizedToken>
150 Jahre alt; Krone bei freistehenden 
<normalizedToken id="E0B1FB00AF059D711EAB29D8AAA4D302" originalValue="Bäumen" pageId="null" pageNumber="679">Baeumen</normalizedToken>
kugelig. Rinde hell bis dunkelgrau, mit 
<normalizedToken id="9596BBC09B83065C55E33E842E480495" originalValue="längsrissiger" pageId="null" pageNumber="679">laengsrissiger</normalizedToken>
Borke. 
<normalizedToken id="0B39B975AAC86571CB3E3959E816BF85" originalValue="Blätter" pageId="null" pageNumber="679">Blaetter</normalizedToken>
mit 2-5 Paaren von 
<normalizedToken id="F8463B5CB80454B70E29E2098AB1E30E" originalValue="seitenständigen" pageId="null" pageNumber="679">seitenstaendigen</normalizedToken>
<normalizedToken id="21D60BE7028DFD3BD109D2F6B2D791C5" originalValue="Teilblättern" pageId="null" pageNumber="679">Teilblaettern</normalizedToken>
, die 
<taxonomicName id="8A1501B6D2D253AD9B1FDBA1E86F4B88" authority="den Blattstiel" authorityName="den Blattstiel" class="Magnoliopsida" family="Salicaceae" genus="Mittelnerv" kingdom="Plantae" order="Malpighiales" pageId="null" pageNumber="679" phylum="Tracheophyta" rank="species" species="gegen">gegen den Blattstiel</taxonomicName>
hin auffallend kleiner werden; Endteilblatt kleiner bis 
<normalizedToken id="B7D28E753ADF79466BC67D6BC1D0A4D0" originalValue="größer" pageId="null" pageNumber="679">groesser</normalizedToken>
als die obersten, 
<normalizedToken id="C191B9FB96321331BA44AD170EBC1EAE" originalValue="seitenständigen" pageId="null" pageNumber="679">seitenstaendigen</normalizedToken>
<normalizedToken id="B2259A4769CBBEF39CC711E4817EFB20" originalValue="Teilblätter" pageId="null" pageNumber="679">Teilblaetter</normalizedToken>
; alle 
<normalizedToken id="EFE00B4DAAC2666CE848912BC62D096F" originalValue="Teilblätter" pageId="null" pageNumber="679">Teilblaetter</normalizedToken>
oval, oft mit aufgesetzter Spitze, bis 15 cm lang, meist ca. 2mal so lang wie breit, ganzrandig (bei bis 6 Jahre alten Pflanzen 
<normalizedToken id="8AD0239E3ED01A85CA7213D359134EC2" originalValue="gezähnt" pageId="null" pageNumber="679">gezaehnt</normalizedToken>
), unterseits zwischen Haupt- und Seitennerven (nur im spitzen Winkel) mit 
<normalizedToken id="B9B9A564BF904797B5C01914B69B1F28" originalValue="Haarbüscheln" pageId="null" pageNumber="679">Haarbuescheln</normalizedToken>
, sonst kahl; Blattstiel bis 20 cm lang, am Grunde verdickt. 
<normalizedToken id="58A4754326658B227772D858B066B3B8" originalValue="Blüte" pageId="null" pageNumber="679">Bluete</normalizedToken>
beginnt im Alter von 20-25 Jahren. ♂ 
<emphasis id="EF44F30E0C4C2E62F6126A22CC588A8C" italics="true" pageId="null" pageNumber="679">
<normalizedToken id="A084EA61960E4DD6669CAE5F93B8E5AF" originalValue="Blütenstände" pageId="null" pageNumber="679">Bluetenstaende</normalizedToken>
</emphasis>
in den Achseln der 
<normalizedToken id="67F7B398FA8901D3BD926C85A1C58E54" originalValue="vorjährigen" pageId="null" pageNumber="679">vorjaehrigen</normalizedToken>
, abgefallenen 
<normalizedToken id="351607B6CE0C709CC0857856124C99E5" originalValue="Blätter" pageId="null" pageNumber="679">Blaetter</normalizedToken>
, 
<normalizedToken id="C761FC19E30E8EB663D77C3EAA2E4EB1" originalValue="hängend" pageId="null" pageNumber="679">haengend</normalizedToken>
, meist nicht 
<normalizedToken id="A9EE95369D9876660FD1688FB4D46E66" originalValue="über" pageId="null" pageNumber="679">ueber</normalizedToken>
10cm lang; die 4 
<normalizedToken id="4FEC619F0C47AB87FF3E6D2A1B081C84" originalValue="Perigonblätter" pageId="null" pageNumber="679">Perigonblaetter</normalizedToken>
mit 2 
<normalizedToken id="1F26990DF6B955312931D13DA8B34F81" originalValue="Vorblättern" pageId="null" pageNumber="679">Vorblaettern</normalizedToken>
zu einer 6teiligen 
<normalizedToken id="28924D4456BE72E20EA6F337D0743B54" originalValue="Blütenhülle" pageId="null" pageNumber="679">Bluetenhuelle</normalizedToken>
verwachsen; 
<normalizedToken id="6A6E54FD5EAD5715541B391C7D0F6C84" originalValue="Staubblätter" pageId="null" pageNumber="679">Staubblaetter</normalizedToken>
6-30. ♀ 
<emphasis id="BA86BB2644AE3D7F465FBFC0AA255B12" italics="true" pageId="null" pageNumber="679">
<normalizedToken id="E291A72F87E2A760492C25BC8EBE14C0" originalValue="Blütenstände" pageId="null" pageNumber="679">Bluetenstaende</normalizedToken>
</emphasis>
1-5 
<normalizedToken id="0BD3E53E49AA44A3B549E5031D8E3E9A" originalValue="blütig" pageId="null" pageNumber="679">bluetig</normalizedToken>
, 
<normalizedToken id="526A6F5DA28894ADDB4A4C717FFE15C8" originalValue="endständig" pageId="null" pageNumber="679">endstaendig</normalizedToken>
an den 
<normalizedToken id="3BED9B248F541624B72F50C6FA6947F8" originalValue="vorjährigen" pageId="null" pageNumber="679">vorjaehrigen</normalizedToken>
Trieben; 
<normalizedToken id="D852D95F30B6D10960721ADF590B73FE" originalValue="Vorblätter" pageId="null" pageNumber="679">Vorblaetter</normalizedToken>
und Perigon mit dem Fruchtknoten verwachsen; Narben 2, breit, lappig und kraus. 
<normalizedToken id="873447AE9C2E42E9694E6F199E97E372" originalValue="Grüne" pageId="null" pageNumber="679">Gruene</normalizedToken>
, fleischige Schale sich durch 
<normalizedToken id="B6FBAE296B1C39102F3EC8362E7E9660" originalValue="Längsrisse" pageId="null" pageNumber="679">Laengsrisse</normalizedToken>
<normalizedToken id="766FE57C897BF0EE9614463C16470A5B" originalValue="öffnend" pageId="null" pageNumber="679">oeffnend</normalizedToken>
und 
<normalizedToken id="5CC80C1A8358EB1DC61A600A6A8C3E93" originalValue="unregelmäßig" pageId="null" pageNumber="679">unregelmaessig</normalizedToken>
<normalizedToken id="1F3A635DB53339CE4D149CB1E57F56A1" originalValue="ablösend" pageId="null" pageNumber="679">abloesend</normalizedToken>
; Fruchtwand (
<normalizedToken id="269227C150CCB76E713377CE160DE63F" originalValue="Nußschale" pageId="null" pageNumber="679">Nussschale</normalizedToken>
) braun, aus 2 wulstig verwachsenen 
<normalizedToken id="9A6639A01D0E7ED39C2AFA6577F16024" originalValue="Hälften" pageId="null" pageNumber="679">Haelften</normalizedToken>
bestehend; die beiden 
<normalizedToken id="A2E3F5FB351A325684167FFDBE625AA2" originalValue="Keimblätter" pageId="null" pageNumber="679">Keimblaetter</normalizedToken>
in der 
<normalizedToken id="154E314CCFA31B851ED7960A74245CD4" originalValue="unvollständig" pageId="null" pageNumber="679">unvollstaendig</normalizedToken>
2- oder 4 
<normalizedToken id="5AA8E0764525F1727C07E1D9D525AF6F" originalValue="fächerigen" pageId="null" pageNumber="679">faecherigen</normalizedToken>
Frucht 
<normalizedToken id="23239E3020981FBE58CB7F8B6EF53C8B" originalValue="groß" pageId="null" pageNumber="679">gross</normalizedToken>
, von der gelben Samenschale 
<normalizedToken id="644FE59E03B2BCDFA0055AD9A6B7E1EE" originalValue="überzogen" pageId="null" pageNumber="679">ueberzogen</normalizedToken>
. - 
<normalizedToken id="33268CE38CE7FA4A10B198AABC69B9B4" originalValue="Blüte" pageId="null" pageNumber="679">Bluete</normalizedToken>
: 
<normalizedToken id="4664C4E73A97BD78F38946B64496C561" originalValue="Später" pageId="null" pageNumber="679">Spaeter</normalizedToken>
<normalizedToken id="50DAA59F7C3C3CFD201A2CC05AD317AF" originalValue="Frühling" pageId="null" pageNumber="679">Fruehling</normalizedToken>
; Fruchtreife: 
<normalizedToken id="EE991881BF7BF11190F6C91D009611AC" originalValue="Spätherbst" pageId="null" pageNumber="679">Spaetherbst</normalizedToken>
.
</paragraph>
<paragraph id="932DC5084C5FE3596DAF389F355287FB" pageId="null" pageNumber="679">
<emphasis id="C2477D6831326DBFC0BE080655E0AD42" italics="true" pageId="null" pageNumber="679">Zytologische Angaben. 2n = 32:</emphasis>
Material aus dem Arnold-Arboretum (USA); Meiose normal (Woodworth 1930).
</paragraph>
<paragraph id="DF8A8BD153B6C4B2068DB39E3A9B6F25" pageId="null" pageNumber="679">
<emphasis id="0D5E2AE5FAA83D1D6239E7AC5CCA8B53" italics="true" pageId="null" pageNumber="679">Standort.</emphasis>
Kollin und montan. Kalkhaltige, 
<normalizedToken id="E5F06648C7DD1ADB8BD56AC10520027D" originalValue="nährstoffreiche" pageId="null" pageNumber="679">naehrstoffreiche</normalizedToken>
, frische bis sickernasse, lockere, humose bis sandige oder steinige 
<normalizedToken id="54D39A63285FD8987B30F92D2689B747" originalValue="Böden" pageId="null" pageNumber="679">Boeden</normalizedToken>
. 
<normalizedToken id="7AE9CCC3B54F464C69763F0D1184F78A" originalValue="Laubmischwälder" pageId="null" pageNumber="679">Laubmischwaelder</normalizedToken>
in den mildesten Lagen (
<normalizedToken id="517420B4DD848FC103228CCB9DB0666F" originalValue="Föhngebiete" pageId="null" pageNumber="679">Foehngebiete</normalizedToken>
); 
<normalizedToken id="B488BDF6752138DC8B26D7F8C0683E44" originalValue="erträgt" pageId="null" pageNumber="679">ertraegt</normalizedToken>
keine 
<normalizedToken id="983B99B67597619B3F3418D4C8812907" originalValue="Spätfröste" pageId="null" pageNumber="679">Spaetfroeste</normalizedToken>
und braucht warme Sommer. In vielen Sorten um 
<normalizedToken id="6F4BB4274DD82FF184901B03A087FF15" originalValue="Häuser" pageId="null" pageNumber="679">Haeuser</normalizedToken>
und auch auf Wiesen angepflanzt; in den 
<normalizedToken id="3511875C9FA711FA43DA66288A199373" originalValue="Wäldern" pageId="null" pageNumber="679">Waeldern</normalizedToken>
nur verwildert.
</paragraph>
<paragraph id="2000964D2C4DA73B61B5F977BE2D559A" pageId="null" pageNumber="679">
<emphasis id="BD06451B002183D77135336C3F6FF8C7" italics="true" pageId="null" pageNumber="679">
Verbreitung. 
<normalizedToken id="178F660AA1A6ACF394856544F4FA812B" originalValue="Ursprünglich" pageId="null" pageNumber="679">Urspruenglich</normalizedToken>
<normalizedToken id="9CFA30BA2634A1B6FF233FD9D51F0F8C" originalValue="Südwestasien" pageId="null" pageNumber="679">Suedwestasien</normalizedToken>
</emphasis>
(Persien, Armenien, Transkaukasien) und 
<normalizedToken id="9DC3AB949366009BB4A77E0480FE8422" originalValue="östliches" pageId="null" pageNumber="679">oestliches</normalizedToken>
Mittelmeergebiet (
<normalizedToken id="A9BDE987E1CA5D05EE00EEB0331699CF" originalValue="Schwarzmeerküsten" pageId="null" pageNumber="679">Schwarzmeerkuesten</normalizedToken>
, Griechenland), heute im 
<normalizedToken id="8806E0754A8BA544067B47274C286AEF" originalValue="gemäßigten" pageId="null" pageNumber="679">gemaessigten</normalizedToken>
<taxonomicName id="36A606F347118D86F124F45C1B026970" authority="Nordafrika und Asien" authorityName="Nordafrika und Asien" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="679" phylum="Arthropoda" rank="genus">Europa, Nordafrika und Asien</taxonomicName>
(bis Japan) verbreitet. - Im Gebiet verbreitet; durch Pollenanalyse erst seit der 
<normalizedToken id="31065A3ECEC9D058FE467839B50AB3E5" originalValue="Römerzeit" pageId="null" pageNumber="679">Roemerzeit</normalizedToken>
nachgewiesen (Zoller 1960).
</paragraph>
<paragraph id="3795E78BEC9FB9B9280BBE26D6A859B9" pageId="null" pageNumber="679">
<emphasis id="F660760EBACF5DE6349D3857CBEC90D4" italics="true" pageId="null" pageNumber="679">Bemerkungen.</emphasis>
Der 
<normalizedToken id="3371795C3121114EBB36859E52FF1734" originalValue="Nußbaum" pageId="null" pageNumber="679">Nussbaum</normalizedToken>
liefert das wertvollste Holz unter unsern Baumarten. 
<normalizedToken id="A12E060CF6A833758100D5C2433EFB63" originalValue="Größere" pageId="null" pageNumber="679">Groessere</normalizedToken>
Bedeutung hat bei uns der 
<normalizedToken id="0C181CB795A72297B1C1409F8525CEC8" originalValue="Nußbaum" pageId="null" pageNumber="679">Nussbaum</normalizedToken>
als Fruchtbaum: beste 
<normalizedToken id="5E9541B9052C3A5B2FA5CA95904DD530" originalValue="Erträge" pageId="null" pageNumber="679">Ertraege</normalizedToken>
(im Alter von 50-100 Jahren) 100-150 kg 
<normalizedToken id="E0BE025A797E13FD94A9DEFA362B1D1B" originalValue="Nüsse" pageId="null" pageNumber="679">Nuesse</normalizedToken>
je Baum und Jahr. 
<normalizedToken id="2D3FBA30D183DA93877B9FA4F95F8CAC" originalValue="Keimfähigkeit" pageId="null" pageNumber="679">Keimfaehigkeit</normalizedToken>
der 
<normalizedToken id="8FCDA5FDC49F6A80B4CB86C092B0D735" originalValue="Nüsse" pageId="null" pageNumber="679">Nuesse</normalizedToken>
geht schon nach einem halben Jahr verloren. Kultursorten werden durch Pfropfen vermehrt.
</paragraph>
</subSubSection>
