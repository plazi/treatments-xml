</paragraph>
</subSubSection>
<subSubSection box="[153,930,2577,2606]" pageId="3" pageNumber="396" type="activity">
<paragraph blockId="3.[153,1361,1944,2844]" box="[153,930,2577,2606]" pageId="3" pageNumber="396">
<emphasis bold="true" box="[153,388,2577,2606]" pageId="3" pageNumber="396">Activity patterns.</emphasis>
Greater Striped Shrews are terrestrial.
</paragraph>
</subSubSection>
<subSubSection box="[155,1094,2617,2646]" pageId="3" pageNumber="396" type="biology_ecology">
<paragraph blockId="3.[153,1361,1944,2844]" box="[155,1094,2617,2646]" pageId="3" pageNumber="396">
<emphasis bold="true" box="[155,855,2617,2646]" pageId="3" pageNumber="396">Movements, Home range and Social organization.</emphasis>
