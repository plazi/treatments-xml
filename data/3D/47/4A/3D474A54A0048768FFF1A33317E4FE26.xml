<subSubSection pageId="44" pageNumber="439" type="breeding">
<paragraph blockId="44.[122,1327,2771,3472]" pageId="44" pageNumber="439">
<emphasis bold="true" box="[123,257,3243,3276]" pageId="44" pageNumber="439">Breeding.</emphasis>
