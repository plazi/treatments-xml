</paragraph>
</subSubSection>
<subSubSection box="[161,1043,1821,1854]" pageId="110" pageNumber="506" type="activity">
<paragraph blockId="110.[161,1370,1235,2129]" box="[161,1043,1821,1854]" pageId="110" pageNumber="506">
<emphasis bold="true" box="[161,397,1821,1854]" pageId="110" pageNumber="506">Activity patterns.</emphasis>
Caspian White-toothed Shrews are terrestrial.
</paragraph>
</subSubSection>
<subSubSection box="[163,1102,1860,1893]" pageId="110" pageNumber="506" type="biology_ecology">
<paragraph blockId="110.[161,1370,1235,2129]" box="[163,1102,1860,1893]" pageId="110" pageNumber="506">
<emphasis bold="true" box="[163,863,1860,1893]" pageId="110" pageNumber="506">Movements, Home range and Social organization.</emphasis>
