<subSubSection pageId="96" pageNumber="492" type="discussion">
<paragraph blockId="96.[778,1371,886,1313]" pageId="96" pageNumber="492">
<taxonomicName authority="Jenkins, Lunde &amp; Moncrieff, 2009" authorityName="Jenkins, Lunde &amp; Moncrieff" authorityYear="2009" box="[782,1054,1004,1037]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="96" pageNumber="492" phylum="Chordata" rank="species" species="cranbrooki">Crocidura cranbrooki</taxonomicName>
