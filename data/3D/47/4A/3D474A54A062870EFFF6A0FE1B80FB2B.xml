was previously included in S. 
<taxonomicName authorityName="Heim de Balsac" authorityYear="1968" box="[756,859,3292,3325]" class="Mammalia" family="Soricidae" genus="Sylvisorex" kingdom="Animalia" order="Soricomorpha" pageId="74" pageNumber="469" phylum="Chordata" rank="species" species="isabellae">isabellae</taxonomicName>
