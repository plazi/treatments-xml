<subSubSection pageId="26" pageNumber="419" type="breeding">
<paragraph blockId="26.[1394,2601,1166,1987]" pageId="26" pageNumber="419">
<emphasis bold="true" box="[1395,1530,1638,1671]" pageId="26" pageNumber="419">Breeding.</emphasis>
