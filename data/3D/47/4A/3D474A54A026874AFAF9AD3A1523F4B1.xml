<subSubSection pageId="14" pageNumber="407" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6870944" ID-Zenodo-Dep="6870944" httpUri="https://zenodo.org/record/6870944/files/figure.png" inLine="true" pageId="14" pageNumber="407" targetBox="[1393,1985,1800,2216]" targetPageId="14">
<paragraph blockId="14.[2007,2601,1790,2218]" pageId="14" pageNumber="407">
<emphasis bold="true" box="[2008,2184,2145,2178]" pageId="14" pageNumber="407">Distribution.</emphasis>
