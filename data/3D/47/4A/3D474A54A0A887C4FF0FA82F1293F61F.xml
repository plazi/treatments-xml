<subSubSection pageId="128" pageNumber="525" type="discussion">
<paragraph blockId="128.[741,1336,1124,1546]" pageId="128" pageNumber="525">
<taxonomicName authorityName="Thomas" authorityYear="1895" box="[745,969,1277,1310]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="525" phylum="Chordata" rank="species" species="silacea">Crocidura silacea</taxonomicName>
seems to be basal to a clade including 
<taxonomicName authorityName="Dollman" authorityYear="1915" box="[985,1096,1316,1349]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="525" phylum="Chordata" rank="species" species="batesi">C. batesi</taxonomicName>
, 
<taxonomicName authorityName="Dollman" authorityYear="1915" box="[1121,1210,1316,1349]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="538" phylum="Chordata" rank="species" species="foxi">C. foxi</taxonomicName>
, C. buet- tikoferi, 
<taxonomicName box="[846,976,1364,1389]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="0" phylum="Chordata" rank="species" species="theresae">C. theresae</taxonomicName>
, 
<taxonomicName authorityName="Hutterer" authorityYear="1983" box="[994,1163,1364,1389]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="538" phylum="Chordata" rank="species" species="grandiceps">C. grandiceps</taxonomicName>
, and 
<taxonomicName class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="0" phylum="Chordata" rank="species" species="wimmeri">C. wimmeri</taxonomicName>
, with 
<taxonomicName baseAuthorityName="Duvernoy" baseAuthorityYear="1838" box="[902,1033,1403,1428]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="0" phylum="Chordata" rank="species" species="cyanea">C. cyanea</taxonomicName>
, 
<taxonomicName baseAuthorityName="A. Smith" baseAuthorityYear="1844" box="[1060,1257,1403,1428]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="528" phylum="Chordata" rank="species" species="mariquensis">C. mariquensis</taxonomicName>
, and 
<taxonomicName authorityName="Thomas" authorityYear="1904" box="[746,944,1434,1467]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="528" phylum="Chordata" rank="species" species="hildegardeae">C. hildegardeae</taxonomicName>
more basal than 
<taxonomicName authorityName="Thomas" authorityYear="1895" box="[1212,1336,1434,1467]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="528" phylum="Chordata" rank="species" species="silacea">C. silacea</taxonomicName>
in this clade. This large clade is sister to a clade including 
<taxonomicName authorityName="Brosset, Dubost &amp; Heim de Balsac" authorityYear="1965" box="[978,1109,1521,1546]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="524" phylum="Chordata" rank="species" species="crenata">C. crenata</taxonomicName>
, 
<taxonomicName baseAuthorityName="Heuglin" baseAuthorityYear="1865" box="[1130,1328,1521,1546]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="542" phylum="Chordata" rank="species" species="fuscomurina">C. fuscomurina</taxonomicName>
,
</paragraph>
<paragraph blockId="128.[131,1337,1554,2534]" box="[134,837,1554,1587]" pageId="128" pageNumber="525">
<taxonomicName authorityName="Thomas" authorityYear="1895" box="[134,248,1554,1587]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="528" phylum="Chordata" rank="species" species="crossei">C. crossei</taxonomicName>
, 
<taxonomicName box="[266,433,1554,1587]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="525" phylum="Chordata" rank="species" species="jouvenetae">C. jouvenetae</taxonomicName>
, and 
<taxonomicName authorityName="Dollman" authorityYear="1915" box="[514,665,1554,1587]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="128" pageNumber="525" phylum="Chordata" rank="species" species="lusitania">C. lusitania</taxonomicName>
. Monotypic.
