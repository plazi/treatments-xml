<subSubSection pageId="126" pageNumber="523" type="breeding">
<paragraph blockId="126.[125,1332,296,650]" pageId="126" pageNumber="523">
<emphasis bold="true" box="[127,261,296,329]" pageId="126" pageNumber="523">Breeding.</emphasis>
