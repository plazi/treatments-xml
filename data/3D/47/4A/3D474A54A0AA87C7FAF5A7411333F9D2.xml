<taxonomicName authorityName="Dollman" authorityYear="1915" box="[1403,1553,3449,3478]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="525" phylum="Chordata" rank="species" species="lusitania">C. lusitania</taxonomicName>
