<taxonomicName authorityName="Dollman" authorityYear="1915" box="[2138,2219,3369,3398]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="538" phylum="Chordata" rank="species" species="foxi">C. foxi</taxonomicName>
