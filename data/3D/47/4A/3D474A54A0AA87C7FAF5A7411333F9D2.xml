<taxonomicName baseAuthorityName="Duvernoy" baseAuthorityYear="1838" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="0" phylum="Chordata" rank="species" species="cyanea">C. cyanea</taxonomicName>
, 
<taxonomicName baseAuthorityName="A. Smith" baseAuthorityYear="1844" box="[1464,1652,3369,3398]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="528" phylum="Chordata" rank="species" species="mariquensis">C. mariquensis</taxonomicName>
, 
<taxonomicName authorityName="Thomas" authorityYear="1895" box="[1669,1788,3369,3398]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="528" phylum="Chordata" rank="species" species="silacea">C. silacea</taxonomicName>
, 
<taxonomicName authorityName="Thomas" authorityYear="1904" box="[1806,1997,3369,3398]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="528" phylum="Chordata" rank="species" species="hildegardeae">C. hildegardeae</taxonomicName>
, 
<taxonomicName authorityName="Dollman" authorityYear="1915" box="[2015,2119,3369,3398]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="0" phylum="Chordata" rank="species" species="batesi">C. batesi</taxonomicName>
