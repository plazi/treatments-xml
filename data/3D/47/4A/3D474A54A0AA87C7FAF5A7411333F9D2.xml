<taxonomicName authorityName="Hutterer" authorityYear="1983" box="[2043,2214,3329,3358]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="538" phylum="Chordata" rank="species" species="grandiceps">C. grandiceps</taxonomicName>
