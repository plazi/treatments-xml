<subSubSection pageId="130" pageNumber="527" type="discussion">
<paragraph blockId="130.[1397,2604,3287,3486]" pageId="130" pageNumber="527">
<taxonomicName authorityName="Jentink" authorityYear="1888" box="[1402,1674,3329,3358]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="527" phylum="Chordata" rank="species" species="buettikoferi">Crocidura buettikoferi</taxonomicName>
