<taxonomicName box="[2299,2442,3369,3398]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="527" phylum="Chordata" rank="species" species="wimmeri">C. wimmeri</taxonomicName>
, and which is sister to another clade including 
<taxonomicName authorityName="Brosset, Dubost &amp; Heim de Balsac" authorityYear="1965" box="[1887,2013,3412,3437]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="524" phylum="Chordata" rank="species" species="crenata">C. crenata</taxonomicName>
, 
<taxonomicName baseAuthorityName="Heuglin" baseAuthorityYear="1865" box="[2030,2223,3412,3437]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="542" phylum="Chordata" rank="species" species="fuscomurina">C. fuscomurina</taxonomicName>
, 
<taxonomicName authorityName="Thomas" authorityYear="1895" box="[2241,2353,3412,3437]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="528" phylum="Chordata" rank="species" species="crossei">C. crossei</taxonomicName>
, 
<taxonomicName box="[2369,2535,3412,3437]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="525" phylum="Chordata" rank="species" species="jouvenetae">C. jouvenetae</taxonomicName>
