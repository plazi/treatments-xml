<taxonomicName box="[1835,1968,3329,3358]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="130" pageNumber="527" phylum="Chordata" rank="species" species="theresae">C. theresae</taxonomicName>
