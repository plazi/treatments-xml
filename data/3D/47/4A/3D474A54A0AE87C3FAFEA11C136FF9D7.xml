<taxonomicName authorityName="Hollister" authorityYear="1916" box="[1947,2106,3416,3441]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="134" pageNumber="531" phylum="Chordata" rank="species" species="polia">Crocidura polia</taxonomicName>
); 420. Ansell's White-toothed Shrew (
<taxonomicName authorityName="Roberts" authorityYear="1946" box="[1404,1672,3460,3481]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="134" pageNumber="531" phylum="Chordata" rank="species" species="maquassiensis">Crocidura maquassiensis</taxonomicName>
