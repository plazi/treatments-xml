<taxonomicName authorityName="Dollman" authorityYear="1910" box="[2054,2218,3460,3481]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="134" pageNumber="531" phylum="Chordata" rank="species" species="turba">Crocidura turba</taxonomicName>
