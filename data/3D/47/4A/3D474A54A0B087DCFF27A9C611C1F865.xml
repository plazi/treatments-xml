<taxonomicName box="[1140,1374,1521,1554]" class="Magnoliopsida" family="Meliaceae" genus="Entandrophragma" kingdom="Plantae" order="Sapindales" pageId="152" pageNumber="550" phylum="Tracheophyta" rank="genus">Entandrophragma</taxonomicName>
(
<taxonomicName box="[181,329,1560,1593]" class="Magnoliopsida" family="Meliaceae" kingdom="Plantae" order="Sapindales" pageId="152" pageNumber="550" phylum="Tracheophyta" rank="family">Meliaceae</taxonomicName>
), 
<taxonomicName box="[358,468,1560,1593]" class="Magnoliopsida" family="Chrysobalanaceae" genus="Parinari" kingdom="Plantae" order="Malpighiales" pageId="152" pageNumber="550" phylum="Tracheophyta" rank="genus">Parinari</taxonomicName>
(
<taxonomicName box="[491,753,1560,1593]" class="Magnoliopsida" family="Chrysobalanaceae" kingdom="Plantae" order="Malpighiales" pageId="152" pageNumber="550" phylum="Tracheophyta" rank="family">Chrysobalanaceae</taxonomicName>
