nized as a population of S. 
<taxonomicName authorityName="Heim de Balsac" authorityYear="1968" box="[1816,1919,2266,2299]" class="Mammalia" family="Soricidae" genus="Sylvisorex" kingdom="Animalia" order="Soricomorpha" pageId="73" pageNumber="468" phylum="Chordata" rank="species" species="isabellae">isabellae</taxonomicName>
