<subSubSection box="[1444,2177,2305,2338]" pageId="73" pageNumber="468" type="distribution">
<caption ID-DOI="http://doi.org/10.5281/zenodo.6871359" ID-Zenodo-Dep="6871359" box="[1444,2177,2305,2338]" httpUri="https://zenodo.org/record/6871359/files/figure.png" inLine="true" pageId="73" pageNumber="468" targetBox="[1441,2032,1840,2254]" targetPageId="73">
<paragraph blockId="73.[1441,2647,2266,3166]" box="[1444,2177,2305,2338]" pageId="73" pageNumber="468">
<emphasis bold="true" box="[1444,1619,2305,2338]" pageId="73" pageNumber="468">Distribution.</emphasis>
