<taxonomicName box="[2417,2557,1488,1513]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="129" pageNumber="526" phylum="Chordata" rank="species" species="theresae">C. theresae</taxonomicName>
