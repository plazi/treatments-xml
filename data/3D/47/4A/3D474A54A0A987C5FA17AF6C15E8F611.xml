<taxonomicName baseAuthorityName="Fraser" baseAuthorityYear="1843" box="[2046,2190,1440,1473]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="129" pageNumber="526" phylum="Chordata" rank="species" species="poensis">C. poensis</taxonomicName>
), which are together closely related to 
<taxonomicName authorityName="Jentink" authorityYear="1888" box="[2208,2390,1488,1513]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="129" pageNumber="528" phylum="Chordata" rank="species" species="buettikoferi">C. buettikoferi</taxonomicName>
