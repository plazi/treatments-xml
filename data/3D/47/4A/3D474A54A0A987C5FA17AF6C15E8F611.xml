<taxonomicName baseAuthorityName="Fraser" baseAuthorityYear="1843" box="[2415,2540,1361,1394]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="129" pageNumber="528" phylum="Chordata" rank="species" species="poensis">C. poensis</taxonomicName>
