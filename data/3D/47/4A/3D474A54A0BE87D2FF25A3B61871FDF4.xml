<subSubSection pageId="150" pageNumber="548" type="discussion">
<paragraph blockId="150.[779,1370,2421,2847]" pageId="150" pageNumber="548">
<taxonomicName authorityName="Heim de Balsac &amp; Lamotte" authorityYear="1956" box="[781,975,2539,2572]" class="Mammalia" family="Soricidae" genus="Myosorex" kingdom="Animalia" order="Soricomorpha" pageId="150" pageNumber="548" phylum="Chordata" rank="species" species="zinki">Mpyosorex zinki</taxonomicName>
was found to be sister to a clade including 
<taxonomicName box="[1085,1364,2578,2611]" class="Mammalia" family="Soricidae" genus="Congosorex" kingdom="Animalia" order="Soricomorpha" pageId="150" pageNumber="548" phylum="Chordata" rank="species" species="verheyeni">Congosorex verheyeni</taxonomicName>
, M. meesteri, 
<taxonomicName box="[947,1084,2626,2651]" class="Mammalia" family="Soricidae" genus="Myosorex" kingdom="Animalia" order="Soricomorpha" pageId="150" pageNumber="546" phylum="Chordata" rank="species" species="sclateri">M. sclateri</taxonomicName>
, 
<taxonomicName authorityName="Sundevall" authorityYear="1846" box="[1104,1213,2626,2651]" class="Mammalia" family="Soricidae" genus="Sorex" kingdom="Animalia" order="Soricomorpha" pageId="150" pageNumber="547" phylum="Chordata" rank="species" species="cafer">M. cafer</taxonomicName>
, 
<taxonomicName authorityName="Smuts" authorityYear="1832" box="[1232,1363,2626,2651]" class="Mammalia" family="Soricidae" genus="Sorex" kingdom="Animalia" order="Soricomorpha" pageId="150" pageNumber="546" phylum="Chordata" rank="species" species="varius">M. varius</taxonomicName>
