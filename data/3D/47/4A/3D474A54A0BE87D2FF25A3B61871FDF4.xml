<taxonomicName box="[855,988,2665,2690]" class="Mammalia" family="Soricidae" genus="Myosorex" kingdom="Animalia" order="Soricomorpha" pageId="150" pageNumber="546" phylum="Chordata" rank="species" species="tenuis">M. tenuis</taxonomicName>
