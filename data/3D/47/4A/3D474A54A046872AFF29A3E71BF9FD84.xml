<paragraph blockId="110.[1442,2648,288,641]" box="[1443,2645,371,400]" pageId="110" pageNumber="506">
<emphasis bold="true" box="[1443,1676,371,400]" pageId="110" pageNumber="506">Activity patterns.</emphasis>
