<taxonomicName authorityName="Thomas" authorityYear="1910" box="[737,860,839,877]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="122" pageNumber="536" phylum="Chordata" rank="species" species="monax">C. monax</taxonomicName>
