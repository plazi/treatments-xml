<taxonomicName box="[2348,2474,2456,2489]" class="Mammalia" family="Soricidae" genus="Sorex" kingdom="Animalia" order="Soricomorpha" pageId="7" pageNumber="400" phylum="Chordata" rank="species" species="granarius">granarius</taxonomicName>
in the 
<taxonomicName authorityName="Linnaeus" authorityYear="1758" class="Mammalia" family="Soricidae" genus="Sorex" kingdom="Animalia" order="Soricomorpha" pageId="7" pageNumber="400" phylum="Chordata" rank="species" species="araneus">araneus</taxonomicName>
