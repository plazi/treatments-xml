<taxonomicName authorityName="Dollman" authorityYear="1915" box="[2057,2162,1867,1900]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="131" pageNumber="0" phylum="Chordata" rank="species" species="batesi">C. batesi</taxonomicName>
