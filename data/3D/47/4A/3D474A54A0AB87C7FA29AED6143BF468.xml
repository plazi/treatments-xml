<taxonomicName authorityName="Thomas" authorityYear="1904" box="[2449,2639,1832,1861]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="131" pageNumber="528" phylum="Chordata" rank="species" species="hildegardeae">C. hildegardeae</taxonomicName>
