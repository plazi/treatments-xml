<taxonomicName baseAuthorityName="A. Smith" baseAuthorityYear="1844" box="[2110,2296,1832,1861]" class="Mammalia" family="Soricidae" genus="Crocidura" kingdom="Animalia" order="Soricomorpha" pageId="131" pageNumber="528" phylum="Chordata" rank="species" species="mariquensis">C. mariquensis</taxonomicName>
