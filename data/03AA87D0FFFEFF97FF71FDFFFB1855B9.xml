<taxonomicName id="4C034D45FFFEFF97FB73FDD5FAF455F3" box="[1218,1337,636,662]" class="Arachnida" family="Araneidae" genus="Larinia" kingdom="Animalia" order="Araneae" pageId="11" pageNumber="10" phylum="Arthropoda" rank="species" species="undetermined">
