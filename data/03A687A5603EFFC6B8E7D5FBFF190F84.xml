cf. 
<emphasis id="B97BEAA1603EFFC6B915D5FBFE090DC7" bold="true" box="[357,482,151,177]" italics="true" pageId="9" pageNumber="558">yeojuensis</emphasis>
</emphasis>
</taxonomicName>
