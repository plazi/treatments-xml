<taxonomicName id="4C6E3EF8F45AFFA7FAF16BFB5EFCFD67" authorityName="Aime &amp; McTaggart" authorityYear="2020" baseAuthorityName="Racib." box="[1321,1451,735,760]" class="Pucciniomycetes" family="Crossopsoraceae" genus="Neoolivea" higherTaxonomySource="GBIF" kingdom="Fungi" order="Pucciniales" pageId="5" pageNumber="132" phylum="Basidiomycota" rank="species" species="tectonae">
<emphasis id="B91A9969F45AFFA7FAF16BFB5EFCFD67" box="[1321,1451,735,760]" italics="true" pageId="5" pageNumber="132">N. tectonae</emphasis>
</taxonomicName>
from other countries (e.g. 
<bibRefCitation id="EFFF388AF45AFFA7FE746A265933FC83" author="Daly, A. M. &amp; Shivas, R. G. &amp; Pegg, G. S. &amp; Mackie, A. E." box="[428,612,770,797]" pageId="5" pageNumber="132" pagination="25 - 26" refId="ref11076" refString="Daly, A. M., Shivas, R. G., Pegg, G. S. &amp; Mackie, A. E. (2006) First record of teak leaf rust (Olivea tectonae) in Australia. Australasian Plant Disease Notes 1: 25 - 26. https: // doi. org / 10.1071 / DN 06011" type="journal article" year="2006">
Daly 
<emphasis id="B91A9969F45AFFA7FE326A27594CFC83" box="[490,539,770,796]" italics="true" pageId="5" pageNumber="132">et al</emphasis>
. 2006
</bibRefCitation>
, 
<bibRefCitation id="EFFF388AF45AFFA7FDB76A26586BFC83" author="Cabral, P. G. C. &amp; Capucho, A. S. &amp; Pereira, O. L. &amp; Maciel-Zambolim, E. &amp; Freitas, R. L. &amp; Zambolim, L." box="[623,828,770,797]" pageId="5" pageNumber="132" pagination="113 - 114" refId="ref10675" refString="Cabral, P. G. C., Capucho, A. S., Pereira, O. L., Maciel-Zambolim, E., Freitas, R. L. &amp; Zambolim, L. (2010) First report of teak leaf rust disease caused by Olivea tectonae in Brazil. Australasian Plant Disease Notes 5: 113 - 114. https: // doi. org / 10.1007 / BF 03215901" type="journal article" year="2010">
Cabral 
