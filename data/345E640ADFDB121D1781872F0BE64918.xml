<subSubSection id="F9E48117246A68BE110E5844F4CDF147" pageId="null" pageNumber="351" type="description">
<paragraph id="8301B99AEF91C6D864E72838B9D7B06F" pageId="null" pageNumber="351">
Ausdauernd, 
<emphasis id="FDB8DC462ECF9F9A07D7C3FFD3751415" italics="true" pageId="null" pageNumber="351">50-120 cm hoch</emphasis>
, dichte, feste Horste bildend (
<emphasis id="F88C219BE4EE19CC89762A96563705F9" italics="true" pageId="null" pageNumber="351">Triebe meist intravaginal</emphasis>
), keine 
<normalizedToken id="7640E0A5C1338920527A8254B4479B8E" originalValue="Ausläufer" pageId="null" pageNumber="351">Auslaeufer</normalizedToken>
vorhanden. Nicht alle 
<normalizedToken id="C2C522F7AE781C34F1AE55F2E90D9773" originalValue="Blätter" pageId="null" pageNumber="351">Blaetter</normalizedToken>
flach: 
<normalizedToken id="2E2F21FEF4D0BFF2977B4CF37B2A5FF8" originalValue="Blätter" pageId="null" pageNumber="351">Blaetter</normalizedToken>
der nicht 
<normalizedToken id="1A984953BDA161C2D192D335EA687944" originalValue="blühenden" pageId="null" pageNumber="351">bluehenden</normalizedToken>
Triebe 
<normalizedToken id="BD1E6BE90F75B6357F7619A3786A11E7" originalValue="borstenförmig" pageId="null" pageNumber="351">borstenfoermig</normalizedToken>
; 
<normalizedToken id="0D61F4350401EE2A87FE58557C5278F7" originalValue="Stengelblätter" pageId="null" pageNumber="351">Stengelblaetter</normalizedToken>
flach oder offen rinnig; 
<emphasis id="A235F9C51012508D0F0A40999A9564F9" italics="true" pageId="null" pageNumber="351">
<normalizedToken id="A56750CAB25A8338CA081BA24BB6CB3B" originalValue="borstenförmige" pageId="null" pageNumber="351">borstenfoermige</normalizedToken>
<normalizedToken id="9BC5DA94C366699198FC28F315ADA75C" originalValue="Blätter" pageId="null" pageNumber="351">Blaetter</normalizedToken>
0,3-0,6 mm dick, im Querschnitt 3eckig, mit 3 Nerven und 5 
<normalizedToken id="79D59811EE22E3EBB9266DAEBD1D7B28" originalValue="Strängen" pageId="null" pageNumber="351">Straengen</normalizedToken>
Festigungsgewebe;
</emphasis>
<normalizedToken id="60DB41B78DB466CDBD8E4C5B7CB37F10" originalValue="Stengelblätter" pageId="null" pageNumber="351">Stengelblaetter</normalizedToken>
2-3 mm breit; 
<normalizedToken id="6B2872744AA65597F8F5EAE4024173C9" originalValue="Blatthäutchen" pageId="null" pageNumber="351">Blatthaeutchen</normalizedToken>
der 
<normalizedToken id="21C7C5945690483E2C08A2C78A7EC5F8" originalValue="Stengelblätter" pageId="null" pageNumber="351">Stengelblaetter</normalizedToken>
bis 0,5 mm lang, gestutzt, am Rande bewimpert. Blattscheiden an den nicht 
<normalizedToken id="910CA1B312C7E80419C575BEF56F3CE7" originalValue="blühenden" pageId="null" pageNumber="351">bluehenden</normalizedToken>
Trieben ganz geschlossen. 
<normalizedToken id="7493CD1C43C4DB601B7AC76616EBBDA4" originalValue="Blütenstand" pageId="null" pageNumber="351">Bluetenstand</normalizedToken>
wie bei 
<taxonomicName id="9EB25244B0414D9AECCC6A9DD7C0C417" class="Liliopsida" family="Poaceae" genus="Festuca" kingdom="Plantae" order="Poales" pageId="null" pageNumber="351" phylum="Tracheophyta" rank="species" species="rubra">
<emphasis id="9272AD343043FAAEAFA967A6F55F13E2" italics="true" pageId="null" pageNumber="351">F. rubra</emphasis>
</taxonomicName>
(Nr. 10), 
<emphasis id="4291B50EBD8D4C8A9715BE464F27CB16" italics="true" pageId="null" pageNumber="351">
<normalizedToken id="0B1F37080C3502B7BF38CD6AB9A1711C" originalValue="Ährchen" pageId="null" pageNumber="351">Aehrchen</normalizedToken>
jedoch 
<normalizedToken id="46ABC28A8F561200781FF8094154D459" originalValue="grün" pageId="null" pageNumber="351">gruen</normalizedToken>
. Fruchtknoten im obern Teil behaart.
</emphasis>
- 
<normalizedToken id="5334B83C9315E5ACB005955AA0008969" originalValue="Blüte" pageId="null" pageNumber="351">Bluete</normalizedToken>
: 
<normalizedToken id="76334847427DF053393338826863A6F0" originalValue="Später" pageId="null" pageNumber="351">Spaeter</normalizedToken>
<normalizedToken id="D276AE0204DE86755EB2E25D15D6E973" originalValue="Frühling" pageId="null" pageNumber="351">Fruehling</normalizedToken>
bis Herbst.
</paragraph>
<paragraph id="8DB5A1D69BB851409A6ABE05BE6BC2A3" pageId="null" pageNumber="351">
<emphasis id="570BAC17CF59444D466A9F349F58F816" italics="true" pageId="null" pageNumber="351">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="BAAEBE1345C1E524D26C97AD1CD55D58" italics="true" pageId="null" pageNumber="351">28:</emphasis>
Material aus verschiedenen Gebieten von Frankreich und Korsika (
<normalizedToken id="12B238A0546EDFDE5DD99F3D17BDE5C7" originalValue="Litardière" pageId="null" pageNumber="351">Litardiere</normalizedToken>
1949 
<normalizedToken id="6F9551DB3B1A583A95DD780DAC92C2B9" originalValue="Litardière" pageId="null" pageNumber="351">Litardiere</normalizedToken>
1950), aus botanischen 
<normalizedToken id="86E79DF03A9922E45E51AF5188BC82C1" originalValue="Gärten" pageId="null" pageNumber="351">Gaerten</normalizedToken>
(Brandberg 1949, Jenkin 1955). 
<emphasis id="915B591B686316E31B84D885041E2F27" italics="true" pageId="null" pageNumber="351">2n</emphasis>
= 
<emphasis id="04FAF32CF469F3516A30E7D2165834EE" italics="true" pageId="null" pageNumber="351">42:</emphasis>
Material aus Kiew (Levitsky und Kusmina 1927), aus botanischen 
<normalizedToken id="435E474FD44BE9E7B224DE4010567EE4" originalValue="Gärten" pageId="null" pageNumber="351">Gaerten</normalizedToken>
(
<normalizedToken id="A71DDCD86C14BAF6476CD0D4BC0186A1" originalValue="Stählin" pageId="null" pageNumber="351">Staehlin</normalizedToken>
1929).
</paragraph>
<paragraph id="D6D2885BDA0773C9BD04B1CB25294A88" pageId="null" pageNumber="351">
<emphasis id="E769C64600244CB2A35A2970D8100706" italics="true" pageId="null" pageNumber="351">Standort.</emphasis>
Kollin und montan, seltener subalpin. Kalkarme, ziemlich trockene 
<normalizedToken id="A29B32CE436FD80F2C333A60D31849BF" originalValue="Böden" pageId="null" pageNumber="351">Boeden</normalizedToken>
. Lichte 
<normalizedToken id="39CC94E73E32B02414AD6332C28D7560" originalValue="Laubmischwälder" pageId="null" pageNumber="351">Laubmischwaelder</normalizedToken>
und 
<normalizedToken id="C89C0C884FA11598C57D6DC45E86153F" originalValue="Nadelwälder" pageId="null" pageNumber="351">Nadelwaelder</normalizedToken>
.
</paragraph>
<paragraph id="4DF9168608BA7CE0D09F22B8EC507007" pageId="null" pageNumber="351">
<emphasis id="2D7B42BEF33BDCF6D310A5D7F5EAA10E" italics="true" pageId="null" pageNumber="351">
Verbreitung. 
<normalizedToken id="DE45AB5D1500AE274856566B43762029" originalValue="Europäische" pageId="null" pageNumber="351">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="27D7766FDF31EBC70CDBACBE03C10803" originalValue="Nordwärts" pageId="null" pageNumber="351">Nordwaerts</normalizedToken>
bis Nordengland, 
<normalizedToken id="3071ED1CEE0B18262378B45CDA229B54" originalValue="Südskandinavien" pageId="null" pageNumber="351">Suedskandinavien</normalizedToken>
, Norddeutschland, 
<normalizedToken id="ABF6FE2E1B2C3614D19D70B83969818F" originalValue="südwärts" pageId="null" pageNumber="351">suedwaerts</normalizedToken>
bis Nordspanien, Sizilien, Balkanhalbinsel, 
<normalizedToken id="AD7A53C5E9AEE7BA4CFAB0500C9DF3BE" originalValue="ostwärts" pageId="null" pageNumber="351">ostwaerts</normalizedToken>
bis Transkaukasien. Verbreitungskarte von Meusel (1964). - Im Gebiet verbreitet, ziemlich 
<normalizedToken id="F8E27E5A408066B704A990902FBE9ACB" originalValue="häufig" pageId="null" pageNumber="351">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
