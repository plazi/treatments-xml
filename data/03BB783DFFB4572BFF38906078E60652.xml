species
</emphasis>
. 
<taxonomicName id="4C12B2A8FFB45728FE8590A07E7D0092" authority="Emerson &amp; Banks, 1957" authorityName="Emerson &amp; Banks" authorityYear="1957" box="[298,790,691,716]" class="Insecta" family="Termitidae" genus="Armitermes" kingdom="Animalia" order="Blattodea" pageId="5" pageNumber="450" phylum="Arthropoda" rank="species" species="brevinasus">
