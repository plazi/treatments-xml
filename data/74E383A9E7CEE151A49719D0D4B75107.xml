Die Gattung 
<taxonomicName id="CF57A00EA9C6F8595C5FE3933EF9E130" class="Magnoliopsida" family="Lamiaceae" genus="Horminum" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="143" phylum="Tracheophyta" rank="genus">
