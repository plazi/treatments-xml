<figureCitation id="89D52A42560C694FC8BA00458213F8FF" box="[161,260,1881,1908]" captionStart="FIGURES 1–6" captionStartId="2.[151,264,1829,1853]" captionTargetBox="[164,1416,193,1790]" captionTargetId="figure-19@2.[151,1436,179,1803]" captionTargetPageId="2" captionText="FIGURES 1–6. Imago of Teliphasa spp. 1, male &amp; 2, female, T. nubilosa; 3, male &amp; 4, female, T. hamata; 5, male, holotype &amp; 6, male, paratype, T. dodaki sp. nov.;" figureDoi="http://doi.org/10.5281/zenodo.6577734" httpUri="https://zenodo.org/record/6577734/files/figure.png" pageId="3" pageNumber="63">Figs 5, 6</figureCitation>
