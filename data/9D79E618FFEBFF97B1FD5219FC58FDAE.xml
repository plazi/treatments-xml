: 
<taxonomicName id="D2D02C8DFFE9FF97B4405745FA39FE8F" box="[1322,1429,295,321]" class="Liliopsida" family="Asphodelaceae" genus="Aloe" kingdom="Plantae" order="Asparagales" pageId="102" pageNumber="103" phylum="Tracheophyta" rank="species" species="vera">
<emphasis id="27A48B1CFFE9FF97B4405745FA39FE8F" box="[1322,1429,295,321]" italics="true" pageId="102" pageNumber="103">Aloe vera</emphasis>
</taxonomicName>
; 
<taxonomicName id="D2D02C8DFFE9FF97B1FD5729FEBAFEAA" box="[151,278,331,357]" class="Magnoliopsida" family="Asteraceae" kingdom="Plantae" order="Asterales" pageId="102" pageNumber="103" phylum="Tracheophyta" rank="family">Asteraceae</taxonomicName>
: 
<taxonomicName id="D2D02C8DFFE9FF97B04B5729FDF7FEAA" box="[289,603,331,357]" class="Magnoliopsida" family="Asteraceae" genus="Chrysanthemum" kingdom="Plantae" order="Asterales" pageId="102" pageNumber="103" phylum="Tracheophyta" rank="species" species="morifolium">
<emphasis id="27A48B1CFFE9FF97B04B5729FDF7FEAA" box="[289,603,331,357]" italics="true" pageId="102" pageNumber="103">Chrysanthemum morifolium</emphasis>
</taxonomicName>
; and 
<taxonomicName id="D2D02C8DFFE9FF97B3F05729FD56FEAA" baseAuthorityName="Moghaddam" baseAuthorityYear="2019" box="[666,762,331,357]" class="Liliopsida" family="Poaceae" kingdom="Plantae" order="Poales" pageId="102" pageNumber="103" phylum="Tracheophyta" rank="family">Poaceae</taxonomicName>
: 
<taxonomicName id="D2D02C8DFFE9FF97B26E5729FB45FEA9" authority="(Moghaddam 2013 b)" baseAuthorityName="Moghaddam" baseAuthorityYear="2013" box="[772,1257,331,358]" class="Liliopsida" family="Poaceae" genus="Festuca" kingdom="Plantae" order="Poales" pageId="102" pageNumber="103" phylum="Tracheophyta" rank="species" species="arundinacea">
<emphasis id="27A48B1CFFE9FF97B26E5729FC5EFEAA" box="[772,1010,331,357]" italics="true" pageId="102" pageNumber="103">Festuca arundinacea</emphasis>
(
<bibRefCitation id="71412AFFFFE9FF97B56A5729FB4EFEA9" author="Moghaddam, M." box="[1024,1250,331,358]" pageId="102" pageNumber="103" pagination="1 - 92" refId="ref94901" refString="Moghaddam, M. (2013 b) An annotated checklist of the scale insects of Iran (Hemiptera, Sternorrhyncha, Coccoidea) with new records and distribution data. ZooKeys, 334, 1 - 92. https: // doi. org / 10.3897 / zookeys. 334.5818" type="journal article" year="2013">Moghaddam 2013b</bibRefCitation>
