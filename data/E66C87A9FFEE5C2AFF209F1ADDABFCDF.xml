(
<bibRefCitation id="0A544B4EFFEE5C2DFD4B9F1ADAB5F997" author="Wittmer W" box="[740,906,1597,1621]" pageId="3" pageNumber="76" pagination="171 - 286" refId="ref5232" refString="Wittmer W. 1995. Zur Kenntnis Gattung Athemus Lewis (Col. Cantharidae). Entomol Basil. 18: 171 - 286." type="journal article" year="1995">Wittmer, 1995</bibRefCitation>
