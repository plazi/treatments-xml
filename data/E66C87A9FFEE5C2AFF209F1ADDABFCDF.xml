<emphasis id="5CB1EAADFFEE5C2DFF209F1AD8E9F996" bold="true" box="[143,470,1596,1621]" italics="true" pageId="3" pageNumber="76">
A key to the 
<taxonomicName id="A9C54D3CFFEE5C2DFEB49F1ADAACF997" authority="Gorham, 1889" authorityName="Gorham" authorityYear="1889" box="[283,915,1596,1621]" class="Insecta" family="Cantharidae" genus="Lycocerus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="3" pageNumber="76" phylum="Arthropoda" rank="genus">
