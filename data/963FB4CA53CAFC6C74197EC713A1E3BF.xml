<taxonomicName id="6A2EEEEACC3A334DED742D918EF5D147" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Scorzonera" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="humilis">
