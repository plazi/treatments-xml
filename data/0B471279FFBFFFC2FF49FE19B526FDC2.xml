</taxonomicName>
and may belong to 
<emphasis id="B19A7F7DFFBFFFC2FF2AFDA3B526FDC2" box="[197,313,565,590]" italics="true" pageId="6" pageNumber="211">
<taxonomicName id="44EED8ECFFBFFFC2FF2AFDA3B52AFDC2" authorityName="White" authorityYear="1841" box="[197,309,565,590]" class="Arachnida" family="Tetragnathidae" genus="Leucauge" kingdom="Animalia" order="Araneae" pageId="6" pageNumber="211" phylum="Arthropoda" rank="genus">Leucauge</taxonomicName>
