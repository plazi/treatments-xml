<collectingCountry id="E9FC764FFFA7BA0BBCF2FA0DBB58F248" box="[2272,2430,3437,3462]" name="Ivory Coast" pageId="27" pageNumber="646">Ivory Coast</collectingCountry>
, 
<collectingCountry id="E9FC764FFFA7BA0BBD83FA0DBBC9F248" box="[2449,2543,3437,3462]" name="Ghana" pageId="27" pageNumber="646">Ghana</collectingCountry>
, 
<collectingCountry id="E9FC764FFFA7BA0BBE13FA0DB84CF248" box="[2561,2666,3437,3462]" name="Nigeria" pageId="27" pageNumber="646">Nigeria</collectingCountry>
, 
<collectingCountry id="E9FC764FFFA0BA0CB4B2F675B311FEFC" box="[160,311,277,306]" name="Cameroon" pageId="28" pageNumber="647">Cameroon</collectingCountry>
, 
<collectingCountry id="E9FC764FFFA0BA0CB55BF675B3B3FEFC" box="[329,405,277,306]" name="Chad" pageId="28" pageNumber="647">Chad</collectingCountry>
