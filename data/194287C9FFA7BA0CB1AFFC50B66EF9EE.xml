<collectingCountry id="E9FC764FFFA0BA0CB623F675B151FEFC" box="[561,887,277,306]" name="Republic of the Congo" pageId="28" pageNumber="647">Republic of the Congo</collectingCountry>
, 
<collectingCountry id="E9FC764FFFA0BA0CB79BF675B638FEFC" box="[905,1054,277,306]" name="Democratic Republic of the Congo" pageId="28" pageNumber="647">DR Congo</collectingCountry>
