</paragraph>
</subSubSection>
<subSubSection id="D9F16554FFA0BA0CB4B2F4CFB033FC1E" box="[160,533,943,976]" pageId="28" pageNumber="647" type="breeding">
<paragraph id="915436DFFFA0BA0CB4B2F4CFB033FC1E" blockId="28.[153,1367,277,1571]" box="[160,533,943,976]" pageId="28" pageNumber="647">
<emphasis id="A39FEACDFFA0BA0CB4B2F4CFB300FC1E" bold="true" box="[160,294,943,976]" pageId="28" pageNumber="647">Breeding.</emphasis>
