<subSubSection id="7138ADA5B363F15DE4CBB8A35238D1E0" pageId="null" pageNumber="456" type="description">
<paragraph id="CF0C8326D8FD0066CDB484FD4F3C5ECC" pageId="null" pageNumber="456">
Die meisten 
<emphasis id="33DD51F059ACA726F2551DD5BD85D823" italics="true" pageId="null" pageNumber="456">
<normalizedToken id="988EB2ECB06E006E5FFEC99D4E7652BD" originalValue="Teilblätter" pageId="null" pageNumber="456">Teilblaetter</normalizedToken>
nach dem Grunde 
<normalizedToken id="88F23414947913A23FFF3C6E8CE45270" originalValue="keilförmig" pageId="null" pageNumber="456">keilfoermig</normalizedToken>
<normalizedToken id="926C8ADC8C3F84415CED709B134F9334" originalValue="verschmälert" pageId="null" pageNumber="456">verschmaelert</normalizedToken>
. 
<normalizedToken id="865337822B7318E99E5721E06837A222" originalValue="Blütenstiele" pageId="null" pageNumber="456">Bluetenstiele</normalizedToken>
kahl. 
<normalizedToken id="3352CE3C8C6E9EA2E6BD4C329A402418" originalValue="Kelchblätter" pageId="null" pageNumber="456">Kelchblaetter</normalizedToken>
nach, der 
<normalizedToken id="B41C155AA254D144AED16D715768D019" originalValue="Blüte" pageId="null" pageNumber="456">Bluete</normalizedToken>
aufgerichtet, bis zur Fruchtreife bleibend.
</emphasis>
Frucht meist kahl.
</paragraph>
<paragraph id="152329C276B55E4150482F75C38013BA" pageId="null" pageNumber="456">
<emphasis id="DE4AE56942BDCB3D31C78E48C3A8102F" italics="true" pageId="null" pageNumber="456">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="00A5D5A699030624ECBF8480CD8C1ECA" italics="true" pageId="null" pageNumber="456">35:</emphasis>
Material aus botanischen 
<normalizedToken id="C3C7298D829DA8B2152DC6098A8753F7" originalValue="Gärten" pageId="null" pageNumber="456">Gaerten</normalizedToken>
; 21 univalente und 14 bivalente Chromosomen (
<normalizedToken id="9134229D871085A282A017D1C80A8818" originalValue="Täckholm" pageId="null" pageNumber="456">Taeckholm</normalizedToken>
1922, Hurst 1928, Hurst 1931); Material aus der Tschechoslowakei (
<normalizedToken id="E7F1BC82142CE9EFD8FB61273FD845BD" originalValue="Klášterský" pageId="null" pageNumber="456">Klastersky</normalizedToken>
in 
<normalizedToken id="555872B0A00318DE96D0A9C4BBF79D19" originalValue="Löve" pageId="null" pageNumber="456">Loeve</normalizedToken>
1969a).
</paragraph>
<paragraph id="0B8E450C2C7BEDC51E47D5CBFB7144C7" pageId="null" pageNumber="456">
<emphasis id="915B5EFD892E3ABD04F517338634A027" italics="true" pageId="null" pageNumber="456">Standort.</emphasis>
Kollin und montan, selten subalpin. Trockene, kalkhaltige 
<normalizedToken id="12370E87CD9B6FAE7616BA6D4FBE3BE5" originalValue="Böden" pageId="null" pageNumber="456">Boeden</normalizedToken>
in sonniger Lage. 
<taxonomicName id="08CB0B590AD851709A012A3BA15A1191" class="Magnoliopsida" family="Berberidaceae" genus="Berberis" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="456" phylum="Tracheophyta" rank="genus">
<emphasis id="593B67E1214D0CEEC4E1C505461F6B37" italics="true" pageId="null" pageNumber="456">Berberis</emphasis>
</taxonomicName>
<normalizedToken id="73F6E8DAFC1FBE76A5EF64225BED906A" originalValue="gebüsch" pageId="null" pageNumber="456">gebuesch</normalizedToken>
. an Steinhaufen.
</paragraph>
<paragraph id="C4EEE9EC315799BCCFCE43E67E277E40" pageId="null" pageNumber="456">
<emphasis id="8657683F2AF33B25B9B6516537DFCC17" italics="true" pageId="null" pageNumber="456">
Verbreitung. 
<normalizedToken id="097346238A5F4F6BC899C13FCCA9873A" originalValue="Mitteleuropäische" pageId="null" pageNumber="456">Mitteleuropaeische</normalizedToken>
Pflanze:
</emphasis>
Wenige Fundstellen in England, sonst 
<normalizedToken id="AAF45D3E6D18AAB6066E38E970633FA9" originalValue="nordwärts" pageId="null" pageNumber="456">nordwaerts</normalizedToken>
bis Holland, Mitteldeutschland, 
<normalizedToken id="F3F87EC4965E1C9EED3AC23AF791B8AF" originalValue="Südpolen" pageId="null" pageNumber="456">Suedpolen</normalizedToken>
; 
<normalizedToken id="DBB813BC474ACADB12AB3749E31DAFF8" originalValue="westwärts" pageId="null" pageNumber="456">westwaerts</normalizedToken>
bis Mittelfrankreich; 
<normalizedToken id="B962A959BBAAA0789033D2C36BA4F657" originalValue="südwärts" pageId="null" pageNumber="456">suedwaerts</normalizedToken>
bis zu den 
<normalizedToken id="38BA57DFD76D6BD3BB0D1757D99DA57D" originalValue="Pyrenäen" pageId="null" pageNumber="456">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="8F749CA18D9199D31E9C4EF009009635" originalValue="nördlicher" pageId="null" pageNumber="456">noerdlicher</normalizedToken>
Apennin, Albanien und 
<normalizedToken id="4478F20CEED11900B30078B270345AFB" originalValue="nördliches" pageId="null" pageNumber="456">noerdliches</normalizedToken>
Donaubecken; vereinzelt durch 
<normalizedToken id="15632ADA9B89D37FF8DF9B15637CEAFF" originalValue="Südrußland" pageId="null" pageNumber="456">Suedrussland</normalizedToken>
, 
<normalizedToken id="EA0D57C6898E5B0BFAB315879718D9E2" originalValue="ostwärts" pageId="null" pageNumber="456">ostwaerts</normalizedToken>
bis ins Dongebiet. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: Ziemlich verbreitet, nicht 
<normalizedToken id="50E3C977ABF4D67F3327BB6E13DA70C5" originalValue="häufig" pageId="null" pageNumber="456">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
