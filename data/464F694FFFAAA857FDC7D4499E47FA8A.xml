<caption id="9A9988D1FFAAA857FB1BD2659E67FBC1" ID-DOI="http://doi.org/10.5281/zenodo.6607189" ID-Zenodo-Dep="6607189" box="[1258,2084,1078,1111]" httpUri="https://zenodo.org/record/6607189/files/figure.png" inLine="true" pageId="0" pageNumber="120" startId="0.[1258,1271,1078,1111]" targetBox="[249,1194,690,1313]" targetPageId="0">
