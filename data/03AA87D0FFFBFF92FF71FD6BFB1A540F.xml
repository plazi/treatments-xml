<taxonomicName id="4C034D45FFFBFF92FE5BFCA3FD855441" authorityName="Sundevall" authorityYear="1833" box="[490,584,778,804]" class="Arachnida" family="Theridiidae" genus="Steatoda" kingdom="Animalia" order="Araneae" pageId="14" pageNumber="13" phylum="Arthropoda" rank="genus">
