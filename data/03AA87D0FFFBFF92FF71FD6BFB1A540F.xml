<taxonomicName id="4C034D45FFFBFF92FBB5FCA3FB465440" authorityName="Sundevall" authorityYear="1833" box="[1028,1163,778,805]" class="Arachnida" family="Theridiidae" kingdom="Animalia" order="Araneae" pageId="14" pageNumber="13" phylum="Arthropoda" rank="family">Theridiidae</taxonomicName>
