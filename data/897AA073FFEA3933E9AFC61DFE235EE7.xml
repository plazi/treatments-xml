<figureCitation id="99E80DE0FFEA3932E827C644FC965AA7" box="[790,873,375,401]" captionStart="Fig" captionStartId="69.[227,270,1179,1205]" captionTargetBox="[227,1437,302,1141]" captionTargetId="figure-147@69.[227,1437,302,1141]" captionTargetPageId="69" captionText="Fig. 24. Otoliths of “Citharus” varians sp. nov. from the US middle and upper Eocene; Wheelock M., Little Brazos River, Stenzel loc., Texas. A–F. Paratypes (IRSNB P 10139–10144). G. Holotype (IRSNB P 10145). 1 = ventral view; 2 = inner view. Scale bars = 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6484405" httpUri="https://zenodo.org/record/6484405/files/figure.png" pageId="68" pageNumber="69">Fig. 24</figureCitation>
