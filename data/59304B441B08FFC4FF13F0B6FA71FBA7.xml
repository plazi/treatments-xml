<caption id="85E6AADA1B08FFC4F84DFE76F7F9FD8C" ID-DOI="http://doi.org/10.5281/zenodo.6588320" ID-Zenodo-Dep="6588320" httpUri="https://zenodo.org/record/6588320/files/figure.png" inLine="true" pageId="22" pageNumber="533" targetBox="[1395,1986,292,706]" targetPageId="22">
