<taxonomicName id="4C2C4D4D003FFFEFFE8EF959FE3C59F1" authorityName="Lane" authorityYear="1956" box="[373,462,1700,1725]" class="Insecta" family="Cerambycidae" genus="Purusia" kingdom="Animalia" order="Coleoptera" pageId="9" pageNumber="160" phylum="Arthropoda" rank="genus">
