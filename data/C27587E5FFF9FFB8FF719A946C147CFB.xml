<location id="4F036028FFF9FFB8FBB29D276D257C1B" LSID="urn:lsid:plazi:treatment:C27587E5FFF9FFB8FF719A946C147CFB:4F036028FFF9FFB8FBB29D276D257C1B" box="[1048,1064,355,378]" county="Esh El Mallaha area" municipality="Paleocene" name="It" pageId="20" pageNumber="34">It</location>
