<heading id="F53DFE5DFFDFAC51121EF54EFA80F9F3" box="[890,1343,1603,1628]" centered="true" fontSize="9" level="2" pageId="9" pageNumber="181" reason="2">
<taxonomicName id="69CA32B2FFDFAC51121EF54EFA80F9F3" authorityName="Laboury &amp; Bennion &amp; Thuy &amp; Weis &amp; Fischer" authorityYear="2022" baseAuthorityName="Laboury &amp; Bennion &amp; Thuy &amp; Weis &amp; Fischer" baseAuthorityYear="2022" box="[890,1343,1603,1628]" class="Reptilia" family="Leptopterygiidae" genus="Temnodontosaurus" higherTaxonomySource="GBIF" isUncertain="true" kingdom="Animalia" order="Ichthyosauria" pageId="9" pageNumber="191" phylum="Chordata" rank="species" species="zetlandicus">
<emphasis id="9CBE9523FFDFAC51121EF54EFBCBF9F3" box="[890,1140,1604,1627]" italics="true" pageId="9" pageNumber="181">TEMNODONTOSAURUS</emphasis>
CF. 
<emphasis id="9CBE9523FFDFAC5115C0F54DFA80F9F3" box="[1188,1343,1607,1627]" italics="true" pageId="9" pageNumber="181">ZETLANDICUS</emphasis>
