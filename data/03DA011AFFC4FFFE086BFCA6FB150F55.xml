<specimenCode id="DBD51877FFC4FFFE09C4FB04FF5E08E5" box="[151,251,1153,1177]" collectionCode="MSA" country="Ireland" httpUri="http://grbio.org/cool/vvha-6rck" name="Museum of Science and Art" pageId="17" pageNumber="101">MSA351</specimenCode>
