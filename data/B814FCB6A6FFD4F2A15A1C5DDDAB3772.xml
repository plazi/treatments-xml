<subSubSection id="77626CABCBE7BE3B9F18AEA68FF0355C" pageId="null" pageNumber="310" type="description">
<paragraph id="364727B8B7793C8FDA6209855FA26F9E" pageId="null" pageNumber="310">
Ausdauernd, mit 
<normalizedToken id="323AD28567A0889CE290A04D83595EA6" originalValue="dünnem" pageId="null" pageNumber="310">duennem</normalizedToken>
Rhizom; 50-100 cm hoch; Stengel 
<emphasis id="70DE92C7E9AD7C7473C1274A50830EB5" italics="true" pageId="null" pageNumber="310">
<normalizedToken id="D13FAC9CD38B7E837145BE7F1D9A3100" originalValue="sommergrün" pageId="null" pageNumber="310">sommergruen</normalizedToken>
</emphasis>
, aufsteigend oder aufrecht, verzweigt, um die Blattansatzstellen kurz behaart, an den Kanten von kurzen, 
<normalizedToken id="90C5F36C24B29EDC178FCF76FFAA4CF2" originalValue="rückwärts" pageId="null" pageNumber="310">rueckwaerts</normalizedToken>
gerichteten, stachligen Haaren rauh. Mittlere und obere 
<normalizedToken id="FB518622A7026F32CC5EE0F7BA25F84F" originalValue="Blätter" pageId="null" pageNumber="310">Blaetter</normalizedToken>
zu 4-6 im Quirl, kurz gestielt, 
<pageBreakToken id="3078AB73E4881FDFEBAA9D6C0B8295B6" pageId="null" pageNumber="310">4</pageBreakToken>
-8 cm lang, lanzettlich, mit der 
<normalizedToken id="7AF6D501AC5E88BA77225EF57A9AB95F" originalValue="größten" pageId="null" pageNumber="310">groessten</normalizedToken>
Breite im untersten Drittel, 2-5mal so lang wie breit, mit 1 
<normalizedToken id="72D40A906E2028A2BD42326AA9CCBC24" originalValue="Längsnerv" pageId="null" pageNumber="310">Laengsnerv</normalizedToken>
(unterseits auch Netznerven sichtbar), spitz, am Rand und unterseits auf dem Mittelnerv von kurzen, 
<normalizedToken id="05E5409C68BAD2F7E44C68D7FE4C3528" originalValue="rückwärts" pageId="null" pageNumber="310">rueckwaerts</normalizedToken>
gerichteten, stachligen Haaren rauh. 
<normalizedToken id="8D7B67FAC67BB672C4AB7D201B310AA9" originalValue="Blütenstand" pageId="null" pageNumber="310">Bluetenstand</normalizedToken>
locker, am Ende der Zweige. 
<emphasis id="4B90567145B7A50FA59449E6491F8ADA" italics="true" pageId="null" pageNumber="310">
Krone 
<normalizedToken id="04B90257FA6108EF3DE049E164A685C7" originalValue="grünlichgelb" pageId="null" pageNumber="310">gruenlichgelb</normalizedToken>
</emphasis>
, mit 5 (seltener 4) grannenartig zugespitzten Zipfeln, 
<emphasis id="EF9EEDA40A65BE7DD273E33456B3B1AA" italics="true" pageId="null" pageNumber="310">im Durchmesser 2</emphasis>
- 
<emphasis id="DDD5071A03B1202C6ABD8C816BA5BB29" italics="true" pageId="null" pageNumber="310">
3 mm. Staubbeutel schmal 
<normalizedToken id="5553BA639035EC95DB10F0B216EA4368" originalValue="eiförmig" pageId="null" pageNumber="310">eifoermig</normalizedToken>
, 0,5
</emphasis>
- 
<emphasis id="4CD66240D93F53DED3E914D2D239B5F3" italics="true" pageId="null" pageNumber="310">
0,6 mm lang. Griffel bis zum Grunde 2teilig. 
<normalizedToken id="60F5D23BE10565973C66E95AD0BD50D1" originalValue="Früchte" pageId="null" pageNumber="310">Fruechte</normalizedToken>
4
</emphasis>
- 
<emphasis id="A2C2376E76464C8DDD799EC82FDFF15D" italics="true" pageId="null" pageNumber="310">6 mm hoch</emphasis>
, 
<normalizedToken id="942322492B3D423BCAA48B81286938AC" originalValue="±" pageId="null" pageNumber="310">+/-</normalizedToken>
schwarz, fleischig, glatt und kahl. - 
<normalizedToken id="814E257AE671E7C604426F38843E6293" originalValue="Blüte" pageId="null" pageNumber="310">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="2A1A18513900BECA86B4665845EABAA9" pageId="null" pageNumber="310">
<emphasis id="98FCB551A379D05158E3EE4B00ABF2CD" italics="true" pageId="null" pageNumber="310">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="18F4FFB957722CB93403F17FD8D1BF03" italics="true" pageId="null" pageNumber="310">22:</emphasis>
Material aus botanischem Garten (Poucques 1949). 
<emphasis id="76B89545D152D3700D7FF087858902BD" italics="true" pageId="null" pageNumber="310">2n</emphasis>
= 
<emphasis id="1CDCD368DB14BDC0237503C9F66B8BE5" italics="true" pageId="null" pageNumber="310">44:</emphasis>
Material aus botanischen 
<normalizedToken id="25DE81C025EF3C1A2B319F827077D030" originalValue="Gärten" pageId="null" pageNumber="310">Gaerten</normalizedToken>
und ohne Herkunftsangabe (Homeyer 1932 1936, Fagerlind 1934 1937, Poucques 1949).
</paragraph>
<paragraph id="3230858AAE2E9185E88EBA210F396197" pageId="null" pageNumber="310">
<emphasis id="ABC0FC54899BBD43C42C33399858D6FF" italics="true" pageId="null" pageNumber="310">Standort.</emphasis>
Kollin und montan. Lockere 
<normalizedToken id="239AFE359654AEB9EDD41F9078C2B66B" originalValue="Böden" pageId="null" pageNumber="310">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="A193323CBCE5B4243796ED07942C8640" originalValue="Äcker" pageId="null" pageNumber="310">Aecker</normalizedToken>
, Weinberge, 
<normalizedToken id="112151F71DFBD0C61D5E276848B28B72" originalValue="Schuttplätze" pageId="null" pageNumber="310">Schuttplaetze</normalizedToken>
, 
<normalizedToken id="71D8B331911DCB7F5C160549A9B8E2B5" originalValue="Wegränder" pageId="null" pageNumber="310">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="1526F1434F2332FC129BCA9A7E5792EE" pageId="null" pageNumber="310">
<emphasis id="FE3CD9AE806E48F9A60E7C98010BEF8D" italics="true" pageId="null" pageNumber="310">Verbreitung.</emphasis>
<normalizedToken id="6C5CD1C4AC13C2428A4D5922B7632191" originalValue="Ursprünglich" pageId="null" pageNumber="310">Urspruenglich</normalizedToken>
wahrscheinlich 
<emphasis id="B2DF0599B27D8D659E9801B7F9D4F658" italics="true" pageId="null" pageNumber="310">
<normalizedToken id="C5B1D295132D5E4C05B850A5ED142379" originalValue="ostmediterran-südwestasiatische" pageId="null" pageNumber="310">ostmediterran-suedwestasiatische</normalizedToken>
Pflanze
</emphasis>
, heute im ganzen Mittelmeergebiet aus 
<normalizedToken id="4C1F0A45BAAC912240265D19BF87074E" originalValue="früheren" pageId="null" pageNumber="310">frueheren</normalizedToken>
Kulturen verwildert. - Im Gebiet: Wallis (
<normalizedToken id="9F2BDC5B7AD31353D602492AF6A18DF3" originalValue="aufwärts" pageId="null" pageNumber="310">aufwaerts</normalizedToken>
bis Naters, kaum 
<normalizedToken id="D3CA70E69CE965710DE4130E795A4AD0" originalValue="ursprünglich" pageId="null" pageNumber="310">urspruenglich</normalizedToken>
, aber weitgehend 
<normalizedToken id="D4B87E46B25F755604CCC8FDCE020703" originalValue="eingebürgert" pageId="null" pageNumber="310">eingebuergert</normalizedToken>
); 
<normalizedToken id="9ACC705CE60D03D9FAC52D97B31AFD33" originalValue="früher" pageId="null" pageNumber="310">frueher</normalizedToken>
oft angebaut und gelegentlich verwildert, so im Aostatal (Aosta, St-Christophe), in der Waadt um Yvorne, im 
<normalizedToken id="C5F608F2953785D8CEFA10AFD40BBBAC" originalValue="Elsaß" pageId="null" pageNumber="310">Elsass</normalizedToken>
(zwischen Rouffach und Westhalten), im Veltlin (zwischen Montagna und Ponte) und bei Bergamo.
</paragraph>
</subSubSection>
