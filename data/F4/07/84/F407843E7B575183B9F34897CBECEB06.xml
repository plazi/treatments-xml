<paragraph pageId="0" pageNumber="181">Type species.</paragraph>
<paragraph pageId="0" pageNumber="181">
<taxonomicName authorityName="Pocock" authorityYear="1895" class="Arachnida" family="Barychelidae" genus="Cyrtogrammomma" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Cyrtogrammomma monticola" order="Araneae" pageId="0" pageNumber="181" phylum="Arthropoda" rank="species" species="monticola">
<emphasis italics="true" pageId="0" pageNumber="181">Cyrtogrammomma monticola</emphasis>
