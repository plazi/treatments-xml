<emphasis id="55CDEF554014466AFF768712E80EB220" box="[163,307,568,590]" italics="true" pageId="12" pageNumber="1264">
<typeStatus id="B8028DE54014466AFF768712E9E5B223" box="[163,216,569,590]" pageId="12" pageNumber="1264">Type</typeStatus>
species:
</emphasis>
<taxonomicName id="A0B948C44014466AFEEA8713EB98B220" authority="Say, 1818" authorityName="Say" authorityYear="1818" box="[319,677,568,589]" class="Malacostraca" family="Haustoriidae" genus="Lepidactylus" kingdom="Animalia" order="Amphipoda" pageId="12" pageNumber="1264" phylum="Arthropoda" rank="species" species="dysticus">
<emphasis id="55CDEF554014466AFEEA8713EB0EB220" box="[319,563,568,589]" italics="true" pageId="12" pageNumber="1264">Lepidactylus dysticus</emphasis>
<bibRefCitation id="03284EB64014466AFDEF8713EB98B220" author="Say T" box="[570,677,568,589]" pageId="12" pageNumber="1264" pagination="374 - 401" refId="ref10772" refString="Say T. 1818. An account of the Crustacea of the United States. Journal of the Academy of Natural Sciences of Philadelphia 1: 374 - 401." type="journal article" year="1818">Say, 1818</bibRefCitation>
