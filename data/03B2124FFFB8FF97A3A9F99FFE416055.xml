<quantity id="4CE30EBCFFB8FF97A045F9BAFC346101" box="[891,936,1591,1617]" metricMagnitude="0" metricUnit="m" metricValue="2.0" pageId="11" pageNumber="462" unit="m" value="2.0">2 m</quantity>
