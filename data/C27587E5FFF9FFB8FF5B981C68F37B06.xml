</paragraph>
<paragraph id="4A6336F3FFF9FFB8FF3D989268277869" blockId="20.[151,757,1208,1347]" pageId="20" pageNumber="34">
1952. 
<taxonomicName id="8DDC4D70FFF9FFB8FF7098926B1A798A" authority="PLUMMER." authorityName="PLUMMER." box="[218,535,1238,1259]" class="Nodosariata" family="Nodosariidae" genus="Nodosaria" kingdom="Chromista" order="Nodosariida" pageId="20" pageNumber="34" phylum="Foraminifera" rank="species" species="vertebralis">
<emphasis id="78A8EAE1FFF9FFB8FF70989268A1798A" box="[218,428,1238,1259]" italics="true" pageId="20" pageNumber="34">Nodosaria vertebralis</emphasis>
PLUMMER.
</taxonomicName>
- NAKKADY, p. 423, pl. 7, fig. 4.
</paragraph>
<paragraph id="4A6336F3FFF9FFB8FF3D995468887822" blockId="20.[151,757,1208,1347]" pageId="20" pageNumber="34">
