<taxonomicName id="8DDC4D70FFF9FFB8FF7099546B167847" authority="PLUMMER." authorityName="PLUMMER." box="[218,539,1296,1318]" class="Nodosariata" family="Nodosariidae" genus="Nodosaria" kingdom="Chromista" order="Nodosariida" pageId="20" pageNumber="34" phylum="Foraminifera" rank="species" species="vertebralis">
