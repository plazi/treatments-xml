<subSubSection id="A894AD313CDFB655D6C9DB105F05607D" pageId="null" pageNumber="47" type="description">
<paragraph id="C5A246089BA1C9720F0AE4F5DA047048" pageId="null" pageNumber="47">
Unterscheidet sich von 
<taxonomicName id="C49BA9573C7E5D8E4F73AEAA3E14F8FB" class="Magnoliopsida" family="Ranunculaceae" genus="Thalictrum" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="47" phylum="Tracheophyta" rank="species" species="flavum">
<emphasis id="7109F321A3E4C582CE8EF77D6A1A66C9" italics="true" pageId="null" pageNumber="47">T. flavum</emphasis>
</taxonomicName>
(Nr. 4c) durch folgende Merkmale: 
<emphasis id="FB0456BD11E0D564BDD61F604D1E7C43" italics="true" pageId="null" pageNumber="47">
Keine unterirdischen 
<normalizedToken id="D77370CB03E3454BB2CCF715B69C85F9" originalValue="Ausläufer" pageId="null" pageNumber="47">Auslaeufer</normalizedToken>
vorhanden. 
<normalizedToken id="EC665750C59AB2C1F5B15D87B2C2B177" originalValue="Teilblätter" pageId="null" pageNumber="47">Teilblaetter</normalizedToken>
an den obersten 
<normalizedToken id="286DCDA6E2D5444D9963881E2A2D102C" originalValue="Stengelblättern" pageId="null" pageNumber="47">Stengelblaettern</normalizedToken>
<normalizedToken id="D7185410D1AF2ED1673C0A0416008F17" originalValue="über" pageId="null" pageNumber="47">ueber</normalizedToken>
5mal so lang wie breit;
</emphasis>
auch an jungen 
<normalizedToken id="60122523197AE0AB78ED6CA91A6FB44B" originalValue="Blättern" pageId="null" pageNumber="47">Blaettern</normalizedToken>
nie 
<normalizedToken id="A16C955D902962C5D1A271F7C322438A" originalValue="Nebenblättchen" pageId="null" pageNumber="47">Nebenblaettchen</normalizedToken>
vorhanden. - 
<normalizedToken id="C121B3960524941166FEE711EDF503AA" originalValue="Blüte" pageId="null" pageNumber="47">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="24DA7B1FD5D6401AD1B544842A04BE71" pageId="null" pageNumber="47">
<emphasis id="3A8062BB7559B59F4CCC373DF2123D1C" italics="true" pageId="null" pageNumber="47">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="DF2395D6E60E6E6BC1D393C4B2A773C3" italics="true" pageId="null" pageNumber="47">28:</emphasis>
Material aus botanischen 
<normalizedToken id="7D3DAF9181078DDB5F91237A7D7D464B" originalValue="Gärten" pageId="null" pageNumber="47">Gaerten</normalizedToken>
(Langlet 1927, Kuhn 1928, Picci 1969).
</paragraph>
<paragraph id="6E66618E2C9277C1A00231DB251E51A0" pageId="null" pageNumber="47">
<emphasis id="C7F60AA0504B85A2B19FBE0B3CC2EC54" italics="true" pageId="null" pageNumber="47">Standort.</emphasis>
Wahrscheinlich wie 
<taxonomicName id="7D28E3B46A7EEC69EF3FBB2E21CE21F5" class="Magnoliopsida" family="Ranunculaceae" genus="Thalictrum" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="47" phylum="Tracheophyta" rank="species" species="exaltatum">
<emphasis id="ACC313A527CC39217127D84AC58DC4A7" italics="true" pageId="null" pageNumber="47">T. exaltatum</emphasis>
</taxonomicName>
(Nr. 4d).
</paragraph>
<paragraph id="0354ACD2434E674AC8FCDEBE66FCD0DD" pageId="null" pageNumber="47">
<emphasis id="5689519D42AF77CFA9B7D47DCDC44730" italics="true" pageId="null" pageNumber="47">
Verbreitung. 
<normalizedToken id="012AFF3056F99BC793DAB5ABE0B950C6" originalValue="Südosteuropäische" pageId="null" pageNumber="47">Suedosteuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="12C8483548137A709D6DC743A37CFAB9" originalValue="Westwärts" pageId="null" pageNumber="47">Westwaerts</normalizedToken>
bis oberes Donautal (
<normalizedToken id="19251B54561DD61F14953AD7C01A1560" originalValue="östliches" pageId="null" pageNumber="47">oestliches</normalizedToken>
Bayern), Etschtal (Bozen, Meran), Apennin, 
<normalizedToken id="24DA0BA26932D8130AD219ACC2BBCC9A" originalValue="nordwärts" pageId="null" pageNumber="47">nordwaerts</normalizedToken>
bis 
<normalizedToken id="ADD4F369BD439754CE1D33AD16C75E46" originalValue="Nordrußland" pageId="null" pageNumber="47">Nordrussland</normalizedToken>
, 
<normalizedToken id="27A2B3D775060321F47F1CF7A610ECAA" originalValue="südwärts" pageId="null" pageNumber="47">suedwaerts</normalizedToken>
bis 
<normalizedToken id="68A8C68E24343590E5EB1B0EB3E0CA73" originalValue="südliche" pageId="null" pageNumber="47">suedliche</normalizedToken>
Balkanhalbinsel, Ostgrenze nicht bekannt. - Im Gebiet: Untermais und Nals bei Meran.
</paragraph>
</subSubSection>
