<taxonomicName id="40BF5F03F50879AE20FFEE7587D1F2D3" authority="" authorityName="Rakotonirina &amp; Fisher" authorityYear="2022" class="Insecta" family="Formicidae" genus="Camponotus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Camponotus (Tanaemyrmex)" order="Hymenoptera" pageId="0" pageNumber="1" phylum="Arthropoda" rank="subGenus" subGenus="Tanaemyrmex">Camponotus (Tanaemyrmex)</taxonomicName>
