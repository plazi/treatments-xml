<subSubSection id="6BE3EC5CA707F55B3B61B2E9533589A0" pageId="null" pageNumber="208" type="description">
<paragraph id="15C755AB20191C4C5C1FDC65896837E6" pageId="null" pageNumber="208">
Unterscheidet sich von 
<taxonomicName id="C6507AD6339E72050DDC3C638FE96A6E" class="Magnoliopsida" family="Brassicaceae" genus="Cardamine" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="208" phylum="Tracheophyta" rank="species" species="kitaibelii">
<emphasis id="6DA3A20E395D208C809D7FDCAD2DD9D6" italics="true" pageId="null" pageNumber="208">C. Kitaibelii</emphasis>
</taxonomicName>
(Nr. 13) durch folgende Merkmale: Stengel kahl; 
<emphasis id="4FCF24111859C9B7F01C4437EB0CBAD6" italics="true" pageId="null" pageNumber="208">
<normalizedToken id="15DC3D1BF1CBB6BD1E573119B061AC16" originalValue="Blätter" pageId="null" pageNumber="208">Blaetter</normalizedToken>
mit 3 
<normalizedToken id="90A26E3746C3391A4826195FFEDC67B5" originalValue="Teilblättern" pageId="null" pageNumber="208">Teilblaettern</normalizedToken>
;
</emphasis>
<normalizedToken id="D5C8601ACFD877A618EEC4984A2AF099" originalValue="Kronblätter" pageId="null" pageNumber="208">Kronblaetter</normalizedToken>
12 
<emphasis id="429B7AEDF3B08F1AF9B3285CA6B823EB" italics="true" pageId="null" pageNumber="208">-</emphasis>
18 mm lang, 
<emphasis id="FBA2B096E656E1719720876CBFC48F2F" italics="true" pageId="null" pageNumber="208">
<normalizedToken id="B322497C008EABE2A138227A9D7D2BE8" originalValue="weiß" pageId="null" pageNumber="208">weiss</normalizedToken>
oder hellgelb;
</emphasis>
<normalizedToken id="DBEDDDD2CBB17F4C96D3E4F3C56529D2" originalValue="Staubblätter" pageId="null" pageNumber="208">Staubblaetter</normalizedToken>
etwa so lang wie die Krone; Griffel an der Frucht 10 
<emphasis id="F13407D593C40368E624BE3CA83540F6" italics="true" pageId="null" pageNumber="208">-</emphasis>
15 mm lang. - 
<normalizedToken id="2743C5A30EB88111CACC2632A1F51D3E" originalValue="Blüte" pageId="null" pageNumber="208">Bluete</normalizedToken>
: 
<normalizedToken id="AC49F37DCD2A0C711956A1E30A16554F" originalValue="Frühling" pageId="null" pageNumber="208">Fruehling</normalizedToken>
und 
<normalizedToken id="9BA0C1AEB5FBCBF19717FBCFF29E06BC" originalValue="früher" pageId="null" pageNumber="208">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="E93A8B5DC393C52494C049223EDEA1EF" pageId="null" pageNumber="208">
<pageBreakToken id="D61BFE0796C1CD26412EC3B9AB28A842" pageId="null" pageNumber="208">(</pageBreakToken>
Banach-Pogan 1954).
</paragraph>
<paragraph id="F21313713869B6169142F6EF387B1F36" pageId="null" pageNumber="208">
<emphasis id="4A16FA38908F97A5A8C8BB6A303143C9" italics="true" pageId="null" pageNumber="208">Standort.</emphasis>
Kollin und montan, selten subalpin. Lockere, ziemlich feuchte, 
<normalizedToken id="25E1AB66AE5F1CE467BA047E9D0B993F" originalValue="nährstoffreiche" pageId="null" pageNumber="208">naehrstoffreiche</normalizedToken>
, humose, tonige 
<normalizedToken id="A2E095A9FA4415D41E648FD1A836C6F4" originalValue="Böden" pageId="null" pageNumber="208">Boeden</normalizedToken>
in schattigen Lagen. 
<normalizedToken id="8D69790FD038274B72411E59C22BD908" originalValue="Buchenwälder" pageId="null" pageNumber="208">Buchenwaelder</normalizedToken>
und 
<normalizedToken id="14CF486CCDCA58482C84FBE2E06F5FF2" originalValue="Buchenmischwälder" pageId="null" pageNumber="208">Buchenmischwaelder</normalizedToken>
, seltener Hochstaudenfluren. 
<emphasis id="59E0A7C754A067C402AA40A762A59B55" italics="true" pageId="null" pageNumber="208">Acero-Fagetum</emphasis>
Bartsch 1940.
</paragraph>
<paragraph id="62CA69715F594A85689D66C6627D54A3" pageId="null" pageNumber="208">
<emphasis id="B28A3DB2CC1CECA7232583864B634E5C" italics="true" pageId="null" pageNumber="208">
Verbreitung. Mittel- und 
<normalizedToken id="9D48A318AD4B56BEA0BFB2B497F7350A" originalValue="südeuropäische" pageId="null" pageNumber="208">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="765907E60608A2D2161F089E7CC4CF36" italics="true" pageId="null" pageNumber="208">
<normalizedToken id="DFC3F72B9590C19FFAE7AD6918B8C1FC" originalValue="östlich" pageId="null" pageNumber="208">oestlich</normalizedToken>
</emphasis>
)
<emphasis id="D6761E77F9AEECCFCA589AC67D3CA00A" italics="true" pageId="null" pageNumber="208">:</emphasis>
Ostalpen, mitteldeutsche, tschechoslowakische und 
<normalizedToken id="91A0F33E7DA7C71BDB12D34581142112" originalValue="südpolnische" pageId="null" pageNumber="208">suedpolnische</normalizedToken>
Gebirge (
<normalizedToken id="EEC5C16160739787B823D0D3DA4A500F" originalValue="westwärts" pageId="null" pageNumber="208">westwaerts</normalizedToken>
bis Oberpfalz und zum Bayrischen Wald), Ostalpen (
<normalizedToken id="EF8AF66A3A32C135A4F7560F6CD536E5" originalValue="westwärts" pageId="null" pageNumber="208">westwaerts</normalizedToken>
bis 
<normalizedToken id="C1588F636E11956DDCE7C49314C50E3A" originalValue="Allgäu" pageId="null" pageNumber="208">Allgaeu</normalizedToken>
und Bergamasker Alpen, isoliert bei Biella im Piemont), mittlerer und 
<normalizedToken id="E242A9784324E1DCAE81985B74134088" originalValue="südlicher" pageId="null" pageNumber="208">suedlicher</normalizedToken>
Apennin, ungarische Mittelgebirge, Karpaten, Gebirge der Balkanhalbinsel (
<normalizedToken id="39DB57AF53EA2937C9C7AEE075799FC8" originalValue="südwärts" pageId="null" pageNumber="208">suedwaerts</normalizedToken>
bis Albanien und Mazedonien). Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: 
<normalizedToken id="67E20A68817448B9F7F38E9446D80549" originalValue="Allgäu" pageId="null" pageNumber="208">Allgaeu</normalizedToken>
(Oberstdorf), 
<normalizedToken id="1DF007867C6E691AFA8AF9DA871B3378" originalValue="Südalpen" pageId="null" pageNumber="208">Suedalpen</normalizedToken>
(Biella, 
<normalizedToken id="1493AC5B43767E137EC7B6A644A039B8" originalValue="südöstliche" pageId="null" pageNumber="208">suedoestliche</normalizedToken>
Bergamasker Alpen)
</paragraph>
</subSubSection>
