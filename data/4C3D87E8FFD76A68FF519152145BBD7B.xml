<subSubSection id="8C8E6575FFD76A68FCED91ED1A34B3D8" pageId="44" pageNumber="802" type="reference_group">
<emphasis id="F6E0EAECFFD76A68FCED91ED1DACBCE7" bold="true" box="[785,940,1972,2005]" pageId="44" pageNumber="802">Taxonomy.</emphasis>
<taxonomicName id="03944D7DFFD76A68FC3691ED1D56BCCC" authority="Parnaby, 2009" authorityName="Parnaby" authorityYear="2009" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="44" pageNumber="802" phylum="Chordata" rank="species" species="corbeni">Nyctophilus corbeni Parnaby, 2009</taxonomicName>
, “Old Coghill Track, 0.7 km east of junction with track to main Gilgai Waterhole; formerly Gilgai Flora Reserve, Pilliga East State Forest, 
<collectingRegion id="0650F81CFFD76A68FBA79E0B1B5BB341" box="[1115,1371,2130,2163]" country="Australia" name="New South Wales" pageId="44" pageNumber="802">New South Wales</collectingRegion>
. Approximate altitude 
<quantity id="036C9B1BFFD76A68FBB09E231AA5B3A9" box="[1100,1189,2170,2203]" metricMagnitude="2" metricUnit="m" metricValue="2.35" pageId="44" pageNumber="802" unit="m" value="235.0">235 m</quantity>
. Coordinates obtained from a Garmin GPS are 
<geoCoordinate id="A1A05039FFD76A68FB029EF81B56B3F0" box="[1278,1366,2209,2242]" degrees="30" minutes="29" pageId="44" pageNumber="802">
30° 
<geoCoordinate id="A1A05039FFD76A68FAC49EF81B56B3F0" box="[1336,1366,2209,2242]" degrees="29" direction="south" minutes="587" orientation="latitude" pageId="44" pageNumber="802">29</geoCoordinate>
</geoCoordinate>
° 587s, 
<geoCoordinate id="A1A05039FFD76A68FC999E901DC9B3D8" box="[869,969,2249,2282]" degrees="149" minutes="20" pageId="44" pageNumber="802">149° 20</geoCoordinate>
/ BoE.”
</subSubSection>
<subSubSection id="8C8E6575FFD76A68FCEF9EA91FF9B2EA" pageId="44" pageNumber="802" type="discussion">
<taxonomicName id="03944D7DFFD76A68FCEF9EA91A0EB223" authorityName="Parnaby" authorityYear="2009" box="[787,1038,2288,2321]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="44" pageNumber="802" phylum="Chordata" rank="species" species="corbeni">Nyctophilus corbeni</taxonomicName>
is in the 
<taxonomicName id="03944D7DFFD76A68FB579EA91AF4B223" authorityName="J. E. Gray" authorityYear="1844" box="[1195,1268,2288,2321]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="44" pageNumber="802" phylum="Chordata" rank="species" species="major">major</taxonomicName>
species group, closely related to 
<taxonomicName id="03944D7DFFD76A68FB919F411ADFB20B" authorityName="J. E. Gray" authorityYear="1844" box="[1133,1247,2328,2361]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="44" pageNumber="803" phylum="Chordata" rank="species" species="major">N. major</taxonomicName>
. 
<taxonomicName id="03944D7DFFD76A68FB119F411D9CB252" authorityName="Parnaby" authorityYear="2009" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="44" pageNumber="802" phylum="Chordata" rank="species" species="corbeni">Nyctophilus corbeni</taxonomicName>
along with 
<taxonomicName id="03944D7DFFD76A68FBB49F661ABDB252" authorityName="J. E. Gray" authorityYear="1844" box="[1096,1213,2367,2400]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="44" pageNumber="803" phylum="Chordata" rank="species" species="major">N. major</taxonomicName>
, N. 
<taxonomicName id="03944D7DFFD76A68FB079F661B5CB252" authorityName="Thomas" authorityYear="1915" box="[1275,1372,2367,2400]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="44" pageNumber="802" phylum="Chordata" rank="species" species="sherrini">sherrini</taxonomicName>
, and 
<taxonomicName id="03944D7DFFD76A68FF139F311F84B2BB" authorityName="Parnaby" authorityYear="2009" box="[239,388,2408,2441]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="44" pageNumber="802" phylum="Chordata" rank="species" species="shirleyae">N. shirleyae</taxonomicName>
were Pacvioly included under 
<taxonomicName id="03944D7DFFD76A68FCA39F311A12B2BB" baseAuthorityName="E. Geoffroy" baseAuthorityYear="1806" box="[863,1042,2408,2441]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="44" pageNumber="803" phylum="Chordata" rank="species" species="timoriensis">N. timoriensis</taxonomicName>
, but they were recently recognized as distinct species, and the name 
<taxonomicName id="03944D7DFFD76A68FCC19FD61DC3B282" baseAuthorityName="E. Geoffroy" baseAuthorityYear="1806" box="[829,963,2447,2480]" class="Mammalia" family="Vespertilionidae" genus="Nyctophilus" kingdom="Animalia" order="Chiroptera" pageId="44" pageNumber="802" phylum="Chordata" rank="species" species="timoriensis">timoriensis</taxonomicName>
is now regarded as a species inquirenda. Monotypic.
</subSubSection>
</paragraph>
<subSubSection id="8C8E6575FFD76A68FF519FBF1B5FB2CD" box="[173,1375,2534,2559]" pageId="44" pageNumber="802" type="distribution">
<caption id="90EB6676FFD76A68FF519FBF1B5FB2CD" ID-DOI="http://doi.org/10.5281/zenodo.6397938" ID-Zenodo-Dep="6397938" box="[173,1375,2534,2559]" httpUri="https://zenodo.org/record/6397938/files/figure.png" inLine="true" pageId="44" pageNumber="802" targetBox="[170,762,1987,2402]" targetPageId="44">
<paragraph id="C42B36FEFFD76A68FF519FBF1B5FB2CD" blockId="44.[173,1382,2408,3467]" box="[173,1375,2534,2559]" pageId="44" pageNumber="802">
<emphasis id="F6E0EAECFFD76A68FF519FBF1F5DB2CD" bold="true" box="[173,349,2534,2559]" pageId="44" pageNumber="802">Distribution.</emphasis>
SE 
<collectingRegion id="0650F81CFFD76A68FE6B9FBF1C43B2CD" box="[407,579,2534,2559]" country="Australia" name="Queensland" pageId="44" pageNumber="802">Queensland</collectingRegion>
, 
<collectingRegion id="0650F81CFFD76A68FDAF9FBF1D47B2CD" box="[595,839,2534,2559]" country="Australia" name="New South Wales" pageId="44" pageNumber="802">New South Wales</collectingRegion>
, NW 
<taxonomicName id="03944D7DFFD76A68FC689FBF1A06B2CD" box="[916,1030,2534,2559]" class="Insecta" family="Geometridae" genus="Victoria" kingdom="Animalia" order="Lepidoptera" pageId="44" pageNumber="802" phylum="Arthropoda" rank="genus">
<collectingRegion id="0650F81CFFD76A68FC689FBF1A06B2CD" box="[916,1030,2534,2559]" country="Australia" name="Victoria" pageId="44" pageNumber="802">Victoria</collectingRegion>
</taxonomicName>
, and SE 
<collectingRegion id="0650F81CFFD76A68FB7E9FBF1B5BB2CD" box="[1154,1371,2534,2559]" country="Australia" name="South Australia" pageId="44" pageNumber="802">South Australia</collectingRegion>
