<taxonomicName id="379919D1FF9EFF69B1103C2320A407AE" authority="Aubl. (1775)" authorityName="Aublet" authorityYear="1775" class="Magnoliopsida" family="Fabaceae" genus="Parivoa" kingdom="Plantae" order="Fabales" pageId="4" pageNumber="193" phylum="Tracheophyta" rank="species" species="grandiflora">
