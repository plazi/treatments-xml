<paragraph id="F0266252FF9EFF69B5E63C4821C5078A" blockId="4.[136,1452,1847,1982]" pageId="4" pageNumber="193">
<taxonomicName id="379919D1FF9EFF69B5E63C48225F0766" authority="Rudge (1808)" authorityName="Rudge" authorityYear="1808" box="[136,557,1847,1874]" genus="Dimorpha" pageId="4" pageNumber="193" rank="species" species="grandiflora">
