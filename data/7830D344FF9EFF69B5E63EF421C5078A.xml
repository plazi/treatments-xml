Willd. (1802)
</taxonomicName>
. 
<emphasis id="C2EDBE40FF9EFF69B45D3C23213C0741" box="[307,334,1884,1909]" italics="true" pageId="4" pageNumber="193">D.</emphasis>
<taxonomicName id="379919D1FF9EFF69B4363C24220E0742" authority="Willd. (1802)" authorityName="Willdenow" authorityYear="1802" baseAuthorityName="Aublet" box="[344,636,1883,1910]" genus="Dimorpha" pageId="4" pageNumber="193" rank="species" species="grandiflora">
