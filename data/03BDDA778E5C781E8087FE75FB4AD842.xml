(
<bibRefCitation id="EF8516908E5C781E8188FE76FDCBDDA3" author="Rylov, V. M." box="[425,566,442,469]" pageId="2" pageNumber="3" pagination="52 - 95" refId="ref4798" refString="Rylov, V. M. 1923. On the Crustacea - Eucopepoda fauna of Manchuria. Annuaire du Musee Zoologique de l'Academie des Sciences de Russie, 24, 52 - 95, plates 1 - 3 [In Russian]." type="journal article" year="1923">Rylov, 1923</bibRefCitation>
