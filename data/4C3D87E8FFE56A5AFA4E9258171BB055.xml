<subSubSection id="8C8E6575FFE56A5AFA499F1F192AB255" box="[1461,1834,2374,2407]" pageId="30" pageNumber="788" type="breeding">
<paragraph id="C42B36FEFFE56A5AFA499F1F192AB255" blockId="30.[1458,2666,1584,2919]" box="[1461,1834,2374,2407]" pageId="30" pageNumber="788">
