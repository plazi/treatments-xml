<typeStatus id="6A0B883606092E45FEC3FA62FE2A222D" box="[332,448,1869,1895]" pageId="35" pageNumber="336">Lectotype</typeStatus>
: MNHN-B22033, male, CL 
<quantity id="72489B7106092E45FD71FA63FC8E222D" box="[766,868,1868,1895]" metricMagnitude="-2" metricUnit="m" metricValue="2.11" pageId="35" pageNumber="336" unit="mm" value="21.1">21.1 mm</quantity>
