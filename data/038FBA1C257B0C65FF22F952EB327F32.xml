<location id="8EF95DD1257B0C64FC1AF848EB487A81" LSID="urn:lsid:plazi:treatment:038FBA1C257B0C65FF22F952EB327F32:8EF95DD1257B0C64FC1AF848EB487A81" box="[943,1063,1976,2002]" country="Turkey" county="Akcay" latitude="37.4396" longLatPrecision="6" longitude="31.8" municipality="Gokcehuyuk" name="Seydisehir" pageId="16" pageNumber="467" stateProvince="Konya">Seydişehir</location>
, 
<geoCoordinate id="EE126DCD257B0C64FB87F848EBE27A81" box="[1074,1165,1976,2002]" degrees="37.4396" direction="north" orientation="latitude" pageId="16" pageNumber="467" precision="5" value="37.4396">37.4396</geoCoordinate>
<geoCoordinate id="EE126DCD257B0C64FB21F848EB9C7A81" box="[1172,1267,1976,2002]" degrees="31.8000" direction="east" orientation="longitude" pageId="16" pageNumber="467" precision="5" value="31.8">31.8000</geoCoordinate>
