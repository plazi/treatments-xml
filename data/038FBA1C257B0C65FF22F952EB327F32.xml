<subSubSection id="C33C5881257B0C65FF72F82CEE467C82" lastPageId="17" lastPageNumber="468" pageId="16" pageNumber="467" type="diagnosis">
<paragraph id="8B990B0A257B0C65FF72F82CEE467C82" blockId="16.[151,1437,1904,2039]" lastBlockId="17.[151,1437,151,609]" lastPageId="17" lastPageNumber="468" pageId="16" pageNumber="467">
<emphasis id="B952D718257B0C64FF72F82CEE2D7AA5" bold="true" box="[199,322,2012,2038]" pageId="16" pageNumber="467">Diagnosis.</emphasis>
<taxonomicName id="4C267089257B0C64FEF9F82CEDEA7AA5" authorityName="Yogurtcuoglu, Kaya, Ozulug &amp; Freyhof" authorityYear="2021" box="[332,645,2012,2038]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="16" pageNumber="467" phylum="Chordata" rank="species" species="isauricus">
<emphasis id="B952D718257B0C64FEF9F82CEDEA7AA5" box="[332,645,2012,2038]" italics="true" pageId="16" pageNumber="467">Oxynoemacheilus isauricus</emphasis>
</taxonomicName>
is distinguished from all other species of the 
<taxonomicName id="4C267089257B0C64FB13F82DEA467AA5" baseAuthorityName="Steindachner" baseAuthorityYear="1897" box="[1190,1321,2013,2039]" class="Actinopterygii" family="Nemacheilidae" genus="Orthrias" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cypriniformes" pageId="16" pageNumber="467" phylum="Chordata" rank="species" species="angorae">
<emphasis id="B952D718257B0C64FB13F82DEA467AA5" box="[1190,1321,2013,2039]" italics="true" pageId="16" pageNumber="467">O. angorae</emphasis>
</taxonomicName>
group by having a very slender caudal peduncle (caudal peduncle depth 2.2–2.6 times in its length vs. 
<quantity id="4CDEA6EF257A0C65FB39FF67EB947DE2" box="[1164,1275,151,177]" metricMagnitude="-2" metricUnit="m" metricValue="3.683" metricValueMax="4.064" metricValueMin="3.302" pageId="17" pageNumber="468" unit="in" value="1.45" valueMax="1.6" valueMin="1.3">1.3–1.6 in</quantity>
<taxonomicName id="4C267089257A0C65FAB5FF67EAF97DE2" box="[1280,1430,151,177]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="anatolicus">
<emphasis id="B952D718257A0C65FAB5FF67EAF97DE2" box="[1280,1430,151,177]" italics="true" pageId="17" pageNumber="468">O. anatolicus</emphasis>
</taxonomicName>
, 
<quantity id="4CDEA6EF257A0C65FF22FF4AEE657D86" box="[151,266,186,213]" metricMagnitude="-2" metricUnit="m" metricValue="4.191" metricValueMax="4.572" metricValueMin="3.81" pageId="17" pageNumber="468" unit="in" value="1.65" valueMax="1.8" valueMin="1.5">1.5–1.8 in</quantity>
<taxonomicName id="4C267089257A0C65FEA6FF4BEEFB7D87" baseAuthorityName="Steindachner" baseAuthorityYear="1897" box="[275,404,187,213]" class="Actinopterygii" family="Nemacheilidae" genus="Orthrias" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="angorae">
<emphasis id="B952D718257A0C65FEA6FF4BEEFB7D87" box="[275,404,187,213]" italics="true" pageId="17" pageNumber="468">O. angorae</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C267089257A0C65FE7BFF4BEDEF7D87" baseAuthorityName="FSJF" baseAuthorityYear="2323" box="[462,640,187,213]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="germencicus">
<emphasis id="B952D718257A0C65FE7BFF4BEDEF7D87" box="[462,640,187,213]" italics="true" pageId="17" pageNumber="468">O. germencicus</emphasis>
</taxonomicName>
, and 
<quantity id="4CDEA6EF257A0C65FD74FF4AEC5B7D86" box="[705,820,186,213]" metricMagnitude="-2" metricUnit="m" metricValue="4.318" metricValueMax="4.826" metricValueMin="3.81" pageId="17" pageNumber="468" unit="in" value="1.7" valueMax="1.9" valueMin="1.5">1.5–1.9 in</quantity>
<taxonomicName id="4C267089257A0C65FC89FF4BECB77D86" box="[828,984,187,213]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="eregliensis">
<emphasis id="B952D718257A0C65FC89FF4BECB77D86" box="[828,984,187,213]" italics="true" pageId="17" pageNumber="468">O. eregliensis</emphasis>
</taxonomicName>
; see details for other species below). It is further differentiated from 
<taxonomicName id="4C267089257A0C65FE53FF2FED107DAA" box="[486,639,223,249]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="anatolicus">
<emphasis id="B952D718257A0C65FE53FF2FED107DAA" box="[486,639,223,249]" italics="true" pageId="17" pageNumber="468">O. anatolicus</emphasis>
</taxonomicName>
, 
<taxonomicName id="4C267089257A0C65FD3AFF2FEC7F7DAB" baseAuthorityName="Steindachner" baseAuthorityYear="1897" box="[655,784,223,249]" class="Actinopterygii" family="Nemacheilidae" genus="Orthrias" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="angorae">
<emphasis id="B952D718257A0C65FD3AFF2FEC7F7DAB" box="[655,784,223,249]" italics="true" pageId="17" pageNumber="468">O. angorae</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C267089257A0C65FCFFFF2FEC897DAA" box="[842,998,223,249]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="eregliensis">
<emphasis id="B952D718257A0C65FCFFFF2FEC897DAA" box="[842,998,223,249]" italics="true" pageId="17" pageNumber="468">O. eregliensis</emphasis>
</taxonomicName>
by possession of a shorter head (head length 21–24% SL vs. 
<quantity id="4CDEA6EF257A0C65FE2AFEF3ED6A7C4E" box="[415,517,259,285]" metricMagnitude="-1" metricUnit="m" metricValue="6.476999999999999" metricValueMax="6.858" metricValueMin="6.096" pageId="17" pageNumber="468" unit="in" value="25.5" valueMax="27.0" valueMin="24.0">24–27 in</quantity>
<taxonomicName id="4C267089257A0C65FDBBFEF3EDC87C4E" box="[526,679,259,285]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="anatolicus">
<emphasis id="B952D718257A0C65FDBBFEF3EDC87C4E" box="[526,679,259,285]" italics="true" pageId="17" pageNumber="468">O. anatolicus</emphasis>
</taxonomicName>
; 
<quantity id="4CDEA6EF257A0C65FD0DFEF3EC727C4E" box="[696,797,259,285]" metricMagnitude="-1" metricUnit="m" metricValue="6.223000000000001" metricValueMax="6.604000000000001" metricValueMin="5.8420000000000005" pageId="17" pageNumber="468" unit="in" value="24.5" valueMax="26.0" valueMin="23.0">23–26 in</quantity>
<taxonomicName id="4C267089257A0C65FC92FEF3ECC77C4F" baseAuthorityName="Steindachner" baseAuthorityYear="1897" box="[807,936,259,285]" class="Actinopterygii" family="Nemacheilidae" genus="Orthrias" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="angorae">
<emphasis id="B952D718257A0C65FC92FEF3ECC77C4F" box="[807,936,259,285]" italics="true" pageId="17" pageNumber="468">O. angorae</emphasis>
</taxonomicName>
and 
<quantity id="4CDEA6EF257A0C65FC51FEF3EB267C4E" box="[996,1097,259,285]" metricMagnitude="-1" metricUnit="m" metricValue="6.35" metricValueMax="6.604" metricValueMin="6.096" pageId="17" pageNumber="468" unit="in" value="25.0" valueMax="26.0" valueMin="24.0">24–26 in</quantity>
<taxonomicName id="4C267089257A0C65FBE7FEF3EB807C4E" box="[1106,1263,259,285]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="eregliensis">
<emphasis id="B952D718257A0C65FBE7FEF3EB807C4E" box="[1106,1263,259,285]" italics="true" pageId="17" pageNumber="468">O. eregliensis</emphasis>
</taxonomicName>
), a moderately deep emarginate caudal fin (vs. slightly emarginate or almost truncate) in which the shortest middle caudal-fin ray is 71–85% of the longest ray of the upper caudal-fin lobe (vs. 
<quantity id="4CDEA6EF257A0C65FC21FEBBEC957C36" box="[916,1018,331,357]" metricMagnitude="0" metricUnit="m" metricValue="2.2479" metricValueMax="2.3622" metricValueMin="2.1336" pageId="17" pageNumber="468" unit="in" value="88.5" valueMax="93.0" valueMin="84.0">84–93 in</quantity>
<taxonomicName id="4C267089257A0C65FBB7FEBBEBF37C36" box="[1026,1180,331,357]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="anatolicus">
<emphasis id="B952D718257A0C65FBB7FEBBEBF37C36" box="[1026,1180,331,357]" italics="true" pageId="17" pageNumber="468">O. anatolicus</emphasis>
</taxonomicName>
; 
<quantity id="4CDEA6EF257A0C65FB19FEBBEA7D7C36" box="[1196,1298,331,357]" metricMagnitude="0" metricUnit="m" metricValue="2.286" metricValueMax="2.3368" metricValueMin="2.2352" pageId="17" pageNumber="468" unit="in" value="90.0" valueMax="92.0" valueMin="88.0">88–92 in</quantity>
<taxonomicName id="4C267089257A0C65FAAEFEBBEAF37C37" baseAuthorityName="Steindachner" baseAuthorityYear="1897" box="[1307,1436,331,357]" class="Actinopterygii" family="Nemacheilidae" genus="Orthrias" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="angorae">
<emphasis id="B952D718257A0C65FAAEFEBBEAF37C37" box="[1307,1436,331,357]" italics="true" pageId="17" pageNumber="468">O. angorae</emphasis>
</taxonomicName>
and 
<quantity id="4CDEA6EF257A0C65FF72FE9FEE457CDA" box="[199,298,367,393]" metricMagnitude="0" metricUnit="m" metricValue="2.2098" metricValueMax="2.3114" metricValueMin="2.1082" pageId="17" pageNumber="468" unit="in" value="87.0" valueMax="91.0" valueMin="83.0">83–91 in</quantity>
<taxonomicName id="4C267089257A0C65FE84FE9FEEA37CDA" box="[305,460,367,393]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="eregliensis">
<emphasis id="B952D718257A0C65FE84FE9FEEA37CDA" box="[305,460,367,393]" italics="true" pageId="17" pageNumber="468">O. eregliensis</emphasis>
</taxonomicName>
), and no depigmented stripe along the anterior part of the lateral line (vs. present in 
<taxonomicName id="4C267089257A0C65FA34FE9FEF9B7CFF" baseAuthorityName="Steindachner" baseAuthorityYear="1897" class="Actinopterygii" family="Nemacheilidae" genus="Orthrias" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="angorae">
<emphasis id="B952D718257A0C65FA34FE9FEF9B7CFF" italics="true" pageId="17" pageNumber="468">O. angorae</emphasis>
</taxonomicName>
). 
<taxonomicName id="4C267089257A0C65FEB8FE63ED2C7CFF" authorityName="Yogurtcuoglu, Kaya, Ozulug &amp; Freyhof" authorityYear="2021" box="[269,579,403,429]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="isauricus">
<emphasis id="B952D718257A0C65FEB8FE63ED2C7CFF" box="[269,579,403,429]" italics="true" pageId="17" pageNumber="468">Oxynoemacheilus isauricus</emphasis>
</taxonomicName>
is further distinguished from 
<taxonomicName id="4C267089257A0C65FC20FE63EB297CFF" baseAuthorityName="FSJF" baseAuthorityYear="2323" box="[917,1094,403,429]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="germencicus">
<emphasis id="B952D718257A0C65FC20FE63EB297CFF" box="[917,1094,403,429]" italics="true" pageId="17" pageNumber="468">O. germencicus</emphasis>
</taxonomicName>
by lacking scales on the belly (vs. present).
</paragraph>
</subSubSection>
<subSubSection id="C33C5881257A0C65FF72FE2AEAE07CA6" box="[199,1423,474,501]" pageId="17" pageNumber="468" type="distribution">
<paragraph id="8B990B0A257A0C65FF72FE2AEAE07CA6" blockId="17.[151,1437,151,609]" box="[199,1423,474,501]" pageId="17" pageNumber="468">
<emphasis id="B952D718257A0C65FF72FE2AEE0E7CA7" bold="true" box="[199,353,474,500]" pageId="17" pageNumber="468">Distribution.</emphasis>
<taxonomicName id="4C267089257A0C65FED2FE2BEDF37CA7" authorityName="Yogurtcuoglu, Kaya, Ozulug &amp; Freyhof" authorityYear="2021" box="[359,668,475,501]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="isauricus">
<emphasis id="B952D718257A0C65FED2FE2BEDF37CA7" box="[359,668,475,501]" italics="true" pageId="17" pageNumber="468">Oxynoemacheilus isauricus</emphasis>
</taxonomicName>
is known from Lake Beyşehir and Suğla basins in Central 
<collectingCountry id="F3314B9A257A0C65FA9AFE2BEAE07CA6" box="[1327,1423,475,501]" name="Turkey" pageId="17" pageNumber="468">Anatolia</collectingCountry>
</paragraph>
</subSubSection>
<subSubSection id="C33C5881257A0C65FF72FE0FEB327F32" pageId="17" pageNumber="468" type="discussion">
<paragraph id="8B990B0A257A0C65FF72FE0FEB327F32" blockId="17.[151,1437,151,609]" pageId="17" pageNumber="468">
<emphasis id="B952D718257A0C65FF72FE0FEE547F4A" bold="true" box="[199,315,511,537]" pageId="17" pageNumber="468">Remarks.</emphasis>
Based on DNA barcoding, 
<taxonomicName id="4C267089257A0C65FDD9FE0FED9B7F4B" authorityName="Yogurtcuoglu, Kaya, Ozulug &amp; Freyhof" authorityYear="2021" box="[620,756,511,537]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="isauricus">
<emphasis id="B952D718257A0C65FDD9FE0FED9B7F4B" box="[620,756,511,537]" italics="true" pageId="17" pageNumber="468">O. isauricus</emphasis>
</taxonomicName>
is well separated by a minimum K2P sequence divergence of 7.5% and 8.0% in the mtDNA-COI barcode region from 
<taxonomicName id="4C267089257A0C65FCA1FDD3EC107F6E" box="[788,895,547,573]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="axylos">
<emphasis id="B952D718257A0C65FCA1FDD3EC107F6E" box="[788,895,547,573]" italics="true" pageId="17" pageNumber="468">O. axylos</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C267089257A0C65FC01FDD3EB217F6E" box="[948,1102,547,573]" class="Actinopterygii" family="Nemacheilidae" genus="Oxynoemacheilus" kingdom="Animalia" order="Cypriniformes" pageId="17" pageNumber="468" phylum="Chordata" rank="species" species="eregliensis">
<emphasis id="B952D718257A0C65FC01FDD3EB217F6E" box="[948,1102,547,573]" italics="true" pageId="17" pageNumber="468">O. eregliensis</emphasis>
</taxonomicName>
, its closest relatives. It is also supported to be a distinct species by the PTP approach, and by the mPTP delimitation.
</paragraph>
</subSubSection>
</treatment>
