<subSubSection id="8D44DA428759B1144454D3D3182D40ED" pageId="null" pageNumber="570" type="description">
<paragraph id="E5884D5B8DB1B4862D18DCBFBF917867" pageId="null" pageNumber="570">
Unterscheidet sich von 
<taxonomicName id="6A21374EFA0723F5C041893CD2D5F80A" class="Liliopsida" family="Amaryllidaceae" genus="Allium" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="570" phylum="Tracheophyta" rank="species" species="paniculatum">
<emphasis id="85D1A91BB2380EB939AE83FF578D3119" italics="true" pageId="null" pageNumber="570">A. paniculatum</emphasis>
</taxonomicName>
(Nr. 12a) durch folgende Merkmale: 
<normalizedToken id="ED509294A1DA6B69BE7E303658ABC9CD" originalValue="Blätter" pageId="null" pageNumber="570">Blaetter</normalizedToken>
unterseits meist rauh; 
<emphasis id="E9F6BDA5BE8D837CE591E752959320F4" italics="true" pageId="null" pageNumber="570">
<normalizedToken id="C7A6ADD37C8B7ECA7A32CBE94AAF9AF8" originalValue="Blütenstand" pageId="null" pageNumber="570">Bluetenstand</normalizedToken>
stets mit sitzenden Zwiebeln.
</emphasis>
- 
<normalizedToken id="F5BB4B3A4426CA111956ED20B5BBB4A6" originalValue="Blüte" pageId="null" pageNumber="570">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="F5CA0ABF1633880548D7A471297E5046" pageId="null" pageNumber="570">
<emphasis id="E677174392A0F8824F94CDC69DB6F1D3" italics="true" pageId="null" pageNumber="570">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="53B6DA1701A2C5E86464B82BA95BA762" italics="true" pageId="null" pageNumber="570">32:</emphasis>
Material aus Schweden und aus zahlreichen botanischen 
<normalizedToken id="F92F22F1D54674CAC14173A0BE962B10" originalValue="Gärten" pageId="null" pageNumber="570">Gaerten</normalizedToken>
; in Pollenmeiosen 
<normalizedToken id="4EA81A20564DC660C7206EBA50FF640E" originalValue="häufig" pageId="null" pageNumber="570">haeufig</normalizedToken>
aneuploide Zahlen (
<emphasis id="09A219CED4A2BA79A6462D3547F8CC8A" italics="true" pageId="null" pageNumber="570">n</emphasis>
= 
<emphasis id="3A8D857FC0CB01CAEE313E9AC0506A9F" italics="true" pageId="null" pageNumber="570">13-18</emphasis>
), meist vegetative Fortpflanzung durch Zwiebeln im 
<normalizedToken id="4F4BB92789281DE8FF448289A974FA85" originalValue="Blütenstand" pageId="null" pageNumber="570">Bluetenstand</normalizedToken>
(Levan 1933Levan 1937), Material aus Finnland (Sorsa 1962), aus Island (
<normalizedToken id="0FD9337CF2E9204197DE366B3BD9A0B0" originalValue="Löve" pageId="null" pageNumber="570">Loeve</normalizedToken>
und 
<normalizedToken id="9D583164EBF6F5E49D8E3E8B9F6CFA91" originalValue="Löve" pageId="null" pageNumber="570">Loeve</normalizedToken>
1956b). 
<emphasis id="96D70AA6805471EFD27F9AD25A27AD23" italics="true" pageId="null" pageNumber="570">2n = 40:</emphasis>
Material von 8 Fundorten in 
<normalizedToken id="CA8EC23BB2A3D4E95E5AFDB4482BA08C" originalValue="Österreich" pageId="null" pageNumber="570">Oesterreich</normalizedToken>
; Pollenmeiose 
<normalizedToken id="456D66DE74D3636AF12B0A05EFEBF05F" originalValue="gestört" pageId="null" pageNumber="570">gestoert</normalizedToken>
, nur 5-10% des Pollens normal; Samenansatz gering; zwischen tetraploiden und pentaploiden Pflanzen keine 
<normalizedToken id="262E12CCE327BAD8CE1ED2BFFE533862" originalValue="äußern" pageId="null" pageNumber="570">aeussern</normalizedToken>
Unterschiede (Tschermak-Woess 1950); Material aus dem 
<normalizedToken id="545493C13119F70D3B0DD5F897F94DD4" originalValue="Elsaß" pageId="null" pageNumber="570">Elsass</normalizedToken>
(Linder und Brun 1956).
</paragraph>
<paragraph id="1EC006A46CD26837A92ED28AF5ADA598" pageId="null" pageNumber="570">
<emphasis id="D0C2FC7C5B258C536A7B8630741B9FC7" italics="true" pageId="null" pageNumber="570">
<pageBreakToken id="7FDA1098335D3BF2EE7F981AD739B18F" pageId="null" pageNumber="570">Standort</pageBreakToken>
.
</emphasis>
Kollin, montan und subalpin. Trockene bis feuchte, 
<normalizedToken id="AF8931FFEF3E7E4450B7B23903B3EE59" originalValue="gedüngte" pageId="null" pageNumber="570">geduengte</normalizedToken>
und 
<normalizedToken id="EBDC4496390B449D79AA11C5D9A4C19B" originalValue="nährstoffarme" pageId="null" pageNumber="570">naehrstoffarme</normalizedToken>
<normalizedToken id="26AA2898BE7A61D33367A5C02D36C2DE" originalValue="Böden" pageId="null" pageNumber="570">Boeden</normalizedToken>
. Fettwiesen, Trockenwiesen, 
<normalizedToken id="7699A947D4DC6E43591A2879130A6DD0" originalValue="Äcker" pageId="null" pageNumber="570">Aecker</normalizedToken>
, 
<normalizedToken id="D2614DEEE7E4ED51B8C57F4FD777306D" originalValue="Wegränder" pageId="null" pageNumber="570">Wegraender</normalizedToken>
, 
<normalizedToken id="85FB8AA421DCF5B1557712330109B19A" originalValue="Gebüsch" pageId="null" pageNumber="570">Gebuesch</normalizedToken>
, 
<normalizedToken id="6A995863192AD1D77779BAB4AFC86AB9" originalValue="Felsbänder" pageId="null" pageNumber="570">Felsbaender</normalizedToken>
und Felsschutt.
</paragraph>
<paragraph id="5D9ACE65147B8A485F40608D8431AF17" pageId="null" pageNumber="570">
<emphasis id="0DE1F0D9A3E90FBE7F345801F9F10430" italics="true" pageId="null" pageNumber="570">
Verbreitung. 
<normalizedToken id="FA3F8B5EE303C751D7931C7ACBBF3E38" originalValue="Europäische" pageId="null" pageNumber="570">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="66CD97DDB4868F136EF3103B86F52C5A" originalValue="Nordwärts" pageId="null" pageNumber="570">Nordwaerts</normalizedToken>
bis Irland, Schottland, Nordskandinavien (70° NB), 
<normalizedToken id="226A64B1AE1EEDD8E938801EEEB1C0A0" originalValue="Südfinnland" pageId="null" pageNumber="570">Suedfinnland</normalizedToken>
, 
<normalizedToken id="30CB672E379E0515EDFF48A42FB2877C" originalValue="Mittelrußland" pageId="null" pageNumber="570">Mittelrussland</normalizedToken>
, 
<normalizedToken id="D0BB69F6966B080B66D11FD42F2DF34F" originalValue="ostwärts" pageId="null" pageNumber="570">ostwaerts</normalizedToken>
bis ins Wolgagebiet; wenige Fundstellen im Mediterrangebiet; aus Nordafrika nicht angegeben. Verbreitungskarte von Meusel (1964). - Im Gebiet verbreitet, ziemlich 
<normalizedToken id="E17690B73B0E6FB39C9BB5B270517885" originalValue="häufig" pageId="null" pageNumber="570">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
