<paragraph blockId="99.[151,1436,836,1688]" box="[199,704,1663,1688]" pageId="99" pageNumber="100">
<emphasis bold="true" box="[199,513,1663,1688]" pageId="99" pageNumber="100">MATERIAL EXAMINED</emphasis>
