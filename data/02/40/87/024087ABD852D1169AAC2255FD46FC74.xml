<bibRefCitation author="Templado J" box="[360,543,683,708]" pageId="32" pageNumber="297" pagination="247 - 254" refId="ref22433" refString="Templado J. 1982. Datos sobre los opistobranquios del Cabo de Palos (Murcia). Bolletino Malacologico. 18: 247 - 254." type="journal article" year="1982">Templado 1982</bibRefCitation>
; 
<bibRefCitation author="Templado J &amp; Talavera P &amp; Murillo L" box="[561,813,683,708]" pageId="32" pageNumber="297" pagination="47 - 50" refId="ref22538" refString="Templado J, Talavera P, Murillo L. 1983. Adiciones a la fauna de opistobranquios del Cabo de Palos (Murcia) I. Iberus. 3: 47 - 50." type="journal article" year="1983">Templado et al. 1983</bibRefCitation>
