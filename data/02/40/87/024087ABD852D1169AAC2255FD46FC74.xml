<bibRefCitation author="Templado J" box="[831,886,683,708]" pageId="32" pageNumber="297" pagination="509 - 526" refId="ref22459" refString="Templado J. 1984. Moluscos de la praderas de Posidonia oceanica en las costas del cabo de Paolos (Murcia). Investigacion Pesquera. 48: 509 - 526." type="journal article" year="1984">1984</bibRefCitation>
; 
<bibRefCitation author="Marin A &amp; Ros JD" box="[903,1142,683,708]" pageId="32" pageNumber="297" pagination="25 - 49" refId="ref20526" refString="Marin A, Ros JD. 1988. Los sacoglosos (Mollusca, Opisthobranchia) del sudeste iberico. Catalogo de las especies y presencia de cloroplastos algales en las mismas. Iberus. 8: 25 - 49." type="journal article" year="1988">Marín and Ros 1988</bibRefCitation>
), 
<collectingRegion box="[160,335,718,743]" country="Spain" name="Illes Baleares" pageId="32" pageNumber="297">Balearic Islands</collectingRegion>
, 
<collectingCountry box="[347,409,718,743]" name="Spain" pageId="32" pageNumber="297">Spain</collectingCountry>
(GROC 2009–2021), 
