<subSubSection pageId="37" pageNumber="302" type="biology_ecology">
<paragraph blockId="37.[160,1156,628,723]" box="[160,252,628,654]" pageId="37" pageNumber="302">
<emphasis bold="true" box="[160,252,628,654]" italics="true" pageId="37" pageNumber="302">Ecology</emphasis>
</paragraph>
<paragraph blockId="37.[160,1156,628,723]" pageId="37" pageNumber="302">
All specimens found in communities of the red alga 
<taxonomicName authority="Boudouresque and Denizot, 1973" authorityName="Boudouresque and Denizot" authorityYear="1973" family="Peyssonneliaceae" genus="Peyssonnelia" kingdom="Plantae" order="Cryptonemiales" pageId="37" pageNumber="302" phylum="Rhodophyta" rank="species" species="rosa-marina">
<emphasis box="[859,1156,663,688]" italics="true" pageId="37" pageNumber="302">Peyssonnelia rosa-marina</emphasis>
Boudouresque and Denizot, 1973
</taxonomicName>
, grazing and laying the egg masses at night.
</paragraph>
</subSubSection>
