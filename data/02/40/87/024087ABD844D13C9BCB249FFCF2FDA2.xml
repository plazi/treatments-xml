<taxonomicName authorityName="Ortea and Bouchet" authorityYear="1989" box="[315,482,1598,1621]" class="Gastropoda" family="Dotidae" genus="Doto" kingdom="Animalia" order="Nudibranchia" pageId="9" pageNumber="274" phylum="Mollusca" rank="species" species="cervicenigra">
<emphasis box="[315,482,1598,1621]" italics="true" pageId="9" pageNumber="274">Doto cervicenigra</emphasis>
</taxonomicName>
