<taxonomicName baseAuthorityName="Forbes" baseAuthorityYear="1838" box="[529,649,1598,1621]" class="Gastropoda" family="Dotidae" genus="Doto" kingdom="Animalia" order="Nudibranchia" pageId="9" pageNumber="274" phylum="Mollusca" rank="species" species="fragilis">Doto fragilis</taxonomicName>
