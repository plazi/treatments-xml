<taxonomicName authorityName="Er. Marcus" authorityYear="1964" box="[160,349,1540,1563]" class="Gastropoda" family="Polyceridae" genus="Polycera" kingdom="Animalia" order="Nudibranchia" pageId="9" pageNumber="274" phylum="Mollusca" rank="species" species="hedgpethi">
<emphasis box="[160,349,1540,1563]" italics="true" pageId="9" pageNumber="274">Polycera hedgpethi</emphasis>
</taxonomicName>
