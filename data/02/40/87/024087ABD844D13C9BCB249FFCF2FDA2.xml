<taxonomicName box="[509,613,1569,1592]" class="Gymnolaemata" family="Bugulidae" genus="Bugula" kingdom="Animalia" order="Cheilostomatida" pageId="9" pageNumber="274" phylum="Bryozoa" rank="species" species="undetermined">
<emphasis box="[509,576,1569,1592]" italics="true" pageId="9" pageNumber="274">Bugula</emphasis>
sp.
</taxonomicName>
(e) Two specimens of 
<taxonomicName baseAuthorityName="Ev. Marcus and Er. Marcus" baseAuthorityYear="1967" box="[844,1055,1569,1592]" class="Gastropoda" family="Aeolidiidae" genus="Anteaeolidiella" kingdom="Animalia" order="Nudibranchia" pageId="9" pageNumber="274" phylum="Mollusca" rank="species" species="lurana">
