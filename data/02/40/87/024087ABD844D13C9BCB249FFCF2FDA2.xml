<taxonomicName authorityName="A. E. Verrill" authorityYear="1880" box="[401,601,1540,1563]" class="Gastropoda" family="Polyceridae" genus="Polycerella" kingdom="Animalia" order="Nudibranchia" pageId="9" pageNumber="274" phylum="Mollusca" rank="species" species="emertoni">
<emphasis box="[401,601,1540,1563]" italics="true" pageId="9" pageNumber="274">Polycerella emertoni</emphasis>
</taxonomicName>
and egg mass on 
<taxonomicName baseAuthorityName="Delle Chiaje" baseAuthorityYear="1822" box="[808,1003,1540,1563]" class="Malacostraca" family="Epialtidae" genus="Amathia" kingdom="Animalia" order="Decapoda" pageId="9" pageNumber="274" phylum="Arthropoda" rank="species" species="verticillata">
<emphasis box="[808,1003,1540,1563]" italics="true" pageId="9" pageNumber="274">Amathia verticillata</emphasis>
</taxonomicName>
. (d) 
<taxonomicName baseAuthorityName="Montagu" baseAuthorityYear="1813" class="Gastropoda" family="Polyceridae" genus="Thecacera" kingdom="Animalia" order="Nudibranchia" pageId="9" pageNumber="274" phylum="Mollusca" rank="species" species="pennigera">
<emphasis italics="true" pageId="9" pageNumber="274">Thecacera pennigera</emphasis>
