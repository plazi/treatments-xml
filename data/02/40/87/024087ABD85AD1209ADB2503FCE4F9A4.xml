<subSubSection pageId="22" pageNumber="287" type="biology_ecology">
<paragraph blockId="22.[160,1155,950,1045]" box="[160,252,950,976]" pageId="22" pageNumber="287">
<emphasis bold="true" box="[160,252,950,976]" italics="true" pageId="22" pageNumber="287">Ecology</emphasis>
</paragraph>
<paragraph blockId="22.[160,1155,950,1045]" pageId="22" pageNumber="287">A single specimen was found in a mass of hydrozoans in a floating dock with other sea slugs.</paragraph>
</subSubSection>
<subSubSection pageId="22" pageNumber="287" type="distribution">
<paragraph blockId="22.[160,1156,1092,1221]" box="[160,300,1092,1118]" pageId="22" pageNumber="287">
<emphasis bold="true" box="[160,300,1092,1118]" italics="true" pageId="22" pageNumber="287">Distribution</emphasis>
</paragraph>
<paragraph blockId="22.[160,1156,1092,1221]" pageId="22" pageNumber="287">
North-east Atlantic (
<bibRefCitation author="OBIS" box="[386,505,1127,1152]" pageId="22" pageNumber="287" pagination="22" refId="ref21226" refString="OBIS. 2021. Ocean Biogeographic Information System. Intergovernmental Oceanographic Commission of UNESCO. Accessed 2021 May 22. www. iobis. org" type="journal article" year="2021">OBIS 2021</bibRefCitation>
); Pacific North American coast (iNaturalist.org 2021; 
<bibRefCitation author="OBIS" pageId="22" pageNumber="287" pagination="22" refId="ref21226" refString="OBIS. 2021. Ocean Biogeographic Information System. Intergovernmental Oceanographic Commission of UNESCO. Accessed 2021 May 22. www. iobis. org" type="journal article" year="2021">OBIS 2021</bibRefCitation>
); 
<collectingCountry box="[235,330,1162,1187]" name="Portugal" pageId="22" pageNumber="287">Portugal</collectingCountry>
(
<bibRefCitation author="Encarnacao J &amp; Seyer T &amp; Teodosio MA &amp; Leitao F" box="[343,597,1162,1187]" pageId="22" pageNumber="287" pagination="214" refId="ref19219" refString="Encarnacao J, Seyer T, Teodosio MA, Leitao F. 2020. First Record of the Nudibranch Tenellia adspersa (Nordmann, 1845) in Portugal, Associated with the Invasive Hydrozoan Cordylophora caspia (Pallas, 1771). Diversity. 12: 214. doi: 10.3390 / d 12060214." type="journal article" year="2020">Encarnação et al. 2020</bibRefCitation>
