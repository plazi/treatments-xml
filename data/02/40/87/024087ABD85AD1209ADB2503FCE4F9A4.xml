<collectingCountry box="[617,682,1162,1187]" name="Spain" pageId="22" pageNumber="287">Spain</collectingCountry>
: 
<collectingRegion box="[692,856,1162,1187]" country="Spain" name="Canarias" pageId="22" pageNumber="287">Canary Islands</collectingRegion>
, Atlantic Andalusian coast, 
<collectingRegion box="[160,236,1196,1221]" country="Spain" name="Galicia" pageId="22" pageNumber="287">Galicia</collectingRegion>
