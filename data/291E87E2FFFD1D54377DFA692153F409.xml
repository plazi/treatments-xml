<subSubSection id="E9AD657FFFFD1D5436E4F9D82153F409" lastPageId="43" lastPageNumber="1444" pageId="42" pageNumber="1443" type="materials_examined">
<paragraph id="A10836F4FFFD1D5536E4F9D8219AF31E" blockId="42.[213,423,1593,1617]" box="[213,423,1593,1617]" pageId="42" pageNumber="1443">
<emphasis id="93C3EAE6FFFD1D5536E4F9D8219AF31E" box="[213,423,1593,1617]" italics="true" pageId="42" pageNumber="1443">Material examined</emphasis>
</paragraph>
<paragraph id="A10836F4FFFD1D5536E4F9802461F3D7" blockId="42.[213,1169,1633,1688]" pageId="42" pageNumber="1443">None. Xue-Xin Chen kindly provided additional information to that given in the original description enabling it to be run through the identification key correctly.</paragraph>
<paragraph id="A10836F4FFFC1D5436A1FF4620ECF5F0" blockId="43.[144,209,167,191]" box="[144,209,167,191]" pageId="43" pageNumber="1444">
<emphasis id="93C3EAE6FFFC1D5436A1FF4620ECF5F0" box="[144,209,167,191]" italics="true" pageId="43" pageNumber="1444">Notes</emphasis>
</paragraph>
<paragraph id="A10836F4FFFC1D5436A1FF2F2153F409" blockId="43.[144,1101,206,326]" pageId="43" pageNumber="1444">
This species is the only one to date known from 
<collectingCountry id="D9A07664FFFC1D5434ADFF2F22D9F5A9" box="[668,740,206,230]" name="China" pageId="43" pageNumber="1444">China</collectingCountry>
, and has a unique colour pattern among the known species being largely brown-black with red-brown markings on the mesopleuron and mesosternum, red-yellow markings on the 1st metasomal tergite, and red-yellow legs.
</paragraph>
</subSubSection>
