<emphasis id="B970EAFEFF8AF664811B3590F705FE32" bold="true" box="[2053,2208,396,425]" pageId="78" pageNumber="136">Taxonomy.</emphasis>
<taxonomicName id="4C044D6FFF8AF66481A43590F7F5FE4B" authority="Dobson, 1878" authorityName="Dobson" authorityYear="1878" class="Dothideomycetes" family="Pteropodidae" genus="Pteropus" kingdom="Fungi" order="Chiroptera" pageId="78" pageNumber="136" phylum="Ascomycota" rank="species" species="lombocensis">Pteropus lombocensis Dobson, 1878</taxonomicName>
<materialsCitation id="3B6C3CB1FF8AF664817435AFF6CEFE63" pageId="78" pageNumber="136">
“Lombock [= Lombok] 
<collectingCountry id="F313767CFF8AF66480F235AFF5E0FE4B" box="[2540,2629,435,464]" name="Iceland" pageId="78" pageNumber="136">Island</collectingCountry>
,” Lesser Sundas, 
<collectingCountry id="F313767CFF8AF66481C035C3F6CEFE63" box="[2270,2411,479,504]" name="Indonesia" pageId="78" pageNumber="136">Indonesia</collectingCountry>
</materialsCitation>
.
</paragraph>
<paragraph id="8BBB36ECFF8AF664811835E2F741FDF5" blockId="78.[2053,2649,396,819]" pageId="78" pageNumber="136">
<taxonomicName id="4C044D6FFF8AF664811835E2F6A8FD84" authorityName="Dobson" authorityYear="1878" box="[2054,2317,510,543]" class="Dothideomycetes" family="Pteropodidae" genus="Pteropus" kingdom="Fungi" order="Chiroptera" pageId="78" pageNumber="136" phylum="Ascomycota" rank="species" species="lombocensis">Pteropus lombocensis</taxonomicName>
is the only member of 
<taxonomicName id="4C044D6FFF8AF66481173639F73DFDDD" authorityName="Dobson" authorityYear="1878" box="[2057,2200,549,582]" class="Dothideomycetes" family="Pteropodidae" genus="Pteropus" kingdom="Fungi" order="Chiroptera" pageId="78" pageNumber="136" phylum="Ascomycota" rank="species" species="lombocensis">lombocensis</taxonomicName>
species group. Three subspecies recognized.
</paragraph>
</subSubSection>
