: Brazil: 
<normalizedToken originalValue="Pará">Para</normalizedToken>
, 
<normalizedToken originalValue="São">Sao</normalizedToken>
<normalizedToken originalValue="Félix">Felix</normalizedToken>
do Xingu, Cave SFX-0057, 
<geoCoordinate degrees="6" direction="south" minutes="24" orientation="latitude" precision="1" seconds="06.2" value="-6.4017224">6°24'06.2&quot;S</geoCoordinate>
, 
<geoCoordinate degrees="51" direction="west" minutes="54" orientation="longitude" precision="1" seconds="08.1" value="-51.902252">51°54'08.1&quot;W</geoCoordinate>
, ♂, 03.II.2018, Ativo Ambiental leg. (ISLA 75762).
</paragraph>
<paragraph pageId="0" pageNumber="97">
