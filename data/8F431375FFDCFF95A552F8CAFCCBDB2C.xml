<taxonomicName id="C0EAD9E0FFDFFF95A7ADF91FFE6BDB0B" baseAuthorityName="Ravelo" baseAuthorityYear="1975" box="[189,429,1776,1802]" class="Arachnida" family="Charinidae" genus="Charinus" kingdom="Animalia" order="Amblypygi" pageId="70" pageNumber="71" phylum="Arthropoda" rank="species" species="tronchonii">
