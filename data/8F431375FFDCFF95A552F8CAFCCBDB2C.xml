<bibRefCitation id="637BDF92FFDFFF95A7D5F8FCFE99DB2F" author="Ravelo P. O." box="[197,351,1811,1838]" firstAuthor="Ravelo" journalOrPublisher="Boletin de la Sociedad Venezolana de Espeleologia" pageId="70" pageNumber="71" pagination="77 - 85" part="6" refId="ref152816" refString="Ravelo P. O. 1975. Speleophrynus tronchonii, nuevo genero y especie de amblipigios de la familia Charontidae, en una cueva de Venezuela. Boletin de la Sociedad Venezolana de Espeleologia 6: 77 - 85." title="Speleophrynus tronchonii, nuevo genero y especie de amblipigios de la familia Charontidae" type="journal article" volumeTitle="una cueva de Venezuela" year="1975">Ravelo 1975</bibRefCitation>
