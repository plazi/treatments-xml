<materialsCitation id="3B1A3CF8935C8E01F2AAFD69FF33FC96" ID-GBIF-Occurrence="3798147335" collectionCode="TYPE" collectorName="J. Serrano" pageId="5" pageNumber="489" specimenCount="2" typeStatus="holotype">
