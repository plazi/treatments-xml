is a male glued to a white card that is pinned together with other labels: “ 
<emphasis id="B906EAB7935C8E01F299FC8DFE4FFCF2" box="[164,414,799,825]" italics="true" pageId="5" pageNumber="489">
<taxonomicName id="4C724D26935C8E01F299FC8DFF21FCF2" authorityName="Dejean" authorityYear="1829" box="[164,240,799,825]" class="Insecta" family="Carabidae" genus="Harpalus" kingdom="Animalia" order="Coleoptera" pageId="5" pageNumber="489" phylum="Arthropoda" rank="species" species="oblitus">oblitus</taxonomicName>
