<taxonomicName id="4C724D26935C8E01F148FC8DFAF3FCF2" authority="Dejean, 1829" authorityName="Dejean" authorityYear="1829" box="[885,1314,799,825]" class="Insecta" family="Carabidae" genus="Harpalus" kingdom="Animalia" order="Coleoptera" pageId="5" pageNumber="489" phylum="Arthropoda" rank="subSpecies" species="oblitus" subSpecies="oblitus">
