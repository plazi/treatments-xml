<collectionCode id="ED63AE60935C8E01F3FFFC8DFDDFFCF2" box="[450,526,799,825]" pageId="5" pageNumber="489">TYPE</collectionCode>
. Kataev des.” and “ 
<typeStatus id="54C98807935C8E01F0D8FC8DFC81FCF2" box="[741,848,799,825]" pageId="5" pageNumber="489">Holotype</typeStatus>
