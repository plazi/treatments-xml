<taxonomicName id="6D06DF65FA518155DA10AD989875B6B6" authority="L." class="Magnoliopsida" family="Amaranthaceae" genus="Amaranthus" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="766" phylum="Tracheophyta" rank="species" species="deflexus">
Amaranthus 
<normalizedToken id="335B90A794A937B01F4DC780886B52AB" originalValue="defléxus" pageId="null" pageNumber="766">deflexus</normalizedToken>
<authorityName id="152F65458612C2ECEDD446C675C4A229" pageId="null" pageNumber="766">L.</authorityName>
