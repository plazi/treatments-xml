<taxonomicName id="09D771CD2FD6544E30FE7375CC05D180" authority="(DC.) Gaudin" class="Liliopsida" family="Poaceae" genus="Koeleria" kingdom="Plantae" order="Poales" pageId="null" pageNumber="314" phylum="Tracheophyta" rank="species" species="hirsuta">
