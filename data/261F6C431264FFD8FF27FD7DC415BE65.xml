<taxonomicName id="69B6A6D61266FFD8FC7EFEB8C4E7BB58" box="[974,1170,331,356]" class="Magnoliopsida" family="Lythraceae" genus="Punica" kingdom="Plantae" order="Myrtales" pageId="3" pageNumber="591" phylum="Tracheophyta" rank="species" species="granatum">
