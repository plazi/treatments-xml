<taxonomicName id="69B6A6D61266FFD8FCBEFEB8C3EDBB5A" box="[782,920,331,358]" class="Insecta" family="Diaspididae" kingdom="Animalia" order="Hemiptera" pageId="3" pageNumber="591" phylum="Arthropoda" rank="family">Diaspididae</taxonomicName>
