<subSubSection id="1A1865D77361D8E8A2F34050E677C4D4" pageId="null" pageNumber="448" type="description">
<paragraph id="4768EB37AFA4B892E0A0AA003337786B" pageId="null" pageNumber="448">
Strauch 1-3 m hoch, meist einzeln, nicht Kolonien bildend. Stamm und 
<normalizedToken id="19FD0108CD66B4CC770DC9230ED8DF20" originalValue="Äste" pageId="null" pageNumber="448">Aeste</normalizedToken>
mit gleichartigen, wenig gebogenen bis hakig 
<normalizedToken id="5D22945B2399F816D4EDE2BE9A2B7B93" originalValue="gekrümmten" pageId="null" pageNumber="448">gekruemmten</normalizedToken>
, am Grunde schmalen bis breiten, schwachen bis 
<normalizedToken id="5A8A8CED544117F8093B15095E7B480F" originalValue="kräftigen" pageId="null" pageNumber="448">kraeftigen</normalizedToken>
(bis 1 cm langen) Stacheln besetzt; selten 
<normalizedToken id="977C174C2DEB35B73E76192C51BD86CD" originalValue="Blütenzweige" pageId="null" pageNumber="448">Bluetenzweige</normalizedToken>
ohne Stacheln. 
<normalizedToken id="D15D59A0DB492ADBEC64CE1D7F3EBE4A" originalValue="Blätter" pageId="null" pageNumber="448">Blaetter</normalizedToken>
der 
<normalizedToken id="6B9B0FBAFDF8341CE6CAF1708768C949" originalValue="Blütenzweige" pageId="null" pageNumber="448">Bluetenzweige</normalizedToken>
7- und 5 
<normalizedToken id="141ABD4136A1A948F700811722838246" originalValue="zählig" pageId="null" pageNumber="448">zaehlig</normalizedToken>
; 
<normalizedToken id="1E835F2FE9F4B52EDD5ADF4AB375FA7D" originalValue="Teilblätter" pageId="null" pageNumber="448">Teilblaetter</normalizedToken>
oval, 
<emphasis id="FA3AC7F4C733ACB06EADF82FC0FB5CC8" italics="true" pageId="null" pageNumber="448">2-4</emphasis>
cm lang, 
<normalizedToken id="31C01BE2B24D9875018E56E8DCD094EE" originalValue="1½" pageId="null" pageNumber="448">11/2</normalizedToken>
-2mal so lang wie breit, fast immer 
<emphasis id="95D135CA38BBC0E885F84E2219C09434" italics="true" pageId="null" pageNumber="448">
1fach 
<normalizedToken id="918715E7A5A3907C71851659B2A7943D" originalValue="gezähnt" pageId="null" pageNumber="448">gezaehnt</normalizedToken>
</emphasis>
, mit nach vorn gerichteten 
<normalizedToken id="2846DF7F1EEDEC68215E0A55EDC20997" originalValue="Zähnen" pageId="null" pageNumber="448">Zaehnen</normalizedToken>
, im untersten Drittel oder Viertel ohne 
<normalizedToken id="C94953CEF254383C7291F8A998E90F76" originalValue="Zähne" pageId="null" pageNumber="448">Zaehne</normalizedToken>
, 
<emphasis id="F8022B2E5EA5951C187AD727B48CF67E" italics="true" pageId="null" pageNumber="448">
ohne 
<normalizedToken id="C3BA2799B29D9181A85E039F048D48A5" originalValue="Stieldrüsen" pageId="null" pageNumber="448">Stieldruesen</normalizedToken>
an den 
<normalizedToken id="2C113DDA90366AAE6870A35C47560486" originalValue="Zähnen" pageId="null" pageNumber="448">Zaehnen</normalizedToken>
, 
<normalizedToken id="DB4EBD2580493560AFD9A121C4B80AAF" originalValue="blaugrün" pageId="null" pageNumber="448">blaugruen</normalizedToken>
oder kupferrot, kahl
</emphasis>
, selten unterseits auf dem Mittelnerv behaart, 
<emphasis id="12B4EEE3C7C6BF560C853FB5BF79B7C0" italics="true" pageId="null" pageNumber="448">
ohne 
<normalizedToken id="402642E89CFFBFA972BF353415AD6E70" originalValue="Drüsen" pageId="null" pageNumber="448">Druesen</normalizedToken>
, Blattstiele kahl.
</emphasis>
<normalizedToken id="77EFBE5E70BFF83271ECC9A7052464C6" originalValue="Hochblätter" pageId="null" pageNumber="448">Hochblaetter</normalizedToken>
den 
<normalizedToken id="F8730E1FFC1C3E5BC8E781AE9A9A6018" originalValue="Nebenblättern" pageId="null" pageNumber="448">Nebenblaettern</normalizedToken>
<normalizedToken id="F1074F4E2955FE1FBBCD7435CB742BA4" originalValue="ähnlich" pageId="null" pageNumber="448">aehnlich</normalizedToken>
. 
<normalizedToken id="00525B58BB1EAE223C40887D9B317DD3" originalValue="Blütenstand" pageId="null" pageNumber="448">Bluetenstand</normalizedToken>
meist 3 
<normalizedToken id="41EB26C4CB22D8164C747FF3F6DBB07C" originalValue="blütig" pageId="null" pageNumber="448">bluetig</normalizedToken>
(1-5 
<normalizedToken id="4E0F8C66D5B0CCDA047EDD9E221E28B0" originalValue="blütig" pageId="null" pageNumber="448">bluetig</normalizedToken>
). 
<normalizedToken id="41A4B0E50DD0D80F48C37327AAD98AF0" originalValue="Blütenstiele" pageId="null" pageNumber="448">Bluetenstiele</normalizedToken>
1-2 cm lang, 
<emphasis id="BFEE04B2223ACB0C8F8299B1D945E0CD" italics="true" pageId="null" pageNumber="448">kahl.</emphasis>
<normalizedToken id="E2A7CCCC70DF03640ACCE3147C0BA553" originalValue="Blütendurchmesser" pageId="null" pageNumber="448">Bluetendurchmesser</normalizedToken>
2-4 cm. 
<emphasis id="385704F8E413A5792B6F5E32C0E245C9" italics="true" pageId="null" pageNumber="448">
<normalizedToken id="4426605759789FBEB8A35F6583900499" originalValue="Kelchblätter" pageId="null" pageNumber="448">Kelchblaetter</normalizedToken>
ganzrandig oder die beiden 
<normalizedToken id="6D812763803C2FA8A7791C591E6E5478" originalValue="äußern" pageId="null" pageNumber="448">aeussern</normalizedToken>
mit 1
</emphasis>
- 
<emphasis id="F14EB4D791560D7E746650BD50BBB210" italics="true" pageId="null" pageNumber="448">
2 Paaren 
<normalizedToken id="31895D0A21B9187000638F9D4067BADA" originalValue="fadenförmiger" pageId="null" pageNumber="448">fadenfoermiger</normalizedToken>
Abschnitte, nach der 
<normalizedToken id="B3809DA593C758B4DA77DB69F625BFD8" originalValue="Blüte" pageId="null" pageNumber="448">Bluete</normalizedToken>
aufrecht, vor der Fruchtreife abfallend
</emphasis>
, mit oder ohne 
<normalizedToken id="380A8DDE5A7171906DB49CD7F3E25B5C" originalValue="Stieldrüsen" pageId="null" pageNumber="448">Stieldruesen</normalizedToken>
, 
<emphasis id="9C78A99355BD298FC2EA173CAF03A123" italics="true" pageId="null" pageNumber="448">
<normalizedToken id="9E153BE80DB4834564A2070CC8F25853" originalValue="außerseits" pageId="null" pageNumber="448">ausserseits</normalizedToken>
nicht behaart, viel 
<normalizedToken id="2D6BE04C75F0FD5C7B272D88D9E34F37" originalValue="länger" pageId="null" pageNumber="448">laenger</normalizedToken>
als die 
<normalizedToken id="B9B2CB003141F4E465AA2ADF82E840C3" originalValue="Kronblätter" pageId="null" pageNumber="448">Kronblaetter</normalizedToken>
.
</emphasis>
<normalizedToken id="C019CC92021FD100ECC22E4145A9F436" originalValue="Kronblätter" pageId="null" pageNumber="448">Kronblaetter</normalizedToken>
rot. Griffel ein 
<normalizedToken id="F5C64DD831F0937EA9E3B1A151613769" originalValue="weißwolliges" pageId="null" pageNumber="448">weisswolliges</normalizedToken>
<normalizedToken id="96CFD4623E55A5F96682AD3B0DF114A6" originalValue="Köpfchen" pageId="null" pageNumber="448">Koepfchen</normalizedToken>
bildend. Frucht kugelig, 
<emphasis id="BF74F97308EA3F7E05016D04AF2D2D07" italics="true" pageId="null" pageNumber="448">kahl</emphasis>
, rotbraun. - 
<normalizedToken id="38671FF71B528AE6FCA2789C83B870C3" originalValue="Blüte" pageId="null" pageNumber="448">Bluete</normalizedToken>
; 
<normalizedToken id="C9F09FFE4E6ECA55910FCC7B040686F1" originalValue="Früher" pageId="null" pageNumber="448">Frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="FD2D90BA48FF1091B543F95DDF64168E" pageId="null" pageNumber="448">
<emphasis id="2DC5D40CD73ACD23F8DA9D31661FCAE6" italics="true" pageId="null" pageNumber="448">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="F1C7890E11F65479F6130F03B91A5DA5" italics="true" pageId="null" pageNumber="448">28:</emphasis>
Material aus botanischen 
<normalizedToken id="28939539A979C169761205B318822928" originalValue="Gärten" pageId="null" pageNumber="448">Gaerten</normalizedToken>
; alle Chromosomen bivalent (
<normalizedToken id="750686066D2009E6E824776D8464C5DF" originalValue="Täckholm" pageId="null" pageNumber="448">Taeckholm</normalizedToken>
1922, Erlanson 1933). 
<emphasis id="823EA72F564CE4B9D81CEE2FA349FDD5" italics="true" pageId="null" pageNumber="448">2n</emphasis>
= 
<emphasis id="35B4CBF7F2682A81C6FE13D18C35F1A9" italics="true" pageId="null" pageNumber="448">28:</emphasis>
Material aus botanischen 
<normalizedToken id="DC8EF40C04E6B06F289E4662A2A0A28D" originalValue="Gärten" pageId="null" pageNumber="448">Gaerten</normalizedToken>
(
<taxonomicName id="754CA6F89F8237664FE09BD22C3B3527" pageId="null" pageNumber="448" rank="variety" variety="glaucescens">
<emphasis id="724A9B32BC3DEE71C2BADA26A9AA2951" italics="true" pageId="null" pageNumber="448">var. glaucescens</emphasis>
</taxonomicName>
)
<emphasis id="B4AE003F99C333CBC6358FC844837320" italics="true" pageId="null" pageNumber="448">;</emphasis>
14 univalente und 14 bivalente Chromosomen (
<normalizedToken id="0AC18D78B84AB3E6F1FBA5A2D62BD9B0" originalValue="Täckholm" pageId="null" pageNumber="448">Taeckholm</normalizedToken>
1922, Hurst 1928, Fagerlind 1945); Material aus der Tschechoslowakei (
<normalizedToken id="2FC449655A0DC21A42407B1B247640A1" originalValue="Klästersky" pageId="null" pageNumber="448">Klaestersky</normalizedToken>
in 
<normalizedToken id="26CAD7BED7E7CB016E00DA21F2128931" originalValue="Löve" pageId="null" pageNumber="448">Loeve</normalizedToken>
1969a).
</paragraph>
<paragraph id="CD1DFE8BEFD40C9B3EFAD7D46A2A8872" pageId="null" pageNumber="448">
<emphasis id="AC3AFCE6703654C547CE048E3FCD2804" italics="true" pageId="null" pageNumber="448">Standort.</emphasis>
Montan und subalpin. Auf 
<normalizedToken id="667640674835629C9C25244392FF2745" originalValue="Felsbänken" pageId="null" pageNumber="448">Felsbaenken</normalizedToken>
und Steinhaufen (kalkhaltige und saure Gesteine) mit 
<normalizedToken id="94C6003212A1ABD21DDF068D4E7B1AF7" originalValue="dünner" pageId="null" pageNumber="448">duenner</normalizedToken>
Erdschicht in sonniger Lage. 
<emphasis id="8F414732A61AB31D8990FBD03A9A39AF" italics="true" pageId="null" pageNumber="448">Berberis-, Corylus-</emphasis>
und 
<emphasis id="656101031270D133ABE2D34572E63BAF" italics="true" pageId="null" pageNumber="448">Amelanehierge</emphasis>
<normalizedToken id="3E14AF7DB87D4E06109443F0453114E0" originalValue="büsch" pageId="null" pageNumber="448">buesch</normalizedToken>
.
</paragraph>
<paragraph id="730F8902D6EFEC330B3020BDC25F9823" pageId="null" pageNumber="448">
<emphasis id="FE18E1E6FBB994D730BFBE4072252324" italics="true" pageId="null" pageNumber="448">
Verbreitung. Mittel- und 
<normalizedToken id="3A21EDA4472DA63438F57EEDAC644A60" originalValue="südeuropäische" pageId="null" pageNumber="448">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
<normalizedToken id="8D6316B252EE83E6C4BA90BA13FA1D21" originalValue="Pyrenäen" pageId="null" pageNumber="448">Pyrenaeen</normalizedToken>
, Alpen, Jura, Vogesen, Schwarzwald, 
<normalizedToken id="4CF1661CDC466B8AB707856A901B0187" originalValue="Schwäbischer" pageId="null" pageNumber="448">Schwaebischer</normalizedToken>
Jura, Karpaten, Apennin, Gebirge der Balkanhalbinsel. - Im Gebiet in den Alpen verbreitet (Nordalpen seltener), im Jura von Westen her bis in den Aargauer Jura (Wasserfluh, Gislifluh), Vogesen, 
<normalizedToken id="0D4CB650067C3D1AA45F951BEA9958E6" originalValue="Südschwarzwald" pageId="null" pageNumber="448">Suedschwarzwald</normalizedToken>
.
</paragraph>
<paragraph id="9F0DB6A9274CDA5D5C7F08B7EAA4151E" pageId="null" pageNumber="448">
<emphasis id="29AA17B89490FD2FB8FF80665CEE27AD" italics="true" pageId="null" pageNumber="448">
Bemerkungen. 
<taxonomicName id="31D6924BD7BDE888AAF58839FB3F3B95" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="448" phylum="Tracheophyta" rank="species" species="rubrifolia">R. rubrifolia</taxonomicName>
</emphasis>
ist die einzige Art der Subsektion 
<emphasis id="DC18DDB500C82477F8E5338A8ED87B6D" italics="true" pageId="null" pageNumber="448">Rubrifoliae</emphasis>
<normalizedToken id="679213DE8F8F89853D7F45D9FA443D1C" originalValue="Crépin" pageId="null" pageNumber="448">Crepin</normalizedToken>
(Sektion 
<emphasis id="B017740F8FE53C2B7F06C62F10674D2E" italics="true" pageId="null" pageNumber="448">Caninae</emphasis>
<normalizedToken id="81F6EF9511CFDD582658B8393FEF3BB5" originalValue="Crépin" pageId="null" pageNumber="448">Crepin</normalizedToken>
).
</paragraph>
</subSubSection>
