<paragraph id="8BF936A7815645573DA32E0FFCBAD554" blockId="12.[136,1452,1562,2093]" box="[136,849,1562,1589]" pageId="12" pageNumber="267">
<heading id="D0B181CB815645573DA32E0FFCBAD554" bold="true" box="[136,849,1562,1589]" fontSize="11" level="1" pageId="12" pageNumber="267" reason="1">
<emphasis id="B932EAB5815645573DA32E0FFCBAD554" bold="true" box="[136,849,1562,1589]" pageId="12" pageNumber="267">
The 
<emphasis id="B932EAB5815645573D952E0FFDE1D555" bold="true" box="[190,522,1562,1589]" italics="true" pageId="12" pageNumber="267">
<taxonomicName id="4C464D24815645573D952E0FFE49D555" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Nevski" baseAuthorityYear="1937" box="[190,418,1562,1589]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="kuhitangi">Elwendia kuhitangi</taxonomicName>
– 
<taxonomicName id="4C464D24815645573C9B2E0EFDE1D555" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Korovin" baseAuthorityYear="1924" box="[432,522,1562,1589]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="salsa">E. salsa</taxonomicName>
</emphasis>
complex in the Pamir-Alay
</emphasis>
</heading>
</paragraph>
</subSubSection>
<subSubSection id="C35C652C815645563DA32E2BFAE9D2F0" lastPageId="13" lastPageNumber="268" pageId="12" pageNumber="267" type="discussion">
<paragraph id="8BF936A7815645573DA32E2BFB01D434" blockId="12.[136,1452,1562,2093]" pageId="12" pageNumber="267">
<taxonomicName id="4C464D24815645573DA32E2BFE8ED538" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Nevski" baseAuthorityYear="1937" box="[136,357,1598,1624]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="kuhitangi">
<emphasis id="B932EAB5815645573DA32E2BFE8ED538" box="[136,357,1598,1624]" italics="true" pageId="12" pageNumber="267">Elwendia kuhitangi</emphasis>
</taxonomicName>
was described by 
<bibRefCitation id="EFD74B56815645573F172E2BFD34D538" author="Nevski, S. A." box="[572,735,1598,1624]" pageId="12" pageNumber="267" pagination="199 - 346" refId="ref10578" refString="Nevski, S. A. (1937) Materials for flora of Kuhitang and its foothills. Transactions of Institute of Botany of Akademy of Science of SSSR. Series 1, flora and systematics of higher plants 4: 199 - 346. [In Russian]" type="journal article" year="1937">Nevski (1937)</bibRefCitation>
from the Kuhitang Range as 
<taxonomicName id="4C464D2481564557391D2E2AFF54D51C" authority="Nevski (1937: 274)" authorityName="Nevski" authorityPageNumber="274" authorityYear="1937" class="Magnoliopsida" family="Apiaceae" genus="Bunium" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="kuhitangi">
<emphasis id="B932EAB581564557391D2E2AFAEAD538" box="[1078,1281,1598,1624]" italics="true" pageId="12" pageNumber="267">Bunium kuhitangi</emphasis>
<bibRefCitation id="EFD74B568156455738212E2BFF54D51C" author="Nevski, S. A." pageId="12" pageNumber="267" pagination="199 - 346" refId="ref10578" refString="Nevski, S. A. (1937) Materials for flora of Kuhitang and its foothills. Transactions of Institute of Botany of Akademy of Science of SSSR. Series 1, flora and systematics of higher plants 4: 199 - 346. [In Russian]" type="journal article" year="1937">Nevski (1937: 274)</bibRefCitation>
</taxonomicName>
. In the protologue, a detailed description of mature fruits that is required for certain identification is lacking. In floristic publications, all high-mountain dwarf plants occurring in the Pamir-Alay from the Kuhitang and Western Hissar Ranges to Darwaz (
<bibRefCitation id="EFD74B56815645573C4D2EBFFDE3D5A5" author="Korovin, E. P." box="[358,520,1706,1733]" pageId="12" pageNumber="267" pagination="396 - 411" refId="ref10242" refString="Korovin, E. P. (1950) Bunium L. In: Schischkin, B. K. (Ed.) Flora of USSR, vol. 16. Academy of Sciences of the URSS, Moscow &amp; Leningrad, pp. 396 - 411. [In Russian]" type="book chapter" year="1950">Korovin 1950</bibRefCitation>
, 
<bibRefCitation id="EFD74B56815645573F3F2EBFFDA4D5A5" author="Korovin, E. P." box="[532,591,1706,1733]" pageId="12" pageNumber="267" pagination="257 - 470" refId="ref10295" refString="Korovin, E. P. (1959) Umbelliferae. In: Vvedensky, A. I. (Ed.) Flora of Uzbekistan, vol. 4. Academy of Science Uzbek SSR, Tashkent, pp. 257 - 470. [In Russian]" type="book chapter" year="1959">1959</bibRefCitation>
; 
<bibRefCitation id="EFD74B56815645573F772EBFFC7AD5A4" author="Kljuykov, E. V. &amp; Pimenov, M. G." box="[604,913,1706,1732]" pageId="12" pageNumber="267" pagination="228 - 235" refId="ref9935" refString="Kljuykov, E. V. &amp; Pimenov, M. G. (1983) Bunium L. In: Adylov, T. A. (Ed.) Opredelitel' rasteniy Sredney Asii: kriticheskiy konspekt flory, vol. 7. Fan, Tashkent, pp. 228 - 235. [In Russian]" type="book chapter" year="1983">Kljuykov &amp; Pimenov 1983</bibRefCitation>
; 
<bibRefCitation id="EFD74B56815645573EB52EBFFB96D5A4" author="Korovin, E. P. &amp; Pimenov, M. G. &amp; Kinzikayeva, G. K." box="[926,1149,1706,1732]" pageId="12" pageNumber="267" pagination="10 - 214" refId="ref10344" refString="Korovin, E. P., Pimenov, M. G. &amp; Kinzikayeva, G. K. (1984) Umbelliferae Moris. In: Ovchinnikov, P. N. (Ed.) Flora of the Tajik SSR, vol. 7. Academy of Sciences of USSR, Moscow &amp; Leningrad, pp. 10 - 214. [In Russian]" type="book chapter" year="1984">
Korovin 
<emphasis id="B932EAB58156455739282EBEFBD7D5A4" box="[1027,1084,1706,1732]" italics="true" pageId="12" pageNumber="267">et al.</emphasis>
1984
</bibRefCitation>
) and in North 
<collectingCountry id="F35176378156455738082EBFFA47D5A4" box="[1315,1452,1706,1732]" name="Afghanistan" pageId="12" pageNumber="267">Afghanistan</collectingCountry>
and East 
<collectingCountry id="F3517637815645573DD82EDAFECBD589" box="[243,288,1743,1769]" name="Iran" pageId="12" pageNumber="267">Iran</collectingCountry>
(
<bibRefCitation id="EFD74B56815645573C1B2EDBFE0CD588" author="Rechinger, K. H." box="[304,487,1742,1768]" pageId="12" pageNumber="267" pagination="236 - 257" refId="ref10656" refString="Rechinger, K. H. (1987) Bunium. In: Hedge, I. C., Lamond, J. M., Rechinger, K. H., et al. (1987) Umbelliferae. In: Rechinger, K. H. (Ed.) Flora iranica, vol. 162. Akademische Druck- und Verlagsanstalt, Graz, Austria, pp. 236 - 257." type="book chapter" year="1987">Rechinger 1987</bibRefCitation>
) passed under the name 
<taxonomicName id="4C464D24815645573E2E2EDAFC7BD588" authorityName="Nevski" authorityYear="1937" box="[773,912,1742,1768]" class="Magnoliopsida" family="Apiaceae" genus="Bunium" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="kuhitangi">
<emphasis id="B932EAB5815645573E2E2EDAFC7BD588" box="[773,912,1742,1768]" italics="true" pageId="12" pageNumber="267">B. kuhitangi</emphasis>
</taxonomicName>
. 
<taxonomicName id="4C464D24815645573E8B2EDBFBA6D588" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Korovin" baseAuthorityYear="1924" box="[928,1101,1742,1768]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="salsa">
<emphasis id="B932EAB5815645573E8B2EDBFBA6D588" box="[928,1101,1742,1768]" italics="true" pageId="12" pageNumber="267">Elwendia salsa</emphasis>
</taxonomicName>
was first described as 
<taxonomicName id="4C464D2481564557387F2EDAFE51D46D" authority="Korovin (1924: 86)" authorityName="Korovin" authorityPageNumber="86" authorityYear="1924" class="Magnoliopsida" family="Apiaceae" genus="Bunium" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="salsum">
<emphasis id="B932EAB581564557387F2EDAFF3DD46C" italics="true" pageId="12" pageNumber="267">Bunium salsum</emphasis>
<bibRefCitation id="EFD74B56815645573DF52EE7FE51D46D" author="Korovin, E. P." box="[222,442,1778,1805]" pageId="12" pageNumber="267" pagination="81 - 86" refId="ref10139" refString="Korovin, E. P. (1924) Umbelliferae turkestanicae novae. Botanicheskie materialy Gerbariya Glavnogo Botanicheskogo Sada RSFSR 5 (6): 81 - 86." type="journal article" year="1924">Korovin (1924: 86)</bibRefCitation>
</taxonomicName>
from the vicinities of Samarkand and treated as closely related to 
<taxonomicName id="4C464D248156455739872EE7FA63D46C" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Nevski" baseAuthorityYear="1937" box="[1196,1416,1778,1804]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="kuhitangi">
<emphasis id="B932EAB58156455739872EE7FA63D46C" box="[1196,1416,1778,1804]" italics="true" pageId="12" pageNumber="267">Elwendia kuhitangi</emphasis>
</taxonomicName>
by 
<bibRefCitation id="EFD74B56815645573DA32F03FEA3D450" author="Kljuykov, E. V." box="[136,328,1814,1840]" pageId="12" pageNumber="267" pagination="76 - 89" refId="ref9894" refString="Kljuykov, E. V. (1988) A survey of the genus Bunium L. Revision of the generic system. Byulleten' Moskovskogo Obshchestva Ispytatelei Prirody. Otdel biologicheskii 93: 76 - 89. [In Russian]" type="journal article" year="1988">Kljuykov (1988)</bibRefCitation>
. In contrast to 
<taxonomicName id="4C464D24815645573CD92F02FD97D450" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Nevski" baseAuthorityYear="1937" box="[498,636,1814,1840]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="kuhitangi">
<emphasis id="B932EAB5815645573CD92F02FD97D450" box="[498,636,1814,1840]" italics="true" pageId="12" pageNumber="267">E. kuhitangi</emphasis>
</taxonomicName>
, 
<taxonomicName id="4C464D24815645573FA02F02FD0ED450" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Korovin" baseAuthorityYear="1924" box="[651,741,1814,1840]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="salsa">
<emphasis id="B932EAB5815645573FA02F02FD0ED450" box="[651,741,1814,1840]" italics="true" pageId="12" pageNumber="267">E. salsa</emphasis>
</taxonomicName>
is morphologically more fully characterised and has a broader distribution area in midlands and low mountains of the Western Pamir-Alay and Western Tian-Shan.
</paragraph>
<paragraph id="8BF936A7815645573D962F4BFCF3DB68" blockId="12.[136,1452,1562,2093]" pageId="12" pageNumber="267">
<bibRefCitation id="EFD74B56815645573D962F4BFE93D418" author="Kljuykov, E. V." box="[189,376,1886,1912]" pageId="12" pageNumber="267" pagination="76 - 89" refId="ref9894" refString="Kljuykov, E. V. (1988) A survey of the genus Bunium L. Revision of the generic system. Byulleten' Moskovskogo Obshchestva Ispytatelei Prirody. Otdel biologicheskii 93: 76 - 89. [In Russian]" type="journal article" year="1988">Kljuykov (1988)</bibRefCitation>
formally described 
<taxonomicName id="4C464D24815645573F7E2F4AFCA5D418" box="[597,846,1886,1912]" class="Magnoliopsida" family="Apiaceae" genus="Bunium" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="subSection" subSection="Salsa">
<emphasis id="B932EAB5815645573F7E2F4AFD47D418" box="[597,684,1887,1912]" italics="true" pageId="12" pageNumber="267">Bunium</emphasis>
subsect. 
<emphasis id="B932EAB5815645573E3A2F4BFCA5D418" box="[785,846,1886,1912]" italics="true" pageId="12" pageNumber="267">Salsa</emphasis>
</taxonomicName>
to accommodate 
<taxonomicName id="4C464D2481564557393A2F4AFB72D418" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Nevski" baseAuthorityYear="1937" box="[1041,1177,1886,1912]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="kuhitangi">
<emphasis id="B932EAB581564557393A2F4AFB72D418" box="[1041,1177,1886,1912]" italics="true" pageId="12" pageNumber="267">E. kuhitangi</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C464D248156455739E62F4AFACED418" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Korovin" baseAuthorityYear="1924" box="[1229,1317,1886,1912]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="salsa">
<emphasis id="B932EAB58156455739E62F4AFACED418" box="[1229,1317,1886,1912]" italics="true" pageId="12" pageNumber="267">E. salsa</emphasis>
</taxonomicName>
. The shared characters used to justify this taxonomy were as follows: fruits with a strong smell, hardly separating into mericarp, pedicels length equal to a fruit; any of these characters is not unique in 
<taxonomicName id="4C464D24815645573EBD2FB3FBEBD4A0" authorityName="Boissier" authorityYear="1844" box="[918,1024,1958,1984]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="genus">
<emphasis id="B932EAB5815645573EBD2FB3FBEBD4A0" box="[918,1024,1958,1984]" italics="true" pageId="12" pageNumber="267">Elwendia</emphasis>
</taxonomicName>
. According to our results, 
<taxonomicName id="4C464D2481564557380F2FB2FA47D4A0" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Nevski" baseAuthorityYear="1937" box="[1316,1452,1958,1984]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="kuhitangi">
<emphasis id="B932EAB581564557380F2FB2FA47D4A0" box="[1316,1452,1958,1984]" italics="true" pageId="12" pageNumber="267">E. kuhitangi</emphasis>
</taxonomicName>
and 
<taxonomicName id="4C464D24815645573D912FDEFEFDD484" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Korovin" baseAuthorityYear="1924" box="[186,278,1994,2020]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="salsa">
<emphasis id="B932EAB5815645573D912FDEFEFDD484" box="[186,278,1994,2020]" italics="true" pageId="12" pageNumber="267">E. salsa</emphasis>
</taxonomicName>
represent a distinct lineage, placed in a clade together with 
<taxonomicName id="4C464D24815645573EF92FDEFBBFD484" box="[978,1108,1995,2020]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="ugamica">
<emphasis id="B932EAB5815645573EF92FDEFBBFD484" box="[978,1108,1995,2020]" italics="true" pageId="12" pageNumber="267">E. ugamica</emphasis>
</taxonomicName>
. Thus, the morphology-based classification was confirmed by our phylogenetic analysis.
</paragraph>
<paragraph id="8BF936A7815645563D962007FF27D244" blockId="12.[136,1452,1562,2093]" lastBlockId="13.[136,1451,158,401]" lastPageId="13" lastPageNumber="268" pageId="12" pageNumber="267">
Based on the present study, we expand the description of 
<taxonomicName id="4C464D24815645573E1C2006FC54DB4C" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Nevski" baseAuthorityYear="1937" box="[823,959,2066,2092]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="12" pageNumber="267" phylum="Tracheophyta" rank="species" species="kuhitangi">
<emphasis id="B932EAB5815645573E1C2006FC54DB4C" box="[823,959,2066,2092]" italics="true" pageId="12" pageNumber="267">E. kuhitangi</emphasis>
</taxonomicName>
with fruit characters and propose diagnostic characters to distinguish between 
<taxonomicName id="4C464D24815745563F2D288AFD7BD3D8" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Nevski" baseAuthorityYear="1937" box="[518,656,158,184]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="13" pageNumber="268" phylum="Tracheophyta" rank="species" species="kuhitangi">
<emphasis id="B932EAB5815745563F2D288AFD7BD3D8" box="[518,656,158,184]" italics="true" pageId="13" pageNumber="268">E. kuhitangi</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A20157CE815745563FBC288AFD20D3D9" box="[663,715,159,185]" pageId="13" pageNumber="268" sensu="stricto">s.str.</taxonomicNameLabel>
and 
<taxonomicName id="4C464D24815745563E29288AFCB7D3D8" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Korovin" baseAuthorityYear="1924" box="[770,860,158,184]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="13" pageNumber="268" phylum="Tracheophyta" rank="species" species="salsa">
<emphasis id="B932EAB5815745563E29288AFCB7D3D8" box="[770,860,158,184]" italics="true" pageId="13" pageNumber="268">E. salsa</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A20157CE815745563E48288AFC73D3D9" box="[867,920,159,185]" pageId="13" pageNumber="268" sensu="stricto">s.str.</taxonomicNameLabel>
, such as the length of terminal segments of the uppermost stem leaves (
<quantity id="4CBE9B42815745563CB728D7FE17D3BD" box="[412,508,194,221]" metricMagnitude="-3" metricUnit="m" metricValue="4.0" metricValueMax="5.0" metricValueMin="3.0" pageId="13" pageNumber="268" unit="mm" value="4.0" valueMax="5.0" valueMin="3.0">3–5 mm</quantity>
vs. 
<quantity id="4CBE9B42815745563F0628D7FD75D3BD" box="[557,670,194,221]" metricMagnitude="-3" metricUnit="m" metricValue="9.5" metricValueMax="12.0" metricValueMin="7.0" pageId="13" pageNumber="268" unit="mm" value="9.5" valueMax="12.0" valueMin="7.0">7–12 mm</quantity>
), number of umbel rays (2–3 vs. 5–10), shape and size of mericarps (narrowly linear vs. linear). Besides, the fruits of 
<taxonomicName id="4C464D24815745563F8528F2FCDCD260" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Nevski" baseAuthorityYear="1937" box="[686,823,230,256]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="13" pageNumber="268" phylum="Tracheophyta" rank="species" species="kuhitangi">
<emphasis id="B932EAB5815745563F8528F2FCDCD260" box="[686,823,230,256]" italics="true" pageId="13" pageNumber="268">E. kuhitangi</emphasis>
</taxonomicName>
separate easier into mericarps and have a less expressed smell.
</paragraph>
<paragraph id="8BF936A7815745563D96293BFAE9D2F0" blockId="13.[136,1451,158,401]" pageId="13" pageNumber="268">
With regards to the distribution, 
<taxonomicName id="4C464D24815745563F16293AFD21D228" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Nevski" baseAuthorityYear="1937" box="[573,714,302,328]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="13" pageNumber="268" phylum="Tracheophyta" rank="species" species="kuhitangi">
<emphasis id="B932EAB5815745563F16293AFD21D228" box="[573,714,302,328]" italics="true" pageId="13" pageNumber="268">E. kuhitangi</emphasis>
</taxonomicName>
is restricted to the Kuhitang Range (Tukmenistan, 
<collectingCountry id="F351763781574556380F293BFA4FD229" box="[1316,1444,302,329]" name="Uzbekistan" pageId="13" pageNumber="268">Uzbekistan</collectingCountry>
) (
<bibRefCitation id="EFD74B56815745563DA42947FE93D20C" author="Kljuykov, E. V. &amp; Tojibaev, K. Sh. &amp; Lyskov, D. F." box="[143,376,338,364]" pageId="13" pageNumber="268" pagination="210 - 220" refId="ref10080" refString="Kljuykov, E. V., Tojibaev, K. Sh. &amp; Lyskov, D. F. (2018) The genus Elwendia Boiss. (Apiaceae) in the flora of Uzbekistan. Turczaninovia 21 (2): 210 - 220. https: // doi. org / 10.14258 / turczaninowia. 21.2.18" type="journal article" year="2018">
Kljuykov 
<emphasis id="B932EAB5815745563C2A2946FEDCD20C" box="[257,311,338,364]" italics="true" pageId="13" pageNumber="268">et al.</emphasis>
2018
</bibRefCitation>
), whereas 
<taxonomicName id="4C464D24815745563CC02946FDA8D20C" authorityName="Pimenov &amp; Kljuykov" baseAuthorityName="Korovin" baseAuthorityYear="1924" box="[491,579,338,364]" class="Magnoliopsida" family="Apiaceae" genus="Elwendia" kingdom="Plantae" order="Apiales" pageId="13" pageNumber="268" phylum="Tracheophyta" rank="species" species="salsa">
<emphasis id="B932EAB5815745563CC02946FDA8D20C" box="[491,579,338,364]" italics="true" pageId="13" pageNumber="268">E. salsa</emphasis>
</taxonomicName>
is characterised by a broader distribution range from 
<collectingCountry id="F35176378157455639A62947FAE0D20C" box="[1165,1291,338,364]" name="Uzbekistan" pageId="13" pageNumber="268">Uzbekistan</collectingCountry>
and 
<collectingCountry id="F35176378157455638162947FA40D20C" box="[1341,1451,338,364]" name="Tajikistan" pageId="13" pageNumber="268">Tajikistan</collectingCountry>
to 
<collectingCountry id="F3517637815745563D8E2962FECDD2F1" box="[165,294,375,401]" name="Kyrgyzstan" pageId="13" pageNumber="268">Kyrgyzstan</collectingCountry>
(
<bibRefCitation id="EFD74B56815745563C1F2963FE3ED2F1" author="Korovin, E. P." box="[308,469,374,401]" pageId="13" pageNumber="268" pagination="257 - 470" refId="ref10295" refString="Korovin, E. P. (1959) Umbelliferae. In: Vvedensky, A. I. (Ed.) Flora of Uzbekistan, vol. 4. Academy of Science Uzbek SSR, Tashkent, pp. 257 - 470. [In Russian]" type="book chapter" year="1959">Korovin 1959</bibRefCitation>
; 
<bibRefCitation id="EFD74B56815745563CCA2963FCFFD2F0" author="Kljuykov, E. V. &amp; Pimenov, M. G." box="[481,788,374,400]" pageId="13" pageNumber="268" pagination="228 - 235" refId="ref9935" refString="Kljuykov, E. V. &amp; Pimenov, M. G. (1983) Bunium L. In: Adylov, T. A. (Ed.) Opredelitel' rasteniy Sredney Asii: kriticheskiy konspekt flory, vol. 7. Fan, Tashkent, pp. 228 - 235. [In Russian]" type="book chapter" year="1983">Kljuykov &amp; Pimenov 1983</bibRefCitation>
; 
<bibRefCitation id="EFD74B56815745563E0B2963FC15D2F0" author="Korovin, E. P. &amp; Pimenov, M. G. &amp; Kinzikayeva, G. K." box="[800,1022,374,400]" pageId="13" pageNumber="268" pagination="10 - 214" refId="ref10344" refString="Korovin, E. P., Pimenov, M. G. &amp; Kinzikayeva, G. K. (1984) Umbelliferae Moris. In: Ovchinnikov, P. N. (Ed.) Flora of the Tajik SSR, vol. 7. Academy of Sciences of USSR, Moscow &amp; Leningrad, pp. 10 - 214. [In Russian]" type="book chapter" year="1984">
Korovin 
<emphasis id="B932EAB5815745563EAF2962FC57D2F0" box="[900,956,374,400]" italics="true" pageId="13" pageNumber="268">et al.</emphasis>
1984
</bibRefCitation>
; 
<bibRefCitation id="EFD74B568157455639212963FB1CD2F0" author="Kljuykov, E. V. &amp; Tojibaev, K. Sh. &amp; Lyskov, D. F." box="[1034,1271,374,400]" pageId="13" pageNumber="268" pagination="210 - 220" refId="ref10080" refString="Kljuykov, E. V., Tojibaev, K. Sh. &amp; Lyskov, D. F. (2018) The genus Elwendia Boiss. (Apiaceae) in the flora of Uzbekistan. Turczaninovia 21 (2): 210 - 220. https: // doi. org / 10.14258 / turczaninowia. 21.2.18" type="journal article" year="2018">
Kljuykov 
<emphasis id="B932EAB58157455639502962FB58D2F0" box="[1147,1203,374,400]" italics="true" pageId="13" pageNumber="268">et al.</emphasis>
2018
</bibRefCitation>
).
</paragraph>
