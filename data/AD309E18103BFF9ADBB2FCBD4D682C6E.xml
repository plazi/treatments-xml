<paragraph id="25262F0E1005FF9ADBE2FA8A48B82D46" blockId="32.[151,1437,1473,1859]" pageId="32" pageNumber="133">
<emphasis id="17EDF31C1005FF9ADBE2FA8A4D432EF6" bold="true" box="[199,374,1473,1499]" pageId="32" pageNumber="133">Measurements</emphasis>
