<subSubSection id="35DA6DBAB30BE37F97828C088AE27C06" pageId="null" pageNumber="66" type="description">
<paragraph id="67FA965BE8FD6F11E27DF6A476DC51A0" pageId="null" pageNumber="66">
<emphasis id="89FCAB5F9993241EEA4351C9D234B6B4" italics="true" pageId="null" pageNumber="66">
Rhizom 
<normalizedToken id="D70C1735B2068DA04796F4473907E89D" originalValue="dünn" pageId="null" pageNumber="66">duenn</normalizedToken>
, lang, mit entfernt stehenden, kugeligen Knollen von 1
</emphasis>
- 
<emphasis id="F6D38C65DC0E8B1C6C07F63C50899942" italics="true" pageId="null" pageNumber="66">2 cm Durchmesser.</emphasis>
Stengel 0,2-0,5 m hoch, locker und abstehend behaart (zerstreute, nach dem Grunde kaum verdickte Borstenhaare und ziemlich dicht stehende, kurze, flaumige Haare). 
<normalizedToken id="3122E2B71B018CCBEAC0440F5515ABF8" originalValue="Blätter" pageId="null" pageNumber="66">Blaetter</normalizedToken>
3-15 cm lang, 
<normalizedToken id="1C3618ED1C4810DB705816751E54B88C" originalValue="1½" pageId="null" pageNumber="66">11/2</normalizedToken>
bis 
<normalizedToken id="E857F98E16E20BEBCD0791F936B42FBA" originalValue="2½" pageId="null" pageNumber="66">21/2</normalizedToken>
mal so lang wie breit, die 
<normalizedToken id="56A18B4B12E03B48D3BE5ED934E054B0" originalValue="größten" pageId="null" pageNumber="66">groessten</normalizedToken>
im mittleren Stengelteil, am Grunde 
<normalizedToken id="7C3A27EAD72AFB8BD7ECA030FF0C5F69" originalValue="plötzlich" pageId="null" pageNumber="66">ploetzlich</normalizedToken>
<normalizedToken id="AE4DCEDB88F6229542FDCFA9012903F0" originalValue="verschmälert" pageId="null" pageNumber="66">verschmaelert</normalizedToken>
(gestutzt oder abgerundet), die untern lang gestielt, die obern mit kurzem, 
<normalizedToken id="567E0AD63DB6881011DEA951A8664AE8" originalValue="geflügeltem" pageId="null" pageNumber="66">gefluegeltem</normalizedToken>
Stiel, 
<emphasis id="FABC8C285D6F5BFA0A068132A78E1FD9" italics="true" pageId="null" pageNumber="66">
dessen 
<normalizedToken id="76A06B82B8B526D31CE312CDA1263A25" originalValue="Flügel" pageId="null" pageNumber="66">Fluegel</normalizedToken>
dem Stengel entlang herablaufen, jedoch selten tiefer als bis zur Mitte des Intervalls bis zum 
<normalizedToken id="3FBAE389A2CF5378BF9818A7D5590DB0" originalValue="nächsten" pageId="null" pageNumber="66">naechsten</normalizedToken>
untern Blatt.
</emphasis>
Krone 1-1,4 cm lang, 
<emphasis id="9181316735A76ECBF476C0735B1B4088" italics="true" pageId="null" pageNumber="66">gelblich; Schlundschuppen nach dem Platzen der Staubbeutel die Kronzipfel um 0,5</emphasis>
- 
<emphasis id="88CC371922A2DDA2629C5E9A3D13BB26" italics="true" pageId="null" pageNumber="66">
2 mm 
<normalizedToken id="89F36C521872A5B41F9E9A1A8C22C920" originalValue="überragend" pageId="null" pageNumber="66">ueberragend</normalizedToken>
.
</emphasis>
- 
<normalizedToken id="C81BA50FD37F0A66BE30A8161AB4E847" originalValue="Blüte" pageId="null" pageNumber="66">Bluete</normalizedToken>
: 
<normalizedToken id="67393752638C2ABECC2B14721D1CD4A1" originalValue="Frühling" pageId="null" pageNumber="66">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="7DCF13850E9981DE296503685CA617B7" pageId="null" pageNumber="66">
<emphasis id="2E7E75907E3B27C08838CDF60437E21B" italics="true" pageId="null" pageNumber="66">Zytologische Angaben. 2n ca. 72:</emphasis>
Material aus der Gegend von Heidelberg (verwildert) (Strey 1931). 
<emphasis id="2CDDEE9A91E6F425F7B7597F4E913E2D" italics="true" pageId="null" pageNumber="66">2n</emphasis>
= 
<emphasis id="443DA9FF45E231E98EDA910A8791BB78" italics="true" pageId="null" pageNumber="66">82:</emphasis>
Material aus 
<normalizedToken id="E248F9FA9BE0652B2F35F4FAE30F8A33" originalValue="Rumänien" pageId="null" pageNumber="66">Rumaenien</normalizedToken>
(Tarnavschi 1948). 
<emphasis id="3A9F6AFD576FC2FDDCFA4C2FA5299EBF" italics="true" pageId="null" pageNumber="66">2n</emphasis>
= 
<emphasis id="53E0D6CFADCE5D9359581FD5F921DD2B" italics="true" pageId="null" pageNumber="66">84:</emphasis>
Material aus der Gegend von Heidelberg (Grau 1971).
</paragraph>
<paragraph id="31CC32D0BDCBB4148375D16A9D227D1B" pageId="null" pageNumber="66">
<emphasis id="5B641F0EC1AE4994839DC8B83A82CE99" italics="true" pageId="null" pageNumber="66">Standort.</emphasis>
Kollin und montan. Kalkhaltige 
<normalizedToken id="2F328E06726F22D8EB616DC4DB6448A7" originalValue="Böden" pageId="null" pageNumber="66">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="D328373000A88EDAC4BE60F36FCD52AC" originalValue="Waldränder" pageId="null" pageNumber="66">Waldraender</normalizedToken>
, Hecken, Weinberge.
</paragraph>
<paragraph id="10BCE8C25D046A4A0189A9F2BD8889F9" pageId="null" pageNumber="66">
<emphasis id="19263747471D226CDBB3641267755D13" italics="true" pageId="null" pageNumber="66">
Verbreitung. 
<normalizedToken id="00FF7BE3BF1518117E28C526F21AB678" originalValue="Südeuropäische" pageId="null" pageNumber="66">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="BD858C7C0346A79CBD5C3A20CC91190E" originalValue="Westwärts" pageId="null" pageNumber="66">Westwaerts</normalizedToken>
bis Seealpen und Korsika; 
<normalizedToken id="915D1B1238E10742BDC7BAF76E300071" originalValue="nordwärts" pageId="null" pageNumber="66">nordwaerts</normalizedToken>
bis 
<normalizedToken id="219433F53B6560F525DF65868A7F8FC9" originalValue="Alpensüdrand" pageId="null" pageNumber="66">Alpensuedrand</normalizedToken>
; 
<normalizedToken id="DF1DE4BAD42F09B4E059E57D365899F0" originalValue="ostwärts" pageId="null" pageNumber="66">ostwaerts</normalizedToken>
bis Jugoslawien und Griechenland; 
<normalizedToken id="0C3AB011C8937C2C82BD2D919A55D5F6" originalValue="südwärts" pageId="null" pageNumber="66">suedwaerts</normalizedToken>
bis Sizilien. - Im Gebiet: 
<normalizedToken id="686B14D9C248C8D7238D8C8277D1A362" originalValue="Südliches" pageId="null" pageNumber="66">Suedliches</normalizedToken>
Tessin (Gegend von Locarno, Val Onsernone, Lugano, Monte Generoso), Bergamasker Alpen (Valtesse); im 
<normalizedToken id="78DA191A1315821BCA9D369F572D19B1" originalValue="Elsaß" pageId="null" pageNumber="66">Elsass</normalizedToken>
<normalizedToken id="76627BC2B9F8C709AD4EF2E6AF233EF6" originalValue="eingebürgert" pageId="null" pageNumber="66">eingebuergert</normalizedToken>
(Florimont, Staufen, Thann, Wissembourg).
</paragraph>
</subSubSection>
