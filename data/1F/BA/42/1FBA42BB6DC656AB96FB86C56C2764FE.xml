<taxonomicName authorityName="Silva Pereira &amp; Oliveira &amp; Desidério &amp; Calor &amp; Hamada" authorityYear="2022" class="Insecta" family="Leptoceridae" genus="Notalina" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Notalina (Neonotalina) ralphi" order="Trichoptera" pageId="0" pageNumber="413" phylum="Arthropoda" rank="species" species="ralphi" subGenus="Neonotalina">Notalina (Neonotalina) ralphi</taxonomicName>
