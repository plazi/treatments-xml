<subSubSection id="8BD7EB8D0DE202A067344EEB4DA83550" pageId="null" pageNumber="483" type="description">
<paragraph id="3319147602CE0149698F1252C4BA889D" pageId="null" pageNumber="483">
<emphasis id="94EEC05170DAB06ED872EAF31DE40E23" italics="true" pageId="null" pageNumber="483">
<normalizedToken id="5F0B571817FB5E83A4765FE9FB3A2474" originalValue="Hülle" pageId="null" pageNumber="483">Huelle</normalizedToken>
deutlich 
<normalizedToken id="5C82E0F5808B3A4DEE22F3C2C3BA5F8E" originalValue="länger" pageId="null" pageNumber="483">laenger</normalizedToken>
als dick
</emphasis>
, 4-6 mm lang und 3-4 mm dick, 
<emphasis id="B6F394AF6F5A3191B743F4B9A430A03B" italics="true" pageId="null" pageNumber="483">
zylindrisch bis 
<normalizedToken id="B1D7875CC3BF2CEAFCAC130EB9B0F8FB" originalValue="glockenförmig" pageId="null" pageNumber="483">glockenfoermig</normalizedToken>
. Die innern 
<normalizedToken id="345DAA7F831D7FBA29755A9AA6B874A3" originalValue="Hüllblätter" pageId="null" pageNumber="483">Huellblaetter</normalizedToken>
3
</emphasis>
- 
<emphasis id="D97E07E50A9E8F612BFCD34A1D6082F5" italics="true" pageId="null" pageNumber="483">
4mal so lang wie die 
<normalizedToken id="C927F4FCFD1B293E742E3A1D1A2347CA" originalValue="äußern" pageId="null" pageNumber="483">aeussern</normalizedToken>
.
</emphasis>
Sonst wie 
<taxonomicName id="50BAC96B8862BB13C9EDFAC8A42D4997" class="Magnoliopsida" family="Asteraceae" genus="Helichrysum" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="483" phylum="Tracheophyta" rank="species" species="stoechas">
<emphasis id="0C397F1F0A68A5D83995D024E937046D" italics="true" pageId="null" pageNumber="483">H. Stoechas</emphasis>
</taxonomicName>
(Nr. 1). - 
<normalizedToken id="74D6842DF4102F144BE738027455B6B6" originalValue="Blüte" pageId="null" pageNumber="483">Bluete</normalizedToken>
: 
<normalizedToken id="D4C3F11E048229485DF13517104D5552" originalValue="Später" pageId="null" pageNumber="483">Spaeter</normalizedToken>
<normalizedToken id="F378489B9D57480E34AFB0069F50F4D4" originalValue="Frühling" pageId="null" pageNumber="483">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="48DADF88FD0C38DDD77626CAD3371E01" pageId="null" pageNumber="483">
<emphasis id="28DC0F02A27305B4537340063A8C73D9" italics="true" pageId="null" pageNumber="483">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="249C5BCAF926FB0549C445F6880AC9BE" italics="true" pageId="null" pageNumber="483">28:</emphasis>
Material aus Mittelitalien (Mori 1957), aus Jugoslawien (Nilsson und Lassen 1971).
</paragraph>
<paragraph id="D10ED121B42D46B010FD830A5371488D" pageId="null" pageNumber="483">
<emphasis id="3EB8E710E955C9E0C219F866D3AB89BF" italics="true" pageId="null" pageNumber="483">Standort.</emphasis>
Kollin. Trockene, meist kalkreiche, steinige oder felsige 
<normalizedToken id="B1116EA014F1241AC028ECCD3BC79FD4" originalValue="Böden" pageId="null" pageNumber="483">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="8F79288FAAFDD1D9294060BE753CDBB3" originalValue="Grasplätze" pageId="null" pageNumber="483">Grasplaetze</normalizedToken>
, Felsen.
</paragraph>
<paragraph id="1CFCDD6ABFEA5573267E8AB5EB66BEB4" pageId="null" pageNumber="483">
<emphasis id="3F350834A071C53F40241CE8FD55F183" italics="true" pageId="null" pageNumber="483">
Verbreitung. 
<normalizedToken id="800E66EEE548C61EB2103BF274394818" originalValue="Südeuropäische" pageId="null" pageNumber="483">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="813E0EB3AC98EDE73C29BC2B0E1AD35D" originalValue="Östliche" pageId="null" pageNumber="483">Oestliche</normalizedToken>
Iberische Halbinsel, 
<normalizedToken id="4BB0F33F2883C565118071C7C5A0C15E" originalValue="Südfrankreich" pageId="null" pageNumber="483">Suedfrankreich</normalizedToken>
, Korsika, Apenninen- und Balkanhalbinsel, Zypern. - Im Gebiet: 
<normalizedToken id="40402BFE9F2225D0582C1DDB011C54FF" originalValue="Südliches" pageId="null" pageNumber="483">Suedliches</normalizedToken>
Comerseegebiet (Rossino, Vercurago, Olgiate, Abbadia bei Lecco), 
<normalizedToken id="F272A31D4DC37A01233EC8EE3C188EA3" originalValue="südöstliche" pageId="null" pageNumber="483">suedoestliche</normalizedToken>
Bergamasker Alpen (Adrara bei Sarnico, Valle Calepio, Westufer des Iseosees).
</paragraph>
</subSubSection>
