<emphasis id="A6FFFF3B29490976FC784E4AFC7FFCE0" box="[827,921,784,805]" italics="true" pageId="18" pageNumber="1062">Habitat:</emphasis>
Wet 
<taxonomicName id="538B58AA29490976FC9A4E4AFBB0FCE0" box="[985,1110,784,805]" class="Sphagnopsida" family="Sphagnaceae" genus="Sphagnum" kingdom="Plantae" order="Sphagnales" pageId="18" pageNumber="1062" phylum="Bryophyta" rank="genus">
<emphasis id="A6FFFF3B29490976FC9A4E4AFBB0FCE0" box="[985,1110,784,805]" italics="true" pageId="18" pageNumber="1062">Sphagnum</emphasis>
