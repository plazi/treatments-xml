<subSubSection id="C306789DFFCDFF9C6BB0FD73FBF7FCCE" pageId="7" pageNumber="572" type="discussion">
<paragraph id="8BA32B16FFCDFF9C6BB0FD73FBF7FCCE" blockId="7.[151,1436,701,870]" pageId="7" pageNumber="572">
This species was originally described from 
<collectingCountry id="F30B6B86FFCDFF9C69B3FD73FD0CFD7E" box="[660,722,701,726]" name="Israel" pageId="7" pageNumber="572">Israel</collectingCountry>
and recorded from 
<collectingCountry id="F30B6B86FFCDFF9C6898FD73FB86FD7E" box="[959,1112,701,726]" name="Saudi Arabia" pageId="7" pageNumber="572">Saudi Arabia</collectingCountry>
, 
<collectingCountry id="F30B6B86FFCDFF9C6F40FD73FB62FD7E" box="[1127,1212,701,726]" name="Kuwait" pageId="7" pageNumber="572">Kuwait</collectingCountry>
, 
<collectingCountry id="F30B6B86FFCDFF9C6FECFD73FAD1FD7E" box="[1227,1295,701,726]" name="Oman" pageId="7" pageNumber="572">Oman</collectingCountry>
and 
<collectingCountry id="F30B6B86FFCDFF9C6E69FD70FA42FD7D" box="[1358,1436,702,725]" name="Yemen" pageId="7" pageNumber="572">Yemen</collectingCountry>
(
<bibRefCitation id="EF8D56E7FFCDFF9C6BB9FD2FFEA5FD52" author="Collingwood, C. A." box="[158,379,737,762]" pageId="7" pageNumber="572" pagination="230 - 302" refId="ref6815" refString="Collingwood, C. A. (1985) Hymenoptera: Fam. Formicidae of Saudi Arabia. Fauna Saudi Arabia, 7, 230 - 302." type="journal article" year="1985">Collingwood, 1985</bibRefCitation>
; 
<bibRefCitation id="EF8D56E7FFCDFF9C6AA0FD2FFD3DFD52" author="Collingwood, C. A. &amp; Agosti, D." box="[391,739,737,762]" pageId="7" pageNumber="572" pagination="300 - 385" refId="ref6843" refString="Collingwood, C. A. &amp; Agosti, D. (1996) Formicidae of Saudi Arabia (Part 2). Fauna of Saudi Arabia, 15, 300 - 385." type="journal article" year="1996">Collingwood and Agosti, 1996</bibRefCitation>
), 
<collectingCountry id="F30B6B86FFCDFF9C69D0FD2FFCEFFD52" box="[759,817,737,762]" name="United Arab Emirates" pageId="7" pageNumber="572">UAE</collectingCountry>
(
<bibRefCitation id="EF8D56E7FFCDFF9C6819FD2FFB8EFD52" author="Collingwood, C. A. &amp; Agosti, D. &amp; Sharaf, M. R. &amp; Van Harten T." box="[830,1104,737,762]" pageId="7" pageNumber="572" pagination="405 - 474" refId="ref6877" refString="Collingwood, C. A., Agosti, D., Sharaf, M. R. &amp; Van Harten T. (2011) Order Hymenoptera, Family Formicidae. Arthropod Fauna of the UAE, 4, 405 - 474." type="journal article" year="2011">
Collingwood 
<emphasis id="B968F704FFCDFF9C68FEFD2CFBCFFD52" box="[985,1041,737,762]" italics="true" pageId="7" pageNumber="572">et al.</emphasis>
2011
</bibRefCitation>
) and 
<collectingCountry id="F30B6B86FFCDFF9C6FA9FD2FFB17FD52" box="[1166,1225,737,762]" name="Syria" pageId="7" pageNumber="572">Syria</collectingCountry>
(
<bibRefCitation id="EF8D56E7FFCDFF9C6FF0FD2FFA4EFD52" author="Santschi, F." box="[1239,1424,737,762]" pageId="7" pageNumber="572" pagination="25 - 70" refId="ref8168" refString="Santschi, F. (1929 b) Etude sur les Cataglyphis. Revue Suisse de Zoologie, 36, 25 - 70." type="journal article" year="1929">Santschi, 1929b</bibRefCitation>
). It is common at Rawdhat Khorim with peak abundance in June and decreasing during cooler months. Workers were collected from the following plants: 
<taxonomicName id="4C1C5095FFCDFF9C6972FCE4FCB7FCEA" authority="Benth" authorityName="Benth" box="[597,873,809,834]" class="Magnoliopsida" family="Fabaceae" genus="Acacia" kingdom="Plantae" order="Fabales" pageId="7" pageNumber="572" phylum="Tracheophyta" rank="species" species="gerrardii">
<emphasis id="B968F704FFCDFF9C6972FCE4FCC9FCEA" box="[597,791,809,834]" italics="true" pageId="7" pageNumber="572">Acacia gerrardii</emphasis>
Benth
</taxonomicName>
(
<taxonomicName id="4C1C5095FFCDFF9C6858FCE7FC33FCEA" box="[895,1005,809,834]" class="Magnoliopsida" family="Fabaceae" kingdom="Plantae" order="Fabales" pageId="7" pageNumber="572" phylum="Tracheophyta" rank="family">Fabaceae</taxonomicName>
), 
<taxonomicName id="4C1C5095FFCDFF9C6F2FFCE4FB59FCE9" box="[1032,1159,810,833]" class="Magnoliopsida" family="Apocynaceae" genus="Calotropis" kingdom="Plantae" order="Gentianales" pageId="7" pageNumber="572" phylum="Tracheophyta" rank="species" species="procera">
<emphasis id="B968F704FFCDFF9C6F2FFCE4FB59FCE9" box="[1032,1159,810,833]" italics="true" pageId="7" pageNumber="572">C. procera</emphasis>
</taxonomicName>
, 
<taxonomicName id="4C1C5095FFCDFF9C6FBAFCE7FA45FCE9" authority="Decne" authorityName="Decne" box="[1181,1435,809,834]" class="Magnoliopsida" family="Apocynaceae" genus="Rhazya" kingdom="Plantae" order="Gentianales" pageId="7" pageNumber="572" phylum="Tracheophyta" rank="species" species="stricta">
<emphasis id="B968F704FFCDFF9C6FBAFCE7FA98FCE9" box="[1181,1350,809,834]" italics="true" pageId="7" pageNumber="572">Rhazya stricta</emphasis>
Decne
</taxonomicName>
(
<taxonomicName id="4C1C5095FFCDFF9C6BB9FC83FEE6FCCE" box="[158,312,845,870]" class="Magnoliopsida" family="Apocynaceae" kingdom="Plantae" order="Gentianales" pageId="7" pageNumber="572" phylum="Tracheophyta" rank="family">Apocynaceae</taxonomicName>
) and 
<taxonomicName id="4C1C5095FFCDFF9C6A50FC83FDB8FCCE" box="[375,614,845,870]" class="Magnoliopsida" family="Rhamnaceae" genus="Ziziphus" kingdom="Plantae" order="Rosales" pageId="7" pageNumber="572" phylum="Tracheophyta" rank="species" species="nummularia">
<emphasis id="B968F704FFCDFF9C6A50FC83FDB8FCCE" box="[375,614,845,870]" italics="true" pageId="7" pageNumber="572">Ziziphus nummularia</emphasis>
</taxonomicName>
(Burm. f) Wight &amp; Arn. (
<taxonomicName id="4C1C5095FFCDFF9C68A0FC83FBC3FCCE" box="[903,1053,845,870]" class="Magnoliopsida" family="Rhamnaceae" kingdom="Plantae" order="Rosales" pageId="7" pageNumber="572" phylum="Tracheophyta" rank="family">Rhamnaceae</taxonomicName>
).
</paragraph>
