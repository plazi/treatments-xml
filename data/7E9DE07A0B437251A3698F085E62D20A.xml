<subSubSection id="10A017B4FC6DAAA1E944377F7A33F075" pageId="null" pageNumber="561" type="description">
<paragraph id="4F2A1F123477D739A0DB62D64C5047C6" pageId="null" pageNumber="561">
5-20 cm hoch. 
<emphasis id="997E75E2A4BC2C8D4BA3FE263AAFAB31" italics="true" pageId="null" pageNumber="561">Stengel sehr kurz</emphasis>
(
<emphasis id="138733181F1129073E64CF0184EDCE9D" italics="true" pageId="null" pageNumber="561">
meist 
<normalizedToken id="72A7A6B15D5627A4EE53590937AF6445" originalValue="kürzer" pageId="null" pageNumber="561">kuerzer</normalizedToken>
als 3 cm
</emphasis>
), 
<emphasis id="B05A719E5DCD8B6046BCEDE2C877829E" italics="true" pageId="null" pageNumber="561">
so 
<normalizedToken id="A8D91505C7E05E11933AA6905DCB9D4F" originalValue="daß" pageId="null" pageNumber="561">dass</normalizedToken>
alle 
<normalizedToken id="D2AB5481E9744BFDD01379F31959DFC4" originalValue="Blätter" pageId="null" pageNumber="561">Blaetter</normalizedToken>
<normalizedToken id="2F53D94421E8E1FF196E9A6E12D73834" originalValue="±" pageId="null" pageNumber="561">+/-</normalizedToken>
<normalizedToken id="B0819E303D4D38128189C2F4F3D2AA28" originalValue="grundständig" pageId="null" pageNumber="561">grundstaendig</normalizedToken>
sind. 
<normalizedToken id="9074CF56577DBE8ACD1F21FF4DBF8FDA" originalValue="Blätter" pageId="null" pageNumber="561">Blaetter</normalizedToken>
mit 25-41 
<normalizedToken id="876CF17C5C20B85F74941F35D4DA49FC" originalValue="Teilblättern" pageId="null" pageNumber="561">Teilblaettern</normalizedToken>
;
</emphasis>
<normalizedToken id="5B63587D1DCE093ECFBA4EBEA3C27DB1" originalValue="Teilblätter" pageId="null" pageNumber="561">Teilblaetter</normalizedToken>
0,5-1,2 cm lang, 
<normalizedToken id="02762DC24BC16255811D83858CDE68D7" originalValue="1½-2½" pageId="null" pageNumber="561">11/2-21/2</normalizedToken>
mal so lang wie breit, stumpf, 
<pageBreakToken id="73998A1242E885100D4417EC47EE04F2" pageId="null" pageNumber="561">oberseits</pageBreakToken>
kahl, unterseits zerstreut und kurz anliegend behaart (Haare 2teilig, 
<normalizedToken id="4C94707ED435472D095032BFFB54A938" originalValue="kompaßnadelartig" pageId="null" pageNumber="561">kompassnadelartig</normalizedToken>
); 
<emphasis id="A768CA2B9F823FE373DF044D3A049CB0" italics="true" pageId="null" pageNumber="561">
<normalizedToken id="D482DD3C8F698A0E9A21B607101D9154" originalValue="Nebenblätter" pageId="null" pageNumber="561">Nebenblaetter</normalizedToken>
bis etwa zur 
<normalizedToken id="32761B1F57E0D38A628A0D1321A051A4" originalValue="Hälfte" pageId="null" pageNumber="561">Haelfte</normalizedToken>
mit dem Blattstiel verwachsen
</emphasis>
, etwa so lang wie die untern 
<normalizedToken id="07168CF796810637F5858E9F2FBF0227" originalValue="Teilblätter" pageId="null" pageNumber="561">Teilblaetter</normalizedToken>
. 
<normalizedToken id="112896F658C8335684154AED92C138BE" originalValue="Blüten" pageId="null" pageNumber="561">Blueten</normalizedToken>
zu 8-15, aufrecht. Stiel des 
<normalizedToken id="850A45D159B40E2A5B5A52685772D3C9" originalValue="Blütenstandes" pageId="null" pageNumber="561">Bluetenstandes</normalizedToken>
<normalizedToken id="4A06DBB13D8D2F1F8B463E33B89CEB7F" originalValue="¾-1¼" pageId="null" pageNumber="561">3/4-11/4</normalizedToken>
so lang wie das 
<normalizedToken id="9933DC376FC38CD6260F24039E017004" originalValue="nächststehende" pageId="null" pageNumber="561">naechststehende</normalizedToken>
Blatt. Kelch 0,9-1,3 cm lang, mit einzelnen kurzen und anliegenden, 
<normalizedToken id="920E69860C2A14D88530C33BA3CB0710" originalValue="weißen" pageId="null" pageNumber="561">weissen</normalizedToken>
Haaren; 
<normalizedToken id="F4365E6569FE11D40FF1B795EE7E8436" originalValue="Kelchzähne" pageId="null" pageNumber="561">Kelchzaehne</normalizedToken>
⅓- 
<normalizedToken id="F0FE33ED747719A7B6CA03D1B8C7E724" originalValue="½" pageId="null" pageNumber="561">1/2</normalizedToken>
so lang wie die 
<normalizedToken id="F2A76B4EF9E19197B636553519CA236B" originalValue="Kelchröhre" pageId="null" pageNumber="561">Kelchroehre</normalizedToken>
. Krone 2,2-2,8 cm lang, purpurn (selten 
<normalizedToken id="4A90E6A37F6E73783AA7F6D6FBBD1598" originalValue="weiß" pageId="null" pageNumber="561">weiss</normalizedToken>
). Frucht im Kelch ungestielt, 
<emphasis id="F2A155EBF544E2A92EBC89F79BF4F1C5" italics="true" pageId="null" pageNumber="561">
aufrecht, wie eine Bohnenfrucht, etwas 
<normalizedToken id="F1B19F87DB814C20D3F43EFB36B627DA" originalValue="aufwärts" pageId="null" pageNumber="561">aufwaerts</normalizedToken>
gebogen, 2,5-3,5 cm lang und 0,3-0,4 cm dick
</emphasis>
, zerstreut, kurz und anliegend 
<normalizedToken id="7DD2F5EB062140EFC57478A1B26A3226" originalValue="weiß" pageId="null" pageNumber="561">weiss</normalizedToken>
behaart. - 
<normalizedToken id="AA9D1E5A3311F6FEAB9E79A8370F0314" originalValue="Blüte" pageId="null" pageNumber="561">Bluete</normalizedToken>
: 
<normalizedToken id="4CFB46CA12E55FE6368CFAFC9FFBCF19" originalValue="Später" pageId="null" pageNumber="561">Spaeter</normalizedToken>
<normalizedToken id="C101AB6939E3121EECB34F069F4DC01C" originalValue="Frühling" pageId="null" pageNumber="561">Fruehling</normalizedToken>
und 
<normalizedToken id="69E23646AC64D4F0FA4104D43BB1B805" originalValue="früher" pageId="null" pageNumber="561">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="170336195EC37BE574F2D4260A39A823" pageId="null" pageNumber="561">
<emphasis id="F4BA433F0E55E29C7773F992277F2BA0" italics="true" pageId="null" pageNumber="561">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="52456C534E23463D0E9410557C5A032F" italics="true" pageId="null" pageNumber="561">16:</emphasis>
Material aus botanischen 
<normalizedToken id="51FECDF97F63EDF831DCE5804BC2C8AA" originalValue="Gärten" pageId="null" pageNumber="561">Gaerten</normalizedToken>
(Kreuter 1930, Ledingham 1960), aus 
<normalizedToken id="8BDBCBD8B2E01048E842B69160C3B154" originalValue="Südfrankreich" pageId="null" pageNumber="561">Suedfrankreich</normalizedToken>
(Caussols) (Guinochet und Logeois 1962), aus den 
<normalizedToken id="C5C03ABE1DDB26E2490FCBAF74947DE8" originalValue="Ostpyrenäen" pageId="null" pageNumber="561">Ostpyrenaeen</normalizedToken>
(Favarger in 
<normalizedToken id="2832EE7AE2106F934049641A8E2CC7B3" originalValue="Löve" pageId="null" pageNumber="561">Loeve</normalizedToken>
und Solbrig 1964).
</paragraph>
<paragraph id="C16E47E965E42C63DD16797F2DF4B262" pageId="null" pageNumber="561">
<emphasis id="BBF292355EEA51D477F8F5391168AA3B" italics="true" pageId="null" pageNumber="561">Standort.</emphasis>
Kollin und montan, seltener subalpin. Trockene, kalkreiche 
<normalizedToken id="69063852FE4DB6072DD690CF3BC83EEC" originalValue="Böden" pageId="null" pageNumber="561">Boeden</normalizedToken>
in warmen Lagen. Trockenwiesen, Felsensteppen, lichte 
<normalizedToken id="22C91E2F63BE80220437C115BA2D5B32" originalValue="Föhrenwälder" pageId="null" pageNumber="561">Foehrenwaelder</normalizedToken>
.
</paragraph>
<paragraph id="14C7B32398F68B3F8A1BB9D04AA711EF" pageId="null" pageNumber="561">
<emphasis id="2D36A59ADD02ACBCF054CDC0A72BF980" italics="true" pageId="null" pageNumber="561">Verbreitung. Mediterrane Pflanze:</emphasis>
Spanien, 
<normalizedToken id="D4497A05F3C451C4635E2D78B682966E" originalValue="Südfrankreich" pageId="null" pageNumber="561">Suedfrankreich</normalizedToken>
, 
<normalizedToken id="8A3DA97D8379B44CE7FE4D594E7EA6B9" originalValue="südliche" pageId="null" pageNumber="561">suedliche</normalizedToken>
Alpen, Apenninenhalbinsel, 
<normalizedToken id="381556C1472EFBFC1B3C099E841E3760" originalValue="südliche" pageId="null" pageNumber="561">suedliche</normalizedToken>
Balkanhalbinsel, Bessarabien, 
<normalizedToken id="D21B1A5E0263FBADFD78F55ABF714DF3" originalValue="Rumänien" pageId="null" pageNumber="561">Rumaenien</normalizedToken>
; Nordwestafrika. - Im Gebiet: Westliche Savoyer Alpen, Maurienne, Tarentaise, Rhonetal (Aigle, Bex), Wallis (St-Maurice bis Binn), Aostatal, Tessin (Riviera, Generoso), Comerseegebiet, unteres Veltlin, Albulagebiet, Domleschg, Ghurer Rheintal, Valle Camonica.
</paragraph>
</subSubSection>
