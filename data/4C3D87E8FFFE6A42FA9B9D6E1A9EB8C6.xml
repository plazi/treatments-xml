<collectingRegion id="0650F81CFFFE6A41F8369A521652B71E" box="[1994,2130,3083,3116]" country="Indonesia" name="Jawa Barat" pageId="5" pageNumber="763">West Java</collectingRegion>
, about 900-1000 metres,” 
<collectingRegion id="0650F81CFFFE6A41F62A9A521414B71E" box="[2518,2580,3083,3116]" country="Indonesia" name="Jawa Timur" pageId="5" pageNumber="763">Java</collectingRegion>
, 
<collectingCountry id="BC83766EFFFE6A41F8379A681657B760" box="[1995,2135,3121,3154]" name="Indonesia" pageId="5" pageNumber="763">Indonesia</collectingCountry>
