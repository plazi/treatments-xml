<taxonomicName id="03944D7DFFFE6A41F7789D98160FB737" authority="Chasen, 1939" authorityName="Chasen" authorityYear="1939" class="Mammalia" family="Vespertilionidae" genus="Glischropus" kingdom="Animalia" order="Chiroptera" pageId="5" pageNumber="763" phylum="Chordata" rank="species" species="javanus">Glischropus javanus Chasen, 1939</taxonomicName>
