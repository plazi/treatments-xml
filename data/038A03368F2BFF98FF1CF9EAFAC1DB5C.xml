<subSubSection id="C339E1AB8F2CFF98FF4CFD54FAC1DB5C" box="[199,1388,763,790]" pageId="5" pageNumber="568" type="etymology">
<paragraph id="8B9CB2208F2CFF98FF4CFD54FAC1DB5C" blockId="5.[151,1437,150,790]" box="[199,1388,763,790]" pageId="5" pageNumber="568">
