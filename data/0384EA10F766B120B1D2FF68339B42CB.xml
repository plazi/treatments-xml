CURRENT STATUS: 
<taxonomicName id="4C2D2085F766B127B0C2FED8318B4200" authority="(Sundevall, 1850)" baseAuthorityName="Sundevall" baseAuthorityYear="1850" box="[391,946,295,322]" class="Aves" family="Alaudidae" genus="Mirafra" kingdom="Animalia" order="Passeriformes" pageId="19" pageNumber="540" phylum="Chordata" rank="subSpecies" species="fasciolata" subSpecies="fasciolata">
<emphasis id="B9598714F766B127B0C2FED830EE4203" box="[391,727,295,321]" italics="true" pageId="19" pageNumber="540">Mirafra fasciolata fasciolata</emphasis>
(
<bibRefCitation id="EFBC26F7F766B127B3A0FED831904200" author="Sundevall, C. J." box="[741,937,295,322]" pageId="19" pageNumber="540" pagination="96 - 111" refId="ref29984" refString="Sundevall, C. J. (1850) Foglar fran sodra Afrika. Ofversigt af Kongliga Vetenskaps-akademiens forhandlingar, 7 (4), 96 - 111." type="journal article" year="1850">Sundevall, 1850</bibRefCitation>
)
</taxonomicName>
; 
<taxonomicName id="4C2D2085F766B127B2FFFED832E84227" authority="(Dickinson &amp; Christidis 2014: 439)" baseAuthorityName="Dickinson &amp; Christidis" baseAuthorityPageNumber="439" baseAuthorityYear="2014" class="Aves" family="Alaudidae" kingdom="Animalia" order="Passeriformes" pageId="19" pageNumber="540" phylum="Chordata" rank="family">
Alaudidae (
<bibRefCitation id="EFBC26F7F766B127B504FED832F14227" author="Dickinson, E. C. &amp; Christidis, L." pageId="19" pageNumber="540" refId="ref28395" refString="Dickinson, E. C. &amp; Christidis, L. (2014) The Howard and Moore Complete Checklist of the Birds of the World. 4 th Edition. Vol. 2. Passerines. Aves Press, Eastbourne, 752 pp." type="book" year="2014">Dickinson &amp; Christidis 2014: 439</bibRefCitation>
