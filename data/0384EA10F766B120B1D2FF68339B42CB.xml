LOCALITY: 
<location id="8EF20DDDF766B127B096FC74304040E7" LSID="urn:lsid:plazi:treatment:0384EA10F766B120B1D2FF68339B42CB:8EF20DDDF766B127B096FC74304040E7" box="[467,633,907,933]" name="Potchefstroom" pageId="19" pageNumber="540" stateProvince="North West">Potchefstroom</location>
, 
<collectingRegion id="49E995E4F766B127B3C0FC74314B40E7" box="[645,882,907,934]" country="Botswana" name="North West" pageId="19" pageNumber="540">North West Province</collectingRegion>
