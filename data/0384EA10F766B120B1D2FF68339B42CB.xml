LOCALITY: 
<location id="8EF20DDDF761B120B09EFEFC306F425F" LSID="urn:lsid:plazi:treatment:0384EA10F766B120B1D2FF68339B42CB:8EF20DDDF761B120B09EFEFC306F425F" box="[475,598,259,285]" name="Saulspoort" pageId="20" pageNumber="541" stateProvince="North West">Saulspoort</location>
, 
<collectingRegion id="49E995E4F761B120B324FEFC3177425F" box="[609,846,259,285]" country="Botswana" name="North West" pageId="20" pageNumber="541">North West Province</collectingRegion>
