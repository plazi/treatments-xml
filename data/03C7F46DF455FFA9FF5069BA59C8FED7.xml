(
<accessionNumber id="943DD898F455FFA8FCE26C9658ECFA52" box="[826,955,1458,1485]" httpUri="http://www.ncbi.nlm.nih.gov/nucleotide/GU058024" pageId="10" pageNumber="137">GU058024</accessionNumber>
, 
<bibRefCitation id="EFFF388AF455FFA8FC1E6C965FD8FA53" author="Dixon, L. J. &amp; Castlebury, L. A. &amp; Aime, M. C. &amp; Glynn, N. C. &amp; Comstock, J. C." box="[966,1167,1458,1485]" pageId="10" pageNumber="137" pagination="459 - 468" refId="ref11258" refString="Dixon, L. J., Castlebury, L. A., Aime, M. C., Glynn, N. C. &amp; Comstock, J. C. (2010) Phylogenetic relationships of sugarcane rust fungi. Mycological Progress 9: 459 - 468. https: // doi. org / 10.3390 / agronomy 9120892" type="journal article" year="2010">
