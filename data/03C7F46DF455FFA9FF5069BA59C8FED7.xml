<subSubSection id="C37416F0F454FFA9FF6569BA59C8FED7" pageId="11" pageNumber="138" type="discussion">
<paragraph id="8BD1457BF454FFA9FF6569BA59C8FED7" blockId="11.[136,1452,158,328]" pageId="11" pageNumber="138">
<emphasis id="B91A9969F454FFA9FF6569BA5A1FFF27" bold="true" box="[189,328,158,184]" pageId="11" pageNumber="138">Comments:</emphasis>
— 
<taxonomicName id="4C6E3EF8F454FFA9FEBC69BB5A9AFF27" box="[356,461,159,184]" class="Liliopsida" family="Poaceae" genus="Zea" kingdom="Plantae" order="Poales" pageId="11" pageNumber="138" phylum="Tracheophyta" rank="species" species="mays">
<emphasis id="B91A9969F454FFA9FEBC69BB5A9AFF27" box="[356,461,159,184]" italics="true" pageId="11" pageNumber="138">Zea mays</emphasis>
</taxonomicName>
can be infected by three species of 
<taxonomicName id="4C6E3EF8F454FFA9FC8A69BA5883FF27" box="[850,980,158,184]" class="Pucciniomycetes" kingdom="Fungi" order="Pucciniales" pageId="11" pageNumber="138" phylum="Basidiomycota" rank="order">Pucciniales</taxonomicName>
, common rust (
<taxonomicName id="4C6E3EF8F454FFA9FBA669BB5EF7FF26" authority="Schwein." authorityName="Schwein." box="[1150,1440,158,185]" class="Pucciniomycetes" family="Pucciniaceae" genus="Puccinia" kingdom="Fungi" order="Pucciniales" pageId="11" pageNumber="138" phylum="Basidiomycota" rank="species" species="sorghi">
<emphasis id="B91A9969F454FFA9FBA669BB5E79FF27" box="[1150,1326,158,184]" italics="true" pageId="11" pageNumber="138">Puccinia sorghi</emphasis>
Schwein.
</taxonomicName>
), southern rust (
<taxonomicName id="4C6E3EF8F454FFA9FEF669E75AFAFF43" box="[302,429,194,220]" class="Pucciniomycetes" family="Pucciniaceae" genus="Puccinia" kingdom="Fungi" order="Pucciniales" pageId="11" pageNumber="138" phylum="Basidiomycota" rank="species" species="polysora">
<emphasis id="B91A9969F454FFA9FEF669E75AFAFF43" box="[302,429,194,220]" italics="true" pageId="11" pageNumber="138">P. polysora</emphasis>
