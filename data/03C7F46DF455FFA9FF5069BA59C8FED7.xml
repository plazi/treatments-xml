<taxonomicName id="4C6E3EF8F455FFA8FD766C97587CFA53" box="[686,811,1458,1484]" class="Pucciniomycetes" family="Pucciniaceae" genus="Puccinia" kingdom="Fungi" order="Pucciniales" pageId="10" pageNumber="137" phylum="Basidiomycota" rank="species" species="polysora">
