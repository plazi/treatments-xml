<subSubSection id="F19883E242890FF95C252A85CAC0C728" pageId="null" pageNumber="612" type="description">
<paragraph id="F06B91589C4E5B2C3AA1E608236B6AFC" pageId="null" pageNumber="612">
Knollen voneinander entfernt. Stengel 5-25 cm hoch. 
<normalizedToken id="6867E1C4E0ABE110B1F1809C35FFB86F" originalValue="Blätter" pageId="null" pageNumber="612">Blaetter</normalizedToken>
2-3, aufrecht, oval, 
<emphasis id="3AA889AB1F0283E633BAF8ACCB933E77" italics="true" pageId="null" pageNumber="612">das oberste</emphasis>
(
<emphasis id="BC1F70E11BDCA6E0D1CDC6D486B77DBA" italics="true" pageId="null" pageNumber="612">
<normalizedToken id="A214DBE28CFA11AB12C65A76A5EB408C" originalValue="gröβte" pageId="null" pageNumber="612">groeβte</normalizedToken>
</emphasis>
) 
<emphasis id="9E6ADE71811B62CDA9FD20AC9890E85E" italics="true" pageId="null" pageNumber="612">bis 3 cm lang</emphasis>
, 
<emphasis id="9E766123B96FF8340A3F7748520B5D42" italics="true" pageId="null" pageNumber="612">2</emphasis>
<normalizedToken id="52AA35B8BFEBF1C37219A3ED5FD28C57" originalValue="½" pageId="null" pageNumber="612">1/2</normalizedToken>
- 
<emphasis id="806C9064F30AF5B55FCD2581C89B6A18" italics="true" pageId="null" pageNumber="612">3</emphasis>
<normalizedToken id="A2D11E6B9495AB1D522A7C78A3F43DFE" originalValue="½" pageId="null" pageNumber="612">1/2</normalizedToken>
<emphasis id="8A1CDCAA269472E45ADDD4B92AE794F6" italics="true" pageId="null" pageNumber="612">mal so lang wie breit.</emphasis>
Untere 
<normalizedToken id="FD2FC2FE067CC40A4E00D22DBB809877" originalValue="Tragblätter" pageId="null" pageNumber="612">Tragblaetter</normalizedToken>
die 
<normalizedToken id="DB5A539F4433B40449EF1F1CEA50B064" originalValue="Perigonblätter" pageId="null" pageNumber="612">Perigonblaetter</normalizedToken>
meist erreichend, obere 
<normalizedToken id="E0311FD2278BA080E9B54200464A45E9" originalValue="kürzer" pageId="null" pageNumber="612">kuerzer</normalizedToken>
. 
<normalizedToken id="F6495D9AB441A3F4B393AE6EE48B3603" originalValue="Äußere" pageId="null" pageNumber="612">Aeussere</normalizedToken>
<normalizedToken id="F91BBC46C1AE7AAB3C6CFB2C22F70276" originalValue="Perigonblätter" pageId="null" pageNumber="612">Perigonblaetter</normalizedToken>
lanzettlich, stumpf, 2,5-3 mm lang, etwa 3mal so lang wie breit; 
<emphasis id="E162BFFDE8AFC2460822A5B051B31845" italics="true" pageId="null" pageNumber="612">
innere 
<normalizedToken id="9AAC0EAF9F6909E36637D1871CE292FF" originalValue="Perigonblätter" pageId="null" pageNumber="612">Perigonblaetter</normalizedToken>
lanzettlich, 
<normalizedToken id="2BFF43045805FD536922006AA139BC73" originalValue="allmählich" pageId="null" pageNumber="612">allmaehlich</normalizedToken>
und fein zugespitzt, 1,5-2 mm lang, 2-3mal so lang wie breit; Lippe lanzettlich
</emphasis>
, etwa so lang wie die innern 
<normalizedToken id="70C10C375C7812239E43D6030F4928A1" originalValue="Perigonblätter" pageId="null" pageNumber="612">Perigonblaetter</normalizedToken>
, am Grunde die 
<normalizedToken id="5A4E9BF06EF081555B64989CA299B5EE" originalValue="Ränder" pageId="null" pageNumber="612">Raender</normalizedToken>
etwas 
<normalizedToken id="95E1A595EB8D050B4E26464B7ADAE9FF" originalValue="aufgewölbt" pageId="null" pageNumber="612">aufgewoelbt</normalizedToken>
. - 
<normalizedToken id="7DBD7C964568C58D78D5C44B96F01BBA" originalValue="Blüte" pageId="null" pageNumber="612">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="6FC431B53E1E1D60EF71E48BCA859B4C" pageId="null" pageNumber="612">
<emphasis id="FEDBE956246360617701BBBB085F9146" italics="true" pageId="null" pageNumber="612">Zytologische Angaben. 2n = 28</emphasis>
(unsicher): Material aus 
<normalizedToken id="F7D00740BB449E10A0660851C4B59E17" originalValue="Dänemark" pageId="null" pageNumber="612">Daenemark</normalizedToken>
(Hagerup 1944a), aus Holland (Kliphuis 1963).
</paragraph>
<paragraph id="DDA8367529266B85174C394784435B84" pageId="null" pageNumber="612">
<emphasis id="547FC60172B11DBCA4F2F9A0E5CBC1E2" italics="true" pageId="null" pageNumber="612">Standort.</emphasis>
Montan. Hochmoore, zwischen Moospolstern.
</paragraph>
<paragraph id="ED604DD993228127D5E003E295441B36" pageId="null" pageNumber="612">
<emphasis id="E8C7113C38BE07C648CE671DA0F79E75" italics="true" pageId="null" pageNumber="612">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
Nordgrenze durch die Shetlandinseln, Nordschweden (68° NB), Halbinsel Kola; 
<normalizedToken id="D0B31E2A89689B206C4955339A34058C" originalValue="Südgrenze" pageId="null" pageNumber="612">Suedgrenze</normalizedToken>
durch 
<normalizedToken id="3E6DBBDA1884BBE5D7DC0863C46770F9" originalValue="Pyrenäen" pageId="null" pageNumber="612">Pyrenaeen</normalizedToken>
, Alpen, Karpaten; weiter 
<normalizedToken id="BB79545464B25D237CCE4C6256C3B3FE" originalValue="östlich" pageId="null" pageNumber="612">oestlich</normalizedToken>
wenige Fundorte zwischen 50 und 60° NB bis ins Amurgebiet; Sachalin, Japan; in Nordamerika wenige Fundorte in Alaska und im Westen zwischen 50 und 60° NB, zudem in 
<normalizedToken id="704EA785C910F537A1B5BD7C7DBEB4D8" originalValue="Südkanada" pageId="null" pageNumber="612">Suedkanada</normalizedToken>
und Minnesota. Verbreitungskarten von 
<normalizedToken id="3ECEC078CAFE92FAFB75DE7F5B0CE46D" originalValue="Hultén" pageId="null" pageNumber="612">Hulten</normalizedToken>
(1958) und Meusel (1964). - Im Gebiet einige Fundstellen im Kt. Schwyz (Gegend von Einsiedeln und Altmatt), Zug (einziger Fundort bei Altmatt wahrscheinlich 
<normalizedToken id="F99BD79F12A861D93D69BC7CBBEEF15F" originalValue="zerstört" pageId="null" pageNumber="612">zerstoert</normalizedToken>
[Merz 1964 
<normalizedToken id="A4B2073229BEEBBF29C4F58F9EECC286" originalValue="mündlich" pageId="null" pageNumber="612">muendlich</normalizedToken>
]), Vogesen (Hohneck), Schwarzwald (Nonnenmattweiher, nach 
<normalizedToken id="0F0C79265126940D82799E42EB5A7525" originalValue="Oberdörfer" pageId="null" pageNumber="612">Oberdoerfer</normalizedToken>
1962 nicht mehr gefunden), deutsches Bodenseegebiet (Gegend von Isny); sehr selten.
</paragraph>
</subSubSection>
