<subSubSection id="1C43A6D897561F71AE6911E4CDE32C72" pageId="null" pageNumber="760" type="description">
<paragraph id="70DFC84A8B5D762BA201E567C81B4124" pageId="null" pageNumber="760">
1 
<normalizedToken id="2D263F9FBA2A14AB06128381CBDE95BE" originalValue="jährig" pageId="null" pageNumber="760">jaehrig</normalizedToken>
; 
<emphasis id="415F5EC4819C38A193ADCD1B5C648AB7" italics="true" pageId="null" pageNumber="760">Pflanze stets 1geschlechtig</emphasis>
(2 
<normalizedToken id="75DAC1447159906198CE818FFFEA91A2" originalValue="häusig" pageId="null" pageNumber="760">haeusig</normalizedToken>
). Stengel kantig gefurcht, kahl. 
<normalizedToken id="1A2882771D3F80B883E59A5FFDEE37BD" originalValue="Blätter" pageId="null" pageNumber="760">Blaetter</normalizedToken>
3eckig, 
<normalizedToken id="B70580D33B6C31EC93CD78BDFAE13AFA" originalValue="spießoder" pageId="null" pageNumber="760">spiessoder</normalizedToken>
<normalizedToken id="5424394A3BF42EA9E5EEFBDE092B2D66" originalValue="pfeilförmig" pageId="null" pageNumber="760">pfeilfoermig</normalizedToken>
oder geteilt; Blattstiel lang. 
<normalizedToken id="1E4B7FC355DB43C5CB98B55E28A012FE" originalValue="Blüten" pageId="null" pageNumber="760">Blueten</normalizedToken>
in voneinander getrennten oder 
<normalizedToken id="9D5F1C2A39FA7C15A6DC173A76B91638" originalValue="ährenartig" pageId="null" pageNumber="760">aehrenartig</normalizedToken>
angeordneten, 
<normalizedToken id="35551DA339D387BD8E80A5198333E7E8" originalValue="mehrblütigen" pageId="null" pageNumber="760">mehrbluetigen</normalizedToken>
<normalizedToken id="602A87CCB58C9AAD9FB7E8F155E29F37" originalValue="Knäueln" pageId="null" pageNumber="760">Knaeueln</normalizedToken>
, in Blattachseln, an Haupt- und Seitentrieben, sitzend. ♂ 
<emphasis id="EA52D833118AD24733C8293FB3DFF6DF" italics="true" pageId="null" pageNumber="760">
<normalizedToken id="7E3DC45549647E5226DAA5611B6694D7" originalValue="Blüten" pageId="null" pageNumber="760">Blueten</normalizedToken>
ohne 
<normalizedToken id="F6ED7ADB732E3DBAFC766AC5BEF8A22B" originalValue="Vorblätter" pageId="null" pageNumber="760">Vorblaetter</normalizedToken>
</emphasis>
, mit 3-5, meist 4 
<normalizedToken id="44B9A4E42B51BBC3F587ABFA81A458AC" originalValue="grünen" pageId="null" pageNumber="760">gruenen</normalizedToken>
<normalizedToken id="2AAF5E89EE67FEA41AE5E0E2978E54A7" originalValue="Perigonblättern" pageId="null" pageNumber="760">Perigonblaettern</normalizedToken>
; 
<normalizedToken id="BE346000DBE2A4C7D6ADDD87F70A68E2" originalValue="Staubblätter" pageId="null" pageNumber="760">Staubblaetter</normalizedToken>
4-5. ♀ 
<emphasis id="5DDF9AF13965220FF6007B5237ED6B7B" italics="true" pageId="null" pageNumber="760">
<normalizedToken id="C7A5A1EF541F0AE1D3E066AAD7E3F278" originalValue="Blüten" pageId="null" pageNumber="760">Blueten</normalizedToken>
mit 2 miteinander verwachsenen 
<normalizedToken id="11CF4A320A8BBEDFFD3E213C1BF43F19" originalValue="Vorblättern" pageId="null" pageNumber="760">Vorblaettern</normalizedToken>
, die zur Zeit der Fruchtreife eine harte, kugelige oder 
<normalizedToken id="8D5519EA5E625186D58A4F6DF078A73D" originalValue="eiförmige" pageId="null" pageNumber="760">eifoermige</normalizedToken>
<normalizedToken id="039E3FE0EBAC6324A242F5BA3A3CA479" originalValue="Hülle" pageId="null" pageNumber="760">Huelle</normalizedToken>
mit 2 kleinen freien Spitzen beim Austritt der Narben bilden;
</emphasis>
die 
<normalizedToken id="54B603370735B8D4EB4E6103047F5094" originalValue="Hülle" pageId="null" pageNumber="760">Huelle</normalizedToken>
<normalizedToken id="3675D47293D7C6754D3C130AD9167FA5" originalValue="umschließt" pageId="null" pageNumber="760">umschliesst</normalizedToken>
die reife Frucht eng; Narben 4-5, 
<normalizedToken id="B83A6B2B535409D0B19932A458E4D7F9" originalValue="fadenförmig" pageId="null" pageNumber="760">fadenfoermig</normalizedToken>
. 
<normalizedToken id="3A2AA61094C10A5360F9AD5EDC5C407B" originalValue="Größter" pageId="null" pageNumber="760">Groesster</normalizedToken>
Durchmesser der reifen Frucht bis 1 cm.
</paragraph>
<paragraph id="BA14350DA7B40D2989746E967CE1BE4D" pageId="null" pageNumber="760">
Die Gattung 
<taxonomicName id="B3676FCA68B5118AA3A7CE53691462BF" class="Magnoliopsida" family="Amaranthaceae" genus="Spinacia" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="760" phylum="Tracheophyta" rank="genus">
<emphasis id="52F21CD990A77580977CA050CF733AE5" italics="true" pageId="null" pageNumber="760">Spinacia</emphasis>
</taxonomicName>
<normalizedToken id="6A3958322E26B799A14B1A0AFBE94A66" originalValue="umfaßt" pageId="null" pageNumber="760">umfasst</normalizedToken>
<emphasis id="61AD39EFD514262ABF161CC87E157B58" italics="true" pageId="null" pageNumber="760">
2 Wildarten, die von der 
<normalizedToken id="641658579DCDF11EDCF14EE74F7A152F" originalValue="Türkei" pageId="null" pageNumber="760">Tuerkei</normalizedToken>
<normalizedToken id="20E8C2A402BEFF850ED8D5E6F9DEBD1E" originalValue="ostwärts" pageId="null" pageNumber="760">ostwaerts</normalizedToken>
bis Tibet verbreitet sind
</emphasis>
(beide Arten haben fiederteilige 
<normalizedToken id="CE5F9C28085B1E47E58A70F5AF7B3A79" originalValue="Blätter" pageId="null" pageNumber="760">Blaetter</normalizedToken>
und miteinander verwachsene ♀ 
<normalizedToken id="87A411ADE0A499C553202A131FE539E3" originalValue="Blüten" pageId="null" pageNumber="760">Blueten</normalizedToken>
). Als Stammpflanze unseres Kulturspinats, der nirgends als wild bekannt ist, kommt 
<taxonomicName id="BE47FD3668C31841A381D1E795A61262" authority="Iljin in Frage. Schluessel, Diagnosen und Verbreitungsangaben" class="Magnoliopsida" family="Amaranthaceae" genus="Spinacia" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="760" phylum="Tracheophyta" rank="species" species="turkestanica">
<emphasis id="39CF2E7E746F974EC3E400F492061FA8" italics="true" pageId="null" pageNumber="760">S. turkestanica</emphasis>
Iljin in Frage. 
<normalizedToken id="0B3DF8E1D815C2B5740466C7AD869D24" originalValue="Schlüssel" pageId="null" pageNumber="760">Schluessel</normalizedToken>
, Diagnosen und Verbreitungsangaben
</taxonomicName>
der 3 Arten von Aellen (1938).
</paragraph>
</subSubSection>
