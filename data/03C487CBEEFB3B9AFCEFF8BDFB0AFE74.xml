<emphasis id="B919EACFEEFC3B98FEF6F8BDFD91F84C" box="[307,596,1907,1933]" italics="true" pageId="429" pageNumber="430">Thoracodelphys longiseta</emphasis>
</taxonomicName>
<emphasis id="B919EACFEEFC3B98FD9FF8BAFD76F84F" bold="true" box="[602,691,1908,1934]" pageId="429" pageNumber="430">
