<subSubSection id="CA264FE686F761997763B5E9D837B55C" pageId="null" pageNumber="192" type="description">
<paragraph id="04B0B37896511D9757774D1B2FDF7569" pageId="null" pageNumber="192">
10-80 cm lang, auf der 
<normalizedToken id="199E13E6713C6A53BF2B1A4FF12C62F4" originalValue="Wasseroberfläche" pageId="null" pageNumber="192">Wasseroberflaeche</normalizedToken>
schwimmend, mit langen, im Schlamm kriechenden 
<normalizedToken id="216A1804F49C4DE0CE6C7A81B81B8E14" originalValue="Ausläufern" pageId="null" pageNumber="192">Auslaeufern</normalizedToken>
. 
<normalizedToken id="54D9E8E7A6EC8228B31A3B23CA4AE082" originalValue="Blätter" pageId="null" pageNumber="192">Blaetter</normalizedToken>
2-8 mm breit, 
<emphasis id="90F4B93AA405A99C6B9CB590482F1A7E" italics="true" pageId="null" pageNumber="192">schlaff</emphasis>
, im Querschnitt flach, 
<emphasis id="7075EEF246AC70957223329F48C195D2" italics="true" pageId="null" pageNumber="192">
<normalizedToken id="69162E74FD71D46CFBC265966A91651C" originalValue="dünn" pageId="null" pageNumber="192">duenn</normalizedToken>
</emphasis>
(siehe Bemerkungen bei 
<taxonomicName id="FE5B88942D8635600D94B401EEC7559A" authority="Nr." authorityName="Nr." class="Liliopsida" family="Typhaceae" genus="Sparganium" kingdom="Plantae" order="Poales" pageId="null" pageNumber="192" phylum="Tracheophyta" rank="species" species="angustifolium">
<emphasis id="E6D31710E3998CD5E97A6E2EE386121F" italics="true" pageId="null" pageNumber="192">S. angustifolium</emphasis>
Nr.
</taxonomicName>
3), mit stumpfer Spitze; obere 
<normalizedToken id="F3F5656C57E41D8C3B4D12483CA425F1" originalValue="Stengelblätter" pageId="null" pageNumber="192">Stengelblaetter</normalizedToken>
am Grunde oft 
<emphasis id="A7F71E4CF7EB37D2FE723268FABDE6B2" italics="true" pageId="null" pageNumber="192">scheidenartig erweitert.</emphasis>
Stengel nie verzweigt. 1-4 ♀ 
<normalizedToken id="A85D97AABDA537CE4B329C03AA105C94" originalValue="Blütenköpfe" pageId="null" pageNumber="192">Bluetenkoepfe</normalizedToken>
und 
<emphasis id="A7180298190AB86B1A55ED9193B1187C" italics="true" pageId="null" pageNumber="192">meist nur 1</emphasis>
♂ 
<emphasis id="EF713562963F118694CADD54F4EA87DF" italics="true" pageId="null" pageNumber="192">
<normalizedToken id="7F11413BB7DC9C54B46912A171EEBE62" originalValue="Blütenkopf" pageId="null" pageNumber="192">Bluetenkopf</normalizedToken>
. Stiele der
</emphasis>
♀ 
<emphasis id="76EC46D031FEE53DD218990BC236DD9D" italics="true" pageId="null" pageNumber="192">
<normalizedToken id="BAE8476AD02EE6883CDCA34E46193B90" originalValue="Blütenköpfe" pageId="null" pageNumber="192">Bluetenkoepfe</normalizedToken>
nicht mit der Hauptachse verwachsen, 
<normalizedToken id="CA69027BD54AA3A61CA389EDCE82288E" originalValue="Blütenköpfe" pageId="null" pageNumber="192">Bluetenkoepfe</normalizedToken>
deshalb stets in den Achseln der 
<normalizedToken id="373649BA91ED00EFB2CAAFC360DCBDC7" originalValue="Hochblätter" pageId="null" pageNumber="192">Hochblaetter</normalizedToken>
</emphasis>
(sitzend oder der unterste Kopf auf bis 2 cm langem Stiel). Staubbeutel 2-3mal so lang wie dick. Reife 
<normalizedToken id="A35A98384312802481B53D1B2A8D6DB3" originalValue="Früchte" pageId="null" pageNumber="192">Fruechte</normalizedToken>
<normalizedToken id="D9F022FB07EF9E0703F46FF7289A27EE" originalValue="spindelförmig" pageId="null" pageNumber="192">spindelfoermig</normalizedToken>
, ohne deutliche Kanten, 
<emphasis id="69F90C1CE33AE9D562CE969F414EC267" italics="true" pageId="null" pageNumber="192">4,5-6 mm lang</emphasis>
(mit Schnabel), etwa in der Mitte am dicksten (⅓- 
<normalizedToken id="25B6DB734957938B0B2FA7ACAEFF01E3" originalValue="½" pageId="null" pageNumber="192">1/2</normalizedToken>
so dick wie lang), mit feinen, undeutlichen 
<normalizedToken id="0C25E243B2291A1D174BD11AA44A0C31" originalValue="Längsnerven" pageId="null" pageNumber="192">Laengsnerven</normalizedToken>
. - 
<normalizedToken id="6D8CB97F0284F7284281461603604698" originalValue="Blüte" pageId="null" pageNumber="192">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="8F3D9C8A6667A1B9843E099CDB3EA35F" pageId="null" pageNumber="192">
<emphasis id="AE06FC9B629C062D7DF872181EEC296C" italics="true" pageId="null" pageNumber="192">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="01E34B20794D9D539F7EA896B41D1166" italics="true" pageId="null" pageNumber="192">30:</emphasis>
Material aus Schleswig-Holstein (Wulff 1938), aus Skandinavien (
<normalizedToken id="50F2A3C7BAA9A1434430743787BD2BCE" originalValue="Löve" pageId="null" pageNumber="192">Loeve</normalizedToken>
und 
<normalizedToken id="B2BFB108FFCA7A9F12E838FCD0666403" originalValue="Löve" pageId="null" pageNumber="192">Loeve</normalizedToken>
1942b), aus Island (
<normalizedToken id="6069E05A5B45652A99932F2107AD1C21" originalValue="Löve" pageId="null" pageNumber="192">Loeve</normalizedToken>
und 
<normalizedToken id="D12CBD71804076F474D77E836CC8CE25" originalValue="Löve" pageId="null" pageNumber="192">Loeve</normalizedToken>
1956b).
</paragraph>
<paragraph id="EE5D162A7DE0A978534317E4140AD6E2" pageId="null" pageNumber="192">
<emphasis id="DCE05AFE326F4073CACFDC02A01E8F92" italics="true" pageId="null" pageNumber="192">Standort.</emphasis>
Kollin, montan und subalpin. 
<normalizedToken id="B59B8A2B4697EE5A46C6DEC2C31BE31A" originalValue="Nährstoffarmes" pageId="null" pageNumber="192">Naehrstoffarmes</normalizedToken>
, saures Wasser 
<normalizedToken id="8984D5EB567A62A64B575AFF8EBD5C59" originalValue="über" pageId="null" pageNumber="192">ueber</normalizedToken>
Torfschlamm, 
<normalizedToken id="393720602BA28261EB5939AB6C784308" originalValue="Gräben" pageId="null" pageNumber="192">Graeben</normalizedToken>
, Schlenken in Mooren, Seebuchten. 
<emphasis id="FB405A178FF967B1940FE5594F19BD06" italics="true" pageId="null" pageNumber="192">Sparganietum minimi</emphasis>
Tx. 1937.
</paragraph>
<paragraph id="E77CCA3E4F50694841FC815C5138121C" pageId="null" pageNumber="192">
<emphasis id="814349F87224D6F7C8F782167CB72094" italics="true" pageId="null" pageNumber="192">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
In 
<taxonomicName id="0541866999A0CCC71936121FE8F1C92A" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="192" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
von 70° NB 
<normalizedToken id="332D6F66AA147A5551E6A65AB67D992D" originalValue="südwärts" pageId="null" pageNumber="192">suedwaerts</normalizedToken>
bis Zentralspanien, 
<normalizedToken id="66BA12DB9E6280640188A133B08C41E9" originalValue="nördlicher" pageId="null" pageNumber="192">noerdlicher</normalizedToken>
Apennin, 
<normalizedToken id="1682475A740E92CF2B3BEB7F854F7CA3" originalValue="südliche" pageId="null" pageNumber="192">suedliche</normalizedToken>
Balkanhalbinsel; in Asien vom Polarkreis 
<normalizedToken id="3ABEB26C9CF8614F8793F7D697EFD2B7" originalValue="südwärts" pageId="null" pageNumber="192">suedwaerts</normalizedToken>
bis Altai und Baikalseegebiet und Kamtschatka; in Nordamerika von Alaska 
<normalizedToken id="B105E98548F1E5CFFEBDBB4E680161B8" originalValue="südwärts" pageId="null" pageNumber="192">suedwaerts</normalizedToken>
bis Colorado und New Jersey. Verbreitungskarten von 
<normalizedToken id="6D79A6C126A79B3788F7C4F26B7B1B96" originalValue="Hultén" pageId="null" pageNumber="192">Hulten</normalizedToken>
(1962) und Meusel (1964). - Im Gebiet zerstreut, ziemlich selten.
</paragraph>
<paragraph id="2D054CCEF0AACBE179B4C363019E3320" pageId="null" pageNumber="192">
<emphasis id="679D3F9B38751B30B8E27672D6585D7A" italics="true" pageId="null" pageNumber="192">Bemerkungen.</emphasis>
Siehe unter 
<taxonomicName id="74A9E9BA66C3A9F5953240AEA704514E" class="Liliopsida" family="Typhaceae" genus="Sparganium" kingdom="Plantae" order="Poales" pageId="null" pageNumber="192" phylum="Tracheophyta" rank="species" species="angustifolium">
<emphasis id="2EFEA08DD5A4B993A9564B31DAA074D5" italics="true" pageId="null" pageNumber="192">S. angustifolium</emphasis>
</taxonomicName>
(Nr. 3).
</paragraph>
</subSubSection>
