<caption id="DF526615FFEA9211FF642FDCFD966386" ID-DOI="http://doi.org/10.5281/zenodo.6458252" ID-Zenodo-Dep="6458252" box="[151,626,2003,2027]" httpUri="https://zenodo.org/record/6458252/files/figure.png" pageId="2" pageNumber="585" startId="2.[151,250,2003,2027]" targetBox="[355,1238,1607,1977]" targetPageId="2">
<paragraph id="8B92369DFFEA9211FF642FDCFD966386" blockId="2.[151,626,2003,2027]" box="[151,626,2003,2027]" pageId="2" pageNumber="585">
<emphasis id="B959EA8FFFEA9211FF642FDCFEF76386" bold="true" box="[151,275,2003,2027]" pageId="2" pageNumber="585">FIGURE 2.</emphasis>
<taxonomicName id="4C2D4D1EFFEA9211FEEA2FDCFE386386" authority="Liu &amp; He, 2022" authorityName="Liu &amp; He" authorityYear="2022" box="[281,476,2003,2027]" class="Insecta" family="Gryllidae" genus="Fodigryllus" kingdom="Animalia" order="Orthoptera" pageId="2" pageNumber="585" phylum="Arthropoda" rank="species" species="bisetus" status="sp. nov.">
