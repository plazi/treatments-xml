<taxonomicName id="4C094D51FFC7FFC6FB01FCAFE525FC99" authorityName="Rafinesque" authorityYear="1815" class="Mammalia" family="Cervidae" genus="Muntiacus" kingdom="Animalia" order="Artiodactyla" pageId="2" pageNumber="409" phylum="Chordata" rank="genus">Muntiacus</taxonomicName>
