<bibRefCitation id="EFD34B33FFC8FFC2A9C6187C8345FC03" author="Wu, S. A." box="[240,349,895,921]" pageId="14" pageNumber="557" pagination="207 - 214" refId="ref11644" refString="Wu, S. A. (2008) Morphology of Kuwania bipora Borchsenius (Hemiptera: Coccoidea: Margarodidae). Entomotaxonomia, 30 (3), 207 - 214." type="journal article" year="2008">Wu 2008</bibRefCitation>
