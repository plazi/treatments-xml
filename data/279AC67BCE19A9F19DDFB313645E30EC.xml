<subSubSection id="B562D5DCED99D11F2EA005EA6D540A2A" pageId="null" pageNumber="433" type="description">
<paragraph id="05712BC16BE129049F3E5EBB585CD3BD" pageId="null" pageNumber="433">
Unterscheidet sich von 
<taxonomicName id="FEBD3E747185F44A605D9A69A42A5855" class="Magnoliopsida" family="Asteraceae" genus="Saussurea" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="433" phylum="Tracheophyta" rank="species" species="discolor">
<emphasis id="4190DDB52D9155E0F5112B9FA65CA85E" italics="true" pageId="null" pageNumber="433">S. discolor</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<emphasis id="E6273900EF512288FFBF97B5DC11B07A" italics="true" pageId="null" pageNumber="433">Stengel locker filzig behaart;</emphasis>
<normalizedToken id="0D3B9683B602DF7E8960A7A1AC4E1DFE" originalValue="Blätter" pageId="null" pageNumber="433">Blaetter</normalizedToken>
unterseits zerstreut graufilzig behaart, mit einzelnen, 
<normalizedToken id="0EF0B451B267D24455B50337F61C725F" originalValue="glänzenden" pageId="null" pageNumber="433">glaenzenden</normalizedToken>
, mehrzelligen Haaren, 
<emphasis id="6110AB781633E733C1F7A6614BF8B019" italics="true" pageId="null" pageNumber="433">lanzettlich, 3</emphasis>
- 
<emphasis id="C0C7BEC25297B05612D41664976E0BF4" italics="true" pageId="null" pageNumber="433">
6mal so lang wie breit, ganzrandig oder mit vereinzelten kleinen 
<normalizedToken id="C73D196D145082AC25B63B6EA0F6D59B" originalValue="Zähnen" pageId="null" pageNumber="433">Zaehnen</normalizedToken>
, allmahlich in den Stiel 
<normalizedToken id="D3C22410E10DC3DA30A948EFA1795AF7" originalValue="verschmälert" pageId="null" pageNumber="433">verschmaelert</normalizedToken>
, selten gestutzt
</emphasis>
, mit meist 
<normalizedToken id="216BC0713710CEE69B612D769404E1C5" originalValue="geflügeltem" pageId="null" pageNumber="433">gefluegeltem</normalizedToken>
Stiel; Kronen meist violettrot; 
<taxonomicName id="F15B6F17755572890336992A7796F351" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="433" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
10-12 mm lang. - 
<normalizedToken id="EE0E1BCE9FA8F0292B14C80C12191E51" originalValue="Blüte" pageId="null" pageNumber="433">Bluete</normalizedToken>
: 
<normalizedToken id="4F62106B47778E96EFADE3870EE40343" originalValue="Später" pageId="null" pageNumber="433">Spaeter</normalizedToken>
Sommer und 
<normalizedToken id="D23757827F494808577CFD208459F7DB" originalValue="früher" pageId="null" pageNumber="433">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="49E2AAE5C420D70F7D595A350587CE4B" pageId="null" pageNumber="433">
<emphasis id="6CCEE413353A6A6363B4071465DA558A" italics="true" pageId="null" pageNumber="433">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="80FAC6FF47E993C6B5B96DF13E3AF7D3" italics="true" pageId="null" pageNumber="433">48:</emphasis>
Material aus botanischem Garten (Taylor aus 
<normalizedToken id="B848E9C362869A711AE4FC74143C7506" originalValue="Löve" pageId="null" pageNumber="433">Loeve</normalizedToken>
1967). 
<emphasis id="5FAC6E296EAB35B508D9B8EBBD2A16A8" italics="true" pageId="null" pageNumber="433">2n</emphasis>
= 
<emphasis id="7FCE3C32803BD8C9EE8606563816E3A8" italics="true" pageId="null" pageNumber="433">52:</emphasis>
Material von Zermatt und vom Piz Arina (Favarger 1965), aus Norwegen (Knaben und 
<normalizedToken id="309C6EF023E824F12AD2BCDAC3344A2B" originalValue="Engelskjön" pageId="null" pageNumber="433">Engelskjoen</normalizedToken>
1967). 
<emphasis id="ACDAAF5EC53ACB75806D2A5A62386DF7" italics="true" pageId="null" pageNumber="433">2n</emphasis>
= 
<emphasis id="25C64B16E14825199F86852F646CCA51" italics="true" pageId="null" pageNumber="433">54:</emphasis>
Material aus Skandinavien (
<normalizedToken id="7241EF0668A40902ED74D953BABE1E60" originalValue="Löve" pageId="null" pageNumber="433">Loeve</normalizedToken>
und 
<normalizedToken id="F8271088C82EF94AE9927E6E16FCAB5D" originalValue="Löve" pageId="null" pageNumber="433">Loeve</normalizedToken>
1944b), aus 
<normalizedToken id="99BC39788DD38F9A6DEBB390DEF9A437" originalValue="Nordrußland" pageId="null" pageNumber="433">Nordrussland</normalizedToken>
(Sokolovskaya und Strelkova 1960), aus Finnland (Sorsa 1963).
</paragraph>
<paragraph id="045D9E38835C309C916A13A5F7594E64" pageId="null" pageNumber="433">
<emphasis id="78DD9EB666EA711D20AE33C84B30BC02" italics="true" pageId="null" pageNumber="433">Standort.</emphasis>
Alpin, seltener subalpin. Humose, tonige, neutrale bis schwach saure 
<normalizedToken id="093515DC1DAC441D79B6E316BEC73795" originalValue="Böden" pageId="null" pageNumber="433">Boeden</normalizedToken>
in windexponierten Lagen. Rasen. Oft im 
<emphasis id="5279A50F5AF9FD4315FD31AFED2871F7" italics="true" pageId="null" pageNumber="433">Elynetum</emphasis>
Br.-Bl. 1913.
</paragraph>
<paragraph id="ED317B943ADF6F5535D59AF0A9374342" pageId="null" pageNumber="433">
<emphasis id="298A740F3CB8F2C0EEF76D29BC9257D3" italics="true" pageId="null" pageNumber="433">Verbreitung. Arktisch-alpine Pflanze</emphasis>
(
<emphasis id="3003C46D5F7DEC4857A4CF40C77272B0" italics="true" pageId="null" pageNumber="433">
<normalizedToken id="4A81E6DDDECB8068A6DA9327763E06E3" originalValue="europäisch" pageId="null" pageNumber="433">europaeisch</normalizedToken>
</emphasis>
)
<emphasis id="ECF9D4CD34CF7C03E96859F77A9EC9A6" italics="true" pageId="null" pageNumber="433">:</emphasis>
<normalizedToken id="100D26F192A91F605AEA6D23D72B875C" originalValue="Großbritannien" pageId="null" pageNumber="433">Grossbritannien</normalizedToken>
, Nordeuropa (
<normalizedToken id="935D2FC7F5E464A688F9161D1617F5C8" originalValue="südwärts" pageId="null" pageNumber="433">suedwaerts</normalizedToken>
bis 
<normalizedToken id="A857B03C5F0F8F4626162C46F46675F4" originalValue="Südnorwegen" pageId="null" pageNumber="433">Suednorwegen</normalizedToken>
und vereinzelt in die baltischen Staaten), 
<normalizedToken id="B9CE584672B14DFCD91C0725E495B8B1" originalValue="Pyrenäen" pageId="null" pageNumber="433">Pyrenaeen</normalizedToken>
, Alpen, Karpaten, Gebirge der Balkanhalbinsel, Nordural; in Ostsibirien und Nordamerika die nahe verwandte 
<taxonomicName id="DFAFDFA7FB057D6D654801268CBF00BB" authority="DC. Karte" authorityName="DC. Karte" class="Magnoliopsida" family="Asteraceae" genus="Saussurea" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="433" phylum="Tracheophyta" rank="species" species="angustifolia">
<emphasis id="B186252A5644A5873E103D630DAE4DCE" italics="true" pageId="null" pageNumber="433">S. angustifolia</emphasis>
DC. Karte
</taxonomicName>
der ostalpinen Verbreitung (
<normalizedToken id="35B56D03DA79A00FF970713971531442" originalValue="östlich" pageId="null" pageNumber="433">oestlich</normalizedToken>
des Rheins) von Gander-Thimm (1963). - Im Gebiet: Zentralalpen und 
<normalizedToken id="BE9789409D0773231A5108AC18A74504" originalValue="nördliche" pageId="null" pageNumber="433">noerdliche</normalizedToken>
<normalizedToken id="C1E8714FD9744E8A5C3F1ADD61E751F7" originalValue="Südalpen" pageId="null" pageNumber="433">Suedalpen</normalizedToken>
(z. B. Valsesia, 
<normalizedToken id="1A219023681CC71C008E4A11099F8B14" originalValue="nördliches" pageId="null" pageNumber="433">noerdliches</normalizedToken>
Tessin, Valle di Scalve in den Bergamasker Alpen), nicht 
<normalizedToken id="ACBADA6E52D9DFA09C99D90DFA1AA8D6" originalValue="häufig" pageId="null" pageNumber="433">haeufig</normalizedToken>
; Nordalpen, selten.
</paragraph>
</subSubSection>
