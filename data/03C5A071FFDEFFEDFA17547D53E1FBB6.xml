<taxonomicName id="4C6C6AE4FFD9FFEDFC3259415E68FEF5" authorityName="Illiger" authorityYear="1811" box="[910,1033,328,353]" class="Mammalia" family="Echimyidae" genus="Loncheres" kingdom="Animalia" order="Rodentia" pageId="52" pageNumber="604" phylum="Chordata" rank="genus">Loncheres</taxonomicName>
