<subSubSection id="C37642ECFFD9FFEDFD7F591159FFFE1D" pageId="52" pageNumber="604" type="discussion">
<paragraph id="8BD31167FFD9FFEDFD7F591159FFFE1D" blockId="52.[706,1300,280,707]" pageId="52" pageNumber="604">
<taxonomicName id="4C6C6AE4FFD9FFEDFD7F591159B7FEAD" baseAuthorityName="Wagner" baseAuthorityYear="1842" box="[707,982,280,313]" class="Mammalia" family="Echimyidae" genus="Phyllomys" kingdom="Animalia" order="Rodentia" pageId="52" pageNumber="604" phylum="Chordata" rank="species" species="nigrispinus">Phyllomys nigrispinus</taxonomicName>
