<subSubSection id="C93B54A5BA951B71E0CFBBA81130F181" pageId="null" pageNumber="411" type="description">
<paragraph id="D3A233D95179121B6B98B230410F19C9" pageId="null" pageNumber="411">
90-180 cm hoch. 
<emphasis id="B5B2AD708389D36B191341F7C5329CB9" italics="true" pageId="null" pageNumber="411">
<normalizedToken id="4098A79C2E2328498F847A03108B5471" originalValue="Äste" pageId="null" pageNumber="411">Aeste</normalizedToken>
fast waagrecht ausgebreitet, an den Enden 
<normalizedToken id="C258738D36DB122F55C95DCCBBC4B26B" originalValue="überhängend" pageId="null" pageNumber="411">ueberhaengend</normalizedToken>
.
</emphasis>
Blattstiele rinnig und hohl. 
<emphasis id="E16AEA398B46D709C2171126C3303026" italics="true" pageId="null" pageNumber="411">
<normalizedToken id="EC2B4DCC2729D94A2E5D4B19DA4BD60C" originalValue="Blühende" pageId="null" pageNumber="411">Bluehende</normalizedToken>
<normalizedToken id="6F962FD0FBABDE44D257EFD69CD96798" originalValue="Köpfe" pageId="null" pageNumber="411">Koepfe</normalizedToken>
3
</emphasis>
- 
<emphasis id="2BE9BE7BA722F0D3DAA1B8648F0BD416" italics="true" pageId="null" pageNumber="411">4,5 cm dick, kurz gestielt</emphasis>
(Stiel meist 
<normalizedToken id="E91F05BF6A8DE2EA33495CAEEF3A637D" originalValue="kürzer" pageId="null" pageNumber="411">kuerzer</normalizedToken>
als der Kopf), 
<emphasis id="4071E2FFAEEB8CA503B1CB055517B754" italics="true" pageId="null" pageNumber="411">in einer nicht doldenartigen Traube.</emphasis>
<normalizedToken id="2B3EA48FB9E64BCE08CF9655FB631F92" originalValue="Hülle" pageId="null" pageNumber="411">Huelle</normalizedToken>
kaum spinnwebig behaart, zur Fruchtzeit offen, 
<emphasis id="0B0E9057E698F31CD207EA865A99F3E5" italics="true" pageId="null" pageNumber="411">
oft rot; 
<normalizedToken id="E98FD748D4544C83643B04D36C0E99E5" originalValue="Hüllblätter" pageId="null" pageNumber="411">Huellblaetter</normalizedToken>
an der Basis des 
<normalizedToken id="E2C0CD7B82BC8E5AEDC964228670A106" originalValue="zurückgebogenen" pageId="null" pageNumber="411">zurueckgebogenen</normalizedToken>
Teiles 0,5
</emphasis>
- 
<emphasis id="06B199213F92A7440591A38345C1E560" italics="true" pageId="null" pageNumber="411">1 mm breit;</emphasis>
die innersten an der Spitze 
<normalizedToken id="8378ECA5A0081109664437765A18FA9F" originalValue="rötlich" pageId="null" pageNumber="411">roetlich</normalizedToken>
, 
<normalizedToken id="935ACA9F7C82EED9368214AD69CF389D" originalValue="allmählich" pageId="null" pageNumber="411">allmaehlich</normalizedToken>
in einen geraden oder 
<normalizedToken id="7E3DC47D0B0597A4B5A19D466CF5A399" originalValue="gekrümmten" pageId="null" pageNumber="411">gekruemmten</normalizedToken>
Stachel 
<normalizedToken id="F8DC9F0BC1CF518194130FCA091C91F7" originalValue="verschmälert" pageId="null" pageNumber="411">verschmaelert</normalizedToken>
, mindestens so lang wie die 
<normalizedToken id="4F58CA27A0D7EF4855C819707DE261F6" originalValue="Blüten" pageId="null" pageNumber="411">Blueten</normalizedToken>
. Kronen ohne 
<normalizedToken id="1423A35BDE1E35E5DC021B60A3C3C9E4" originalValue="Drüsen" pageId="null" pageNumber="411">Druesen</normalizedToken>
, purpurn. 
<emphasis id="7F5E0D33B6216B039B7D28FF58214DA3" italics="true" pageId="null" pageNumber="411">
<normalizedToken id="46217F704ED7330B12DAC38772892C91" originalValue="Früchte" pageId="null" pageNumber="411">Fruechte</normalizedToken>
7
</emphasis>
- 
<emphasis id="7445567C30F5F0ABCCB0DD63089AAB22" italics="true" pageId="null" pageNumber="411">11 mm lang.</emphasis>
- 
<normalizedToken id="BEB5D2C4D8822C4B97B9BE1B5726F3C5" originalValue="Blüte" pageId="null" pageNumber="411">Bluete</normalizedToken>
: 
<normalizedToken id="D757EADA42DA2635A6F8F5D02068EAE3" originalValue="Später" pageId="null" pageNumber="411">Spaeter</normalizedToken>
Sommer und 
<normalizedToken id="8701CD752DB79A4CFACDAD83B0623A02" originalValue="früher" pageId="null" pageNumber="411">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="B529B2C8EFE3E896CB5347B801C8866F" pageId="null" pageNumber="411">
<emphasis id="103266B6719E4A04AB877323AF073FEF" italics="true" pageId="null" pageNumber="411">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="BC81C7E2CFE27523C4088775744DB453" italics="true" pageId="null" pageNumber="411">36:</emphasis>
Material aus Skandinavien (
<normalizedToken id="4BC651A3A30C1ABBD37A427808A21D05" originalValue="Löve" pageId="null" pageNumber="411">Loeve</normalizedToken>
und 
<normalizedToken id="412AA950B6A4EE7699CBC20FFD722BCE" originalValue="Löve" pageId="null" pageNumber="411">Loeve</normalizedToken>
1944b), unbekannter Herkunft (Tarnavschi aus Tischler 1950), aus Jugoslawien (Moore in 
<normalizedToken id="9238117D3D2B8415F2F9E5CC25213481" originalValue="Löve" pageId="null" pageNumber="411">Loeve</normalizedToken>
1968c), aus der Slowakei (Index Slov. 1967).
</paragraph>
<paragraph id="E7C7980F304B25D82D0C1927BA7E7142" pageId="null" pageNumber="411">
<emphasis id="DD2ECE469ABCED171461E596243C0794" italics="true" pageId="null" pageNumber="411">Standort.</emphasis>
Montan, seltener subalpin. Sickerfeuchte, 
<normalizedToken id="1F91DC21FEB8D22EC87F9207B8B7646B" originalValue="nährstoffreiche" pageId="null" pageNumber="411">naehrstoffreiche</normalizedToken>
, neutrale, lockere, lehmige 
<normalizedToken id="1A0FCAC0E8E81D3FAB17837E57B73DE1" originalValue="Böden" pageId="null" pageNumber="411">Boeden</normalizedToken>
in 
<normalizedToken id="CF0FF39E05059D6DA1D608D908F0095C" originalValue="wärmeren" pageId="null" pageNumber="411">waermeren</normalizedToken>
Lagen. 
<normalizedToken id="9A149CD3B6AC5091733FBA000F77FD36" originalValue="Waldschläge" pageId="null" pageNumber="411">Waldschlaege</normalizedToken>
, 
<normalizedToken id="D8BAECAE4E1BB18D3DAD98FB0B67C53B" originalValue="Gebüsche" pageId="null" pageNumber="411">Gebuesche</normalizedToken>
, 
<normalizedToken id="E4CE89596DD2B7B3E726B1B8D46BE98D" originalValue="Auenwälder" pageId="null" pageNumber="411">Auenwaelder</normalizedToken>
.
</paragraph>
<paragraph id="5CA26B621B55AE01EBB20B7EB0F687C3" pageId="null" pageNumber="411">
<emphasis id="7219A44742816D051F585D516F486651" italics="true" pageId="null" pageNumber="411">
Verbreitung. 
<normalizedToken id="DBF91C74283B2EBCCFF41CC6AE9D9A8E" originalValue="Europäische" pageId="null" pageNumber="411">Europaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="108B9641666227C332792D13581AF1E9" originalValue="Nordwärts" pageId="null" pageNumber="411">Nordwaerts</normalizedToken>
bis Irland, Schottland und 
<normalizedToken id="A39B95E9904F4DA72E73AA4CE05B0F1D" originalValue="Südskandinavien" pageId="null" pageNumber="411">Suedskandinavien</normalizedToken>
; 
<normalizedToken id="FD51288C8C55362769C10B1E6BABB47F" originalValue="westwärts" pageId="null" pageNumber="411">westwaerts</normalizedToken>
bis zu den 
<normalizedToken id="2286E69B03F1C7B4EDDC1987585C04A6" originalValue="Pyrenäen" pageId="null" pageNumber="411">Pyrenaeen</normalizedToken>
; 
<normalizedToken id="F282F86A09C08792DF38114103B89B16" originalValue="südwärts" pageId="null" pageNumber="411">suedwaerts</normalizedToken>
bis Sizilien und Bulgarien; 
<normalizedToken id="114A55A03952AE5A867C88F9D77F3EA9" originalValue="ostwärts" pageId="null" pageNumber="411">ostwaerts</normalizedToken>
bis zur Wolga; in Amerika eingeschleppt. - Im Gebiet zerstreut, nicht 
<normalizedToken id="B0E9F2D62270CFB75AA6A978CEFF97DC" originalValue="häufig" pageId="null" pageNumber="411">haeufig</normalizedToken>
, in den Zentralalpen selten.
</paragraph>
