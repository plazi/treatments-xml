<subSubSection id="EE04417D4BCC82EA1D0CD05F9B1E5FE9" pageId="null" pageNumber="512" type="description">
<paragraph id="286B23D580AD3FACBC754662AEFFFAB6" pageId="null" pageNumber="512">
1 
<normalizedToken id="4E272A54874999B537B157661D95717B" originalValue="jährig" pageId="null" pageNumber="512">jaehrig</normalizedToken>
, mit 
<normalizedToken id="4A66346FB49258005C21C6B330DCF3F8" originalValue="dünner" pageId="null" pageNumber="512">duenner</normalizedToken>
Wurzel; 20-160 cm hoch. Stengel verzweigt, gegen den Grund hin braunrot, kahl oder zerstreut behaart. 
<emphasis id="00A4E0130DE4252890AD0C5AD65720A2" italics="true" pageId="null" pageNumber="512">
<normalizedToken id="4B30AE7DCC6694DD28CD1F2E2513FF62" originalValue="Blätter" pageId="null" pageNumber="512">Blaetter</normalizedToken>
in einen kurzen, 
<normalizedToken id="81A6D8CE29951408F8F9CFDC7C7D7501" originalValue="geflügelten" pageId="null" pageNumber="512">gefluegelten</normalizedToken>
Stiel 
<normalizedToken id="0404A4A63AA40FBC89C4E9A0636ECC99" originalValue="verschmälert" pageId="null" pageNumber="512">verschmaelert</normalizedToken>
</emphasis>
, 
<normalizedToken id="724AF37EDDB0336DE6289B4E1FF58CA6" originalValue="dunkelgrün" pageId="null" pageNumber="512">dunkelgruen</normalizedToken>
, kahl, nur am Rande von kurzen, nach vorn gerichteten Haaren rauh, 
<emphasis id="8BC6B98A61037B2348D281C3B9D52D70" italics="true" pageId="null" pageNumber="512">ungeteilt</emphasis>
, lanzettlich, lang zugespitzt, 
<emphasis id="2C84035F99E4FA91DB770AF2BAAF6F02" italics="true" pageId="null" pageNumber="512">
grob 
<normalizedToken id="827C33AE959EA64F5281CF0F884DFCDF" originalValue="gezähnt" pageId="null" pageNumber="512">gezaehnt</normalizedToken>
;
</emphasis>
<normalizedToken id="5F782CB4ECD3209C6E8CEBACA69EC620" originalValue="Zähne" pageId="null" pageNumber="512">Zaehne</normalizedToken>
jederseits 5-10, nach vorn gerichtet. 
<normalizedToken id="7FCA2B5406348766549A62AB8839F0BF" originalValue="Köpfe" pageId="null" pageNumber="512">Koepfe</normalizedToken>
aufrecht, zur 
<normalizedToken id="B94F33E64338857B3CE9FD69D58C9724" originalValue="Blütezeit" pageId="null" pageNumber="512">Bluetezeit</normalizedToken>
im Durchmesser 0,8-1,5 cm, 
<emphasis id="4957132F2676752C2FD13A883C028F48" italics="true" pageId="null" pageNumber="512">
meist ohne 
<normalizedToken id="E372201400A236B667195B2AE7C75305" originalValue="zungenförmige" pageId="null" pageNumber="512">zungenfoermige</normalizedToken>
<normalizedToken id="B62D1CFE966F793F71A7BA9CC402C153" originalValue="Blüten" pageId="null" pageNumber="512">Blueten</normalizedToken>
.
</emphasis>
<normalizedToken id="564BD1FA7EC4994A668439AE7E97D89B" originalValue="Äußere" pageId="null" pageNumber="512">Aeussere</normalizedToken>
<normalizedToken id="64093B0BAE01E3D24B81AD4115D1BA61" originalValue="Hüllblätter" pageId="null" pageNumber="512">Huellblaetter</normalizedToken>
2-6, 
<emphasis id="C9687045C05A018C5309EDC8679340DF" italics="true" pageId="null" pageNumber="512">20</emphasis>
- 
<emphasis id="A39FBF921A6C89F0BBF15BBDD2DC2F65" italics="true" pageId="null" pageNumber="512">60 mm lang</emphasis>
und 3-15 mm breit, am Rande von kurzen, nach vorn gerichteten Haaren rauh; innere 
<normalizedToken id="451FCA4BE49F420AED3C6B537DC68E7F" originalValue="Hüllblätter" pageId="null" pageNumber="512">Huellblaetter</normalizedToken>
etwa 8-12, gelb, mit braunen 
<normalizedToken id="40D7DB023AF6573FDF360FE33B541553" originalValue="Längsstreifen" pageId="null" pageNumber="512">Laengsstreifen</normalizedToken>
, 6-10 mm lang. 
<normalizedToken id="1AA0121DA85BFA73025FADCF5DA799A7" originalValue="Früchte" pageId="null" pageNumber="512">Fruechte</normalizedToken>
4kantig, 
<emphasis id="0BF87A2B299B1C4D9BEF8FE8FA756074" italics="true" pageId="null" pageNumber="512">
<normalizedToken id="477C8F0A8181AF83FF10BB9948E4D11B" originalValue="höckerig" pageId="null" pageNumber="512">hoeckerig</normalizedToken>
, auf den 
<normalizedToken id="48C7454E9CDEC25E20FE654BC9167D7B" originalValue="Höckern" pageId="null" pageNumber="512">Hoeckern</normalizedToken>
mit einzelnen 
<normalizedToken id="09A1297D2264F4F3C5AA34D5D707A98F" originalValue="vorwärts" pageId="null" pageNumber="512">vorwaerts</normalizedToken>
gerichteten Haaren
</emphasis>
(
<emphasis id="68A3C10E0FA04DB9E9A4FFEE239A7D5D" italics="true" pageId="null" pageNumber="512">
daneben auch 
<normalizedToken id="A8C8F144717D326C1D559EEC4FE7D441" originalValue="rückwärts" pageId="null" pageNumber="512">rueckwaerts</normalizedToken>
gerichtete Haare
</emphasis>
), 5-8 mm lang, 1,5-2,5 mm breit. 
<emphasis id="B486D24ADC1657803CD1064B902B2CF5" italics="true" pageId="null" pageNumber="512">Borsten 3</emphasis>
- 
<emphasis id="BA5BFF3842C9CC7D4ED3DDBDCCF195DB" italics="true" pageId="null" pageNumber="512">4</emphasis>
, 2-4 mm lang. - 
<normalizedToken id="CC0825D536CDE80D5CA463D3324E9163" originalValue="Blüte" pageId="null" pageNumber="512">Bluete</normalizedToken>
: 
<normalizedToken id="64C9534A5FB9BA9BC3FC8B687E48D699" originalValue="Später" pageId="null" pageNumber="512">Spaeter</normalizedToken>
Sommer und Herbst.
</paragraph>
<paragraph id="1E503D1536C4DAC9DB24E66DA8CA8233" pageId="null" pageNumber="512">
<emphasis id="67548FF3AAB2D31ABEE91FBEB0B4C4AF" italics="true" pageId="null" pageNumber="512">
<pageBreakToken id="C1F62089579C3493C9257C1872E55A4A" pageId="null" pageNumber="512">Zytologische</pageBreakToken>
Angaben.
</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="EB4EB40D6B2956377DE0185B716421F7" pageId="null" pageNumber="512">
<emphasis id="50E0F92F22D515A2B46C61B659ECF88F" italics="true" pageId="null" pageNumber="512">Standort.</emphasis>
Kollin. 
<normalizedToken id="63CF34060F4F811C60E6925EEC8B95E2" originalValue="Nährstoffreiche" pageId="null" pageNumber="512">Naehrstoffreiche</normalizedToken>
, periodisch 
<normalizedToken id="AD0C11CBED292FF2AA00D3F69C1E8965" originalValue="überschwemmte" pageId="null" pageNumber="512">ueberschwemmte</normalizedToken>
<normalizedToken id="00D91385F04C31EDE60F06C6E3CD9CAA" originalValue="Schlammböden" pageId="null" pageNumber="512">Schlammboeden</normalizedToken>
. 
<normalizedToken id="D354011DD4F2EB2EB1AD1365D5DED1DA" originalValue="Flußufer" pageId="null" pageNumber="512">Flussufer</normalizedToken>
, 
<normalizedToken id="7AF6E062E618E5D5917B1A78D97BECCF" originalValue="Auenwälder" pageId="null" pageNumber="512">Auenwaelder</normalizedToken>
. 
<emphasis id="2124FDEF6EAB9F2477C4CCA3E63FF5A7" italics="true" pageId="null" pageNumber="512">Polygono-Bidentetum</emphasis>
(W. Kreh) Lohmeyer 1950 und verwandte Gesellschaften.
</paragraph>
<paragraph id="3C48B011B7E19A1D1611B2E0CDAC6BD0" pageId="null" pageNumber="512">
<emphasis id="B21D9E0ECC7F8DBA1A0235B94BE1F0EE" italics="true" pageId="null" pageNumber="512">Verbreitung. Nordamerikanische Pflanze</emphasis>
(
<emphasis id="2C09806CB604594253DDC03EAA250B2B" italics="true" pageId="null" pageNumber="512">
<normalizedToken id="BABC8124CDF085654CB97197B7293EB9" originalValue="östlich" pageId="null" pageNumber="512">oestlich</normalizedToken>
</emphasis>
), im 
<normalizedToken id="A1839CDA0AA37D1001376E95BA1626A6" originalValue="nördlichen" pageId="null" pageNumber="512">noerdlichen</normalizedToken>
Europa eingeschleppt. - Im Gebiet: 
<normalizedToken id="04E3A879E492552D4D250AB1CEC26545" originalValue="Dép" pageId="null" pageNumber="512">Dep</normalizedToken>
. Jura (Litzler 1968), Oberrheinische Tiefebene, 
<normalizedToken id="437FE8E68DC3EEC4138BAE3ACAA83CD1" originalValue="nördliches" pageId="null" pageNumber="512">noerdliches</normalizedToken>
Mittelland (Aare und Rhein, von Brugg an 
<normalizedToken id="F3637C94BAD67B2855F195C7637B6108" originalValue="abwärts" pageId="null" pageNumber="512">abwaerts</normalizedToken>
).
</paragraph>
<paragraph id="D92131322A06EE2A3CE2450ED1681ADA" pageId="null" pageNumber="512">
<emphasis id="B172C1C369EDB6818AFCCDCA90732784" italics="true" pageId="null" pageNumber="512">
Bemerkungen. 
<taxonomicName id="513AE3CE1EF728CD1318D9523577D498" class="Magnoliopsida" family="Asteraceae" genus="Bidens" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="512" phylum="Tracheophyta" rank="species" species="decipiens">B. decipiens</taxonomicName>
</emphasis>
ist im Gebiet erst seit 1942 bekannt (
<normalizedToken id="731DFC842BC266049149B9EC84A2BAD8" originalValue="Häfliger" pageId="null" pageNumber="512">Haefliger</normalizedToken>
und Koch 1943). Sie unterscheidet sich von der in Nordamerika weiter 
<normalizedToken id="8514D0F9ADEB2A1AB5CCA72C189F21E2" originalValue="südlich" pageId="null" pageNumber="512">suedlich</normalizedToken>
verbreiteten und in Europa nicht bekannten 
<taxonomicName id="EBA506DAB5FBDC2B4824AECAF2A88714" class="Magnoliopsida" family="Asteraceae" genus="Bidens" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="512" phylum="Tracheophyta" rank="species" species="connata">
<emphasis id="7BAAD53FFE716D9407F9D1C53D31FA25" italics="true" pageId="null" pageNumber="512">B. connata</emphasis>
</taxonomicName>
durch die breit 
<normalizedToken id="5ED5D779AB2011AC587C3BC663FD0257" originalValue="geflügelten" pageId="null" pageNumber="512">gefluegelten</normalizedToken>
Blattstiele und die bis 6 cm langen 
<normalizedToken id="32568E00475F9C0AD254811065B88745" originalValue="Hüllblätter" pageId="null" pageNumber="512">Huellblaetter</normalizedToken>
(bei 
<taxonomicName id="F24DBBE1CEC65F958F75557AEC6EC8AD" class="Magnoliopsida" family="Asteraceae" genus="Bidens" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="512" phylum="Tracheophyta" rank="species" species="connata">
<emphasis id="2FF87956896ABCC8634C3D344B82C8BA" italics="true" pageId="null" pageNumber="512">B. connata</emphasis>
</taxonomicName>
bis 3 cm lang).
</paragraph>
