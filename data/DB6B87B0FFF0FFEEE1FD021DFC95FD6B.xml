<taxonomicName id="94C24D25FFF0FFEEE1C20231FE36FD47" authorityName="Wiltshire" authorityYear="1941" box="[248,405,619,644]" class="Insecta" family="Nymphalidae" genus="Melitaea" kingdom="Animalia" order="Lepidoptera" pageId="8" pageNumber="33" phylum="Arthropoda" rank="species" species="sarvistana">
