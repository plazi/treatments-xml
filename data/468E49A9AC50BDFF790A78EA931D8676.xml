<subSubSection id="50FAFCE6DE7BD19197D8EEE5E3CFA126" pageId="null" pageNumber="712" type="description">
<paragraph id="6C6D6996703D08E3E9B3008348490AAB" pageId="null" pageNumber="712">
Unterscheidet sich von 
<taxonomicName id="94C5F2B15D7B9F19DCC8820B6D3DA11A" class="Insecta" family="Staphylinidae" genus="Thesium" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="712" phylum="Arthropoda" rank="species" species="alpinum">
<emphasis id="241687FB6400DE41F67ACC8A24AC3ACB" italics="true" pageId="null" pageNumber="712">T. alpinum</emphasis>
</taxonomicName>
(Nr. 5) durch folgende Merkmale: 
<emphasis id="D646784E6545CE039917CAE48B0F1074" italics="true" pageId="null" pageNumber="712">
<normalizedToken id="494511CF47D5154280AE9482B84F439A" originalValue="Blütenstand" pageId="null" pageNumber="712">Bluetenstand</normalizedToken>
allseitswendig; die 3 
<normalizedToken id="00CED46BC62ED05D299A897808CE0B71" originalValue="Hochblätter" pageId="null" pageNumber="712">Hochblaetter</normalizedToken>
vor jeder 
<normalizedToken id="CFC73E7F92746BC2BB7E54225F3EA0F7" originalValue="Blüte" pageId="null" pageNumber="712">Bluete</normalizedToken>
am Rande mit feinen, borstigen 
<normalizedToken id="E4C095DC236316BFE2C7F27841738B6F" originalValue="Zähnen" pageId="null" pageNumber="712">Zaehnen</normalizedToken>
</emphasis>
(10fache 
<normalizedToken id="3A24716CD4312ECC79F12F991B853E72" originalValue="Vergrößerung" pageId="null" pageNumber="712">Vergroesserung</normalizedToken>
!); 
<emphasis id="D6203238BE7717B6032DC45B45DA1343" italics="true" pageId="null" pageNumber="712">
<normalizedToken id="194E0C9CDA335165BA17ABD2A3F38722" originalValue="Blüten" pageId="null" pageNumber="712">Blueten</normalizedToken>
5 
<normalizedToken id="56A1BCD47D84402D74A2171BD31450C7" originalValue="zählig" pageId="null" pageNumber="712">zaehlig</normalizedToken>
; 
<normalizedToken id="123F84474ABD08D7A16DD1E8E92C4F3A" originalValue="über" pageId="null" pageNumber="712">ueber</normalizedToken>
der Frucht der verwachsene Teil des Perigons 
<normalizedToken id="901A9723F8DC15DE711FD795B5838CB9" originalValue="kürzer" pageId="null" pageNumber="712">kuerzer</normalizedToken>
, aber ebenso dick wie der obere Teil mit den freien, an der Spitze 
<normalizedToken id="CE93B448279057849F7B4EBB4E1B9063" originalValue="einwärts" pageId="null" pageNumber="712">einwaerts</normalizedToken>
gebogenen Perigonzipfeln.
</emphasis>
- 
<normalizedToken id="A4783B7C9D5414C360571F9475D401D1" originalValue="Blüte" pageId="null" pageNumber="712">Bluete</normalizedToken>
: 
<normalizedToken id="7D10B878E3572F3BAB9FDFA410AC31DC" originalValue="Später" pageId="null" pageNumber="712">Spaeter</normalizedToken>
<normalizedToken id="18238344301D10948303DB746CC27429" originalValue="Frühling" pageId="null" pageNumber="712">Fruehling</normalizedToken>
und 
<normalizedToken id="C720C8E8F7301412D3129D569FE0555B" originalValue="früher" pageId="null" pageNumber="712">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="DBD1097A4135233940D56E799ABAA1DC" pageId="null" pageNumber="712">
<emphasis id="6045DAFD254568C38C1DF5D9DC34E1B5" italics="true" pageId="null" pageNumber="712">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="BAD78AA6596971512E3246B8E04565EE" pageId="null" pageNumber="712">
<emphasis id="94800876D57DCD8F838466B37F5B4449" italics="true" pageId="null" pageNumber="712">Standort.</emphasis>
Montan, subalpin und alpin, seltener kollin. Saure, 
<normalizedToken id="32E26335F0F34DB51E9091B37450A67D" originalValue="nährstoffarme" pageId="null" pageNumber="712">naehrstoffarme</normalizedToken>
, trockene bis frische, humose, oft steinige 
<normalizedToken id="7AA7FD5239363AA2D922482D284FA22C" originalValue="Böden" pageId="null" pageNumber="712">Boeden</normalizedToken>
(Versauerungszeiger). Magerwiesen.
</paragraph>
<paragraph id="FA308D297B9C84FAD8928290B5456731" pageId="null" pageNumber="712">
<emphasis id="AFB4ED9E2324BEFD00BE3AC0C8B1F21D" italics="true" pageId="null" pageNumber="712">
Verbreitung. Mittel- und 
<normalizedToken id="B934BE3C1785DA0440D1DAFCB1F698EA" originalValue="südeuropäische" pageId="null" pageNumber="712">suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="C004D41EC0350CE3BC1307A47081B83D" originalValue="Nordwärts" pageId="null" pageNumber="712">Nordwaerts</normalizedToken>
bis 
<normalizedToken id="BCB28760AB75FC8F1060A7A407617FC2" originalValue="Südwest-" pageId="null" pageNumber="712">Suedwest-</normalizedToken>
und Mittelfrankreich, Holland, Rand der norddeutschen Tiefebene, Polen, 
<normalizedToken id="A393FAE69E8F3CCCE3030585B52A5C86" originalValue="ostwärts" pageId="null" pageNumber="712">ostwaerts</normalizedToken>
bis in die Westkarpaten, 
<normalizedToken id="A54F96A481C482C76BFD6165F041C844" originalValue="südwärts" pageId="null" pageNumber="712">suedwaerts</normalizedToken>
bis nordspanische Gebirge, etruskischer Apennin, Gebirge Jugoslawiens. Verbreitungskarte von Meusel 1964). - Im Gebiet ziemlich verbreitet, nicht 
<normalizedToken id="F21C0ECCAFA56FDAEF0E525C30E05510" originalValue="häufig" pageId="null" pageNumber="712">haeufig</normalizedToken>
(auf der 
<normalizedToken id="59927C7BACD4AEDEF0FBE40FA37AA4EB" originalValue="Alpensüdseite" pageId="null" pageNumber="712">Alpensuedseite</normalizedToken>
sehr selten). Karte der zirkumalpinen Verbreitung von Bresinsky (1965).
</paragraph>
</subSubSection>
