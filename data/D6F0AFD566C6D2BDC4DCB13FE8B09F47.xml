<subSubSection id="276D4447B2C762DB19C28F987815D822" pageId="null" pageNumber="760" type="description">
<paragraph id="5A9325193384C708923F28C63D7F63B6" pageId="null" pageNumber="760">
1 
<normalizedToken id="A632C5B461CA5E6710B5D7863A61DB4B" originalValue="jährig" pageId="null" pageNumber="760">jaehrig</normalizedToken>
, 10-20 cm hoch. Stengel niederliegend oder bogig aufsteigend, meist schon am Grunde verzweigt, flaumig behaart oder kahl. 
<normalizedToken id="28D03C87AB82AC327B7DDE3CBFBE5383" originalValue="Blätter" pageId="null" pageNumber="760">Blaetter</normalizedToken>
<normalizedToken id="A90AEB385F1BD15B5F56D76543D2BABB" originalValue="nadelförmig" pageId="null" pageNumber="760">nadelfoermig</normalizedToken>
, meist etwa 1 cm lang, unterseits abgerundet, oberseits mit Rillen, 
<emphasis id="574271F4C7BA7C21F85D900A67FE4CD2" italics="true" pageId="null" pageNumber="760">mit feiner, stachliger, gelber Spitze.</emphasis>
<normalizedToken id="EC746B44368762E46D1341AD830691AE" originalValue="Blüten" pageId="null" pageNumber="760">Blueten</normalizedToken>
einzeln in den Blattachseln. Die 
<emphasis id="11E703C345CC1161F7CDD31DCDEDAEEE" italics="true" pageId="null" pageNumber="760">
2 
<normalizedToken id="089BCB6CBFE1C3CC3A0A7608031DCD3D" originalValue="Vorblätter" pageId="null" pageNumber="760">Vorblaetter</normalizedToken>
<normalizedToken id="BA9F7050191D477E1C852D45D8A1122E" originalValue="häutig" pageId="null" pageNumber="760">haeutig</normalizedToken>
</emphasis>
, mit langer, feiner, 
<normalizedToken id="BBC06CD859435D1F6E0886083F9D37A8" originalValue="weißer" pageId="null" pageNumber="760">weisser</normalizedToken>
Spitze, oft 
<emphasis id="422B15FFA636E489EA4514A5BC4B1A3C" italics="true" pageId="null" pageNumber="760">
deutlich 
<normalizedToken id="CB07E01D5ED32ED17147137E7B2BAFEA" originalValue="länger" pageId="null" pageNumber="760">laenger</normalizedToken>
</emphasis>
(
<emphasis id="F2122324DA412F20FF44D93C0132B932" italics="true" pageId="null" pageNumber="760">bis 2mal so lang</emphasis>
) 
<emphasis id="FEC1217B6D28E76863D4B97E76172688" italics="true" pageId="null" pageNumber="760">
als die 
<normalizedToken id="CC8896CF4B8959FCCEDC499591149C68" originalValue="Perigonblätter" pageId="null" pageNumber="760">Perigonblaetter</normalizedToken>
. 
<normalizedToken id="FF289E7E3B387DAF08B6F0FD21BFB8B1" originalValue="Perigonblätter" pageId="null" pageNumber="760">Perigonblaetter</normalizedToken>
2
</emphasis>
- 
<emphasis id="E7425385D0212E02925F239D07C9BC12" italics="true" pageId="null" pageNumber="760">2,5 mm lang. -</emphasis>
<normalizedToken id="1689260518E8D569F9BBA2162DC20294" originalValue="Blüte" pageId="null" pageNumber="760">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="664084D3378E9BDA652AA296C442469F" pageId="null" pageNumber="760">
<emphasis id="1DF023A65F1F3806B909D2F98C070203" italics="true" pageId="null" pageNumber="760">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="FB87D8CB14941E07C0E1BB3A76E360DA" pageId="null" pageNumber="760">
<emphasis id="1938C7815E7CAA6075502574489F2258" italics="true" pageId="null" pageNumber="760">Standort.</emphasis>
Kollin, seltener montan. Trockene, sandige bis kiesige, kalkhaltige 
<normalizedToken id="10D74E61C4091488CEEED6F62A2073D3" originalValue="Böden" pageId="null" pageNumber="760">Boeden</normalizedToken>
in 
<normalizedToken id="4798FB6D9997687B95C5142952704A9E" originalValue="heißen" pageId="null" pageNumber="760">heissen</normalizedToken>
Lagen. 
<normalizedToken id="004E99AF1DC982F444221F5002800186" originalValue="Äcker" pageId="null" pageNumber="760">Aecker</normalizedToken>
, Weinberge, entlang Bahnlinien in Ausbreitung begriffen.
</paragraph>
<paragraph id="ADA6468D57DA104962BE205F11C006FC" pageId="null" pageNumber="760">
<emphasis id="00FF5F1F7CB4DA23BB9AAA6E32E8394C" italics="true" pageId="null" pageNumber="760">
<pageBreakToken id="5DC5004DDDEC4470600E6184E9872666" pageId="null" pageNumber="760">Verbreitung</pageBreakToken>
. 
<normalizedToken id="AC83C6700AC2B659C5D019C5E23CC50F" originalValue="Südeuropäisch-südwestasiatische" pageId="null" pageNumber="760">Suedeuropaeisch-suedwestasiatische</normalizedToken>
Pflanze:
</emphasis>
Ganz 
<normalizedToken id="041073BAD8B1D0172E11274100A26592" originalValue="Südeuropa" pageId="null" pageNumber="760">Suedeuropa</normalizedToken>
, 
<normalizedToken id="427B26AB7E35BAEF20E07BE4FF5B883C" originalValue="nordwärts" pageId="null" pageNumber="760">nordwaerts</normalizedToken>
bis Nordfrankreich, 
<normalizedToken id="7AB4D448C7DE94B4066E9F46EFCE0032" originalValue="Thüringen" pageId="null" pageNumber="760">Thueringen</normalizedToken>
, Magdeburg, 
<normalizedToken id="0F01CBF2B4CCF489CF00826D40664982" originalValue="Südpolen" pageId="null" pageNumber="760">Suedpolen</normalizedToken>
, 
<normalizedToken id="6BC024F37521CAE02985AFA93182416D" originalValue="Südrußland" pageId="null" pageNumber="760">Suedrussland</normalizedToken>
; 
<normalizedToken id="99131839DA1D6ACA00345D2ACA5F804E" originalValue="ostwärts" pageId="null" pageNumber="760">ostwaerts</normalizedToken>
bis zu den zentralasiatischen Gebirgen. - Im Gebiet in den Gegenden mit Weinklima; ziemlich selten, auch auf Bahnarealen.
</paragraph>
</subSubSection>
