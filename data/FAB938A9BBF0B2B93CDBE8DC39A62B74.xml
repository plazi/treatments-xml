<taxonomicName id="262DB6F317039CEB50FEE4FCE6748050" authority="L." class="Magnoliopsida" family="Adoxaceae" genus="Viburnum" kingdom="Plantae" order="Dipsacales" pageId="null" pageNumber="314" phylum="Tracheophyta" rank="species" species="opulus">
