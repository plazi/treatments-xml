<taxonomicName id="4E984D1F0727FF88F721F43861664DDC" authority="Baird, 1855" authorityName="Baird" authorityYear="1855" box="[2258,2665,3009,3038]" class="Mammalia" family="Geomyidae" genus="Geomys" kingdom="Animalia" order="Rodentia" pageId="11" pageNumber="244" phylum="Chordata" rank="species" species="breviceps">Geomys breviceps Baird, 1855</taxonomicName>
, 
<materialsCitation id="39F03CC10727FF88F7D3F41562CF4A07" ID-GBIF-Occurrence="3799834309" box="[2080,2496,3052,3077]" pageId="11" pageNumber="244">Morehouse Parish, La.,” oy</materialsCitation>
</paragraph>
<paragraph id="8927369C0727FF88F7EDF3F662234AA0" blockId="11.[2078,2671,3009,3431]" pageId="11" pageNumber="244">According to J. W. Demastes in 1994, the subspecies sagittalis may be a distinct species based on mtDNA evidence. Two subspecies recognized.</paragraph>
</subSubSection>
<subSubSection id="C18265170727FF88F7ECF3576C6A4B8F" pageId="11" pageNumber="244" type="synonymic_list">
<caption id="DDE766140727FF88F7ECF3576C6A4B8F" ID-DOI="http://doi.org/10.5281/zenodo.6603857" ID-Zenodo-Dep="6603857" httpUri="https://zenodo.org/record/6603857/files/figure.png" inLine="true" pageId="11" pageNumber="244" targetBox="[1464,2054,3016,3428]" targetPageId="11">
<paragraph id="8927369C0727FF88F7ECF35762A04AC9" blockId="11.[2078,2671,3009,3431]" box="[2079,2479,3246,3275]" pageId="11" pageNumber="244">
<emphasis id="BBECEA8E0727FF88F7ECF35762A04AC9" bold="true" box="[2079,2479,3246,3275]" pageId="11" pageNumber="244">Subspecies and Distribution.</emphasis>
</paragraph>
<paragraph id="8927369C0727FF88F7D1F320614F4B1B" blockId="11.[2078,2671,3009,3431]" pageId="11" pageNumber="244">
<taxonomicName id="4E984D1F0727FF88F7D1F320628C4AF0" authority="Baird, 1855" authorityName="Baird" authorityYear="1855" box="[2082,2435,3289,3314]" class="Mammalia" family="Geomyidae" genus="Geomys" kingdom="Animalia" order="Rodentia" pageId="11" pageNumber="244" phylum="Chordata" rank="subSpecies" species="breviceps" subSpecies="breviceps">G.b.brevicepsBaird,1855—NCLouisiana(MerRouge,MorehouseParish),USA.</taxonomicName>
</paragraph>
<paragraph id="8927369C0727FF88F7D2F2E66C6A4B8F" blockId="11.[2078,2671,3009,3431]" lastBlockId="11.[1466,1893,3444,3469]" pageId="11" pageNumber="244">
<taxonomicName id="4E984D1F0727FF88F7D2F2E662A34B42" authority="Merriam, 1895" authorityName="Merriam" authorityYear="1895" box="[2081,2476,3359,3392]" class="Mammalia" family="Geomyidae" genus="Geomys" kingdom="Animalia" order="Rodentia" pageId="11" pageNumber="244" phylum="Chordata" rank="subSpecies" species="breviceps" subSpecies="sagittalis">G. b. sagittalis Merriam, 1895</taxonomicName>
— SE Oklahoma, SW Arkansas, E Texas (E of the Brazos River), and W Louisiana, USA.
</paragraph>
