<subSubSection id="B339FBDFC0030E5596B54FEB4555EDE3" pageId="null" pageNumber="95" type="vernacular_names">
<paragraph id="0E2A608297C4988BB00CEBE0DECC08E5" pageId="null" pageNumber="95">Marum-Gamander, Amberkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="1A99C88473E8FAEF9981EBD5F7482C28" pageId="null" pageNumber="95" type="description">
<paragraph id="4A4A0EB15C1B98A67CB7A8E90910672F" pageId="null" pageNumber="95">
Ausdauernd, mit 
<emphasis id="E798C3F7B8BE3A3CCEBD143D28E4E390" italics="true" pageId="null" pageNumber="95">
in der ganzen 
<normalizedToken id="7F22F9358BCB49152246F69C564BEB80" originalValue="Länge" pageId="null" pageNumber="95">Laenge</normalizedToken>
verholzten, verzweigten, niederliegenden, kurz und anliegend filzig behaarten Stengeln; Zweige aufrecht
</emphasis>
, 10-50 cm hoch; mit intensivem Geruch. 
<emphasis id="1C410CC583BA7E4228AA1365E9256D06" italics="true" pageId="null" pageNumber="95">
<normalizedToken id="A4180A532F55D953C23FC56B9936635E" originalValue="Blätter" pageId="null" pageNumber="95">Blaetter</normalizedToken>
oval bis lanzettlich, 0,5
</emphasis>
- 
<emphasis id="6E849DEABEBF0FAAC5CC02D9D563706A" italics="true" pageId="null" pageNumber="95">1 cm lang und 0,3</emphasis>
- 
<emphasis id="373A155B4B1C49679629935541DA9841" italics="true" pageId="null" pageNumber="95">0,7 cm breit, ganzrandig</emphasis>
, mit nach unten eingerolltem Rand, 
<emphasis id="A4D66D5D93A8ED0EB452A9E23D6B8123" italics="true" pageId="null" pageNumber="95">
<normalizedToken id="EEB6F2077C196F533B6F024C3FB1D272" originalValue="immergrün" pageId="null" pageNumber="95">immergruen</normalizedToken>
</emphasis>
, lederig, oberseits zerstreut behaart, 
<emphasis id="9DCB8C895DA998CE9BB01816BAEA4D7B" italics="true" pageId="null" pageNumber="95">
unterseits dicht 
<normalizedToken id="FFD1724469227783F7EF0B37ED950320" originalValue="weißfilzig" pageId="null" pageNumber="95">weissfilzig</normalizedToken>
behaart
</emphasis>
. 
<normalizedToken id="A7988BA1EDBE3E6341704D16B92B99BC" originalValue="Blüten" pageId="null" pageNumber="95">Blueten</normalizedToken>
zu 1-2 in den Achseln von 
<normalizedToken id="4040935455C5A94E8C483EA02492EEC5" originalValue="Blättern" pageId="null" pageNumber="95">Blaettern</normalizedToken>
, am Ende der Zweige 
<normalizedToken id="0C98A0DA0F3018371E307E63AA2A8015" originalValue="ährenartig" pageId="null" pageNumber="95">aehrenartig</normalizedToken>
<normalizedToken id="A7088B6363BB786868D2C3FED27BF0CB" originalValue="gehäuft" pageId="null" pageNumber="95">gehaeuft</normalizedToken>
. 
<normalizedToken id="F9B7548B79333F0777D9CC63E5FAAE3F" originalValue="Blütenstiel" pageId="null" pageNumber="95">Bluetenstiel</normalizedToken>
bedeutend 
<normalizedToken id="F1C594734FE82C675A4F08ACB15F3171" originalValue="kürzer" pageId="null" pageNumber="95">kuerzer</normalizedToken>
als der Kelch. Kelch etwa 6 mm lang, fast 
<normalizedToken id="23DCB3319A8F4BBFB60D7785718399E9" originalValue="regelmäßig" pageId="null" pageNumber="95">regelmaessig</normalizedToken>
5 
<normalizedToken id="736A95B0B7F6A74603514F78FCCB66FC" originalValue="zähnig" pageId="null" pageNumber="95">zaehnig</normalizedToken>
; 
<normalizedToken id="D1404657EC6474E5E5C0E686298CE4E4" originalValue="Zähne" pageId="null" pageNumber="95">Zaehne</normalizedToken>
3eckig, kurz zugespitzt. Krone 1-1,5 cm lang, 
<emphasis id="51740C2F357E13ECB75491E641E77B23" italics="true" pageId="null" pageNumber="95">purpurn</emphasis>
. 
<normalizedToken id="2BBA555BB9011080A1110EDF0F216A18" originalValue="Teilfrüchte" pageId="null" pageNumber="95">Teilfruechte</normalizedToken>
1,5-2 mm lang und fast so dick, grubig, 
<emphasis id="B492D405DBC985B58C836405A75FADC7" italics="true" pageId="null" pageNumber="95">behaart</emphasis>
. - 
<normalizedToken id="01042F2783CCA383D0481056B24BAC39" originalValue="Blüte" pageId="null" pageNumber="95">Bluete</normalizedToken>
: 
<normalizedToken id="B1C2B2CCE525D206B940CBFA4A230DEC" originalValue="Später" pageId="null" pageNumber="95">Spaeter</normalizedToken>
<normalizedToken id="55ED7DB97F40E7C3F91914AFF8169F43" originalValue="Frühling" pageId="null" pageNumber="95">Fruehling</normalizedToken>
und Sommer.
</paragraph>
<paragraph id="F0DBC4869CCB2CDE92553E1C8C0261F0" pageId="null" pageNumber="95">
<emphasis id="7185E4A4BDFF716D110AC489B8F505B7" italics="true" pageId="null" pageNumber="95">Zytologische Angaben</emphasis>
. Keine Untersuchungen.
</paragraph>
<paragraph id="55972BE6D25D516EBEDE2EC9710AD814" pageId="null" pageNumber="95">
<emphasis id="45386B650BF9DCF9081CE253F472DAA0" italics="true" pageId="null" pageNumber="95">Standort</emphasis>
. Kollin. Warme, steinige, trockene Orte.
</paragraph>
<paragraph id="3006A6FD63F23FB476E1EACA68CE183A" pageId="null" pageNumber="95">
<emphasis id="56E074A39CA5AEAF809FDC7497348155" italics="true" pageId="null" pageNumber="95">
Verbreitung. 
<normalizedToken id="B979E94FABBED81DE1A3A76D206F8FEF" originalValue="Südeuropäische" pageId="null" pageNumber="95">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Mittelmeerinseln, 
<normalizedToken id="91CB4354FB4B4CA4693A6789105DB409" originalValue="Südspanien" pageId="null" pageNumber="95">Suedspanien</normalizedToken>
, 
<normalizedToken id="E2E5DC42DE48DE25E8ABFB363A8611B9" originalValue="Süditalien" pageId="null" pageNumber="95">Sueditalien</normalizedToken>
, Dalmatien; sonst oft kultiviert und gelegentlich verwildert. - Im Gebiet nicht einheimisch, aber gelegentlich als Arzneipflanze kultiviert und verwildert (
<normalizedToken id="A3B34EC2EA6FBC416E2D71D033376A17" originalValue="Borromäische" pageId="null" pageNumber="95">Borromaeische</normalizedToken>
Inseln und 
<normalizedToken id="B9B226FBA6362B00147B303B09D920A8" originalValue="früher" pageId="null" pageNumber="95">frueher</normalizedToken>
bei Gandria).
</paragraph>
</subSubSection>
