<taxonomicName id="4C4E4D47FFD481096991FE0BFD19FDE9" authority="Cockerell, 1915: 475" authorityName="Cockerell" authorityPageNumber="475" authorityYear="1915" box="[204,641,492,519]" class="Insecta" genus="Nematophlebia" kingdom="Animalia" order="Megaloptera" pageId="58" pageNumber="59" phylum="Arthropoda" rank="genus">
