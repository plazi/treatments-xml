<taxonomicName id="4C4E4D47FFD481096A63FE0BFAD0FDE8" authority="Cockerell, 1915: 476" authorityName="Cockerell" authorityPageNumber="476" authorityYear="1915" box="[830,1352,492,519]" class="Insecta" genus="Nematophlebia" kingdom="Animalia" order="Megaloptera" pageId="58" pageNumber="59" phylum="Arthropoda" rank="species" species="plicata">
