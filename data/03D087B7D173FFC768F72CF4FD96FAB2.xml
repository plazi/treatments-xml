<paragraph id="8BC636A1D172FFC068FF2CD7FB4CF920" blockId="3.[174,1233,1702,1751]" pageId="3" pageNumber="422">
Рис. 1. 
<taxonomicName id="4C794D22D172FFC068AA2CD6FE16F94B" baseAuthorityName="Alekseev" baseAuthorityYear="1924" box="[251,465,1703,1724]" class="Mammalia" family="Phocidae" genus="Pontophoca" higherTaxonomySource="GBIF" kingdom="Animalia" order="Carnivora" pageId="3" pageNumber="422" phylum="Chordata" rank="species" species="sarmatica">
