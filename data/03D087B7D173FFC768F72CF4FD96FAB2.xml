<caption id="DF066629D172FFC068FF2C37FCB9F8C0" ID-DOI="http://doi.org/10.5281/zenodo.6462209" ID-Zenodo-Dep="6462209" httpUri="https://zenodo.org/record/6462209/files/figure.png" pageId="3" pageNumber="422" startId="3.[174,207,1606,1628]" targetBox="[266,1108,994,1488]" targetPageId="3">
