<subSubSection id="F940C0953C92D5D8AF3015F2410251F4" pageId="null" pageNumber="631" type="description">
<paragraph id="1E65A61B7FC1470477353D32F000273A" pageId="null" pageNumber="631">
Knollen kugelig bis 
<normalizedToken id="34D4940DC0F5F248B8AE437BF04BA7D4" originalValue="eiförmig" pageId="null" pageNumber="631">eifoermig</normalizedToken>
. Stengel 15-40 cm hoch, 
<emphasis id="8CB664D3F801F5A63A370B9771509A8D" italics="true" pageId="null" pageNumber="631">unter der Mitte mit 3-5 lang ovalen, 5-15 cm langen, 2</emphasis>
<normalizedToken id="A04FA031A5A131963F953C2979ECCCAB" originalValue="½" pageId="null" pageNumber="631">1/2</normalizedToken>
- 
<emphasis id="633FD6A7D9AA759C3A0512C545CAE1D0" italics="true" pageId="null" pageNumber="631">4</emphasis>
<normalizedToken id="56143AC8C7402B1F21E8A996A50E8848" originalValue="½" pageId="null" pageNumber="631">1/2</normalizedToken>
<emphasis id="4C13013EA00EDCFE1C4FE0536D0FA567" italics="true" pageId="null" pageNumber="631">mal so langen wie breiten</emphasis>
(
<normalizedToken id="E45AC249D4C09683163DAF7981D02DBB" originalValue="größte" pageId="null" pageNumber="631">groesste</normalizedToken>
Breite in oder 
<normalizedToken id="F2DFD1EFA638F8B8AE9BCB2161724527" originalValue="über" pageId="null" pageNumber="631">ueber</normalizedToken>
der Mitte), 
<emphasis id="78D54632282C11441F3320E363ECF342" italics="true" pageId="null" pageNumber="631">
stumpfen 
<normalizedToken id="57772CF073397247D438EA8B12A1307E" originalValue="Blättern" pageId="null" pageNumber="631">Blaettern</normalizedToken>
.
</emphasis>
<normalizedToken id="9B604552C998C6E6091FC5A914B550F2" originalValue="Blütenstand" pageId="null" pageNumber="631">Bluetenstand</normalizedToken>
<normalizedToken id="19D16AEDDEF8247C10E27E3A2E33D9DC" originalValue="eiförmig" pageId="null" pageNumber="631">eifoermig</normalizedToken>
bis zylindrisch, 4-10 cm lang, 
<emphasis id="1C97C2EE4929A497E6E500E7B9669F22" italics="true" pageId="null" pageNumber="631">
<normalizedToken id="047BA6015CA66846451737A4D2FA9E6A" originalValue="vielblütig" pageId="null" pageNumber="631">vielbluetig</normalizedToken>
</emphasis>
(meist 
<normalizedToken id="1D6033C95D240155C30D69AE2AC16DA1" originalValue="über" pageId="null" pageNumber="631">ueber</normalizedToken>
10 
<normalizedToken id="5A827712F7B3627C712816260C333AF7" originalValue="Blüten" pageId="null" pageNumber="631">Blueten</normalizedToken>
) 
<emphasis id="54710418711AE3A1FA0C26D4BB094CAC" italics="true" pageId="null" pageNumber="631">
und ziemlich 
<normalizedToken id="ADCC0491D06E9BAE93F7C6C9B185A738" originalValue="dichtblütig" pageId="null" pageNumber="631">dichtbluetig</normalizedToken>
.
</emphasis>
<normalizedToken id="F6C3B74F93284DA9F2BA1EE9A74B00A8" originalValue="Tragblätter" pageId="null" pageNumber="631">Tragblaetter</normalizedToken>
<normalizedToken id="42EB83A325236AF7FA6AB8A388D9703E" originalValue="häutig" pageId="null" pageNumber="631">haeutig</normalizedToken>
, durchscheinend, 
<normalizedToken id="E7FAE2E06C4739062A024D4BB10059A1" originalValue="allmählich" pageId="null" pageNumber="631">allmaehlich</normalizedToken>
und fein zugespitzt, so lang oder 
<normalizedToken id="475C8CA734DCFCD3949556E8C6FEEB3B" originalValue="länger" pageId="null" pageNumber="631">laenger</normalizedToken>
als der Fruchtknoten. 
<emphasis id="17C784CF30B22AEDC6C5CD689CFC278C" italics="true" pageId="null" pageNumber="631">
<normalizedToken id="5F40E42188AEFEFE259819924C2AD986" originalValue="Blüten" pageId="null" pageNumber="631">Blueten</normalizedToken>
hellgelb;
</emphasis>
die beiden seitlichen, 
<normalizedToken id="31327733B55E89F52AEF6D1B94B6044E" originalValue="äußern" pageId="null" pageNumber="631">aeussern</normalizedToken>
<normalizedToken id="4F87991370A03A55632A5DB9394A56E2" originalValue="Perigonblätter" pageId="null" pageNumber="631">Perigonblaetter</normalizedToken>
abstehend oder 
<normalizedToken id="00E8019D178C1E5236C2D72EA6E4EC87" originalValue="zurückgebogen" pageId="null" pageNumber="631">zurueckgebogen</normalizedToken>
, die 3 
<normalizedToken id="C99299A7C120A3B259E43683BB252B09" originalValue="übrigen" pageId="null" pageNumber="631">uebrigen</normalizedToken>
zusammenneigend, oval, 6-10 mm lang, etwa doppelt so lang wie breit, die 
<normalizedToken id="376DC958A367659D3356A706E469E01F" originalValue="äußern" pageId="null" pageNumber="631">aeussern</normalizedToken>
wenig 
<normalizedToken id="9D421F531E10ACDBAB33A7C02855D783" originalValue="länger" pageId="null" pageNumber="631">laenger</normalizedToken>
als die innern, stumpf, konkav; Lippe etwa so lang wie die 
<normalizedToken id="6C4CA19BE6BBA31F9947F66CD698039A" originalValue="äußern" pageId="null" pageNumber="631">aeussern</normalizedToken>
<normalizedToken id="D681934D6066DE6A7A0AFB2CCF17FAB3" originalValue="Perigonblätter" pageId="null" pageNumber="631">Perigonblaetter</normalizedToken>
, im 
<normalizedToken id="873CFC931CC2D59C289F36814BC9FB2F" originalValue="Umriß" pageId="null" pageNumber="631">Umriss</normalizedToken>
rundlich, nach oben konvex, durch 2 schmale, 1-2 mm tiefe Einschnitte 3teilig; Sporn 
<emphasis id="8B3FCC72E36003BE1B3E214B0FE8E134" italics="true" pageId="null" pageNumber="631">
<normalizedToken id="F42CFE595FFAFBA606F164CCB74878A1" originalValue="±" pageId="null" pageNumber="631">+/-</normalizedToken>
</emphasis>
gerade, stumpf, horizontal oder 
<normalizedToken id="5EDFC78AC64971EEDE9C4EF4A1FC5E75" originalValue="aufwärts" pageId="null" pageNumber="631">aufwaerts</normalizedToken>
gerichtet, 
<normalizedToken id="475872C84F204F72D8A3ED78A18F34DE" originalValue="ungefähr" pageId="null" pageNumber="631">ungefaehr</normalizedToken>
so lang wie der Fruchtknoten. - 
<normalizedToken id="001C3AED6FD932C085B148771E854599" originalValue="Blüte" pageId="null" pageNumber="631">Bluete</normalizedToken>
: 
<normalizedToken id="363C2739123063320A74CBACE5DDCE62" originalValue="Später" pageId="null" pageNumber="631">Spaeter</normalizedToken>
<normalizedToken id="2660A696E0231CA53D480B702FD21B9A" originalValue="Frühling" pageId="null" pageNumber="631">Fruehling</normalizedToken>
und 
<normalizedToken id="0A8D691EEC7E46F4C031B90EBA19455E" originalValue="früher" pageId="null" pageNumber="631">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="D38CC1909E1720BA2E97C8330140DBB6" pageId="null" pageNumber="631">
<emphasis id="F418AA8DC8EA20FF1DA07D65BE100EA2" italics="true" pageId="null" pageNumber="631">Zytologische Angaben. 2n = 40:</emphasis>
Material aus Herblingen (Schaffhausen) und vom rechten Ufer des Walensees (Heusser 1938).
</paragraph>
<paragraph id="DF3E65CD4D9E57C8FD265BE6CCFBE717" pageId="null" pageNumber="631">
<emphasis id="DEA18D9F6D1CE1BDDE9DAF618F01F64A" italics="true" pageId="null" pageNumber="631">Standort.</emphasis>
Kollin und montan, selten subalpin. Stets kalkhaltige, humose, feinerdenreiche 
<normalizedToken id="107E5B5E3B419750C667BC3DA49B78C5" originalValue="Böden" pageId="null" pageNumber="631">Boeden</normalizedToken>
. Lichte 
<normalizedToken id="B0ACD7BF40DAFC24736E778A9C844B33" originalValue="Laubmischwälder" pageId="null" pageNumber="631">Laubmischwaelder</normalizedToken>
und 
<normalizedToken id="4AE9A4106A6C9794780005D1D18E36DB" originalValue="Gebüsche" pageId="null" pageNumber="631">Gebuesche</normalizedToken>
, besonders in warmen Gegenden mit mildem Klima.
</paragraph>
<paragraph id="18400DD9D6784BA11647264A3BBC0C32" pageId="null" pageNumber="631">
<emphasis id="944B286FF342F3A591D01E2B6A5CBA01" italics="true" pageId="null" pageNumber="631">
Verbreitung. 
<normalizedToken id="4A9EBA6DA14D908C8F08AE2935E5100B" originalValue="Südeuropäische" pageId="null" pageNumber="631">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Nordgrenze durch 
<normalizedToken id="F7AEE727BD038C7AA89E1A60F9B92426" originalValue="Dép" pageId="null" pageNumber="631">Dep</normalizedToken>
. Var, Westalpen, 
<normalizedToken id="5BE79E84874C2C1C9A27531F4F306134" originalValue="Elsaß" pageId="null" pageNumber="631">Elsass</normalizedToken>
, Pfalz, 
<normalizedToken id="8ADE07D3E20818073E83DB66546E1F80" originalValue="Thüringen" pageId="null" pageNumber="631">Thueringen</normalizedToken>
, Salzburg, Wiener Becken, 
<normalizedToken id="13BC4E8E3AA504E427D5201382F94653" originalValue="Siebenbürgen" pageId="null" pageNumber="631">Siebenbuergen</normalizedToken>
, Krim, 
<normalizedToken id="1B5F72234A53E556C60A90FAFB16DED4" originalValue="ostwärts" pageId="null" pageNumber="631">ostwaerts</normalizedToken>
bis Kaukasus; 
<normalizedToken id="63CCFC208882BCCAE854F378F24DB089" originalValue="Südgrenze" pageId="null" pageNumber="631">Suedgrenze</normalizedToken>
durch 
<normalizedToken id="47DCCA7449B51EA8E4FC1434A4B1F7FD" originalValue="Pyrenäen" pageId="null" pageNumber="631">Pyrenaeen</normalizedToken>
, Korsika, 
<normalizedToken id="E55E6D9509D4A18FDA813416C1C30878" originalValue="Süditalien" pageId="null" pageNumber="631">Sueditalien</normalizedToken>
, Kreta, Kleinasien. - Im Gebiet: 
<normalizedToken id="0B02F4BF4E83129A4BE54ABFCF0731B8" originalValue="Elsaß" pageId="null" pageNumber="631">Elsass</normalizedToken>
, Wiesental bei Basel, Schaffhausen (viele Fundstellen) und angrenzende deutsche Gebiete, Jura (Mont Grelle im Savoyer Jura, Grand-Colombier im 
<normalizedToken id="02C76499E33300D2D1927EEE63AC9318" originalValue="Dép" pageId="null" pageNumber="631">Dep</normalizedToken>
. Ain, Solothurner, Basler und Aargauer Jura [sehr selten]), Alpengebiet (besonders Zentral- und 
<normalizedToken id="FCD47EF8EDE34D4AB74C03B071DE9DB2" originalValue="Südalpen" pageId="null" pageNumber="631">Suedalpen</normalizedToken>
); selten.
</paragraph>
</subSubSection>
