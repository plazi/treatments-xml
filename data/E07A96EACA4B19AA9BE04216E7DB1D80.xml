Blasse 
<taxonomicName id="11BABABA54A98AB3CCEB2BB6B30BC0FB" class="Liliopsida" family="Orchidaceae" genus="Orchis" kingdom="Plantae" order="Asparagales" pageId="null" pageNumber="631" phylum="Tracheophyta" rank="genus">Orchis</taxonomicName>
