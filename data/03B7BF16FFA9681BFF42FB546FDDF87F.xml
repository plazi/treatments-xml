<taxonomicName id="4C1E7583FFA9681BFC1CF85E6FDDF818" authority="Jakovlev, 1880" authorityName="Jakovlev" authorityYear="1880" box="[969,1436,1930,1952]" class="Insecta" family="Aradidae" genus="Aneurus" kingdom="Animalia" order="Hemiptera" pageId="7" pageNumber="392" phylum="Arthropoda" rank="species" species="macrotylus" subGenus="Neaneurus">
