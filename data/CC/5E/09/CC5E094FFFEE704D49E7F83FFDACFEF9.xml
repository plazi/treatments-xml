(Honshu, Shikoku) (
<bibRefCitation author="Yukawa, J. &amp; Masuda, H." box="[610,949,151,177]" pageId="25" pageNumber="26" refId="ref55993" refString="Yukawa, J. &amp; Masuda, H. (1996) Insect and mite galls of Japan in colors. Zenkoku-Nouson-Kyoukai, Tokyo, 826 pp. [in Japanese]" type="book" year="1996">Yukawa &amp; Masuda 1996: 122</bibRefCitation>
