<subSubSection pageId="13" pageNumber="14" type="biology_ecology">
<paragraph blockId="13.[151,1436,1585,1756]" pageId="13" pageNumber="14">
<emphasis bold="true" box="[199,295,1693,1719]" pageId="13" pageNumber="14">Biology.</emphasis>
<taxonomicName authorityName="Tang &amp; Melika" authorityYear="2011" box="[303,589,1693,1719]" class="Insecta" family="Cynipidae" genus="Andricus" kingdom="Animalia" order="Hymenoptera" pageId="13" pageNumber="14" phylum="Arthropoda" rank="species" species="pseudocurvator">
<emphasis box="[303,589,1693,1719]" italics="true" pageId="13" pageNumber="14">Andricus pseudocurvator</emphasis>
</taxonomicName>
induces galls on hosts in 
<taxonomicName box="[886,976,1693,1720]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="13" pageNumber="14" phylum="Tracheophyta" rank="species" species="fabri">
<emphasis box="[886,976,1693,1720]" italics="true" pageId="13" pageNumber="14">Q. fabri</emphasis>
</taxonomicName>
and 
<taxonomicName box="[1034,1150,1694,1720]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="13" pageNumber="14" phylum="Tracheophyta" rank="species" species="serrata">
<emphasis box="[1034,1150,1694,1720]" italics="true" pageId="13" pageNumber="14">Q. serrata</emphasis>
</taxonomicName>
(sect. 
<taxonomicName box="[1227,1321,1694,1720]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="13" pageNumber="14" phylum="Tracheophyta" rank="genus">
<emphasis box="[1227,1321,1694,1720]" italics="true" pageId="13" pageNumber="14">Quercus</emphasis>
</taxonomicName>
), forming integral leaf galls in the sexual generation and bud galls in the asexual generation (Table 1; 
<bibRefCitation author="Tang, C. - T. &amp; Melika, G. &amp; Yang, M. - M. &amp; Nicholls, J. A. &amp; Stone, G. N." box="[1175,1375,1729,1756]" pageId="13" pageNumber="14" pagination="37 - 52" refId="ref53727" refString="Tang, C. - T., Melika, G., Yang, M. - M., Nicholls, J. A. &amp; Stone, G. N. (2011 b) New species of oak gallwasps from Taiwan (Hymenoptera: Cynipidae: Cynipini). Zootaxa, 2865 (1), 37 - 52. https: // doi. org / 10.11646 / zootaxa. 2865.1.2" type="journal article" year="2011">
Tang 
<emphasis box="[1238,1287,1729,1755]" italics="true" pageId="13" pageNumber="14">et al</emphasis>
. 2011b
</bibRefCitation>
).
</paragraph>
