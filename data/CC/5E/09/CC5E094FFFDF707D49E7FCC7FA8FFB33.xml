<taxonomicName box="[593,749,1101,1128]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="41" pageNumber="42" phylum="Tracheophyta" rank="species" species="mongolica">
