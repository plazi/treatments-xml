<taxonomicName authorityName="Melika et al." authorityYear="2010" baseAuthorityName="Monzen" baseAuthorityYear="1953" class="Insecta" family="Cynipidae" genus="Trichagalma" kingdom="Animalia" order="Hymenoptera" pageId="41" pageNumber="42" phylum="Arthropoda" rank="species" species="acutissimae">
