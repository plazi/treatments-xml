<taxonomicName box="[1114,1301,854,880]" class="Magnoliopsida" family="Fagaceae" genus="Cyclobalanopsis" higherTaxonomySource="GBIF" kingdom="Plantae" order="Fagales" pageId="37" pageNumber="38" phylum="Tracheophyta" rank="genus">
