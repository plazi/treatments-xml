<subSubSection pageId="42" pageNumber="43" type="distribution">
<paragraph blockId="42.[151,1437,962,1133]" pageId="42" pageNumber="43">
<emphasis bold="true" box="[151,305,962,988]" pageId="42" pageNumber="43">Distribution.</emphasis>
Russian Far East and 
<collectingCountry box="[567,631,963,989]" name="Japan" pageId="42" pageNumber="43">Japan</collectingCountry>
(
<collectingRegion box="[648,762,963,989]" country="Japan" name="Hokkaido" pageId="42" pageNumber="43">Hokkaido</collectingRegion>
) (
<bibRefCitation author="Schweger, S. &amp; Melika, G. &amp; Tang, C. - T. &amp; Bihari, P. &amp; Bozso, M. &amp; Stone, G. N. &amp; Nicholls, J. A. &amp; Penzes, Z." box="[786,1162,962,989]" pageId="42" pageNumber="43" pagination="451 - 497" refId="ref52498" refString="Schweger, S., Melika, G., Tang, C. - T., Bihari, P., Bozso, M., Stone, G. N., Nicholls, J. A. &amp; Penzes, Z. (2015 a) New species of cynipid inquilines of the genus Synergus (Hymenoptera: Cynipidae: Synergini) from the Eastern Palaearctic. Zootaxa, 3999 (4), 451 - 497. https: // doi. org / 10.11646 / zootaxa. 3999.4.1" type="journal article" year="2015">
Schwéger 
<emphasis box="[908,960,963,989]" italics="true" pageId="42" pageNumber="43">et al</emphasis>
. 2015a: 478–479
</bibRefCitation>
, 482). Presumably, also from 
<collectingCountry box="[213,280,999,1025]" name="China" pageId="42" pageNumber="43">China</collectingCountry>
(
<collectingRegion box="[295,472,999,1025]" country="China" name="Hebei" pageId="42" pageNumber="43">Hebei Province</collectingRegion>
) in 
<taxonomicName authorityName="Yasumatsu &amp; Masuda" authorityYear="1955" baseAuthorityName="Mukaigawa" baseAuthorityYear="1913" box="[516,689,999,1025]" class="Insecta" family="Cynipidae" genus="Andricus" kingdom="Animalia" order="Hymenoptera" pageId="42" pageNumber="43" phylum="Arthropoda" rank="species" species="mukaigawae">
<emphasis box="[516,689,999,1025]" italics="true" pageId="42" pageNumber="43">A. mukaigawae</emphasis>
</taxonomicName>
ŏ (
<bibRefCitation author="Pujade-Villar, J. &amp; Wang, Y. &amp; Tang, G. &amp; Shen, J. &amp; Ferrer-Suay, M." box="[724,1062,999,1025]" pageId="42" pageNumber="43" pagination="17 - 24" refId="ref51876" refString="Pujade-Villar, J., Wang, Y., Tang, G., Shen, J. &amp; Ferrer-Suay, M. (2016 b) Andricus mukaigawae and Andricus kashiwaphilus from China with remarks of morphological differences and inquilines (Hymenoptera: Cynipidae). Butlleti de la Institucio Catalana d'Historia Natural, 80, 17 - 24." type="journal article" year="2016">
Pujade-Villar 
<emphasis box="[883,932,999,1025]" italics="true" pageId="42" pageNumber="43">et al</emphasis>
. 2016b: 19
</bibRefCitation>
), but this record needs to be confirmed.
</paragraph>
</subSubSection>
<subSubSection pageId="42" pageNumber="43" type="biology_ecology">
<paragraph blockId="42.[151,1437,962,1133]" pageId="42" pageNumber="43">
<emphasis bold="true" box="[199,295,1070,1096]" pageId="42" pageNumber="43">Biology.</emphasis>
Reared from galls of 
<taxonomicName baseAuthorityName="Abe" baseAuthorityYear="1998" box="[546,815,1071,1097]" class="Insecta" family="Cynipidae" genus="Andricus" kingdom="Animalia" order="Hymenoptera" pageId="42" pageNumber="43" phylum="Arthropoda" rank="species" species="kashiwaphilus">
<emphasis box="[546,815,1071,1097]" italics="true" pageId="42" pageNumber="43">Andricus kashiwaphilus</emphasis>
</taxonomicName>
ŏ, 
<taxonomicName authorityName="Yasumatsu &amp; Masuda" authorityYear="1955" baseAuthorityName="Mukaigawa" baseAuthorityYear="1913" box="[853,1027,1071,1097]" class="Insecta" family="Cynipidae" genus="Andricus" kingdom="Animalia" order="Hymenoptera" pageId="42" pageNumber="43" phylum="Arthropoda" rank="species" species="mukaigawae">
<emphasis box="[853,1027,1071,1097]" italics="true" pageId="42" pageNumber="43">A. mukaigawae</emphasis>
</taxonomicName>
ŏ, and undetermined acorn and bud galls on 
<taxonomicName box="[246,364,1107,1133]" class="Magnoliopsida" family="Fagaceae" genus="Castanea" kingdom="Plantae" order="Fagales" pageId="42" pageNumber="43" phylum="Tracheophyta" rank="species" species="dentata">
<emphasis box="[246,364,1107,1133]" italics="true" pageId="42" pageNumber="43">Q. dentata</emphasis>
</taxonomicName>
and 
<taxonomicName box="[419,571,1107,1133]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="42" pageNumber="43" phylum="Tracheophyta" rank="species" species="mongolica">
<emphasis box="[419,571,1107,1133]" italics="true" pageId="42" pageNumber="43">Q. mongolica</emphasis>
</taxonomicName>
(Table 2; 
<bibRefCitation author="Schweger, S. &amp; Melika, G. &amp; Tang, C. - T. &amp; Bihari, P. &amp; Bozso, M. &amp; Stone, G. N. &amp; Nicholls, J. A. &amp; Penzes, Z." box="[685,939,1106,1133]" pageId="42" pageNumber="43" pagination="451 - 497" refId="ref52498" refString="Schweger, S., Melika, G., Tang, C. - T., Bihari, P., Bozso, M., Stone, G. N., Nicholls, J. A. &amp; Penzes, Z. (2015 a) New species of cynipid inquilines of the genus Synergus (Hymenoptera: Cynipidae: Synergini) from the Eastern Palaearctic. Zootaxa, 3999 (4), 451 - 497. https: // doi. org / 10.11646 / zootaxa. 3999.4.1" type="journal article" year="2015">
Schwéger 
<emphasis box="[802,852,1107,1133]" italics="true" pageId="42" pageNumber="43">et al</emphasis>
. 2015a
</bibRefCitation>
).
</paragraph>
