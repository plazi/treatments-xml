<paragraph blockId="41.[151,1437,1630,2017]" pageId="41" pageNumber="42">
<emphasis bold="true" box="[199,315,1775,1801]" pageId="41" pageNumber="42">Remarks.</emphasis>
In 
<bibRefCitation author="Lobato-Vila, I. &amp; Wang, Y. &amp; Melika, G. &amp; Guo, R. &amp; Xiaoxue, J. &amp; Pujade-Villar, J." box="[352,646,1775,1801]" pageId="41" pageNumber="42" pagination="341 - 362" refId="ref46693" refString="Lobato-Vila, I., Wang, Y., Melika, G., Guo, R., Xiaoxue, J. &amp; Pujade-Villar, J. (2021 a) A review of the species in the genus Synergus Hartig (Hymenoptera: Cynipidae: Synergini) from mainland China, with an updated key to Eastern Palaearctic and Oriental species. Journal of Asia-Pacific Entomology, 24 (1), 341 - 362. https: // doi. org / 10.1016 / j. aspen. 2020.11.014" type="journal article" year="2021">
Lobato-Vila 
<emphasis box="[494,543,1775,1801]" italics="true" pageId="41" pageNumber="42">et al</emphasis>
. (2021a)
</bibRefCitation>
, new material of 
<taxonomicName authorityName="Walker" authorityYear="1874" box="[840,977,1775,1801]" class="Insecta" family="Cynipidae" genus="Synergus" kingdom="Animalia" order="Hymenoptera" pageId="41" pageNumber="42" phylum="Arthropoda" rank="species" species="japonicus">
<emphasis box="[840,977,1775,1801]" italics="true" pageId="41" pageNumber="42">S. japonicus</emphasis>
</taxonomicName>
from 
<collectingCountry box="[1045,1112,1775,1801]" name="China" pageId="41" pageNumber="42">China</collectingCountry>
was identified as originating from galls of 
<taxonomicName authorityName="Yasumatsu &amp; Masuda" authorityYear="1955" baseAuthorityName="Mukaigawa" baseAuthorityYear="1913" box="[303,553,1811,1837]" class="Insecta" family="Cynipidae" genus="Andricus" kingdom="Animalia" order="Hymenoptera" pageId="41" pageNumber="42" phylum="Arthropoda" rank="species" species="mukaigawae">
<emphasis box="[303,553,1811,1837]" italics="true" pageId="41" pageNumber="42">Andricus mukaigawae</emphasis>
</taxonomicName>
on 
<taxonomicName box="[595,683,1811,1837]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="41" pageNumber="42" phylum="Tracheophyta" rank="species" species="fabri">
<emphasis box="[595,683,1811,1837]" italics="true" pageId="41" pageNumber="42">Q. fabri</emphasis>
</taxonomicName>
(sect. 
<taxonomicName box="[757,851,1811,1837]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="41" pageNumber="42" phylum="Tracheophyta" rank="genus">
<emphasis box="[757,851,1811,1837]" italics="true" pageId="41" pageNumber="42">Quercus</emphasis>
</taxonomicName>
). According to 
<bibRefCitation author="Penzes, Z. &amp; Tang, C. - T. &amp; Stone, G. N. &amp; Nicholls, J. A. &amp; Schweger, S. &amp; Bozso, M. &amp; Melika, G." box="[1027,1252,1811,1837]" pageId="41" pageNumber="42" pagination="245 - 289" refId="ref49925" refString="Penzes, Z., Tang, C. - T., Stone, G. N., Nicholls, J. A., Schweger, S., Bozso, M. &amp; Melika, G. (2018) Current status of the oak gallwasp (Hymenoptera: Cynipidae: Cynipini) fauna of the Eastern Palaearctic and Oriental Regions. Zootaxa, 4433 (2), 245 - 289. https: // doi. org / 10.11646 / zootaxa. 4433.2.2" type="journal article" year="2018">
Pénzes 
<emphasis box="[1112,1161,1811,1837]" italics="true" pageId="41" pageNumber="42">et al</emphasis>
. (2018)
</bibRefCitation>
, 
<taxonomicName authorityName="Yasumatsu &amp; Masuda" authorityYear="1955" baseAuthorityName="Mukaigawa" baseAuthorityYear="1913" box="[1264,1437,1811,1837]" class="Insecta" family="Cynipidae" genus="Andricus" kingdom="Animalia" order="Hymenoptera" pageId="41" pageNumber="42" phylum="Arthropoda" rank="species" species="mukaigawae">
<emphasis box="[1264,1437,1811,1837]" italics="true" pageId="41" pageNumber="42">A. mukaigawae</emphasis>
</taxonomicName>
is found on 
<emphasis box="[283,519,1847,1873]" italics="true" pageId="41" pageNumber="42">
<taxonomicName box="[283,390,1847,1873]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="41" pageNumber="42" phylum="Tracheophyta" rank="species" species="aliena">Q. aliena</taxonomicName>
, 
<taxonomicName box="[401,519,1847,1873]" class="Magnoliopsida" family="Fagaceae" genus="Castanea" kingdom="Plantae" order="Fagales" pageId="41" pageNumber="42" phylum="Tracheophyta" rank="species" species="dentata">Q. dentata</taxonomicName>
</emphasis>
, 
<taxonomicName box="[533,660,1847,1873]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="41" pageNumber="42" phylum="Tracheophyta" rank="species" species="griffithii">
<emphasis box="[533,660,1847,1873]" italics="true" pageId="41" pageNumber="42">Q. griffithii</emphasis>
</taxonomicName>
, 
<taxonomicName box="[674,1035,1847,1873]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="41" pageNumber="42" phylum="Tracheophyta" rank="variety" species="mongolica" variety="grasseserrata">
<emphasis box="[674,826,1847,1873]" italics="true" pageId="41" pageNumber="42">Q. mongolica</emphasis>
var. 
<emphasis box="[881,1035,1847,1872]" italics="true" pageId="41" pageNumber="42">grasseserrata</emphasis>
</taxonomicName>
, and 
<taxonomicName box="[1095,1210,1847,1873]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="41" pageNumber="42" phylum="Tracheophyta" rank="species" species="serrata">
<emphasis box="[1095,1210,1847,1873]" italics="true" pageId="41" pageNumber="42">Q. serrata</emphasis>
</taxonomicName>
(sect. 
<taxonomicName box="[1284,1378,1847,1873]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="41" pageNumber="42" phylum="Tracheophyta" rank="genus">
<emphasis box="[1284,1378,1847,1873]" italics="true" pageId="41" pageNumber="42">Quercus</emphasis>
</taxonomicName>
), but not on 
<taxonomicName box="[229,317,1883,1909]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="41" pageNumber="42" phylum="Tracheophyta" rank="species" species="fabri">
<emphasis box="[229,317,1883,1909]" italics="true" pageId="41" pageNumber="42">Q. fabri</emphasis>
</taxonomicName>
.
</paragraph>
