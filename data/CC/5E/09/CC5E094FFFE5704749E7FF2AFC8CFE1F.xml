<taxonomicName box="[1143,1252,361,387]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="19" pageNumber="20" phylum="Tracheophyta" rank="species" species="glauca">
<emphasis box="[1143,1252,361,387]" italics="true" pageId="19" pageNumber="20">Q. glauca</emphasis>
</taxonomicName>
(sect. 
<taxonomicName class="Magnoliopsida" family="Fagaceae" genus="Cyclobalanopsis" higherTaxonomySource="GBIF" kingdom="Plantae" order="Fagales" pageId="19" pageNumber="20" phylum="Tracheophyta" rank="genus">
<emphasis italics="true" pageId="19" pageNumber="20">Cyclobalanopsis</emphasis>
</taxonomicName>
) (Table 1; 
<bibRefCitation author="Yukawa, J. &amp; Masuda, H." box="[359,640,397,423]" pageId="19" pageNumber="20" refId="ref55993" refString="Yukawa, J. &amp; Masuda, H. (1996) Insect and mite galls of Japan in colors. Zenkoku-Nouson-Kyoukai, Tokyo, 826 pp. [in Japanese]" type="book" year="1996">Yukawa &amp; Masuda 1996</bibRefCitation>
