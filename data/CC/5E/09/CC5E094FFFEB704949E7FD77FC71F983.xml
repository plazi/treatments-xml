<subSubSection pageId="29" pageNumber="30" type="distribution">
<paragraph blockId="29.[151,1437,849,1595]" pageId="29" pageNumber="30">
<emphasis bold="true" box="[151,305,849,875]" pageId="29" pageNumber="30">Distribution.</emphasis>
<collectingCountry box="[314,378,849,875]" name="Japan" pageId="29" pageNumber="30">Japan</collectingCountry>
(Honshu, Kyushu, Shikoku) (
<bibRefCitation author="Mukaigawa, Y." box="[722,984,849,875]" pageId="29" pageNumber="30" pagination="485 - 488" refId="ref48757" refString="Mukaigawa, Y. (1914) Study on life history of Cynipidae. Insect World, 18, 485 - 488 + 1 plate. [in Japanese]" type="book chapter" year="1914">Mukaigawa 1914: 487</bibRefCitation>
; 
<bibRefCitation author="Mukaigawa, Y." box="[998,1257,849,875]" pageId="29" pageNumber="30" pagination="203 - 208" refId="ref48843" refString="Mukaigawa, Y. (1922) Mie-Ken san Fashibachi (Cynipidae) no Kenkyu. Dobuts. Zasshi, 34, 203 - 208, 1 pl. [in Japanese] https: // doi. org / 10.5026 / jgeography. 34.203" type="journal article" year="1922">Mukaigawa 1922: 203</bibRefCitation>
; 
<bibRefCitation author="Monzen, K." pageId="29" pageNumber="30" pagination="295 - 368" refId="ref48447" refString="Monzen, K. (1929) Studies on galls. Saito-hoonkai-jigyo-nenpo, 5, 295 - 368 + 20. [in Japanese]" type="journal article" year="1929">Monzen 1929: 349</bibRefCitation>
; 
<bibRefCitation author="Shinji, O." box="[208,381,885,911]" pageId="29" pageNumber="30" refId="ref52964" refString="Shinji, O. (1944) Galls and gall insects. Shunyo-do, Tokyo, 580 pp. [in Japanese]" type="book" year="1944">Shinji 1944: 67</bibRefCitation>
(photo 113); 
<bibRefCitation author="Yukawa, J. &amp; Masuda, H." box="[532,869,885,911]" pageId="29" pageNumber="30" refId="ref55993" refString="Yukawa, J. &amp; Masuda, H. (1996) Insect and mite galls of Japan in colors. Zenkoku-Nouson-Kyoukai, Tokyo, 826 pp. [in Japanese]" type="book" year="1996">Yukawa &amp; Masuda 1996: 133</bibRefCitation>
, 134; 
<bibRefCitation author="Ide, T. &amp; Abe, Y." box="[937,1176,885,912]" pageId="29" pageNumber="30" pagination="467 - 480" refId="ref44370" refString="Ide, T. &amp; Abe, Y. (2015) A new species of Dryocosmus Giraud (Hymenoptera: Cynipidae: Cynipini) in Japan and Korea - First record of Eastern Palearctic Dryocosmus species showing alternation of generations on section Cerris oaks. Proceedings of the Entomological Society of Washington, 117 (4), 467 - 480. https: // doi. org / 10.4289 / 0013 - 8797.117.4.467" type="journal article" year="2015">Ide &amp; Abe 2015: 476</bibRefCitation>
) and Korean Peninsula (
<bibRefCitation author="Saito, K." box="[159,341,921,947]" pageId="29" pageNumber="30" pagination="93 - 107" refId="ref52399" refString="Saito, K. (1932) Studies of the galls in Corea [sic]. Bulletin of the Scientific Researches of the Alumni Association of the Morioka College of Agriculture and Forestry, 7, 93 - 107." type="journal article" year="1932">Saito 1932: 101</bibRefCitation>
; 
<bibRefCitation author="Yukawa, J. &amp; Masuda, H." box="[352,688,921,947]" pageId="29" pageNumber="30" refId="ref55993" refString="Yukawa, J. &amp; Masuda, H. (1996) Insect and mite galls of Japan in colors. Zenkoku-Nouson-Kyoukai, Tokyo, 826 pp. [in Japanese]" type="book" year="1996">Yukawa &amp; Masuda 1996: 133</bibRefCitation>
, 134; 
<bibRefCitation author="Pujade-Villar, J. &amp; Kang, M. &amp; Bae, J. &amp; Wang, Y. &amp; Guo, R. &amp; Roca-Cusachs, M. &amp; Jung, S." box="[757,1119,921,948]" pageId="29" pageNumber="30" pagination="1208 - 1221" refId="ref50634" refString="Pujade-Villar, J., Kang, M., Bae, J., Wang, Y., Guo, R., Roca-Cusachs, M. &amp; Jung, S. (2020 a) Current state of knowledge of the Korean Cynipini: Subspecies description, new combinations and checklist (Hymenoptera, Cynipidae). Journal of AsiaPacific Entomology, 23 (4), 1208 - 1221. https: // doi. org / 10.1016 / j. aspen. 2020.08.012" type="journal article" year="2020">
Pujade-Villar 
<emphasis box="[913,962,921,947]" italics="true" pageId="29" pageNumber="30">et al</emphasis>
. 2020a: 1215
</bibRefCitation>
).
</paragraph>
</subSubSection>
<subSubSection pageId="29" pageNumber="30" type="discussion">
<paragraph blockId="29.[151,1437,849,1595]" pageId="29" pageNumber="30">
<emphasis bold="true" box="[199,315,957,983]" pageId="29" pageNumber="30">Remarks.</emphasis>
The alternating lifecycle was reported by 
<bibRefCitation author="Mukaigawa, Y." box="[802,1018,957,983]" pageId="29" pageNumber="30" pagination="485 - 488" refId="ref48757" refString="Mukaigawa, Y. (1914) Study on life history of Cynipidae. Insect World, 18, 485 - 488 + 1 plate. [in Japanese]" type="book chapter" year="1914">Mukaigawa (1914)</bibRefCitation>
and 
<bibRefCitation author="Yukawa, J. &amp; Masuda, H." box="[1075,1380,957,983]" pageId="29" pageNumber="30" refId="ref55993" refString="Yukawa, J. &amp; Masuda, H. (1996) Insect and mite galls of Japan in colors. Zenkoku-Nouson-Kyoukai, Tokyo, 826 pp. [in Japanese]" type="book" year="1996">Yukawa &amp; Masuda (1996)</bibRefCitation>
. The sexual and asexual generations were described by 
<bibRefCitation author="Ide, T. &amp; Abe, Y." box="[715,916,993,1020]" pageId="29" pageNumber="30" pagination="467 - 480" refId="ref44370" refString="Ide, T. &amp; Abe, Y. (2015) A new species of Dryocosmus Giraud (Hymenoptera: Cynipidae: Cynipini) in Japan and Korea - First record of Eastern Palearctic Dryocosmus species showing alternation of generations on section Cerris oaks. Proceedings of the Entomological Society of Washington, 117 (4), 467 - 480. https: // doi. org / 10.4289 / 0013 - 8797.117.4.467" type="journal article" year="2015">Ide &amp; Abe (2015)</bibRefCitation>
.
</paragraph>
<paragraph blockId="29.[151,1437,849,1595]" pageId="29" pageNumber="30">
<emphasis bold="true" box="[199,354,1028,1055]" pageId="29" pageNumber="30">Remarks (2).</emphasis>
<taxonomicName authorityName="Pujade-Villar et al. (2020 a:" authorityYear="1215" baseAuthorityName="Ide &amp; Abe" baseAuthorityYear="2015" box="[360,681,1029,1055]" class="Insecta" family="Cynipidae" genus="Plagiotrochus" kingdom="Animalia" order="Hymenoptera" pageId="29" pageNumber="30" phylum="Arthropoda" rank="species" species="kunugiphagus">
<emphasis box="[360,681,1029,1055]" italics="true" pageId="29" pageNumber="30">Plagiotrochus kunugiphagus</emphasis>
</taxonomicName>
was erroneously identified as 
<taxonomicName authority="Hartig, 1840" authorityName="Hartig" authorityYear="1840" box="[1019,1361,1029,1055]" class="Insecta" family="Cynipidae" genus="Andricus" kingdom="Animalia" order="Hymenoptera" pageId="29" pageNumber="30" phylum="Arthropoda" rank="species" species="inflator">
<emphasis box="[1019,1210,1029,1055]" italics="true" pageId="29" pageNumber="30">Andricus inflator</emphasis>
<bibRefCitation author="Hartig, T." box="[1217,1361,1029,1055]" pageId="29" pageNumber="30" pagination="176 - 209" refId="ref44244" refString="Hartig, T. (1840) Uber die Familie der Gallwespen. Zeitschrift fur die Entomologie, 2, 176 - 209." type="journal article" year="1840">Hartig, 1840</bibRefCitation>
</taxonomicName>
, a species described from Europe, based exclusively on the morphology of the galls (
<bibRefCitation author="Monzen, K." box="[1052,1213,1065,1091]" pageId="29" pageNumber="30" pagination="295 - 368" refId="ref48447" refString="Monzen, K. (1929) Studies on galls. Saito-hoonkai-jigyo-nenpo, 5, 295 - 368 + 20. [in Japanese]" type="journal article" year="1929">Monzen 1929</bibRefCitation>
, 
<bibRefCitation author="Monzen, K." box="[1225,1284,1065,1091]" pageId="29" pageNumber="30" pagination="27 - 32" refId="ref48495" refString="Monzen, K. (1938) Galls as injurious forest insects. Sanrin, 663, 27 - 32. [in Japanese]" type="journal article" year="1938">1938</bibRefCitation>
; 
<bibRefCitation author="Shinji, O." box="[1297,1432,1065,1091]" pageId="29" pageNumber="30" refId="ref52964" refString="Shinji, O. (1944) Galls and gall insects. Shunyo-do, Tokyo, 580 pp. [in Japanese]" type="book" year="1944">Shinji 1944</bibRefCitation>
; 
<bibRefCitation author="Ishii, T." box="[151,268,1101,1127]" pageId="29" pageNumber="30" pagination="98 - 100" refId="ref45219" refString="Ishii, T. (1949) Tamabachi (Mosshokushiho) wo kataru. Shin-Konchu, 2, 98 - 100." type="journal article" year="1949">Ishii 1949</bibRefCitation>
; 
<bibRefCitation author="Sakagami, S." box="[281,459,1101,1128]" pageId="29" pageNumber="30" pagination="67 - 79" refId="ref52473" refString="Sakagami, S. (1952) Zur Cynipoidenfauna Japan und seiner Nachbarlander (Hymenoptera). Mushi, 24, 67 - 79." type="journal article" year="1952">Sakagami 1952</bibRefCitation>
; 
<bibRefCitation author="Inoue, M." box="[472,604,1101,1127]" pageId="29" pageNumber="30" refId="ref45200" refString="Inoue, M. (1960) Ringyo Gaityu Bojo Ron. Volume 3. Chikyu-Shuppansha, Tokyo." type="book" year="1960">Inoue 1960</bibRefCitation>
). Although the galls of both species are quite similar, the adult wasps are morphologically very different (
<bibRefCitation author="Ide, T. &amp; Abe, Y." box="[511,697,1137,1164]" pageId="29" pageNumber="30" pagination="467 - 480" refId="ref44370" refString="Ide, T. &amp; Abe, Y. (2015) A new species of Dryocosmus Giraud (Hymenoptera: Cynipidae: Cynipini) in Japan and Korea - First record of Eastern Palearctic Dryocosmus species showing alternation of generations on section Cerris oaks. Proceedings of the Entomological Society of Washington, 117 (4), 467 - 480. https: // doi. org / 10.4289 / 0013 - 8797.117.4.467" type="journal article" year="2015">Ide &amp; Abe 2015</bibRefCitation>
).
</paragraph>
<paragraph blockId="29.[151,1437,849,1595]" pageId="29" pageNumber="30">
<emphasis bold="true" box="[199,355,1172,1199]" pageId="29" pageNumber="30">Remarks (3).</emphasis>
The host plants of 
<taxonomicName authorityName="Pujade-Villar et al. (2020 a:" authorityYear="1215" baseAuthorityName="Ide &amp; Abe" baseAuthorityYear="2015" box="[572,757,1173,1199]" class="Insecta" family="Cynipidae" genus="Plagiotrochus" kingdom="Animalia" order="Hymenoptera" pageId="29" pageNumber="30" phylum="Arthropoda" rank="species" species="kunugiphagus">
<emphasis box="[572,757,1173,1199]" italics="true" pageId="29" pageNumber="30">P. kunugiphagus</emphasis>
</taxonomicName>
are 
<taxonomicName box="[806,961,1173,1199]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="29" pageNumber="30" phylum="Tracheophyta" rank="species" species="acutissima">
<emphasis box="[806,961,1173,1199]" italics="true" pageId="29" pageNumber="30">Q. acutissima</emphasis>
</taxonomicName>
and, occasionally, 
<taxonomicName box="[1175,1317,1173,1199]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="29" pageNumber="30" phylum="Tracheophyta" rank="species" species="variabilis">
<emphasis box="[1175,1317,1173,1199]" italics="true" pageId="29" pageNumber="30">Q. variabilis</emphasis>
</taxonomicName>
(both section 
<taxonomicName box="[203,275,1209,1235]" class="Magnoliopsida" family="Fagaceae" genus="Cerris" higherTaxonomySource="GBIF" kingdom="Plantae" order="Fagales" pageId="29" pageNumber="30" phylum="Tracheophyta" rank="genus">
<emphasis box="[203,275,1209,1235]" italics="true" pageId="29" pageNumber="30">Cerris</emphasis>
</taxonomicName>
) in 
<collectingCountry box="[321,392,1209,1235]" name="South Korea" pageId="29" pageNumber="30">Korea</collectingCountry>
, according to the original description and 
<bibRefCitation author="Pujade-Villar, J. &amp; Kang, M. &amp; Bae, J. &amp; Wang, Y. &amp; Guo, R. &amp; Roca-Cusachs, M. &amp; Jung, S." box="[871,1184,1209,1235]" pageId="29" pageNumber="30" pagination="1208 - 1221" refId="ref50634" refString="Pujade-Villar, J., Kang, M., Bae, J., Wang, Y., Guo, R., Roca-Cusachs, M. &amp; Jung, S. (2020 a) Current state of knowledge of the Korean Cynipini: Subspecies description, new combinations and checklist (Hymenoptera, Cynipidae). Journal of AsiaPacific Entomology, 23 (4), 1208 - 1221. https: // doi. org / 10.1016 / j. aspen. 2020.08.012" type="journal article" year="2020">
Pujade-Villar 
<emphasis box="[1028,1078,1209,1235]" italics="true" pageId="29" pageNumber="30">et al</emphasis>
. (2020a)
</bibRefCitation>
. However, photos 136 and 
<quantity box="[199,270,1245,1271]" metricMagnitude="0" metricUnit="m" metricValue="5.9182" pageId="29" pageNumber="30" unit="in" value="233.0">233 in</quantity>
<bibRefCitation author="Shinji, O." box="[277,425,1245,1271]" pageId="29" pageNumber="30" refId="ref52964" refString="Shinji, O. (1944) Galls and gall insects. Shunyo-do, Tokyo, 580 pp. [in Japanese]" type="book" year="1944">Shinji (1944)</bibRefCitation>
belong to a different oak species (
<taxonomicName box="[812,927,1245,1271]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="29" pageNumber="30" phylum="Tracheophyta" rank="species" species="serrata">
<emphasis box="[812,927,1245,1271]" italics="true" pageId="29" pageNumber="30">Q. serrata</emphasis>
</taxonomicName>
= 
<taxonomicName box="[957,1129,1245,1271]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="29" pageNumber="30" phylum="Tracheophyta" rank="species" species="glandulifera">
<emphasis box="[957,1129,1245,1271]" italics="true" pageId="29" pageNumber="30">Q. glandulifera</emphasis>
</taxonomicName>
; sect. 
<taxonomicName box="[1202,1296,1245,1271]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="29" pageNumber="30" phylum="Tracheophyta" rank="genus">
<emphasis box="[1202,1296,1245,1271]" italics="true" pageId="29" pageNumber="30">Quercus</emphasis>
</taxonomicName>
). Therefore, it is necessary to confirm the host plant.
</paragraph>
<paragraph blockId="29.[151,1437,849,1595]" pageId="29" pageNumber="30">
<emphasis bold="true" box="[199,357,1316,1343]" pageId="29" pageNumber="30">Remarks (4).</emphasis>
In 
<bibRefCitation author="Mukaigawa, Y." box="[398,616,1317,1343]" pageId="29" pageNumber="30" pagination="485 - 488" refId="ref48757" refString="Mukaigawa, Y. (1914) Study on life history of Cynipidae. Insect World, 18, 485 - 488 + 1 plate. [in Japanese]" type="book chapter" year="1914">Mukaigawa (1914)</bibRefCitation>
, this species was mentioned as ‘Kunugi-no-ibo-fushi-bachi’ and in 
<bibRefCitation author="Mukaigawa, Y." pageId="29" pageNumber="30" pagination="203 - 208" refId="ref48843" refString="Mukaigawa, Y. (1922) Mie-Ken san Fashibachi (Cynipidae) no Kenkyu. Dobuts. Zasshi, 34, 203 - 208, 1 pl. [in Japanese] https: // doi. org / 10.5026 / jgeography. 34.203" type="journal article" year="1922">Mukaigawa (1922)</bibRefCitation>
, as ‘Kunugi-ibo-fushi-bachi’.
</paragraph>
<paragraph blockId="29.[151,1437,849,1595]" pageId="29" pageNumber="30">
<emphasis bold="true" box="[199,358,1388,1415]" pageId="29" pageNumber="30">Remarks (5).</emphasis>
<bibRefCitation author="Yukawa, J. &amp; Masuda, H." box="[368,675,1389,1415]" pageId="29" pageNumber="30" refId="ref55993" refString="Yukawa, J. &amp; Masuda, H. (1996) Insect and mite galls of Japan in colors. Zenkoku-Nouson-Kyoukai, Tokyo, 826 pp. [in Japanese]" type="book" year="1996">Yukawa &amp; Masuda (1996)</bibRefCitation>
photographed the asexual gall of this species and described it as ‘Kunugi-eda-tama-fushi’ (C-076), and the sexual gall as ‘Kunugi- waka-me-maru-zui-fushi’ (C-079). Later, 
<bibRefCitation author="Ide, T. &amp; Abe, Y." pageId="29" pageNumber="30" pagination="467 - 480" refId="ref44370" refString="Ide, T. &amp; Abe, Y. (2015) A new species of Dryocosmus Giraud (Hymenoptera: Cynipidae: Cynipini) in Japan and Korea - First record of Eastern Palearctic Dryocosmus species showing alternation of generations on section Cerris oaks. Proceedings of the Entomological Society of Washington, 117 (4), 467 - 480. https: // doi. org / 10.4289 / 0013 - 8797.117.4.467" type="journal article" year="2015">Ide &amp; Abe (2015)</bibRefCitation>
identified these galls as belonging to their newly described species, 
<taxonomicName authorityName="Pujade-Villar et al. (2020 a:" authorityYear="1215" baseAuthorityName="Ide &amp; Abe" baseAuthorityYear="2015" box="[1046,1237,1461,1487]" class="Insecta" family="Cynipidae" genus="Plagiotrochus" kingdom="Animalia" order="Hymenoptera" pageId="29" pageNumber="30" phylum="Arthropoda" rank="species" species="kunugiphagus">
<emphasis box="[1046,1237,1461,1487]" italics="true" pageId="29" pageNumber="30">D. kunugiphagus</emphasis>
</taxonomicName>
.
</paragraph>
</subSubSection>
<subSubSection pageId="29" pageNumber="30" type="biology_ecology">
<paragraph blockId="29.[151,1437,849,1595]" pageId="29" pageNumber="30">
<emphasis bold="true" box="[199,295,1497,1523]" pageId="29" pageNumber="30">Biology.</emphasis>
Both generations induce twig galls, presumably on 
<taxonomicName box="[878,1033,1497,1523]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="29" pageNumber="30" phylum="Tracheophyta" rank="species" species="acutissima">
<emphasis box="[878,1033,1497,1523]" italics="true" pageId="29" pageNumber="30">Q. acutissima</emphasis>
</taxonomicName>
and 
<taxonomicName box="[1087,1229,1497,1523]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="29" pageNumber="30" phylum="Tracheophyta" rank="species" species="variabilis">
<emphasis box="[1087,1229,1497,1523]" italics="true" pageId="29" pageNumber="30">Q. variabilis</emphasis>
</taxonomicName>
(sect. 
<taxonomicName box="[1303,1375,1497,1523]" class="Magnoliopsida" family="Fagaceae" genus="Cerris" higherTaxonomySource="GBIF" kingdom="Plantae" order="Fagales" pageId="29" pageNumber="30" phylum="Tracheophyta" rank="genus">
<emphasis box="[1303,1375,1497,1523]" italics="true" pageId="29" pageNumber="30">Cerris</emphasis>
</taxonomicName>
) (see Remarks 3 above) (Table 1; 
<bibRefCitation author="Ide, T. &amp; Abe, Y." box="[472,658,1533,1560]" pageId="29" pageNumber="30" pagination="467 - 480" refId="ref44370" refString="Ide, T. &amp; Abe, Y. (2015) A new species of Dryocosmus Giraud (Hymenoptera: Cynipidae: Cynipini) in Japan and Korea - First record of Eastern Palearctic Dryocosmus species showing alternation of generations on section Cerris oaks. Proceedings of the Entomological Society of Washington, 117 (4), 467 - 480. https: // doi. org / 10.4289 / 0013 - 8797.117.4.467" type="journal article" year="2015">Ide &amp; Abe 2015</bibRefCitation>
). More detailed information on the biology of this species is summarized in 
<bibRefCitation author="Penzes, Z. &amp; Tang, C. - T. &amp; Stone, G. N. &amp; Nicholls, J. A. &amp; Schweger, S. &amp; Bozso, M. &amp; Melika, G." box="[243,465,1569,1595]" pageId="29" pageNumber="30" pagination="245 - 289" refId="ref49925" refString="Penzes, Z., Tang, C. - T., Stone, G. N., Nicholls, J. A., Schweger, S., Bozso, M. &amp; Melika, G. (2018) Current status of the oak gallwasp (Hymenoptera: Cynipidae: Cynipini) fauna of the Eastern Palaearctic and Oriental Regions. Zootaxa, 4433 (2), 245 - 289. https: // doi. org / 10.11646 / zootaxa. 4433.2.2" type="journal article" year="2018">
Pénzes 
<emphasis box="[328,384,1569,1595]" italics="true" pageId="29" pageNumber="30">et al.</emphasis>
(2018)
</bibRefCitation>
under the name 
<taxonomicName authorityName="Ide &amp; Abe" authorityYear="2015" box="[652,956,1569,1595]" class="Insecta" family="Cynipidae" genus="Dryocosmus" kingdom="Animalia" order="Hymenoptera" pageId="29" pageNumber="30" phylum="Arthropoda" rank="species" species="kunugiphagus">
<emphasis box="[652,956,1569,1595]" italics="true" pageId="29" pageNumber="30">Dryocosmus kunugiphagus</emphasis>
</taxonomicName>
.
</paragraph>
</subSubSection>
