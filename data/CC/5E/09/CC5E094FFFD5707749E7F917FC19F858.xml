Russian Far East (
<bibRefCitation author="Schweger, S. &amp; Melika, G. &amp; Tang, C. - T. &amp; Yang, M. - M. &amp; Stone, G. N. &amp; Nicholls, J. A. &amp; Sinclair, F. &amp; Hearn, J. &amp; Bozso, M. &amp; Penzes, Z." box="[510,804,1810,1837]" pageId="35" pageNumber="36" pagination="1 - 84" refId="ref52592" refString="Schweger, S., Melika, G., Tang, C. - T., Yang, M. - M., Stone, G. N., Nicholls, J. A., Sinclair, F., Hearn, J., Bozso, M. &amp; Penzes, Z. (2015 b) New species of cynipid inquilines of the genus Saphonecrus (Hymenoptera: Cynipidae: Synergini) from the Eastern Palaearctic, with a re-appraisal of known species world-wide. Zootaxa, 4054 (1), 1 - 84. https: // doi. org / 10.11646 / zootaxa. 4054.1.1" type="journal article" year="2015">
Schwéger 
<emphasis box="[629,677,1810,1836]" italics="true" pageId="35" pageNumber="36">et al</emphasis>
. 2015b: 23
</bibRefCitation>
, 25) and 
<collectingCountry box="[904,971,1810,1836]" name="China" pageId="35" pageNumber="36">China</collectingCountry>
(
<collectingRegion box="[985,1056,1810,1836]" country="China" name="Hebei" pageId="35" pageNumber="36">Hebei</collectingRegion>
, 
<collectingRegion box="[1067,1167,1810,1836]" country="China" name="Zhejiang" pageId="35" pageNumber="36">Zhejiang</collectingRegion>
Provinces) (
<bibRefCitation author="Pujade-Villar, J. &amp; Wang, Y. &amp; Tang, G. &amp; Shen, J. &amp; Ferrer-Suay, M." pageId="35" pageNumber="36" pagination="17 - 24" refId="ref51876" refString="Pujade-Villar, J., Wang, Y., Tang, G., Shen, J. &amp; Ferrer-Suay, M. (2016 b) Andricus mukaigawae and Andricus kashiwaphilus from China with remarks of morphological differences and inquilines (Hymenoptera: Cynipidae). Butlleti de la Institucio Catalana d'Historia Natural, 80, 17 - 24." type="journal article" year="2016">
Pujade-Villar 
<emphasis box="[188,237,1846,1872]" italics="true" pageId="35" pageNumber="36">et al</emphasis>
. 2016b: 19
</bibRefCitation>
; 
<bibRefCitation author="Lobato-Vila, I. &amp; Wang, Y. &amp; Melika, G. &amp; Guo, R. &amp; Xiaoxue, J. &amp; Pujade-Villar, J." box="[378,699,1846,1873]" pageId="35" pageNumber="36" pagination="1 - 28" refId="ref46786" refString="Lobato-Vila, I., Wang, Y., Melika, G., Guo, R., Xiaoxue, J. &amp; Pujade-Villar, J. (2021 b) A taxonomic review of the gall wasp genus Saphonecrus Dalla-Torre &amp; Kieffer and other oak cynipid inquilines (Hymenoptera: Cynipidae) from mainland China, with updated keys to Eastern Palaearctic and Oriental species. Zoological Studies, 60 (10), 1 - 28. https: // doi. org / 10.6620 / ZS. 2021.60 - 10" type="journal article" year="2021">
Lobato-Vila 
