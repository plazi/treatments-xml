<subSubSection pageId="40" pageNumber="41" type="discussion">
<paragraph blockId="40.[151,1437,150,465]" pageId="40" pageNumber="41">
<emphasis bold="true" box="[199,315,258,284]" pageId="40" pageNumber="41">Remarks.</emphasis>
<bibRefCitation author="Kovalev, O. V." box="[321,496,258,285]" pageId="40" pageNumber="41" pagination="25 - 38" refId="ref45839" refString="Kovalev, O. V. (1965) Gall wasps (Hymenoptera, Cynipidae) from the south of the Soviet Far East. Entomologicheskoe Obozrenie, 44 (1 / 2), 46 - 73. [in Russian; English translation in Entomology Review, 44, 25 - 38]" type="journal article" year="1965">Kovalev (1965)</bibRefCitation>
found 
<taxonomicName authority="(Boyer de Fonscolombe, 1832)" baseAuthorityName="Boyer de Fonscolombe" baseAuthorityYear="1832" box="[574,1230,258,285]" class="Insecta" family="Cynipidae" genus="Synergus" kingdom="Animalia" order="Hymenoptera" pageId="40" pageNumber="41" phylum="Arthropoda" rank="species" species="gallaepomiformis">
<emphasis box="[574,879,258,285]" italics="true" pageId="40" pageNumber="41">Synergus gallaepomiformis</emphasis>
(Boyer de Fonscolombe, 1832)
</taxonomicName>
in the Russian Far East, which was reared from asexual galls of 
<emphasis box="[657,897,294,320]" italics="true" pageId="40" pageNumber="41">
<taxonomicName authorityName="Wachi &amp; Abe" authorityYear="2010" baseAuthorityName="Ashmead" baseAuthorityYear="1904" box="[657,893,294,320]" class="Insecta" family="Cynipidae" genus="Andricus" kingdom="Animalia" order="Hymenoptera" pageId="40" pageNumber="41" phylum="Arthropoda" rank="species" species="hakonensis">Andricus hakonensis</taxonomicName>
.
</emphasis>
According to 
<bibRefCitation author="Abe, Y. &amp; Melika, G. &amp; Stone, G. N." box="[1055,1245,294,321]" pageId="40" pageNumber="41" pagination="169 - 212" refId="ref42072" refString="Abe, Y., Melika, G. &amp; Stone, G. N. (2007) The diversity and phylogeography of cynipid gallwasps (Hymenoptera: Cynipidae) of the Oriental and Eastern Palearctic regions, and their associated communities. Oriental Insects, 41 (1), 169 - 212. https: // doi. org / 10.1080 / 00305316.2007.10417504" type="journal article" year="2007">
Abe 
<emphasis box="[1108,1157,294,320]" italics="true" pageId="40" pageNumber="41">et al</emphasis>
. (2007)
</bibRefCitation>
and 
<bibRefCitation author="Schweger, S. &amp; Melika, G. &amp; Tang, C. - T. &amp; Bihari, P. &amp; Bozso, M. &amp; Stone, G. N. &amp; Nicholls, J. A. &amp; Penzes, Z." pageId="40" pageNumber="41" pagination="451 - 497" refId="ref52498" refString="Schweger, S., Melika, G., Tang, C. - T., Bihari, P., Bozso, M., Stone, G. N., Nicholls, J. A. &amp; Penzes, Z. (2015 a) New species of cynipid inquilines of the genus Synergus (Hymenoptera: Cynipidae: Synergini) from the Eastern Palaearctic. Zootaxa, 3999 (4), 451 - 497. https: // doi. org / 10.11646 / zootaxa. 3999.4.1" type="journal article" year="2015">
Schwéger 
<emphasis italics="true" pageId="40" pageNumber="41">et al</emphasis>
. (2015a)
</bibRefCitation>
and based on the adult description given by Kovalev, these specimens belong to 
<taxonomicName authorityName="Melika, Acs &amp; Bechtold" authorityYear="2004" box="[1181,1313,330,357]" class="Insecta" family="Cynipidae" genus="Synergus" kingdom="Animalia" order="Hymenoptera" pageId="40" pageNumber="41" phylum="Arthropoda" rank="species" species="chinensis">
<emphasis box="[1181,1313,330,357]" italics="true" pageId="40" pageNumber="41">S. chinensis</emphasis>
</taxonomicName>
.
</paragraph>
</subSubSection>
