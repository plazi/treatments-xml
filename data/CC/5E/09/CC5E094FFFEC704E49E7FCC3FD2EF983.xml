; 
<bibRefCitation author="Sakagami, S." box="[1166,1385,1029,1056]" pageId="26" pageNumber="27" pagination="67 - 79" refId="ref52473" refString="Sakagami, S. (1952) Zur Cynipoidenfauna Japan und seiner Nachbarlander (Hymenoptera). Mushi, 24, 67 - 79." type="journal article" year="1952">Sakagami 1952: 73</bibRefCitation>
; 
<bibRefCitation author="Yukawa, J. &amp; Masuda, H." pageId="26" pageNumber="27" refId="ref55993" refString="Yukawa, J. &amp; Masuda, H. (1996) Insect and mite galls of Japan in colors. Zenkoku-Nouson-Kyoukai, Tokyo, 826 pp. [in Japanese]" type="book" year="1996">Yukawa &amp; Masuda 1996: 136</bibRefCitation>
