(Honshu, Kyushu, Shikoku) (
<bibRefCitation author="Ashmead, W. H." box="[711,928,1029,1055]" pageId="26" pageNumber="27" pagination="65 - 84" refId="ref42279" refString="Ashmead, W. H. (1904) Description of new Hymenoptera from Japan (I). Journal of the New York Entomological Society, 12 (3), 65 - 84." type="journal article" year="1904">Ashmead 1904: 79</bibRefCitation>
