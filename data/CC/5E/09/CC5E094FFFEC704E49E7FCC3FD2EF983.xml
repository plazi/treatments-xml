(
<bibRefCitation author="Kim, J. I. &amp; Kwon, Y. J. &amp; Paek, J. C. &amp; Lee, S. M. &amp; An, S. R. &amp; Park, H. C. &amp; Chu, H. Y." box="[657,895,1065,1091]" pageId="26" pageNumber="27" refId="ref45724" refString="Kim, J. I., Kwon, Y. J., Paek, J. C., Lee, S. M., An, S. R., Park, H. C. &amp; Chu, H. Y. (1994) Check list of insects from Korea. The Entomological Society of Korea and Korean Society of Applied Entomology, Kon-Kuk University Press, Seoul, 744 pp." type="book" year="1994">
