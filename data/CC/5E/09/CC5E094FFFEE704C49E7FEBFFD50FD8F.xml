<taxonomicName box="[1279,1436,505,531]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="24" pageNumber="25" phylum="Tracheophyta" rank="species" species="hypophaea">
<emphasis box="[1279,1436,505,531]" italics="true" pageId="24" pageNumber="25">Q. hypophaea</emphasis>
</taxonomicName>
(sect. 
<taxonomicName box="[218,405,541,567]" class="Magnoliopsida" family="Fagaceae" genus="Cyclobalanopsis" higherTaxonomySource="GBIF" kingdom="Plantae" order="Fagales" pageId="24" pageNumber="25" phylum="Tracheophyta" rank="genus">
<emphasis box="[218,405,541,567]" italics="true" pageId="24" pageNumber="25">Cyclobalanopsis</emphasis>
</taxonomicName>
) (Table 1; 
<bibRefCitation author="Tang, C. - T. &amp; Miko, I. &amp; Nicholls, J. A. &amp; Schweger, S. &amp; Yang, M. - M. &amp; Stone, G. N. &amp; Sinclair, F. &amp; Bozso, M. &amp; Melika, G. &amp; Penzes, Z." box="[527,727,541,567]" pageId="24" pageNumber="25" pagination="77 - 162" refId="ref53803" refString="Tang, C. - T., Miko, I., Nicholls, J. A., Schweger, S., Yang, M. - M., Stone, G. N., Sinclair, F., Bozso, M., Melika, G. &amp; Penzes, Z. (2016 a) New Dryocosmus Giraud species associated with Cyclobalanopsis and non- Quercus host plants from the Eastern Palearctic (Hymenoptera: Cynipidae: Cynipini). Journal of Hymenoptera Research, 53, 77 - 162. https: // doi. org / 10.3897 / jhr. 53.9890" type="journal article" year="2016">
Tang 
<emphasis box="[590,639,541,567]" italics="true" pageId="24" pageNumber="25">et al</emphasis>
. 2016a
</bibRefCitation>
).
</paragraph>
