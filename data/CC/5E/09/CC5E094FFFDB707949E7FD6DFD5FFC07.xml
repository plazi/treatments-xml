<subSubSection pageId="45" pageNumber="46" type="distribution">
<paragraph blockId="45.[151,1437,824,959]" pageId="45" pageNumber="46">
<emphasis bold="true" box="[151,305,824,850]" pageId="45" pageNumber="46">Distribution.</emphasis>
<collectingCountry box="[311,375,825,851]" name="Japan" pageId="45" pageNumber="46">Japan</collectingCountry>
(Honshu) (
<bibRefCitation author="Shinji, O." box="[502,706,824,850]" pageId="45" pageNumber="46" pagination="427 - 438" refId="ref52707" refString="Shinji, O. (1938 a) Studies on Japanese Cynipidae. Doubut-sugaku-Zasshi (Zoological Magazine), 50 (10), 427 - 438. [in Japanese]" type="journal article" year="1938">Shinji 1938a: 433</bibRefCitation>
; 
<bibRefCitation author="Sakagami, S." box="[718,935,824,851]" pageId="45" pageNumber="46" pagination="67 - 79" refId="ref52473" refString="Sakagami, S. (1952) Zur Cynipoidenfauna Japan und seiner Nachbarlander (Hymenoptera). Mushi, 24, 67 - 79." type="journal article" year="1952">Sakagami 1952: 76</bibRefCitation>
) and 
<collectingCountry box="[998,1139,824,851]" name="South Korea" pageId="45" pageNumber="46">South Korea</collectingCountry>
(
<bibRefCitation author="Kim, J. I. &amp; Kwon, Y. J. &amp; Paek, J. C. &amp; Lee, S. M. &amp; An, S. R. &amp; Park, H. C. &amp; Chu, H. Y." box="[1153,1392,824,851]" pageId="45" pageNumber="46" refId="ref45724" refString="Kim, J. I., Kwon, Y. J., Paek, J. C., Lee, S. M., An, S. R., Park, H. C. &amp; Chu, H. Y. (1994) Check list of insects from Korea. The Entomological Society of Korea and Korean Society of Applied Entomology, Kon-Kuk University Press, Seoul, 744 pp." type="book" year="1994">
Kim 
<emphasis box="[1212,1261,824,850]" italics="true" pageId="45" pageNumber="46">et al</emphasis>
. 1994: 223
</bibRefCitation>
). 
<emphasis bold="true" box="[199,315,860,886]" pageId="45" pageNumber="46">Remarks.</emphasis>
Uncertain status (
<bibRefCitation author="Abe, Y. &amp; Melika, G. &amp; Stone, G. N." box="[518,695,860,887]" pageId="45" pageNumber="46" pagination="169 - 212" refId="ref42072" refString="Abe, Y., Melika, G. &amp; Stone, G. N. (2007) The diversity and phylogeography of cynipid gallwasps (Hymenoptera: Cynipidae) of the Oriental and Eastern Palearctic regions, and their associated communities. Oriental Insects, 41 (1), 169 - 212. https: // doi. org / 10.1080 / 00305316.2007.10417504" type="journal article" year="2007">
Abe 
<emphasis box="[573,622,860,886]" italics="true" pageId="45" pageNumber="46">et al</emphasis>
. 2007
</bibRefCitation>
; 
<bibRefCitation author="Penzes, Z. &amp; Tang, C. - T. &amp; Stone, G. N. &amp; Nicholls, J. A. &amp; Schweger, S. &amp; Bozso, M. &amp; Melika, G." box="[707,916,860,887]" pageId="45" pageNumber="46" pagination="245 - 289" refId="ref49925" refString="Penzes, Z., Tang, C. - T., Stone, G. N., Nicholls, J. A., Schweger, S., Bozso, M. &amp; Melika, G. (2018) Current status of the oak gallwasp (Hymenoptera: Cynipidae: Cynipini) fauna of the Eastern Palaearctic and Oriental Regions. Zootaxa, 4433 (2), 245 - 289. https: // doi. org / 10.11646 / zootaxa. 4433.2.2" type="journal article" year="2018">
Pénzes 
<emphasis box="[792,841,860,886]" italics="true" pageId="45" pageNumber="46">et al</emphasis>
. 2018
</bibRefCitation>
). The 
<typeStatus box="[984,1043,861,887]" pageId="45" pageNumber="46">types</typeStatus>
are lost. 
<emphasis bold="true" box="[199,295,896,922]" pageId="45" pageNumber="46">Biology.</emphasis>
Induces galls on 
<taxonomicName box="[494,613,896,922]" class="Magnoliopsida" family="Fagaceae" genus="Castanea" kingdom="Plantae" order="Fagales" pageId="45" pageNumber="46" phylum="Tracheophyta" rank="species" species="dentata">
<emphasis box="[494,613,896,922]" italics="true" pageId="45" pageNumber="46">Q. dentata</emphasis>
</taxonomicName>
(sect. 
<taxonomicName baseAuthorityName="Shinji" baseAuthorityYear="1943" box="[688,782,896,922]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="45" pageNumber="46" phylum="Tracheophyta" rank="genus">
<emphasis box="[688,782,896,922]" italics="true" pageId="45" pageNumber="46">Quercus</emphasis>
</taxonomicName>
) (
<bibRefCitation author="Shinji, O." box="[807,956,896,922]" pageId="45" pageNumber="46" pagination="427 - 438" refId="ref52707" refString="Shinji, O. (1938 a) Studies on Japanese Cynipidae. Doubut-sugaku-Zasshi (Zoological Magazine), 50 (10), 427 - 438. [in Japanese]" type="journal article" year="1938">Shinji 1938a</bibRefCitation>
). According to 
<bibRefCitation author="Yukawa, J. &amp; Masuda, H." box="[1131,1431,896,922]" pageId="45" pageNumber="46" refId="ref55993" refString="Yukawa, J. &amp; Masuda, H. (1996) Insect and mite galls of Japan in colors. Zenkoku-Nouson-Kyoukai, Tokyo, 826 pp. [in Japanese]" type="book" year="1996">Yukawa &amp; Masuda (1996)</bibRefCitation>
, the gall is similar to that of 
<taxonomicName authorityName="Wachi &amp; Abe" authorityYear="2010" baseAuthorityName="Ashmead" baseAuthorityYear="1904" box="[460,692,932,958]" class="Insecta" family="Cynipidae" genus="Andricus" kingdom="Animalia" order="Hymenoptera" pageId="45" pageNumber="46" phylum="Arthropoda" rank="species" species="hakonensis">
<emphasis box="[460,692,932,958]" italics="true" pageId="45" pageNumber="46">Andricus hakonensis</emphasis>
</taxonomicName>
<specimenCount box="[699,725,933,959]" pageId="45" pageNumber="46" type="male">♂</specimenCount>
<specimenCount box="[726,744,933,959]" pageId="45" pageNumber="46" type="female">♀</specimenCount>
.
</paragraph>
