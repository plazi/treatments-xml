<taxonomicName box="[609,722,639,665]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="38" pageNumber="39" phylum="Tracheophyta" rank="species" species="glauca">
