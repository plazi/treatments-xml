<emphasis box="[1291,1343,639,665]" italics="true" pageId="38" pageNumber="39">et al</emphasis>
. 2011b
</bibRefCitation>
; 
<bibRefCitation author="Melika, G. &amp; Tang, C. - T. &amp; Yang, M. - M. &amp; Bihari, P. &amp; Bozso, M. &amp; Penzes, Z." box="[151,361,675,701]" pageId="38" pageNumber="39" pagination="143 - 163" refId="ref48306" refString="Melika, G., Tang, C. - T., Yang, M. - M., Bihari, P., Bozso, M. &amp; Penzes, Z. (2012) New species of cynipid inquilines of the genus Ufo Melika &amp; Pujade-Villar, 2005 (Hymenoptera: Cynipidae: Synergini). Zootaxa, 3478 (1), 143 - 163. https: // doi. org / 10.11646 / zootaxa. 3478.1.17" type="journal article" year="2012">
