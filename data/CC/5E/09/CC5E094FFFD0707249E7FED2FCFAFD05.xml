<taxonomicName box="[782,917,639,665]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="38" pageNumber="39" phylum="Tracheophyta" rank="species" species="longinux">
<emphasis box="[782,917,639,665]" italics="true" pageId="38" pageNumber="39">Q. longinux</emphasis>
</taxonomicName>
(sect. 
<taxonomicName box="[996,1183,639,665]" class="Magnoliopsida" family="Fagaceae" genus="Cyclobalanopsis" higherTaxonomySource="GBIF" kingdom="Plantae" order="Fagales" pageId="38" pageNumber="39" phylum="Tracheophyta" rank="genus">
<emphasis box="[996,1183,639,665]" italics="true" pageId="38" pageNumber="39">Cyclobalanopsis</emphasis>
</taxonomicName>
