<collectingCountry box="[311,378,1070,1096]" name="China" pageId="34" pageNumber="35">China</collectingCountry>
(
<collectingRegion box="[391,586,1070,1096]" country="China" name="Yunnan" pageId="34" pageNumber="35">Yunnan Province</collectingRegion>
) (
<bibRefCitation author="Melika, G. &amp; Acs, Z. &amp; Bechtold, M." box="[608,928,1070,1097]" pageId="34" pageNumber="35" pagination="319 - 336" refId="ref47565" refString="Melika, G., Acs, Z. &amp; Bechtold, M. (2004) New species of cynipid inquilines from China (Hymenoptera: Cynipidae: Synergini). Acta Zoologica Academiae Scientiarum Hungaricae, 50 (4), 319 - 336." type="journal article" year="2004">
Melika 
<emphasis box="[695,744,1070,1096]" italics="true" pageId="34" pageNumber="35">et al</emphasis>
. 2004: 333–334
</bibRefCitation>
; 
<bibRefCitation author="Wang, Y. &amp; Chen, X. &amp; Pujade-Villar, J. &amp; Wu, H. &amp; He, J." box="[938,1270,1070,1097]" pageId="34" pageNumber="35" pagination="1034 - 1039" refId="ref55032" refString="Wang, Y., Chen, X., Pujade-Villar, J., Wu, H. &amp; He, J. (2010) The genus Saphonecrus Dalla-Torre &amp; Kieffer, 1910 (Hymenoptera: Cynipidae) in China, with descriptions of two new species. Biologia, 65, 1034 - 1039. https: // doi. org / 10.2478 / s 11756 - 010 - 0120 - 9" type="journal article" year="2010">
