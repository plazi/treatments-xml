<bibRefCitation author="Shinji, O." pageId="25" pageNumber="26" pagination="427 - 438" refId="ref52707" refString="Shinji, O. (1938 a) Studies on Japanese Cynipidae. Doubut-sugaku-Zasshi (Zoological Magazine), 50 (10), 427 - 438. [in Japanese]" type="journal article" year="1938">Shinji 1938a: 427</bibRefCitation>
; 
<bibRefCitation author="Sakagami, S." box="[208,427,854,881]" pageId="25" pageNumber="26" pagination="67 - 79" refId="ref52473" refString="Sakagami, S. (1952) Zur Cynipoidenfauna Japan und seiner Nachbarlander (Hymenoptera). Mushi, 24, 67 - 79." type="journal article" year="1952">Sakagami 1952: 72</bibRefCitation>
