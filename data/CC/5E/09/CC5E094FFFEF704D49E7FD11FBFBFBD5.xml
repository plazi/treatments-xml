<bibRefCitation author="Monzen, K." box="[840,1056,819,845]" pageId="25" pageNumber="26" pagination="192 - 200" refId="ref48472" refString="Monzen, K. (1931) On Japanese gallwasps. Oyo-doubutsugaku-zasshi, 3, 192 - 200. [in Japanese]" type="journal article" year="1931">Monzen 1931: 193</bibRefCitation>
