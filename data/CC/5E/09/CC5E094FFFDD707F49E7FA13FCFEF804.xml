<subSubSection pageId="43" pageNumber="44" type="discussion">
<paragraph blockId="43.[151,1437,1558,1981]" pageId="43" pageNumber="44">
<emphasis bold="true" box="[199,315,1630,1656]" pageId="43" pageNumber="44">Remarks.</emphasis>
According to 
<bibRefCitation author="Melika, G. &amp; Tang, C. - T. &amp; Yang, M. - M. &amp; Bihari, P. &amp; Bozso, M. &amp; Penzes, Z." box="[480,712,1630,1657]" pageId="43" pageNumber="44" pagination="143 - 163" refId="ref48306" refString="Melika, G., Tang, C. - T., Yang, M. - M., Bihari, P., Bozso, M. &amp; Penzes, Z. (2012) New species of cynipid inquilines of the genus Ufo Melika &amp; Pujade-Villar, 2005 (Hymenoptera: Cynipidae: Synergini). Zootaxa, 3478 (1), 143 - 163. https: // doi. org / 10.11646 / zootaxa. 3478.1.17" type="journal article" year="2012">
Melika 
<emphasis box="[568,619,1630,1656]" italics="true" pageId="43" pageNumber="44">et al</emphasis>
. (2012)
</bibRefCitation>
, a 
<typeStatus box="[746,842,1631,1657]" pageId="43" pageNumber="44">paratype</typeStatus>
of 
<taxonomicName authorityName="Melika, Pujade-Villar &amp; Choi" authorityYear="2007" box="[883,1021,1630,1656]" class="Insecta" family="Cynipidae" genus="Ufo" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="43" pageNumber="44" phylum="Arthropoda" rank="species" species="koreanus">
<emphasis box="[883,1021,1630,1656]" italics="true" pageId="43" pageNumber="44">U. koreanus</emphasis>
</taxonomicName>
labelled ‘ 
<collectingCountry box="[1132,1236,1630,1656]" name="South Korea" pageId="43" pageNumber="44">KOREA</collectingCountry>
, NIAST, 
<date pageId="43" pageNumber="44" value="1997-10-10">10. Oct. 1997</date>
, YPT., June Yeol Choi.’ belongs to 
<taxonomicName authorityName="Tang &amp; Melika" authorityYear="2012" box="[606,804,1667,1692]" class="Insecta" family="Cynipidae" genus="Ufo" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="43" pageNumber="44" phylum="Arthropoda" rank="species" species="cerroneuroteri">
<emphasis box="[606,804,1667,1692]" italics="true" pageId="43" pageNumber="44">U. cerroneuroteri</emphasis>
</taxonomicName>
.
</paragraph>
<paragraph blockId="43.[151,1437,1558,1981]" pageId="43" pageNumber="44">
<emphasis bold="true" box="[199,356,1702,1728]" pageId="43" pageNumber="44">Remarks (2).</emphasis>
<taxonomicName authorityName="Melika, Pujade-Villar &amp; Choi" authorityYear="2007" box="[364,516,1702,1728]" class="Insecta" family="Cynipidae" genus="Ufo" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="43" pageNumber="44" phylum="Arthropoda" rank="species" species="koreanus">
<emphasis box="[364,516,1702,1728]" italics="true" pageId="43" pageNumber="44">Ufo koreanus</emphasis>
</taxonomicName>
was originally thought to have been reared from galls of 
<taxonomicName authorityName="Ashmead" authorityYear="1904" box="[1169,1370,1703,1728]" class="Insecta" family="Cynipidae" genus="Neuroterus" kingdom="Animalia" order="Hymenoptera" pageId="43" pageNumber="44" phylum="Arthropoda" rank="species" species="nawai">
<emphasis box="[1169,1370,1703,1728]" italics="true" pageId="43" pageNumber="44">Neuroterus nawai</emphasis>
</taxonomicName>
(now 
<taxonomicName authorityName="Ide &amp; Abe" authorityYear="2016" baseAuthorityName="Ashmead" baseAuthorityYear="1904" box="[151,339,1739,1764]" class="Insecta" family="Cynipidae" genus="Latuspina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="43" pageNumber="44" phylum="Arthropoda" rank="species" species="nawai">
<emphasis box="[151,339,1739,1764]" italics="true" pageId="43" pageNumber="44">Latuspina nawai</emphasis>
</taxonomicName>
) (
<bibRefCitation author="Melika, G. &amp; Choi, J. - Y. &amp; Pujade-Villar, J. &amp; Penzes, Z. &amp; Fulop, D." box="[365,577,1738,1765]" pageId="43" pageNumber="44" pagination="197 - 200" refId="ref47612" refString="Melika, G., Choi, J. - Y., Pujade-Villar, J., Penzes, Z. &amp; Fulop, D. (2007) A new species of inquiline cynipid of the genus Ufo Melika &amp; Pujade-Villar, 2005 from Korea (Hymenoptera: Cynipidae: Synergini). Journal of Asia-Pacific Entomology, 108 (3), 197 - 200. https: // doi. org / 10.1016 / S 1226 - 8615 (08) 60353 - 2" type="journal article" year="2007">
Melika 
<emphasis box="[454,504,1738,1764]" italics="true" pageId="43" pageNumber="44">et al</emphasis>
. 2007
</bibRefCitation>
) on 
<taxonomicName authority="(Melika et al. 2012)" baseAuthorityName="Melika" baseAuthorityYear="2012" box="[629,1010,1738,1765]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="43" pageNumber="44" phylum="Tracheophyta" rank="species" species="variabilis">
<emphasis box="[629,771,1738,1765]" italics="true" pageId="43" pageNumber="44">Q. variabilis</emphasis>
(
<bibRefCitation author="Melika, G. &amp; Tang, C. - T. &amp; Yang, M. - M. &amp; Bihari, P. &amp; Bozso, M. &amp; Penzes, Z." box="[787,1002,1738,1765]" pageId="43" pageNumber="44" pagination="143 - 163" refId="ref48306" refString="Melika, G., Tang, C. - T., Yang, M. - M., Bihari, P., Bozso, M. &amp; Penzes, Z. (2012) New species of cynipid inquilines of the genus Ufo Melika &amp; Pujade-Villar, 2005 (Hymenoptera: Cynipidae: Synergini). Zootaxa, 3478 (1), 143 - 163. https: // doi. org / 10.11646 / zootaxa. 3478.1.17" type="journal article" year="2012">
Melika 
<emphasis box="[877,927,1738,1764]" italics="true" pageId="43" pageNumber="44">et al</emphasis>
. 2012
</bibRefCitation>
)
</taxonomicName>
, and not 
<taxonomicName baseAuthorityName="Ashmead" baseAuthorityYear="1904" box="[1115,1287,1738,1764]" class="Insecta" family="Cynipidae" genus="Biorhiza" kingdom="Animalia" order="Hymenoptera" pageId="43" pageNumber="44" phylum="Arthropoda" rank="species" species="nawai">
<emphasis box="[1115,1287,1738,1764]" italics="true" pageId="43" pageNumber="44">Biorhiza nawai</emphasis>
</taxonomicName>
as presumed in 
<bibRefCitation author="Lobato-Vila, I. &amp; Kang, M. &amp; Roca-Cusachs, M. &amp; Kim, I. &amp; Joon, S. &amp; Pujade-Villar, J." box="[181,479,1774,1801]" pageId="43" pageNumber="44" pagination="179 - 198" refId="ref46607" refString="Lobato-Vila, I., Kang, M., Roca-Cusachs, M., Kim, I., Joon, S. &amp; Pujade-Villar, J. (2020 d) Taxonomic assessment of the inquiline fauna (Hymenoptera: Cynipidae: Synergini, Ceroptresini) reared from cynipid galls on oaks (Quercus spp.) from South Korea. Zootaxa, 4860 (2), 179 - 198. https: // doi. org / 10.11646 / zootaxa. 4860.2.2" type="journal article" year="2020">
Lobato-Vila 
<emphasis box="[325,375,1774,1800]" italics="true" pageId="43" pageNumber="44">et al</emphasis>
. (2020d)
</bibRefCitation>
and reconfirmed in 
<bibRefCitation author="Lobato-Vila, I. &amp; Wang, Y. &amp; Melika, G. &amp; Guo, R. &amp; Xiaoxue, J. &amp; Pujade-Villar, J." box="[711,1011,1774,1801]" pageId="43" pageNumber="44" pagination="1 - 28" refId="ref46786" refString="Lobato-Vila, I., Wang, Y., Melika, G., Guo, R., Xiaoxue, J. &amp; Pujade-Villar, J. (2021 b) A taxonomic review of the gall wasp genus Saphonecrus Dalla-Torre &amp; Kieffer and other oak cynipid inquilines (Hymenoptera: Cynipidae) from mainland China, with updated keys to Eastern Palaearctic and Oriental species. Zoological Studies, 60 (10), 1 - 28. https: // doi. org / 10.6620 / ZS. 2021.60 - 10" type="journal article" year="2021">
Lobato-Vila 
<emphasis box="[854,905,1774,1800]" italics="true" pageId="43" pageNumber="44">et al</emphasis>
. (2021b)
</bibRefCitation>
. However, the host gall mentioned in 
<bibRefCitation author="Melika, G. &amp; Choi, J. - Y. &amp; Pujade-Villar, J. &amp; Penzes, Z. &amp; Fulop, D." box="[151,380,1810,1836]" pageId="43" pageNumber="44" pagination="197 - 200" refId="ref47612" refString="Melika, G., Choi, J. - Y., Pujade-Villar, J., Penzes, Z. &amp; Fulop, D. (2007) A new species of inquiline cynipid of the genus Ufo Melika &amp; Pujade-Villar, 2005 from Korea (Hymenoptera: Cynipidae: Synergini). Journal of Asia-Pacific Entomology, 108 (3), 197 - 200. https: // doi. org / 10.1016 / S 1226 - 8615 (08) 60353 - 2" type="journal article" year="2007">
Melika 
<emphasis box="[238,295,1810,1836]" italics="true" pageId="43" pageNumber="44">et al.</emphasis>
(2007)
</bibRefCitation>
, which was later pictured in 
<bibRefCitation author="Melika, G. &amp; Pujade-Villar, J. &amp; Abe, Y. &amp; Tang, C. - T. &amp; Nicholls, J. &amp; Wachi, N. &amp; Ide, T. &amp; Yang, M. - M. &amp; Penzes, Zs &amp; Csoka, G. &amp; Stone, G. N." box="[707,926,1810,1837]" pageId="43" pageNumber="44" pagination="1 - 79" refId="ref47700" refString="Melika, G., Pujade-Villar, J., Abe, Y., Tang, C. - T., Nicholls, J., Wachi, N., Ide, T., Yang, M. - M., Penzes, Zs, Csoka, G. &amp; Stone, G. N. (2010) Palaearctic oak gallwasps galling oaks (Quercus) in the section Cerris: re-appraisal of generic limits, with descriptions of new genera and species (Hymenoptera: Cynipidae: Cynipini). Zootaxa, 2470 (1), 1 - 79. https: // doi. org / 10.11646 / zootaxa. 2470.1.1" type="journal article" year="2010">
Melika 
<emphasis box="[794,844,1810,1836]" italics="true" pageId="43" pageNumber="44">et al</emphasis>
. (2010
</bibRefCitation>
, 2012) corresponds to the asexual generation of 
<taxonomicName authorityName="Pujade-Villar &amp; Melika" authorityYear="2020" box="[182,555,1846,1873]" class="Insecta" family="Cynipidae" genus="Cerroneuroterus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="43" pageNumber="44" phylum="Arthropoda" rank="species" species="yukawamasudai">
<emphasis box="[182,555,1846,1873]" italics="true" pageId="43" pageNumber="44">Cerroneuroterus yukawamasudai</emphasis>
</taxonomicName>
(see Remarks 2 for 
<taxonomicName authorityName="Ide &amp; Abe" authorityYear="2016" baseAuthorityName="Ashmead" baseAuthorityYear="1904" box="[781,968,1847,1872]" class="Insecta" family="Cynipidae" genus="Latuspina" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="43" pageNumber="44" phylum="Arthropoda" rank="species" species="nawai">
<emphasis box="[781,968,1847,1872]" italics="true" pageId="43" pageNumber="44">Latuspina nawai</emphasis>
</taxonomicName>
).
</paragraph>
</subSubSection>
<subSubSection pageId="43" pageNumber="44" type="biology_ecology">
<paragraph blockId="43.[151,1437,1558,1981]" pageId="43" pageNumber="44">
<emphasis bold="true" box="[199,295,1882,1908]" pageId="43" pageNumber="44">Biology.</emphasis>
Reared from galls of 
<taxonomicName authorityName="Ide &amp; Abe" authorityYear="2021" baseAuthorityName="Ashmead" baseAuthorityYear="1904" box="[534,835,1883,1909]" class="Insecta" family="Cynipidae" genus="Cerroneuroterus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="43" pageNumber="44" phylum="Arthropoda" rank="species" species="japonicus">
<emphasis box="[534,835,1883,1909]" italics="true" pageId="43" pageNumber="44">Cerroneuroterus japonicus</emphasis>
</taxonomicName>
(= 
