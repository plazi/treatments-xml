<taxonomicName box="[570,773,1851,1877]" pageId="26" pageNumber="27">
<emphasis box="[570,682,1852,1877]" italics="true" pageId="26" pageNumber="27">Latuspina</emphasis>
species
</taxonomicName>
, the host oak is probably in section 
<taxonomicName box="[1178,1250,1852,1878]" class="Magnoliopsida" family="Fagaceae" genus="Cerris" higherTaxonomySource="GBIF" kingdom="Plantae" order="Fagales" pageId="26" pageNumber="27" phylum="Tracheophyta" rank="genus">
