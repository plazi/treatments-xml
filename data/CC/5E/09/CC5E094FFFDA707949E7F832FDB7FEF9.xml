<taxonomicName box="[1290,1405,259,285]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="45" pageNumber="46" phylum="Tracheophyta" rank="species" species="serrata">
<emphasis box="[1290,1405,259,285]" italics="true" pageId="45" pageNumber="46">Q. serrata</emphasis>
</taxonomicName>
(= 
<taxonomicName box="[151,323,295,321]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="45" pageNumber="46" phylum="Tracheophyta" rank="species" species="glandulifera">
<emphasis box="[151,323,295,321]" italics="true" pageId="45" pageNumber="46">Q. glandulifera</emphasis>
</taxonomicName>
) (sect. 
<taxonomicName box="[407,501,295,321]" class="Magnoliopsida" family="Fagaceae" genus="Quercus" kingdom="Plantae" order="Fagales" pageId="45" pageNumber="46" phylum="Tracheophyta" rank="genus">
<emphasis box="[407,501,295,321]" italics="true" pageId="45" pageNumber="46">Quercus</emphasis>
