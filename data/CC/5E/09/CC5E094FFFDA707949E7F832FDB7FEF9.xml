<bibRefCitation author="Monzen, K." box="[771,946,259,285]" pageId="45" pageNumber="46" pagination="295 - 368" refId="ref48447" refString="Monzen, K. (1929) Studies on galls. Saito-hoonkai-jigyo-nenpo, 5, 295 - 368 + 20. [in Japanese]" type="journal article" year="1929">Monzen (1929)</bibRefCitation>
, 
<taxonomicName authorityName="Ashmead" authorityYear="1904" box="[957,1097,259,285]" class="Insecta" family="Cynipidae" genus="Andricus" kingdom="Animalia" order="Hymenoptera" pageId="45" pageNumber="46" phylum="Arthropoda" rank="species" species="japonicus">
<emphasis box="[957,1097,259,285]" italics="true" pageId="45" pageNumber="46">A. japonicus</emphasis>
</taxonomicName>
