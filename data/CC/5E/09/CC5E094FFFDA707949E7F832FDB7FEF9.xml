<subSubSection pageId="45" pageNumber="46" type="biology_ecology">
<paragraph blockId="45.[151,1437,150,321]" pageId="45" pageNumber="46">
<emphasis bold="true" box="[199,295,258,284]" pageId="45" pageNumber="46">Biology.</emphasis>
Unknown (
<bibRefCitation author="Ashmead, W. H." box="[426,600,259,285]" pageId="45" pageNumber="46" pagination="65 - 84" refId="ref42279" refString="Ashmead, W. H. (1904) Description of new Hymenoptera from Japan (I). Journal of the New York Entomological Society, 12 (3), 65 - 84." type="journal article" year="1904">Ashmead 1904</bibRefCitation>
