<subSubSection id="C3246572FF9FC930FF62FF1CFB46FE82" pageId="62" pageNumber="63" type="diagnosis">
<paragraph id="8B8136F9FF9FC930FF62FF1CFB46FE82" blockId="62.[151,1437,150,501]" pageId="62" pageNumber="63">
<emphasis id="B94AEAEBFF9FC930FF62FF1CFECCFF73" bold="true" box="[199,322,150,176]" pageId="62" pageNumber="63">Diagnosis.</emphasis>
Females of 
<taxonomicName id="4C3E4D7AFF9FC930FE62FF1DFD09FF73" authorityName="Rheims &amp; Jäger" authorityYear="2022" baseAuthorityName="Simon" baseAuthorityYear="1898" box="[455,647,151,176]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="62" pageNumber="63" phylum="Arthropoda" rank="species" species="sanctivincenti" status="comb. nov.">
<emphasis id="B94AEAEBFF9FC930FE62FF1DFD09FF73" box="[455,647,151,176]" italics="true" pageId="62" pageNumber="63">M. sanctivincenti</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFF9FC930FD29FF1DFC85FF72" bold="true" box="[652,779,151,177]" pageId="62" pageNumber="63">
<taxonomicNameLabel id="A2795790FF9FC930FD29FF1DFC85FF72" box="[652,779,151,177]" pageId="62" pageNumber="63" rank="species">comb. nov.</taxonomicNameLabel>
</emphasis>
resemble those of 
<taxonomicName id="4C3E4D7AFF9FC930FC7DFF1DFBFBFF73" authority="Rheims &amp; Jäger, 2022" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[984,1141,151,176]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="62" pageNumber="63" phylum="Arthropoda" rank="species" species="tapirapeco" status="spec. nov.">
<emphasis id="B94AEAEBFF9FC930FC7DFF1DFBFBFF73" box="[984,1141,151,176]" italics="true" pageId="62" pageNumber="63">M. tapirapeco</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFF9FC930FBDEFF1DFB62FF72" bold="true" box="[1147,1260,151,177]" pageId="62" pageNumber="63">
<taxonomicNameLabel id="A2795790FF9FC930FBDEFF1DFB62FF72" box="[1147,1260,151,177]" pageId="62" pageNumber="63" rank="species">spec. nov.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13052A7CFF9FC930FB5FFF1DFA1BFF72" box="[1274,1429,150,177]" captionStart="FIGURES 253–259" captionStartId="63.[151,264,1813,1837]" captionTargetBox="[163,1422,393,1776]" captionTargetId="figure-80@63.[154,1434,381,1790]" captionTargetPageId="63" captionText="FIGURES 253–259. 253–256 Meri tambor spec. nov., male (INPA 3522), left palp (253 prolateral, 254 ventral, 255 retrolateral, 256 detail of embolus); 257–259 Meri tapirapeco spec. nov., female (INPA) (257 epigyne, 258 vulva, 259 schematic course of internal duct system). C—conductor; E—embolus; EP— epigynal pocket; FD—fertilization duct; ft—first turn of duct system; GP—glandular projection; LL—lateral lobe; MS—median septum; PTA—prolateral tibial apophysis; RpP—retro proximal projection; RTA—retrolateral tibial projection; SdP—subdistal projection; SP—spermathecae; tp—tegular protrusion. Scale lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6550500" httpUri="https://zenodo.org/record/6550500/files/figure.png" pageId="62" pageNumber="63">Figs 257–259</figureCitation>
) and 
<taxonomicName id="4C3E4D7AFF9FC930FF6DFF31FEA0FF16" authority="Rheims &amp; Jäger, 2022" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[200,302,187,213]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="62" pageNumber="63" phylum="Arthropoda" rank="species" species="zeteki" status="spec. nov.">
<emphasis id="B94AEAEBFF9FC930FF6DFF31FEA0FF16" box="[200,302,187,213]" italics="true" pageId="62" pageNumber="63">M. zeteki</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFF9FC930FE90FF31FE27FF16" bold="true" box="[309,425,187,213]" pageId="62" pageNumber="63">
<taxonomicNameLabel id="A2795790FF9FC930FE90FF31FE27FF16" box="[309,425,187,213]" pageId="62" pageNumber="63" rank="species">spec. nov.</taxonomicNameLabel>
</emphasis>
(
<figureCitation id="13052A7CFF9FC930FE1CFF31FDDBFF16" box="[441,597,187,213]" captionStart="FIGURES 309–311" captionStartId="75.[151,264,1172,1196]" captionTargetBox="[177,1410,642,1141]" captionTargetId="figure-185@75.[170,1418,633,1148]" captionTargetPageId="75" captionText="FIGURES 309–311. Meri zeteki spec. nov. female (MCZ 99617, holotype) (309 epigyne, 310 vulva, 311 schematic course of internal duct system). ag—anterior groove; EP—epigynal pocket; FD—fertilization duct; ft—first turn of duct system; GP— glandular projection; LL—lateral lobe; MS—median septum; SP—spermathecae. Scale lines: 1 mm." figureDoi="http://doi.org/10.5281/zenodo.6550416" httpUri="https://zenodo.org/record/6550416/files/figure.png" pageId="62" pageNumber="63">Figs 309–311</figureCitation>
) by the epigyne with EP opening medially on MS. They are distinguished from both species by the MS with lateral margins diverning anteriorly (
<figureCitation id="13052A7CFF9FC930FC7DFF55FBB2FF3A" box="[984,1084,222,249]" captionStart="FIGURES 250–252" captionStartId="61.[151,264,1938,1962]" captionTargetBox="[189,1403,1171,1906]" captionTargetId="figure-364@61.[181,1406,1166,1915]" captionTargetPageId="61" captionText="FIGURES 250–252. Meri sanctivincenti (Simon) comb. nov., female (250 epigyne, 251 vulva, 252 schematic course of internal duct system). EP—epigynal pocket; ft—first turn of duct system; FD—fertilization duct; GP—glandular projection; LL—lateral lobe; MS—median septum; SP—spermathecae. Scale line: 1 mm. Modified from Jäger 2020 (94: figs 349–351)." figureDoi="http://doi.org/10.5281/zenodo.6550498" httpUri="https://zenodo.org/record/6550498/files/figure.png" pageId="62" pageNumber="63">Fig. 250</figureCitation>
) and vulva with spermathecae rounded with smooth margins (
<figureCitation id="13052A7CFF9FC930FE5BFE89FDEEFEDE" box="[510,608,258,285]" captionStart="FIGURES 250–252" captionStartId="61.[151,264,1938,1962]" captionTargetBox="[189,1403,1171,1906]" captionTargetId="figure-364@61.[181,1406,1166,1915]" captionTargetPageId="61" captionText="FIGURES 250–252. Meri sanctivincenti (Simon) comb. nov., female (250 epigyne, 251 vulva, 252 schematic course of internal duct system). EP—epigynal pocket; ft—first turn of duct system; FD—fertilization duct; GP—glandular projection; LL—lateral lobe; MS—median septum; SP—spermathecae. Scale line: 1 mm. Modified from Jäger 2020 (94: figs 349–351)." figureDoi="http://doi.org/10.5281/zenodo.6550498" httpUri="https://zenodo.org/record/6550498/files/figure.png" pageId="62" pageNumber="63">Fig. 251</figureCitation>
) (MS with lateral margins converging anteriorly and spermathecae with grooved margins in 
<taxonomicName id="4C3E4D7AFF9FC930FED2FEADFD98FE83" authority="Rheims &amp; Jäger, 2022" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[375,534,295,320]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="62" pageNumber="63" phylum="Arthropoda" rank="species" species="tapirapeco" status="spec. nov.">
<emphasis id="B94AEAEBFF9FC930FED2FEADFD98FE83" box="[375,534,295,320]" italics="true" pageId="62" pageNumber="63">M. tapirapeco</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFF9FC930FDB8FEADFD01FE82" bold="true" box="[541,655,295,321]" pageId="62" pageNumber="63">
<taxonomicNameLabel id="A2795790FF9FC930FDB8FEADFD01FE82" box="[541,655,295,321]" pageId="62" pageNumber="63" rank="species">spec. nov.</taxonomicNameLabel>
</emphasis>
and 
<taxonomicName id="4C3E4D7AFF9FC930FD63FEADFCA5FE82" authority="Rheims &amp; Jäger, 2022" authorityName="Rheims &amp; Jäger" authorityYear="2022" box="[710,811,295,321]" class="Arachnida" family="Sparassidae" genus="Meri" kingdom="Animalia" order="Araneae" pageId="62" pageNumber="63" phylum="Arthropoda" rank="species" species="zeteki" status="spec. nov.">
<emphasis id="B94AEAEBFF9FC930FD63FEADFCA5FE82" box="[710,811,295,321]" italics="true" pageId="62" pageNumber="63">M. zeteki</emphasis>
</taxonomicName>
<emphasis id="B94AEAEBFF9FC930FC97FEADFC2AFE82" bold="true" box="[818,932,295,321]" pageId="62" pageNumber="63">
<taxonomicNameLabel id="A2795790FF9FC930FC97FEADFC2AFE82" box="[818,932,295,321]" pageId="62" pageNumber="63" rank="species">spec. nov.</taxonomicNameLabel>
</emphasis>
). Males were not located.
</paragraph>
</subSubSection>
<subSubSection id="C3246572FF9FC930FF62FEC0FC8DFE12" pageId="62" pageNumber="63" type="description">
<paragraph id="8B8136F9FF9FC930FF62FEC0FD99FEA6" blockId="62.[151,1437,150,501]" box="[199,535,330,357]" pageId="62" pageNumber="63">
<emphasis id="B94AEAEBFF9FC930FF62FEC0FED7FEA7" bold="true" box="[199,345,330,356]" pageId="62" pageNumber="63">Description.</emphasis>
See 
<bibRefCitation id="EFAF4B08FF9FC930FE2AFEC1FD99FEA6" author="Simon, E." box="[399,535,331,357]" pageId="62" pageNumber="63" pagination="860 - 890" refId="ref51914" refString="Simon, E. (1898) On the spiders of the island of St Vincent. III. Proceedings of the Zoological Society of London, 65, 860 - 890. https: // doi. org / 10.1111 / j. 1096 - 3642.1898. tb 01390. x" type="journal article" year="1898">Simon 1898</bibRefCitation>
</paragraph>
<paragraph id="8B8136F9FF9FC930FF62FEE4FC8DFE12" blockId="62.[151,1437,150,501]" pageId="62" pageNumber="63">
<emphasis id="B94AEAEBFF9FC930FF62FEE4FE52FE4B" bold="true" box="[199,476,366,392]" pageId="62" pageNumber="63">Additional description.</emphasis>
Epigyne: EF slightly wider than long; MAB long and narrow; MS longer than wide; EP triangular, as wide as long (
<figureCitation id="13052A7CFF9FC930FE52FE19FDD5FE6E" box="[503,603,402,429]" captionStart="FIGURES 250–252" captionStartId="61.[151,264,1938,1962]" captionTargetBox="[189,1403,1171,1906]" captionTargetId="figure-364@61.[181,1406,1166,1915]" captionTargetPageId="61" captionText="FIGURES 250–252. Meri sanctivincenti (Simon) comb. nov., female (250 epigyne, 251 vulva, 252 schematic course of internal duct system). EP—epigynal pocket; ft—first turn of duct system; FD—fertilization duct; GP—glandular projection; LL—lateral lobe; MS—median septum; SP—spermathecae. Scale line: 1 mm. Modified from Jäger 2020 (94: figs 349–351)." figureDoi="http://doi.org/10.5281/zenodo.6550498" httpUri="https://zenodo.org/record/6550498/files/figure.png" pageId="62" pageNumber="63">Fig. 250</figureCitation>
). Vulva: internal ducts with FW sinuous, posteriad; GP arising from ducts at first turn, anteriad; FD antero laterad (figs 251–252).
</paragraph>
</subSubSection>
<subSubSection id="C3246572FF9FC930FF62FE50FCE4FE36" box="[199,874,474,501]" pageId="62" pageNumber="63" type="distribution">
<paragraph id="8B8136F9FF9FC930FF62FE50FCE4FE36" blockId="62.[151,1437,150,501]" box="[199,874,474,501]" pageId="62" pageNumber="63">
<emphasis id="B94AEAEBFF9FC930FF62FE50FEEFFE37" bold="true" box="[199,353,474,500]" pageId="62" pageNumber="63">Distribution.</emphasis>
Only known from the 
<typeStatus id="5485885BFF9FC930FDC5FE51FD1EFE36" box="[608,656,475,501]" pageId="62" pageNumber="63">type</typeStatus>
locality (
<figureCitation id="13052A7CFF9FC930FD5EFE51FCD3FE36" box="[763,861,474,501]" captionStart="FIGURES 315–318" captionStartId="76.[151,264,1371,1395]" captionTargetBox="[156,1431,489,1348]" captionTargetId="figure-159@76.[156,1431,489,1348]" captionTargetPageId="76" captionText="FIGURES 315–318. Distribution maps for species of Meri gen. nov. 315 (M. martinique spec. nov., M. sanctivincenti (Simon) comb. nov., M. trinitatis (Strand) comb. nov., M. carabobo spec. nov., M. kaieteur spec. nov.); 316 (M. jaraua spec. nov., M. arraijan spec. nov., M. formosus (Banks) comb. nov., M. guri spec. nov., M. tumatumari spec. nov.); 317 (M. zeteki spec. nov., M. manaos spec. nov., M. yaciba spec. nov., M. tapirapeco spec. nov., M. abuna spec. nov.); 318 (M. mathani (Simon) comb. nov., M. pictitarsis (Simon) comb. nov., M. conduri spec. nov., M. paiaia spec. nov., M. tambor spec. nov.);" figureDoi="http://doi.org/10.5281/zenodo.6550426" httpUri="https://zenodo.org/record/6550426/files/figure.png" pageId="62" pageNumber="63">Fig. 315</figureCitation>
).
</paragraph>
</subSubSection>
