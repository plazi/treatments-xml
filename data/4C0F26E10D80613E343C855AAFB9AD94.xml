<paragraph id="31FD49CCAF21B2AC55DAE2C20C588A17" pageId="null" pageNumber="516">
<taxonomicName id="1BCC3226A936FDFDDAFA64C5D3BB5458" authority="Viv." class="Magnoliopsida" family="Fabaceae" genus="Trifolium" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="516" phylum="Tracheophyta" rank="species" species="nigrescens">
Trifolium 
<normalizedToken id="2B4048770EC991EAEE9358D22067934B" originalValue="nigréscens" pageId="null" pageNumber="516">nigrescens</normalizedToken>
Viv.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="9540AFC906631E229F3D8E1C649378A8" pageId="null" pageNumber="516" type="vernacular_names">
<paragraph id="04476DC7D564822B00FC2AF152A94CD3" pageId="null" pageNumber="516">Schwarzwerdender Klee</paragraph>
</subSubSection>
</title>
<subSubSection id="23D6203D9F7C5AB928FDD83BB53467C1" pageId="null" pageNumber="516" type="description">
<paragraph id="C2BB91150ABBE1CA4D3B880687A62ACB" pageId="null" pageNumber="516">
1 
<normalizedToken id="4A0C417CD11C90007A8097D8AE9D9F0F" originalValue="jährig" pageId="null" pageNumber="516">jaehrig</normalizedToken>
; 5-30 cm hoch. Stengel meist niederliegend, oft verzweigt, meist kahl. 
<normalizedToken id="5A00B709ADD489D75A94A5D627787C26" originalValue="Teilblätter" pageId="null" pageNumber="516">Teilblaetter</normalizedToken>
1-2mal so lang wie breit, 
<emphasis id="99211010E1D6C7BD33AF8DF4E8584341" italics="true" pageId="null" pageNumber="516">bis 1 cm lang, vorn meist ausgerandet</emphasis>
, fein 
<normalizedToken id="25632678C04C1434A15EAAC4F2EFCB12" originalValue="gezähnt" pageId="null" pageNumber="516">gezaehnt</normalizedToken>
, mit der 
<normalizedToken id="A22752C450FA6F758685A38B4DA710EF" originalValue="größten" pageId="null" pageNumber="516">groessten</normalizedToken>
Breite oberhalb der Mitte, oft mit schwarzen Flecken, kahl. 
<normalizedToken id="9142B3251BC7243B5F2CC7B7B00E6427" originalValue="Nebenblätter" pageId="null" pageNumber="516">Nebenblaetter</normalizedToken>
wie bei 
<taxonomicName id="807BB4BB9DE9DDB8683335EBB08C0886" class="Magnoliopsida" family="Fabaceae" genus="Trifolium" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="516" phylum="Tracheophyta" rank="species" species="hybridum">
<emphasis id="98247F6CBE6D5ADD0A2ED3212AD73D55" italics="true" pageId="null" pageNumber="516">T. hybridum</emphasis>
</taxonomicName>
(Nr. 9). 
<normalizedToken id="42BCCEEAD507EF6393F964AF67A02E7D" originalValue="Blütenstände" pageId="null" pageNumber="516">Bluetenstaende</normalizedToken>
kugelig, 
<normalizedToken id="F8C6B5CD7B84DF5298C3F6284770B590" originalValue="vielblütig" pageId="null" pageNumber="516">vielbluetig</normalizedToken>
, 1-2 cm im Durchmesser, einzeln in den Achseln der obern 
<normalizedToken id="B734C1F16F33C5EE34B0125C53BEF8C7" originalValue="Stengelblätter" pageId="null" pageNumber="516">Stengelblaetter</normalizedToken>
oder am Ende der Zweige, auf langen, aufrechten oder aufsteigenden Stielen. 
<normalizedToken id="4A1FFB583D1AA543123D3CFC2299E652" originalValue="Blüten" pageId="null" pageNumber="516">Blueten</normalizedToken>
gestielt; 
<normalizedToken id="60AE415F50E2EFBA4A0E88A4EA8A4289" originalValue="Blütenstiele" pageId="null" pageNumber="516">Bluetenstiele</normalizedToken>
(besonders die obern) meist 
<normalizedToken id="52519C0043BFD97A1DDC1B477D787FCA" originalValue="länger" pageId="null" pageNumber="516">laenger</normalizedToken>
als die 
<normalizedToken id="98CA3159F5C383671E97F14A22BFDF1A" originalValue="Kelchröhre" pageId="null" pageNumber="516">Kelchroehre</normalizedToken>
, 
<emphasis id="4597B1D7115B1E1C84FF35C4F1B568E2" italics="true" pageId="null" pageNumber="516">
<normalizedToken id="24BF379E15FAF728634814AF5F5B2545" originalValue="völlig" pageId="null" pageNumber="516">voellig</normalizedToken>
kahl. 
<normalizedToken id="D21CC822EC117F60DD840201AAF09C00" originalValue="Kelchröhre" pageId="null" pageNumber="516">Kelchroehre</normalizedToken>
10nervig
</emphasis>
, fast kahl; Kelchzipfel schmal 3eckig, die kleineren 
<normalizedToken id="C192E0F751F3BD23C5F10EFEB69D0BC7" originalValue="kürzer" pageId="null" pageNumber="516">kuerzer</normalizedToken>
als die 
<normalizedToken id="1DD6BB5E263A49CDD15E0D38A285F98A" originalValue="Kelchröhre" pageId="null" pageNumber="516">Kelchroehre</normalizedToken>
. Krone 5-8 mm lang, 3-4mal so lang wie die 
<normalizedToken id="6CC13C09B1C5EDCB1747ED0031D3B01F" originalValue="Kelchröhre" pageId="null" pageNumber="516">Kelchroehre</normalizedToken>
, 
<emphasis id="1B40D72198732AFBB860FB569AA90935" italics="true" pageId="null" pageNumber="516">
<normalizedToken id="6E620A880527894B55A7618DE3006096" originalValue="weiß" pageId="null" pageNumber="516">weiss</normalizedToken>
</emphasis>
(selten gelblich oder rosa). - 
<normalizedToken id="DA1C72DFFABD45D8793C8F2655D8E30F" originalValue="Blüte" pageId="null" pageNumber="516">Bluete</normalizedToken>
: 
<normalizedToken id="69B9E9D170FE18E6319004AEED558290" originalValue="Frühling" pageId="null" pageNumber="516">Fruehling</normalizedToken>
und 
<normalizedToken id="B91C8E9909B72376E6B44C97C799B954" originalValue="früher" pageId="null" pageNumber="516">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="F93C13E6B77FB967E0CDCD54DD7FEE23" pageId="null" pageNumber="516">
<emphasis id="9D86306AA4E2A9510E0086333B90BC04" italics="true" pageId="null" pageNumber="516">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="9B1099D207DED78E5558B6BFEEC597ED" italics="true" pageId="null" pageNumber="516">16:</emphasis>
Material von Samenstationen (Brewbaker 1955), aus Portugal (Rodrigues 1953), aus Italien (Larsen 1956a). Die Art ist selbststeril (Brewbaker 1955).
</paragraph>
<paragraph id="95C583F753037E262B6DE6ABAFF14F3F" pageId="null" pageNumber="516">
<emphasis id="F2F7386A629927882CEBC28019FEA231" italics="true" pageId="null" pageNumber="516">Standort.</emphasis>
Kollin. Trockene, sandige 
<normalizedToken id="8BF8FCCCD995864A3A23C798E038CD61" originalValue="Böden" pageId="null" pageNumber="516">Boeden</normalizedToken>
in warmen Lagen. Sonnige 
<normalizedToken id="A6B5287ADF54A061EE4CC8260B5C2E39" originalValue="Hänge" pageId="null" pageNumber="516">Haenge</normalizedToken>
, 
<normalizedToken id="ED6BFC93D44D607D542EE64FBD3C4DE5" originalValue="Grasplätze" pageId="null" pageNumber="516">Grasplaetze</normalizedToken>
, Schuttstellen.
</paragraph>
<paragraph id="59E88B50614684836947C38C5C0686F9" pageId="null" pageNumber="516">
<emphasis id="6C09BE3679B20C4E57B247E74F9D2A10" italics="true" pageId="null" pageNumber="516">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="8E4F54AB8740C0354E5E92C8AC8A7DFA" originalValue="Südeuropa" pageId="null" pageNumber="516">Suedeuropa</normalizedToken>
(
<normalizedToken id="3EC386DDF9D022F986565D5941743853" originalValue="nordwärts" pageId="null" pageNumber="516">nordwaerts</normalizedToken>
bis 
<normalizedToken id="6D8ED314E444271D533054C57D211382" originalValue="Südfrankreich" pageId="null" pageNumber="516">Suedfrankreich</normalizedToken>
, Alpen, Bulgarien); Kleinasien, Syrien; Nordwestafrika. - Im Gebiet: Aostatal (Ivrea, Aymaville), 
<normalizedToken id="85EA5DDB23F54BCC13E1B8CC8C6CF783" originalValue="südliche" pageId="null" pageNumber="516">suedliche</normalizedToken>
Bergamasker Alpen (Valle Caleppio); sonst selten adventiv.
</paragraph>
</subSubSection>
