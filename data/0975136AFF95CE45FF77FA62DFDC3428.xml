<taxonomicName id="46DCD9FFFF95CE45FCA4F9A0D89C3AA4" authorityName="Rios-Tamayo &amp; Goloboff" authorityYear="2018" box="[859,975,1649,1675]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="24" pageNumber="25" phylum="Arthropoda" rank="species" species="taragui">
<emphasis id="B3A87E6EFF95CE45FCA4F9A0D89C3AA4" box="[859,975,1649,1675]" italics="true" pageId="24" pageNumber="25">A. taragui</emphasis>
</taxonomicName>
(
<bibRefCitation id="E54DDF8DFF95CE45FC1FF9A1DE003AA4" author="Rios-Tamayo, D. &amp; Goloboff, P. A." box="[992,1363,1648,1674]" pageId="24" pageNumber="25" pagination="1 - 83" refId="ref140496" refString="Rios-Tamayo, D. &amp; Goloboff, P. A. (2018) Taxonomic revision and morphology of the trapdoor spider genus Actinopus (Mygalomorphae: Actinopodidae) in Argentina. Bulletin of the American Museum of Natural History, 419, 1 - 83. https: // doi. org / 10.1206 / 0003 - 0090 - 419.1.1" type="journal article" year="2018">Ríos-Tamayo &amp; Goloboff, 2018</bibRefCitation>
