<subSubSection id="3EF3C48455D50C58250CF69AC92A3C31" pageId="null" pageNumber="356" type="description">
<paragraph id="457E970FDD9C89F62E678674292E80C7" lastPageNumber="355" pageId="null" pageNumber="356">
2-5 
<normalizedToken id="8AF0F2C323E640C824E1D21AF9AF70A0" originalValue="jährig" pageId="null" pageNumber="356">jaehrig</normalizedToken>
; 20-100 cm hoch. Stengel meist mehrmals verzweigt, 
<emphasis id="6E63E71C860C78476456F9B6DD3A3231" italics="true" pageId="null" pageNumber="356">
im untern Teil ziemlich dicht und meist 
<normalizedToken id="329A3437FC7691CA5A1FBC58ADD7D324" originalValue="rückwärts" pageId="null" pageNumber="356">rueckwaerts</normalizedToken>
abstehend behaart
</emphasis>
(Haare 0,3-1 mm lang). 
<normalizedToken id="0FEAEC3710A04C0EFB382660569D1A72" originalValue="Grundständige" pageId="null" pageNumber="356">Grundstaendige</normalizedToken>
<normalizedToken id="6B626C803EFAA36A12E44FEB588D1A02" originalValue="Blätter" pageId="null" pageNumber="356">Blaetter</normalizedToken>
und unterstes Stengelblattpaar meist fiederteilig, am Rande und auf den Nerven sowie 
<emphasis id="7F75D8B8A5DD50670E92D147759EAA94" italics="true" pageId="null" pageNumber="356">gegen den Grund zu auf der Unterseite des Blattstiels behaart</emphasis>
(Haare 0,4-0,8 mm lang), sonst behaart oder fast kahl, 
<pageBreakToken id="5D86DB9F1011AAA6FB1D91B1BE0DC50F" pageId="null" pageNumber="355" start="start">matt</pageBreakToken>
; 
<emphasis id="F3031430FE9CC24B1E981ADAE54B3C87" italics="true" pageId="null" pageNumber="355">
die mittleren 
<normalizedToken id="A7F43FA152DBD661F950A9FD5528B488" originalValue="Stengelblätter" pageId="null" pageNumber="355">Stengelblaetter</normalizedToken>
2
</emphasis>
- 
<emphasis id="4030E3289F0EEAE47FADCD7EEF0DCF7D" italics="true" pageId="null" pageNumber="355">3fach fiederteilig, mit 0,5</emphasis>
- 
<emphasis id="E39EF2ABF0EC25630E177C60CC66793D" italics="true" pageId="null" pageNumber="355">1,8 mm breiten Zipfeln;</emphasis>
Endzipfel 
<normalizedToken id="9526B3B91ED7C372EF1A3B0C9890E218" originalValue="höchstens" pageId="null" pageNumber="355">hoechstens</normalizedToken>
<normalizedToken id="EB4AE66B3DCEF2564B520F234FF136F5" originalValue="1½" pageId="null" pageNumber="355">11/2</normalizedToken>
mal so breit wie die seitlichen. 
<normalizedToken id="90821017EB3A8BA601F9BA7848FC634E" originalValue="Köpfe" pageId="null" pageNumber="355">Koepfe</normalizedToken>
1,5-3 cm im Durchmesser. 
<normalizedToken id="ECCF9DEE831CBECA3809F3546D5D321F" originalValue="Hüllblätter" pageId="null" pageNumber="355">Huellblaetter</normalizedToken>
<normalizedToken id="5D2D77F2305CFB8D635316997284F31D" originalValue="½-1¼" pageId="null" pageNumber="355">1/2-11/4</normalizedToken>
so lang wie die 
<normalizedToken id="88C886D70227063C36061E86B24261C0" originalValue="äußern" pageId="null" pageNumber="355">aeussern</normalizedToken>
<normalizedToken id="B72AA1C4D69BF9F516737F11FD4AEBFA" originalValue="Blüten" pageId="null" pageNumber="355">Blueten</normalizedToken>
. 
<normalizedToken id="85BD5300F83E2224BE20E72D62A79EA6" originalValue="Blütenkopfstiele" pageId="null" pageNumber="355">Bluetenkopfstiele</normalizedToken>
meist 
<normalizedToken id="FE57E500C0F6005E3268CC637094EE08" originalValue="kürzer" pageId="null" pageNumber="355">kuerzer</normalizedToken>
als der Rest des Stengels. 
<normalizedToken id="DBBA3374727D8803883C14A0E44048E5" originalValue="Blüten" pageId="null" pageNumber="355">Blueten</normalizedToken>
lila. 
<emphasis id="BC23CE25B98B9569CBC72820175AE514" italics="true" pageId="null" pageNumber="355">Kelchborsten 1</emphasis>
- 
<emphasis id="1D6515DEFE33EA75F40433C1BB8A7C8F" italics="true" pageId="null" pageNumber="355">3 mm lang</emphasis>
(selten nicht vorhanden), am Grunde 0,08-0,15 mm breit, stielrund, nicht gekielt, 
<emphasis id="41341DB3B92886D101926A469D22C254" italics="true" pageId="null" pageNumber="355">hell- bis dunkelbraun.</emphasis>
- 
<normalizedToken id="837D454A82E5064A474AA14337AD2EB7" originalValue="Blüte" pageId="null" pageNumber="355">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="400AB30976F5CBE16260BCB9E03162E6" pageId="null" pageNumber="356">
<emphasis id="1FCF0F53D2D624A49727FA9E2A3CCBB7" italics="true" pageId="null" pageNumber="356">
<pageBreakToken id="898C24226D2839711EAD55E2F6195C1A" pageId="null" pageNumber="356">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="FCAA4EB8BF309B1170CCE69B47C72FB3" italics="true" pageId="null" pageNumber="356">16:</emphasis>
Material aus botanischen 
<normalizedToken id="508D0339BFD8706CBD6C5B749F8BA67B" originalValue="Gärten" pageId="null" pageNumber="356">Gaerten</normalizedToken>
(Risse 1928, Kachidze 1929, Frey 1970), 
<taxonomicName id="2DB3FC50BCB9D2B59708668C0E3B126D" authority="R. Lit." authorityName="R. Lit." pageId="null" pageNumber="356" rank="variety" variety="corsica">
var. 
<emphasis id="994B134FB2DAAFD347BF3E55A88D609F" italics="true" pageId="null" pageNumber="356">corsica</emphasis>
R. Lit.
</taxonomicName>
aus Korsika (Contandriopoulos 1964), von Martigny im Wallis (Grossmann 
<normalizedToken id="1741275E66219F6B697A212A4E203F4F" originalValue="unveröffentlicht" pageId="null" pageNumber="356">unveroeffentlicht</normalizedToken>
).
</paragraph>
<paragraph id="B9D3EC9A9BBA734420EC20AAF1F822B9" pageId="null" pageNumber="356">
<emphasis id="7122F65568DFEFF6CA83580DB3A432C5" italics="true" pageId="null" pageNumber="356">Standort.</emphasis>
Kollin und montan, selten subalpin. Trockene, lockere 
<normalizedToken id="106CD1CC7CC5070EFF83170421519BEC" originalValue="Böden" pageId="null" pageNumber="356">Boeden</normalizedToken>
in warmen Lagen. Lichte 
<normalizedToken id="C9D490F6A9A8202E98E578D3EC7AF5D0" originalValue="Föhrenwälder" pageId="null" pageNumber="356">Foehrenwaelder</normalizedToken>
, Felsensteppen, Trockenwiesen.
</paragraph>
<paragraph id="54E5B751B6267ABCBCB855B933F5726D" pageId="null" pageNumber="356">
<emphasis id="8F3614D3AD74763412167AE1479150E8" italics="true" pageId="null" pageNumber="356">
Verbreitung. 
<normalizedToken id="29E1BD5A7A169B2EEEF29B5872929F5A" originalValue="Südeuropäische" pageId="null" pageNumber="356">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="E1ACF53C941D93A9B24B7AD4EB9EAF19" originalValue="Nordwärts" pageId="null" pageNumber="356">Nordwaerts</normalizedToken>
bis Lyon, Alpen, Karpaten; 
<normalizedToken id="D3169DE3F125DD31848E69478204BF62" originalValue="ostwärts" pageId="null" pageNumber="356">ostwaerts</normalizedToken>
bis Westbulgarien. - Im Gebiet: Savoyen, zentralalpine 
<normalizedToken id="B6B5678A318BE3EB6731448701734A68" originalValue="Täler" pageId="null" pageNumber="356">Taeler</normalizedToken>
(oft nur in 
<normalizedToken id="357DCF8A3B92619FD3D1DB838E711127" originalValue="Übergangsformen" pageId="null" pageNumber="356">Uebergangsformen</normalizedToken>
zu 
<taxonomicName id="0FF7BCCE127A50522A5EBCCD6F387A7E" class="Magnoliopsida" family="Caprifoliaceae" genus="Scabiosa" kingdom="Plantae" order="Dipsacales" pageId="null" pageNumber="356" phylum="Tracheophyta" rank="species" species="columbaria">
<emphasis id="86755E57BCB87BFED5193082CDCB1A6E" italics="true" pageId="null" pageNumber="356">S. columbaria</emphasis>
</taxonomicName>
), nicht 
<normalizedToken id="4BBFC9ED79D2C37858785BC101683E90" originalValue="häufig" pageId="null" pageNumber="356">haeufig</normalizedToken>
; 
<normalizedToken id="4EE0BB625D9364A67C355240D69D2D08" originalValue="Südalpen" pageId="null" pageNumber="356">Suedalpen</normalizedToken>
, selten (z. B. Gegend des Iseosees).
</paragraph>
</subSubSection>
