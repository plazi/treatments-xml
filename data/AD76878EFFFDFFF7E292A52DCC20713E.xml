. 
<taxonomicName id="E2DF4D1BFFFAFFF6E32CA5FCCC8A73D8" authority="(Cockerell, 1914)" baseAuthorityName="Cockerell" baseAuthorityYear="1914" box="[297,714,1946,1970]" class="Insecta" family="Chrysopidae" genus="Lithochrysa" kingdom="Animalia" order="Neuroptera" pageId="20" pageNumber="321" phylum="Arthropoda" rank="species" species="wickhami">
<emphasis id="17ABEA8AFFFAFFF6E32CA5FCCC4B73D8" box="[297,523,1946,1970]" italics="true" pageId="20" pageNumber="321">Lithochrysa wickhami</emphasis>
(
<bibRefCitation id="414E4B69FFFAFFF6E01FA5FCCC8373D8" author="Cockerell, T. D. A." box="[538,707,1946,1970]" pageId="20" pageNumber="321" pagination="714 - 724" refId="ref23258" refString="Cockerell, T. D. A. (1914) New and little-known insects from the Miocene of Florissant, Colorado. Journal of Geology, 22, 714 - 724. https: // doi. org / 10.1086 / 622186" type="journal article" year="1914">Cockerell, 1914</bibRefCitation>
