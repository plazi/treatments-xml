<typeStatus id="4E66882AFFE1FFCDFC66E8CDFC14FD4B" box="[976,1020,728,749]" pageId="20" pageNumber="1499">type</typeStatus>
locality in 
<collectingCountry id="E9CA7618FFE1FFCDFF5BE8E1FEAFFCAC" box="[237,327,756,778]" name="Thailand" pageId="20" pageNumber="1499">Thailand</collectingCountry>
(
<figureCitation id="09E62A0DFFE1FFCDFEE3E8E1FE71FCAC" box="[341,409,756,778]" captionStart="Map 3" captionStartId="17.[178,223,1423,1443]" captionTargetBox="[178,1085,552,1406]" captionTargetId="figure-217@17.[178,1085,552,1406]" captionTargetPageId="17" captionText="Map 3: Distributions of Micrillus indicus (EPPELSHEIM) (triangles), M. nigriceps (CAMERON) (diamonds), M. intermedius (CAMERON) (open and filled circles), and M. siamensis nov.sp. (filled circle) in the Oriental region, based on examined records." figureDoi="http://doi.org/10.5281/zenodo.6512094" httpUri="https://zenodo.org/record/6512094/files/figure.png" pageId="20" pageNumber="1499">Map 3</figureCitation>
