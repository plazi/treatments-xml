<subSubSection pageId="0" pageNumber="77" type="etymology">
<paragraph pageId="0" pageNumber="77">Etymology.</paragraph>
<paragraph pageId="0" pageNumber="77">
The specific epithet 
<taxonomicName authorityName="Chae &amp; Lee &amp; Kim" authorityYear="2022" class="Arachnida" family="Sparassidae" genus="Sinopoda" kingdom="Animalia" lsidName="Sinopoda bogil" order="Araneae" pageId="0" pageNumber="77" phylum="Arthropoda" rank="species" species="bogil">
