<collectingRegion id="E20058913D5DFFBAFDBDFD8EFCCDFDF7" box="[567,806,583,609]" country="Colombia" name="Risaralda" pageId="46" pageNumber="47">Risaralda department</collectingRegion>
(
<figureCitation id="B8FF8AF63D5DFFBAFCBFFD8EFC63FDF7" box="[821,904,583,609]" captionStart="FIGURE 33" captionStartId="59.[151,250,1943,1967]" captionTargetBox="[198,1395,187,1920]" captionTargetId="figure-18@59.[192,1395,181,1920]" captionTargetPageId="59" captionText="FIGURE 33. Distribution of species of the philipi group in Colombia." figureDoi="http://doi.org/10.5281/zenodo.4468455" httpUri="https://zenodo.org/record/4468455/files/figure.png" pageId="46" pageNumber="47">Fig. 33</figureCitation>
