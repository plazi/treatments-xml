<taxonomicName authority="Almeida &amp; Souza &amp; Menegola &amp; Sanner &amp; Vieira, 2014" authorityName="Almeida &amp; Souza &amp; Menegola &amp; Sanner &amp; Vieira" authorityYear="2014" box="[294,508,1546,1568]" class="Gymnolaemata" family="Colatooeciidae" genus="Cigclisula" kingdom="Animalia" order="Cheilostomatida" pageId="33" pageNumber="34" phylum="Bryozoa" rank="species" species="winstonae" status="n. sp.">
