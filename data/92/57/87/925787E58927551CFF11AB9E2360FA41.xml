<subSubSection pageId="5" pageNumber="562" type="diagnosis">
<paragraph blockId="5.[151,1437,546,1509]" pageId="5" pageNumber="562">
<emphasis bold="true" box="[199,322,654,680]" pageId="5" pageNumber="562">Diagnosis.</emphasis>
