<subSubSection box="[199,1399,1598,1625]" pageId="10" pageNumber="567" type="distribution">
<paragraph blockId="10.[151,1436,1598,1769]" box="[199,1399,1598,1625]" pageId="10" pageNumber="567">
<emphasis bold="true" box="[199,353,1598,1624]" pageId="10" pageNumber="567">Distribution.</emphasis>
Known from Nujiang and Dulongjiang valleys of Western 
<collectingRegion box="[1015,1104,1599,1625]" country="China" name="Yunnan" pageId="10" pageNumber="567">Yunnan</collectingRegion>
, P. R. 
<collectingCountry box="[1174,1241,1598,1624]" name="China" pageId="10" pageNumber="567">China</collectingCountry>
(
<figureCitation box="[1255,1342,1598,1624]" captionStart="FIGURES 62–67" captionStartId="14.[151,264,1875,1899]" captionTargetBox="[151,1435,181,1850]" captionTargetId="figure-24@14.[151,1435,181,1851]" captionTargetPageId="14" captionText="FIGURES 62–67. Habitats and living adult of Agalope spp. in P.R. China. 62, Pianma, Lushui, Western Yunnan; 63, Samage, Weixi, Northwestern Yunnan; 64, Gongshan, Nujiang Lisu Autonomous Prefecture, Western Yunnan; 65, living adult of A. aurelia, resting on leaves, Gongshan; 66, Longgu Village, Chayu, Southeastern Xizang; 67, Taohuagou, Bomi, Southeastern Xizang." figureDoi="http://doi.org/10.5281/zenodo.6854108" httpUri="https://zenodo.org/record/6854108/files/figure.png" pageId="10" pageNumber="567">Figs 64</figureCitation>
, 
<figureCitation box="[1354,1386,1598,1624]" captionStart="FIGURES 68" captionStartId="15.[151,264,1790,1814]" captionTargetBox="[151,1435,1101,1767]" captionTargetId="figure-333@15.[151,1435,1101,1767]" captionTargetPageId="15" captionText="FIGURES 68. Distribution map of Agalope spp. in SE Asia." figureDoi="http://doi.org/10.5281/zenodo.6854112" httpUri="https://zenodo.org/record/6854112/files/figure.png" pageId="10" pageNumber="567">68</figureCitation>
