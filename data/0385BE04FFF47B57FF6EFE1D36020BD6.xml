<subSubSection id="C3365C99FFF47B57FF08FDA436020BD6" pageId="15" pageNumber="1116" type="discussion">
<paragraph id="8B930F12FFF47B57FF08FDA436020BD6" blockId="15.[168,775,434,679]" pageId="15" pageNumber="1116">
<emphasis id="B958D300FFF47B57FF08FDA434F70B15" inLineHeading="true" pageId="15" pageNumber="1116" reason="1">
<emphasis id="B958D300FFF47B57FF08FDA435120B32" bold="true" box="[206,316,555,579]" pageId="15" pageNumber="1116">Remarks.</emphasis>
This species is similar to 
<taxonomicName id="4C2C7491FFF47B57FD9AFDA534F70B15" baseAuthorityName="Walker" baseAuthorityYear="1858" class="Insecta" family="Noctuidae" genus="Ophiusa" kingdom="Animalia" order="Lepidoptera" pageId="15" pageNumber="1116" phylum="Arthropoda" rank="species" species="disjungens">
<emphasis id="B958D300FFF47B57FD9AFDA534F70B15" italics="true" pageId="15" pageNumber="1116">Ophiusa disjungens</emphasis>
</taxonomicName>
</emphasis>
but abdomen orange with a black dorsal patch near extremity. Hindwing with black band broad in 
<taxonomicName id="4C2C7491FFF47B57FD5AFDE134F70BD6" baseAuthorityName="Walker" baseAuthorityYear="1858" class="Insecta" family="Noctuidae" genus="Ophiusa" kingdom="Animalia" order="Lepidoptera" pageId="15" pageNumber="1116" phylum="Arthropoda" rank="species" species="disjungens">
<emphasis id="B958D300FFF47B57FD5AFDE134F70BD6" italics="true" pageId="15" pageNumber="1116">O. disjungens</emphasis>
</taxonomicName>
and narrow in 
<taxonomicName id="4C2C7491FFF47B57FEBCFD00360B0BD6" authorityName="Walker" authorityYear="1858" box="[378,549,655,679]" class="Insecta" family="Noctuidae" genus="Anua" kingdom="Animalia" order="Lepidoptera" pageId="15" pageNumber="1116" phylum="Arthropoda" rank="species" species="discriminans">
<emphasis id="B958D300FFF47B57FEBCFD00360B0BD6" box="[378,549,655,679]" italics="true" pageId="15" pageNumber="1116">O. discriminans</emphasis>
</taxonomicName>
.
</paragraph>
