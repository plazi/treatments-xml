<taxonomicName id="BCF14D0E2100FF94B1DCFBA98944FBE5" authorityName="ASSING" authorityYear="2012" box="[163,276,1103,1124]" class="Insecta" family="Staphylinidae" genus="Lobrathium" kingdom="Animalia" order="Coleoptera" pageId="7" pageNumber="198" phylum="Arthropoda" rank="species" species="taureum">
