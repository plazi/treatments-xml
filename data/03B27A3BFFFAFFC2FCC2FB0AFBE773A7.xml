<paragraph id="8BA4CB2DFFFAFFC2FCABFA4AFBE773A7" blockId="6.[811,1457,1462,1744]" pageId="6" pageNumber="119">
<bibRefCitation id="EF8AB6DCFFFAFFC2FCABFA4AFBE77099" author="LECOMTE H." box="[813,1037,1494,1521]" pageId="6" pageNumber="119" pagination="915 - 978" refId="ref13275" refString="LECOMTE H. 1930. - Ebenacees, in LECOMTE H. &amp; HUMBERT H. (eds), Flore generale de l'Indo-Chine. Vol. 3. Masson &amp; Co., Paris: 915 - 978. https: // www. biodiversitylibrary. org / page / 27563332" type="book chapter" year="1930">Lecomte (1930: 925)</bibRefCitation>
only cited the collection of 
<emphasis id="B96F173FFFFAFFC2FAAAFA4AFA9E7098" box="[1324,1396,1494,1520]" italics="true" pageId="6" pageNumber="119">Béjaud</emphasis>
from 
