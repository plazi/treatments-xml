<taxonomicName id="4C1BB0AEFFFAFFC2FA13F9EAFC7E73C7" class="Magnoliopsida" family="Ebenaceae" genus="Diospyros" kingdom="Plantae" order="Ericales" pageId="6" pageNumber="119" phylum="Tracheophyta" rank="species" species="ehretioides">
