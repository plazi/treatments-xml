, 
<materialsCitation id="74FC3CA3FF526AEDF6469B0D1880B6A8" ID-GBIF-Occurrence="3783319562" pageId="169" pageNumber="931">
“Teapa, 
<collectingRegion id="0650F81CFF526AEDFA8F9BD81BEBB6A8" box="[1395,1515,3457,3482]" country="Mexico" name="Tabasco" pageId="169" pageNumber="931">Tabasco</collectingRegion>
