<caption id="DF1341EFFFC3FFF7FAD7519C506AF622" ID-DOI="http://doi.org/10.5281/zenodo.6623884" ID-Zenodo-Dep="6623884" box="[1387,2571,2453,2486]" httpUri="https://zenodo.org/record/6623884/files/figure.png" inLine="true" pageId="46" pageNumber="598" startId="46.[1387,1559,2453,2486]" targetBox="[1383,1975,1989,2404]" targetPageId="46">
