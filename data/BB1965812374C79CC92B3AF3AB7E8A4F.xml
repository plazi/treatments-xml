<td id="323577BBA3C64814C4D6CB0D8C82267B" align="left" pageId="null" pageNumber="831" valign="top">2. Stengel, Blattstiele und Blattnerven auf der Blattunterseite mit Borstenhaaren</td>
<td id="5556510E0589F1915062E185D68CF4A2" align="left" pageId="null" pageNumber="831" valign="bottom">
<taxonomicName id="5986C953FD542B153FCBEF11C9D16C4F" class="Magnoliopsida" family="Apiaceae" genus="Chaerophyllum" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="831" phylum="Tracheophyta" rank="species" species="villarsii">
<italic id="B7B0B4700A25B5814494C1E7649CB2A3" pageId="null" pageNumber="831">Ch. Villarsii</italic>
</taxonomicName>
(Nr. 1a)
