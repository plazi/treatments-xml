</tr>
<tr id="93BE6AA4518F8C5ADCA28E809F6E39C1" pageId="null" pageNumber="831">
<td id="BF2EEA00B49C66A721FA1F041EDAB1EB" align="left" pageId="null" pageNumber="831" valign="top">
2*. 
<normalizedToken id="01AF8DCA83E92782308D5C38DBFE7782" originalValue="Blätter" pageId="null" pageNumber="831">Blaetter</normalizedToken>
unterseits mit weicher und flaumiger Behaarung; auf den Hauptnerven 2 
<normalizedToken id="1BA3F27881F75ACFAA9A4E99281BAF83" originalValue="weiße" pageId="null" pageNumber="831">weisse</normalizedToken>
Streifen mit flaumigen Haaren, zwischen denen auch Borstenhaare vorhanden sein 
<normalizedToken id="C9AE0F2407E836CEAB6E0CCCA9382445" originalValue="können" pageId="null" pageNumber="831">koennen</normalizedToken>
</td>
<td id="0BC90791AE273F72E789EA780ED99C9A" align="left" pageId="null" pageNumber="831" valign="bottom">
<taxonomicName id="1573BC2DCFB094B7D07FA135473BD796" class="Magnoliopsida" family="Apiaceae" genus="Chaerophyllum" kingdom="Plantae" order="Apiales" pageId="null" pageNumber="831" phylum="Tracheophyta" rank="species" species="elegans">
<italic id="97F8A7AB9BF72965520B1B2FEE928F9C" pageId="null" pageNumber="831">Ch. elegans</italic>
