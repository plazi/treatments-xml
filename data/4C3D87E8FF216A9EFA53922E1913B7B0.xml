<treatmentCitation id="453510EFFF216A9EF7F393101704BE54" box="[2063,2308,1353,1382]" pageId="218" pageNumber="980">Juste et al, 2019</treatmentCitation>
, 
<materialsCitation id="74FC3CA3FF216A9EF6E793101781BE87" ID-GBIF-Occurrence="3783319783" latitude="42.0" longitude="-5.3258333" pageId="218" pageNumber="980">
