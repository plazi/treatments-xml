<subSubSection id="2ED884BE3EBCAE89714542F6D2B89D61" pageId="null" pageNumber="368" type="description">
<paragraph id="3CE3346379ABC7C6964DD02265D135B9" pageId="null" pageNumber="368">
<emphasis id="E80769ABB92424DDCB9A63F3368DBFDF" italics="true" pageId="null" pageNumber="368">
Ausdauernd, mit 
<normalizedToken id="9FD69CFE66505ED589E454E39809F729" originalValue="Ausläufern" pageId="null" pageNumber="368">Auslaeufern</normalizedToken>
, mit 
<normalizedToken id="ED04304B666697F0D157E3007FD3BDB9" originalValue="überwinternden" pageId="null" pageNumber="368">ueberwinternden</normalizedToken>
, sterilen Blattrosetten
</emphasis>
und mit mehreren 
<normalizedToken id="105D9D37C197EBA655037C5D80E6CE60" originalValue="Blütenstengeln" pageId="null" pageNumber="368">Bluetenstengeln</normalizedToken>
; 25-60 cm hoch. Stengel aufrecht, meist einfach, im untern Teil 
<normalizedToken id="288D1840DCFA7D9EF4854DFE67568195" originalValue="beblättert" pageId="null" pageNumber="368">beblaettert</normalizedToken>
. 
<normalizedToken id="5764C56F69339FD89D4361B8B8132ED8" originalValue="Blätter" pageId="null" pageNumber="368">Blaetter</normalizedToken>
zerstreut behaart, schmal oval bis schmal lanzettlich, ganzrandig oder stumpf 
<normalizedToken id="0A850501E4D29C85CBB557D7A94ECC05" originalValue="gezähnt" pageId="null" pageNumber="368">gezaehnt</normalizedToken>
und 
<emphasis id="5EA1D11DB69C0C2DAC95217B61654C70" italics="true" pageId="null" pageNumber="368">nicht wellig.</emphasis>
<normalizedToken id="8FB79F93713E452A4CEDFEF96B6DE9E1" originalValue="Blüten" pageId="null" pageNumber="368">Blueten</normalizedToken>
in einem 
<normalizedToken id="8BF1BD1DC7225D965F666BC059B0F1BB" originalValue="endständigen" pageId="null" pageNumber="368">endstaendigen</normalizedToken>
, 2,5-3 cm dicken, kugeligen Kopf. 
<normalizedToken id="0A15A1B2125E6D2CDC468F7C7FC0E8DD" originalValue="Hüllblätter" pageId="null" pageNumber="368">Huellblaetter</normalizedToken>
im 
<normalizedToken id="F7B14FE21A0338C928FE428886F2D91D" originalValue="Umriß" pageId="null" pageNumber="368">Umriss</normalizedToken>
breit lanzettlich, grob 
<normalizedToken id="AE676B4CEB2B35798343B1E461626362" originalValue="gezähnt" pageId="null" pageNumber="368">gezaehnt</normalizedToken>
, am Grunde oft behaart. Krone 12-15 mm lang, blau. - 
<normalizedToken id="2307549131A4DD5323093533C8D3C1AE" originalValue="Blüte" pageId="null" pageNumber="368">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="2C6A43737911A481E5D9F78E08083CB7" pageId="null" pageNumber="368">
<emphasis id="131E09F524D379355D5FAA1C4676B8D6" italics="true" pageId="null" pageNumber="368">Zytologische Angaben 2n</emphasis>
= 
<emphasis id="D66EE5A4BA219D75CA2995BFEF5CE65D" italics="true" pageId="null" pageNumber="368">48:</emphasis>
Material aus Spanien (Podlech und Damboldt 1963). 
<emphasis id="F65786654D1FD5FBE2F3075616A351B6" italics="true" pageId="null" pageNumber="368">2n</emphasis>
= 
<emphasis id="1D5C3C7A7ED35D8647F24050EF2A07BE" italics="true" pageId="null" pageNumber="368">60:</emphasis>
Material ohne Herkunftsangabe (Rosen 1931). Favarger und 
<normalizedToken id="B86E11857F4BC8672905CB957F3EC354" originalValue="Küpfer" pageId="null" pageNumber="368">Kuepfer</normalizedToken>
(1968) 
<normalizedToken id="66396AC6F45E0828F4B7550BC16FA113" originalValue="zählten" pageId="null" pageNumber="368">zaehlten</normalizedToken>
in den 
<normalizedToken id="2A98B4E97ACB0B8EDD7BE8324917268A" originalValue="Ostpyrenäen" pageId="null" pageNumber="368">Ostpyrenaeen</normalizedToken>
an der 
<taxonomicName id="7E148402B4A60B5AA192C8A25325029C" pageId="null" pageNumber="368" rank="variety" variety="pygmaea">
var. 
<emphasis id="A48984A67D5C70874976ED5CE50F4CB5" italics="true" pageId="null" pageNumber="368">pygmaea</emphasis>
</taxonomicName>
G. et G. 
<emphasis id="31749535E8B864F17FC7864C3CFB310E" italics="true" pageId="null" pageNumber="368">2n</emphasis>
= 
<emphasis id="437B60BF27AF8B95BD17D9615F8BE82E" italics="true" pageId="null" pageNumber="368">12.</emphasis>
</paragraph>
<paragraph id="CC2FDF2C4AE311E7C101330B00CF9052" pageId="null" pageNumber="368">
<emphasis id="2C213076202347DCB9799C285F45FF85" italics="true" pageId="null" pageNumber="368">Standort.</emphasis>
Kollin. Kalkfreie, sandige, trockene 
<normalizedToken id="86BC6328155830B20843858EE904ED7A" originalValue="Böden" pageId="null" pageNumber="368">Boeden</normalizedToken>
in milden Lagen. Lichte 
<normalizedToken id="7490D884209B0A94CDE39FC7AC61E47D" originalValue="Wälder" pageId="null" pageNumber="368">Waelder</normalizedToken>
, buschige 
<normalizedToken id="25F122E02A719F974098A3BBA6AD4108" originalValue="Hänge" pageId="null" pageNumber="368">Haenge</normalizedToken>
, 
<normalizedToken id="9B1C6D375C624EC25D23E73FFCEA27D3" originalValue="Wegränder" pageId="null" pageNumber="368">Wegraender</normalizedToken>
.
</paragraph>
<paragraph id="5242B4F203742008AE6836E00B89C270" pageId="null" pageNumber="368">
<emphasis id="AF2E616C6B24E279C02C945B039342C0" italics="true" pageId="null" pageNumber="368">
Verbreitung. 
<normalizedToken id="6B670EB233014804508C27857CD125DF" originalValue="Westeuropäische" pageId="null" pageNumber="368">Westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Von Portugal 
<normalizedToken id="9101B37825FC2E987ADDE5B6FDD2EF47" originalValue="ostwärts" pageId="null" pageNumber="368">ostwaerts</normalizedToken>
bis Westdeutschland, unteres Rhonetal und Korsika. - Im Gebiet: Vogesen, Oberrheinische Tiefebene, Schwarzwald, Baar, 
<normalizedToken id="DD7BA45F8805CA79E61431DFFBE21D4C" originalValue="nördliches" pageId="null" pageNumber="368">noerdliches</normalizedToken>
Bodenseegebiet; ziemlich 
<normalizedToken id="ED6258E92398321277FCFDE33E53683F" originalValue="häufig" pageId="null" pageNumber="368">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
