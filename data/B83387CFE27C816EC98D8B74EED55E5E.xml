<specimenCount id="269CFD50E27C816FC98D8B9DEAD15C64" box="[166,181,1529,1552]" pageId="10" pageNumber="507" type="female">♀</specimenCount>
(
<collectorName id="9D6F530FE27C816FC9E98B9DEB445C7B" box="[194,288,1529,1551]" pageId="10" pageNumber="507">Shatalkin</collectorName>
) (
<collectionCode id="568BAE1CE27C816FC8198B9DEBE75C7B" box="[306,387,1529,1551]" collectionName="Russia, Moscow, Moscow State University" country="China" httpUri="http://grbio.org/cool/49rk-3jpq" name="Zoological Museum, University of Amoy" pageId="10" pageNumber="507">ZMUM</collectionCode>
