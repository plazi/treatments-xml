<subSubSection id="401724B4DA5CABC502C05ACF2B409E9F" pageId="null" pageNumber="234" type="description">
<paragraph id="FABD7E6A073F68E8FE666E466DE9826F" pageId="null" pageNumber="234">
30-80 cm hoch. 
<emphasis id="66B9BA1DA836E1DAEE8CE4091E0510BA" italics="true" pageId="null" pageNumber="234">
Stengel im untern Teil mit fast ungestielten, anliegenden, 
<normalizedToken id="349EE775AF92FB27039E5FA2089C1290" originalValue="kompaßnadelartigen" pageId="null" pageNumber="234">kompassnadelartigen</normalizedToken>
, 2
</emphasis>
(
<emphasis id="49E91916EF45B3498E10D6B8851F5CA1" italics="true" pageId="null" pageNumber="234">selten 3</emphasis>
- 
<emphasis id="08FDF698BA9FB86831982A62557030E5" italics="true" pageId="null" pageNumber="234">4</emphasis>
) 
<emphasis id="F3BC05BB3658B79A7BF400486C8BB3FC" italics="true" pageId="null" pageNumber="234">
strahligen Haaren, meist ohne 1fache Haare. 
<normalizedToken id="1E8A1B80D7DCEC2289DD744CF263B1CC" originalValue="Stengelblätter" pageId="null" pageNumber="234">Stengelblaetter</normalizedToken>
20-50, dicht stehend und einander bedeckend, mit 1-4 mm langen Zipfeln den Stengel umfassend und ihm anliegend
</emphasis>
, mit schmalen 
<normalizedToken id="FCFF1809FA1411506BE9D1C754DB0D43" originalValue="Zähnen" pageId="null" pageNumber="234">Zaehnen</normalizedToken>
, spitz, mit 
<normalizedToken id="4C98CA5D3B2CBDFCAC64A19296E21F3C" originalValue="kompaßnadelartigen" pageId="null" pageNumber="234">kompassnadelartigen</normalizedToken>
Haaren. 
<normalizedToken id="45299B7C8C095CCFAE6700655820F8E7" originalValue="Kelchblätter" pageId="null" pageNumber="234">Kelchblaetter</normalizedToken>
2-3 mm lang. 
<normalizedToken id="C1E86A56776868CB9DC65F4640BCF637" originalValue="Kronblätter" pageId="null" pageNumber="234">Kronblaetter</normalizedToken>
3,5-6 mm lang, 0,7-1,4 mm breit. 
<normalizedToken id="C940D4962BE651BD4E8E861596234D3D" originalValue="Früchte" pageId="null" pageNumber="234">Fruechte</normalizedToken>
30-55 mm lang und 
<emphasis id="B4E5025B416F7099BA23EE6DBEE44F6C" italics="true" pageId="null" pageNumber="234">0,6</emphasis>
- 
<emphasis id="3EB2ED4207B7BFE3BF4C535C64F6E22A" italics="true" pageId="null" pageNumber="234">1 mm breit, ohne deutliche Nerven</emphasis>
, die untern die 
<normalizedToken id="E260056168DAA0A669B5A0BEB70D4C2F" originalValue="Blüten" pageId="null" pageNumber="234">Blueten</normalizedToken>
kaum 
<normalizedToken id="57230920103CD0994CAA433502D3D597" originalValue="überragend" pageId="null" pageNumber="234">ueberragend</normalizedToken>
. Samen 0,8-1,1 mm lang, mit kaum 0,1 mm breitem Rand. - 
<normalizedToken id="5FADDEFD9337DA786C2237FD8315E0A9" originalValue="Blüte" pageId="null" pageNumber="234">Bluete</normalizedToken>
: 
<normalizedToken id="D22E42B5CE51B5B4C6562228C65611AA" originalValue="Später" pageId="null" pageNumber="234">Spaeter</normalizedToken>
<normalizedToken id="8547216386DFFEEDCF7A18FC8346D455" originalValue="Frühling" pageId="null" pageNumber="234">Fruehling</normalizedToken>
und 
<normalizedToken id="C219927DA66F2EF8185AD9780A090DBC" originalValue="früher" pageId="null" pageNumber="234">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="F6D775D112597A49E7EB8342C26A11B7" pageId="null" pageNumber="234">
<emphasis id="A882E0E4373C8F0CC70F0F80503E031A" italics="true" pageId="null" pageNumber="234">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0DC1B054DD5F3C50DD293E5908B59E61" italics="true" pageId="null" pageNumber="234">16:</emphasis>
Material aus der Tschechoslowakei (
<normalizedToken id="4FF8C41EC03128F58338CE2C5C460E88" originalValue="Novotná" pageId="null" pageNumber="234">Novotna</normalizedToken>
1962), von vielen Orten aus 
<normalizedToken id="2B11A7F3B0632561A28C6DB4BA82D437" originalValue="Österreich" pageId="null" pageNumber="234">Oesterreich</normalizedToken>
(Titz 1966Titz 1968a), von 3 Orten aus Frankreich (Burdet 1967), aus der Tschechoslowakei und Deutschland (darunter auch vom Bodensee) (Czapik und 
<normalizedToken id="8790AAE9BD534F134B60009B3DF6F787" originalValue="Novotná" pageId="null" pageNumber="234">Novotna</normalizedToken>
1967).
</paragraph>
<paragraph id="B5EFB446FFBE31996EE07C491FE2B4F6" pageId="null" pageNumber="234">
<emphasis id="2566752D25024CA0CF61D8E28C81965E" italics="true" pageId="null" pageNumber="234">Standort.</emphasis>
Kollin. Wechselfeuchte, oft stickstoffreiche 
<normalizedToken id="CB7AF166C75CEAF208E650C3F2067100" originalValue="Böden" pageId="null" pageNumber="234">Boeden</normalizedToken>
in warmen Lagen. Streuwiesen, 
<normalizedToken id="F51ABB88F4DB02BB0B216EF44DAB11ED" originalValue="Auenwälder" pageId="null" pageNumber="234">Auenwaelder</normalizedToken>
, 
<normalizedToken id="E51AAB480412EB6B7D923B5B4B6E7A6F" originalValue="Schuttplätze" pageId="null" pageNumber="234">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="773F46B2FAAE11EE4D8629AD46466E39" pageId="null" pageNumber="234">
<emphasis id="FA4C917C5779783714F34E5B57FFBD69" italics="true" pageId="null" pageNumber="234">Verbreitung.</emphasis>
Wahrscheinlich 
<emphasis id="96B477D30683B93B209BC306B10C24C8" italics="true" pageId="null" pageNumber="234">
<normalizedToken id="E2D99449A3617EE89AD5123961E2D6B7" originalValue="osteuropäische" pageId="null" pageNumber="234">osteuropaeische</normalizedToken>
Pflanze.
</emphasis>
- Im Gebiet: Untersee (Reichenau, Hegne, Gaienhofen), Hochrhein (
<normalizedToken id="B904A2B2F2C1D3B0C7EEF86598CCBFBB" originalValue="Dießenhofen" pageId="null" pageNumber="234">Diessenhofen</normalizedToken>
).
</paragraph>
</subSubSection>
