<location id="8EB56036FFD96561FE6F46F0FD85C6C6" LSID="urn:lsid:plazi:treatment:03C387FBFFD96562FF434630FB4DC2CE:8EB56036FFD96561FE6F46F0FD85C6C6" box="[443,546,1940,1964]" country="Cameroon" name="Lolodorf" pageId="29" pageNumber="30">Lolodorf</location>
