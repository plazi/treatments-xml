<normalizedToken id="023E4FE7BC6BDCA0A781829AAEA35C85" originalValue="Rühr-mich-nicht-an" pageId="null" pageNumber="693">Ruehr-mich-nicht-an</normalizedToken>
, Wald-Springkraut
</paragraph>
