<normalizedToken id="B836BBAC733F7D1E0F78CD715848488E" originalValue="alpínum" pageId="null" pageNumber="712">alpinum</normalizedToken>
<authorityName id="F2213EDE46DA12C39886C5918288D027" pageId="null" pageNumber="712">L.</authorityName>
