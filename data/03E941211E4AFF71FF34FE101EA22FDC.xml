<paragraph id="8BFFF0371E4AFF71FF3BFA2F1A7227E4" blockId="13.[194,1401,1034,3469]" box="[200,1397,1428,1461]" pageId="13" pageNumber="41">
<taxonomicName id="4C408BB41E4AFF71FF3BFA2F1D5727E4" authority="Heptner, 1961" authorityName="Heptner" authorityYear="1961" box="[200,592,1428,1461]" class="Mammalia" family="Ochotonidae" genus="Ochotona" kingdom="Animalia" order="Lagomorpha" pageId="13" pageNumber="41" phylum="Chordata" rank="subSpecies" species="rufescens" subSpecies="shukurovi">O. r. shukurovi Heptner, 1961</taxonomicName>
