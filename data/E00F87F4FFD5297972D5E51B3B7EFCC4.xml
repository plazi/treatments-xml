<taxonomicName id="AFA64D61FFD5297973C3E51C3A34FDE4" authorityName="de Saussure" authorityYear="1869" box="[414,519,612,635]" class="Insecta" family="Liturgusidae" genus="Gonatista" kingdom="Animalia" order="Mantodea" pageId="2" pageNumber="263" phylum="Arthropoda" rank="genus">
