<taxonomicName id="DEC04D28FF97FFF6A6FBBD73FCFAF478" authority="(Arechavaletae 1905: 235) D. M. Porter (1964: 211)" authorityName="D. M. Porter" authorityPageNumber="211" authorityYear="1964" baseAuthorityName="Arechavaletae" baseAuthorityPageNumber="235" baseAuthorityYear="1905" class="Demospongiae" family="Acarnidae" genus="Wigginsia" kingdom="Animalia" order="Poecilosclerida" pageId="9" pageNumber="162" phylum="Porifera" rank="species" species="turbinata">
