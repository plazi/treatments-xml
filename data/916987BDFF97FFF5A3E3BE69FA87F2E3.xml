<taxonomicName id="DEC04D28FF97FFF6A75ABE9FFDD4F41C" authority="(Lehmann 1826: 17) D. M. Porter (1964: 211)" authorityName="D. M. Porter" authorityPageNumber="211" authorityYear="1964" baseAuthorityName="Lehmann" baseAuthorityPageNumber="17" baseAuthorityYear="1826" class="Demospongiae" family="Acarnidae" genus="Wigginsia" kingdom="Animalia" order="Poecilosclerida" pageId="9" pageNumber="162" phylum="Porifera" rank="species" species="langsdorffii">
