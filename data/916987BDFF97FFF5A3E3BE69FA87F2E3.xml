<taxonomicName id="DEC04D28FF97FFF6A117BD73FB3AF41C" authority="(Link &amp; Otto 1827: 425) F. Ritter (1979: 196)" authorityName="F. Ritter" authorityPageNumber="196" authorityYear="1979" baseAuthorityName="Link &amp; Otto" baseAuthorityPageNumber="425" baseAuthorityYear="1827" box="[636,1263,1544,1571]" class="Demospongiae" family="Acarnidae" genus="Wigginsia" kingdom="Animalia" order="Poecilosclerida" pageId="9" pageNumber="162" phylum="Porifera" rank="species" species="sellowii">
<emphasis id="2BB4EAB9FF97FFF6A117BD73FD20F41C" box="[636,757,1545,1571]" italics="true" pageId="9" pageNumber="162">W. sellowii</emphasis>
(
<bibRefCitation id="7D514B5AFF97FFF6A069BD73FBD0F41C" author="Link, J. H. &amp; Otto, C. F." box="[770,1029,1544,1571]" pageId="9" pageNumber="162" pagination="24 - 420" refId="ref8897" refString="Link, J. H. &amp; Otto, C. F. (1827) Gattung Echinocactus. Verein zur Beforderung des Gartenbaues in den Preussischen Staaten 3: 24 - 420." type="journal article" year="1827">Link &amp; Otto 1827: 425</bibRefCitation>
