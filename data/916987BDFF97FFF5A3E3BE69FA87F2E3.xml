<paragraph id="197F36ABFF97FFF6A3E3BE02FC53F7AC" blockId="9.[136,1452,1400,2075]" box="[136,902,1400,1427]" pageId="9" pageNumber="162">
<emphasis id="2BB4EAB9FF97FFF6A3E3BE02FEB8F7AD" bold="true" box="[136,365,1400,1426]" pageId="9" pageNumber="162">Species richness:—</emphasis>
<taxonomicName id="DEC04D28FF97FFF6A206BE03FE08F7AD" authorityName="Porter" authorityYear="1964" box="[365,477,1401,1426]" class="Demospongiae" family="Acarnidae" genus="Wigginsia" kingdom="Animalia" order="Poecilosclerida" pageId="9" pageNumber="162" phylum="Porifera" rank="genus">
<emphasis id="2BB4EAB9FF97FFF6A206BE03FE08F7AD" box="[365,477,1401,1426]" italics="true" pageId="9" pageNumber="162">Wigginsia</emphasis>
</taxonomicName>
includes 5 species (
<bibRefCitation id="7D514B5AFF97FFF6A1D6BE03FCAFF7AC" author="Hunt, D. R. &amp; Taylor, N. P. &amp; Charles, G." box="[701,890,1400,1427]" pageId="9" pageNumber="162" refId="ref8565" refString="Hunt, D. R., Taylor, N. P. &amp; Charles, G. (Eds.) (2006) The New Cactus Lexicon. Dh Books, Milborne Port, 373 pp." type="book" year="2006">
Hunt 
<emphasis id="2BB4EAB9FF97FFF6A195BE03FCE3F7AC" box="[766,822,1401,1427]" italics="true" pageId="9" pageNumber="162">et al.</emphasis>
2006
</bibRefCitation>
).
</paragraph>
<paragraph id="197F36ABFF97FFF6A3D6BEE6FCE2F7E4" blockId="9.[136,1452,1400,2075]" pageId="9" pageNumber="162">
<emphasis id="2BB4EAB9FF97FFF6A3D6BEE6FE02F789" bold="true" box="[189,471,1436,1462]" pageId="9" pageNumber="162">General distribution:—</emphasis>
<taxonomicName id="DEC04D28FF97FFF6A2BCBEE7FD92F789" authorityName="Porter" authorityYear="1964" box="[471,583,1437,1462]" class="Demospongiae" family="Acarnidae" genus="Wigginsia" kingdom="Animalia" order="Poecilosclerida" pageId="9" pageNumber="162" phylum="Porifera" rank="genus">
<emphasis id="2BB4EAB9FF97FFF6A2BCBEE7FD92F789" box="[471,583,1437,1462]" italics="true" pageId="9" pageNumber="162">Wigginsia</emphasis>
</taxonomicName>
is geographically restricted to southern 
<collectingCountry id="61D7763BFF97FFF6A768BEE7FB9FF788" box="[1027,1098,1437,1463]" name="Brazil" pageId="9" pageNumber="162">Brazil</collectingCountry>
, 
<collectingCountry id="61D7763BFF97FFF6A73EBEE7FB62F788" box="[1109,1207,1437,1463]" name="Uruguay" pageId="9" pageNumber="162">Uruguay</collectingCountry>
and 
<collectingCountry id="61D7763BFF97FFF6A781BEE7FA89F788" box="[1258,1372,1437,1463]" name="Argentina" pageId="9" pageNumber="162">Argentina</collectingCountry>
, in Rio Grande do Sul, four species were found in the Pampa Biome.
</paragraph>
</subSubSection>
