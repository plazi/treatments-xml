<taxonomicName id="86B1ACD242118949FEE65D70FCFFC616" authority="Yatskov, 1990" authorityName="Yatskov" authorityYear="1990" box="[368,827,1599,1626]" class="Cephalopoda" family="Beloceratidae" genus="Eobeloceras" kingdom="Animalia" order="Ammonoidea" pageId="22" pageNumber="32" phylum="Mollusca" rank="species" species="palentinum">
