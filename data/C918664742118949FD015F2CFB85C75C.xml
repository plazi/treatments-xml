<taxonomicName id="86B1ACD242118949FC575D52FAE8C67A" authority="Matern, 1931" authorityName="Matern" authorityYear="1931" box="[961,1324,1564,1591]" class="Cephalopoda" family="Taouzitidae" genus="Taouzites" kingdom="Animalia" order="Ammonoidea" pageId="22" pageNumber="32" phylum="Mollusca" rank="species" species="acutus">
<emphasis id="73C50B4342118949FC575D52FB40C67A" box="[961,1156,1565,1590]" italics="true" pageId="22" pageNumber="32">Taouzites acutus</emphasis>
