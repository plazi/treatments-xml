Key to males of 
<taxonomicName id="4C5DC7DDFFF91568E6051A56FE413938" authorityName="Alencar &amp; Azevedo" authorityYear="2018" box="[352,487,547,573]" class="Insecta" family="Bethylidae" genus="Pristonesia" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="323" phylum="Arthropoda" rank="genus">
