<caption id="DF04C0D2502EFFD3FF63F882FD713990" ID-DOI="http://doi.org/10.5281/zenodo.6552087" ID-Zenodo-Dep="6552087" httpUri="https://zenodo.org/record/6552087/files/figure.png" pageId="6" pageNumber="23" startId="6.[151,250,1797,1821]" targetBox="[152,1436,489,1773]" targetPageId="6">
