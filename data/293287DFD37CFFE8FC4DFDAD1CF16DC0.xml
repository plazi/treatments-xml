<quantity id="66639B2CD37CFFE8FB3AFA8C1C756F01" box="[1213,1311,1377,1401]" metricMagnitude="-4" metricUnit="m" metricValue="8.1" pageId="3" pageNumber="147" unit="mm" value="0.81">0,81 mm</quantity>
