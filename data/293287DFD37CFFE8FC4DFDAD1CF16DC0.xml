<quantity id="66639B2CD37CFFE8FB20FA6C1C606FE1" box="[1191,1290,1409,1433]" metricMagnitude="-4" metricUnit="m" metricValue="2.6" pageId="3" pageNumber="147" unit="mm" value="0.26">0,26 mm</quantity>
