<quantity id="66639B2CD37CFFE8FBBAFA8C1DF46F01" box="[1085,1182,1377,1401]" metricMagnitude="-4" metricUnit="m" metricValue="5.8" pageId="3" pageNumber="147" unit="mm" value="0.58">0,58 mm</quantity>
