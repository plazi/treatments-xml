<taxonomicName id="E299548D1000FF9FDA00FEFC4DE32AFD" authorityName="Okajima &amp; Masumoto" authorityYear="2022" box="[293,470,439,465]" class="Insecta" family="Phlaeothripidae" genus="Asianthrips" kingdom="Animalia" order="Thysanoptera" pageId="37" pageNumber="138" phylum="Arthropoda" rank="species" species="vietnamensis">
