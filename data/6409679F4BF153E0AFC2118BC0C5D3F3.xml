LINN-80.23 (
<typeStatus id="F62643A2DED1666F4756A4E87ECF3640">lectotype</typeStatus>
, designated by 
<bibRefCitation id="921D106FC578E4C5FD421FF6050BBACE" author="Hitchcock, AS" journalOrPublisher="Contributions from the United States National Herbarium" pageId="0" pageNumber="1" pagination="113 - 158" publicationUrl="https://www.biodiversitylibrary.org/item/13772page/148/mode/1up" refId="B29" refString="Hitchcock, AS, 1908. Types of American grasses: A study of the American species of grasses described by Linnaeus, Gronovius, Sloan, Swartz and Michaux. Contributions from the United States National Herbarium 12 (3): 113 - 158, https://www.biodiversitylibrary.org/item/13772page/148/mode/1up" title="Types of American grasses: A study of the American species of grasses described by Linnaeus, Gronovius, Sloan, Swartz and Michaux." url="https://www.biodiversitylibrary.org/item/13772page/148/mode/1up" volume="12" year="1908">Hitchcock 1908</bibRefCitation>
