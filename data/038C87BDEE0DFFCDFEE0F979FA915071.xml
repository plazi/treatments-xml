<taxonomicName id="4C254D28EE0DFFCDFC71FB39FBA05051" box="[918,1034,1268,1294]" class="Magnoliopsida" family="Rosaceae" genus="Cotoneaster" kingdom="Plantae" order="Rosales" pageId="4" pageNumber="143" phylum="Tracheophyta" rank="species" species="ellipticus">
<emphasis id="B951EAB9EE0DFFCDFC71FB39FBA05051" box="[918,1034,1268,1294]" italics="true" pageId="4" pageNumber="143">C. ellipticus</emphasis>
