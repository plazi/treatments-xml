<subSubSection id="1153682192BDB03A5F8FBC45CF561451" pageId="null" pageNumber="85" type="vernacular_names">
<paragraph id="A61CB17161D7C62389D7E84791F84161" pageId="null" pageNumber="85">Italienische Ochsenzunge</paragraph>
</subSubSection>
</title>
<subSubSection id="564C3B152312831E6D65DBDBAC9C91DF" pageId="null" pageNumber="85" type="description">
<paragraph id="5BDA81FF33C5CC04D56DE12EE5BDC1E4" pageId="null" pageNumber="85">
<normalizedToken id="230A30C11924222F8F0F20C86EC659B3" originalValue="Mehrjährig" pageId="null" pageNumber="85">Mehrjaehrig</normalizedToken>
, oft bis 1,5 m hoch; ganze Pflanze dicht mit biegsamen, abstehenden Haaren besetzt. 
<normalizedToken id="DD4CDAE49B1B0711931E1E57BC78D82A" originalValue="Blätter" pageId="null" pageNumber="85">Blaetter</normalizedToken>
bis 30 cm lang, 4-8mal so lang wie breit, nach dem Grunde nur wenig 
<normalizedToken id="AC6BD3B422C625D8B2DFAA90A5D70398" originalValue="verschmälert" pageId="null" pageNumber="85">verschmaelert</normalizedToken>
, meist mit glattem Rand. Stengel im obern Teil mit zahlreichen 
<normalizedToken id="192C255A7CB217BF43807B3673828EB6" originalValue="seitenständigen" pageId="null" pageNumber="85">seitenstaendigen</normalizedToken>
<normalizedToken id="03C4A7772C63BC11335FF87A2A7C67D7" originalValue="Blütenständen" pageId="null" pageNumber="85">Bluetenstaenden</normalizedToken>
. 
<emphasis id="DFDB3692F3E389068B5EB542E6D6F8AE" italics="true" pageId="null" pageNumber="85">Kelch bis fast zum Grunde geteilt</emphasis>
, mit 
<normalizedToken id="D8F918070F4AEEEC9DD576138BC9552C" originalValue="allmählich" pageId="null" pageNumber="85">allmaehlich</normalizedToken>
und fein zugespitzten Zipfeln, zur Fruchtzeit 15-20 mm lang. Krone blau; 
<normalizedToken id="6F91A84DE97CE3540BEDA0A46816D853" originalValue="Kronröhre" pageId="null" pageNumber="85">Kronroehre</normalizedToken>
10-15 mm lang, 
<emphasis id="3A0F8BC0BC9BEE2A596D6C54AED3F608" italics="true" pageId="null" pageNumber="85">
Durchmesser der Krone auffallend 
<normalizedToken id="B88FBC4EA5DB9EFEFE3D3211CDF0193E" originalValue="groß" pageId="null" pageNumber="85">gross</normalizedToken>
, ca. 15 mm.
</emphasis>
- 
<normalizedToken id="9531F8A331C324D2C42EC869BD183E0B" originalValue="Blüte" pageId="null" pageNumber="85">Bluete</normalizedToken>
: Sommer bis Herbst.
</paragraph>
<paragraph id="3E314BBC4B0ADF3FC6D9EEC758CA9767" pageId="null" pageNumber="85">
<emphasis id="82229E03C38A23CC9A8C6924BEB8F8CE" italics="true" pageId="null" pageNumber="85">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="BA08835764031EB2F6A193AB69D0EBE7" italics="true" pageId="null" pageNumber="85">32:</emphasis>
Zahlreiche 
<normalizedToken id="182DC3988CB4AA82BEBEE40D7D8952EB" originalValue="übereinstimmende" pageId="null" pageNumber="85">uebereinstimmende</normalizedToken>
<normalizedToken id="E5DE6DA6F5F336546DCF049049483885" originalValue="Zählungen" pageId="null" pageNumber="85">Zaehlungen</normalizedToken>
in 
<normalizedToken id="D5829EF10D425681B4C0F3168DFCF646" originalValue="Löve" pageId="null" pageNumber="85">Loeve</normalizedToken>
und 
<normalizedToken id="11AB8BF6C0A6680A963CD49C79462B03" originalValue="Löve" pageId="null" pageNumber="85">Loeve</normalizedToken>
(1961).
</paragraph>
<paragraph id="5D0CC0514732C326680BFBF79AD312A2" pageId="null" pageNumber="85">
<emphasis id="6A87FF489AF755ABE9CAF8D451ADB134" italics="true" pageId="null" pageNumber="85">Standort.</emphasis>
Kollin. Trockene, meist 
<normalizedToken id="8FB3A7E9E5E822411006622E50B2EB70" originalValue="nährstoffreiche" pageId="null" pageNumber="85">naehrstoffreiche</normalizedToken>
<normalizedToken id="1788022218590D8D3A1375D0E28316CE" originalValue="Böden" pageId="null" pageNumber="85">Boeden</normalizedToken>
in warmen Lagen. Ruderalstellen.
</paragraph>
<paragraph id="C61D64793D1D96CE481D949B867CC3EE" pageId="null" pageNumber="85">
<emphasis id="919BB43DE47995976E3D198B59A18608" italics="true" pageId="null" pageNumber="85">Verbreitung. Mediterran-westasiatische Pflanze:</emphasis>
Ganzes Mediterrangebiet; 
<normalizedToken id="2FDB5C572C69DAA0B0A107CD7F8A4280" originalValue="ostwärts" pageId="null" pageNumber="85">ostwaerts</normalizedToken>
durch Kleinasien und den Kaukasus bis Zentralasien (
<normalizedToken id="DB49792181EE9DD5AC0D925C68B023F6" originalValue="größte" pageId="null" pageNumber="85">groesste</normalizedToken>
Verbreitung aller 
<taxonomicName id="9D0AA1D8345EF820AD458DE964B3A450" class="Magnoliopsida" family="Boraginaceae" genus="Anchusa" kingdom="Plantae" order="Boraginales" pageId="null" pageNumber="85" phylum="Tracheophyta" rank="genus">
<emphasis id="7D786A9F58FC439521237414687841AD" italics="true" pageId="null" pageNumber="85">Anchusa</emphasis>
</taxonomicName>
arten [
<normalizedToken id="3770741C4A3921021663BD3651295A35" originalValue="Guçuleac" pageId="null" pageNumber="85">Guculeac</normalizedToken>
1927]). - Im Gebiet in den warmen Gegenden, nicht 
<normalizedToken id="6E19A02D43740E01E177FC3B368B5B2C" originalValue="häufig" pageId="null" pageNumber="85">haeufig</normalizedToken>
, aber in Ausbreitung begriffen.
</paragraph>
</subSubSection>
