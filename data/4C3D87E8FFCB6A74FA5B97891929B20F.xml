, 
<collectingRegion id="0650F81CFFCB6A74F5FB92751BCEBF46" country="Papua New Guinea" name="Chimbu" pageId="48" pageNumber="806">Chimbu</collectingRegion>
, 
<collectingRegion id="0650F81CFFCB6A74FA20920A18ECBF46" box="[1500,1772,1107,1140]" country="Papua New Guinea" name="Western Highlands" pageId="48" pageNumber="806">Western Highlands</collectingRegion>
, 
<collectingRegion id="0650F81CFFCB6A74F901920A161DBF46" box="[1789,2077,1107,1140]" country="Papua New Guinea" name="Southern Highlands" pageId="48" pageNumber="806">Southern Highlands</collectingRegion>
