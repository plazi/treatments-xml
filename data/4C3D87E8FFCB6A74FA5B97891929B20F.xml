<caption id="90EB6676FFCB6A74FA5B92751748BF46" ID-DOI="http://doi.org/10.5281/zenodo.6397958" ID-Zenodo-Dep="6397958" httpUri="https://zenodo.org/record/6397958/files/figure.png" inLine="true" pageId="48" pageNumber="806" targetBox="[1445,2036,647,1061]" targetPageId="48">
<paragraph id="C42B36FEFFCB6A74FA5B92751748BF46" blockId="48.[1447,2656,1068,2365]" pageId="48" pageNumber="806">
<emphasis id="F6E0EAECFFCB6A74FA5B92751857BF7F" bold="true" box="[1447,1623,1068,1101]" pageId="48" pageNumber="806">Distribution.</emphasis>
