<subSubSection id="F5F417E857DFA1716B46120F7DF2E8CB" pageId="null" pageNumber="188" type="nomenclature">
<paragraph id="E4414C50F57CC606CA4B2ADC3C2A57EA" pageId="null" pageNumber="188">
<taxonomicName id="C452FB9324F132934489543CA98B2411" authority="L." class="Magnoliopsida" family="Plantaginaceae" genus="Veronica" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="188" phylum="Tracheophyta" rank="species" species="prostrata">
Veronica 
<normalizedToken id="0503849E473B69EFA694D54B280B5589" originalValue="prostráta" pageId="null" pageNumber="188">prostrata</normalizedToken>
<authorityName id="F17D617E5479F2BE7FA8253737822836" pageId="null" pageNumber="188">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="B099CB5C06155660761637EF53D892B9" pageId="null" pageNumber="188" type="vernacular_names">
<paragraph id="C9FE3313D7A8E42DE06CD8633B23037E" pageId="null" pageNumber="188">Niederliegender Ehrenpreis</paragraph>
</subSubSection>
</title>
<subSubSection id="90C105DABF460447139E5BDA8E116003" pageId="null" pageNumber="188" type="description">
<paragraph id="5E5DFF951B485964D5BE2816EE2FCAFA" pageId="null" pageNumber="188">
Bis 20 cm hoch. Unfruchtbare Stengel niederliegend, die 
<normalizedToken id="3C371EB158ABAD4B0C063C56D6E8F5FB" originalValue="blühenden" pageId="null" pageNumber="188">bluehenden</normalizedToken>
aufsteigend. 
<normalizedToken id="751B27B64297A7F50A4B2B6C6F64CBFA" originalValue="Blätter" pageId="null" pageNumber="188">Blaetter</normalizedToken>
lanzettlich, am Grunde 
<normalizedToken id="8B4E88E5C0C49D78E112BB6F7C8B11B4" originalValue="verschmälert" pageId="null" pageNumber="188">verschmaelert</normalizedToken>
, bis 3 cm lang und 0,5 cm breit, 
<emphasis id="3B2D588C07AD5347A6DEADC66BD731BC" italics="true" pageId="null" pageNumber="188">3</emphasis>
- 
<emphasis id="857D1AF2E2D0795F0080089C28CAC9EE" italics="true" pageId="null" pageNumber="188">
10mal so lang wie breit, fein 
<normalizedToken id="37DAF6F3CE80B8611B6998E5101EB85E" originalValue="gezähnt" pageId="null" pageNumber="188">gezaehnt</normalizedToken>
</emphasis>
, am Rande oft nach unten eingerollt, 
<emphasis id="0CE302BF0BF0A1CBE4534A93DD0E5610" italics="true" pageId="null" pageNumber="188">kurz und dicht behaart</emphasis>
(
<emphasis id="491F5C4AB77A83BA83C862AADE514619" italics="true" pageId="null" pageNumber="188">auch unterseits</emphasis>
). Kelchzipfel kahl oder am Rande bewimpert, schmal. 
<emphasis id="ACB8D3682E671DF0114A9D3919A1BFE2" italics="true" pageId="null" pageNumber="188">Krone im Durchmesser 4</emphasis>
- 
<emphasis id="AD780599BE9A7A0CFD33AF8045E383BE" italics="true" pageId="null" pageNumber="188">11 mm, hellviolett</emphasis>
(selten rosa oder 
<normalizedToken id="2FB9EE00AFEEB522E88DB4BDAD52B908" originalValue="weiß" pageId="null" pageNumber="188">weiss</normalizedToken>
). Samen etwa 1 mm im Durchmesser. - 
<normalizedToken id="6027161C34355D2D816A9A661A44CD74" originalValue="Blüte" pageId="null" pageNumber="188">Bluete</normalizedToken>
: 
<normalizedToken id="E387C624B016210A8194B6D4EA610D4B" originalValue="Später" pageId="null" pageNumber="188">Spaeter</normalizedToken>
<normalizedToken id="4CEACE2E1C44F5E91C8E539A456414BF" originalValue="Frühling" pageId="null" pageNumber="188">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="ADF4C37DF3C6816B013B1B153DCB6A98" pageId="null" pageNumber="188">
<emphasis id="2026D79B414A8BE392B106EC53008CC8" italics="true" pageId="null" pageNumber="188">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="594CC122E2C47A5D2308A38465E477D1" italics="true" pageId="null" pageNumber="188">16:</emphasis>
Material aus 
<normalizedToken id="B886885407C75475CA1E3AB5B1C939E9" originalValue="Österreich" pageId="null" pageNumber="188">Oesterreich</normalizedToken>
und Ungarn (Scheerer 1937, 
<normalizedToken id="BC8B6BE2445BA615E9B3BE33C5447359" originalValue="Pólya" pageId="null" pageNumber="188">Polya</normalizedToken>
1945, Mattick in Tischler 1950), aus Serbien (Fischer 1969), aus dem Wallis (Brandt 1953), aus Savoyen, Wallis und 
<normalizedToken id="7F117C8A4F49A19F8F4E1873C75CBD7E" originalValue="Graubünden" pageId="null" pageNumber="188">Graubuenden</normalizedToken>
(Brandt 1961).
</paragraph>
<paragraph id="A48E006BA811432FABCDE1138F0AD265" pageId="null" pageNumber="188">
<emphasis id="2AAD292AEE0AD9E987945002340DF6F7" italics="true" pageId="null" pageNumber="188">Standort</emphasis>
. Kollin und montan, seltener subalpin. Trockene, kalkhaltige, sandige 
<normalizedToken id="A3312A5CA76B487CF1B0B0E3C9779A16" originalValue="Böden" pageId="null" pageNumber="188">Boeden</normalizedToken>
in warmen Lagen. Trockenwiesen, Felsensteppen, lichte 
<normalizedToken id="B41F47BD9422825B67808682E38C5338" originalValue="Föhrenwälder" pageId="null" pageNumber="188">Foehrenwaelder</normalizedToken>
.
</paragraph>
<paragraph id="296805366DD14751D995044163D06B52" pageId="null" pageNumber="188">
<emphasis id="7F763CAF2350E36AC1F281DCC755E32B" italics="true" pageId="null" pageNumber="188">
Verbreitung. 
<normalizedToken id="91448035337FC55FF6DF13E8DCA77A5F" originalValue="Osteuropäisch-westasiatische" pageId="null" pageNumber="188">Osteuropaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="FFF1D8F6C85811F604E181ED57FC92A9" originalValue="Nordwärts" pageId="null" pageNumber="188">Nordwaerts</normalizedToken>
bis Alpen, Ostdeutschland, 
<normalizedToken id="FCF3A60A9887F70DE1A469053568EB4C" originalValue="Mittelrußland" pageId="null" pageNumber="188">Mittelrussland</normalizedToken>
; 
<normalizedToken id="5B56182262F0653F78DA78513A4B189D" originalValue="westwärts" pageId="null" pageNumber="188">westwaerts</normalizedToken>
bis Westalpen; 
<normalizedToken id="2FB2897B0CEF0353EB615ABC303F4C14" originalValue="ostwärts" pageId="null" pageNumber="188">ostwaerts</normalizedToken>
bis Kaukasus, 
<normalizedToken id="D1BDBBCA0943A2E9582F0FD8A52D7967" originalValue="Südwestsibirien" pageId="null" pageNumber="188">Suedwestsibirien</normalizedToken>
. - Im Gebiet: Zentralalpine 
<normalizedToken id="C5AED7E4B2DD3A1DADE02BCC15562587" originalValue="Täler" pageId="null" pageNumber="188">Taeler</normalizedToken>
(Maurienne, Tarentaise, Wallis, Aostatal, Gegend von Tiefencastel, Unterengadin, Oberinntal, 
<normalizedToken id="EECDE565B40E69FF52D9B49D657A3490" originalValue="Münstertal" pageId="null" pageNumber="188">Muenstertal</normalizedToken>
, Vintschgau, oberes Veltlin und Gegend von Bormio); Langenseegebiet (Monte Nudo), Comerseegebiet (Somasca bei Lecco); nicht 
<normalizedToken id="6FE3529F67D7E631695D19547C64DBFE" originalValue="häufig" pageId="null" pageNumber="188">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
