, 
<collectingCountry id="F31E7642FFE7FFE6FD09FB99E57DFBB2" box="[706,832,1070,1099]" name="Paraguay" pageId="34" pageNumber="441">Paraguay</collectingCountry>
, 
<collectingCountry id="F31E7642FFE7FFE6FC84FB99E5FAFBB2" box="[847,967,1070,1099]" name="Uruguay" pageId="34" pageNumber="441">Uruguay</collectingCountry>
, N 
<collectingCountry id="F31E7642FFE7FFE6FC3CFB99E2BAFBB2" box="[1015,1159,1070,1099]" name="Argentina" pageId="34" pageNumber="441">Argentina</collectingCountry>
