<taxonomicName id="00D6E32527DF20C81BAAC6914C963B6B" authority="L." class="Insecta" family="Hesperiidae" genus="Viola" kingdom="Animalia" order="Lepidoptera" pageId="null" pageNumber="740" phylum="Arthropoda" rank="species" species="hirta">
