<subSubSection id="C37565586428FF80FF1AF4E34ACAC529" pageId="24" pageNumber="25" type="discussion">
<paragraph id="8BD036D36428FF80FF1AF4E3485DC494" blockId="24.[189,303,679,705]" box="[189,303,679,705]" pageId="24" pageNumber="25">
<heading id="D09881BF6428FF80FF1AF4E3485DC494" bold="true" box="[189,303,679,705]" fontSize="11" level="3" pageId="24" pageNumber="25" reason="3">
<emphasis id="B91BEAC16428FF80FF1AF4E3485DC494" bold="true" box="[189,303,679,705]" pageId="24" pageNumber="25">Remarks</emphasis>
</heading>
</paragraph>
<paragraph id="8BD036D36428FF80FF1AF4914ACAC529" blockId="24.[189,1399,725,893]" pageId="24" pageNumber="25">
The genus 
<emphasis id="B91BEAC16428FF80FEEBF4914897C4BA" box="[332,485,725,751]" italics="true" pageId="24" pageNumber="25">Reversabella</emphasis>
<bibRefCitation id="EFFE4B226428FF80FE54F4914A42C4BA" author="Coryell H. N. &amp; Johnson S. C." box="[499,816,725,751]" pageId="24" pageNumber="25" pagination="214 - 224" refId="ref27752" refString="Coryell H. N. &amp; Johnson S. C. 1939. Ostracoda of the Clore Limestone, Upper Mississipian of Illinois. Journal of Paleontology 13 (2): 214 - 224. https: // www. jstor. org / stable / 1298771" type="journal article" year="1939">Coryell &amp; Johnson, 1939</bibRefCitation>
(
<typeStatus id="54D488716428FF80FCE1F4914A08C4BA" box="[838,890,725,751]" pageId="24" pageNumber="25">type</typeStatus>
species: 
<emphasis id="B91BEAC16428FF80FC53F4914D99C4BA" box="[1012,1259,725,751]" italics="true" pageId="24" pageNumber="25">Reversabella njorthi</emphasis>
<bibRefCitation id="EFFE4B226428FF80FB5EF491481FC546" author="Coryell H. N. &amp; Johnson S. C." pageId="24" pageNumber="25" pagination="214 - 224" refId="ref27752" refString="Coryell H. N. &amp; Johnson S. C. 1939. Ostracoda of the Clore Limestone, Upper Mississipian of Illinois. Journal of Paleontology 13 (2): 214 - 224. https: // www. jstor. org / stable / 1298771" type="journal article" year="1939">Coryell &amp; Johnson, 1939</bibRefCitation>
) was originally erected “to receive form which have reversed overlap” (
<bibRefCitation id="EFFE4B226428FF80FB5EF4BC48D4C563" author="Coryell H. N. &amp; Johnson S. C." pageId="24" pageNumber="25" pagination="214 - 224" refId="ref27752" refString="Coryell H. N. &amp; Johnson S. C. 1939. Ostracoda of the Clore Limestone, Upper Mississipian of Illinois. Journal of Paleontology 13 (2): 214 - 224. https: // www. jstor. org / stable / 1298771" type="journal article" year="1939">Coryell &amp; Johnson 1939: 221</bibRefCitation>
) compared to 
<taxonomicName id="4C6F4D506428FF80FDC7F5584AE9C563" authority="Roundy, 1936" authorityName="Roundy" authorityYear="1936" box="[608,923,796,822]" class="Ostracoda" family="Paraparchitidae" genus="Sansabella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Palaeocopida" pageId="24" pageNumber="25" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAC16428FF80FDC7F5584B93C563" box="[608,737,796,822]" italics="true" pageId="24" pageNumber="25">Sansabella</emphasis>
Roundy, 1936
</taxonomicName>
. Later, reversed overlap appears to be common in the genus 
<taxonomicName id="4C6F4D506428FF80FE6DF57B4B39C50C" authorityName="Roundy" authorityYear="1936" box="[458,587,831,857]" class="Ostracoda" family="Paraparchitidae" genus="Sansabella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Palaeocopida" pageId="24" pageNumber="25" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAC16428FF80FE6DF57B4B39C50C" box="[458,587,831,857]" italics="true" pageId="24" pageNumber="25">Sansabella</emphasis>
</taxonomicName>
(
<bibRefCitation id="EFFE4B226428FF80FDFBF57B4B86C50C" author="Moore R. C." box="[604,756,831,857]" pageId="24" pageNumber="25" refId="ref31105" refString="Moore R. C. 1961. Treatise on Invertebrate Paleontology. Arthropoda 3, Crustacea, Ostracoda. Geological Society of America and University of Kansas Press." type="book" year="1961">Moore 1961</bibRefCitation>
; 
<bibRefCitation id="EFFE4B226428FF80FCA4F57B4AB1C50C" author="Sohn I. G." box="[771,963,831,857]" pageId="24" pageNumber="25" pagination="52 - 62" refId="ref33158" refString="Sohn I. G. 1988. Revision of the Late Mississippian New Ostracode Genera in Coryell and Johnson 1939. Micropaleontology 34 (1): 52 - 62. https: // doi. org / 10.2307 / 1485610" type="journal article" year="1988">Sohn 1988: 187</bibRefCitation>
) and 
<emphasis id="B91BEAC16428FF80FBAEF57B4DD0C50C" box="[1033,1186,831,857]" italics="true" pageId="24" pageNumber="25">Reversabella</emphasis>
has subsequently been considered as a junior synonym of 
<taxonomicName id="4C6F4D506428FF80FD31F5264AC6C529" authority="(Sohn 1988)" baseAuthorityName="Sohn" baseAuthorityYear="1988" box="[662,948,866,892]" class="Ostracoda" family="Paraparchitidae" genus="Sansabella" higherTaxonomySource="GBIF" kingdom="Animalia" order="Palaeocopida" pageId="24" pageNumber="25" phylum="Arthropoda" rank="genus">
<emphasis id="B91BEAC16428FF80FD31F5264A65C529" box="[662,791,866,892]" italics="true" pageId="24" pageNumber="25">Sansabella</emphasis>
(
<bibRefCitation id="EFFE4B226428FF80FC81F5264AD9C529" author="Sohn I. G." box="[806,939,866,892]" pageId="24" pageNumber="25" pagination="52 - 62" refId="ref33158" refString="Sohn I. G. 1988. Revision of the Late Mississippian New Ostracode Genera in Coryell and Johnson 1939. Micropaleontology 34 (1): 52 - 62. https: // doi. org / 10.2307 / 1485610" type="journal article" year="1988">Sohn 1988</bibRefCitation>
)
</taxonomicName>
.
</paragraph>
