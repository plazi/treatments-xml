<emphasis id="B97B5A479151FFEDE77CC3862CF8AAB4" bold="true" box="[782,937,2725,2758]" pageId="6" pageNumber="440">Taxonomy.</emphasis>
<taxonomicName id="4C0FFDD69151FFEDE7B4C3862C03AA9C" authority="Dobson, 1878" authorityName="Dobson" authorityYear="1878" class="Mammalia" family="Mormoopidae" genus="Chilonycteris" kingdom="Animalia" order="Chiroptera" pageId="6" pageNumber="440" phylum="Chordata" rank="species" species="psilotis">Chilonycteris psilotis Dobson, 1878</taxonomicName>
, 
<materialsCitation id="3B678C089151FFEDE711C3EE2B52AB4C" pageId="6" pageNumber="440">
type locality unknown. Restricted by IL. de Ia Towe in 1955 to “Tehuantepec, 
<collectingRegion id="49CB48B79151FFEDE77DC2062C28AB4C" box="[783,889,2853,2878]" country="Mexico" name="Oaxaca" pageId="6" pageNumber="440">Oaxaca</collectingRegion>
