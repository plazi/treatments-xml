</materialsCitation>
</paragraph>
<paragraph id="8BB086559151FFEDE77DC2672A47ABC1" blockId="6.[781,1373,2725,3153]" pageId="6" pageNumber="440">
<taxonomicName id="4C0FFDD69151FFEDE77DC2672CD8AB17" authorityName="Dobson" authorityYear="1878" box="[783,905,2884,2917]" class="Mammalia" family="Mormoopidae" genus="Pteronotus" kingdom="Animalia" order="Chiroptera" pageId="6" pageNumber="440" phylum="Chordata" rank="species" species="psilotis">P. psilotis</taxonomicName>
