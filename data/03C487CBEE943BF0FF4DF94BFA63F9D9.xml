Genus 
<taxonomicName id="4C6D4D5EEE943BF0FF1AF948FDD6F95E" authority="Monniot C., 1983" authorityName="Monniot C." authorityYear="1983" box="[223,531,1669,1696]" class="Maxillopoda" family="Notodelphyidae" genus="Remex" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="453" pageNumber="454" phylum="Arthropoda" rank="genus">
<emphasis id="B919EACFEE943BF0FF1AF948FEF7F961" bold="true" box="[223,306,1670,1696]" italics="true" pageId="453" pageNumber="454">Remex</emphasis>
Monniot C., 1983
