<quantity id="887C9B52537EFFB0FB388248FA38F8CB" box="[1292,1424,1867,1893]" metricMagnitude="2" metricUnit="m" metricValue="1.51" metricValueMax="2.0" metricValueMin="1.02" pageId="32" pageNumber="33" unit="m" value="151.0" valueMax="200.0" valueMin="102.0">102–200 m</quantity>
