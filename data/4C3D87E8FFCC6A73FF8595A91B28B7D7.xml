), NE &amp; C 
<collectingRegion id="0650F81CFFCC6A73FCB290591DC1BD2F" box="[846,961,1536,1565]" country="Indonesia" name="Sulawesi Utara" pageId="55" pageNumber="813">Sulawesi</collectingRegion>
