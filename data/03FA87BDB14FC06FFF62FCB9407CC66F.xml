FIGURES 1–9. 
<taxonomicName id="4C534D28B14EC068FEB0F8C1410EC04C" authority="Li &amp; Elie &amp; Liu &amp; Zhang, 2022" authorityName="Li &amp; Elie &amp; Liu &amp; Zhang" authorityYear="2022" box="[325,531,1867,1891]" class="Insecta" family="Aeolothripidae" genus="Aduncothrips" kingdom="Animalia" order="Thysanoptera" pageId="3" pageNumber="52" phylum="Arthropoda" rank="species" species="albus" status="sp.n.">
<emphasis id="B927EAB9B14EC068FEB0F8C1410EC04C" bold="true" box="[325,531,1867,1891]" italics="true" pageId="3" pageNumber="52">Aduncothrips albus</emphasis>
</taxonomicName>
<taxonomicNameLabel id="A21457C2B14EC068FDE9F8C64153C04B" box="[540,590,1868,1892]" pageId="3" pageNumber="52" rank="species">sp.n.</taxonomicNameLabel>
