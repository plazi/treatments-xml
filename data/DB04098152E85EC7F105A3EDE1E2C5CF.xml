<subSubSection id="19BA04E9F3ED48D65CCE6634082143D6" pageId="null" pageNumber="261" type="description">
<paragraph id="0AE5259BC4271A4D573E4F9C71F1F052" pageId="null" pageNumber="261">
1-4 
<normalizedToken id="C5958FC56AD41ACA1F0F91E2248DC70B" originalValue="jährig" pageId="null" pageNumber="261">jaehrig</normalizedToken>
, 10-30 cm hoch, meist aufrecht, 
<normalizedToken id="E9C3A37862C79E1B5CC379C1F972F0E9" originalValue="rötlich" pageId="null" pageNumber="261">roetlich</normalizedToken>
<normalizedToken id="DD6F9B6A91DDA581E44E0E4DC3F39A0F" originalValue="überlaufen" pageId="null" pageNumber="261">ueberlaufen</normalizedToken>
, vom Grunde an verzweigt; ohne niederliegende, sterile Triebe; unten kahl, 
<emphasis id="33708A369BD5A6407DBDF172F39EF649" italics="true" pageId="null" pageNumber="261">
im obern Teil 
<normalizedToken id="A05E2FCC563398DFF579C79BF486B2D8" originalValue="drüsig" pageId="null" pageNumber="261">druesig</normalizedToken>
behaart.
</emphasis>
Alle 
<normalizedToken id="DC7A4CAF6F3E948897BE445545129E2B" originalValue="Blätter" pageId="null" pageNumber="261">Blaetter</normalizedToken>
flach, ohne 
<normalizedToken id="04BE6AD9DF31762F62002FE9D2220E5D" originalValue="Zähne" pageId="null" pageNumber="261">Zaehne</normalizedToken>
, untere 
<normalizedToken id="68866E75A83E9789045C7827ABAF1785" originalValue="Blätter" pageId="null" pageNumber="261">Blaetter</normalizedToken>
oval bis rundlich, obere lanzettlich, bis 3 cm lang, auf der Oberseite hohlrinnig, im Querschnitt etwa 4mal breiter als dick, die untern 
<normalizedToken id="346EA2C7BF0365E9444CA4F78D36F327" originalValue="gegenständig" pageId="null" pageNumber="261">gegenstaendig</normalizedToken>
oder zu 3-4 
<normalizedToken id="166261E9B26FBD8C712FD75906901262" originalValue="quirlständig" pageId="null" pageNumber="261">quirlstaendig</normalizedToken>
, die obern meist 
<normalizedToken id="C9FAE83ECF6249FA6276CFF24B0934A2" originalValue="wechselständig" pageId="null" pageNumber="261">wechselstaendig</normalizedToken>
. 
<emphasis id="77905EB90965D074E676584DCDD984F2" italics="true" pageId="null" pageNumber="261">
<normalizedToken id="F3C2A964E7573596A02CD065DC503035" originalValue="Blütenstand" pageId="null" pageNumber="261">Bluetenstand</normalizedToken>
eine lockere, bis 20 cm hohe Rispe.
</emphasis>
<normalizedToken id="383D11BD0FE443B2117F903557581EE4" originalValue="Blütenstiele" pageId="null" pageNumber="261">Bluetenstiele</normalizedToken>
und 
<normalizedToken id="E20876D4D71FB383F6CB434B871C7D1B" originalValue="außerseits" pageId="null" pageNumber="261">ausserseits</normalizedToken>
auch Kelch- und 
<normalizedToken id="1CB147435BA6BD3727B762A1C4FB8404" originalValue="Kronblätter" pageId="null" pageNumber="261">Kronblaetter</normalizedToken>
mit 
<normalizedToken id="25012B71571683F7E8AE774A61148802" originalValue="Drüsen" pageId="null" pageNumber="261">Druesen</normalizedToken>
. 
<normalizedToken id="7934F0AFC2BB026CF773DEA0BA13A718" originalValue="Blüten" pageId="null" pageNumber="261">Blueten</normalizedToken>
meist 5 
<normalizedToken id="DFCBF824D6C4BAE9A4AF5F0CF70A936F" originalValue="zählig" pageId="null" pageNumber="261">zaehlig</normalizedToken>
. 
<normalizedToken id="A9662693B772522CFB6CFA933479DE06" originalValue="Kelchblätter" pageId="null" pageNumber="261">Kelchblaetter</normalizedToken>
etwa 1,5 mm lang, spitz. 
<normalizedToken id="F563147B58F167F34EDF12C13EE3D5E2" originalValue="Kronblätter" pageId="null" pageNumber="261">Kronblaetter</normalizedToken>
etwa 3mal so lang wie die 
<normalizedToken id="4C080816BFE474C585F21F9F26798841" originalValue="Kelchblätter" pageId="null" pageNumber="261">Kelchblaetter</normalizedToken>
, mit grannenartiger Spitze, hellrosa, mit roten Streifen. - 
<normalizedToken id="9489152BC9D530B42370F1C510D0AEC3" originalValue="Blüte" pageId="null" pageNumber="261">Bluete</normalizedToken>
: Sommer; in den 
<normalizedToken id="483A98CF16070AFC58CBB5C2AE99606E" originalValue="südlichen" pageId="null" pageNumber="261">suedlichen</normalizedToken>
Gegenden schon im 
<normalizedToken id="C79B29767C5C86B568D0B562A4DE2B0F" originalValue="späten" pageId="null" pageNumber="261">spaeten</normalizedToken>
Winter und 
<normalizedToken id="E134FDFCBD5BE5123ED0218C0A32D25B" originalValue="Frühjahr" pageId="null" pageNumber="261">Fruehjahr</normalizedToken>
.
</paragraph>
<paragraph id="ED5EC07ABB7861D0660205C3D1D752CB" pageId="null" pageNumber="261">
<emphasis id="5D68BC209B2C6AD47C39E4819FD9EE2D" italics="true" pageId="null" pageNumber="261">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="3FC3575B9C8DA822D21E61FE0A7DF83C" italics="true" pageId="null" pageNumber="261">22:</emphasis>
Material aus Griechenland (Uhl in 
<normalizedToken id="061FD6025E635DA62A9AD115BEA8D1E1" originalValue="Löve" pageId="null" pageNumber="261">Loeve</normalizedToken>
und 
<normalizedToken id="CD9C71597FEFAC78720F6C4E560F01DF" originalValue="Löve" pageId="null" pageNumber="261">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="8488EE1643EC7D98D59A8358EF4AA202" pageId="null" pageNumber="261">
<emphasis id="8C44FAC9EC716C48D97EEB66C12C6828" italics="true" pageId="null" pageNumber="261">Standort.</emphasis>
Kollin. Feuchte, 
<normalizedToken id="E13FCB4204BADA80ED5C8F3CF3EA6AAB" originalValue="nährstoffreiche" pageId="null" pageNumber="261">naehrstoffreiche</normalizedToken>
, sandige bis lehmige, beschattete 
<normalizedToken id="663D97E9B310762A83F911EF04046007" originalValue="Böden" pageId="null" pageNumber="261">Boeden</normalizedToken>
. 
<normalizedToken id="AB3DE20D7A4CDA13E3991587D3EC81CD" originalValue="Wälder" pageId="null" pageNumber="261">Waelder</normalizedToken>
, 
<normalizedToken id="6BC1A0A987A8A1D3BB44DD285AE06B2C" originalValue="Böschungen" pageId="null" pageNumber="261">Boeschungen</normalizedToken>
, Mauern.
</paragraph>
<paragraph id="0B49C32FC6DB3C040871B060908043B5" pageId="null" pageNumber="261">
<emphasis id="8A47CA457BC30299FFE99BADCDFD4713" italics="true" pageId="null" pageNumber="261">
Verbreitung. 
<normalizedToken id="C8D790890E09A52A7BF0E8885F0542DE" originalValue="Südeuropäische" pageId="null" pageNumber="261">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
Spanien, in Westeuropa 
<normalizedToken id="7000BFD1087EBD7AE8F1ED5865B8F3D1" originalValue="nordwärts" pageId="null" pageNumber="261">nordwaerts</normalizedToken>
bis Belgien, Lothringen, 
<normalizedToken id="8558D9790B337AA6C946A434864643FA" originalValue="Elsaß" pageId="null" pageNumber="261">Elsass</normalizedToken>
; Apenninenhalbinsel, Judikarien, Balkanhalbinsel und Donaubecken. - Im Gebiet: 
<normalizedToken id="803C2AA4947AABA2AFD9CD5508144BA9" originalValue="Alpensüdfuß" pageId="null" pageNumber="261">Alpensuedfuss</normalizedToken>
(im Tessin 
<normalizedToken id="B3037F9C124E160D00B3408E3B7F9F4B" originalValue="nordwärts" pageId="null" pageNumber="261">nordwaerts</normalizedToken>
bis Bellinzona, in 
<normalizedToken id="FDD5EBA4A2E8F279DDB9774BFC8FE461" originalValue="Graubünden" pageId="null" pageNumber="261">Graubuenden</normalizedToken>
im Misox), Savoyen, 
<normalizedToken id="0C1384EC485D9B9E652946CE1C46E03E" originalValue="Französischer" pageId="null" pageNumber="261">Franzoesischer</normalizedToken>
Jura (Bletterans), Genf, Waadt (Communy, Coppet), 
<normalizedToken id="D07D867D18A8FA37CE9D38B6534F335A" originalValue="Elsaß" pageId="null" pageNumber="261">Elsass</normalizedToken>
, bei Zofingen 
<normalizedToken id="8F73E4482074FB6C029DEE0C223CBC40" originalValue="eingebürgert" pageId="null" pageNumber="261">eingebuergert</normalizedToken>
.
</paragraph>
</subSubSection>
