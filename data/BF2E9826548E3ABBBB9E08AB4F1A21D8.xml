<subSubSection id="94E960E9ED646B1397D321E5E6E74504" pageId="null" pageNumber="30" type="description">
<paragraph id="8B57660DB9B918502C3E124DA7272BE5" pageId="null" pageNumber="30">
<emphasis id="11D326ACC0334C5444AB62A8D48844CD" italics="true" pageId="null" pageNumber="30">
<normalizedToken id="B30F7101103EDFB0E5F1B44FF9D110A6" originalValue="Grundständige" pageId="null" pageNumber="30">Grundstaendige</normalizedToken>
<normalizedToken id="D78DF9D0AB06B45D6E8F0ADB8FE25758" originalValue="Blätter" pageId="null" pageNumber="30">Blaetter</normalizedToken>
in einer Rosette
</emphasis>
, breit oval, meist 
<normalizedToken id="B1C0597A8B606AAC87DA48238BF7EAA7" originalValue="±" pageId="null" pageNumber="30">+/-</normalizedToken>
<emphasis id="B852E1BF9F02BD13CC1F3424CB4A72BB" italics="true" pageId="null" pageNumber="30">stumpf</emphasis>
, etwas 
<normalizedToken id="7C08FE4B1574E6AC1BC483334E23B593" originalValue="über" pageId="null" pageNumber="30">ueber</normalizedToken>
der Mitte am breitesten, 
<normalizedToken id="29D83478BE7C44B612B692D59DC31A89" originalValue="1½" pageId="null" pageNumber="30">11/2</normalizedToken>
-2mal so lang wie breit, 
<emphasis id="B52E40E3EF0577742EB0642809B14396" italics="true" pageId="null" pageNumber="30">
kaum 1 cm lang, nur wenig 
<normalizedToken id="798243B688ADA327FE18B0BAA2477624" originalValue="größer" pageId="null" pageNumber="30">groesser</normalizedToken>
als die 
<normalizedToken id="1DA566C84D7A16111E8AD52AF7A6356C" originalValue="Stengelblätter" pageId="null" pageNumber="30">Stengelblaetter</normalizedToken>
, 
<normalizedToken id="A67DEAFE9E7C84B7E959B308AD58E0D4" originalValue="glänzend" pageId="null" pageNumber="30">glaenzend</normalizedToken>
, lederig, starr
</emphasis>
(im Gegensatz zu 
<taxonomicName id="F207147A214041CB6B8599BCE44A60BC" authority="Nr." authorityName="Nr." class="Magnoliopsida" family="Gentianaceae" genus="Gentiana" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="30" phylum="Tracheophyta" rank="species" species="verna">
<emphasis id="46D9FF968D5F537BADFCBC7055EDECA4" italics="true" pageId="null" pageNumber="30">G. verna</emphasis>
Nr.
</taxonomicName>
10a, sind die 
<normalizedToken id="3F8802B6109C0C12622EB948BCA0BDB5" originalValue="vorjährigen" pageId="null" pageNumber="30">vorjaehrigen</normalizedToken>
abgestorbenen, braunen 
<normalizedToken id="1C94E35B4D4AD81CBE393C5CCEB410FB" originalValue="Blätter" pageId="null" pageNumber="30">Blaetter</normalizedToken>
meist noch vorhanden). Kelch und Krone wie bei 
<taxonomicName id="72D7CF20F3FF487DB338D748A2B034EE" class="Magnoliopsida" family="Gentianaceae" genus="Gentiana" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="30" phylum="Tracheophyta" rank="species" species="verna">
<emphasis id="3F8FBB785EB6FB36AF86BC44CCA17E05" italics="true" pageId="null" pageNumber="30">G. verna</emphasis>
</taxonomicName>
, aber die Kronblattzipfel breiter. - 
<normalizedToken id="A675895260FAE9C0CDF62A11E59FE68A" originalValue="Blüte" pageId="null" pageNumber="30">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="01890C0CB5B8D033AA4DFC3477D4CDD4" pageId="null" pageNumber="30">
<emphasis id="7581DD4A10C1D4AE128C014A7AA5C3A3" italics="true" pageId="null" pageNumber="30">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="F0FEB9A6DF3452AD73D16F6DA3D78C4F" italics="true" pageId="null" pageNumber="30">28:</emphasis>
Material aus den 
<normalizedToken id="57F8FC402F43B23E30D30CFBD3CE92F3" originalValue="Waadtländer" pageId="null" pageNumber="30">Waadtlaender</normalizedToken>
Alpen (Favarger 1965), aus dem Val Queyras in den Westalpen (darunter auch Pflanzen mit 2 oder 4 B-Chromosomen, Favarger 1969). 
<emphasis id="A004B1B10D1A7F5207526A2CCC2ECEDB" italics="true" pageId="null" pageNumber="30">2n</emphasis>
= 
<emphasis id="CD67A4E0DFD4898E48F2D64F3196B9C6" italics="true" pageId="null" pageNumber="30">31</emphasis>
(wahrscheinlich 28+3 B-Chromosomen): Material aus der Sierra Nevada (
<normalizedToken id="1415BABDF6BFB152F35C919B923254D5" originalValue="Küpfer" pageId="null" pageNumber="30">Kuepfer</normalizedToken>
1968).
</paragraph>
<paragraph id="DB11EBE7846E2AF3A2A81AEDCC526232" pageId="null" pageNumber="30">
<emphasis id="03D12DB0BA446D48F0505EDCB952E9C4" italics="true" pageId="null" pageNumber="30">Standort.</emphasis>
Alpin. Ziemlich feuchte, kalkreiche, steinige 
<normalizedToken id="A290A6219486B5071050FBFB7277D788" originalValue="Böden" pageId="null" pageNumber="30">Boeden</normalizedToken>
. Lockere Rasen. Besonders im 
<emphasis id="47B998D52C1702AB651CC63EDE970252" italics="true" pageId="null" pageNumber="30">Caricetum firmae</emphasis>
Br.-Bl. 1926.
</paragraph>
<paragraph id="15DD94D41073BCBD529331C678A63218" pageId="null" pageNumber="30">
<emphasis id="22CE8DD74183ACCBCF2853986884CD0E" italics="true" pageId="null" pageNumber="30">
Verbreitung. Mittel- und 
<normalizedToken id="0DD8B584DE68E17511D0B508189DAB2E" originalValue="südeuropäische" pageId="null" pageNumber="30">suedeuropaeische</normalizedToken>
Gebirgspflanze:
</emphasis>
Sierra Nevada, 
<normalizedToken id="48371B9A83551C40427E4CC36C4A2FEF" originalValue="Pyrenäen" pageId="null" pageNumber="30">Pyrenaeen</normalizedToken>
, Alpen, Apennin (
<normalizedToken id="483E56209E08D61F423A8EDA9BF03256" originalValue="südwärts" pageId="null" pageNumber="30">suedwaerts</normalizedToken>
bis in die Abruzzen und Campania), Tatra, 
<normalizedToken id="C2CFB4FCB59791F0771AAB3785506B96" originalValue="Siebenbürgen" pageId="null" pageNumber="30">Siebenbuergen</normalizedToken>
. - Im Gebiet in den Alpen zerstreut, nicht 
<normalizedToken id="1216CE98BF84285207A7C046EF981CE7" originalValue="häufig" pageId="null" pageNumber="30">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
