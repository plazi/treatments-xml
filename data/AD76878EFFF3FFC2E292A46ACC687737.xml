<paragraph id="25603698FFF0FFFCE292A78ECB607195" blockId="30.[151,1312,1512,1536]" box="[151,1312,1512,1536]" pageId="30" pageNumber="331">
<emphasis id="17ABEA8AFFF0FFFCE292A78ECF59726A" bold="true" box="[151,281,1512,1536]" pageId="30" pageNumber="331">FIGURE 21</emphasis>
