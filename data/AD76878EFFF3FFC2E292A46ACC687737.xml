<taxonomicName id="E2DF4D1BFFF0FFFCE323A78ECCD2726A" authority="Scudder, 1890" authorityName="Scudder" authorityYear="1890" box="[294,658,1512,1536]" class="Insecta" family="Chrysopidae" genus="Palaeochrysa" kingdom="Animalia" order="Neuroptera" pageId="30" pageNumber="331" phylum="Arthropoda" rank="species" species="stricta">
<emphasis id="17ABEA8AFFF0FFFCE323A78ECFB97195" box="[294,505,1512,1536]" italics="true" pageId="30" pageNumber="331">Palaeochrysa stricta</emphasis>
<bibRefCitation id="414E4B69FFF0FFFCE3FAA78ECCD2726A" author="Scudder, S. H." box="[511,658,1512,1536]" pageId="30" pageNumber="331" pagination="1 - 734" refId="ref25710" refString="Scudder, S. H. (1890) The Tertiary insects of North America. Report of the United States Geological Survey of the Territories, 13, 1 - 734, 28 pls. https: // doi. org / 10.5962 / bhl. title. 44698" type="journal article" year="1890">Scudder, 1890</bibRefCitation>
