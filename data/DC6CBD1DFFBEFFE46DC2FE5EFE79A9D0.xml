<taxonomicName id="93C57788FFBEFFE46CEDFD02FE6DA9B6" authorityName="OPITZ" authorityYear="1997" box="[413,504,671,692]" class="Insecta" family="Cleridae" genus="Pilosirus" higherTaxonomySource="GBIF" kingdom="Animalia" order="Coleoptera" pageId="26" pageNumber="1555" phylum="Arthropoda" rank="genus">
