<subSubSection id="595A11EFDD132CD5C4F9B45B2C35A267" pageId="null" pageNumber="66" type="description">
<paragraph id="4C998FF11B0DD223465A24B452E2CE0D" pageId="null" pageNumber="66">
1 
<normalizedToken id="34E27D5BEF6F7FCD4DBA933DC965D223" originalValue="jährig" pageId="null" pageNumber="66">jaehrig</normalizedToken>
oder ausdauernd, bis 50 cm lang, untergetaucht, 
<emphasis id="BA50E3491F82937BCAAA2AEF051BFB7A" italics="true" pageId="null" pageNumber="66">im Schlamm kriechend.</emphasis>
Nur 
<emphasis id="D46894E9B51F0162DA35A8033158B2DD" italics="true" pageId="null" pageNumber="66">
<normalizedToken id="C2833744ED244E05B7A8F158B9ACDF1A" originalValue="Schwimmblätter" pageId="null" pageNumber="66">Schwimmblaetter</normalizedToken>
vorhanden
</emphasis>
, diese lang gestielt, im 
<normalizedToken id="DA452F78A55CA5CA40BC6028FA293049" originalValue="Umriß" pageId="null" pageNumber="66">Umriss</normalizedToken>
herz- bis 
<normalizedToken id="0E981A7F4B4D4F5E6C24292D74CC2E72" originalValue="nierenförmig" pageId="null" pageNumber="66">nierenfoermig</normalizedToken>
, bis auf ⅘ 3-5teilig, selten ganzrandig; Abschnitte stumpf. Stengel niederliegend, Spitze aufsteigend, verzweigt, 
<emphasis id="34C7F40442ACA21028D0C0D2F45355DC" italics="true" pageId="null" pageNumber="66">an den Knoten wurzelnd.</emphasis>
<normalizedToken id="58AB9BBE1767DDA1DB6F0229F62EC3A6" originalValue="Blütenstiele" pageId="null" pageNumber="66">Bluetenstiele</normalizedToken>
<normalizedToken id="E40DFB59948ABD2B16F556A08E57F560" originalValue="kürzer" pageId="null" pageNumber="66">kuerzer</normalizedToken>
als der Stiel des 
<normalizedToken id="F8B8A8F30672631F3C331ACBB930E6DA" originalValue="gegenüberstehenden" pageId="null" pageNumber="66">gegenueberstehenden</normalizedToken>
Blattes. 
<normalizedToken id="1FC884A4840E488C63C702A8B8BF6956" originalValue="Blüten" pageId="null" pageNumber="66">Blueten</normalizedToken>
klein, im Durchmesser bis 0,5 cm; 
<normalizedToken id="5C4279A4181F2E1154F74E41ABE6E7D2" originalValue="Kelchblätter" pageId="null" pageNumber="66">Kelchblaetter</normalizedToken>
wenig 
<normalizedToken id="C1FF3DF508BBA9405335358F076EEC19" originalValue="kürzer" pageId="null" pageNumber="66">kuerzer</normalizedToken>
als die 
<normalizedToken id="ED6CA5BC4882CD573B5F10F5F9FAA0D3" originalValue="Kronblätter" pageId="null" pageNumber="66">Kronblaetter</normalizedToken>
. 
<normalizedToken id="1BBCE19B52529A87C0FF69CB0D493CC1" originalValue="Früchtchen" pageId="null" pageNumber="66">Fruechtchen</normalizedToken>
oval, 1,4-1,7 mm lang und 0,9-1,1 mm breit, scharf gekielt, kahl, mit 10-14 deutlichen, oft unterbrochenen Querrippen. 
<normalizedToken id="2E7EC9BB4D5553379B1A4CBE8856BBD1" originalValue="Blütenboden" pageId="null" pageNumber="66">Bluetenboden</normalizedToken>
kugelig oder 
<normalizedToken id="98B529665CC692F91759EE072F308AD2" originalValue="eiförmig" pageId="null" pageNumber="66">eifoermig</normalizedToken>
, kahl.
</paragraph>
<paragraph id="0EEBD9496BCE071FD989EDB9FEAED2D8" pageId="null" pageNumber="66">
<emphasis id="D6E158D19B3AF52884D050AB6B4DE1A8" italics="true" pageId="null" pageNumber="66">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="BEC18131B40D4F6FAB1290C07BD9C4BB" italics="true" pageId="null" pageNumber="66">16:</emphasis>
Material aus 
<normalizedToken id="1709DF09A717F4D1A656FD88D1B98CA9" originalValue="Dänemark" pageId="null" pageNumber="66">Daenemark</normalizedToken>
. Pollenmeiose und Pollenentwicklung normal (
<normalizedToken id="859039BC2F1CDC43EF33048951FAD70E" originalValue="Böcher" pageId="null" pageNumber="66">Boecher</normalizedToken>
1938a); Material von mehreren Fundstellen in Portugal, England und Deutschland (Cook 1962Cook 1966).
</paragraph>
<paragraph id="2B49D1E1203859801A8FDEA6AB6F2D3F" pageId="null" pageNumber="66">
<emphasis id="61C6EA75CC825C43E83E8E6A67847E5A" italics="true" pageId="null" pageNumber="66">Standort.</emphasis>
Kollin. Kalkfreies, 
<normalizedToken id="488342A22B2487C8B344113C8C9A7B8E" originalValue="kühles" pageId="null" pageNumber="66">kuehles</normalizedToken>
, wenige Zentimeter tiefes Wasser. Quellfluren, 
<normalizedToken id="7581404D1C68447723CE23BC1A0DE59C" originalValue="Gräben" pageId="null" pageNumber="66">Graeben</normalizedToken>
. 
<normalizedToken id="5FC9ADC23A6679F73A19FFC5CF34EAF6" originalValue="Ausführliche" pageId="null" pageNumber="66">Ausfuehrliche</normalizedToken>
Standortsbeschreibungen und pflanzensoziologische Angaben von Segal (1967).
</paragraph>
<paragraph id="85CC1722235C741CA8EF08E6BFFA8E02" pageId="null" pageNumber="66">
<emphasis id="E4BC067E0FEA9150FD67723E32F4AB54" italics="true" pageId="null" pageNumber="66">
Verbreitung. 
<normalizedToken id="115C97AFD499BD8440FE870F25F79FF5" originalValue="Westeuropäisch-nordamerikanische" pageId="null" pageNumber="66">Westeuropaeisch-nordamerikanische</normalizedToken>
Pflanze:
</emphasis>
Irland, 
<normalizedToken id="25DD1F5F238068C59A5A65849F9DC008" originalValue="Großbritannien" pageId="null" pageNumber="66">Grossbritannien</normalizedToken>
, Norwegen (bei 63° NB), 
<normalizedToken id="C3BBEADCFFEF9CF2F033A968A54AC65D" originalValue="Dänemark" pageId="null" pageNumber="66">Daenemark</normalizedToken>
, Norddeutschland (wenige Fundstellen), Frankreich (westlich Rhein Rhone), Spanien und Portugal (wenige Fundstellen); atlantische 
<normalizedToken id="9BCE7095DB64123FB937BAD9469025C3" originalValue="Küste" pageId="null" pageNumber="66">Kueste</normalizedToken>
Nordamerikas zwischen 30 und 40° NB und Neufundland. Verbreitungskarten von 
<normalizedToken id="49E2A370C03BA67FF2EB332AAFFCAD30" originalValue="Hultén" pageId="null" pageNumber="66">Hulten</normalizedToken>
(1958), Meusel (1965) und Cook (1966). - Im Gebiet: 
<normalizedToken id="D4947D4443E1675EB0DB108DA0C24010" originalValue="Dép" pageId="null" pageNumber="66">Dep</normalizedToken>
. Jura und 
<normalizedToken id="CD543F31B7717402D49C3F2CEFC87C42" originalValue="Dép" pageId="null" pageNumber="66">Dep</normalizedToken>
. Doubs (Bresse, La Serre), Vogesen, Oberrheinische Tiefebene (in letzter Zeit nicht mehr gefunden).
</paragraph>
</subSubSection>
