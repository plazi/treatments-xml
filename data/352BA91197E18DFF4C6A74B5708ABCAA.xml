<subSubSection id="965256AD23DAD7D9779152130D79F042" pageId="null" pageNumber="353" type="description">
<paragraph id="F961E5A86B339A69BD5CCDC6F8586FD5" pageId="null" pageNumber="353">
Pflanzen 10-30 cm hoch. 
<normalizedToken id="70390483BA525579143488BEE02D96BE" originalValue="Grundständige" pageId="null" pageNumber="353">Grundstaendige</normalizedToken>
<normalizedToken id="473EDDD21755163F14F660C88FBE640E" originalValue="Blätter" pageId="null" pageNumber="353">Blaetter</normalizedToken>
im Durchmesser 2,5-10 cm, oberseits 
<emphasis id="09D3D79F3297227DD0382708ACB3A3C0" italics="true" pageId="null" pageNumber="353">
<normalizedToken id="9592F3EF270D104EB3D7173134E32FDA" originalValue="blaugrün" pageId="null" pageNumber="353">blaugruen</normalizedToken>
, dicht
</emphasis>
und abstehend behaart, unterseits heller 
<normalizedToken id="BE0B4D204D6461BBA47CEDF3580BB556" originalValue="blaugrün" pageId="null" pageNumber="353">blaugruen</normalizedToken>
, 
<emphasis id="71CAE26C7B91F4375C7A772BA961DE3D" italics="true" pageId="null" pageNumber="353">dicht</emphasis>
und abstehend behaart, meist bis auf ⅔ 9teilig; Abschnitte an 
<normalizedToken id="FC835348C7E0A88C406F3A83F585DA6D" originalValue="Frühlingsblättern" pageId="null" pageNumber="353">Fruehlingsblaettern</normalizedToken>
<normalizedToken id="D58E9A770BAD03E0A197439E42BB20F1" originalValue="halbkreisförmig" pageId="null" pageNumber="353">halbkreisfoermig</normalizedToken>
, an 
<normalizedToken id="652053F3EF3F2EB8D4BAE0FBA286EBED" originalValue="Sommerblättern" pageId="null" pageNumber="353">Sommerblaettern</normalizedToken>
schmal parabolisch, jederseits mit 6-9 
<normalizedToken id="4DE89B0F3D92A3469C0F9B1F84F1617A" originalValue="Zähnen" pageId="null" pageNumber="353">Zaehnen</normalizedToken>
; 
<normalizedToken id="140218789BF2105E21A293C32F2F9408" originalValue="Zähne" pageId="null" pageNumber="353">Zaehne</normalizedToken>
1-2 mm lang, 0,8-1,3mal so lang wie breit, an der Spitze oft etwas 
<normalizedToken id="6D5A69F386B272CA26FCF307D06B8501" originalValue="einwärts" pageId="null" pageNumber="353">einwaerts</normalizedToken>
gebogen; 
<emphasis id="22F9A7F5A1722AF21E1D06ED70CF1CE0" italics="true" pageId="null" pageNumber="353">Blattstiele sehr dicht und senkrecht abstehend behaart.</emphasis>
Stengel bogig aufsteigend, bis zu den untersten Verzweigungen des 
<normalizedToken id="2DE16F81FEB0E109970C3FA4A03B9BF1" originalValue="Blütenstandes" pageId="null" pageNumber="353">Bluetenstandes</normalizedToken>
<emphasis id="A55F80EEFF9C5E2DCC97415B5B2B5F60" italics="true" pageId="null" pageNumber="353">
sehr dicht und senkrecht abstehend behaart. 
<normalizedToken id="27FBB668D26A1D3421F7DA9F15AFF65C" originalValue="Äste" pageId="null" pageNumber="353">Aeste</normalizedToken>
des 
<normalizedToken id="A378CF62629F3A0C1273CC923D9C6B66" originalValue="Blütenstandes" pageId="null" pageNumber="353">Bluetenstandes</normalizedToken>
locker behaart.
</emphasis>
<normalizedToken id="C38F504CC40E92EF6B40F871CE36561F" originalValue="Kelchblätter" pageId="null" pageNumber="353">Kelchblaetter</normalizedToken>
und oft auch die Kelchbecher zerstreut und abstehend behaart bis kahl.
</paragraph>
<paragraph id="DA3A8039BE8162CEA737B42AC103C226" pageId="null" pageNumber="353">
<emphasis id="C7DA604B254C58B2EB18BE10409A37D0" italics="true" pageId="null" pageNumber="353">
<pageBreakToken id="44895319133733F9707385E383853BDC" pageId="null" pageNumber="353">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="EF460C5DF89339AF247E47B41E936B68" italics="true" pageId="null" pageNumber="353">101:</emphasis>
Material aus Skandinavien (Ehrenberg 1945). 
<emphasis id="B2F24B9FA6506B61DF59C3636F2FF1BB" italics="true" pageId="null" pageNumber="353">2n</emphasis>
= 
<emphasis id="6435D6A8266E4439DF9531C177A675BC" italics="true" pageId="null" pageNumber="353">103-109:</emphasis>
Material aus der Umgebung von 
<normalizedToken id="F6C922FD3F34E5322507768E285AC520" originalValue="Zürich" pageId="null" pageNumber="353">Zuerich</normalizedToken>
, aus dem Baltikum und von 20 Fundstellen in Skandinavien (Turesson 1957), aus England und Ostdeutschland (Wegener 1967).
</paragraph>
<paragraph id="4BC31FA6F3E605B6DD2574DB9A5D73AB" pageId="null" pageNumber="353">
<emphasis id="65CE9AFA32FBB202528AD98E30F05D09" italics="true" pageId="null" pageNumber="353">Standort.</emphasis>
Montan, subalpin, alpin, seltener kollin. Trockene, sandige bis steinige 
<normalizedToken id="C380D2412705DD0DB859A615F0D37820" originalValue="Böden" pageId="null" pageNumber="353">Boeden</normalizedToken>
. Magere Wiesen und Weiden.
</paragraph>
<paragraph id="BB34D3594CD10FE3B99343759D7EB2D9" pageId="null" pageNumber="353">
<emphasis id="F7117AC186660C9EEBABEC4F55919DCD" italics="true" pageId="null" pageNumber="353">Verbreitung. Eurosibirische Pflanze:</emphasis>
Alpen, Jura, deutsche Gebirge, Nordwestdeutschland, 
<normalizedToken id="9B28029FDFF50F7B22DBCA897922874F" originalValue="Großbritannien" pageId="null" pageNumber="353">Grossbritannien</normalizedToken>
, in Skandinavien bis 70° NB, Baltikum, Polen, Karpaten, Gebirge der Balkanhalbinsel, in 
<normalizedToken id="32D549B0A0DB74B82E093BAD9DC145AF" originalValue="Rußland" pageId="null" pageNumber="353">Russland</normalizedToken>
<normalizedToken id="3DCB33429046EE21AF444D32354358D1" originalValue="Südgrenze" pageId="null" pageNumber="353">Suedgrenze</normalizedToken>
durch unteres Wolga-Don-Gebiet; Ostgrenze in Zentralsibirien. - Im Gebiet eine der 
<normalizedToken id="1874C3920A251F9A9D28A83B55B83B54" originalValue="häufigsten" pageId="null" pageNumber="353">haeufigsten</normalizedToken>
<emphasis id="0697E63A9E696DF978A7D28AC222B3F4" italics="true" pageId="null" pageNumber="353">Alchemillaarten.</emphasis>
</paragraph>
<paragraph id="5A601E8B79C707F66A11E0ACECC9B7E4" pageId="null" pageNumber="353">
<emphasis id="0D42BBF6C481B51C475773982D41F744" italics="true" pageId="null" pageNumber="353">
Bemerkungen. 
<taxonomicName id="A3558EE778E2C2EFFCDD224ACD7F7CF2" class="Magnoliopsida" family="Rosaceae" genus="Alchemilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="353" phylum="Tracheophyta" rank="species" species="monticola">A. monticola</taxonomicName>
</emphasis>
wird oft mit 
<taxonomicName id="DD1584B5F0787CBAF15D3E22E29CE35B" class="Magnoliopsida" family="Rosaceae" genus="Alchemilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="353" phylum="Tracheophyta" rank="species" species="hybrida">
<emphasis id="8EC103838C2EF6ADC4AB36F81F16800E" italics="true" pageId="null" pageNumber="353">A. hybrida</emphasis>
</taxonomicName>
(Nr. 8a) verwechselt; es 
<normalizedToken id="EFA9594268E1994D3862C234EDB39031" originalValue="genügt" pageId="null" pageNumber="353">genuegt</normalizedToken>
, den 
<normalizedToken id="D729131E0703C66028C24E6B2D57E01B" originalValue="Blütenstand" pageId="null" pageNumber="353">Bluetenstand</normalizedToken>
zu betrachten, um die beiden Arten zu unterscheiden: 
<taxonomicName id="A82F9D17296C24C23B4E3B3DD76EA0B5" class="Magnoliopsida" family="Rosaceae" genus="Alchemilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="353" phylum="Tracheophyta" rank="species" species="hybrida">
<emphasis id="1F7D1B8AF4769CDB4FEEC37AB3C11D68" italics="true" pageId="null" pageNumber="353">A. hybrida</emphasis>
</taxonomicName>
hat dicht und abstehend 
<emphasis id="D4140AE183EED3AED0A085D4FDD0CDAD" italics="true" pageId="null" pageNumber="353">
behaarte 
<normalizedToken id="FC60D3C3C38EFEA2B30D1E968909CD93" originalValue="Blütenstiele" pageId="null" pageNumber="353">Bluetenstiele</normalizedToken>
</emphasis>
, bei 
<taxonomicName id="F62B2C6852FB3E895E745327827E20D1" class="Magnoliopsida" family="Rosaceae" genus="Alchemilla" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="353" phylum="Tracheophyta" rank="species" species="monticola">
<emphasis id="2267D1EFA3844C8AAFD2E66567EA4428" italics="true" pageId="null" pageNumber="353">A. monticola</emphasis>
</taxonomicName>
sind die 
<emphasis id="E145DEDF4B1727E6053C4B032D217936" italics="true" pageId="null" pageNumber="353">
<normalizedToken id="DE48C635BD249FCF90BC0F86D250E906" originalValue="Blütenstiele" pageId="null" pageNumber="353">Bluetenstiele</normalizedToken>
kahl.
</emphasis>
</paragraph>
</subSubSection>
