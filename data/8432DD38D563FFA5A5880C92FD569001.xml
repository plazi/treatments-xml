<taxonomicName id="CB9B17ADD563FFA6A4210AC3FE2F901B" authority="Mirab-balou &amp; Bazgir &amp; Mahmoodi, 2015" authorityName="Mirab-balou &amp; Bazgir &amp; Mahmoodi" authorityYear="2015" box="[263,448,1790,1812]" class="Insecta" family="Thripidae" genus="Eryngyothrips" kingdom="Animalia" order="Thysanoptera" pageId="1" pageNumber="472" phylum="Arthropoda" rank="species" species="veisii" status="sp. n.">
<emphasis id="3EEFB03CD563FFA6A4210AC3FE2F901B" box="[263,448,1790,1812]" italics="true" pageId="1" pageNumber="472">Eryngyothrips veisii</emphasis>
</taxonomicName>
<taxonomicNameLabel id="25DC0D47D563FFA6A4E10AC3FE14901B" box="[455,507,1790,1812]" pageId="1" pageNumber="472" rank="species">sp. n.</taxonomicNameLabel>
: 1 
<emphasis id="3EEFB03CD563FFA6A7310AC3FDC2901C" box="[535,557,1790,1811]" italics="true" pageId="1" pageNumber="472">—</emphasis>
antenna; 2 
<emphasis id="3EEFB03CD563FFA6A7BB0AC3FD5C901C" box="[669,691,1790,1811]" italics="true" pageId="1" pageNumber="472">—</emphasis>
