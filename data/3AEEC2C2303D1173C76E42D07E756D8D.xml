<subSubSection id="AA0EBFFBFA15EEDF77D2E6B64238AD35" pageId="null" pageNumber="479" type="nomenclature">
<paragraph id="46BD7E7B0066D3C68B449E89CED04F0E" pageId="null" pageNumber="479">
<taxonomicName id="52011A485333A55D3103AF49C24FE07B" class="Magnoliopsida" family="Asteraceae" genus="Gnaphalium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="479" phylum="Tracheophyta" rank="genus">Gnaphalium</taxonomicName>
<normalizedToken id="52901A19CBFA8A930BCCD0B88B500EED" originalValue="norvégicum" pageId="null" pageNumber="479">norvegicum</normalizedToken>
Gunnerus
</paragraph>
</subSubSection>
<subSubSection id="38EF311F1E1A88A7D0581B88361C15CB" pageId="null" pageNumber="479" type="vernacular_names">
<paragraph id="D938E4B5B2F3BF0A38E9E35795BA0D4E" pageId="null" pageNumber="479">Norwegisches Ruhrkraut</paragraph>
</subSubSection>
</title>
<subSubSection id="D6854E4F350A619E165CCEC8E240FA5C" pageId="null" pageNumber="479" type="description">
<paragraph id="099CD30164F86EA0390DFB3C18B2FDB1" pageId="null" pageNumber="479">
Unterscheidet sich von 
<taxonomicName id="37CEB43FB00ED1962B1567F7DA1DB8E3" class="Magnoliopsida" family="Asteraceae" genus="Gnaphalium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="479" phylum="Tracheophyta" rank="species" species="silvaticum">
<emphasis id="E22D6FC145F3A0FE9CB7DAA2E0BA801D" italics="true" pageId="null" pageNumber="479">G. silvaticum</emphasis>
</taxonomicName>
(Nr. 5) durch folgende Merkmale: 
<emphasis id="1087FE9917AD68B1F2F3ED81632D3794" italics="true" pageId="null" pageNumber="479">
<normalizedToken id="3ECF26003FDDFF2D9F9DFDC5E755CC1D" originalValue="Blätter" pageId="null" pageNumber="479">Blaetter</normalizedToken>
meist 3nervig, bis 15 cm lang und 2 cm breit;
</emphasis>
die untersten 
<normalizedToken id="FEDE364ED11B382FC9773EDA17250E60" originalValue="Blätter" pageId="null" pageNumber="479">Blaetter</normalizedToken>
im 
<normalizedToken id="73B5C72CECAAE35852134D9A237A5886" originalValue="Gesamtblütenstand" pageId="null" pageNumber="479">Gesamtbluetenstand</normalizedToken>
<emphasis id="86AC3A035112E9CD76963CAF21F9CE78" italics="true" pageId="null" pageNumber="479">
<normalizedToken id="9A350E16453F0A031F9C39B29C5838F6" originalValue="länger" pageId="null" pageNumber="479">laenger</normalizedToken>
als dieser oder mindestens 5 cm lang, am Grunde 
<normalizedToken id="89205BE8E232A52673C498B238A6741B" originalValue="verschmälert" pageId="null" pageNumber="479">verschmaelert</normalizedToken>
; 
<normalizedToken id="F4891FD1427E4DD267B94A3DFB712A28" originalValue="Hüllblätter" pageId="null" pageNumber="479">Huellblaetter</normalizedToken>
mit auch 
<normalizedToken id="3DDB55E40BF84C12D5B87E1725DD1B9D" originalValue="außen" pageId="null" pageNumber="479">aussen</normalizedToken>
dunkelbraunem, nicht durchsichtigem Rand
</emphasis>
, meist stumpf und 
<emphasis id="0D8C4B7E1D6E16CB1DE47B341B0E85FC" italics="true" pageId="null" pageNumber="479">ganzrandig.</emphasis>
- 
<normalizedToken id="F288F535E74BD7126FE983A9097852BB" originalValue="Blüte" pageId="null" pageNumber="479">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="796789F41B6C661FA5C4F1A04DF8984B" pageId="null" pageNumber="479">
<emphasis id="15E31E6EED9CDABA06B3988AA7C69F2E" italics="true" pageId="null" pageNumber="479">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5C317E501375A77B6094DC115D9B0D81" italics="true" pageId="null" pageNumber="479">56:</emphasis>
Material aus Skandinavien (
<normalizedToken id="532F0ACF0F997F20A541DC9565B01383" originalValue="Löve" pageId="null" pageNumber="479">Loeve</normalizedToken>
und 
<normalizedToken id="1B84F8691986B0D8A0BA8F2B7B6573F0" originalValue="Löve" pageId="null" pageNumber="479">Loeve</normalizedToken>
1944b), aus Island (
<normalizedToken id="C32BE015207672506C179565CEAA0B3A" originalValue="Löve" pageId="null" pageNumber="479">Loeve</normalizedToken>
und 
<normalizedToken id="E0083A25FD0D99CEF89A2F64A28D08F9" originalValue="Löve" pageId="null" pageNumber="479">Loeve</normalizedToken>
1956b), aus den Sudeten und der Tatra (Skalinska et al. 1959), aus 
<normalizedToken id="7773039BE2C79EC26D63B0FBC17E6724" originalValue="Nordrußland" pageId="null" pageNumber="479">Nordrussland</normalizedToken>
(Sokolovskaya und Strelkova 1960). 
<emphasis id="CBEE80B6876C5374199478DC27244AE3" italics="true" pageId="null" pageNumber="479">2n</emphasis>
= 
<emphasis id="E558C9ED43F2AEDA6BF28714A0E6E309" italics="true" pageId="null" pageNumber="479">54</emphasis>
- 
<emphasis id="0B6592B7A79A29B4B83E76606F77088D" italics="true" pageId="null" pageNumber="479">57:</emphasis>
Material aus 
<normalizedToken id="F52B63B49332A66391E6CA1225025D91" originalValue="Grönland" pageId="null" pageNumber="479">Groenland</normalizedToken>
(
<normalizedToken id="23FC5431F7C697362ACA388B14D3E7CE" originalValue="Jörgensen" pageId="null" pageNumber="479">Joergensen</normalizedToken>
et al. 1958).
</paragraph>
<paragraph id="BAFA290EC12C1B157419D897AA972B6E" pageId="null" pageNumber="479">
<emphasis id="27FCA1824A2514C0B6A9DE12E8899BAC" italics="true" pageId="null" pageNumber="479">Standort.</emphasis>
Subalpin, selten alpin. 
<normalizedToken id="1DC8A447F520D51AF733E0BF1D2BCED0" originalValue="Mäßig" pageId="null" pageNumber="479">Maessig</normalizedToken>
feuchte, kalkarme, humose 
<normalizedToken id="B2B5F22629BECD21C25A7E2C9A5B434A" originalValue="Böden" pageId="null" pageNumber="479">Boeden</normalizedToken>
in schattigen Lagen. Lichte 
<normalizedToken id="F231FCF404A6E09DEB7785FED8F1AC16" originalValue="Wälder" pageId="null" pageNumber="479">Waelder</normalizedToken>
, grasige 
<normalizedToken id="D2C284697C585EA06073C623FD2BAA9F" originalValue="Hänge" pageId="null" pageNumber="479">Haenge</normalizedToken>
, Weiden, Zwergstrauchgesellschaften.
</paragraph>
<paragraph id="4D86A4779AFF59597446FAA0218C94CB" pageId="null" pageNumber="479">
<emphasis id="473B12F8B27812EAE8D75B0C270B65F3" italics="true" pageId="null" pageNumber="479">Verbreitung. Eurosibirisch-nordamerikanische Pflanze:</emphasis>
Skandinavien, Schottland, 
<normalizedToken id="165D64E21D0579299050BDF20AA041DE" originalValue="Pyrenäen" pageId="null" pageNumber="479">Pyrenaeen</normalizedToken>
, Plateau Central, Vogesen, Schwarzwald, Jura, Alpen, 
<normalizedToken id="B4E055583272368B9529509AE9980118" originalValue="Böhmerwald" pageId="null" pageNumber="479">Boehmerwald</normalizedToken>
, Erzgebirge, Sudeten, Karpaten, Gebirge der Balkanhalbinsel (
<normalizedToken id="17923341969CB2A3577E7008EF3C1625" originalValue="südwärts" pageId="null" pageNumber="479">suedwaerts</normalizedToken>
bis Mazedonien); Kaukasus, Ural, Sibirien, Altai; 
<normalizedToken id="B834CC43EB9078E6556D461C5FAFBB75" originalValue="Grönland" pageId="null" pageNumber="479">Groenland</normalizedToken>
; Nordamerika (Baffinland, Labrador, Neufundland, Quebec). Verbreitungskarte von 
<normalizedToken id="1AC366463ECBE0B2C38F6C30D519C221" originalValue="Hultén" pageId="null" pageNumber="479">Hulten</normalizedToken>
(1958). - Im Gebiet: Alpen, Jura (Chasseron), Vogesen, Schwarzwald; nicht 
<normalizedToken id="F9949AE33E487DB451DBFA9E8D7589C5" originalValue="häufig" pageId="null" pageNumber="479">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
