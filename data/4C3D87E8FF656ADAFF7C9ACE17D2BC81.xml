<quantity id="036C9B1BFF656ADAF6AB90761403BD62" box="[2391,2563,1583,1616]" metricMagnitude="3" metricUnit="m" metricValue="1.5375" metricValueMax="2.55" metricValueMin="0.525" pageId="158" pageNumber="919" unit="m" value="1537.5" valueMax="2550.0" valueMin="525.0">525-2550 m</quantity>
.
</paragraph>
