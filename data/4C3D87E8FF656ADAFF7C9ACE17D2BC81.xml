<subSubSection id="8C8E6575FF656ADAFF829B7B16E1B808" pageId="158" pageNumber="919" type="reference_group">
<paragraph id="C42B36FEFF656ADAFF829B7B16E1B808" blockId="158.[125,1335,3362,3472]" lastBlockId="158.[1406,2620,719,1971]" pageId="158" pageNumber="919">
<emphasis id="F6E0EAECFF656ADAFF829B7B1F1EB609" bold="true" box="[126,286,3362,3387]" pageId="158" pageNumber="919">Taxonomy.</emphasis>
<taxonomicName id="03944D7DFF656ADAFECC9B7B1CF2B609" authority="Furey et al., 2009" authorityName="Furey" authorityYear="2009" box="[304,754,3362,3387]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="eleryi">Murina eleryi Furey et al., 2009</taxonomicName>
, “Kim Hy Commune, Na Ri district of Kim Hy Nature Reserve, 
<collectingRegion id="0650F81CFF656ADAFE099B101CFCB650" box="[501,764,3401,3426]" country="Vietnam" name="Bac Kan" pageId="158" pageNumber="919">Bac Kan province</collectingRegion>
, 
<collectingCountry id="BC83766EFF656ADAFCF19B101D8CB650" box="[781,908,3401,3426]" name="Vietnam" pageId="158" pageNumber="919">Vietnam</collectingCountry>
, 
<geoCoordinate id="A1A05039FF656ADAFC5C9B101A55B650" box="[928,1109,3401,3426]" degrees="22" direction="north" minutes="16.392" orientation="latitude" pageId="158" pageNumber="919" precision="1" value="22.2732">22°16.392’N</geoCoordinate>
, 
<geoCoordinate id="A1A05039FF656ADAFB919B101B2CB650" box="[1133,1324,3401,3426]" degrees="106" direction="east" minutes="03.427" orientation="longitude" pageId="158" pageNumber="919" precision="1" value="106.05711">106°03.427’E</geoCoordinate>
, 
<quantity id="036C9B1BFF656ADAFF829B351ED5B6BB" box="[126,213,3436,3465]" metricMagnitude="2" metricUnit="m" metricValue="5.25" pageId="158" pageNumber="919" unit="m" value="525.0">525 m</quantity>
a.s.l. (above sea level).” Specimens now attributed to 
<taxonomicName id="03944D7DFF656ADAF679974317F2BA09" authority="Furey et al., 2009" authorityName="Furey" authorityYear="2009" box="[2437,2546,282,315]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="eleryi">M. eleryi</taxonomicName>
were previously considered to be 
<taxonomicName id="03944D7DFF656ADAF68E971F17F5BA51" authorityName="Milne-Edwards" authorityYear="1872" box="[2418,2549,326,355]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="aurata">M. aurata</taxonomicName>
. 
<taxonomicName id="03944D7DFF656ADAF5F9971F1671BAB8" authority="Furey et al., 2009" authorityName="Furey" authorityYear="2009" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="eleryi">Murina eleryi</taxonomicName>
was originally described solely from 
<collectingCountry id="BC83766EFF656ADAF7C297C016B8BA80" box="[2110,2232,409,434]" name="Vietnam" pageId="158" pageNumber="919">Vietnam</collectingCountry>
, but later studies showed that other specimens from South-east Asia might also be included underit instead of 
<taxonomicName id="03944D7DFF656ADAF8169452166FB91A" authorityName="Milne-Edwards" authorityYear="1872" box="[2026,2159,523,552]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="aurata">M. aurata</taxonomicName>
, potentially restricting 
<taxonomicName id="03944D7DFF656ADAF64B9452143BB91A" authorityName="Milne-Edwards" authorityYear="1872" box="[2487,2619,523,552]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="aurata">M. aurata</taxonomicName>
to the Tibetan region. Based on limited genetic data, 
<taxonomicName id="03944D7DFF656ADAF7569403171AB945" authority="Furey et al., 2009" authorityName="Furey" authorityYear="2009" box="[2218,2330,602,631]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="eleryi">M. eleryi</taxonomicName>
appears to be closely related to 
<taxonomicName id="03944D7DFF656ADAF75494D8174DB9AC" authority="Soisook et al., 2013" authorityName="Soisook" authorityYear="2013" box="[2216,2381,641,670]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="balaensis">M. balaensis</taxonomicName>
, 
<taxonomicName id="03944D7DFF656ADAF69F94D817F0B9AC" authority="Kuo Haochih et al., 2009" authorityName="Kuo Haochih" authorityYear="2009" box="[2403,2544,641,670]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="gracilis">M. gracilis</taxonomicName>
, and 
<taxonomicName id="03944D7DFF656ADAF81694FD1693B9F7" authority="Kuo Haochih et al. 2009" authorityName="Kuo Haochih" box="[2026,2195,676,709]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="recondita">M. recondita</taxonomicName>
. In a genetic study in 2017, specimens identified as 
<taxonomicName id="03944D7DFF656ADAF92494961974B9DE" box="[1752,1908,719,748]" class="Mammalia" family="Vespertilionidae" genus="Murina" isUncertain="true" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="eleryi">M. cf. eleryi</taxonomicName>
from 
<collectingCountry id="BC83766EFF656ADAF83794961651B9DE" box="[1995,2129,719,748]" name="Myanmar" pageId="158" pageNumber="919">Myanmar</collectingCountry>
clustered separately from 
<taxonomicName id="03944D7DFF656ADAF6309496143CB9DE" authority="Furey et al., 2009" authorityName="Furey" authorityYear="2009" box="[2508,2620,719,748]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="eleryi">M. eleryi</taxonomicName>
from 
<collectingCountry id="BC83766EFF656ADAFA2994AB1817B821" box="[1493,1559,754,787]" name="Laos" pageId="158" pageNumber="919">Laos</collectingCountry>
, 
<collectingCountry id="BC83766EFF656ADAF9D594AB18A3B821" box="[1577,1699,754,787]" name="Vietnam" pageId="158" pageNumber="919">Vietnam</collectingCountry>
, and 
<collectingCountry id="BC83766EFF656ADAF90594AB194FB821" box="[1785,1871,754,787]" name="China" pageId="158" pageNumber="919">China</collectingCountry>
, suggesting that they represent true 
<taxonomicName id="03944D7DFF656ADAF69494AB17F1B821" authorityName="Milne-Edwards" authorityYear="1872" box="[2408,2545,754,787]" class="Mammalia" family="Vespertilionidae" genus="Murina" kingdom="Animalia" order="Chiroptera" pageId="158" pageNumber="919" phylum="Chordata" rank="species" species="aurata">M. aurata</taxonomicName>
(not included in the study) or an undescribed species. Monotypic.
</paragraph>
</subSubSection>
