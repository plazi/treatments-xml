, 
<bibRefCitation id="2E16E6CD3E2069183153D244FBF5FD85" author="GEGECHKORI &amp; LOGINOVA" box="[782,1121,607,631]" firstAuthor="GEGECHKORI" pageId="16" pageNumber="17" refId="ref9895" refString="GEGECHKORI A. M. &amp; LOGINOVA M. M. 1990: Psillidy (Homoptera, Psylloidea) SSSR (annotirovannyy spisok). [The Psyllids (Homoptera, Psylloidea) of the USSR (an annotated check list)]. Mecniereba, Tbilisi, 191 pp (in Russian, English summary)." type="book" year="1990">GEGECHKORI &amp; LOGINOVA 1990</bibRefCitation>
, 
<bibRefCitation id="2E16E6CD3E20691832CAD29BFE70FD65" author="BURCKHARDT &amp; LAUTERER" box="[151,484,639,663]" firstAuthor="BURCKHARDT" pageId="16" pageNumber="17" pagination="99 - 153" refId="ref9650" refString="BURCKHARDT D. &amp; LAUTERER P. 1997: A taxonomic reassessment of the triozid genus Bactericera (Hemiptera, Psylloidea). Journal of Natural History 31: 99 - 153." type="journal article" year="1997">BURCKHARDT &amp; LAUTERER 1997</bibRefCitation>
, 
<bibRefCitation id="2E16E6CD3E20691833B2D29BFDD1FD65" author="LI" box="[495,581,639,663]" firstAuthor="LI" pageId="16" pageNumber="17" refId="ref10438" refString="LI F. 2011: [Psyllidomorpha of China (Insecta: Hemiptera)]. Science Press, Beijing, China, 1976 pages + 19 plates (in Chinese, English summary)." type="book" year="2011">LI 2011</bibRefCitation>
