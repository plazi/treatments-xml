<collectingCountry box="[359,426,1519,1545]" name="China" pageId="6" pageNumber="299">China</collectingCountry>
(
<collectingRegion box="[441,576,1519,1545]" country="China" name="Guangdong" pageId="6" pageNumber="299">Guangdong</collectingRegion>
, 
<collectingRegion box="[587,671,1519,1545]" country="China" name="Hainan" pageId="6" pageNumber="299">Hainan</collectingRegion>
