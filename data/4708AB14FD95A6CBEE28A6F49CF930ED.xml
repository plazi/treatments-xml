<taxonomicName id="0C58DA183334B04B84C856D13EE5C92C" authority="Cavanilles" class="Magnoliopsida" family="Asteraceae" genus="Galinsoga" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="508" phylum="Tracheophyta" rank="species" species="parviflora">
Galinsoga 
<normalizedToken id="4785CA5BE85179A083F2EC75003EE95C" originalValue="parviflóra" pageId="null" pageNumber="508">parviflora</normalizedToken>
Cavanilles
</taxonomicName>
