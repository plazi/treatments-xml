do Xingu, Cave SFX-0057, 
<geoCoordinate id="CA53D680D8AA979CE1106523176AFF87" degrees="6" direction="south" minutes="24" orientation="latitude" precision="1" seconds="06.2" value="-6.4017224">6°24'06.2&quot;S</geoCoordinate>
