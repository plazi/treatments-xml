<geoCoordinate id="7DB2C2DB2C76DC1793BC589FA67088FF" degrees="51" direction="west" minutes="54" orientation="longitude" precision="1" seconds="08.1" value="-51.902252">51°54'08.1&quot;W</geoCoordinate>
