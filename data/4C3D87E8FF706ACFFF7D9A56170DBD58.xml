No information.
</paragraph>
</subSubSection>
<subSubSection id="8C8E6575FF706ACFFA7F92CC18F9BF84" box="[1411,1785,1173,1206]" pageId="139" pageNumber="899" type="breeding">
<paragraph id="C42B36FEFF706ACFFA7F92CC18F9BF84" blockId="139.[1410,2620,741,1642]" box="[1411,1785,1173,1206]" pageId="139" pageNumber="899">
