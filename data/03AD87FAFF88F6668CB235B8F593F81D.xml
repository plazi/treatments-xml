<subSubSection id="C31E6567FF88F66681133649F6DDFD26" pageId="76" pageNumber="134" type="reference_group">
<paragraph id="8BBB36ECFF88F66681133649F6DDFD26" blockId="76.[2061,2655,597,1017]" pageId="76" pageNumber="134">
<emphasis id="B970EAFEFF88F66681133649F70CFDF5" bold="true" box="[2061,2217,597,622]" pageId="76" pageNumber="134">Taxonomy.</emphasis>
<taxonomicName id="4C044D6FFF88F66681A63649F7F6FD0D" authority="K. Andersen, 1909" authorityName="K. Andersen" authorityYear="1909" class="Mammalia" family="Pteropodidae" genus="Acerodon" kingdom="Animalia" order="Chiroptera" pageId="76" pageNumber="134" phylum="Chordata" rank="species" species="humilis">Acerodon humilis K. Andersen, 1909</taxonomicName>
