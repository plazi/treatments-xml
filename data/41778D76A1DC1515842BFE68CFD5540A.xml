<subSubSection id="7798B4ABA8453F228B8716899BFB36F5" pageId="null" pageNumber="228" type="description">
<paragraph id="1F705614B937CC8C3892F8F360DAC823" pageId="null" pageNumber="228">
Unterscheidet sich von 
<emphasis id="C577EBB0AC7CC910E5BAEA8142BB4512" italics="true" pageId="null" pageNumber="228">P. rostrato-capitata</emphasis>
(Nr. 8) durch folgende Merkmale: 5-15 cm hoch; 
<emphasis id="B70931AA45F0C9AD15CB803D54B5FC0B" italics="true" pageId="null" pageNumber="228">Stengel niederliegend oder auf steigend;</emphasis>
<normalizedToken id="470C47B15B6E4DA37910CBEF656C27FA" originalValue="Blätter" pageId="null" pageNumber="228">Blaetter</normalizedToken>
gelegentlich behaart; Blattabschnitte 
<normalizedToken id="8337AC2C186F0BCB54546397879EE8C6" originalValue="gezähnt" pageId="null" pageNumber="228">gezaehnt</normalizedToken>
, mit kaum 1 mm langen 
<normalizedToken id="4AFC83A860ABAE5FF57DD7057FF0ACB5" originalValue="Zähnen" pageId="null" pageNumber="228">Zaehnen</normalizedToken>
; 
<emphasis id="D1B805DAEC8BFA5EEFE7611364576908" italics="true" pageId="null" pageNumber="228">
<normalizedToken id="610AF3E7974C13FC1A2C104A2AA8B88C" originalValue="Blüten" pageId="null" pageNumber="228">Blueten</normalizedToken>
wenige
</emphasis>
(
<emphasis id="23930DC19C1C8DD12E0898E73D4176CB" italics="true" pageId="null" pageNumber="228">oft nur 1</emphasis>
- 
<emphasis id="DB6996C42CA734BD7A7480876DCBB707" italics="true" pageId="null" pageNumber="228">3</emphasis>
)
<emphasis id="AB041BF9E0CD16B14F365A08C780064C" italics="true" pageId="null" pageNumber="228">; Kelch 6</emphasis>
- 
<emphasis id="827DD899FC8016C7A87F564AD38EC027" italics="true" pageId="null" pageNumber="228">
9 mm lang, am Grunde 
<normalizedToken id="565447BA6DFD7D6C284B84E8DB68DDD3" originalValue="allmählich" pageId="null" pageNumber="228">allmaehlich</normalizedToken>
<normalizedToken id="0018AC39B3DF577A9AA7BE1B96240FF4" originalValue="verschmälert" pageId="null" pageNumber="228">verschmaelert</normalizedToken>
, 
<normalizedToken id="8CB09A5E8FC223881912555377472332" originalValue="außen" pageId="null" pageNumber="228">aussen</normalizedToken>
kahl oder zerstreut behaart, am Rande und auf der Innenseite der Zipfel kurz und dicht behaart
</emphasis>
(
<emphasis id="C71ED8BC877440D260886247868AA83D" italics="true" pageId="null" pageNumber="228">
Haare 
<normalizedToken id="01EA4046BBEECF6D1511A47441809816" originalValue="kürzer" pageId="null" pageNumber="228">kuerzer</normalizedToken>
als 1 mm
</emphasis>
)
<emphasis id="7CA89DB68A8A35CB7CC0C35D892E35AA" italics="true" pageId="null" pageNumber="228">;</emphasis>
Unterlippe abstehend, 
<emphasis id="4634F89DC2354BA3B38BF3FE06F8BE12" italics="true" pageId="null" pageNumber="228">kahl.</emphasis>
- 
<normalizedToken id="27990ED0F3973ECA786CDA42C56B910B" originalValue="Blüte" pageId="null" pageNumber="228">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="F6CD45048864A29F7BADD376F2DA5B74" pageId="null" pageNumber="228">
<emphasis id="ABA2C7C5DB5BBF058551B4F5E4CE75EB" italics="true" pageId="null" pageNumber="228">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B4A31A247FA72012E1F970A57CAE19D7" italics="true" pageId="null" pageNumber="228">16:</emphasis>
Material vom Simplon (Favarger 1959), aus dem Val Queyras in den Westalpen (Favarger 1969).
</paragraph>
<paragraph id="54BFD9C443949BF543BFFEEBFF3E476C" pageId="null" pageNumber="228">
<emphasis id="45E8121F3FEA80B5ABDC642D49C43785" italics="true" pageId="null" pageNumber="228">
<pageBreakToken id="7824133372455FC80122A61A10F0FC60" pageId="null" pageNumber="228">Standort</pageBreakToken>
</emphasis>
. Alpin (bis 
<normalizedToken id="879A61E6F649F9A6AE820B3D7EF0848E" originalValue="über" pageId="null" pageNumber="228">ueber</normalizedToken>
3200 m), selten subalpin. Steinige, kalkarme 
<normalizedToken id="6FA602D9EE8F1FDC044D0D9F172C8BAA" originalValue="Böden" pageId="null" pageNumber="228">Boeden</normalizedToken>
. Wiesen, Weiden, Felsschutt. 
<emphasis id="140312759397003C1DD1FF713FA224AE" italics="true" pageId="null" pageNumber="228">Caricetum curvulae</emphasis>
Brockmann-Jerosch 1907; 
<emphasis id="748B576BAC2A3035BC787F0F30EC71E7" italics="true" pageId="null" pageNumber="228">Oxyrietum digynae</emphasis>
Br.-Bl. 1926.
</paragraph>
<paragraph id="C3273EF3E7F7FB67E0A67DD05748CEF5" pageId="null" pageNumber="228">
<emphasis id="1EDC7C7F325CED03E7E9CB6A604D2950" italics="true" pageId="null" pageNumber="228">
Verbreitung. 
<normalizedToken id="6A2B58B5188B47919F3ACDF14A0C8430" originalValue="Alpin-pyrenäische" pageId="null" pageNumber="228">Alpin-pyrenaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="8E1E95DDCB9D231F07624CACC9D4ACEC" originalValue="Pyrenäen" pageId="null" pageNumber="228">Pyrenaeen</normalizedToken>
, Alpen (
<normalizedToken id="7EB2B2211C34360280C6FA4349DFF516" originalValue="ostwärts" pageId="null" pageNumber="228">ostwaerts</normalizedToken>
bis Salzburg und 
<normalizedToken id="808C3A3C0ABAE098B331B90D8E865FFB" originalValue="Kärnten" pageId="null" pageNumber="228">Kaernten</normalizedToken>
). Verbreitungskarte von 
<normalizedToken id="8321D1822C69F0CDCD4F6A79CCE1113E" originalValue="Merxmüller" pageId="null" pageNumber="228">Merxmueller</normalizedToken>
(1952). - Im Gebiet: Zentral- und 
<normalizedToken id="DDB78E5D329AB63CA70178DA9DD7F2B3" originalValue="Südalpen" pageId="null" pageNumber="228">Suedalpen</normalizedToken>
, ziemlich 
<normalizedToken id="60EA4CAB571F6C3BE8B23118C21477D0" originalValue="häufig" pageId="null" pageNumber="228">haeufig</normalizedToken>
; Nordalpen, selten.
</paragraph>
</subSubSection>
