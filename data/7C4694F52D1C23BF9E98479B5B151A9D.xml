<subSubSection id="14D41029AD304BBF88E0C612462FA344" pageId="null" pageNumber="434" type="vernacular_names">
<paragraph id="86D5686B9EA051F9573EA4A75C8111A6" pageId="null" pageNumber="434">Pairas Segge</paragraph>
</subSubSection>
</title>
<subSubSection id="26863438259556459FDBA11E7A66ACCF" pageId="null" pageNumber="434" type="description">
<paragraph id="58A3017BA9A6CCFCEA677B7AD7BB10DF" pageId="null" pageNumber="434">
15-60 cm hoch. 
<normalizedToken id="31D83F1F64EC9356D9A7B4857209295B" originalValue="Blätter" pageId="null" pageNumber="434">Blaetter</normalizedToken>
2-3 mm breit, etwa 
<normalizedToken id="A2C3446534898E9C384DA530A149C3A6" originalValue="½" pageId="null" pageNumber="434">1/2</normalizedToken>
so lang wie der Stengel; 
<emphasis id="77A362646DAFD7970B2F34C5D31940ED" italics="true" pageId="null" pageNumber="434">
<normalizedToken id="DCF12A850560DCE402B4E4DF24528B7C" originalValue="Blatthäutchen" pageId="null" pageNumber="434">Blatthaeutchen</normalizedToken>
meist breiter als hoch.
</emphasis>
Stengel und 
<normalizedToken id="553ECF2D266FCB2054780876F1FC5B77" originalValue="Blütenstand" pageId="null" pageNumber="434">Bluetenstand</normalizedToken>
wie bei 
<taxonomicName id="700F45F08671B6215D70A185C412874D" class="Liliopsida" family="Cyperaceae" genus="Carex" kingdom="Plantae" order="Poales" pageId="null" pageNumber="434" phylum="Tracheophyta" rank="species" species="contigua">
<emphasis id="1C8F9CEC679572B46C1A8EF525AB9482" italics="true" pageId="null" pageNumber="434">C. contigua</emphasis>
</taxonomicName>
(Nr. 20a). 
<emphasis id="264FC7373AA8CC7FB98C6AF01750FD96" italics="true" pageId="null" pageNumber="434">
<normalizedToken id="4580FE7741B7C80EE75AB7BEC9BBAA1C" originalValue="Fruchtschläuche" pageId="null" pageNumber="434">Fruchtschlaeuche</normalizedToken>
3-4 mm lang, 1,7-2mal so lang wie breit, am Grunde ohne schwammiges Gewebe
</emphasis>
, braun, 
<normalizedToken id="2F43BA0F690FED304FADBFC53831E65A" originalValue="glänzend" pageId="null" pageNumber="434">glaenzend</normalizedToken>
, sparrig abstehend.
</paragraph>
<paragraph id="3DFF2680C9892A20140BDB650B36C002" pageId="null" pageNumber="434">
<emphasis id="9CF3F9DBEC6CBC191EA1A5ADE5590DCF" italics="true" pageId="null" pageNumber="434">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5D5A7C73F657AE6439150736DD45901D" italics="true" pageId="null" pageNumber="434">56:</emphasis>
Material aus 
<normalizedToken id="7EDA9F1C53E8ECF8F328E4A1716288D6" originalValue="Süddeutschland" pageId="null" pageNumber="434">Sueddeutschland</normalizedToken>
(Hohentwiel im Hegau), aus der Schweiz (
<normalizedToken id="C02102B660209C2A52B8AC73B2B0E133" originalValue="Bölchen" pageId="null" pageNumber="434">Boelchen</normalizedToken>
, Blatten, Monte 
<normalizedToken id="FFDDE6C4C1C8631F2DEAF662BDA77438" originalValue="Brè" pageId="null" pageNumber="434">Bre</normalizedToken>
) (Studer in lit.).
</paragraph>
<paragraph id="11750F50EA379AEC9F7FE43FD9395CEA" pageId="null" pageNumber="434">
<emphasis id="2C33D46A3549E0A13CABFB12BD6237A2" italics="true" pageId="null" pageNumber="434">Standort.</emphasis>
Kollin und montan, selten subalpin. Trockene 
<normalizedToken id="86C6B7EEA7815CA392E9B92393BD1E03" originalValue="Böden" pageId="null" pageNumber="434">Boeden</normalizedToken>
. 
<normalizedToken id="4442106A2C7C2E13FBA843EB3E21C569" originalValue="Südexponierte" pageId="null" pageNumber="434">Suedexponierte</normalizedToken>
<normalizedToken id="931192558548CD2802C5273F50378FE3" originalValue="Waldschläge" pageId="null" pageNumber="434">Waldschlaege</normalizedToken>
, 
<normalizedToken id="C173C2E2CB46E3C274324525F28A900E" originalValue="Waldränder" pageId="null" pageNumber="434">Waldraender</normalizedToken>
, seltener in trockenen Wiesen und an 
<normalizedToken id="1688AA30899B0F8CA442C41F968C7858" originalValue="Wegrändern" pageId="null" pageNumber="434">Wegraendern</normalizedToken>
.
</paragraph>
<paragraph id="71F66C94F4693D7BAD73FFF4FC792E8C" pageId="null" pageNumber="434">
<emphasis id="0FB0CD45B245D2832DB33F298D3444A9" italics="true" pageId="null" pageNumber="434">Verbreitung. Eurasiatische Pflanze:</emphasis>
In 
<taxonomicName id="5077FEAD01ABA1CD847235B7736CE866" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="434" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
der norwegischen 
<normalizedToken id="12FA8F11C15FC4C7B20A2BBE30B0F2E4" originalValue="Küste" pageId="null" pageNumber="434">Kueste</normalizedToken>
entlang 
<normalizedToken id="FCD4B2720808C5D4C042F53CA445A276" originalValue="nordwärts" pageId="null" pageNumber="434">nordwaerts</normalizedToken>
bis 67° NB, 1 Fundstelle auf Island, sonst bis 62° NB; im Mediterrangebiet sehr selten, in Nordafrika im Atlasgebirge und in Algerien; 
<normalizedToken id="0DC0A4C1846732850B00C5F79AD83073" originalValue="ostwärts" pageId="null" pageNumber="434">ostwaerts</normalizedToken>
bis Ural, Kaukasus, Altai und Ostsibirien (Minusinsk); im 
<normalizedToken id="FAB661CED4FD9687D76853390766E588" originalValue="östlichen" pageId="null" pageNumber="434">oestlichen</normalizedToken>
Nordamerika 
<normalizedToken id="19CD7A9562FD14CC66FAA304F6FC86F6" originalValue="eingebürgert" pageId="null" pageNumber="434">eingebuergert</normalizedToken>
. - Im Gebiet: Oberrheinische Tiefebene, 
<normalizedToken id="1B2B61C411E750871B775ED72A17F7B2" originalValue="Jurasüdfuß" pageId="null" pageNumber="434">Jurasuedfuss</normalizedToken>
, Schaffhausen, Hegau, Walenseegebiet, zentral- und 
<normalizedToken id="664323A642231C024F987E34FFD6B05D" originalValue="südalpine" pageId="null" pageNumber="434">suedalpine</normalizedToken>
<normalizedToken id="B62F1FC93A726F763FDDA37208444175" originalValue="Täler" pageId="null" pageNumber="434">Taeler</normalizedToken>
, 
<normalizedToken id="7B00050F091D7E5ABE0393A024596B4B" originalValue="häufig" pageId="null" pageNumber="434">haeufig</normalizedToken>
; sonst zerstreut und selten.
</paragraph>
</subSubSection>
