<subSubSection id="6A78E77E42341F6240A2A97294CF854B" pageId="null" pageNumber="213" type="description">
<paragraph id="7098761359CCCC3479058029CE750E91" pageId="null" pageNumber="213">
1 
<normalizedToken id="E40ECB2C8C2B6C87CAC98E45F3321AF4" originalValue="jährig" pageId="null" pageNumber="213">jaehrig</normalizedToken>
; 15-30 cm hoch; 
<normalizedToken id="46140748296FC904F659F4B522800B81" originalValue="unterwärts" pageId="null" pageNumber="213">unterwaerts</normalizedToken>
fast kahl, 
<normalizedToken id="40A444DA9ED8EA30E8641635BED883CD" originalValue="oberwärts" pageId="null" pageNumber="213">oberwaerts</normalizedToken>
<normalizedToken id="155AF4488AAAB5B6DBA3BA8918C08481" originalValue="drüsig" pageId="null" pageNumber="213">druesig</normalizedToken>
behaart und mit einzelnen, mehrzelligen Haaren. Stengel aufrecht, einfach oder etwas verzweigt. Untere 
<normalizedToken id="F439C74B1108A740655A207183009064" originalValue="Blätter" pageId="null" pageNumber="213">Blaetter</normalizedToken>
<normalizedToken id="7FC6F5EB0E5BE0D75E9A089D79FEA4F7" originalValue="gegenständig" pageId="null" pageNumber="213">gegenstaendig</normalizedToken>
, obere 
<normalizedToken id="4723096018E99AF3138E0A0EF1B91FF8" originalValue="wechselständig" pageId="null" pageNumber="213">wechselstaendig</normalizedToken>
, kurz gestielt, schmal lanzettlich, 
<emphasis id="AA10C39100A810B341584EC42EDCC35A" italics="true" pageId="null" pageNumber="213">4</emphasis>
- 
<emphasis id="6DFA2C02A17B60EB32552D97C8E4E98B" italics="true" pageId="null" pageNumber="213">
15mal so lang wie breit. 
<normalizedToken id="4692455C695C8100B7C3F4A7945DA40A" originalValue="Blüten" pageId="null" pageNumber="213">Blueten</normalizedToken>
1
</emphasis>
- 
<emphasis id="B77870F0E91F4ABCD71D9DBA3D8EEEB8" italics="true" pageId="null" pageNumber="213">1,4 cm lang</emphasis>
, kurz gestielt, in den Achseln der obern 
<normalizedToken id="00080FD123DDE293C0B3146C4D4A5A60" originalValue="Blätter" pageId="null" pageNumber="213">Blaetter</normalizedToken>
. 
<emphasis id="35518372162D30020C462C1F2A97914F" italics="true" pageId="null" pageNumber="213">Krone rosa</emphasis>
, dunkler gestreift, mit dunklem Gaumen. Samen etwa 1 mm lang, auf der einen Seite flach, in der Mitte mit einer Leiste, auf der andern mit einem 
<normalizedToken id="49BD49DF1BB3E60D47BF61F66D67E113" originalValue="ringförmigen" pageId="null" pageNumber="213">ringfoermigen</normalizedToken>
, 
<normalizedToken id="84FB93F56EB1A5F19B300D5B7FB084AF" originalValue="körnigen" pageId="null" pageNumber="213">koernigen</normalizedToken>
Wulst. - 
<normalizedToken id="DA2D5E46FAA51A98A4CCAFD21B77C2D3" originalValue="Blüte" pageId="null" pageNumber="213">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="9D6CC77D20258770B67FAB15ADB413F0" originalValue="früher" pageId="null" pageNumber="213">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="551F1968D568299E4E47C2C8071E6C32" pageId="null" pageNumber="213">
<emphasis id="C6C9BC0EC453F6B9F98E753C0D4875C2" italics="true" pageId="null" pageNumber="213">
<pageBreakToken id="EA2E1474A3E1B88CD31265074F90FFC8" pageId="null" pageNumber="213">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="210E22E710404179721EC3717CDA271C" italics="true" pageId="null" pageNumber="213">16:</emphasis>
Material unbekannter Herkunft (Heitz 1927, Battaglia aus Tischler 1950), von den Kanaren (Larsen 1960), aus 
<normalizedToken id="ECC98F0092007993712DE9FFB814C5A2" originalValue="Südfrankreich" pageId="null" pageNumber="213">Suedfrankreich</normalizedToken>
(Van Loon et al. 1971). Sobti und Singh (1961) 
<normalizedToken id="5EA7B1AF5A2D5075A930178FB2EF85AB" originalValue="zählten" pageId="null" pageNumber="213">zaehlten</normalizedToken>
an Material aus Indien 2n = 14.
</paragraph>
<paragraph id="AAA71801762A3472DE0D93DC47608EF3" pageId="null" pageNumber="213">
<emphasis id="97FDEB7AE3AE8BB3E01A525501C42302" italics="true" pageId="null" pageNumber="213">Standort.</emphasis>
Kollin und montan. Lockere, 
<normalizedToken id="05AEA726FA39D04015A68BA0AEC3A708" originalValue="nährstoffreiche" pageId="null" pageNumber="213">naehrstoffreiche</normalizedToken>
, kalkarme, lehmige 
<normalizedToken id="5CF482BF14D55C2AF6CDAB3689478990" originalValue="Böden" pageId="null" pageNumber="213">Boeden</normalizedToken>
in warmen, wintermilden Lagen. Weinberge, Mauern, 
<normalizedToken id="964D079A4410A73C452F5CEA16272A80" originalValue="Schuttplätze" pageId="null" pageNumber="213">Schuttplaetze</normalizedToken>
, 
<normalizedToken id="69665525156CB3F2B04D7C5014606C5F" originalValue="Äcker" pageId="null" pageNumber="213">Aecker</normalizedToken>
.
</paragraph>
<paragraph id="5B4EB52C2AC2ADA02693265629E8DDC9" pageId="null" pageNumber="213">
<emphasis id="A18B423E714B45FA4A62337F1E927A8E" italics="true" pageId="null" pageNumber="213">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="3C168CD54551347A619BEF8E8778DBE1" originalValue="Südliches" pageId="null" pageNumber="213">Suedliches</normalizedToken>
Europa (
<normalizedToken id="3B505E21B4BC56419D7AF99EBEEB4F96" originalValue="nördlich" pageId="null" pageNumber="213">noerdlich</normalizedToken>
der Alpen nur vereinzelt und 
<normalizedToken id="E261F1A35FF95185C7CBD5F1E5E0B659" originalValue="unbeständig" pageId="null" pageNumber="213">unbestaendig</normalizedToken>
); Westasien; Nordafrika; auch verschleppt. - Im Gebiet vor allem 
<normalizedToken id="39B240E72DF34B9439BFE0E6754F3950" originalValue="südlich" pageId="null" pageNumber="213">suedlich</normalizedToken>
der Alpen, in der Oberrheinischen Tiefebene und im westlichen Teil; ziemlich selten.
</paragraph>
<paragraph id="B06647102516350B7FF000EE970FDFA1" pageId="null" pageNumber="213">
<emphasis id="9EFC7410409E6BCF365EAB70170ECCBF" italics="true" pageId="null" pageNumber="213">Bemerkungen.</emphasis>
Gelegentlich tritt adventiv auch eine 
<taxonomicName id="D880E1B1069FF6CA76668EEE3EFE788E" authority="Chavannes" authorityName="Chavannes" pageId="null" pageNumber="213" rank="variety" variety="grandiflora">
var. 
<emphasis id="FB033ECCF88A6BA3A80C7ADD57D482A0" italics="true" pageId="null" pageNumber="213">grandiflora</emphasis>
Chavannes
</taxonomicName>
auf mit etwa 2 cm langen 
<normalizedToken id="DB37CF56B52BA2D5A711EBFADDACDA35" originalValue="Blüten" pageId="null" pageNumber="213">Blueten</normalizedToken>
.
</paragraph>
</subSubSection>
