<taxonomicName id="03944D7DFFE06A5FFC6694CF1D2AB9ED" authority="Linnaeus, 1758" authorityName="Linnaeus" authorityYear="1758" class="Mammalia" family="Vespertilionidae" genus="Vespertilio" kingdom="Animalia" order="Chiroptera" pageId="27" pageNumber="785" phylum="Chordata" rank="species" species="murinus">Vespertilio murinus Linnaeus, 1758</taxonomicName>
