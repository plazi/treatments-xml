<subSubSection id="8BA9ABA8CDB6C8D41F0F2B1F914DE940" pageId="null" pageNumber="727" type="description">
<paragraph id="6A6EE19DC017CD2A427EFC3971C3236D" pageId="null" pageNumber="727">
Unterscheidet sich von 
<taxonomicName id="0937CCCFFFB51E68DC0F04463B327389" class="Magnoliopsida" family="Polygonaceae" genus="Rumex" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="727" phylum="Tracheophyta" rank="species" species="patientia">
<emphasis id="BCA4974357D05E990BFF05A8A1D5A0F8" italics="true" pageId="null" pageNumber="727">R. Patientia</emphasis>
</taxonomicName>
(Nr.8) durch folgende Merkmale: 
<emphasis id="F296F692FF0A87CC040C7D84CD362D40" italics="true" pageId="null" pageNumber="727">
Innere 
<normalizedToken id="509E24FC4196CCDA56DEA40DD95C8A03" originalValue="Perigonblätter" pageId="null" pageNumber="727">Perigonblaetter</normalizedToken>
am Rande fein, 
<normalizedToken id="C950332F69CF1DFBB4E0ED8DB825B857" originalValue="unregelmäβig" pageId="null" pageNumber="727">unregelmaeβig</normalizedToken>
und scharf 
<normalizedToken id="5162DA665330E6782414CBFE64818C2D" originalValue="gezähnt" pageId="null" pageNumber="727">gezaehnt</normalizedToken>
</emphasis>
(
<normalizedToken id="50CC88CED8D8154927B2E719324CCE79" originalValue="Zähne" pageId="null" pageNumber="727">Zaehne</normalizedToken>
bis 1 mm hoch); 
<emphasis id="8749FC417E2846805B92FF3DC6F44150" italics="true" pageId="null" pageNumber="727">
1 inneres Perigonblatt mit 
<normalizedToken id="DEDE61CF4526EFB6BEBB359AF03D1926" originalValue="groβer" pageId="null" pageNumber="727">groβer</normalizedToken>
, 2
</emphasis>
- 
<emphasis id="92679A9AA3A4C5F7478A82631FB9D6E6" italics="true" pageId="null" pageNumber="727">
3 mm langer Schwiele, die beiden andern 
<normalizedToken id="213CF90BED6B2FC86352B81BCADE8E96" originalValue="Perigonblätter" pageId="null" pageNumber="727">Perigonblaetter</normalizedToken>
mit etwa 1 mm langer Schwiele.
</emphasis>
- 
<normalizedToken id="C461835956D77A58B26F912950BE8EAB" originalValue="Blüte" pageId="null" pageNumber="727">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="7CF68AF1E8A8B4ECA91DEB404FD00C5D" pageId="null" pageNumber="727">
<emphasis id="5EB832315B048A15BCA182608753F185" italics="true" pageId="null" pageNumber="727">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="6CD94C89D2D72A526B7D3366792D28DC" pageId="null" pageNumber="727">
<emphasis id="3A86DEF6EA186014BED30C810268CDB3" italics="true" pageId="null" pageNumber="727">Standort.</emphasis>
Kollin. 
<normalizedToken id="83C9695C40AC3157DA2937F009937468" originalValue="Wegränder" pageId="null" pageNumber="727">Wegraender</normalizedToken>
, 
<normalizedToken id="1EB70B5310D3073FCE251BED33AF593B" originalValue="Schuttplätze" pageId="null" pageNumber="727">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="F80C893EE76F306E2A07E0AE4987A343" pageId="null" pageNumber="727">
<emphasis id="49A930ECAD8AB708B6EEEBC7987D11A3" italics="true" pageId="null" pageNumber="727">Verbreitung. Ostmediterrane Pflanze:</emphasis>
<normalizedToken id="DC8E9EFEA5E4EF8B5F2DC6722330594D" originalValue="Süditalien" pageId="null" pageNumber="727">Sueditalien</normalizedToken>
, 
<normalizedToken id="F34E70DBDE7AD9FD833D5278E79531E3" originalValue="südliche" pageId="null" pageNumber="727">suedliche</normalizedToken>
Balkanhalbinsel, westliches Anatolien. - Im Gebiet bei Genf-La-Treille 
<normalizedToken id="6D1600F7DB466B16E51B27C2D95D9084" originalValue="eingebürgert" pageId="null" pageNumber="727">eingebuergert</normalizedToken>
.
</paragraph>
