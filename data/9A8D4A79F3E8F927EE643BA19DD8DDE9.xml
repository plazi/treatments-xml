<taxonomicName id="D0A760BD912EB261B37168ADBA282C2C" authority="Schultes" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="hoppeanum">
