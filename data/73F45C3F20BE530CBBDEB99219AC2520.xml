<subSubSection id="A0B2228FB9FC7C81443752AEE8171726" pageId="null" pageNumber="591" type="vernacular_names">
<paragraph id="CD2D3D2EB8F6C3726808FA41E3172358" pageId="null" pageNumber="591">Stinkende Schwertlilie</paragraph>
</subSubSection>
</title>
<subSubSection id="84ED1233D9230E0532C71A1968BB0374" pageId="null" pageNumber="591" type="description">
<paragraph id="F073FC3EFD9EAB883EA0244290F8FCF8" pageId="null" pageNumber="591">
Unterscheidet sich von 
<taxonomicName id="39FEA02486EBAE3C7FEE431172DA9BA2" class="Insecta" family="Tarachodidae" genus="Iris" kingdom="Animalia" order="Mantodea" pageId="null" pageNumber="591" phylum="Arthropoda" rank="species" species="sibirica">
<emphasis id="7AF13736A3C28602C76B56FA3D5C252B" italics="true" pageId="null" pageNumber="591">I. sibirica</emphasis>
</taxonomicName>
(Nr.5) durch folgende Merkmale: 
<emphasis id="B787666B9EB8F4B995DA89629C955992" italics="true" pageId="null" pageNumber="591">
Stengel mit 1 Kante; 
<normalizedToken id="55076C4229F9FDFD05F3BA7E06014AAF" originalValue="äuβere" pageId="null" pageNumber="591">aeuβere</normalizedToken>
<normalizedToken id="11D70987D79A3834A0AB0E764823DE27" originalValue="Perigonblätter" pageId="null" pageNumber="591">Perigonblaetter</normalizedToken>
blau bis 
<normalizedToken id="4A1B2B5B822EF124A70F645462B31D1D" originalValue="rötlich" pageId="null" pageNumber="591">roetlich</normalizedToken>
, innere gelb mit violetten Flecken; die beiden Zipfel der Narbenoberlippe spitz. -
</emphasis>
<normalizedToken id="3ED2071866A7EC7EBC418F7F3E15CD22" originalValue="Blüte" pageId="null" pageNumber="591">Bluete</normalizedToken>
: 
<normalizedToken id="28920B0515AB1F0CE16DC2C751DAEE45" originalValue="Frühling" pageId="null" pageNumber="591">Fruehling</normalizedToken>
und 
<normalizedToken id="1A49C0E82FECAD8164B1BA41AB73A249" originalValue="früher" pageId="null" pageNumber="591">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="1BC281EA162DA20FBB46D7700F67B15A" pageId="null" pageNumber="591">
<emphasis id="6EBEA55F52F2403D3E7B918B20AF58D1" italics="true" pageId="null" pageNumber="591">
<pageBreakToken id="A4DAA66089199AAF6A4451D3930A50D8" pageId="null" pageNumber="591">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="07AB96571FD312CD8B6B12466E68FE06" italics="true" pageId="null" pageNumber="591">40:</emphasis>
Ohne Herkunftsangabe (Simonet 1928), aus dem Gebiet von Pisa (Mori 1957).
</paragraph>
<paragraph id="D7B814D1B9B7B67EC2A8DB2A52C49436" pageId="null" pageNumber="591">
<emphasis id="1234EF56C1E9046EE1338A347D058841" italics="true" pageId="null" pageNumber="591">Standort.</emphasis>
Kollin. Trockene Wiesen.
</paragraph>
<paragraph id="C0B77E02FF8D7B83EA94245106C60E56" pageId="null" pageNumber="591">
<emphasis id="5149CC2A2D097E87F6B6514C7C1C8B17" italics="true" pageId="null" pageNumber="591">Verbreitung. Westmediterrane Pflanze:</emphasis>
Nordwestafrika; Iberische Halbinsel, Frankreich, 
<normalizedToken id="18749E4605C48128C69886D76BADCDBD" originalValue="nordwärts" pageId="null" pageNumber="591">nordwaerts</normalizedToken>
bis Irland und Schottland (verwildert), Italien, Griechenland; Angaben aus dem Kaukasus unsicher. - Im Gebiet: 
<normalizedToken id="EA4970EB1A5E27C29D0BD6BC06BDA1D8" originalValue="Ursprünglich" pageId="null" pageNumber="591">Urspruenglich</normalizedToken>
wahrscheinlich in Savoyen, 
<normalizedToken id="AA7D9E8F00A9FFB1D4694A304007C78D" originalValue="Dép" pageId="null" pageNumber="591">Dep</normalizedToken>
. Ain, Jura und Doubs; in Genf, Waadt und Tessin verwilderte Gartenpflanze.
</paragraph>
</subSubSection>
