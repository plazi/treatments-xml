<subSubSection id="46A639588B3DB911021BED8BBB73F930" pageId="null" pageNumber="58" type="description">
<paragraph id="39E12EB7FB13EE373D5EBD8F668F01D0" pageId="null" pageNumber="58">
1 
<normalizedToken id="0D693EC62339A88B4B2BA2DC850C4574" originalValue="jährige" pageId="null" pageNumber="58">jaehrige</normalizedToken>
oder ausdauernde 
<normalizedToken id="1EBE2710A9F53FB1A1EC997B435E9D0D" originalValue="Kräuter" pageId="null" pageNumber="58">Kraeuter</normalizedToken>
. 
<normalizedToken id="BF533D9C1F9890E96CFC2BB7AB864278" originalValue="Blütenstände" pageId="null" pageNumber="58">Bluetenstaende</normalizedToken>
<normalizedToken id="6E9A86CD66F1FAD18DF5087A04BF5CA5" originalValue="vielblütig" pageId="null" pageNumber="58">vielbluetig</normalizedToken>
. 
<normalizedToken id="5B7F6A8060AEE768E3E948EA5FE607A9" originalValue="Blüten" pageId="null" pageNumber="58">Blueten</normalizedToken>
mit Tragblatt. 
<emphasis id="662D7FFF559049B876207517522DE354" italics="true" pageId="null" pageNumber="58">
Krone 
<normalizedToken id="4E4C7AB860B9F0E78718CD9EB9053314" originalValue="groß" pageId="null" pageNumber="58">gross</normalizedToken>
, flach ausgebreitet und nur am Grunde zu einer kurzen 
<normalizedToken id="5528DBD1488D5693A3D25EA4233D623D" originalValue="Röhre" pageId="null" pageNumber="58">Roehre</normalizedToken>
verwachsen;
</emphasis>
Schlundschuppen aus der 
<normalizedToken id="5E62AEFEC9D69ABB7AC7E69324D25006" originalValue="Kronröhre" pageId="null" pageNumber="58">Kronroehre</normalizedToken>
herausragend. Die 5 
<normalizedToken id="851843395635B394A4F2A9626BE71ECA" originalValue="Staubblätter" pageId="null" pageNumber="58">Staubblaetter</normalizedToken>
die Schlundschuppen weit 
<normalizedToken id="2EB38240AC08740D92D3DF79E6E1626B" originalValue="überragend" pageId="null" pageNumber="58">ueberragend</normalizedToken>
, 
<emphasis id="DFBC43FE7B52EFEA7E688D4FACA271D2" italics="true" pageId="null" pageNumber="58">
<normalizedToken id="7A6ABD39804EF0B09A693773A1554FFA" originalValue="Staubfäden" pageId="null" pageNumber="58">Staubfaeden</normalizedToken>
mit nach 
<normalizedToken id="19CFF32E19B1A2C5B64F149603571901" originalValue="außen" pageId="null" pageNumber="58">aussen</normalizedToken>
gerichtetem 
<normalizedToken id="6FD0EFF965D45E8B35F415B9251B201D" originalValue="Anhängsel" pageId="null" pageNumber="58">Anhaengsel</normalizedToken>
.
</emphasis>
<normalizedToken id="674D4DF15F3A75558AD45AAA9A25F385" originalValue="Teilfrüchte" pageId="null" pageNumber="58">Teilfruechte</normalizedToken>
mit warziger 
<normalizedToken id="CF29924B4635367854386F6206754B9E" originalValue="Oberfläche" pageId="null" pageNumber="58">Oberflaeche</normalizedToken>
.
</paragraph>
<paragraph id="FE1EB9C2E29BF4D6EAD4FCFC90F882FF" pageId="null" pageNumber="58">
Die Gattung 
<taxonomicName id="B27C4BFFCDCFB1B163A76F4DB2E1951D" class="Magnoliopsida" family="Boraginaceae" genus="Borago" kingdom="Plantae" order="Boraginales" pageId="null" pageNumber="58" phylum="Tracheophyta" rank="genus">
<emphasis id="EC46450D0289359805246E5BBEF8C9B6" italics="true" pageId="null" pageNumber="58">Borago</emphasis>
</taxonomicName>
<normalizedToken id="23592619652CCCBCC0E7F135054D2344" originalValue="umfaßt" pageId="null" pageNumber="58">umfasst</normalizedToken>
<emphasis id="067A8930D491900F83941DF4E8CA5F11" italics="true" pageId="null" pageNumber="58">3 Arten</emphasis>
, die 
<emphasis id="E38AA5E3988520DF138C20E095A4D5C0" italics="true" pageId="null" pageNumber="58">im Mediterrangebiet und in Westasien verbreitet sind.</emphasis>
</paragraph>
</subSubSection>
