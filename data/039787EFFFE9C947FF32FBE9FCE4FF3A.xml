<typeStatus id="5485885BFFE8C947FDC5FF55FD1EFF3A" box="[608,656,223,249]" pageId="73" pageNumber="74">type</typeStatus>
locality (
<figureCitation id="13052A7CFFE8C947FD5EFF55FCD3FF3A" box="[763,861,223,249]" captionStart="FIGURES 315–318" captionStartId="76.[151,264,1371,1395]" captionTargetBox="[156,1431,489,1348]" captionTargetId="figure-159@76.[156,1431,489,1348]" captionTargetPageId="76" captionText="FIGURES 315–318. Distribution maps for species of Meri gen. nov. 315 (M. martinique spec. nov., M. sanctivincenti (Simon) comb. nov., M. trinitatis (Strand) comb. nov., M. carabobo spec. nov., M. kaieteur spec. nov.); 316 (M. jaraua spec. nov., M. arraijan spec. nov., M. formosus (Banks) comb. nov., M. guri spec. nov., M. tumatumari spec. nov.); 317 (M. zeteki spec. nov., M. manaos spec. nov., M. yaciba spec. nov., M. tapirapeco spec. nov., M. abuna spec. nov.); 318 (M. mathani (Simon) comb. nov., M. pictitarsis (Simon) comb. nov., M. conduri spec. nov., M. paiaia spec. nov., M. tambor spec. nov.);" figureDoi="http://doi.org/10.5281/zenodo.6550426" httpUri="https://zenodo.org/record/6550426/files/figure.png" pageId="73" pageNumber="74">Fig. 317</figureCitation>
).
