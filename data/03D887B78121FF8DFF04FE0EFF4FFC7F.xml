<subSubSection id="C36B652A8121FF8DFF31FC96FF4FFC7F" pageId="14" pageNumber="15" type="distribution">
<paragraph id="8BCE36A18121FF8DFF31FC96FD30FC92" blockId="14.[136,1452,698,941]" box="[189,643,806,833]" pageId="14" pageNumber="15">
<emphasis id="B905EAB38121FF8DFF31FC96FEC6FC92" bold="true" box="[189,373,806,832]" pageId="14" pageNumber="15">Distribution:—</emphasis>
<collectingCountry id="F36676318121FF8DFEF9FC97FE51FC93" box="[373,482,807,833]" name="Myanmar" pageId="14" pageNumber="15">Myanmar</collectingCountry>
and 
<collectingCountry id="F36676318121FF8DFD94FC96FDCCFC92" box="[536,639,806,832]" name="Thailand" pageId="14" pageNumber="15">Thailand</collectingCountry>
.
</paragraph>
<paragraph id="8BCE36A18121FF8DFF31FCFAFF4FFC7F" blockId="14.[136,1452,698,941]" pageId="14" pageNumber="15">
<emphasis id="B905EAB38121FF8DFF31FCFAFEA8FCB6" bold="true" box="[189,283,842,868]" pageId="14" pageNumber="15">Note:—</emphasis>
<bibRefCitation id="EFE04B508121FF8DFE97FCFAFDACFCB7" author="Seidenfaden, G." box="[283,543,842,869]" pageId="14" pageNumber="15" pagination="1 - 398" refId="ref228308" refString="Seidenfaden, G. (1988) Orchid genera in Thailand XIV. Fifty-nine vandoid genera. Opera Botanica 95: 1 - 398." type="journal article" year="1988">Seidenfaden (1988: 96)</bibRefCitation>
speculated that the origin of this plant was 
<collectingCountry id="F36676318121FF8DFC75FCFBFBD5FCB7" box="[1017,1126,843,869]" name="Myanmar" pageId="14" pageNumber="15">Myanmar</collectingCountry>
(as 
<taxonomicName id="4C714D228121FF8DFB1DFCFAFA28FCB6" box="[1169,1435,842,868]" class="Liliopsida" family="Orchidaceae" genus="Staurochilus" higherTaxonomySource="GBIF" kingdom="Plantae" order="Asparagales" pageId="14" pageNumber="15" phylum="Tracheophyta" rank="species" species="joiceyanus">
<emphasis id="B905EAB38121FF8DFB1DFCFAFA28FCB6" box="[1169,1435,842,868]" italics="true" pageId="14" pageNumber="15">Staurochilus joiceyanus</emphasis>
</taxonomicName>
). He later described it as 
<taxonomicName id="4C714D228121FF8DFE11FCDFFC2BFC5A" authority="(Seidenfaden 1997: 49)" baseAuthorityName="Seidenfaden" baseAuthorityPageNumber="49" baseAuthorityYear="1997" box="[413,920,878,905]" class="Liliopsida" family="Orchidaceae" genus="Acampe" kingdom="Plantae" order="Asparagales" pageId="14" pageNumber="15" phylum="Tracheophyta" rank="species" species="thailandica">
<emphasis id="B905EAB38121FF8DFE11FCDFFD32FC5A" box="[413,641,878,905]" italics="true" pageId="14" pageNumber="15">Acampe thailandica</emphasis>
(
<bibRefCitation id="EFE04B508121FF8DFD1EFCDEFC23FC5A" author="Seidenfaden, G." box="[658,912,878,904]" pageId="14" pageNumber="15" refId="ref228353" refString="Seidenfaden, G. (1997) Contributions to the orchid flora of Thailand XIII. Olsen &amp; Olsen, Fredensborg, 64 pp." type="book" year="1997">Seidenfaden 1997: 49</bibRefCitation>
)
</taxonomicName>
, which is now considered conspecific with 
<taxonomicName id="4C714D228121FF8DFA1FFCDFFF46FC7E" class="Liliopsida" family="Orchidaceae" genus="Trichoglottis" kingdom="Plantae" order="Asparagales" pageId="14" pageNumber="15" phylum="Tracheophyta" rank="species" species="joiceyana">
<emphasis id="B905EAB38121FF8DFA1FFCDFFF46FC7E" italics="true" pageId="14" pageNumber="15">A. joiceyana</emphasis>
</taxonomicName>
.
</paragraph>
