<paragraph id="3FEF67695090C8B43159191A2231FFDA" pageId="0" pageNumber="15">Type material examined.</paragraph>
<paragraph id="8708073D72728E024ED487AE48DFD095" pageId="0" pageNumber="15">
<emphasis id="7624EC8DB9F74765FC92FD9175C1C4F6" bold="true" italics="true" pageId="0" pageNumber="15">Holotype</emphasis>
: male (SYSU), China, Guangdong, Longmen County, Nankunshan Mountain, Guanyintan (观音潭), 
<geoCoordinate id="EF680EB939A2CDFAA6A4666A1195ED4A" degrees="23" direction="north" minutes="38" orientation="latitude" precision="15" seconds="13" value="23.636944">23°38'13&quot;N</geoCoordinate>
