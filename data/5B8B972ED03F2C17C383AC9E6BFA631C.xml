<subSubSection id="3CFB68971F2B17BBEE9BD39AF500BF28" pageId="null" pageNumber="605" type="description">
<paragraph id="4ADFD716B3720628D5F61684EE1BD407" pageId="null" pageNumber="605">
<normalizedToken id="5CDBFA50A97F466050D826AFDF0728A9" originalValue="Flügel" pageId="null" pageNumber="605">Fluegel</normalizedToken>
am Stengel 2-4 mm breit. Blattstiel 8-12 mm breit. 
<emphasis id="EC4A1E436102B5EBCA50D56C7B3C564F" italics="true" pageId="null" pageNumber="605">
<normalizedToken id="DF8EAC74E0CFE8D4ED66501AB9C3C85F" originalValue="Blätter" pageId="null" pageNumber="605">Blaetter</normalizedToken>
</emphasis>
(
<emphasis id="0DA5F255B77B96533A749FE5D7ABEC82" italics="true" pageId="null" pageNumber="605">wenigstens die obern</emphasis>
) 
<emphasis id="5837C3D517973085546F2F248DD4A3F4" italics="true" pageId="null" pageNumber="605">
mit 4 bis 8 
<normalizedToken id="28C0DA88C5448388B34D98CD716C235C" originalValue="Teilblättern" pageId="null" pageNumber="605">Teilblaettern</normalizedToken>
</emphasis>
, 
<normalizedToken id="48C2BBFDA81CCC57083054C747B506BE" originalValue="Teilblätter" pageId="null" pageNumber="605">Teilblaetter</normalizedToken>
5-10 cm lang, 3-8mal so lang wie breit; 
<emphasis id="602AE42879A9941CE6FDAA1FCEECBF4B" italics="true" pageId="null" pageNumber="605">
<normalizedToken id="E04EEB0B15E7C0F1388BAE521F70A939" originalValue="Nebenblätter" pageId="null" pageNumber="605">Nebenblaetter</normalizedToken>
</emphasis>
⅓- 
<normalizedToken id="C5325EF56885B93B8FA0FF48517D07E2" originalValue="½" pageId="null" pageNumber="605">1/2</normalizedToken>
<emphasis id="620216F7CEE12B0EBA4553A7851BDEBE" italics="true" pageId="null" pageNumber="605">
so lang wie die 
<normalizedToken id="60DCD37F0BFF055CD04BF395C31A1E18" originalValue="Teilblätter" pageId="null" pageNumber="605">Teilblaetter</normalizedToken>
</emphasis>
, ⅔- 
<normalizedToken id="39651D3198F074CB8EF9AA216F2DE27D" originalValue="1½" pageId="null" pageNumber="605">11/2</normalizedToken>
<emphasis id="A4CB7459315D42770937C5D12C8D9645" italics="true" pageId="null" pageNumber="605">mal so breit wie der Stengel.</emphasis>
<normalizedToken id="011B0DB0F93DC70592C24D2327AA9CC1" originalValue="Blütenstand" pageId="null" pageNumber="605">Bluetenstand</normalizedToken>
3-12 
<normalizedToken id="291D8B357DE8C0BF5426A1FBB0DDCEE3" originalValue="blütig" pageId="null" pageNumber="605">bluetig</normalizedToken>
. 
<normalizedToken id="011D5A5D21FEBFB024996D40F51B7972" originalValue="Längere" pageId="null" pageNumber="605">Laengere</normalizedToken>
<normalizedToken id="DC3FA2E138E786DF1DF5D22B6B18BD17" originalValue="Kelchzähne" pageId="null" pageNumber="605">Kelchzaehne</normalizedToken>
<normalizedToken id="E966FBE233DAB638DE60970F3C6428E0" originalValue="1½" pageId="null" pageNumber="605">11/2</normalizedToken>
-2mal so lang wie die 
<normalizedToken id="09AF6F2EC7AD4CB9926A27948B6A27FB" originalValue="Kelchröhre" pageId="null" pageNumber="605">Kelchroehre</normalizedToken>
. 
<emphasis id="CE12ACE1DFE416E6B1AD12A6F86263CE" italics="true" pageId="null" pageNumber="605">Krone 1,4-2 cm lang, purpurrot.</emphasis>
Frucht 6,5-8 cm lang und 0,9-1,1 cm breit. Samen deutlich warzig. - 
<normalizedToken id="DCB7B3B288BAE9B0CF34ECAB308F8BAB" originalValue="Blüte" pageId="null" pageNumber="605">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="A9F29C90B7239E45FE3D4CAAA46C0BC2" pageId="null" pageNumber="605">
<emphasis id="441AAA7AFAF21F711316F176BA961D18" italics="true" pageId="null" pageNumber="605">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="EC9139AEB4B57D907722FA17F69A409B" italics="true" pageId="null" pageNumber="605">14:</emphasis>
Material unbekannter Herkunft und aus botanischen 
<normalizedToken id="5BB8AB915DE5EA3C5E5582F993F5A7A0" originalValue="Gärten" pageId="null" pageNumber="605">Gaerten</normalizedToken>
(Simonet 1932, Senn 1938a), aus dem Wallis und aus 
<normalizedToken id="D8B0F6EDCF81B120EBA6E79D06E84468" originalValue="Rußland" pageId="null" pageNumber="605">Russland</normalizedToken>
(Brunsberg 1965).
</paragraph>
<paragraph id="C11C1679382FBFBA394F5ECDADF63D69" pageId="null" pageNumber="605">
<emphasis id="B83929B2A07E11E048DAA5A5C0294687" italics="true" pageId="null" pageNumber="605">Standort.</emphasis>
Montan und subalpin, seltener kollin. Schutt- und Blockhalden in warmen Lagen.
</paragraph>
<paragraph id="780FBE8070E765529649F3D52D74F37C" pageId="null" pageNumber="605">
<emphasis id="2A9A643D6A94EAC368E38200B7D26F04" italics="true" pageId="null" pageNumber="605">
Verbreitung. 
<normalizedToken id="440D5AFCE92947020371811C04F222AA" originalValue="Mitteleuropäische" pageId="null" pageNumber="605">Mitteleuropaeische</normalizedToken>
Pflanze:
</emphasis>
Jura, Alpen, mitteldeutsche Gebirge, 
<normalizedToken id="12A8EC3C11031B4484F38030C998C33B" originalValue="Südschweden" pageId="null" pageNumber="605">Suedschweden</normalizedToken>
, 
<normalizedToken id="9BBDBC66C2AA77BAA217E3D578FDE635" originalValue="Preußen" pageId="null" pageNumber="605">Preussen</normalizedToken>
, Polen. Im Gebiet: Jura, Baar, Alpen; nicht 
<normalizedToken id="E8DE2EB4C96E0FE15EFD415D13DBBCC7" originalValue="häufig" pageId="null" pageNumber="605">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
