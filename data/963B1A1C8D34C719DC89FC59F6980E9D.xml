<subSubSection id="5688F8818D34C71EDC89FC15F0080DD5" pageId="3" pageNumber="33" type="diagnosis">
<paragraph id="1E2DAB0A8D34C71EDC89FC15F0080DD5" blockId="3.[136,1452,990,1264]" pageId="3" pageNumber="33">
<emphasis id="2CE677188D34C71EDC89FC15F5AA0A89" bold="true" box="[136,243,990,1012]" pageId="3" pageNumber="33">Diagnosis:</emphasis>
— 
<taxonomicName id="D992D0898D34C71EDD0AFC14F4F90A8E" authorityName="Hamzaoglu &amp; Koc" authorityYear="2022" box="[267,416,990,1012]" class="Magnoliopsida" family="Brassicaceae" genus="Hesperis" kingdom="Plantae" order="Brassicales" pageId="3" pageNumber="33" phylum="Tracheophyta" rank="species" species="zaferi">
<emphasis id="2CE677188D34C71EDD0AFC14F4F90A8E" box="[267,416,990,1012]" italics="true" pageId="3" pageNumber="33">Hesperis zaferi</emphasis>
</taxonomicName>
is related to 
<taxonomicName id="D992D0898D34C71EDE28FC14F7F40A89" authorityName="A. Duran (Duran &amp; Cetin" authorityYear="2016" box="[553,685,991,1012]" class="Magnoliopsida" family="Brassicaceae" genus="Hesperis" kingdom="Plantae" order="Brassicales" pageId="3" pageNumber="33" phylum="Tracheophyta" rank="species" species="tosyaensis">
<emphasis id="2CE677188D34C71EDE28FC14F7F40A89" box="[553,685,991,1012]" italics="true" pageId="3" pageNumber="33">H. tosyaensis</emphasis>
</taxonomicName>
and 
<taxonomicName id="D992D0898D34C71EDEE3FC14F60B0A8E" authorityName="A. Duran" authorityYear="2009" box="[738,850,990,1012]" class="Magnoliopsida" family="Brassicaceae" genus="Hesperis" kingdom="Plantae" order="Brassicales" pageId="3" pageNumber="33" phylum="Tracheophyta" rank="species" species="ozcelikii">
<emphasis id="2CE677188D34C71EDEE3FC14F60B0A8E" box="[738,850,990,1012]" italics="true" pageId="3" pageNumber="33">H. ozcelikii</emphasis>
</taxonomicName>
in habit, inflorescence, and siliquae dimensions, but can be distinguished by basal leaves (entire versus lyrate or sinuate-dentate), leaf hairs (bifurcate hairs versus bifurcate, glandular, a few simple and trifid hairs, or glandular and stellate hairs or trifid and a few glandular hairs and very rarely a few simple hairs), pedicels (densely glandular and sparsely simple hairs versus glabrous or sparsely bifurcate and rarely trifid hairs, or densely glandular or rarely stellate and glandular hairs), petal claws (
<quantity id="D96A06EF8D34C71EDE9EFBA5F7AB0DF9" box="[671,754,1134,1156]" metricMagnitude="-3" metricUnit="m" metricValue="8.0" metricValueMax="9.0" metricValueMin="7.0" pageId="3" pageNumber="33" unit="mm" value="8.0" valueMax="9.0" valueMin="7.0">7–9 mm</quantity>
long versus 
<quantity id="D96A06EF8D34C71EDF74FBA5F68A0DF9" box="[885,979,1134,1156]" metricMagnitude="-2" metricUnit="m" metricValue="1.1" metricValueMax="1.3" metricValueMin="0.9" pageId="3" pageNumber="33" unit="mm" value="11.0" valueMax="13.0" valueMin="9.0">9–13 mm</quantity>
long), and silique hairs (glandular hairs versus glabrous or densely glandular, sparsely bifurcate and rarely a few simple hairs) in 
<taxonomicName id="D992D0898D34C71EDFD0FB58F10B0DD5" authorityName="A. Duran (Duran &amp; Cetin" authorityYear="2016" box="[977,1106,1171,1192]" class="Magnoliopsida" family="Brassicaceae" genus="Hesperis" kingdom="Plantae" order="Brassicales" pageId="3" pageNumber="33" phylum="Tracheophyta" rank="species" species="tosyaensis">
<emphasis id="2CE677188D34C71EDFD0FB58F10B0DD5" box="[977,1106,1171,1192]" italics="true" pageId="3" pageNumber="33">H. tosyaensis</emphasis>
</taxonomicName>
and 
<taxonomicName id="D992D0898D34C71ED881FB58F1B40DDA" authorityName="A. Duran" authorityYear="2009" box="[1152,1261,1170,1192]" class="Magnoliopsida" family="Brassicaceae" genus="Hesperis" kingdom="Plantae" order="Brassicales" pageId="3" pageNumber="33" phylum="Tracheophyta" rank="species" species="ozcelikii">
<emphasis id="2CE677188D34C71ED881FB58F1B40DDA" box="[1152,1261,1170,1192]" italics="true" pageId="3" pageNumber="33">H. ozcelikii</emphasis>
</taxonomicName>
(
<tableCitation id="53109EB18D34C71ED8FBFB59F01D0DD5" box="[1274,1348,1170,1192]" captionStart="TABLE 2" captionStartId="5.[136,224,158,182]" captionTargetPageId="5" captionText="TABLE 2. Diagnostic characters of Hesperis zaferi, H. tosyaensis and H. ozcelikii." httpUri="http://table.plazi.org/id/4AEDFB828D32C718DC89FF55F6A709CA" pageId="3" pageNumber="33" tableUuid="4AEDFB828D32C718DC89FF55F6A709CA">Table 2</tableCitation>
).
</paragraph>
</subSubSection>
