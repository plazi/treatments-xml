<subSubSection pageId="82" pageNumber="83" type="discussion">
<paragraph blockId="82.[151,1437,1147,1354]" pageId="82" pageNumber="83">
<emphasis bold="true" box="[199,308,1256,1282]" pageId="82" pageNumber="83">Remarks</emphasis>
. 
<bibRefCitation author="Shinohara, A." box="[324,521,1255,1282]" pageId="82" pageNumber="83" pagination="99 - 116" refId="ref76721" refString="Shinohara, A. (2001) The group of Pamphilius sylvaticus (Hymenoptera, Pamphiliidae): Two new species, new collection records, and a key to Palearctic species. Japanese Journal of Systematic Entomology, 7, 99 - 116." type="journal article" year="2001">Shinohara (2001)</bibRefCitation>
described 
<taxonomicName authorityName="Shinohara" authorityYear="2001" box="[646,776,1255,1281]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="82" pageNumber="83" phylum="Arthropoda" rank="species" species="viridulus">
<emphasis box="[646,776,1255,1281]" italics="true" pageId="82" pageNumber="83">P. viridulus</emphasis>
</taxonomicName>
based on 
<specimenCount box="[894,1035,1255,1282]" pageId="82" pageNumber="83" type="female">two females</specimenCount>
, and these are still the only known specimens of this species. 
<bibRefCitation author="Shinohara, A." box="[444,632,1291,1318]" pageId="82" pageNumber="83" pagination="99 - 116" refId="ref76721" refString="Shinohara, A. (2001) The group of Pamphilius sylvaticus (Hymenoptera, Pamphiliidae): Two new species, new collection records, and a key to Palearctic species. Japanese Journal of Systematic Entomology, 7, 99 - 116." type="journal article" year="2001">Shinohara (2001</bibRefCitation>
, 
<bibRefCitation author="Shinohara, A." box="[642,714,1291,1317]" pageId="82" pageNumber="83" pagination="359 - 438" refId="ref76809" refString="Shinohara, A. (2002 b) Systematics of the leaf-rolling or webspinning sawfly subfamily Pamphiliinae: a preliminary overview. In: Viitasaari, M. (Ed.), Sawflies (Hymenoptera, Symphyta) I. Tremex Press, Helsinki, pp. 359 - 438." type="book chapter" year="2002">2002b</bibRefCitation>
) placed this species in the 
<taxonomicName baseAuthorityName="Linne" baseAuthorityYear="1758" box="[1009,1146,1291,1317]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="82" pageNumber="83" phylum="Arthropoda" rank="species" species="sylvaticus">
<emphasis box="[1009,1146,1291,1317]" italics="true" pageId="82" pageNumber="83">P. sylvaticus</emphasis>
</taxonomicName>
group. No molecular data for this species are available.
</paragraph>
