<paragraph blockId="36.[151,1436,1159,1330]" box="[151,543,1159,1186]" pageId="36" pageNumber="37">
<heading box="[151,543,1159,1186]" fontSize="11" level="2" pageId="36" pageNumber="37" reason="5">
<taxonomicName authority="Benes, 1972" authorityName="Benes" authorityYear="1972" box="[151,543,1159,1186]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="36" pageNumber="37" phylum="Arthropoda" rank="species" species="takeuchii">
<emphasis bold="true" box="[151,397,1159,1186]" italics="true" pageId="36" pageNumber="37">Pamphilius takeuchii</emphasis>
Beneš, 1972
</taxonomicName>
</heading>
</paragraph>
</subSubSection>
<subSubSection pageId="36" pageNumber="37" type="discussion">
<paragraph blockId="36.[151,1436,1159,1330]" pageId="36" pageNumber="37">
<bibRefCitation author="Sundukov, Yu. N. &amp; Lelej, A. S." box="[151,435,1195,1221]" pageId="36" pageNumber="37" pagination="1 - 12" refId="ref79941" refString="Sundukov, Yu. N. &amp; Lelej, A. S. (2009) Sawflies (Hymenoptera, Symphyta) of the Russian Far East. Additions and corrections. Far Eastern Entomologist, 200, 1 - 12." type="journal article" year="2009">Sundukov &amp; Lelej (2009</bibRefCitation>
, 
<bibRefCitation author="Sundukov, Yu. N. &amp; Lelej, A. S." box="[447,505,1195,1221]" pageId="36" pageNumber="37" pagination="62 - 119" refId="ref79983" refString="Sundukov, Yu. N. &amp; Lelej, A. S. (2012) Podotryad Symphyta - Sidyachebryukhie. In: Lelej, A. S. (Ed), Annotated Catalogue of the Insects of Russian Far East. Vol. I. Hymenoptera. Dalnauka, Vladivostok, pp. 62 - 119. [in Russian]" type="book chapter" year="2012">2012</bibRefCitation>
) and 
<bibRefCitation author="Sundukov, Yu. N." box="[568,764,1195,1221]" pageId="36" pageNumber="37" pagination="20 - 117" refId="ref79858" refString="Sundukov, Yu. N. (2017) Suborder Symphyta - Sawflies and wood wasps. In: Lelej, A. S., Proshchalykin, M. Yu. &amp; Loktionov, V. M. (Eds.), Annotated catalogue of the Hymenoptera of Russia. Vol. I. Symphyta and Apocrita: Aculeata. Proceedings of the Zoological Institute of the Russian Academy of Sciences, Supplement 6, pp. 20 - 117." type="journal article" year="2017">Sundukov (2017)</bibRefCitation>
included Primorskij Kraj in the distribution of 
<taxonomicName authorityName="Benes" authorityYear="1972" box="[1298,1430,1195,1221]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="36" pageNumber="37" phylum="Arthropoda" rank="species" species="takeuchii">
<emphasis box="[1298,1430,1195,1221]" italics="true" pageId="36" pageNumber="37">P. takeuchii</emphasis>
</taxonomicName>
. However, as discussed in detail by 
<bibRefCitation author="Shinohara, A." box="[547,745,1231,1257]" pageId="36" pageNumber="37" pagination="91 - 100" refId="ref77072" refString="Shinohara, A. (2013) Pamphiliid sawflies (Hymenoptera, Pamphiliidae) from Shikoku, southwestern Japan. Japanese Journal of Systematic Entomology, 19, 91 - 100." type="journal article" year="2013">Shinohara (2013)</bibRefCitation>
, the only known Russian specimen that was once determined as 
<taxonomicName authority="(Benes 1974)" baseAuthorityName="Benes" baseAuthorityYear="1974" box="[180,463,1267,1293]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="36" pageNumber="37" phylum="Arthropoda" rank="species" species="takeuchii">
<emphasis box="[180,309,1267,1293]" italics="true" pageId="36" pageNumber="37">P. takeuchii</emphasis>
(
<bibRefCitation author="Benes, K." box="[322,455,1267,1293]" pageId="36" pageNumber="37" pagination="298 - 314" refId="ref72854" refString="Benes, K. (1974) The Siberian species of Pamphilius Latr., related to P. histrio Latr. (Hymenoptera, Pamphiliidae). Acta Entomologica Bohemoslovaca, 71, 298 - 314." type="journal article" year="1974">Beneš 1974</bibRefCitation>
)
</taxonomicName>
is the 
<typeStatus box="[533,631,1267,1293]" pageId="36" pageNumber="37">holotype</typeStatus>
of 
<taxonomicName authority="Shinohara, 1986" authorityName="Shinohara" authorityYear="1986" box="[666,969,1267,1293]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="36" pageNumber="37" phylum="Arthropoda" rank="species" species="croceus">
<emphasis box="[666,778,1268,1293]" italics="true" pageId="36" pageNumber="37">P. croceus</emphasis>
Shinohara, 1986
</taxonomicName>
. 
<taxonomicName baseAuthorityName="Benes" baseAuthorityYear="1974" box="[979,1215,1267,1293]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="36" pageNumber="37" phylum="Arthropoda" rank="species" species="takeuchii">
<emphasis box="[979,1215,1267,1293]" italics="true" pageId="36" pageNumber="37">Pamphilius takeuchii</emphasis>
</taxonomicName>
is endemic to 
<collectingCountry box="[1372,1436,1268,1294]" name="Japan" pageId="36" pageNumber="37">Japan</collectingCountry>
and not known from 
<collectingCountry box="[386,461,1303,1329]" name="Russia" pageId="36" pageNumber="37">Russia</collectingCountry>
(
<bibRefCitation author="Shinohara, A. &amp; Zhou, H. - Z." box="[475,753,1303,1329]" pageId="36" pageNumber="37" pagination="153 - 189" refId="ref79412" refString="Shinohara, A. &amp; Zhou, H. - Z. (2006) Leaf-rolling sawflies of the Pamphilius komonensis complex (Hymenoptera, Pamphiliidae). Bulletin of the National Science Museum, Tokyo, Series A, 32, 153 - 189." type="journal article" year="2006">Shinohara &amp; Zhou 2006</bibRefCitation>
).
</paragraph>
</subSubSection>
