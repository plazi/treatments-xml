</taxonomicName>
, and a Chinese species, 
<taxonomicName authority="Shinohara &amp; Wei, 2016" authorityName="Shinohara &amp; Wei" authorityYear="2016" box="[578,936,988,1014]" class="Insecta" family="Pamphiliidae" genus="Onycholyda" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="66" pageNumber="67" phylum="Arthropoda" rank="species" species="atra">
<emphasis box="[578,661,988,1014]" italics="true" pageId="66" pageNumber="67">O. atra</emphasis>
<bibRefCitation author="Shinohara, A. &amp; Wei, M. - C." box="[669,936,988,1014]" pageId="66" pageNumber="67" pagination="301 - 318" refId="ref79214" refString="Shinohara, A. &amp; Wei, M. - C. (2016) Leaf-rolling sawflies (Hymenoptera, Pamphiliidae, Pamphiliinae) of Tianmushan Mountains, Zhejiang Province, China. Zootaxa, 4072 (3), 301 - 318. https: // doi. org / 10.11646 / zootaxa. 4072.3.1" type="journal article" year="2016">Shinohara &amp; Wei, 2016</bibRefCitation>
</taxonomicName>
