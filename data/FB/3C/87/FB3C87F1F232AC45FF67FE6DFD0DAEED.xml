<bibRefCitation author="Takeuchi, K." box="[1032,1208,952,978]" pageId="66" pageNumber="67" pagination="3 - 16" refId="ref80368" refString="Takeuchi, K. (1930) A revisional list of the Japanese Pamphiliidae, with description of nine new species. Transactions of the Kansai Entomological Society, 1, 3 - 16." type="journal article" year="1930">Takeuchi, 1930</bibRefCitation>
)
</taxonomicName>
and 
<taxonomicName authority="Shinohara, 1987" authorityName="Shinohara" authorityYear="1987" class="Insecta" family="Pamphiliidae" genus="Onycholyda" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="66" pageNumber="67" phylum="Arthropoda" rank="species" species="similis">
<emphasis box="[1273,1381,952,978]" italics="true" pageId="66" pageNumber="67">O. similis</emphasis>
