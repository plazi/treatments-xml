<subSubSection pageId="66" pageNumber="67" type="discussion">
<paragraph blockId="66.[151,1437,808,1518]" pageId="66" pageNumber="67">
<emphasis bold="true" box="[199,308,952,978]" pageId="66" pageNumber="67">Remarks</emphasis>
. This species is similar to two Japanese species, 
<taxonomicName authority="(Takeuchi, 1930)" baseAuthorityName="Takeuchi" baseAuthorityYear="1930" box="[865,1217,952,978]" class="Insecta" family="Pamphiliidae" genus="Onycholyda" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="66" pageNumber="67" phylum="Arthropoda" rank="species" species="minomalis">
