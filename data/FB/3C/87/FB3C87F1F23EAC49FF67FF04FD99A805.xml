, 
<figureCitation box="[1047,1092,711,738]" captionStart="FIGURE 159" captionStartId="244.[151,250,1756,1780]" captionTargetBox="[157,1427,187,1724]" captionTargetId="figure-26@244.[151,1436,181,1733]" captionTargetPageId="244" captionText="FIGURE 159. Condensed ML tree based on NaK gene sequences, with details of Pamphilius sylvaticus group." figureDoi="http://doi.org/10.5281/zenodo.6876882" httpUri="https://zenodo.org/record/6876882/files/figure.png" pageId="78" pageNumber="79">159</figureCitation>
), 
<taxonomicName authorityName="Shinohara" authorityYear="1985" box="[1114,1214,711,737]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="78" pageNumber="79" phylum="Arthropoda" rank="species" species="benesi">
