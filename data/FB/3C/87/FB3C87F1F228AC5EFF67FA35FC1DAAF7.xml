<collectingCountry box="[1295,1436,1863,1889]" name="South Korea" pageId="88" pageNumber="89">South Korea</collectingCountry>
(
<bibRefCitation author="Shinohara, A." box="[159,341,1899,1925]" pageId="88" pageNumber="89" pagination="225 - 252" refId="ref76684" refString="Shinohara, A. (1998) Pamphilius albopictus (Hymenoptera, Pamphiliidae) and its close relatives. Bulletin of the National Science Museum, Tokyo, Series A, 24, 225 - 252." type="journal article" year="1998">Shinohara 1998</bibRefCitation>
