<taxonomicName authorityName="Shinohara" authorityYear="1980" box="[784,871,1220,1245]" class="Insecta" family="Pamphiliidae" genus="Neurotoma" kingdom="Animalia" order="Hymenoptera" pageId="59" pageNumber="60" phylum="Arthropoda" rank="species" species="satoi">
