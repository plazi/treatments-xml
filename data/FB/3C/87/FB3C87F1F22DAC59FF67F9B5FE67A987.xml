<taxonomicName authority="Shinohara &amp; Kramp &amp; Taeger, 2022" authorityName="Shinohara &amp; Kramp &amp; Taeger" authorityYear="2022" box="[985,1179,1907,1933]" class="Insecta" family="Pamphiliidae" genus="Lyda" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="93" pageNumber="94" phylum="Arthropoda" rank="species" species="sapporensis" status="n. sp.">
