<location LSID="urn:lsid:plazi:treatment:FB3C87F1F22CAC5BFF67FB98FC48ADD9:764A603CF22CAC5BFCD2FA33FC3BAEB9" box="[802,916,1440,1466]" name="Shinohara" pageId="92" pageNumber="93">Shinohara</location>
(
<collectionCode box="[930,1014,1441,1467]" country="Japan" httpUri="http://grbio.org/cool/f678-ci92" name="National Science Museum (Natural History)" pageId="92" pageNumber="93">NSMT</collectionCode>
).
</paragraph>
</subSubSection>
<subSubSection pageId="92" pageNumber="93" type="distribution">
<paragraph blockId="92.[151,1437,1332,1755]" pageId="92" pageNumber="93">
<emphasis bold="true" box="[199,345,1476,1502]" pageId="92" pageNumber="93">Distribution</emphasis>
. Europe, 
<collectingCountry box="[455,503,1477,1503]" name="Iran" pageId="92" pageNumber="93">Iran</collectingCountry>
, Siberia to Kamchatka Kraj and the continental part of the Russian Far East, northeastern 
<collectingCountry box="[237,307,1512,1538]" name="China" pageId="92" pageNumber="93">China</collectingCountry>
, North and 
<collectingCountry box="[438,578,1512,1539]" name="South Korea" pageId="92" pageNumber="93">South Korea</collectingCountry>
(Shinohara 2005).
</paragraph>
</subSubSection>
<subSubSection box="[199,1254,1548,1575]" pageId="92" pageNumber="93" type="biology_ecology">
<paragraph blockId="92.[151,1437,1332,1755]" box="[199,1254,1548,1575]" pageId="92" pageNumber="93">
<emphasis bold="true" box="[199,324,1549,1575]" pageId="92" pageNumber="93">Host plant</emphasis>
. 
<taxonomicName authorityName="S.F.Gray" authorityYear="1822" box="[338,465,1548,1574]" class="Magnoliopsida" family="Betulaceae" kingdom="Plantae" order="Fagales" pageId="92" pageNumber="93" phylum="Tracheophyta" rank="family">Betulaceae</taxonomicName>
: 
<taxonomicName box="[476,604,1548,1575]" class="Magnoliopsida" family="Betulaceae" genus="Betula" kingdom="Plantae" order="Fagales" pageId="92" pageNumber="93" phylum="Tracheophyta" rank="species" species="undetermined">
<emphasis box="[476,549,1548,1574]" italics="true" pageId="92" pageNumber="93">Betula</emphasis>
spp.
</taxonomicName>
,? 
<taxonomicName box="[628,746,1548,1575]" class="Magnoliopsida" family="Betulaceae" genus="Alnus" kingdom="Plantae" order="Fagales" pageId="92" pageNumber="93" phylum="Tracheophyta" rank="species" species="undetermined">
<emphasis box="[628,692,1548,1574]" italics="true" pageId="92" pageNumber="93">Alnus</emphasis>
spp.
</taxonomicName>
(
<bibRefCitation author="Taeger, A. &amp; Altenhofer, E. &amp; Blank, S. M. &amp; Jansen, E. &amp; Kraus, M. &amp; Pschorn-Walcher, H. &amp; Ritzau, C." box="[759,966,1548,1575]" pageId="92" pageNumber="93" pagination="49 - 135" refId="ref80046" refString="Taeger, A., Altenhofer, E., Blank, S. M., Jansen, E., Kraus, M., Pschorn-Walcher, H. &amp; Ritzau, C. (1998) Kommentare zur Biologie, Verbreitung und Gefahrdung der Pflanzenwespen Deutschlands (Hymenoptera, Symphyta). In: Taeger, A. &amp; Blank, S. M. (Eds), Pflanzenwespen Deutschlands (Hymenoptera, Symphyta). Kommentierte Bestandsaufnahme. Goecke &amp; Evers, Keltern, pp. 49 - 135." type="book chapter" year="1998">
Taeger 
<emphasis box="[844,900,1548,1574]" italics="true" pageId="92" pageNumber="93">et al.</emphasis>
1998
</bibRefCitation>
; 
<bibRefCitation author="Shinohara, A." box="[978,1169,1548,1575]" pageId="92" pageNumber="93" pagination="453 - 480" refId="ref76861" refString="Shinohara, A. (2003 a) Leaf-rolling sawflies of the Pamphilius vafer complex (Hymenoptera, Pamphiliidae) in Europe. Insect Systematics &amp; Evolution, Copenhagen, 34, 453 - 480. https: // doi. org / 10.1163 / 187631203 X 00063" type="journal article" year="2003">Shinohara 2003a</bibRefCitation>
, 2005).
</paragraph>
</subSubSection>
<subSubSection pageId="92" pageNumber="93" type="discussion">
<paragraph blockId="92.[151,1437,1332,1755]" pageId="92" pageNumber="93">
<emphasis bold="true" box="[199,308,1585,1611]" pageId="92" pageNumber="93">Remarks</emphasis>
. This is a widely distributed Palaearctic species but not recorded from 
<collectingCountry box="[1152,1216,1585,1611]" name="Japan" pageId="92" pageNumber="93">Japan</collectingCountry>
(
<bibRefCitation author="Shinohara, A." box="[1234,1432,1584,1611]" pageId="92" pageNumber="93" pagination="453 - 480" refId="ref76861" refString="Shinohara, A. (2003 a) Leaf-rolling sawflies of the Pamphilius vafer complex (Hymenoptera, Pamphiliidae) in Europe. Insect Systematics &amp; Evolution, Copenhagen, 34, 453 - 480. https: // doi. org / 10.1163 / 187631203 X 00063" type="journal article" year="2003">Shinohara 2003a</bibRefCitation>
, 2005). It belongs to the 
<taxonomicName authorityName=": Malaise" authorityYear="1931" box="[415,500,1621,1647]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="92" pageNumber="93" phylum="Arthropoda" rank="species" species="vafer">
<emphasis box="[415,500,1621,1647]" italics="true" pageId="92" pageNumber="93">P. vafer</emphasis>
</taxonomicName>
complex (Shinohara 2005) or the 
<taxonomicName authorityName=": Malaise" authorityYear="1931" box="[880,965,1621,1647]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="92" pageNumber="93" phylum="Arthropoda" rank="species" species="vafer">
<emphasis box="[880,965,1621,1647]" italics="true" pageId="92" pageNumber="93">P. vafer</emphasis>
</taxonomicName>
subgroup of the 
<taxonomicName authorityName=": Malaise" authorityYear="1931" box="[1151,1236,1621,1647]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="92" pageNumber="93" phylum="Arthropoda" rank="species" species="vafer">
<emphasis box="[1151,1236,1621,1647]" italics="true" pageId="92" pageNumber="93">P. vafer</emphasis>
</taxonomicName>
group (
<bibRefCitation author="Shinohara, A." pageId="92" pageNumber="93" pagination="359 - 438" refId="ref76809" refString="Shinohara, A. (2002 b) Systematics of the leaf-rolling or webspinning sawfly subfamily Pamphiliinae: a preliminary overview. In: Viitasaari, M. (Ed.), Sawflies (Hymenoptera, Symphyta) I. Tremex Press, Helsinki, pp. 359 - 438." type="book chapter" year="2002">Shinohara 2002b</bibRefCitation>
). The larva is a solitary leaf-roller, making a leaf-roll on the underside. The oviposition is on the upperside (
<typeStatus box="[159,216,1693,1719]" pageId="92" pageNumber="93">Type</typeStatus>
II of Shinohara 2005). As noted under 
<taxonomicName authorityName="Shinohara" authorityYear="2005" box="[657,790,1692,1718]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="92" pageNumber="93" phylum="Arthropoda" rank="species" species="alnivorus">
<emphasis box="[657,790,1692,1718]" italics="true" pageId="92" pageNumber="93">P. alnivorus</emphasis>
</taxonomicName>
, the site of oviposition (upperside of a leaf) and direction of leaf-rolling (underside) in this species and 
<taxonomicName authorityName="Shinohara" authorityYear="2005" box="[660,794,1728,1754]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="92" pageNumber="93" phylum="Arthropoda" rank="species" species="alnivorus">
<emphasis box="[660,794,1728,1754]" italics="true" pageId="92" pageNumber="93">P. alnivorus</emphasis>
</taxonomicName>
are characteristic.
</paragraph>
</subSubSection>
