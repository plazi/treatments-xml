: 
<bibRefCitation author="Shinohara, A. &amp; Okutani, T." box="[322,657,917,941]" pageId="63" pageNumber="64" pagination="276 - 281" refId="ref78722" refString="Shinohara, A. &amp; Okutani, T. (1983) Host-plants of Japanese Pamphiliidae (Hymenoptera, Pamphiliidae). Kontyu, Tokyo, 51, 276 - 281." type="journal article" year="1983">Shinohara &amp; Okutani, 1983: 277</bibRefCitation>
