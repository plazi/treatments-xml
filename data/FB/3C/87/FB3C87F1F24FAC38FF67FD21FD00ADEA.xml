<emphasis bold="true" box="[199,434,1131,1157]" pageId="63" pageNumber="64">Material examined.</emphasis>
About 
<specimenCount box="[518,688,1131,1158]" pageId="63" pageNumber="64" type="generic">355 specimens</specimenCount>
