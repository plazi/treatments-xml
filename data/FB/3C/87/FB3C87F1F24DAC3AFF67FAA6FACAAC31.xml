<taxonomicName authorityName="Takeuchi" authorityYear="1938" box="[1142,1436,1780,1806]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="61" pageNumber="62" phylum="Arthropoda" rank="species" species="leucocephalus">
