<bibRefCitation author="Shinohara, A. &amp; Byun, B. - K." pageId="58" pageNumber="59" pagination="75 - 91" refId="ref77325" refString="Shinohara, A. &amp; Byun, B. - K. (1993) Pamphiliid sawfly genera Neurotoma and Onycholyda (Hymenoptera, Symphyta) of Korea. Insecta Koreana, Chuncheon, 10, 75 - 91." type="journal article" year="1993">Shinohara &amp; Byun 1993</bibRefCitation>
, 
<bibRefCitation author="Shinohara, A. &amp; Lee, J. - W." box="[408,670,878,905]" pageId="58" pageNumber="59" pagination="213 - 220" refId="ref78505" refString="Shinohara, A. &amp; Lee, J. - W. (1997) Collection records of pamphiliid sawflies (Hymenoptera) from Korea. Bulletin of the National Science Museum, Tokyo, Series A, 23, 213 - 220." type="journal article" year="1997">Shinohara &amp; Lee 1997</bibRefCitation>
