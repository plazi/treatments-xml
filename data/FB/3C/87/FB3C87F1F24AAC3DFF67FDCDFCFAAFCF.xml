<typeStatus box="[799,847,843,869]" pageId="58" pageNumber="59">type</typeStatus>
series, all from South Korea (
<bibRefCitation author="Shinohara, A." box="[1194,1377,842,868]" pageId="58" pageNumber="59" pagination="87 - 117" refId="ref75956" refString="Shinohara, A. (1980) East Asian species of the genus Neurotoma (Hymenoptera: Pamphiliidae). Transactions of the Shikoku Entomological Society, 15, 87 - 117." type="journal article" year="1980">Shinohara 1980</bibRefCitation>
