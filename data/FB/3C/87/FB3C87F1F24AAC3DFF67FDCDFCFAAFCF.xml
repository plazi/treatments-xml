<subSubSection pageId="58" pageNumber="59" type="materials_examined">
<paragraph blockId="58.[151,1437,842,1229]" pageId="58" pageNumber="59">
<emphasis bold="true" box="[151,386,842,868]" pageId="58" pageNumber="59">Material examined.</emphasis>
