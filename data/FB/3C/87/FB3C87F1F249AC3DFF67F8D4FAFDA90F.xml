<taxonomicName authority="Shinohara, 1980" authorityName="Shinohara" authorityYear="1980" class="Insecta" family="Pamphiliidae" genus="Neurotoma" kingdom="Animalia" order="Hymenoptera" pageId="58" pageNumber="59" phylum="Arthropoda" rank="species" species="sinica">
