<taxonomicName box="[338,448,223,249]" class="Magnoliopsida" family="Rosaceae" kingdom="Plantae" order="Rosales" pageId="74" pageNumber="75" phylum="Tracheophyta" rank="family">Rosaceae</taxonomicName>
: 
<taxonomicName authority="Thunb." authorityName="Thunb." box="[459,722,222,248]" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="74" pageNumber="75" phylum="Tracheophyta" rank="species" species="multiflora">
<emphasis box="[459,634,222,248]" italics="true" pageId="74" pageNumber="75">Rosa multiflora</emphasis>
Thunb.
</taxonomicName>
(
<bibRefCitation author="Shinohara, A." box="[735,916,222,248]" pageId="74" pageNumber="75" refId="ref75876" refString="Shinohara, A. (1971) [Sawflies of Shiki]. In: Torasanbe. Publications of Biology Club. Vol. 7. Keio Gijuku Shiki High School, Shiki, pp. 24 - 31. [in Japanese]" type="book" year="1971">Shinohara 1971</bibRefCitation>
