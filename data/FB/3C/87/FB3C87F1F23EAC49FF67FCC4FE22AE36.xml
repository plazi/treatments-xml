<subSubSection pageId="78" pageNumber="79" type="discussion">
<paragraph blockId="78.[151,1436,1091,1333]" pageId="78" pageNumber="79">
<emphasis bold="true" box="[199,308,1235,1261]" pageId="78" pageNumber="79">Remarks</emphasis>
. This species is known only from 
<specimenCount box="[696,864,1235,1261]" pageId="78" pageNumber="79" type="generic">five specimens</specimenCount>
collected in the Russian Far East and 
<collectingCountry box="[1295,1436,1235,1262]" name="South Korea" pageId="78" pageNumber="79">South Korea</collectingCountry>
(
<bibRefCitation author="Shinohara, A. &amp; Lee, J. - W." box="[159,415,1271,1298]" pageId="78" pageNumber="79" pagination="213 - 220" refId="ref78505" refString="Shinohara, A. &amp; Lee, J. - W. (1997) Collection records of pamphiliid sawflies (Hymenoptera) from Korea. Bulletin of the National Science Museum, Tokyo, Series A, 23, 213 - 220." type="journal article" year="1997">Shinohara &amp; Lee 1997</bibRefCitation>
). 
<bibRefCitation author="Shinohara, A." box="[433,632,1271,1297]" pageId="78" pageNumber="79" pagination="307 - 320" refId="ref76348" refString="Shinohara, A. (1988 a) The group of Pamphilius sylvaticus (Hymenoptera, Pamphiliidae): Five new species and additional records from the Far East. Kontyu, Tokyo, 56, 307 - 320." type="journal article" year="1988">
Shinohara (1988 
<bibRefCitation author="Shinohara, A." box="[619,632,1271,1297]" pageId="78" pageNumber="79" pagination="359 - 438" refId="ref76809" refString="Shinohara, A. (2002 b) Systematics of the leaf-rolling or webspinning sawfly subfamily Pamphiliinae: a preliminary overview. In: Viitasaari, M. (Ed.), Sawflies (Hymenoptera, Symphyta) I. Tremex Press, Helsinki, pp. 359 - 438." type="book chapter" year="2002">a</bibRefCitation>
</bibRefCitation>
, 2002b) placed it in the 
<taxonomicName baseAuthorityName="Linne" baseAuthorityYear="1758" box="[895,1031,1271,1297]" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="78" pageNumber="79" phylum="Arthropoda" rank="species" species="sylvaticus">
<emphasis box="[895,1031,1271,1297]" italics="true" pageId="78" pageNumber="79">P. sylvaticus</emphasis>
</taxonomicName>
group. No molecular data have been available for analysis.
</paragraph>
