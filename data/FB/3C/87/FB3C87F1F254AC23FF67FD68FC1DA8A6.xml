<paragraph blockId="36.[151,1437,763,934]" box="[151,551,763,790]" pageId="36" pageNumber="37">
<heading box="[151,551,763,790]" fontSize="11" level="2" pageId="36" pageNumber="37" reason="5">
<taxonomicName authority="(Rohwer, 1910)" baseAuthorityName="Rohwer" baseAuthorityYear="1910" box="[151,551,763,790]" class="Insecta" family="Pamphiliidae" genus="Onycholyda" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="36" pageNumber="37" phylum="Arthropoda" rank="species" species="lucida">
<emphasis bold="true" box="[151,369,763,790]" italics="true" pageId="36" pageNumber="37">Onycholyda lucida</emphasis>
(Rohwer, 1910)
</taxonomicName>
</heading>
</paragraph>
</subSubSection>
<subSubSection pageId="36" pageNumber="37" type="discussion">
<paragraph blockId="36.[151,1437,763,934]" pageId="36" pageNumber="37">
<bibRefCitation author="Sundukov, Yu. N." box="[151,346,799,825]" pageId="36" pageNumber="37" pagination="20 - 117" refId="ref79858" refString="Sundukov, Yu. N. (2017) Suborder Symphyta - Sawflies and wood wasps. In: Lelej, A. S., Proshchalykin, M. Yu. &amp; Loktionov, V. M. (Eds.), Annotated catalogue of the Hymenoptera of Russia. Vol. I. Symphyta and Apocrita: Aculeata. Proceedings of the Zoological Institute of the Russian Academy of Sciences, Supplement 6, pp. 20 - 117." type="journal article" year="2017">Sundukov (2017)</bibRefCitation>
included the Sakha Republic in the distribution of this species. The record of 
<bibRefCitation author="Kajmuk, E. L." box="[1205,1376,799,825]" pageId="36" pageNumber="37" pagination="71 - 90" refId="ref73666" refString="Kajmuk, E. L. (1972) Materialy po faune pilil'shchikov (Hymenoptera, Tenthredinoidea) yuzhnoj Jakutii. In: Fauna i ekologija nasekomykh Jakutii, Jakutsk, pp. 71 - 90." type="book chapter" year="1972">Kajmuk (1972)</bibRefCitation>
from Yakutia (also 
<bibRefCitation author="Verzhutskij, B. N." box="[303,494,835,861]" pageId="36" pageNumber="37" pagination="1 - 303" refId="ref80536" refString="Verzhutskij, B. N. (1981) Rastitel'nojadnye nasekomye v ekosistemakh Vostochnoj Sibiri (pilil'shchiki i rogokhvosty). Nauka, Novosibirsk, pp. 1 - 303." type="book chapter" year="1981">Verzhutskij 1981</bibRefCitation>
) was based on a misidentification of 
<taxonomicName authority="(Fallen, 1808) (Shinohara 1986 c)" authorityName="Shinohara" authorityYear="1986" baseAuthorityName="Fallen" baseAuthorityYear="1808" class="Insecta" family="Pamphiliidae" genus="Pamphilius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="36" pageNumber="37" phylum="Arthropoda" rank="species" species="balteatus">
<emphasis box="[907,1143,835,861]" italics="true" pageId="36" pageNumber="37">Pamphilius balteatus</emphasis>
(
<bibRefCitation author="Fallen, C. F." box="[1157,1299,835,861]" pageId="36" pageNumber="37" pagination="219 - 227" refId="ref73308" refString="Fallen, C. F. (1808) Forsok till uppstallning och beskrifning a de i Sverige fundne Arter af Insect-Slagtet Tenthredo Linn. Kongl. Vetenskaps Academiens nya Handlingar, Stockholm, 29, 219 - 227." type="journal article" year="1808">Fallén, 1808</bibRefCitation>
) (
<bibRefCitation author="Shinohara, A." pageId="36" pageNumber="37" pagination="611 - 617" refId="ref76251" refString="Shinohara, A. (1986 c) The sawfly genus Onycholyda (Hymenoptera, Pamphiliidae) of Japan IV. Kontyu, Tokyo, 54, 611 - 617." type="journal article" year="1986">Shinohara 1986c</bibRefCitation>
)
</taxonomicName>
. 
<bibRefCitation author="Zhelochovtsev, A. N. &amp; Zinovjev, A. G." box="[244,630,871,898]" pageId="36" pageNumber="37" pagination="395 - 415" refId="ref81182" refString="Zhelochovtsev, A. N. &amp; Zinovjev, A. G. (1995) A list of the sawflies and horntails (Hymenoptera, Symphyta) of the fauna of Russia and adjacent territories. I. Entomologicheskoe Obozrenie, 74, 395 - 415. [in Russian]" type="journal article" year="1995">Zhelochovtsev &amp; Zinovjev (1995)</bibRefCitation>
and 
<bibRefCitation author="Shinohara, A. &amp; Lelej, A. S." box="[686,977,871,897]" pageId="36" pageNumber="37" pagination="922 - 942" refId="ref78590" refString="Shinohara, A. &amp; Lelej, A. S. (2007) 2. Sem. Pamphiliidae - Pautinnye Pilil'shchiki, ili Pilil'shchiki-tkachi. In: Lelej, A. S. (Ed.), Setchatokryloobraznye, Skorpionnitsy, Pereponchatokrylye. Ch. 5. Opredelitel' Nasekomykh Dal'nego Vostoka Rossii. Tom IV. Dal'nauka, Vladivostok, pp. 922 - 942." type="book chapter" year="2007">Shinohara &amp; Lelej (2007)</bibRefCitation>
did not include 
<taxonomicName baseAuthorityName="Rohwer" baseAuthorityYear="1910" box="[1163,1268,871,898]" class="Insecta" family="Pamphiliidae" genus="Onycholyda" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="36" pageNumber="37" phylum="Arthropoda" rank="species" species="lucida">
<emphasis box="[1163,1268,871,898]" italics="true" pageId="36" pageNumber="37">O. lucida</emphasis>
</taxonomicName>
in the Russian fauna. 
<taxonomicName baseAuthorityName="Rohwer" baseAuthorityYear="1910" box="[227,440,907,933]" class="Insecta" family="Pamphiliidae" genus="Onycholyda" higherTaxonomySource="GBIF" kingdom="Animalia" order="Hymenoptera" pageId="36" pageNumber="37" phylum="Arthropoda" rank="species" species="lucida">
<emphasis box="[227,440,907,933]" italics="true" pageId="36" pageNumber="37">Onycholyda lucida</emphasis>
</taxonomicName>
is endemic to 
<collectingCountry box="[603,667,908,934]" name="Japan" pageId="36" pageNumber="37">Japan</collectingCountry>
(Shinohara 2019, 2020).
</paragraph>
</subSubSection>
