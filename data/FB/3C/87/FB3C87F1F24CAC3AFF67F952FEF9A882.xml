<paragraph blockId="60.[151,571,1729,1755]" box="[151,571,1729,1755]" pageId="60" pageNumber="61">
<heading bold="true" box="[151,571,1729,1755]" fontSize="11" level="2" pageId="60" pageNumber="61" reason="3">
<emphasis bold="true" box="[151,571,1729,1755]" pageId="60" pageNumber="61">
Tribe 
<taxonomicName authority="Cameron, 1890" authorityName="Cameron" authorityYear="1890" box="[226,571,1729,1755]" class="Insecta" family="Pamphiliidae" kingdom="Animalia" order="Hymenoptera" pageId="60" pageNumber="61" phylum="Arthropoda" rank="tribe" tribe="Pamphiliini">
Pamphiliini 
<bibRefCitation author="Cameron, P." box="[380,571,1729,1755]" pageId="60" pageNumber="61" refId="ref73094" refString="Cameron, P. (1890) A monograph of the British phytophagous Hymenoptera. (Tenthredo, Sirex and Cynips, Linne). Vol. III. Ray Society, London, 274 pp., 17 pls." type="book" year="1890">Cameron, 1890</bibRefCitation>
</taxonomicName>
</emphasis>
