<subSubSection box="[199,457,223,249]" pageId="72" pageNumber="73" type="biology_ecology">
<paragraph blockId="72.[151,1437,150,393]" box="[199,457,223,249]" pageId="72" pageNumber="73">
<emphasis bold="true" box="[199,324,223,249]" pageId="72" pageNumber="73">Host plant</emphasis>
