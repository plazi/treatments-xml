<bibRefCitation id="017B82DBFFFFFFC0FEB4F8ABFE0BF83A" author="Guenee, A. M." box="[338,502,1913,1940]" pageId="23" pageNumber="24" refId="ref37734" refString="Guenee, A. M. (1852) Histoire naturelle des Insectes. VII. Species general des Lepidopteres. Noctuelites. Tome III. Librairie Encyclopedique de Roret, Paris, 442 pp." type="book" year="1852">Guenée, 1852</bibRefCitation>
