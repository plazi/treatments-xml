<heading id="D0CC81C3FFD6C60EFF1DDDE0D45E1BDB" bold="true" box="[151,525,907,934]" fontSize="11" level="1" pageId="1" pageNumber="76" reason="1">
<emphasis id="B94FEABDFFD6C60EFF1DDDE0D45E1BDB" bold="true" box="[151,525,907,934]" pageId="1" pageNumber="76">
Genus 
<taxonomicName id="4C3B4D2CFFD6C60EFF64DDE0D45E1BDB" authority="Simon, 1897" authorityName="Simon" authorityYear="1897" box="[238,525,907,934]" class="Arachnida" family="Trachelidae" genus="Orthobula" kingdom="Animalia" order="Araneae" pageId="1" pageNumber="76" phylum="Arthropoda" rank="genus">
<emphasis id="B94FEABDFFD6C60EFF64DDE0D73F1BD8" bold="true" box="[238,364,907,934]" italics="true" pageId="1" pageNumber="76">Orthobula</emphasis>
<bibRefCitation id="EFAA4B5EFFD6C60EFEF9DDE0D45E1BDB" author="Simon, E." box="[371,525,907,933]" pageId="1" pageNumber="76" pagination="1 - 192" refId="ref3639" refString="Simon, E. (1897 a) Histoire naturelle des araignees. Tome second, Premier fascicule. Librairie Encyclopedique de Roret, Paris, 1 - 192." type="book chapter" year="1897">Simon, 1897</bibRefCitation>
