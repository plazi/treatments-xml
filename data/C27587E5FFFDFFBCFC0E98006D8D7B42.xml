</taxonomicName>
, p. 122, pl. 16, figs. 27-31, pl. 17, figs. 1-3.
</paragraph>
<paragraph id="4A6336F3FFFDFFBCFC9598936D20786B" blockId="16.[831,1437,1183,1290]" pageId="16" pageNumber="30">
1956. 
<taxonomicName id="8DDC4D70FFFDFFBCFC2898936DB5798C" authority="CUSHMAN." authorityName="CUSHMAN." box="[898,1208,1239,1261]" class="Globothalamea" family="Pseudogaudryinidae" genus="Clavulinoides" kingdom="Chromista" order="Textulariida" pageId="16" pageNumber="30" phylum="Foraminifera" rank="species" species="asper">
