1937. 
<taxonomicName id="8DDC4D70FFFDFFBCFC2898DB6DB779D5" authority="CUSHMAN" authorityName="CUSHMAN" box="[898,1210,1183,1204]" class="Globothalamea" family="Pseudogaudryinidae" genus="Clavulinoides" kingdom="Chromista" order="Textulariida" pageId="16" pageNumber="30" phylum="Foraminifera" rank="species" species="asper">
