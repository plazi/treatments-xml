(
<bibRefCitation id="017B82DBFFFFFFC0FE64FBECFD5AFBF6" author="Griveaud, P. &amp; Viette, P. E. L." box="[386,679,1086,1112]" pageId="23" pageNumber="24" pagination="53 - 62" refId="ref37664" refString="Griveaud, P. &amp; Viette, P. E. L. (1960) Nouvelles especes malgaches de noctuelles quadrifides (Lepidopteres). Bulletin de l'Academie Malgache, New Series, 38, 53 - 62." type="journal article" year="1960">Griveaud &amp; Viette, 1960</bibRefCitation>
