<collectingRegion country="United States of America" name="New York" pageId="19" pageNumber="580">New York</collectingRegion>
, 
<collectingCountry box="[872,1006,369,393]" name="United States of America" pageId="19" pageNumber="580">United States</collectingCountry>
, and Sandbian of 
<collectingCountry box="[1182,1282,369,393]" name="Argentina" pageId="19" pageNumber="580">Argentina</collectingCountry>
.
</paragraph>
</subSubSection>
