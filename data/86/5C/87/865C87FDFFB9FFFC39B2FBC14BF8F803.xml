<emphasis bold="true" box="[220,254,1767,1784]" pageId="28" pageNumber="589">A-H</emphasis>
, 
<taxonomicName authority="Ernst &amp; Carrera, 2022" authorityName="Ernst &amp; Carrera" authorityYear="2022" box="[264,496,1767,1784]" class="Stenolaemata" family="Stictoporellidae" genus="Pseudostictoporella" kingdom="Animalia" order="Cryptostomida" pageId="28" pageNumber="589" phylum="Bryozoa" rank="species" species="simplex" status="n. sp.">
