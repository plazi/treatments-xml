<subSubSection pageId="28" pageNumber="589" type="discussion">
<paragraph blockId="28.[810,1456,1874,2028]" pageId="28" pageNumber="589">
<taxonomicName authority="Ernst &amp; Carrera, 2022" authorityName="Ernst &amp; Carrera" authorityYear="2022" box="[813,1063,1905,1931]" class="Stenolaemata" family="Stictoporellidae" genus="Pseudostictoporella" kingdom="Animalia" order="Cryptostomida" pageId="28" pageNumber="589" phylum="Bryozoa" rank="species" species="simplex" status="n. sp.">
<emphasis box="[813,1063,1905,1931]" italics="true" pageId="28" pageNumber="589">Pseudostictoporella simplex</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[1067,1120,1906,1932]" pageId="28" pageNumber="589" rank="species">n. sp.</taxonomicNameLabel>
is similar to 
<taxonomicName authority="Ross, 1970" authorityName="Ross" authorityYear="1970" box="[1237,1452,1905,1932]" class="Stenolaemata" family="Stictoporellidae" genus="Pseudostictoporella" kingdom="Animalia" order="Cryptostomida" pageId="28" pageNumber="589" phylum="Bryozoa" rank="species" species="typicalis">
<emphasis box="[1237,1333,1905,1931]" italics="true" pageId="28" pageNumber="589">P.typicalis</emphasis>
<bibRefCitation author="ROSS J. R. P." box="[1339,1452,1905,1932]" pageId="28" pageNumber="589" pagination="346 - 382" refId="ref22702" refString="ROSS J. R. P. 1970. - Distribution, paleoecology, and correlation of Champlainian Ectoprocta (Bryozoa), New York State, Part III. Journal of Paleontology 44: 346 - 382. https: // www. jstor. org / stable / 1302548" type="journal article" year="1970">Ross, 1970</bibRefCitation>
</taxonomicName>
, but differs from it in absence of metazooecia and pustules. 
<taxonomicName authority="Jimenez-Sanchez, 2009" authorityName="Jimenez-Sanchez" authorityYear="2009" class="Stenolaemata" family="Stictoporellidae" genus="Pseudostictoporella" kingdom="Animalia" order="Cryptostomida" pageId="28" pageNumber="589" phylum="Bryozoa" rank="species" species="iberiensis">
<emphasis box="[1390,1405,1938,1963]" italics="true" pageId="28" pageNumber="589">P</emphasis>
. 
<emphasis italics="true" pageId="28" pageNumber="589">iberiensis</emphasis>
Jiménez-Sánchez, 2009
</taxonomicName>
from the Katian of Spain possesses hemisepta and may not belong to the genus 
<taxonomicName authorityName="Ross" authorityYear="1970" box="[1266,1446,2001,2027]" class="Stenolaemata" family="Stictoporellidae" genus="Pseudostictoporella" kingdom="Animalia" order="Cryptostomida" pageId="28" pageNumber="589" phylum="Bryozoa" rank="genus">
<emphasis box="[1266,1446,2001,2027]" italics="true" pageId="28" pageNumber="589">Pseudostictoporella</emphasis>
</taxonomicName>
.
</paragraph>
</subSubSection>
