<paragraph blockId="25.[131,775,1491,1676]" pageId="25" pageNumber="586">
<taxonomicName authority="Billings, 1865" authorityName="Billings" authorityYear="1865" box="[132,417,1522,1549]" class="Stenolaemata" family="Arthrostylidae" genus="Arthroclema" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Cryptostomida" pageId="25" pageNumber="586" phylum="Bryozoa" rank="genus">
