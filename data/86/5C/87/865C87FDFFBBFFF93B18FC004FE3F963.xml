<bibRefCitation author="BASSLER R. S." box="[401,542,1618,1645]" pageId="25" pageNumber="586" pagination="381 - 385" refId="ref18772" refString="BASSLER R. S. 1952. - Taxonomic notes on genera of fossil and Recent Bryozoa. Journal of the Washington Academy of Sciences 42: 381 - 385. https: // www. jstor. org / stable / 24531385" type="journal article" year="1952">
Bassler, 
<quantity box="[486,569,1618,1645]" metricMagnitude="1" metricUnit="m" metricValue="4.95808" pageId="25" pageNumber="586" unit="in" value="1952.0">1952 in</quantity>
</bibRefCitation>
</taxonomicName>
