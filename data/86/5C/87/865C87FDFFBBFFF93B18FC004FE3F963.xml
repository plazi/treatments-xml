<taxonomicName authorityName="Billings" authorityYear="1865" box="[647,773,1586,1612]" class="Stenolaemata" family="Arthrostylidae" genus="Arthroclema" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Cryptostomida" pageId="25" pageNumber="586" phylum="Bryozoa" rank="genus">
<emphasis box="[647,773,1586,1612]" italics="true" pageId="25" pageNumber="586">Arthroclema</emphasis>
</taxonomicName>
differs from 
<taxonomicName authority="Bassler, 1952" authorityName="Bassler" authorityYear="1952" box="[262,542,1618,1645]" class="Stenolaemata" family="Arthrostylidae" genus="Ulrichostylus" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Cryptostomida" pageId="25" pageNumber="586" phylum="Bryozoa" rank="genus">
