<taxonomicName authority="(McKinney, 1971)" baseAuthorityName="McKinney" baseAuthorityYear="1971" box="[134,426,1300,1326]" class="Stenolaemata" family="Halloporidae" genus="Tarphophragma" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Trepostomatida" pageId="19" pageNumber="580" phylum="Bryozoa" rank="species" species="ovata">
