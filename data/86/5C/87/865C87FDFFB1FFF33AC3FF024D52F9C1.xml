in 
<taxonomicName baseAuthorityName="Ulrich" baseAuthorityYear="1886" class="Stenolaemata" family="Amplexoporidae" genus="Monotrypella" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Trepostomatida" pageId="19" pageNumber="580" phylum="Bryozoa" rank="species" species="multitabulata">
