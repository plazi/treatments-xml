, 
<collectingCountry box="[814,910,1388,1412]" name="Argentina" pageId="29" pageNumber="590">Argentine</collectingCountry>
Precordillera, western 
<collectingCountry box="[1133,1233,1388,1412]" name="Argentina" pageId="29" pageNumber="590">Argentina</collectingCountry>
