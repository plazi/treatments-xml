differs from 
<taxonomicName authority="Nicholson &amp; Etheridge, 1877" authorityName="Nicholson &amp; Etheridge" authorityYear="1877" class="Stenolaemata" family="Monticuliporidae" genus="Prasopora" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Trepostomatida" pageId="9" pageNumber="570" phylum="Bryozoa" rank="genus">
<emphasis box="[1270,1368,1528,1553]" italics="true" pageId="9" pageNumber="570">Prasopora</emphasis>
<bibRefCitation author="NICHOLSON H. A. &amp; ETHERIDGE R. &amp; JR" pageId="9" pageNumber="570" pagination="388 - 392" refId="ref22169" refString="NICHOLSON H. A. &amp; ETHERIDGE R., JR. 1877. - On Prasopora grayae, a new genus and species of Silurian corals. Annals and Magazine of the Natural History 4: 388 - 392. https: // doi. org / 10.1080 / 00222937708682254" type="journal article" year="1877">Nicholson &amp; Etheridge, 1877</bibRefCitation>
</taxonomicName>
