<taxonomicName authority="Ulrich, 1882" authorityName="Ulrich" authorityYear="1882" box="[884,1140,1557,1583]" class="Stenolaemata" family="Leioclemidae" genus="Leioclema" kingdom="Animalia" order="Trepostomatida" pageId="13" pageNumber="574" phylum="Bryozoa" rank="genus">
