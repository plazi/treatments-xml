<emphasis box="[940,1068,1525,1550]" italics="true" pageId="13" pageNumber="574">Heterotrypa</emphasis>
<bibRefCitation author="NICHOLSON H. A." box="[1075,1267,1525,1551]" pageId="13" pageNumber="574" refId="ref22054" refString="NICHOLSON H. A. 1879. - On the Structure and Affinities of the &quot; Tabulate Corals &quot; of the Paleozoic Period, with Critical Descriptions of Illustrative Species. 15 pls, 44 text-figs. William Blackwood and Sons, Edinburgh, 342 p. https: // doi. org / 10.5962 / bhl. title. 9117" type="book" year="1879">Nicholson, 1879</bibRefCitation>
</taxonomicName>
