<taxonomicName authority="Ross, 1963" authorityName="Ross" authorityYear="1963" class="Stenolaemata" family="Trematoporidae" genus="Jordanopora" higherTaxonomySource="CoL,GBIF" kingdom="Animalia" order="Trepostomatida" pageId="19" pageNumber="580" phylum="Bryozoa" rank="species" species="heroensis">
<emphasis box="[1233,1456,1526,1552]" italics="true" pageId="19" pageNumber="580">Jordanopora heroensis</emphasis>
<bibRefCitation author="ROSS J. R. P." box="[813,932,1558,1584]" pageId="19" pageNumber="580" pagination="727 - 739" refId="ref22586" refString="ROSS J. R. P. 1963 a. - Chazyan (Ordovician) leptotrypellid and atactotoechid Bryozoa. Palaeontology 5: 727 - 739." type="journal article" year="1963">
Ross, 
<quantity box="[876,961,1558,1584]" metricMagnitude="1" metricUnit="m" metricValue="4.98602" pageId="19" pageNumber="580" unit="in" value="1963.0">1963 in</quantity>
</bibRefCitation>
</taxonomicName>
its morphology and dimensions.
</paragraph>
