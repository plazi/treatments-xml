</typeStatus>
<collectionCode box="[188,259,1982,1999]" pageId="7" pageNumber="568">SPECIES</collectionCode>
. — 
<taxonomicName authority="Bassler, 1911" authorityName="Bassler" authorityYear="1911" box="[302,631,1977,2001]" class="Stenolaemata" family="Fistuliporidae" genus="Fistulipora" kingdom="Animalia" order="Cystoporida" pageId="7" pageNumber="568" phylum="Bryozoa" rank="species" species="primaeva">
