</taxonomicName>
by subsequent designation (
<bibRefCitation author="BASSLER R. S." box="[259,383,2003,2027]" pageId="7" pageNumber="568" pagination="381 - 385" refId="ref18772" refString="BASSLER R. S. 1952. - Taxonomic notes on genera of fossil and Recent Bryozoa. Journal of the Washington Academy of Sciences 42: 381 - 385. https: // www. jstor. org / stable / 24531385" type="journal article" year="1952">Bassler 1952</bibRefCitation>
