<subSubSection id="FB5A94BD8DDD27A983EB19DC1BE936A2" pageId="null" pageNumber="13" type="description">
<paragraph id="7E6D8AD68B49FBA9ECF63ACE95BE93FC" pageId="null" pageNumber="13">
<emphasis id="A86D760EE2CCCD878FD8785D6673DFD1" italics="true" pageId="null" pageNumber="13">
<normalizedToken id="B6D6CBA0FDA112AF876A7F83D4D899CF" originalValue="Blätter" pageId="null" pageNumber="13">Blaetter</normalizedToken>
<normalizedToken id="F95E94C9CBC4BCCA3588A160A81A3987" originalValue="immergrün" pageId="null" pageNumber="13">immergruen</normalizedToken>
, lederig
</emphasis>
, ungeteilt. 
<emphasis id="2075C8107FBEFEAEBDB7ADC4DFB43DB1" italics="true" pageId="null" pageNumber="13">
<normalizedToken id="3665D12A3F81044A91C6260CC0F22BD4" originalValue="Blüten" pageId="null" pageNumber="13">Blueten</normalizedToken>
in kurzen Trauben oder 
<normalizedToken id="199ACE8FDFCC5E73A3805FAEED411E6E" originalValue="Ähren" pageId="null" pageNumber="13">Aehren</normalizedToken>
</emphasis>
, klein, ⚥. Kelch klein, 
<normalizedToken id="F1AA0E2F34D14FD665AA13DEBD906FE8" originalValue="glockenförmig" pageId="null" pageNumber="13">glockenfoermig</normalizedToken>
, 4 
<normalizedToken id="E4115CE26015DC7605DE481A905DC8E7" originalValue="zähnig" pageId="null" pageNumber="13">zaehnig</normalizedToken>
. Krone weit 
<normalizedToken id="40BFCE6DC8CD7963301571A0115958D0" originalValue="glockenförmig" pageId="null" pageNumber="13">glockenfoermig</normalizedToken>
, 4teilig, nur am Grunde zu einer kurzen 
<normalizedToken id="79F5BE5619247EAF3BD43406C2A84790" originalValue="Röhre" pageId="null" pageNumber="13">Roehre</normalizedToken>
verwachsen. 
<emphasis id="7E05EBC7B03109BDDA60218339227FF6" italics="true" pageId="null" pageNumber="13">
Frucht eine kugelige oder 
<normalizedToken id="74F1BD47758AD26D3C73719F8E31CA33" originalValue="eiförmige" pageId="null" pageNumber="13">eifoermige</normalizedToken>
Steinfrucht.
</emphasis>
</paragraph>
<paragraph id="770AEB08E0BE91C82D3CB957831ECE5E" pageId="null" pageNumber="13">
Die Gattung 
<taxonomicName id="8CF9090B5424FD31CFBE4DEDB2EEFEF0" class="Magnoliopsida" family="Oleaceae" genus="Phillyrea" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="13" phylum="Tracheophyta" rank="genus">
<emphasis id="2CDEAC639FB6053882CC21EEF9279BB1" italics="true" pageId="null" pageNumber="13">Phillyrea</emphasis>
</taxonomicName>
<normalizedToken id="737331489E05FB90EF359A29E512F587" originalValue="umfaßt" pageId="null" pageNumber="13">umfasst</normalizedToken>
etwa 
<emphasis id="8B5479D662667FD56AE90E9FAA5CDC09" italics="true" pageId="null" pageNumber="13">5 Arten mit vorwiegend mediterraner Verbreitung. Chromosomengrundzahl:</emphasis>
n = 23.
</paragraph>
