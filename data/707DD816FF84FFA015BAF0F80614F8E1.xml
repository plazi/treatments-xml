<paragraph id="F86B6900FF84FFA015BAF0F80166FD3C" blockId="10.[151,609,711,772]" box="[151,609,711,737]" pageId="10" pageNumber="11">
<heading id="A323DE6CFF84FFA015BAF0F80166FD3C" bold="true" box="[151,609,711,737]" fontSize="11" level="1" pageId="10" pageNumber="11" reason="1">
<emphasis id="CAA0B512FF84FFA015BAF0F80166FD3C" bold="true" box="[151,609,711,737]" pageId="10" pageNumber="11">
<taxonomicName id="3FD41283FF84FFA015BAF0F80110FD3C" authority="Troubridge" authorityName="Troubridge" authorityYear="2008" box="[151,535,711,737]" class="Insecta" family="Noctuidae" genus="Sympistis" kingdom="Animalia" order="Lepidoptera" pageId="10" pageNumber="11" phylum="Arthropoda" rank="species" species="jocelynae" status="sp. n.">
<emphasis id="CAA0B512FF84FFA015BAF0F80285FD3C" bold="true" box="[151,386,711,737]" italics="true" pageId="10" pageNumber="11">Sympistis jocelynae</emphasis>
Troubridge
</taxonomicName>
<taxonomicNameLabel id="D1930869FF84FFA01732F0F80166FD3C" box="[543,609,711,737]" pageId="10" pageNumber="11" rank="species">sp. n.</taxonomicNameLabel>
