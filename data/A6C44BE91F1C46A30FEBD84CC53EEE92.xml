<subSubSection id="B6FD6F566E94D424DB4EF10044076043" pageId="null" pageNumber="15" type="vernacular_names">
<paragraph id="2E15FCB1C78234985884C010469FADAE" pageId="null" pageNumber="15">Manna-Esche, Blumen-Esche</paragraph>
</subSubSection>
</title>
<subSubSection id="CFF9D42D7D7E00ACCFE924962CB81F06" pageId="null" pageNumber="15" type="description">
<paragraph id="F0C153F960DF5BB095141813A611D543" pageId="null" pageNumber="15">
Bis 10 m hoher Baum. 
<emphasis id="9DC6C66659AB92657D872454EBD579A4" italics="true" pageId="null" pageNumber="15">Knospen grau.</emphasis>
<normalizedToken id="EF5231FB8E9678404A10ADCD028E63EC" originalValue="Blätter" pageId="null" pageNumber="15">Blaetter</normalizedToken>
gefiedert, 
<emphasis id="E7E231C3B70C4F1009C12811AD520DA1" italics="true" pageId="null" pageNumber="15">mit 5</emphasis>
, 7 
<emphasis id="6AB82F36B2FBB63CB0B081EDDE84B08F" italics="true" pageId="null" pageNumber="15">oder 9 gestielten</emphasis>
, ovalen bis lanzettlichen, fein 
<normalizedToken id="9E9861546057D3175C1884EBE3D2A732" originalValue="gezähnten" pageId="null" pageNumber="15">gezaehnten</normalizedToken>
<normalizedToken id="04DC06EBEB96DFF2A4A5DA37E430A5CB" originalValue="Teilblättern" pageId="null" pageNumber="15">Teilblaettern</normalizedToken>
(
<normalizedToken id="A8546C1485A393DDEEE7E52F88012B3A" originalValue="Zähne" pageId="null" pageNumber="15">Zaehne</normalizedToken>
nach vorn gerichtet), oberseits kahl, unterseits nur auf den Mittelnerven der 
<normalizedToken id="0A896D527EEF614BE14AAA1ECCBE98F0" originalValue="Teilblätter" pageId="null" pageNumber="15">Teilblaetter</normalizedToken>
kraus behaart. 
<emphasis id="E16454F944AF5E14060C85E216B63987" italics="true" pageId="null" pageNumber="15">
<normalizedToken id="4A4B21B6A277C379270691818CBF1DCA" originalValue="Blüten" pageId="null" pageNumber="15">Blueten</normalizedToken>
mit den 
<normalizedToken id="D3317F5FF7A9591E20482AF0AAF6205A" originalValue="Blättern" pageId="null" pageNumber="15">Blaettern</normalizedToken>
erscheinend
</emphasis>
, stark duftend. 
<emphasis id="9D3DFD73C57FCA3CBDE0428BC2EA901F" italics="true" pageId="null" pageNumber="15">
Kelch tief 4teilig. 
<normalizedToken id="E7E858D81796D866B849BAFFD0C1FA31" originalValue="Kronblätter" pageId="null" pageNumber="15">Kronblaetter</normalizedToken>
2 oder 4, am Grunde paarweise miteinander verbunden, sehr schmal lanzettlich, 7
</emphasis>
- 
<emphasis id="86D200DACE499BA30A4D5FB3A63E4C00" italics="true" pageId="null" pageNumber="15">
15 mm lang, 
<normalizedToken id="1F9D5963BF4883CAAA73B3E1EDB90ECF" originalValue="weiß" pageId="null" pageNumber="15">weiss</normalizedToken>
.
</emphasis>
Frucht 
<normalizedToken id="908F9EF8F6299B4E292B22EBF06ACDD4" originalValue="dünn" pageId="null" pageNumber="15">duenn</normalizedToken>
gestielt, 
<normalizedToken id="8BD9BB011BEE9FFBD457E8B25C99D08F" originalValue="hängend" pageId="null" pageNumber="15">haengend</normalizedToken>
, flach und 
<normalizedToken id="46B2C94331BAE23AC7F45EE68195332A" originalValue="dünn" pageId="null" pageNumber="15">duenn</normalizedToken>
, 2-4 cm lang und 0,5-0,8 cm breit. - 
<normalizedToken id="16A789B8582D7FF1C2E13A9698840EF8" originalValue="Blüte" pageId="null" pageNumber="15">Bluete</normalizedToken>
: 
<normalizedToken id="FADA7C2252267C0FAE27AB8ABA70D555" originalValue="Später" pageId="null" pageNumber="15">Spaeter</normalizedToken>
<normalizedToken id="5A0BECF0CEDA685384333D1915223797" originalValue="Frühling" pageId="null" pageNumber="15">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="B19ACD6A4C89D2EEACDECE87C9A7F6BF" pageId="null" pageNumber="15">
<emphasis id="8CF3CB39923E6DF2F240F734A09BBE1A" italics="true" pageId="null" pageNumber="15">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E001BDAE545DF2CEE9A0B10A6998BC0E" italics="true" pageId="null" pageNumber="15">46:</emphasis>
Material aus botanischem Garten (Taylor 1945, Wright 1957).
</paragraph>
<paragraph id="CA9C297394F218390B0F31FD6C5904B2" pageId="null" pageNumber="15">
<emphasis id="DE184D7BB6048D4BB962739CCB6EEA01" italics="true" pageId="null" pageNumber="15">Standort.</emphasis>
Kollin, seltener montan. Trockene, meist kalkreiche 
<normalizedToken id="3965E65E0154D0AD2BBB05EE19A95DB4" originalValue="Böden" pageId="null" pageNumber="15">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="3356977B9E5FE71080BD7123AC83211C" originalValue="Laubmischwälder" pageId="null" pageNumber="15">Laubmischwaelder</normalizedToken>
. 
<emphasis id="D61EB3898C82686C432197DB672CFF88" italics="true" pageId="null" pageNumber="15">Helleboro-Ornetum</emphasis>
Antonietti 1968, 
<emphasis id="2201F0733C8017AB4E574203D3189010" italics="true" pageId="null" pageNumber="15">Erisithalo-Ulmetum fraxinetosum orni</emphasis>
Antonietti 1968.
</paragraph>
<paragraph id="E8C86CA6D1F93CB1514736875C1903CF" pageId="null" pageNumber="15">
<emphasis id="168A4E2EEA664500248410686F6D55E7" italics="true" pageId="null" pageNumber="15">
Verbreitung. 
<normalizedToken id="67C42E4604BDC35AC86F49E00E58CAD6" originalValue="Südeuropäisch-westasiatische" pageId="null" pageNumber="15">Suedeuropaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="DFDA764449D6C3272718CEB31E1B0CFB" originalValue="Nordwärts" pageId="null" pageNumber="15">Nordwaerts</normalizedToken>
bis 
<normalizedToken id="CE7DCCF3831D8874A4EBC4D8606F5C4D" originalValue="Pyrenäen" pageId="null" pageNumber="15">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="D592B5CF824641E1226C210888CF37AA" originalValue="Südalpen" pageId="null" pageNumber="15">Suedalpen</normalizedToken>
, Kroatien, Mittelungarn, Dobrudscha; Kleinasien. - Im Gebiet: Am 
<normalizedToken id="2C868DB41A00E5CB50950AEE543F9E3C" originalValue="Alpensüdfuß" pageId="null" pageNumber="15">Alpensuedfuss</normalizedToken>
und im Vintschgau ziemlich 
<normalizedToken id="514222F70CD9708720960B03E25387D3" originalValue="häufig" pageId="null" pageNumber="15">haeufig</normalizedToken>
, sonst gelegentlich angepflanzt und selten verwildert.
</paragraph>
</subSubSection>
