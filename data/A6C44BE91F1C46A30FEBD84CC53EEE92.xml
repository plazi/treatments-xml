<taxonomicName id="74C304021E0F5F40128A7F580ED67214" authority="L." class="Magnoliopsida" family="Oleaceae" genus="Fraxinus" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="15" phylum="Tracheophyta" rank="species" species="ornus">
Fraxinus 
<normalizedToken id="D44DF1272DA1CE5E3BC6CBC3AF0043CF" originalValue="Órnus" pageId="null" pageNumber="15">Ornus</normalizedToken>
<authorityName id="25639B10189B01B473AB86BA2AD3D6C0" pageId="null" pageNumber="15">L.</authorityName>
</taxonomicName>
</paragraph>
