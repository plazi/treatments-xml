<paragraph id="6773B30A10ED4EA07B0F50ED596E15FC" pageId="null" pageNumber="472">Falzblume</paragraph>
</subSubSection>
</title>
<subSubSection id="FF8A564AEC305B7E8AB6D74598EAE0F2" pageId="null" pageNumber="472" type="description">
<paragraph id="6AD272470B39336F2020D772A677F451" pageId="null" pageNumber="472">
1 
<normalizedToken id="9A4EBC3764136DF70DD08B341CA9E5C2" originalValue="jährig" pageId="null" pageNumber="472">jaehrig</normalizedToken>
, mit 
<normalizedToken id="1AC9C501E7465F6DF18966BA55C3C153" originalValue="dünner" pageId="null" pageNumber="472">duenner</normalizedToken>
Pfahlwurzel. Stengel, 
<normalizedToken id="7B6D219E35D8012720ED79C6A5DDBDE3" originalValue="Blätter" pageId="null" pageNumber="472">Blaetter</normalizedToken>
und 
<normalizedToken id="129C638B0F4D39DE7976F56A61655808" originalValue="Hüllblätter" pageId="null" pageNumber="472">Huellblaetter</normalizedToken>
filzig behaart. 
<normalizedToken id="4F0DA9D470B424D2F6584703FEA5A6F7" originalValue="Blätter" pageId="null" pageNumber="472">Blaetter</normalizedToken>
klein, ganzrandig. 
<normalizedToken id="D64445ACC2F39250F60DCF8E1A0DDF45" originalValue="Blütenköpfe" pageId="null" pageNumber="472">Bluetenkoepfe</normalizedToken>
klein, in 
<normalizedToken id="ECD7A7A643C1E096C89E5C848678DF98" originalValue="Knäueln" pageId="null" pageNumber="472">Knaeueln</normalizedToken>
angeordnet. 
<normalizedToken id="08278CFE0A22783E76E82DD4DBAF538F" originalValue="Hüllblätter" pageId="null" pageNumber="472">Huellblaetter</normalizedToken>
wenige, die 
<normalizedToken id="F47F2E89A440ABACB27982A426D4717F" originalValue="äußern" pageId="null" pageNumber="472">aeussern</normalizedToken>
klein, die innern 
<normalizedToken id="ADB6053251F7752A84B95CF4798197CC" originalValue="größer" pageId="null" pageNumber="472">groesser</normalizedToken>
und 
<emphasis id="E3C8922E4C7793A8A3796A5415C416F5" italics="true" pageId="null" pageNumber="472">
die 
<normalizedToken id="280B7B3760C6D24A482EC636DE4545AC" originalValue="Randblüten" pageId="null" pageNumber="472">Randblueten</normalizedToken>
<normalizedToken id="EAF1357F6017DB44065B989B8338947D" originalValue="umhüllend" pageId="null" pageNumber="472">umhuellend</normalizedToken>
. Boden des 
<normalizedToken id="C5746C418E2BD2AA65016A209DF0B6E0" originalValue="Blütenkopfes" pageId="null" pageNumber="472">Bluetenkopfes</normalizedToken>
mit 
<normalizedToken id="04A249F8433F1A2BEE1364AD8E321FCD" originalValue="stielförmig" pageId="null" pageNumber="472">stielfoermig</normalizedToken>
<normalizedToken id="10F4CDBF6C380AE3FE3E9E44759E000E" originalValue="erhöhten" pageId="null" pageNumber="472">erhoehten</normalizedToken>
Ansatzstellen 
<normalizedToken id="16466068711026C6DE8FF9B31EC8AD05" originalValue="für" pageId="null" pageNumber="472">fuer</normalizedToken>
die 
<normalizedToken id="44BAEF2A4EB23F4298BE1F35F6DFD68C" originalValue="Früchte" pageId="null" pageNumber="472">Fruechte</normalizedToken>
</emphasis>
, ohne 
<normalizedToken id="1DD6EC1A5ED15315862B8D2D81F73B2D" originalValue="Spreublätter" pageId="null" pageNumber="472">Spreublaetter</normalizedToken>
und ohne Haare. 
<normalizedToken id="848CB6BB5D5F7187D0D5C79EDB5499DF" originalValue="Blüten" pageId="null" pageNumber="472">Blueten</normalizedToken>
unscheinbar, gelblich, 
<emphasis id="B223195AB8B0C57EFCD83AFEE44D78F5" italics="true" pageId="null" pageNumber="472">
die 
<normalizedToken id="C51EBA091E73071618347D82BDA3F9FD" originalValue="äußern" pageId="null" pageNumber="472">aeussern</normalizedToken>
<normalizedToken id="5A899865850EF6B25DF8381908665AB6" originalValue="fadenförmig" pageId="null" pageNumber="472">fadenfoermig</normalizedToken>
</emphasis>
(
<emphasis id="8569F387A60330BDF101269634BDF355" italics="true" pageId="null" pageNumber="472">
eng 
<normalizedToken id="831C3DB9FB669D86D1F24CD4D63A7AC2" originalValue="röhrenförmig" pageId="null" pageNumber="472">roehrenfoermig</normalizedToken>
</emphasis>
), ♀, 
<emphasis id="BEEF15E4D798FCEF5B1DB4CA8E7B1996" italics="true" pageId="null" pageNumber="472">
fruchtbar, die innern 
<normalizedToken id="124598C71BC291DA5C71C7DEA0485CE9" originalValue="röhrenförmig" pageId="null" pageNumber="472">roehrenfoermig</normalizedToken>
, scheinbar
</emphasis>
⚥, ♀ 
<emphasis id="B1F4BE5966CCBD8D68A99BEEA6876A43" italics="true" pageId="null" pageNumber="472">steril.</emphasis>
Staubbeutel unten mit 
<normalizedToken id="E4D8E21153C66F7E04605AD83B88EE4E" originalValue="verlängerter" pageId="null" pageNumber="472">verlaengerter</normalizedToken>
Spitze. 
<emphasis id="72AA06CE8403AA2F2EB2418096A62001" italics="true" pageId="null" pageNumber="472">
<normalizedToken id="B59BE1A6BE55021F2A969195473BDA7A" originalValue="Früchte" pageId="null" pageNumber="472">Fruechte</normalizedToken>
vom dicht filzig behaarten 
<normalizedToken id="5C5338EA6235E7EF871C379C3D4C3FB0" originalValue="Hüllblatt" pageId="null" pageNumber="472">Huellblatt</normalizedToken>
fest umschlossen und mit diesem abfallend, meist ohne 
<taxonomicName id="3540AF01CABFC3372435D4FB418C8EB6" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="472" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
.
</emphasis>
</paragraph>
<paragraph id="CF5AA30802CA5FBF58B8540ED784D843" pageId="null" pageNumber="472">
Die Gattung 
<taxonomicName id="57D46B4D588DF3016DBE2A87460504A5" class="Magnoliopsida" family="Asteraceae" genus="Micropus" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="472" phylum="Tracheophyta" rank="genus">
<emphasis id="DF55D00DF48D0C3B5A96F48E2B342E63" italics="true" pageId="null" pageNumber="472">Micropus</emphasis>
</taxonomicName>
<normalizedToken id="1CA6571394D9156D0BDC217A92D6AD28" originalValue="umfaßt" pageId="null" pageNumber="472">umfasst</normalizedToken>
<emphasis id="D60AA323F2B2A80587850115FEAA4CCB" italics="true" pageId="null" pageNumber="472">5 Arten</emphasis>
, von denen 
<emphasis id="5599E4442641DC20EEDD9EA831F3147E" italics="true" pageId="null" pageNumber="472">4 im Mittelmeergebiet und 1 in Kalifornien und Oregon</emphasis>
beheimatet sind.
</paragraph>
</subSubSection>
