<subSubSection id="A134A6C23241674697AC5C4A495CB273" pageId="null" pageNumber="145" type="description">
<paragraph id="B7AB288B19883022FAD899845272F2CD" pageId="null" pageNumber="145">
<emphasis id="E0175826AB81ECD4A9CC8E1B066166F5" italics="true" pageId="null" pageNumber="145">
<normalizedToken id="C133FCB0DEA8F195851ED3AE8C7C6D5C" originalValue="Ähnlich" pageId="null" pageNumber="145">Aehnlich</normalizedToken>
<taxonomicName id="5991F4A8F626786363C81A7CC483F8CA" class="Polypodiopsida" family="Ophioglossaceae" genus="Botrychium" kingdom="Plantae" order="Ophioglossales" pageId="null" pageNumber="145" phylum="Tracheophyta" rank="species" species="lunaria">B. Lunaria</taxonomicName>
</emphasis>
(Nr. 1), 
<emphasis id="F67AD068959A4799BBF11DEF2095502C" italics="true" pageId="null" pageNumber="145">
der nicht sporentragende Blatteil jedoch nahe 
<normalizedToken id="4A07CF78BC22BCD2166FB4ED451D714A" originalValue="über" pageId="null" pageNumber="145">ueber</normalizedToken>
dem Rhizom abzweigend
</emphasis>
, im 
<normalizedToken id="035E9A415C80538CB4A50FD04A6FF320" originalValue="Umriß" pageId="null" pageNumber="145">Umriss</normalizedToken>
oval, nur 2-6 cm lang und 1-4 cm breit, 
<emphasis id="FF30E4164DB87B3C7763EBE194D7848A" italics="true" pageId="null" pageNumber="145">
fiederteilig oder durch Vertiefung der basalen Einschnitte 3teilig. Abschnitte im 
<normalizedToken id="01F2FBA3BC7D94BE64FCC2BE393B2C6C" originalValue="Umriß" pageId="null" pageNumber="145">Umriss</normalizedToken>
<normalizedToken id="F072323A1B423B6123B7C209CDB74095" originalValue="halbkreisförmig" pageId="null" pageNumber="145">halbkreisfoermig</normalizedToken>
, mit 
<normalizedToken id="A6B1EC87CBDF91F45D3BA64356BAA104" originalValue="keilförmig" pageId="null" pageNumber="145">keilfoermig</normalizedToken>
<normalizedToken id="E03121A16300288E46BF69BBBA852551" originalValue="verschmälerter" pageId="null" pageNumber="145">verschmaelerter</normalizedToken>
Basis. Sporendurchmesser 47-56 
<normalizedToken id="2021079372E133FB78F616E4C6315250" originalValue="μ" pageId="null" pageNumber="145">μ</normalizedToken>
</emphasis>
. 
<normalizedToken id="2B0BAEB840083C0BDA1BF388587F5E42" originalValue="Übrige" pageId="null" pageNumber="145">Uebrige</normalizedToken>
Merkmale wie bei 
<emphasis id="6EF3579D9FFE1A2E9B91A8A4B8274227" italics="true" pageId="null" pageNumber="145">
<taxonomicName id="AA11613487401E0C33EE00EA746516FE" class="Polypodiopsida" family="Ophioglossaceae" genus="Botrychium" kingdom="Plantae" order="Ophioglossales" pageId="null" pageNumber="145" phylum="Tracheophyta" rank="species" species="lunaria">B. Lunaria</taxonomicName>
.
</emphasis>
- Sporenreife: Sommer.
</paragraph>
<paragraph id="3B8FC79278DA7212CD7656296FF84609" pageId="null" pageNumber="145">
<emphasis id="CCF14D851F736625D84DCC22DFD6236A" italics="true" pageId="null" pageNumber="145">Zytologische Angaben. 2n = 90:</emphasis>
Material aus Nordamerika (Michigan), 2 morphologisch und 
<normalizedToken id="6E1A95B9D4BB1AE74EF90587184162A0" originalValue="ökologisch" pageId="null" pageNumber="145">oekologisch</normalizedToken>
getrennte Sippen haben gleiche Chromosomenzahlen (Wagner 1955).
</paragraph>
<paragraph id="D111A234C1742447C2E2162EFC0874C3" pageId="null" pageNumber="145">
<emphasis id="0DED6B668D9A1E4A75FA13ADC31C4887" italics="true" pageId="null" pageNumber="145">Standort.</emphasis>
Kollin, montan und subalpin. Feuchte, sandige, saure 
<normalizedToken id="3AA1821E4D57DB3D9DBFCBEE96C8145F" originalValue="Böden" pageId="null" pageNumber="145">Boeden</normalizedToken>
. Weiden, 
<normalizedToken id="2D7DFA0874C8C6CF6B2FD777332FCB4F" originalValue="Fluß-" pageId="null" pageNumber="145">Fluss-</normalizedToken>
und Seeufer.
</paragraph>
<paragraph id="F4A02C9D21C355AB9A6F736556DC9D3A" pageId="null" pageNumber="145">
<emphasis id="E7BD3EA0F825DDA61C304D664A936BCD" italics="true" pageId="null" pageNumber="145">
Verbreitung. 
<normalizedToken id="BCD8B48B2251FE94E22CB22534A96D43" originalValue="Europäisch-nordamerikanische" pageId="null" pageNumber="145">Europaeisch-nordamerikanische</normalizedToken>
Pflanze:
</emphasis>
Nordeuropa (
<normalizedToken id="B3F3CC96C4EDD846F7285CF93C8B4EAC" originalValue="südliches" pageId="null" pageNumber="145">suedliches</normalizedToken>
Skandinavien und Finnland) Mitteleuropa (sehr selten), Japan (?); in Nordamerika von Kanada 
<normalizedToken id="C0C8C72C5A02A666D25B7DD4BC400772" originalValue="südwärts" pageId="null" pageNumber="145">suedwaerts</normalizedToken>
bis Kalifornien und Pennsylvanien; 
<normalizedToken id="94FCC0FCF514FF14454368AADF133841" originalValue="Südgrönland" pageId="null" pageNumber="145">Suedgroenland</normalizedToken>
. Verbreitungskarten von 
<normalizedToken id="9084440266C9DD867A27C7E415AC5F99" originalValue="Hultén" pageId="null" pageNumber="145">Hulten</normalizedToken>
(1958) und Meusel (1964). - Im Gebiet von STUDER (
<normalizedToken id="E9093F2B943ED61438D31990B93F66A0" originalValue="unveröffentlicht" pageId="null" pageNumber="145">unveroeffentlicht</normalizedToken>
) neuere Angaben: 
<normalizedToken id="CC92A67A1B284D620E65B56110A20904" originalValue="Graubünden" pageId="null" pageNumber="145">Graubuenden</normalizedToken>
(San Bernardino, 1640-1700 m), Wallis (hinteres 
<normalizedToken id="DECD97C98946509F042097A9AB6F6300" originalValue="Lötschental" pageId="null" pageNumber="145">Loetschental</normalizedToken>
, Ane, ca. 2300 m); 
<normalizedToken id="33A9828902E4B906489FB3EDB07E80D5" originalValue="ältere" pageId="null" pageNumber="145">aeltere</normalizedToken>
Angaben aus Savoyen (auf 
<normalizedToken id="D5227B31315999178DEE9FBD4E5C2352" originalValue="Gletschermoränen" pageId="null" pageNumber="145">Gletschermoraenen</normalizedToken>
im 
<normalizedToken id="F5769522B7C98E35E652FCDBF5960D26" originalValue="nördlichen" pageId="null" pageNumber="145">noerdlichen</normalizedToken>
Montblancgebiet; vgl. auch Le Brun 1957), von Engelberg und Handeck (Berner Oberland), vom Nordschwarzwald (Neubulach).
</paragraph>
</subSubSection>
