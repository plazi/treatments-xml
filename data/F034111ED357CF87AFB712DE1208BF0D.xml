<subSubSection id="57D8546FD631345F8A09784876C4AD90" pageId="null" pageNumber="378" type="description">
<paragraph id="2033195149FF047C4626E85055489235" pageId="null" pageNumber="378">
<normalizedToken id="5403A3E27FCBFF2FC3027B02BA980B20" originalValue="Grundständige" pageId="null" pageNumber="378">Grundstaendige</normalizedToken>
<normalizedToken id="37E64DB58E257C5B5504C6B5CF24850F" originalValue="Blätter" pageId="null" pageNumber="378">Blaetter</normalizedToken>
<normalizedToken id="1988B8DDF1EF53CC41FD96550ADCEFBF" originalValue="herzförmig" pageId="null" pageNumber="378">herzfoermig</normalizedToken>
, 
<emphasis id="1A101058079AAC532093AB392BAFABD1" italics="true" pageId="null" pageNumber="378">
nicht oder nur wenig 
<normalizedToken id="9FDD2D3DC54D190F3D52861C69AFFDEE" originalValue="länger" pageId="null" pageNumber="378">laenger</normalizedToken>
als breit, oft schwarz gefleckt
</emphasis>
, 
<normalizedToken id="86260305A5B533299CBC1DC2DA32A685" originalValue="unregelmäßig" pageId="null" pageNumber="378">unregelmaessig</normalizedToken>
und doppelt 
<normalizedToken id="8C7ADF9E3083B25510DDF80F048D15AE" originalValue="gezähnt" pageId="null" pageNumber="378">gezaehnt</normalizedToken>
; 
<normalizedToken id="1B3B3E1F72BF22E860303084A4465304" originalValue="Zähne" pageId="null" pageNumber="378">Zaehne</normalizedToken>
stumpf oder spitz, nach vorn gerichtet; untere 
<normalizedToken id="2D8D25480674BC5EAAD8957475CC198D" originalValue="Stengelblätter" pageId="null" pageNumber="378">Stengelblaetter</normalizedToken>
wie die 
<normalizedToken id="14524D23FE73879912802B66B41CD7FB" originalValue="Grundblätter" pageId="null" pageNumber="378">Grundblaetter</normalizedToken>
, aber 
<normalizedToken id="D12A917F2822F82D286914709EE93DE4" originalValue="kürzer" pageId="null" pageNumber="378">kuerzer</normalizedToken>
gestielt und kleiner; mittlere 
<normalizedToken id="FBA089089A8B588CCC680F85FA18BEB3" originalValue="Stengelblätter" pageId="null" pageNumber="378">Stengelblaetter</normalizedToken>
an der Basis 
<normalizedToken id="7DE5733A7730ECE9F6EC81FDF8B5FB6E" originalValue="herzförmig" pageId="null" pageNumber="378">herzfoermig</normalizedToken>
oder abgerundet; obere 
<normalizedToken id="F9CB1185165C7D185F4A43D96EBD54A4" originalValue="Stengelblätter" pageId="null" pageNumber="378">Stengelblaetter</normalizedToken>
sitzend, mit abgerundeter Basis. 
<emphasis id="51EA6A3B95E409C90EE435827645FE10" italics="true" pageId="null" pageNumber="378">
<normalizedToken id="A613E640E695CDE8B8E6FC05EDF3CDC5" originalValue="Blüten" pageId="null" pageNumber="378">Blueten</normalizedToken>
<normalizedToken id="0D82B48901D050FB1DB01F1457C5A8F5" originalValue="weiß" pageId="null" pageNumber="378">weiss</normalizedToken>
bis gelblich mit 
<normalizedToken id="7C73E0DAE6023BC6D8392A44A89DE0A5" originalValue="grünlicher" pageId="null" pageNumber="378">gruenlicher</normalizedToken>
Spitze, selten 
<normalizedToken id="8E0D155955FED495B2E361568A1508E0" originalValue="bläulich" pageId="null" pageNumber="378">blaeulich</normalizedToken>
.
</emphasis>
Kelchzipfel etwa 3 mm lang, meist 
<normalizedToken id="5EBA90E41C6B84ED089F0D806983D540" originalValue="länger" pageId="null" pageNumber="378">laenger</normalizedToken>
als die Frucht. - 
<normalizedToken id="3E747649C1BE8E8AC65D680270404DCE" originalValue="Blüte" pageId="null" pageNumber="378">Bluete</normalizedToken>
: 
<normalizedToken id="C5913AB4388821E2581BAC872A913FA4" originalValue="Später" pageId="null" pageNumber="378">Spaeter</normalizedToken>
<normalizedToken id="C20DA41100FD5CA12C13EC0F33C524D1" originalValue="Frühling" pageId="null" pageNumber="378">Fruehling</normalizedToken>
und 
<normalizedToken id="86797A22AA0452C97DDDCF6AB76ADF51" originalValue="früher" pageId="null" pageNumber="378">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="5EEEC78D6338296FCA889682F8B18B3B" pageId="null" pageNumber="378">
<emphasis id="53BE4A26889C7644A5F647FA5A515C5F" italics="true" pageId="null" pageNumber="378">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="ECBC7C2EADFF8B59A90332DF9294F400" italics="true" pageId="null" pageNumber="378">22:</emphasis>
Material aus botanischem Garten (Gadella 1966). 
<emphasis id="5B5A725AB54412D6D7469A70D05DDB67" italics="true" pageId="null" pageNumber="378">2n</emphasis>
= 
<emphasis id="4CEAA4CEE80B62932A6FA23F9742D868" italics="true" pageId="null" pageNumber="378">22+ 0</emphasis>
- 
<emphasis id="A9CF9B65E2723BC6E895572F0212A136" italics="true" pageId="null" pageNumber="378">3 B-Chromosomen:</emphasis>
Material von 31 verschiedenen Orten aus Polen (Ochlewska 1966), aus 
<normalizedToken id="B1695FEE59ED3F3009F3000BEC6E0CFD" originalValue="Österreich" pageId="null" pageNumber="378">Oesterreich</normalizedToken>
(Polatschek 1966a), aus den Niederlanden (Gadella und Kliphuis 1968). 
<emphasis id="35F78B41706D3A8C39EAB6B83D3A3F3C" italics="true" pageId="null" pageNumber="378">2n</emphasis>
= 
<emphasis id="36D5BC4A514B9823EE43A9572D1673C0" italics="true" pageId="null" pageNumber="378">24:</emphasis>
Material aus dem Jura und aus Savoyen (Contandriopoulos 1962).
</paragraph>
<paragraph id="BAC04A6D4ABBA5BCA70E48B4ED2301C4" pageId="null" pageNumber="378">
<emphasis id="970A0EE573B61C58A89917EA83C5E49F" italics="true" pageId="null" pageNumber="378">
<pageBreakToken id="C3E63301339E4E776849C7280E2598EE" pageId="null" pageNumber="378">Standort</pageBreakToken>
</emphasis>
. Kollin und montan, seltener subalpin. 
<normalizedToken id="F9390B65AE10A6C27470C1DED6A56538" originalValue="Mäßig" pageId="null" pageNumber="378">Maessig</normalizedToken>
feuchte, lockere, 
<normalizedToken id="929B2AA32AA3AD64D64F5ED3D984356E" originalValue="nährstoffreiche" pageId="null" pageNumber="378">naehrstoffreiche</normalizedToken>
, schwach saure bis neutrale, humose, lehmige 
<normalizedToken id="2469FFE10D889E73CCEA6EED626B08D2" originalValue="Böden" pageId="null" pageNumber="378">Boeden</normalizedToken>
. 
<normalizedToken id="BF228860DB4BB8254662FDA366A1920F" originalValue="Laubmischwälder" pageId="null" pageNumber="378">Laubmischwaelder</normalizedToken>
, 
<normalizedToken id="996AD50C0F2CCBBAACEBB460211311A7" originalValue="Gebüsche" pageId="null" pageNumber="378">Gebuesche</normalizedToken>
, in 
<normalizedToken id="BC64677240C6485873A778593E81A2F7" originalValue="höheren" pageId="null" pageNumber="378">hoeheren</normalizedToken>
Lagen auch Fettwiesen.
</paragraph>
<paragraph id="594AB3C7330AEB414EEA889C996F2C6B" pageId="null" pageNumber="378">
<emphasis id="A27367DBEBBB7D182AB5984C1EAAE3B5" italics="true" pageId="null" pageNumber="378">
Verbreitung. 
<normalizedToken id="5D2A7118DFEA8830C1771F60F48DDF16" originalValue="Mitteleuropäische" pageId="null" pageNumber="378">Mitteleuropaeische</normalizedToken>
Pflanze:
</emphasis>
West- und 
<normalizedToken id="E5031DF49730C0022C4F6253684D7D0D" originalValue="nordwärts" pageId="null" pageNumber="378">nordwaerts</normalizedToken>
bis 
<normalizedToken id="0499217CE497E656E5717F9875F283FA" originalValue="Pyrenäen" pageId="null" pageNumber="378">Pyrenaeen</normalizedToken>
, 
<normalizedToken id="DADAB1CFF97B56BC7C5827CBF8CFBB8E" originalValue="Südengland" pageId="null" pageNumber="378">Suedengland</normalizedToken>
, 
<normalizedToken id="FF5774AE23C40554AAF383DFB3A16A13" originalValue="Südnorwegen" pageId="null" pageNumber="378">Suednorwegen</normalizedToken>
, Ostsee; 
<normalizedToken id="3B2E6F8EFE51AA0991F732D1689A8FE3" originalValue="ostwärts" pageId="null" pageNumber="378">ostwaerts</normalizedToken>
bis 
<normalizedToken id="7792BAC0377805CBA1F536A02B04F39F" originalValue="Mittelrußland" pageId="null" pageNumber="378">Mittelrussland</normalizedToken>
; 
<normalizedToken id="F5FD4994D6DEAB551DF51E8CED4C11F2" originalValue="südwärts" pageId="null" pageNumber="378">suedwaerts</normalizedToken>
bis Mittelitalien und Serbien. - Im Gebiet 
<normalizedToken id="8195B3A4191D799333A1BADB0F98CBFF" originalValue="zîemlich" pageId="null" pageNumber="378">ziemlich</normalizedToken>
<normalizedToken id="0C538D988CFB01CA5C4B2CAC5C343FBB" originalValue="häufig" pageId="null" pageNumber="378">haeufig</normalizedToken>
(in Savoyen selten).
</paragraph>
</subSubSection>
