<subSubSection id="AE77D94868B3D903FD4FE83E78C3E129" pageId="null" pageNumber="733" type="description">
<paragraph id="5240B0845C9E60DCE86DB72C8759B70F" pageId="null" pageNumber="733">
1 
<normalizedToken id="DD4B31AACC24FBF36F850C1F8DE8125E" originalValue="jährig" pageId="null" pageNumber="733">jaehrig</normalizedToken>
, 3-15 cm hoch. Stengel 
<normalizedToken id="64EA9B5DDCD2CDDF9D2B05DBC84A338E" originalValue="±" pageId="null" pageNumber="733">+/-</normalizedToken>
aufrecht, unverzweigt, im untern Teil mit zahlreichen Haaren. 
<emphasis id="A0928CBBF93EE1A626BC8CD3C8C2D092" italics="true" pageId="null" pageNumber="733">
Blattspreite der mittleren 
<normalizedToken id="64F070A78EE97472A534E677FEB7D786" originalValue="Stengelblätter" pageId="null" pageNumber="733">Stengelblaetter</normalizedToken>
meist bedeutend 
<normalizedToken id="A1FEAAB28B5769764597A5C3199BCCCE" originalValue="kürzer" pageId="null" pageNumber="733">kuerzer</normalizedToken>
als 1 cm, stumpf;
</emphasis>
seitliche Zipfel der 
<pageBreakToken id="4B152E6C8C97FF9F60BA0E0A05CE7683" pageId="null" pageNumber="733">
<normalizedToken id="8B8AA45D46AF861CD96EDB4262A52F36" originalValue="Nebenblätter" pageId="null" pageNumber="733">Nebenblaetter</normalizedToken>
</pageBreakToken>
2-4mal so lang wie die Breite der ungeteilten Mitte. 
<normalizedToken id="CD64C1E494B0B8D7376BC95559E8AA62" originalValue="Blüten" pageId="null" pageNumber="733">Blueten</normalizedToken>
ohne Duft. 
<emphasis id="633203C30964A26134692232B25C2D20" italics="true" pageId="null" pageNumber="733">
<normalizedToken id="19068D2198CC5D02D84C10A9D03B3DE5" originalValue="Kelchblätter" pageId="null" pageNumber="733">Kelchblaetter</normalizedToken>
mit dem 
<normalizedToken id="8C27872820FCD0D15059744A17B6966F" originalValue="Anhängsel" pageId="null" pageNumber="733">Anhaengsel</normalizedToken>
3-6 mm lang.
</emphasis>
Obere 2 
<normalizedToken id="EC07FFAE2DF1991964C878D8CECFB317" originalValue="Kronblätter" pageId="null" pageNumber="733">Kronblaetter</normalizedToken>
<normalizedToken id="B270EF76517D8F70CF3D41FD2D32B337" originalValue="weiß" pageId="null" pageNumber="733">weiss</normalizedToken>
, die untern gelblich; unterstes Kronblatt 
<normalizedToken id="F41AC304CD5E173ABBED9255C1DA5E68" originalValue="¾-1¼" pageId="null" pageNumber="733">3/4-11/4</normalizedToken>
mal so lang wie die 
<normalizedToken id="26027B0A1B21287C6E7F730AB7B10AA0" originalValue="Kelchblätter" pageId="null" pageNumber="733">Kelchblaetter</normalizedToken>
, 
<emphasis id="97443BEB1264454A5AEA8777CB63CF9B" italics="true" pageId="null" pageNumber="733">mit dem Sporn 6-10 mm lang;</emphasis>
Sporn 1- 
<normalizedToken id="6A49EDE40B95F92601E7E6B0F627EC0B" originalValue="1½" pageId="null" pageNumber="733">11/2</normalizedToken>
so lang wie die 
<normalizedToken id="8B8661BF62503E1687B40AD5EA39816B" originalValue="Kelchblattanhängsel" pageId="null" pageNumber="733">Kelchblattanhaengsel</normalizedToken>
. Narbe ohne nach vorn 
<normalizedToken id="FF2B483F27D7275A4B3BA4817F23D385" originalValue="verlängerte" pageId="null" pageNumber="733">verlaengerte</normalizedToken>
Unterlippe. - 
<normalizedToken id="E2732C94AB737DF6BAE4E6D6154808FC" originalValue="Blüte" pageId="null" pageNumber="733">Bluete</normalizedToken>
: 
<normalizedToken id="A8788C89BB9C8F82439A2EDEC9240272" originalValue="Frühling" pageId="null" pageNumber="733">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="6DBF1B4328354BF77DCFBF57083B3E0E" pageId="null" pageNumber="733">
<emphasis id="B8D635BD1B52F359AB89A814BAC6E587" italics="true" pageId="null" pageNumber="733">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="A1C19258533C008C31C5D682BE6E14F2" italics="true" pageId="null" pageNumber="733">14:</emphasis>
Material aus dem Kaukasus (Clausen 1931). 
<emphasis id="25143F2925B5B2B0F6B0BB1DDFC520FB" italics="true" pageId="null" pageNumber="733">2n</emphasis>
= 
<emphasis id="5AE514E579AE92BC7590E5BAD93D2344" italics="true" pageId="null" pageNumber="733">16:</emphasis>
Material aus botanischem Garten (Clausen 1931), aus Mazedonien (Schmidt 1964). 
<emphasis id="6503DE8F91F5974DE853790A1FD15C0C" italics="true" pageId="null" pageNumber="733">2n</emphasis>
= 
<emphasis id="2B1B983C988214DA1E225BB96EA3086D" italics="true" pageId="null" pageNumber="733">36:</emphasis>
Material aus dem Kaukasus (Clausen 1931). 
<emphasis id="66B351AF57737CBA75759C08143824BA" italics="true" pageId="null" pageNumber="733">2n</emphasis>
= 
<emphasis id="142D738671E309BBF77590CAFD2932E1" italics="true" pageId="null" pageNumber="733">48:</emphasis>
Material aus Jersey und England (als 
<emphasis id="192C6038BC11DD24C1B9E114595F84CD" italics="true" pageId="null" pageNumber="733">V. nana</emphasis>
[DC.] 
<normalizedToken id="D417AC4207ACBB77C2A3C2278233BB2A" originalValue="Corbière" pageId="null" pageNumber="733">Corbiere</normalizedToken>
bezeichnet) (Clausen 1931, Fothergill 1944, Pettet 1964).
</paragraph>
<paragraph id="53997313D6148C3B4BEF69457916211C" pageId="null" pageNumber="733">
<emphasis id="284AA0ADE7F7FCAB2631E582EF934DB0" italics="true" pageId="null" pageNumber="733">Standort.</emphasis>
Kollin und montan. Trockene, 
<normalizedToken id="1DEA621A8E9E29149F5B53CB4ABEFC20" originalValue="nährstoffreiche" pageId="null" pageNumber="733">naehrstoffreiche</normalizedToken>
, meist kalkarme, lockere 
<normalizedToken id="ACE15104F8BDFD3A858AA5AA7D7F5C46" originalValue="Böden" pageId="null" pageNumber="733">Boeden</normalizedToken>
in warmen Lagen. Getreidefelder, Weinberge, Trockenrasen.
</paragraph>
<paragraph id="9FE1593471B810111EAA0183E63D34BB" pageId="null" pageNumber="733">
<emphasis id="3CD7C8B2AF8C1B9DF4B7195495D01082" italics="true" pageId="null" pageNumber="733">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="3BA175CFD8F2D5CFBDA4B33586D05A53" originalValue="Nordwärts" pageId="null" pageNumber="733">Nordwaerts</normalizedToken>
bis England, Alpen, 
<normalizedToken id="F820685CE251DBAABD3E0513559AB7CD" originalValue="Mähren" pageId="null" pageNumber="733">Maehren</normalizedToken>
, Karpaten, Ostukraine; 
<normalizedToken id="98A3FDC33D9B940FBE84737CFAA92F2A" originalValue="ostwärts" pageId="null" pageNumber="733">ostwaerts</normalizedToken>
bis Transkaukasien; 
<normalizedToken id="54C411D99E366BEB2944B965E215A243" originalValue="südwärts" pageId="null" pageNumber="733">suedwaerts</normalizedToken>
bis Algerien. - Im Gebiet: Savoyen (
<normalizedToken id="A42B5095BF8091B3C8137D447C62F1F9" originalValue="Chambéry" pageId="null" pageNumber="733">Chambery</normalizedToken>
, untere Tarentaise), mittleres Aostatal, Wallis (
<normalizedToken id="DFE47703B193626F89D5DDEC0DDFAD4F" originalValue="Dorénaz" pageId="null" pageNumber="733">Dorenaz</normalizedToken>
bis Visp), Veltlin, Puschlav; selten.
</paragraph>
<paragraph id="CC25F4202D520EAEE96F8FFA134D87D0" pageId="null" pageNumber="733">
<emphasis id="93BB0C77D5F69A29AD6ABACF0B8DF30B" italics="true" pageId="null" pageNumber="733">
Bemerkungen. 
<taxonomicName id="F9825DA71B8E3D026086E259D7871F3C" class="Insecta" family="Hesperiidae" genus="Viola" kingdom="Animalia" order="Lepidoptera" pageId="null" pageNumber="733" phylum="Arthropoda" rank="species" species="kitaibeliana">V. Kitaibeliana</taxonomicName>
</emphasis>
ist sehr vielgestaltig und gliedert sich in mehrere geographische Sippen und in 4 Chromosomensippen, 
<normalizedToken id="E78E6133A73959C83B9ED1342A8F576E" originalValue="über" pageId="null" pageNumber="733">ueber</normalizedToken>
deren Verbreitung nichts Genaues bekannt ist. Die Pflanzen aus dem Puschlav und von Bormio sind auch als 
<taxonomicName id="0EFF583ED704AFC03847A4D8B6F025B1" class="Insecta" family="Hesperiidae" genus="Viola" kingdom="Animalia" order="Lepidoptera" pageId="null" pageNumber="733" phylum="Arthropoda" rank="species" species="tricolor">
<emphasis id="FE90DC16D4B52D1BAB17D3E7DB71EC2E" italics="true" pageId="null" pageNumber="733">V. tricolor</emphasis>
</taxonomicName>
ssp. 
<emphasis id="F16729A63FF0C90C138444C797EFA832" italics="true" pageId="null" pageNumber="733">Brockmanniana</emphasis>
W. Becker bezeichnet worden.
</paragraph>
</subSubSection>
