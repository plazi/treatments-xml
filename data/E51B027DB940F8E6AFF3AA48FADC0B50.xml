<paragraph id="A8D0A212C6C46606F6F591B7C1EF1DE1" pageId="null" pageNumber="60">
<taxonomicName id="45951651A7005B08ECAFDD12F6EE6896" authority="L." class="Magnoliopsida" family="Ranunculaceae" genus="Clematis" kingdom="Plantae" order="Ranunculales" pageId="null" pageNumber="60" phylum="Tracheophyta" rank="species" species="viticella">
