<subSubSection id="59C2C70BBDB78DB14F4453F362B91CE3" pageId="null" pageNumber="387" type="description">
<paragraph id="1C58439085417E74FD8F6BD605778219" pageId="null" pageNumber="387">
1 
<normalizedToken id="2D65FA77ACC0B9F4BB4EC62860A33BA3" originalValue="jährig" pageId="null" pageNumber="387">jaehrig</normalizedToken>
, selten ausdauernd, niedrig, bogig aufsteigend. 
<normalizedToken id="28544B7151E0A3BD21FC1D14E7634F09" originalValue="Blütenstand" pageId="null" pageNumber="387">Bluetenstand</normalizedToken>
eine 
<normalizedToken id="7AA5351704673A025A9F92697D476FDC" originalValue="dünne" pageId="null" pageNumber="387">duenne</normalizedToken>
<normalizedToken id="F9EFAB344C8F91E957421A5DAADD7778" originalValue="Ähre" pageId="null" pageNumber="387">Aehre</normalizedToken>
, 
<emphasis id="E0975ACD2DA7A959DC498A2EB3FE0333" italics="true" pageId="null" pageNumber="387">die vor dem Spreizen der Spelzen nicht dicker ist als der Stengel</emphasis>
(nur noch bei 
<taxonomicName id="4952E1C1321CCC178A6A8CB076A25FB8" class="Liliopsida" family="Poaceae" genus="Psilurus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="387" phylum="Tracheophyta" rank="genus">
<emphasis id="5CFC9A2E3B7E0E04A9613CFF3A5E30A8" italics="true" pageId="null" pageNumber="387">Psilurus</emphasis>
</taxonomicName>
so!). 
<emphasis id="A9513BF7662DE8CFAA8F2DDDC1DA53C8" italics="true" pageId="null" pageNumber="387">
<normalizedToken id="8281C108CDA6DF713A2C327E00E9575F" originalValue="Ährchen" pageId="null" pageNumber="387">Aehrchen</normalizedToken>
1 
<normalizedToken id="E4CB2B4AE3AF26383CC153C0D30A7B8B" originalValue="blütig" pageId="null" pageNumber="387">bluetig</normalizedToken>
, in 
<normalizedToken id="0679055159E4B24B45FAFB16EF849E9E" originalValue="Höhlungen" pageId="null" pageNumber="387">Hoehlungen</normalizedToken>
der Hauptachse eingesenkt. Bei den 
<normalizedToken id="ADFCB9425248BFD7ED1D82A42159A4D8" originalValue="seitenständigen" pageId="null" pageNumber="387">seitenstaendigen</normalizedToken>
<normalizedToken id="6B032379A8EED25DE2B2084F7ACBE416" originalValue="Ährchen" pageId="null" pageNumber="387">Aehrchen</normalizedToken>
nur 1 
<normalizedToken id="04BD18E0ADE66ED1D21697C5D52DDC3C" originalValue="Hüllspelze" pageId="null" pageNumber="387">Huellspelze</normalizedToken>
</emphasis>
(
<emphasis id="CAAFF31B93E45374E91C7DBE6F360D74" italics="true" pageId="null" pageNumber="387">
die 
<normalizedToken id="F8C496DF2D67BDAE56F1DCF6E5190D92" originalValue="äußere" pageId="null" pageNumber="387">aeussere</normalizedToken>
, obere
</emphasis>
) 
<emphasis id="0A8ED31C4F56624432D66BA40F0F162E" italics="true" pageId="null" pageNumber="387">vorhanden;</emphasis>
<normalizedToken id="ACCD69E5554618A9027C96718C1E254C" originalValue="endständiges" pageId="null" pageNumber="387">endstaendiges</normalizedToken>
<normalizedToken id="F7BC8E24D0EBDE598703242DE0427298" originalValue="Ährchen" pageId="null" pageNumber="387">Aehrchen</normalizedToken>
mit 2 
<normalizedToken id="BFBC2390636CC3748EF2DBC716486B93" originalValue="Hüllspelzen" pageId="null" pageNumber="387">Huellspelzen</normalizedToken>
(wie bei 
<taxonomicName id="1557987E1C9086004AA79C4DC6FEA13D" class="Liliopsida" family="Poaceae" genus="Lolium" kingdom="Plantae" order="Poales" pageId="null" pageNumber="387" phylum="Tracheophyta" rank="genus">
<emphasis id="80B4C36A81091D910813CCEE408F1217" italics="true" pageId="null" pageNumber="387">Lolium</emphasis>
</taxonomicName>
und 
<taxonomicName id="1FF4C86386423D4149C1094A4A24037C" class="Liliopsida" family="Poaceae" genus="Psilurus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="387" phylum="Tracheophyta" rank="genus">
<emphasis id="931DACBC6787DE27E4787482A9202DB9" italics="true" pageId="null" pageNumber="387">Psilurus</emphasis>
</taxonomicName>
). 
<normalizedToken id="8B7CE99B356738D12E0C2BE51E995667" originalValue="Hüllspelze" pageId="null" pageNumber="387">Huellspelze</normalizedToken>
die 
<normalizedToken id="E7A6004F659430574F0EE81B0CE894E3" originalValue="Höhlung" pageId="null" pageNumber="387">Hoehlung</normalizedToken>
der Hauptachse mit dem 
<normalizedToken id="8089CD9076C316137883FA2A565B64EA" originalValue="Ährchen" pageId="null" pageNumber="387">Aehrchen</normalizedToken>
zudeckend oder abstehend, 
<normalizedToken id="2F311B07F135D91E15D477CC4F7E5BB7" originalValue="zäh" pageId="null" pageNumber="387">zaeh</normalizedToken>
, mehrnervig. Deckspelze mit dem 
<taxonomicName id="1E2EB8BEA9F52911128E98DCD076CC31" class="Liliopsida" family="Poaceae" genus="Ruecken" higherTaxonomySource="GBIF" kingdom="Plantae" order="Poales" pageId="null" pageNumber="387" phylum="Tracheophyta" rank="species" species="gegen">
<normalizedToken id="2CBE3A6833F8CFB3F2BEFDCF8A61E6F5" originalValue="Rücken" pageId="null" pageNumber="387">Ruecken</normalizedToken>
gegen
</taxonomicName>
die Hauptachse gewendet, 
<normalizedToken id="05374E88D7988987CBE4D593C6C7EB56" originalValue="häutig" pageId="null" pageNumber="387">haeutig</normalizedToken>
, undeutlich 3nervig, wenig 
<normalizedToken id="8B3F87FB3E35F17223D89F42A07FCEA8" originalValue="kürzer" pageId="null" pageNumber="387">kuerzer</normalizedToken>
oder so lang wie die 
<normalizedToken id="71DD5C6C3CE3A7E55A25927196965753" originalValue="Hüllspelze" pageId="null" pageNumber="387">Huellspelze</normalizedToken>
, 
<emphasis id="1C6A0C9DCE64BA3F879A8F1D131F099F" italics="true" pageId="null" pageNumber="387">ohne Granne.</emphasis>
Vorspelze 
<normalizedToken id="68ED25AA59F3735CAF2BD48021016C31" originalValue="häutig" pageId="null" pageNumber="387">haeutig</normalizedToken>
, 
<normalizedToken id="A5744CA8D9872A78B266A43C15151A9D" originalValue="ungefähr" pageId="null" pageNumber="387">ungefaehr</normalizedToken>
so lang wie die Deckspelze.
</paragraph>
<paragraph id="BD62103C4F9B59EEBB0165B8603FD489" pageId="null" pageNumber="387">
Die Gattung 
<taxonomicName id="9ECF8E0D41A64365B24DD396194C3857" class="Liliopsida" family="Poaceae" genus="Lepturus" kingdom="Plantae" order="Poales" pageId="null" pageNumber="387" phylum="Tracheophyta" rank="genus">
<emphasis id="F377D43F99CAAB82EEA03BA00EB52039" italics="true" pageId="null" pageNumber="387">Lepturus</emphasis>
</taxonomicName>
<normalizedToken id="8BCC09456764C32E75F4DF9259A6A932" originalValue="umfaßt" pageId="null" pageNumber="387">umfasst</normalizedToken>
etwa 
<emphasis id="46278EBD738A28FB1451139C7CDBC369" italics="true" pageId="null" pageNumber="387">15 Arten, die im Mediterrangebiet verbreitet sind.</emphasis>
</paragraph>
</subSubSection>
