<subSubSection id="D8052174966056FD0BC8345CF9D414D3" pageId="null" pageNumber="491" type="description">
<paragraph id="19D9A30043A840AC88D6C7C96629F14A" pageId="null" pageNumber="491">
Ausdauernde 
<normalizedToken id="D46B2ACC6A372C9403D43B638E96803C" originalValue="Kräuter" pageId="null" pageNumber="491">Kraeuter</normalizedToken>
mit 
<emphasis id="713F6CD1ABADACDACC7F7972AFDADDD7" italics="true" pageId="null" pageNumber="491">
<normalizedToken id="8D80923BB7ADBF6F026DF500C0EFADFF" originalValue="grasähnlichen" pageId="null" pageNumber="491">grasaehnlichen</normalizedToken>
, steifen, nicht geteilten 
<normalizedToken id="CDB10D38F509E314D81F0753CFDA1D87" originalValue="Blättern" pageId="null" pageNumber="491">Blaettern</normalizedToken>
.
</emphasis>
<normalizedToken id="7EE9E7DD18FDBE459AD9749E700FAC26" originalValue="Blütenstand" pageId="null" pageNumber="491">Bluetenstand</normalizedToken>
(Kolben) scheinbar 
<normalizedToken id="19D2E01095CBC1CC6BFC66043D3ED1FC" originalValue="seitenständig" pageId="null" pageNumber="491">seitenstaendig</normalizedToken>
; 
<emphasis id="56C53C8BF721F4E1A7EF251C36A05BBE" italics="true" pageId="null" pageNumber="491">Hochblatt</emphasis>
(
<taxonomicName id="45B5E967D80D2510ADEA6B84602FE8D0" class="Bivalvia" family="Iridinidae" genus="Spatha" higherTaxonomySource="GBIF" kingdom="Animalia" order="Unionida" pageId="null" pageNumber="491" phylum="Mollusca" rank="genus">
<emphasis id="C7D514C61B7108581B1E273CA84B4EF2" italics="true" pageId="null" pageNumber="491">Spatha</emphasis>
</taxonomicName>
) 
<emphasis id="DC1B3681753B7C2A93102AD489BAC738" italics="true" pageId="null" pageNumber="491">
blattartig, die Fortsetzung des Stengels bildend, den Kolben nicht 
<normalizedToken id="6B1228051FD0F04BDE2B5EAA4314B077" originalValue="umhüllend" pageId="null" pageNumber="491">umhuellend</normalizedToken>
.
</emphasis>
Ganze Kolbenachse mit 
<normalizedToken id="A1A2B3B0CE6D38BB7ED9AEB8C5F5636A" originalValue="Blüten" pageId="null" pageNumber="491">Blueten</normalizedToken>
besetzt. 
<emphasis id="75B6CD648A717620DCA21EB6B1900D2B" italics="true" pageId="null" pageNumber="491">
Alle 
<normalizedToken id="A2ED781D2ED2805CCC252499C57EC4C7" originalValue="Blüten" pageId="null" pageNumber="491">Blueten</normalizedToken>
zwitterig. 
<normalizedToken id="48BF36BEA22E434989F7A7A43AE5190A" originalValue="Perigonblätter" pageId="null" pageNumber="491">Perigonblaetter</normalizedToken>
6
</emphasis>
, frei, 
<normalizedToken id="56BEC86BC536C9C635A2C8925B4723CD" originalValue="häutig" pageId="null" pageNumber="491">haeutig</normalizedToken>
. Fruchtknoten 2-3 
<normalizedToken id="1EE0DB1D4874478C7963E5A87DA4C85B" originalValue="fächerig" pageId="null" pageNumber="491">faecherig</normalizedToken>
, mehrsamig, Narbe sitzend. Frucht eine 
<normalizedToken id="B8FD514341954E79526023974BB722C5" originalValue="rötliche" pageId="null" pageNumber="491">roetliche</normalizedToken>
Beere. 
<normalizedToken id="5DE7B1A165C4804BDC6B2287D2775625" originalValue="Staubblätter" pageId="null" pageNumber="491">Staubblaetter</normalizedToken>
6.
</paragraph>
<paragraph id="83C45AC543C579EC9B976CC56A27D83D" pageId="null" pageNumber="491">
Die Gattung 
<taxonomicName id="509E1DB9B5C769D8FD269AD3F3A010E6" class="Liliopsida" family="Acoraceae" genus="Acorus" kingdom="Plantae" order="Acorales" pageId="null" pageNumber="491" phylum="Tracheophyta" rank="genus">
<emphasis id="EB4AF5D70836BF3BB0A31EDB41A5A440" italics="true" pageId="null" pageNumber="491">Acorus</emphasis>
</taxonomicName>
<normalizedToken id="4E13ADCFFFF3A3C5092C27D6C6520693" originalValue="umfaßt" pageId="null" pageNumber="491">umfasst</normalizedToken>
<emphasis id="81D36461FFC07E61CE3112CEC6190956" italics="true" pageId="null" pageNumber="491">
2 Arten mit eurasiatisch-nordamerikanischer Verbreitung. 
<taxonomicName id="93610D4B09C8913FC2426F1B62D2E8D4" authority="Soland." authorityName="Soland." class="Liliopsida" family="Potamogetonaceae" genus="Potamogeton" kingdom="Plantae" order="Alismatales" pageId="null" pageNumber="491" phylum="Tracheophyta" rank="species" species="gramineus">A. gramineus Soland.</taxonomicName>
</emphasis>
ist auf 
<normalizedToken id="28883D653F8CE1EDADA1B086CAB70249" originalValue="Südostasien" pageId="null" pageNumber="491">Suedostasien</normalizedToken>
und das 
<normalizedToken id="54E2CB03CFA2FE65E9B5489CB87BC28E" originalValue="nördliche" pageId="null" pageNumber="491">noerdliche</normalizedToken>
China 
<normalizedToken id="324E0DFFF60EDE45419B06BD3AC08DA4" originalValue="beschränkt" pageId="null" pageNumber="491">beschraenkt</normalizedToken>
. 
<emphasis id="CBE2D50ED11C13AC7B694C926A8D57A7" italics="true" pageId="null" pageNumber="491">Monographische Bearbeitung</emphasis>
von Engler (1905).
</paragraph>
</subSubSection>
