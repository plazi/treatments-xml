<subSubSection id="89665C42487AE674EDC16E24A62AF473" pageId="null" pageNumber="702" type="description">
<paragraph id="28B1793F864379C2624FFDF1A9129483" pageId="null" pageNumber="702">
Unterscheidet sich von der Gattung 
<taxonomicName id="2E8AF0113E8DD63CC5EA09043CBAB6C6" class="Aves" family="Sulidae" genus="Morus" kingdom="Animalia" order="Suliformes" pageId="null" pageNumber="702" phylum="Chordata" rank="genus">
<emphasis id="B9D52A652484763C64C59F238DD22D6C" italics="true" pageId="null" pageNumber="702">Morus</emphasis>
</taxonomicName>
(S. 701) durch folgende Merkmale: ♀ 
<normalizedToken id="1F48BB25D89CD913394BD4A7C6988729" originalValue="Blütenstände" pageId="null" pageNumber="702">Bluetenstaende</normalizedToken>
kugelig; 
<emphasis id="46D100A80596498D5783EB7AE6490816" italics="true" pageId="null" pageNumber="702">
Fruchtknoten mit auffallend langen, 
<normalizedToken id="C448C9A2842ED886E511CA9579D0C61F" originalValue="fadenförmigen" pageId="null" pageNumber="702">fadenfoermigen</normalizedToken>
Narben;
</emphasis>
<normalizedToken id="F5E5E7E02EF65094E4E4FF40BCD7CB06" originalValue="Früchte" pageId="null" pageNumber="702">Fruechte</normalizedToken>
auf fleischigem Stiel, der auf ebenfalls fleischigem Fruchtboden steht.
</paragraph>
<paragraph id="960F1E48050ED3E234CDE991B38A8E5F" pageId="null" pageNumber="702">
Die Gattung 
<taxonomicName id="798A61AE97BD09BCDA9EA3F1BEB151FA" class="Magnoliopsida" family="Moraceae" genus="Broussonetia" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="702" phylum="Tracheophyta" rank="genus">
<emphasis id="A613F667841F3D842588ABAB04F1EBB1" italics="true" pageId="null" pageNumber="702">Broussonetia</emphasis>
</taxonomicName>
<normalizedToken id="88E48EBFE76594EA37D14EBCCD564F88" originalValue="umfaßt" pageId="null" pageNumber="702">umfasst</normalizedToken>
<emphasis id="D7C630B251578FB4441869779077BD8E" italics="true" pageId="null" pageNumber="702">7 Arten, die in Ostasien vorkommen.</emphasis>
In 
<taxonomicName id="929D537BB629577728D10CAE16DACEFF" class="Insecta" family="Cerambycidae" genus="Europa" kingdom="Animalia" order="Coleoptera" pageId="null" pageNumber="702" phylum="Arthropoda" rank="genus">Europa</taxonomicName>
<taxonomicName id="AE9257FF45BE01F81B9D3B6D7464BE80" authority="in Gaerten" authorityName="in Gaerten" class="Magnoliopsida" family="Moraceae" genus="Broussonetia" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="702" phylum="Tracheophyta" rank="species" species="papyrifera">
<emphasis id="2F47390BDBF2CD2AC5A50D8311FE2F89" italics="true" pageId="null" pageNumber="702">B. papyrifera</emphasis>
in 
<normalizedToken id="D5CA12E7F28B87F489382A643FBD6948" originalValue="Gärten" pageId="null" pageNumber="702">Gaerten</normalizedToken>
</taxonomicName>
kultiviert und oft verwildert.
</paragraph>
