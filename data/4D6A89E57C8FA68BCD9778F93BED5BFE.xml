<subSubSection id="F3AF229A16AA2B7285389816EC6D5BBC" pageId="null" pageNumber="590" type="vernacular_names">
<paragraph id="B1CB6CC9F9B2B533A0272B0CC217D92C" pageId="null" pageNumber="590">Doldiges Habichtskraut</paragraph>
</subSubSection>
</title>
<subSubSection id="E1B7E6D3B9A9E50F5504729042D1C81C" pageId="null" pageNumber="590" type="description">
<paragraph id="D68EF0D32E24CB85B9AF57D49EC300E1" pageId="null" pageNumber="590">
<emphasis id="C7781178AF90C0398D8C5284BA0E839C" italics="true" pageId="null" pageNumber="590">20</emphasis>
- 
<emphasis id="2668590ECCB236B9D64D2B1864E8758C" italics="true" pageId="null" pageNumber="590">120 cm hoch;</emphasis>
ohne 
<normalizedToken id="0F89FC72667271E4D5484D6B27180CEB" originalValue="Ausläufer" pageId="null" pageNumber="590">Auslaeufer</normalizedToken>
. 
<emphasis id="60D9743A287BA3E4315757D44309A66E" italics="true" pageId="null" pageNumber="590">Stengel mit zahlreichen</emphasis>
(
<emphasis id="CC8A0E4EEA6914EEE89919543DAECFBD" italics="true" pageId="null" pageNumber="590">vom Grund bis zur untersten Abzweigung mindestens 10</emphasis>
) 
<emphasis id="241E8AAC82733F33FC973F8CC9E56A73" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="2D670E35F7DE6ABDD2918B7C6F2F2B6F" originalValue="Stengelblättern" pageId="null" pageNumber="590">Stengelblaettern</normalizedToken>
</emphasis>
, gerade, im obersten Drittel verzweigt, meist 6-30 
<normalizedToken id="8DCA7098D0993826F10D825FA4D3A29B" originalValue="köpfig" pageId="null" pageNumber="590">koepfig</normalizedToken>
, ohne oder mit einfachen Haaren und 
<normalizedToken id="BB86ACCF6AE0B5591AE2360D63C3A769" originalValue="Drüsenhaaren" pageId="null" pageNumber="590">Druesenhaaren</normalizedToken>
, unter den 
<normalizedToken id="6FCC05C5F0B60BD3C756EEB962F27EA0" originalValue="Blütenköpfen" pageId="null" pageNumber="590">Bluetenkoepfen</normalizedToken>
mit Sternhaaren. 
<emphasis id="C7ED4305789594109E0C36054AD24E4C" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="1EF243A253B61E24ECD801A92E347CE0" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
zur 
<normalizedToken id="AC5B07A65FB88B9A04BB823C7FD568DF" originalValue="Blütezeit" pageId="null" pageNumber="590">Bluetezeit</normalizedToken>
alle 
<normalizedToken id="1FDC3ABD6E956B250A9668D78D2F7E95" originalValue="stengelständig" pageId="null" pageNumber="590">stengelstaendig</normalizedToken>
, aber bisweilen die untersten rosettenartig 
<normalizedToken id="C5563CF37D3122C30F5A4C92407711C3" originalValue="gehäuft" pageId="null" pageNumber="590">gehaeuft</normalizedToken>
</emphasis>
, lanzettlich, die untern 
<normalizedToken id="3763A0A47DDF594B32BF37288CCE893F" originalValue="allmählich" pageId="null" pageNumber="590">allmaehlich</normalizedToken>
in einen Stiel 
<normalizedToken id="4A2D1710F1BFBC982AD6463C71105AE7" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
, die mittleren und obern mit 
<normalizedToken id="A373CF2168C2F5C4C9EDBCFDEED20E68" originalValue="verschmälertem" pageId="null" pageNumber="590">verschmaelertem</normalizedToken>
bis 
<normalizedToken id="67EA5C5445B6991B039ED83BAC6BFDC6" originalValue="herzförmigem" pageId="null" pageNumber="590">herzfoermigem</normalizedToken>
Grunde, sitzend, oft den Stengel teilweise umfassend, ganzrandig oder 
<normalizedToken id="815D55E2D0B723CC811735193A24D299" originalValue="gezähnt" pageId="null" pageNumber="590">gezaehnt</normalizedToken>
, spitz, behaart oder kahl, ohne 
<normalizedToken id="44400083B7CFA5750BCDA0F41BE6CF64" originalValue="Drüsenhaare" pageId="null" pageNumber="590">Druesenhaare</normalizedToken>
(nur gelegentlich unterseits mit 0,1 mm langen 
<normalizedToken id="A6977F829ABD8806F540B72CCA01CC9A" originalValue="Drüsen" pageId="null" pageNumber="590">Druesen</normalizedToken>
). 
<normalizedToken id="CD643BE8241004B2298BC7E9D4E8710E" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
<normalizedToken id="70F76AF77F2A38D3C9CA210138F695FC" originalValue="±" pageId="null" pageNumber="590">+/-</normalizedToken>
stumpf, meist ohne oder nur mit wenigen, einfachen Haaren, mit fast keinen bis zahlreichen Sternhaaren und mit oder ohne 
<normalizedToken id="7BE1DF50AFC479FE02A8F89DB8A3F6E5" originalValue="Drüsenhaare" pageId="null" pageNumber="590">Druesenhaare</normalizedToken>
.
</paragraph>
<paragraph id="535A9A5F6D0E7CB55290E74DC4AF45E0" pageId="null" pageNumber="590">
Die Artengruppe des 
<taxonomicName id="6B5DE5F6A78A1D679A64159413337D26" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="umbellatum">
<emphasis id="23C9183BCE2C1FB222A4FF2B879ECEFD" italics="true" pageId="null" pageNumber="590">H. umbellatum</emphasis>
</taxonomicName>
<normalizedToken id="6F5186423C760420366DF4807709E539" originalValue="umfaßt" pageId="null" pageNumber="590">umfasst</normalizedToken>
<emphasis id="70069402F88328BD14C75132A57139FC" italics="true" pageId="null" pageNumber="590">etwa 12 Arten und hat eurasiatische Verbreitung.</emphasis>
Zwischenarten innerhalb der Artengruppe und mit Arten aus der Gruppe des 
<taxonomicName id="08B842760D48C54FC011B48991B23382" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="murorum">
<emphasis id="5D9717225A72F81BA2996732C7645502" italics="true" pageId="null" pageNumber="590">H. murorum</emphasis>
</taxonomicName>
(Nr. 11) sind zahlreich und treten z. T. 
<normalizedToken id="61AFBA41A8B4045816A57FBDF6EB46FD" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
auf.
</paragraph>
<paragraph id="DA4233612E6717DD9F78459A855CB18F" pageId="null" pageNumber="590">
<table id="B40B3E2C75C369AC0821C8A71F0BE390" frame="void" pageId="null" pageNumber="590" rules="none" xmlns:xlink="http://www.w3.org/1999/xlink">
<tbody id="21F9CB9FC32A474AAC14A17B98DF0997" pageId="null" pageNumber="590">
<tr id="BFE265F6AF3FB324E4EA550515C54832" pageId="null" pageNumber="590">
<td id="DF41D804A5BA8A5DF7B6E433F6DD64E6" align="left" pageId="null" pageNumber="590" valign="top">
1. Stengel ohne 
<normalizedToken id="37092ACD5F41C4D6E3D8A6A69639C9C8" originalValue="Drüsenhaare" pageId="null" pageNumber="590">Druesenhaare</normalizedToken>
(oder nur mit einzelnen 
<normalizedToken id="6B07C68839B8463D243EADBB2D4B97C1" originalValue="Drüsenhaaren" pageId="null" pageNumber="590">Druesenhaaren</normalizedToken>
unter den 
<normalizedToken id="4282466C87C2E377CB6C936591592BCE" originalValue="Blütenköpfen" pageId="null" pageNumber="590">Bluetenkoepfen</normalizedToken>
); 
<normalizedToken id="F0EC58E78D6FB3BE61D2C69AA194F3D0" originalValue="Stengelblätter" pageId="null" pageNumber="590">Stengelblaetter</normalizedToken>
mit 
<normalizedToken id="86E8D821E550813695381D565BA7AFC0" originalValue="verschmälertem" pageId="null" pageNumber="590">verschmaelertem</normalizedToken>
, abgerundetem oder undeutlich 
<normalizedToken id="7D0320F4766B30E31746B27A8CE1444D" originalValue="herzförmigem" pageId="null" pageNumber="590">herzfoermigem</normalizedToken>
Grund, den Stengel nicht oder nur wenig umfassend; 
<normalizedToken id="4CC390B1F8CC462A0080DC03FF44144C" originalValue="Zähne" pageId="null" pageNumber="590">Zaehne</normalizedToken>
der Krone kahl.
</td>
</tr>
<tr id="3807FC5643A43A68AC2F5460D32D6E71" pageId="null" pageNumber="590">
<td id="B1D5E62445403D34490B87E26F4FFD3F" align="left" pageId="null" pageNumber="590" valign="top">
2. Mittlere 
<normalizedToken id="570030A1923E164E49B2559112364F28" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
5-12mal so lang wie breit; 
<normalizedToken id="085E1077EECC4E70772978E0999E7D40" originalValue="äußere" pageId="null" pageNumber="590">aeussere</normalizedToken>
<normalizedToken id="836008D711DD7865A704400A853BAF0E" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
teilweise 
<normalizedToken id="C951D02A279E7027FDED291493CBBA4B" originalValue="zurückgebogen" pageId="null" pageNumber="590">zurueckgebogen</normalizedToken>
</td>
<td id="C0901551458DA9E736A07DB09A9365A9" align="left" pageId="null" pageNumber="590" valign="bottom">
<taxonomicName id="BE7D3FBB180937439C9E0C9A6090E5EB" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="umbellatum">
<italic id="13F76F058E3DFD0A492BAD13581204E7" pageId="null" pageNumber="590">H. umbellatum</italic>
</taxonomicName>
(Nr. 14a)
</td>
</tr>
<tr id="49A730FE2EAAB04BB8554F910A790240" pageId="null" pageNumber="590">
<td id="746C9F330BD0959FFB16FCDFEB4CA5E9" align="left" pageId="null" pageNumber="590" valign="top">
2*. Mittlere 
<normalizedToken id="EDA2D760059FA9DDA2D84B3210EE2CC6" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
2-5mal so lang wie breit; 
<normalizedToken id="C6270C7721BFCFAF01EA7EEE029FB003" originalValue="äußere" pageId="null" pageNumber="590">aeussere</normalizedToken>
<normalizedToken id="7E4EC00749D7D9B283A1C321648D67DE" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
nicht oder nur wenig abstehend.
</td>
</tr>
<tr id="E81E0E3EAC55CD1FAE4CA3FDCC1FB312" pageId="null" pageNumber="590">
<td id="9C9558D851748523D81D3BC96FD51C1D" align="left" pageId="null" pageNumber="590" valign="top">
3. 
<normalizedToken id="17D407A03373F35CB7BA5109B746AE04" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
selten rosettenartig 
<normalizedToken id="635787674E3F9633C01FFAEFE92ECA5E" originalValue="gehäuft" pageId="null" pageNumber="590">gehaeuft</normalizedToken>
; wabenartige Leisten auf dem Boden des 
<normalizedToken id="30AA2A99A7FB61FEA6F33F47568A5AB3" originalValue="Blütenkopfes" pageId="null" pageNumber="590">Bluetenkopfes</normalizedToken>
mit einzelnen Haaren; 
<normalizedToken id="6A4A10C14935461C8B8683626B3EA799" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
dunkelbraun bis schwarz, 2,5-3 mm lang
</td>
<td id="8B8FC4B078B7AB81F41797CEFDB857FA" align="left" pageId="null" pageNumber="590" valign="bottom">
<taxonomicName id="83D3D3215422C6613E179CCC10921B7F" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="sabaudum">
<italic id="843A35F80BEB58EF2D80FBD6FA294B12" pageId="null" pageNumber="590">H. sabaudum</italic>
</taxonomicName>
(Nr. 14b)
</td>
</tr>
<tr id="DACD12889E539161FE8A38AA8F9F5AD7" pageId="null" pageNumber="590">
<td id="E8C6F379EA6C01A2BC446AA681CE5133" align="left" pageId="null" pageNumber="590" valign="top">
3*. 
<normalizedToken id="55445937595C4B77A5D2C56C941496A0" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
in der untern 
<normalizedToken id="D8CA36012953FFF61B77B621B60A5A79" originalValue="Stengelhälfte" pageId="null" pageNumber="590">Stengelhaelfte</normalizedToken>
meist rosettenartig 
<normalizedToken id="612CAD0D9AF65D8FE38CC0B3528178F9" originalValue="gehäuft" pageId="null" pageNumber="590">gehaeuft</normalizedToken>
; 
<normalizedToken id="D8E8364EDF3B0C0E971876FA5765470E" originalValue="Blütenboden" pageId="null" pageNumber="590">Bluetenboden</normalizedToken>
kahl; 
<normalizedToken id="90001ACDA8E4B250ACAD99B19352E8CB" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
hell- bis dunkelbraun, 4-4,5 mm lang
</td>
<td id="1FCA17ACB21E4597E7B5B184070DDF91" align="left" pageId="null" pageNumber="590" valign="bottom">
<taxonomicName id="A660D8435BFC3EBAE95F34B9B21D4D37" class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="racemosum">
<italic id="6195E1E6CAC2758E3FC79C35333501CD" pageId="null" pageNumber="590">H. racemosum</italic>
</taxonomicName>
(Nr. 14c)
</td>
</tr>
<tr id="049D7E4E873E3F559717A0E44E44C9C9" pageId="null" pageNumber="590">
<td id="9ED22BA8BAB1910C9FB938BC0B3C9AAB" align="left" pageId="null" pageNumber="590" valign="top">
1*. Stengel im obern Teil mit zahlreichen 0,2-0,7 mm langen 
<normalizedToken id="8D3A1BD28FF552DDD3D5D0E5A9F12C71" originalValue="Drüsenhaaren" pageId="null" pageNumber="590">Druesenhaaren</normalizedToken>
; 
<normalizedToken id="BBC5563F21D8C61785ADB0C718AF4669" originalValue="Stengelblätter" pageId="null" pageNumber="590">Stengelblaetter</normalizedToken>
mit breit 
<normalizedToken id="6E5E2289A3FDDB7187A467FCF4588637" originalValue="herzförmigem" pageId="null" pageNumber="590">herzfoermigem</normalizedToken>
Grund den Stengel umfassend; 
<normalizedToken id="E5437BBB20A39B744DEEA76B5A22B019" originalValue="Zähne" pageId="null" pageNumber="590">Zaehne</normalizedToken>
der Krone bewimpert
</td>
<td id="73466EBB3B144F4EA145EC0EFC5EA7C2" align="left" pageId="null" pageNumber="590" valign="bottom">
<taxonomicName id="07F0707DE3C2EC7ED919F027FCD20960" class="Demospongiae" family="Chondrillidae" genus="Chondrilla" kingdom="Animalia" order="Chondrillida" pageId="null" pageNumber="590" phylum="Porifera" rank="species" species="prenanthoides">
<italic id="C29AEAD8D03B62021B14EDE00888FA94" pageId="null" pageNumber="590">H. prenanthoides</italic>
</taxonomicName>
(Nr. 14d)
</td>
</tr>
</tbody>
