<paragraph id="744558A862CEEAC249CAC8E978F713A1" pageId="null" pageNumber="590">
<pageBreakToken id="80ED57501D24EDB3EB645ACFFFC5A738" pageId="null" pageNumber="590">Artengruppe</pageBreakToken>
des 
<taxonomicName id="A8CDFE2045D49719E2C956F671F3D384" authority="L." class="Magnoliopsida" family="Asteraceae" genus="Hieracium" kingdom="Plantae" order="Asterales" pageId="null" pageNumber="590" phylum="Tracheophyta" rank="species" species="umbellatum">
Hieracium 
<normalizedToken id="6B8E977014547446D50B1DB47F3E1AEF" originalValue="umbellátum" pageId="null" pageNumber="590">umbellatum</normalizedToken>
<authorityName id="0635F1DDA17BBE9186CB7EECBE181DB9" pageId="null" pageNumber="590">L.</authorityName>
</taxonomicName>
</paragraph>
