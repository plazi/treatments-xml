<heading id="47438182FF86E25BFCE2F927D1FF70A9" box="[827,1204,1711,1735]" centered="true" fontSize="9" level="2" pageId="5" pageNumber="304" reason="2">
<taxonomicName id="DBB44D6DFF86E25BFCE2F927D17870A9" baseAuthorityName="Temminck &amp; Schlegel" baseAuthorityYear="1838" box="[827,1075,1711,1735]" class="Amphibia" family="Hynobiidae" genus="Hynobius" higherTaxonomySource="GBIF" kingdom="Animalia" order="Caudata" pageId="5" pageNumber="304" phylum="Chordata" rank="species" species="nebulosus">Hynobius nebulosus</taxonomicName>
<emphasis id="2EC0EAFCFF86E25BFBE2F938D1FF70A9" box="[1083,1204,1711,1735]" italics="true" pageId="5" pageNumber="304">
