<subSubSection id="04E0B7F2D6BDE2E525783E0C8749BC81" pageId="null" pageNumber="283" type="description">
<paragraph id="4A021A678414B4A905A60E8A5E998B9D" pageId="null" pageNumber="283">
Unterscheidet sich von 
<taxonomicName id="F73D496D76D84B6D22F7904EB66BD209" class="Magnoliopsida" family="Rubiaceae" genus="Asperula" kingdom="Plantae" order="Gentianales" pageId="null" pageNumber="283" phylum="Tracheophyta" rank="species" species="cynanchica">
<emphasis id="EA5FA9E12B6915FB3C2EE5BD519CE0D3" italics="true" pageId="null" pageNumber="283">A. cynanchica</emphasis>
</taxonomicName>
(Nr. 3) durch folgende Merkmale: 
<emphasis id="A7E89AC3E40CF39EE940923C312A7E5E" italics="true" pageId="null" pageNumber="283">
<normalizedToken id="9FE64D7F55DFAF1999278E65C0DF9062" originalValue="Blätter" pageId="null" pageNumber="283">Blaetter</normalizedToken>
im 
<normalizedToken id="DC7D52E38D0BEE3B9292B728D0B7FB50" originalValue="Blütenstand" pageId="null" pageNumber="283">Bluetenstand</normalizedToken>
3
</emphasis>
- 
<emphasis id="924AC2C1F56EB3A78832B9CAA1CDBDE8" italics="true" pageId="null" pageNumber="283">
6mal so lang wie breit, weit 
<normalizedToken id="260EFE482233D4D2E0C31D118EED980B" originalValue="über" pageId="null" pageNumber="283">ueber</normalizedToken>
die Fruchtknoten hinausragend. 
<normalizedToken id="7E3A2F7E0416526B0A0C0E1F02289C29" originalValue="Kronröhre" pageId="null" pageNumber="283">Kronroehre</normalizedToken>
2,5
</emphasis>
- 
<emphasis id="E265D285BB4B558D0D5F25AD79FEE2D5" italics="true" pageId="null" pageNumber="283">4 mm lang, 1</emphasis>
<normalizedToken id="3DB7C77C1745B087237370C359FB384C" originalValue="½" pageId="null" pageNumber="283">1/2</normalizedToken>
- 
<emphasis id="54BFA63123D22612348AA61623EA0413" italics="true" pageId="null" pageNumber="283">3mal so lang wie die Zipfel.</emphasis>
- 
<normalizedToken id="626B4EF1D84F66390940979E7FE0DAE4" originalValue="Blüte" pageId="null" pageNumber="283">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="9AF2FE351AE3A4606F8C9E1D2AD62396" pageId="null" pageNumber="283">
<emphasis id="46EE7AE6CF01E618BEACF2A27C9AF7BC" italics="true" pageId="null" pageNumber="283">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="840E518793AEAEB6F41BA83FB72EF121" italics="true" pageId="null" pageNumber="283">22:</emphasis>
Material von 11 verschiedenen Populationen aus den Alpes Maritimes, aus dem Wallis, aus dem Aostatal, von der Grigna und vom Gardaseegebiet (Romerio 1965). Fagerlind (1934 1937) 
<normalizedToken id="3BFC707E2B3D77DE1ACF3E7BBB06E562" originalValue="zählte" pageId="null" pageNumber="283">zaehlte</normalizedToken>
an Material aus botanischen 
<normalizedToken id="8D73E43E43827B76CD4C93410C9DA940" originalValue="Gärten" pageId="null" pageNumber="283">Gaerten</normalizedToken>
2n = 44. Ernet und Ehrendorfer (
<normalizedToken id="B6A4E4207AB3AFAE6A565152515DD57D" originalValue="unveröffentlicht" pageId="null" pageNumber="283">unveroeffentlicht</normalizedToken>
) 
<normalizedToken id="8B56DB130A6F7A140348D66C8ADB2F56" originalValue="zählten" pageId="null" pageNumber="283">zaehlten</normalizedToken>
an Material von zahlreichen Orten Mittel- und 
<normalizedToken id="A46B998977AA8AE32265F2C460CBC6E2" originalValue="Südeuropas" pageId="null" pageNumber="283">Suedeuropas</normalizedToken>
<emphasis id="C1BB683D0376860446A3D171BB4D15FB" italics="true" pageId="null" pageNumber="283">2n</emphasis>
= 
<emphasis id="4A5E45BA5DDD9B6459B6CFF1C8596A6E" italics="true" pageId="null" pageNumber="283">20</emphasis>
und 
<emphasis id="72E732BB4954F4AE747708EB487BAE96" italics="true" pageId="null" pageNumber="283">2n</emphasis>
= 
<emphasis id="541F13D5726FEA75FCE0DCBBA82B33A6" italics="true" pageId="null" pageNumber="283">40</emphasis>
und halten die Zahlen 2n = 22 und 44 
<normalizedToken id="284358FCBCE04766882BD090FC59793F" originalValue="für" pageId="null" pageNumber="283">fuer</normalizedToken>
falsch.
</paragraph>
<paragraph id="F7DE4DD4ABF07C13F2E3B31872160E19" pageId="null" pageNumber="283">
<emphasis id="3AB2AFE859F48A66CFEE13F822628DE0" italics="true" pageId="null" pageNumber="283">Standort</emphasis>
. Kollin und montan, seltener subalpin. Trockene, kalkhaltige 
<normalizedToken id="5450EA29A7739BD3A6D6C19B84847085" originalValue="Böden" pageId="null" pageNumber="283">Boeden</normalizedToken>
in 
<normalizedToken id="5F5C1F58E7F7A9D178E62F14EA89D7A4" originalValue="wärmeren" pageId="null" pageNumber="283">waermeren</normalizedToken>
Lagen. Trockenwiesen, Blaugrashalden, Felsensteppen, Schutthalden. 
<emphasis id="6D8EFF4157C35C40ABD55A158CB0C6C5" italics="true" pageId="null" pageNumber="283">Stipo-Poion carniolicae</emphasis>
Br.-Bl. 1961.
</paragraph>
<paragraph id="3DF03CE412F145B2C8180741A9FF3B9C" pageId="null" pageNumber="283">
<emphasis id="6DF35DED1B9FF1C4701FF15A2D346B7C" italics="true" pageId="null" pageNumber="283">
Verbreitung. 
<normalizedToken id="555386233A3ACE069500D60516CD03B5" originalValue="Südalpin-apenninische" pageId="null" pageNumber="283">Suedalpin-apenninische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="0FE7D3AA2812D21034692132A5ECAA8A" originalValue="Südalpen" pageId="null" pageNumber="283">Suedalpen</normalizedToken>
, 
<normalizedToken id="B3CDDB4081B8EFC9DAD75668DB3D26EC" originalValue="nördlicher" pageId="null" pageNumber="283">noerdlicher</normalizedToken>
Apennin. - Im Gebiet: Savoyen (Maurienne, obere Tarentaise, Gegend von 
<normalizedToken id="55A1D5D173DDC108BC613D677A2F8541" originalValue="Chambéry" pageId="null" pageNumber="283">Chambery</normalizedToken>
), Wallis, Aostatal, 
<normalizedToken id="479E1B04F2B19C01759D45FD1E1F47C4" originalValue="südliches" pageId="null" pageNumber="283">suedliches</normalizedToken>
Tessin (
<normalizedToken id="F3DD96AB90F334376D6E8CF852553160" originalValue="nordwärts" pageId="null" pageNumber="283">nordwaerts</normalizedToken>
bis Bellinzona), Comerseegebiet, Bergamasker Alpen (Concarena im Val Camonica); nicht 
<normalizedToken id="CD130133B93631D85FC66A84DCDB8204" originalValue="häufig" pageId="null" pageNumber="283">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
