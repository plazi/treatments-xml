<subSubSection id="C3485ED6097CB222EC95FB7624DA4F7C" pageId="40" pageNumber="491" type="etymology">
<paragraph id="8BED0D5D097CB222EC95FB7624284EC0" blockId="40.[151,1437,1194,2013]" pageId="40" pageNumber="491">
<emphasis id="B926D14F097CB222EC95FB7621294EED" bold="true" box="[151,290,1194,1220]" pageId="40" pageNumber="491">Etymology:</emphasis>
<taxonomicName id="4C5276DE097CB222ED28FB7621A94EED" authorityName="Hoedeman" authorityYear="1951" box="[298,418,1194,1220]" class="Actinopterygii" family="Aphaniidae" genus="Aphaniops" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyprinodontiformes" pageId="40" pageNumber="491" phylum="Chordata" rank="genus">
<emphasis id="B926D14F097CB222ED28FB7621A94EED" box="[298,418,1194,1220]" italics="true" pageId="40" pageNumber="491">Aphaniops</emphasis>
</taxonomicName>
: 
<emphasis id="B926D14F097CB222EDB0FB7622544EED" box="[434,607,1194,1221]" italics="true" pageId="40" pageNumber="491">
<taxonomicName id="4C5276DE097CB222EDB0FB7622174EED" authorityName="Nardo" authorityYear="1827" box="[434,540,1194,1220]" class="Actinopterygii" family="Cyprinodontidae" genus="Aphanius" kingdom="Animalia" order="Cyprinodontiformes" pageId="40" pageNumber="491" phylum="Chordata" rank="genus">Aphanius</taxonomicName>
-opsis
</emphasis>
, resembling 
<taxonomicName id="4C5276DE097CB222EEF0FB7623574EED" authorityName="Nardo" authorityYear="1827" box="[754,860,1194,1220]" class="Actinopterygii" family="Cyprinodontidae" genus="Aphanius" kingdom="Animalia" order="Cyprinodontiformes" pageId="40" pageNumber="491" phylum="Chordata" rank="genus">
<emphasis id="B926D14F097CB222EEF0FB7623574EED" box="[754,860,1194,1220]" italics="true" pageId="40" pageNumber="491">Aphanius</emphasis>
</taxonomicName>
; 
<taxonomicName id="4C5276DE097CB222EF6EFB7623BE4EED" baseAuthorityName="Freyhof, Weissenbacher &amp; Geiger" baseAuthorityYear="2017" box="[876,949,1194,1220]" class="Actinopterygii" family="Aphaniidae" genus="Aphaniops" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyprinodontiformes" pageId="40" pageNumber="491" phylum="Chordata" rank="species" species="kruppi">
<emphasis id="B926D14F097CB222EF6EFB7623BE4EED" box="[876,949,1194,1220]" italics="true" pageId="40" pageNumber="491">kruppi</emphasis>
</taxonomicName>
: named for Dr. Fareed Krupp for his valuable contributions to the explorations of the freshwater fishes of the Middle East.
</paragraph>
<paragraph id="8BED0D5D097CB222ECC5FB2E23294F25" blockId="40.[151,1437,1194,2013]" box="[199,802,1266,1292]" pageId="40" pageNumber="491">
