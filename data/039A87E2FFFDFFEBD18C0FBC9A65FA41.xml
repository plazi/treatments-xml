<figureCitation id="13082A71FFFDFFEBD1BB0F909F93FB61" box="[160,241,1195,1221]" captionStart="FIGURES 27–34" captionStartId="12.[151,264,1862,1886]" captionTargetBox="[165,1421,181,1838]" captionTargetId="figure-18@12.[165,1421,181,1838]" captionTargetPageId="12" captionText="FIGURES 27–34. 27–28, dorsal view, scale bar 5.0 mm, 27, Heza sericans Stål, 1859, female, 28, Isocondylus elongatus (Lepeletier &amp; Serville, 1825), male; 29–33, Notocyrtus costai Gil-Santana &amp; Forero, 2009; 29–31, female holotype deposited in MZUSP, 29–30, scale bar 2.0 mm, 29, dorsal view, 30, lateral view, 31, labels and right hind leg glued to a card pinned with the specimen; 32–33, female from French Guiana, dorsal view, 32, scale bar 5.0 mm, 33, head, scale bar 1.0 mm; 34, Notocyrtus depressus Stål, 1872, female, dorsal view, scale bar 5.0 mm." figureDoi="http://doi.org/10.5281/zenodo.6332724" httpUri="https://zenodo.org/record/6332724/files/figure.png" pageId="10" pageNumber="391">Fig. 27</figureCitation>
