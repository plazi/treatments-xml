<subSubSection id="C329657FFFFDFFEBD18C0FCF9C4AFA3A" pageId="10" pageNumber="391" type="reference_group">
<paragraph id="8B8C36F4FFFDFFEBD18C0FCF9C4AFA3A" blockId="10.[151,1436,1267,1510]" pageId="10" pageNumber="391">
<taxonomicName id="4C334D77FFFDFFEBD18C0FCF9E54FAA9" authorityName="Stal" authorityYear="1859" box="[151,310,1268,1293]" class="Insecta" family="Reduviidae" genus="Heza" kingdom="Animalia" order="Hemiptera" pageId="10" pageNumber="391" phylum="Arthropoda" rank="species" species="sericans">
<emphasis id="B947EAE6FFFDFFEBD18C0FCF9E54FAA9" box="[151,310,1268,1293]" italics="true" pageId="10" pageNumber="391">Heza sericans</emphasis>
</taxonomicName>
was described from 
<collectingCountry id="F3247664FFFDFFEBD33E0FC89D0BFAA9" box="[549,617,1267,1293]" name="Brazil" pageId="10" pageNumber="391">Brazil</collectingCountry>
(
<bibRefCitation id="EFA24B05FFFDFFEBD3610FC89D8EFAAA" author="Stal, C." box="[634,748,1267,1294]" pageId="10" pageNumber="391" pagination="175 - 204" refId="ref13583" refString="Stal, C. (1859) Till kannedomen om Reduvini. Ofversigt af Kongliga Vetenskaps-Akademiens Forhandlingar, 16, 175 - 204." type="journal article" year="1859">Stål 1859</bibRefCitation>
), then recorded from 
<collectingCountry id="F3247664FFFDFFEBD2F90FC89BEBFAA9" box="[994,1161,1267,1293]" name="French Guiana" pageId="10" pageNumber="391">French Guiana</collectingCountry>
only by 
<bibRefCitation id="EFA24B05FFFDFFEBD5EB0FC89AFBFAA9" author="Villiers, A." box="[1264,1433,1267,1293]" pageId="10" pageNumber="391" pagination="679 - 684" refId="ref13861" refString="Villiers, A. (1971) Reduviidae [Heteroptera] recoltes en Guyane Francaise par la mission du Museum National D'Histoire Naturelle. Annales de la Societe Entomologique de France, New Series, 7 (3), 679 - 684." type="journal article" year="1971">Villiers (1971)</bibRefCitation>
. Subsequent publications on the genus (
<bibRefCitation id="EFA24B05FFFDFFEBD34A0E2C9C74FA95" author="Maldonado, J. C." box="[593,790,1303,1329]" pageId="10" pageNumber="391" pagination="403 - 433" refId="ref13139" refString="Maldonado, J. C. (1976) The genus Heza (Hemiptera: Reduviidae). Journal of Agriculture of the University of Puerto Rico, 60 (3), 403 - 433. https: // doi. org / 10.46429 / jaupr. v 60 i 3.10533" type="journal article" year="1976">Maldonado 1976</bibRefCitation>
, 
<bibRefCitation id="EFA24B05FFFDFFEBD2390E2C9C3FFA95" author="Maldonado, J. C." box="[802,861,1303,1329]" pageId="10" pageNumber="391" pagination="407 - 418" refId="ref13191" refString="Maldonado, J. C. (1983) Concerning new and old species of Heza (Hemiptera: Reduviidae). Journal of Agriculture of the University of Puerto Rico, 67, 407 - 418. https: // doi. org / 10.46429 / jaupr. v 67 i 4.7735" type="journal article" year="1983">1983</bibRefCitation>
, 
<bibRefCitation id="EFA24B05FFFDFFEBD2720E2C9CC0FA95" author="Maldonado, J. C." box="[873,930,1303,1329]" pageId="10" pageNumber="391" refId="ref13244" refString="Maldonado, J. C. (1990) Systematic catalogue of the Reduviidae of the World. Caribbean Journal of Science, Special publication No. 1. University of Puerto Rico, Mayaguez, 694 pp." type="book" year="1990">1990</bibRefCitation>
) omitted this record, therefore it seemed advisable to confirm its presence in this country here. The species was redescribed by 
<bibRefCitation id="EFA24B05FFFDFFEBD5580E009A76FAF2" author="Maldonado, J. C." box="[1091,1300,1339,1366]" pageId="10" pageNumber="391" pagination="403 - 433" refId="ref13139" refString="Maldonado, J. C. (1976) The genus Heza (Hemiptera: Reduviidae). Journal of Agriculture of the University of Puerto Rico, 60 (3), 403 - 433. https: // doi. org / 10.46429 / jaupr. v 60 i 3.10533" type="journal article" year="1976">Maldonado (1976)</bibRefCitation>
and may be recognized by the diagnostic criteria of the conspicuous annuli on first antennal segment, veins of membrane being whitish basally, and the three-spined connexival segments.
</paragraph>
</subSubSection>
