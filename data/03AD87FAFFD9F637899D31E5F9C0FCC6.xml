<collectingRegion id="49C0F80EFFD9F6378ABD3321FBBDF8C5" box="[931,1048,1853,1886]" country="Indonesia" name="Sulawesi Utara" pageId="29" pageNumber="87">Sulawesi</collectingRegion>
