A–D. 
<taxonomicName id="A2CF4C9FFFF0FFBDFEEEF8B3622B2474" authorityName="Wang &amp; Zhang" authorityYear="2022" box="[345,558,1853,1877]" class="Insecta" family="Cicadellidae" genus="Chanohirata" kingdom="Animalia" order="Hemiptera" pageId="4" pageNumber="436" phylum="Arthropoda" rank="species" species="minima">
