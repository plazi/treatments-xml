<paragraph pageId="0" pageNumber="93">Remarks.</paragraph>
<paragraph pageId="0" pageNumber="93">
The male adult of 
<taxonomicName genus="S." lsidName="S. baishanzuensis" pageId="0" pageNumber="93" rank="species" species="baishanzuensis">
