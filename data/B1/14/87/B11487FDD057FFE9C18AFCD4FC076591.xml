<materialsCitation collectingDate="1981-05-20" collectionCode="S, G" collectorName="Sumac Road &amp; Spur" country="Australia" elevation="170" latitude="-41.133335" location="S of Arthur River" longLatPrecision="1158" longitude="145.03334" pageId="6" pageNumber="215" specimenCount="1" stateProvince="Tasmania">
