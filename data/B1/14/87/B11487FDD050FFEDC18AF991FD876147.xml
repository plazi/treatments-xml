<paragraph blockId="2.[136,1452,1787,1886]" pageId="2" pageNumber="211">
Endemic to 
<collectingRegion box="[272,379,1787,1813]" country="Australia" name="Tasmania" pageId="2" pageNumber="211">Tasmania</collectingRegion>
where it is an occasional epiphyte on shaded, smooth bark in rainforest. This species is clearly closely related to 
<taxonomicName box="[333,505,1823,1849]" class="Lecanoromycetes" family="Xylographaceae" genus="Lambiella" kingdom="Fungi" pageId="2" pageNumber="211" phylum="Ascomycota" rank="species" species="globulispora">
<emphasis box="[333,505,1823,1849]" italics="true" pageId="2" pageNumber="211">L. globulispora</emphasis>
</taxonomicName>
, 
<taxonomicName box="[518,662,1823,1849]" class="Lecanoromycetes" family="Xylographaceae" genus="Lambiella" kingdom="Fungi" pageId="2" pageNumber="211" phylum="Ascomycota" rank="species" species="umbratilis">
<emphasis box="[518,662,1823,1849]" italics="true" pageId="2" pageNumber="211">L. umbratilis</emphasis>
</taxonomicName>
and the newly described 
<taxonomicName box="[945,1070,1823,1849]" class="Lecanoromycetes" family="Xylographaceae" genus="Lambiella" kingdom="Fungi" pageId="2" pageNumber="211" phylum="Ascomycota" rank="species" species="plumbea">
<emphasis box="[945,1070,1823,1849]" italics="true" pageId="2" pageNumber="211">L. plumbea</emphasis>
</taxonomicName>
(see 
<tableCitation box="[1128,1209,1823,1850]" captionStart="TABLE 1" captionStartId="3.[136,224,159,183]" captionTargetPageId="3" captionText="TABLE 1. Comparison of salient features of the Lambiella applanata group. including the newly described L. plumbea." pageId="2" pageNumber="211">Table 1</tableCitation>
). 
<collectionCode box="[1231,1250,1824,1850]" country="USA" lsid="urn:lsid:biocol.org:col:15406" name="Harvard University - Arnold Arboretum" pageId="2" pageNumber="211" type="Herbarium">A</collectionCode>
