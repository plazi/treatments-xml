<subSubSection id="3DCCC556C29F11B3C083FEE99DB2A26D" pageId="null" pageNumber="479" type="description">
<paragraph id="68C96F2F1539A80BE556B1F5716A46E2" pageId="null" pageNumber="479">
Unterscheidet sich von 
<taxonomicName id="E39DCB3E715A93E12D95003FBAAE3779" class="Magnoliopsida" family="Rosaceae" genus="Spiraea" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="479" phylum="Tracheophyta" rank="species" species="japonica">
<emphasis id="A89542BA2435691E49527F12D1AEB81B" italics="true" pageId="null" pageNumber="479">S. japonica</emphasis>
</taxonomicName>
(Nr. 2) durch folgende Merkmale: 
<normalizedToken id="BFA1237E77F5507BEF837A207D84BB1B" originalValue="Blätter" pageId="null" pageNumber="479">Blaetter</normalizedToken>
zum 
<normalizedToken id="97AAE2B3A8B05A4A0F3C717E64777948" originalValue="großen" pageId="null" pageNumber="479">grossen</normalizedToken>
Teil schmal lanzettlich, bis 8 cm lang, 4-6mal so lang wie breit, meist 1fach 
<normalizedToken id="4858F24663AFD0C03243254931CE0D08" originalValue="gezähnt" pageId="null" pageNumber="479">gezaehnt</normalizedToken>
, meist sitzend. 
<emphasis id="CFE4448A85BE98DA75485E877790A0DB" italics="true" pageId="null" pageNumber="479">
Der zusammengesetzte 
<normalizedToken id="6BF3E39FEA9AA572F94652F203BBB9BF" originalValue="Blütenstand" pageId="null" pageNumber="479">Bluetenstand</normalizedToken>
ist zylindrisch. 
<normalizedToken id="5F9B548AA498BC17D8E1B7C7F9E2E662" originalValue="Kelchblätter" pageId="null" pageNumber="479">Kelchblaetter</normalizedToken>
nach der 
<normalizedToken id="D3F2D81EE1114FB17BBB55C28336A41B" originalValue="Blüte" pageId="null" pageNumber="479">Bluete</normalizedToken>
aufgerichtet. 
<normalizedToken id="03E5FE1713470111992336D750649B13" originalValue="Kronblätter" pageId="null" pageNumber="479">Kronblaetter</normalizedToken>
hellrosa. -
</emphasis>
<normalizedToken id="8F336902BCC169EA5A88546C79DD6B1D" originalValue="Blüte" pageId="null" pageNumber="479">Bluete</normalizedToken>
: 
<normalizedToken id="A3BC13E24F5232E5D5950310845C231F" originalValue="Früher" pageId="null" pageNumber="479">Frueher</normalizedToken>
Sommer bis Herbst.
</paragraph>
<paragraph id="A783E4AA324B19BB84F636EC70D02509" pageId="null" pageNumber="479">
<emphasis id="3125D8F1E98D788D7E082283C7F7A8CA" italics="true" pageId="null" pageNumber="479">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="6790A47EBA7813E9E1119F6A834F48B6" italics="true" pageId="null" pageNumber="479">36:</emphasis>
Material aus botanischen 
<normalizedToken id="55412B97EFF3713168B5470C8E320245" originalValue="Gärten" pageId="null" pageNumber="479">Gaerten</normalizedToken>
; nur 1% des Pollens normal (Sax 1936).
</paragraph>
<paragraph id="565DDD2D0C00BB510CBF1FBB5B33DE31" pageId="null" pageNumber="479">
<emphasis id="8C5A9348CA9C47FB63894885B31D034C" italics="true" pageId="null" pageNumber="479">Standort.</emphasis>
Kollin. In 
<normalizedToken id="2D234A5BD6E623DDCC841C9474304F9A" originalValue="Auenwäldern" pageId="null" pageNumber="479">Auenwaeldern</normalizedToken>
verwilderte Gartenpflanze.
</paragraph>
<paragraph id="96DCB25678BEA87475ADDD277169B388" pageId="null" pageNumber="479">
<emphasis id="4CAD56AB4E670285FD020F4F02FA734A" italics="true" pageId="null" pageNumber="479">Verbreitung.</emphasis>
<normalizedToken id="644BDC8F5ACCBC5CC6346109225022B7" originalValue="Ursprünglich" pageId="null" pageNumber="479">Urspruenglich</normalizedToken>
<emphasis id="771BA1324E81D34A1C2717641D30A83A" italics="true" pageId="null" pageNumber="479">
<normalizedToken id="DD24D3BFF69F9C13DD0CBDC504D4D397" originalValue="osteuropäisch-asiatische" pageId="null" pageNumber="479">osteuropaeisch-asiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="D32B014C2A06BE3DBF130C7BFF221DB3" originalValue="Natürliche" pageId="null" pageNumber="479">Natuerliche</normalizedToken>
Westgrenze der Verbreitung vermutlich in 
<normalizedToken id="30BAEB1B62BADA773317C33B8948F692" originalValue="Böhmen" pageId="null" pageNumber="479">Boehmen</normalizedToken>
, 
<normalizedToken id="7DE469D26E4D048289AF82278C6B9F3A" originalValue="Oberösterreich" pageId="null" pageNumber="479">Oberoesterreich</normalizedToken>
, Ungarn; durch Mittel- und 
<normalizedToken id="8C01128645A1155346858284DE35ED32" originalValue="Südrußland" pageId="null" pageNumber="479">Suedrussland</normalizedToken>
und Sibirien 
<normalizedToken id="2FC24CBD296CFE607CF86E45685F7DC8" originalValue="ostwärts" pageId="null" pageNumber="479">ostwaerts</normalizedToken>
bis Ostasien. Im westlichen Europa und Nordamerika 
<normalizedToken id="5E508AC79641B34AA8507BFEBB94CF5A" originalValue="eingeführt" pageId="null" pageNumber="479">eingefuehrt</normalizedToken>
. - Im Gebiet gelegentlich verwilderte Gartenpflanze, z.B. in 
<normalizedToken id="BA52601F8012F351B10562FD43476F42" originalValue="Auenwäldern" pageId="null" pageNumber="479">Auenwaeldern</normalizedToken>
im Schwarzwald (Wolfachtal) und im Emmental zwischen Trub und Fankhaus.
</paragraph>
</subSubSection>
