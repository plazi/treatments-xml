<taxonomicName id="8DDC4D70FFFBFFBAFC289D1F6C4B7C11" authority="NAKKADY" authorityName="NAKKADY" authorityYear="1950" box="[898,1350,347,368]" class="Nodosariata" family="Vaginulinidae" genus="Marginulina" kingdom="Chromista" order="Vaginulinida" pageId="22" pageNumber="36" phylum="Foraminifera" rank="subSpecies" species="wetherellii" subSpecies="longiscata">
