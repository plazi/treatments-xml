<collectingCountry id="C7D57663FFB71B00FABFF762010A4F37" box="[1381,1548,2263,2305]" name="Australia" pageId="9" pageNumber="159">Australia</collectingCountry>
. 
<collectingCountry id="C7D57663FFB71B00F9E8F762019F4F37" box="[1586,1689,2263,2305]" name="Guam" pageId="9" pageNumber="159">Guam</collectingCountry>
