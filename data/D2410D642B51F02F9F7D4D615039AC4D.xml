<subSubSection id="99B1095130E80663535ABA06D34941EC" pageId="null" pageNumber="593" type="vernacular_names">
<paragraph id="FA60CADEEA3A39BF4B02C91410A0F83A" pageId="null" pageNumber="593">Platterbsen-Wicke</paragraph>
</subSubSection>
</title>
<subSubSection id="4642A4F03DA5A77EFF026330C5C63D1D" pageId="null" pageNumber="593" type="description">
<paragraph id="F453ACE63FC428A883BD90D1E16E4B3B" pageId="null" pageNumber="593">
1-2 
<normalizedToken id="F66BB4DA68CE20EC4A1F02F1BF7FCCFA" originalValue="jährig" pageId="null" pageNumber="593">jaehrig</normalizedToken>
; 5-25 cm hoch. Stengel niederliegend oder bogig aufsteigend, am Grunde meist verzweigt, zerstreut behaart. 
<emphasis id="0622345235F6FB968BEF8F3B0BCFA004" italics="true" pageId="null" pageNumber="593">
<normalizedToken id="76ED68045E5817F5CCAD150E01074DB6" originalValue="Blätter" pageId="null" pageNumber="593">Blaetter</normalizedToken>
mit 4-6 
<normalizedToken id="33DABFD400F3F63AD1F0F2AC06BFE68C" originalValue="Teilblättern" pageId="null" pageNumber="593">Teilblaettern</normalizedToken>
</emphasis>
und 
<normalizedToken id="3285B46AA661E1E40D9C18043B32DED9" originalValue="endständiger" pageId="null" pageNumber="593">endstaendiger</normalizedToken>
, grannenartiger Spitze oder Ranke (bei obern 
<normalizedToken id="704F2802CE500B44B37532E1E6254357" originalValue="Blättern" pageId="null" pageNumber="593">Blaettern</normalizedToken>
); 
<normalizedToken id="81E0885F05EDFDBD9AD266822BD91C78" originalValue="Teilblätter" pageId="null" pageNumber="593">Teilblaetter</normalizedToken>
0,5-1,5 cm lang und 
<normalizedToken id="D87001F831C2A4B59C8A7EDC98241F69" originalValue="1½" pageId="null" pageNumber="593">11/2</normalizedToken>
(untere 
<normalizedToken id="238536C8CABE9D70545595FE4301DC37" originalValue="Blätter" pageId="null" pageNumber="593">Blaetter</normalizedToken>
)-6mal (obere 
<normalizedToken id="A10215634B5C68370C34B06F6146708F" originalValue="Blätter" pageId="null" pageNumber="593">Blaetter</normalizedToken>
) so lang wie breit, zerstreut behaart; 
<normalizedToken id="C0B69F31EF3427931FADEB6F0D466707" originalValue="Nebenblätter" pageId="null" pageNumber="593">Nebenblaetter</normalizedToken>
schmal, 
<normalizedToken id="3BE0A6EE3457007853D2766DF47BD2DF" originalValue="¼-½" pageId="null" pageNumber="593">1/4-1/2</normalizedToken>
so lang wie die untern 
<normalizedToken id="A43CD2D44348DAA2787DB73060A7E8B0" originalValue="Teilblätter" pageId="null" pageNumber="593">Teilblaetter</normalizedToken>
, am Grunde mit einem abstehenden Zipfel, sonst ganzrandig, ohne 
<normalizedToken id="799F78127F7C348C2629A676C3E44C80" originalValue="Nektardrüse" pageId="null" pageNumber="593">Nektardruese</normalizedToken>
. 
<normalizedToken id="082E3774079EFABC934CA904889F0E1B" originalValue="Blüten" pageId="null" pageNumber="593">Blueten</normalizedToken>
zu 1-2 in den Blattachseln, fast ungestielt, aufrecht abstehend. Kelch zerstreut behaart; 
<normalizedToken id="ACB39D4EDA1AD64C4B2DE774677CD4BC" originalValue="Kelchzähne" pageId="null" pageNumber="593">Kelchzaehne</normalizedToken>
<normalizedToken id="9FAC6929A79F32EB07846D3DEE940B5F" originalValue="±" pageId="null" pageNumber="593">+/-</normalizedToken>
gleichartig, 
<normalizedToken id="13018BBA1A9350C20D7525B13692F749" originalValue="¾" pageId="null" pageNumber="593">3/4</normalizedToken>
bis fast so lang wie die 
<normalizedToken id="418C5C0D7FB712F135A22407FB9B8295" originalValue="Kelchröhre" pageId="null" pageNumber="593">Kelchroehre</normalizedToken>
. 
<emphasis id="0AE1FF0C4978DF94366A819471102CE3" italics="true" pageId="null" pageNumber="593">Krone 0,6-0,7 cm lang</emphasis>
, violett (selten 
<normalizedToken id="D8F87EC2DC99D28DDE9E83DA308B046E" originalValue="weiß" pageId="null" pageNumber="593">weiss</normalizedToken>
). Frucht abstehend, flach, 2-3 cm lang und 
<emphasis id="D8A398F37241B870AE29AA0895A4C224" italics="true" pageId="null" pageNumber="593">0,3-0,4 cm breit</emphasis>
, meist kahl, 5-10samig. Samen 1-2 mm lang. - 
<normalizedToken id="0107DEF1A09EC356A187B80FB16C238E" originalValue="Blüte" pageId="null" pageNumber="593">Bluete</normalizedToken>
: 
<normalizedToken id="01745ADD4894AF831410D37BC1AB659E" originalValue="Später" pageId="null" pageNumber="593">Spaeter</normalizedToken>
<normalizedToken id="F04790983C3B1A0B544F4C94C13653AB" originalValue="Frühling" pageId="null" pageNumber="593">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="80CB5B24EF1F1FF0E50FBC903805B63D" pageId="null" pageNumber="593">
<emphasis id="9936D948E680F86B6CCCB7CDEADE0D6D" italics="true" pageId="null" pageNumber="593">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="5D3756966D08214A04A071666BA76AED" italics="true" pageId="null" pageNumber="593">12:</emphasis>
Material unbekannter Herkunft (Heitz 1931b), aus Skandinavien (
<normalizedToken id="24B5E04542B7E09BEEF25390D4C3F017" originalValue="Löve" pageId="null" pageNumber="593">Loeve</normalizedToken>
und 
<normalizedToken id="61B2FF699EF55317BD76BE902B13EC80" originalValue="Löve" pageId="null" pageNumber="593">Loeve</normalizedToken>
1944b), aus Ungarn (Baksay 1954), aus der Slowakei (
<normalizedToken id="2B72E488E011FAFD953CD64BFB69D9F3" originalValue="Činčura" pageId="null" pageNumber="593">Cincura</normalizedToken>
1963), aus Holland (Gadella und Kliphuis 1966).
</paragraph>
<paragraph id="005D2A8FB09DC74E8EE584A6C99C7ADC" pageId="null" pageNumber="593">
<emphasis id="533939A74064D79C28479D4BD082307B" italics="true" pageId="null" pageNumber="593">Standort.</emphasis>
Kollin. Trockene, lockere, meist kalkarme, sandige 
<normalizedToken id="A3B13C706BF8D4E45BF95D81637A366C" originalValue="Böden" pageId="null" pageNumber="593">Boeden</normalizedToken>
in warmen Lagen. Nicht geschlossene, trockene Rasen.
</paragraph>
<paragraph id="35488C9F530794163AAB592AFB55D153" pageId="null" pageNumber="593">
<emphasis id="F32C7606EB01DB55D13F441C99BDA6D2" italics="true" pageId="null" pageNumber="593">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="B28E318390B78F05BDFAED5FB77664F8" originalValue="Nordwärts" pageId="null" pageNumber="593">Nordwaerts</normalizedToken>
vereinzelt bis Irland, 
<normalizedToken id="D068035F79034033164B3011630B97E3" originalValue="Südschweden" pageId="null" pageNumber="593">Suedschweden</normalizedToken>
, Lettland, Karpaten, Krim; 
<normalizedToken id="1ADF7B10259611F425FF93ED8ECD0C41" originalValue="Südwestasien" pageId="null" pageNumber="593">Suedwestasien</normalizedToken>
(
<normalizedToken id="11AAEC80B0872FBC1FE7D5C1CE3265E3" originalValue="ostwärts" pageId="null" pageNumber="593">ostwaerts</normalizedToken>
bis Kaukasus); Nordwestafrika. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet: Oberrheinische Tiefebene, Bodenseegebiet (Sipplingen), 
<normalizedToken id="CC205D25D63E9AD50F2D9644EBF7A199" originalValue="Dép" pageId="null" pageNumber="593">Dep</normalizedToken>
. Ain, westliches Savoyen, 
<normalizedToken id="3EE849B122CEE96F37FFFC21D3971202" originalValue="früher" pageId="null" pageNumber="593">frueher</normalizedToken>
bei Genf, Wallis, Aostatal, 
<normalizedToken id="2E62DB198CE5ADF79D3C2C3341FA0705" originalValue="südalpine" pageId="null" pageNumber="593">suedalpine</normalizedToken>
<normalizedToken id="D6405C2915DEA1A8903D1924926EB825" originalValue="Täler" pageId="null" pageNumber="593">Taeler</normalizedToken>
, Vintschgau; selten.
</paragraph>
</subSubSection>
