<taxonomicName id="A2EA84A9FFFCFFC3FF71FE08FDDAFE5A" authority="(Moore, 1877)" baseAuthorityName="Moore" baseAuthorityYear="1877" box="[151,551,474,501]" class="Insecta" family="Noctuidae" genus="Eudocima" kingdom="Animalia" order="Lepidoptera" pageId="20" pageNumber="21" phylum="Arthropoda" rank="species" species="aurantia">
<emphasis id="579E2338FFFCFFC3FF71FE08FDDAFE5A" bold="true" box="[151,551,474,501]" pageId="20" pageNumber="21">
<emphasis id="579E2338FFFCFFC3FF71FE08FE85FE5B" bold="true" box="[151,376,474,501]" italics="true" pageId="20" pageNumber="21">Eudocima aurantia</emphasis>
(
<bibRefCitation id="017B82DBFFFCFFC3FE61FE08FDE3FE5A" author="Moore, F." box="[391,542,474,500]" pageId="20" pageNumber="21" pagination="580 - 632" refId="ref39152" refString="Moore, F. (1877) The lepidopterous fauna of the Andaman and Nicobar Islands. Proceedings of the scientific Meetings of the Zoological Society of London, 1877 (3), 580 - 632, pls. 58 - 60." type="journal article" year="1877">Moore, 1877</bibRefCitation>
