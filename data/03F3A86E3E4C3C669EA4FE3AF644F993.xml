<paragraph id="8BE519783E4C3C679EA4F893F644F8D8" blockId="6.[166,1225,1798,1847]" pageId="6" pageNumber="201">
Рис. 3. 
<taxonomicName id="4C5A62FB3E4C3C679EECF893F051F8F3" authorityName="Luhe" authorityYear="1911" baseAuthorityName="Zeder" baseAuthorityYear="1800" box="[238,531,1798,1820]" class="Palaeacanthocephala" family="Centrorhynchidae" genus="Centrorhynchus" kingdom="Animalia" order="Polymorphida" pageId="6" pageNumber="201" phylum="Acanthocephala" rank="species" species="globocaudatus">
