<subSubSection id="FDD6DD8BEF9DD70B404406EA1A36EF57" pageId="null" pageNumber="248" type="description">
<paragraph id="733C1AB6C8C7F92DD170193B919C9AAE" pageId="null" pageNumber="248">
15-50 cm hoch. Stengel (oft schon im untern Teil) verzweigt, 
<emphasis id="6B382E15988A06827D3A5FCD8C0464C1" italics="true" pageId="null" pageNumber="248">
dicht 
<normalizedToken id="CA37DC7279CF8F11300E210BF7376C72" originalValue="drüsig" pageId="null" pageNumber="248">druesig</normalizedToken>
behaart. 
<normalizedToken id="643464D9081AED69D65C4BD16595F596" originalValue="Blätter" pageId="null" pageNumber="248">Blaetter</normalizedToken>
<normalizedToken id="1C56FFED85046036E76D64DC645C4238" originalValue="drüsig" pageId="null" pageNumber="248">druesig</normalizedToken>
behaart
</emphasis>
, schmal lanzettlich, ganzrandig oder mit einzelnen 
<normalizedToken id="74E03FDF5635DA554004642D10208E6D" originalValue="Zähnen" pageId="null" pageNumber="248">Zaehnen</normalizedToken>
, 
<emphasis id="B82C5D462D93719F15FBB2EF5ADB280F" italics="true" pageId="null" pageNumber="248">6</emphasis>
- 
<emphasis id="8E79E794EAB368D7ED7D488EC81DB3EB" italics="true" pageId="null" pageNumber="248">20mal so lang wie breit.</emphasis>
Unterste 
<normalizedToken id="A7DDC1FF69A82D723FA33C189D459241" originalValue="Blüten" pageId="null" pageNumber="248">Blueten</normalizedToken>
in den Achseln des 
<emphasis id="1CABD00000C34628F16CFD16A4D5FC95" italics="true" pageId="null" pageNumber="248">10. bis 30. Blattpaares.</emphasis>
Kelch 3-4 mm lang, zur Fruchtzeit bis 5 mm lang, 
<emphasis id="49FC36CC63F81B83D176CD6BAD3FE732" italics="true" pageId="null" pageNumber="248">
dicht und 
<normalizedToken id="3B50A36C01D8B7D911EE03FADCC1E8EC" originalValue="drüsig" pageId="null" pageNumber="248">druesig</normalizedToken>
behaart;
</emphasis>
<normalizedToken id="2560974BB36318691B83160FCD306BF2" originalValue="Kelchzähne" pageId="null" pageNumber="248">Kelchzaehne</normalizedToken>
am Grunde 0,8-1,2 mm breit. 
<emphasis id="119B5769C5326D86257263CF23C132C5" italics="true" pageId="null" pageNumber="248">Krone 5</emphasis>
- 
<emphasis id="9CEEBC92F5A0B40EB5E54A39023CCCA1" italics="true" pageId="null" pageNumber="248">6 mm lang, hellgelb</emphasis>
, 
<normalizedToken id="97C1CD3200FF668D8D3C0B6D401FECEE" originalValue="±" pageId="null" pageNumber="248">+/-</normalizedToken>
<emphasis id="6859BBB3BA07A0CF8605B445D39BB98E" italics="true" pageId="null" pageNumber="248">kahl. Frucht 3</emphasis>
- 
<emphasis id="4C089E817A02F4CAA2A5448033750C10" italics="true" pageId="null" pageNumber="248">4 mm lang</emphasis>
, etwas 
<normalizedToken id="F6CDF916E9685C14D91204FAC43D5223" originalValue="kürzer" pageId="null" pageNumber="248">kuerzer</normalizedToken>
als der Kelch, 
<normalizedToken id="9C58F7B8BEE125572C0A25BE945631D8" originalValue="1¼-1½" pageId="null" pageNumber="248">11/4-11/2</normalizedToken>
mal so lang wie breit, etwas behaart. Samen 1,4-1,8 mm lang. - 
<normalizedToken id="209911BC17FA797548AC73EAC3C75687" originalValue="Blüte" pageId="null" pageNumber="248">Bluete</normalizedToken>
: 
<normalizedToken id="093CA07E7BF2184F2E6E35B4F5D6D364" originalValue="Später" pageId="null" pageNumber="248">Spaeter</normalizedToken>
Sommer und 
<normalizedToken id="CCCBDB696E60395F5EBE00FC13DE5917" originalValue="früher" pageId="null" pageNumber="248">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="475093B3B4B11097B0D7AF4879E213F3" pageId="null" pageNumber="248">
<emphasis id="6FB4FCAE16B7543C2D9568175ECE688E" italics="true" pageId="null" pageNumber="248">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="E42BC7CF6FB944A6465618D4EB6EECDA" italics="true" pageId="null" pageNumber="248">48:</emphasis>
Material aus England (Hambler 1955).
</paragraph>
<paragraph id="8773DDD45AC92322512497F4FC80EC05" pageId="null" pageNumber="248">
<emphasis id="33BB08A1A25AB95A73CA1EEAFD757BBD" italics="true" pageId="null" pageNumber="248">Standort.</emphasis>
Kollin und montan. Trockene, lockere 
<normalizedToken id="7B65F3B7E0438F050E7FBD11A2C2A9A6" originalValue="Böden" pageId="null" pageNumber="248">Boeden</normalizedToken>
in warmen Lagen. Lichte 
<normalizedToken id="8B12037768C0AFC54653E3B58BCE900B" originalValue="Föhrenwälder" pageId="null" pageNumber="248">Foehrenwaelder</normalizedToken>
, steinige 
<normalizedToken id="8390A576B00D6F6A868831C8FDE8312F" originalValue="Hänge" pageId="null" pageNumber="248">Haenge</normalizedToken>
. 
<emphasis id="0DACE6A5D7B26F0AAF7B3409FAD3D0BD" italics="true" pageId="null" pageNumber="248">Odontito-Pinetum</emphasis>
Br.-Bl. 1949.
</paragraph>
<paragraph id="7CFE4E11F5AA41A430D4E48EEEC12334" pageId="null" pageNumber="248">
<emphasis id="92253574F4DD73387C13530E12E2135E" italics="true" pageId="null" pageNumber="248">Verbreitung. Westmediterrane Pflanze:</emphasis>
Westalpen, 
<normalizedToken id="D0141AE8A3B7619013BE054F6AD70E24" originalValue="Südfrankreich" pageId="null" pageNumber="248">Suedfrankreich</normalizedToken>
, 
<normalizedToken id="6365B16FA2BC4A25FABF4D92F4A9BD50" originalValue="Süd-" pageId="null" pageNumber="248">Sued-</normalizedToken>
und Mittelspanien, 
<normalizedToken id="CDD0C81D6A762CD56EB40AF43C13DA14" originalValue="Südwestengland" pageId="null" pageNumber="248">Suedwestengland</normalizedToken>
, 
<normalizedToken id="E33D7A1E8D0DA757A7420602034F485C" originalValue="Südirland" pageId="null" pageNumber="248">Suedirland</normalizedToken>
; Nordwestafrika. - Im Gebiet: Savoyen (Vernay in der Maurienne, vgl. Braun-Blanquet 1961), Wallis (Ardon bis Binn), Aostatal (z. B. 
<normalizedToken id="29087BDEAD70B9ABCBB4620E1CA4FC4F" originalValue="Entrèves" pageId="null" pageNumber="248">Entreves</normalizedToken>
); ziemlich selten.
</paragraph>
</subSubSection>
