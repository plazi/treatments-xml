<subSubSection id="E507F3ADFC3C6F2A19B2F4D0EC5920D2" pageId="null" pageNumber="590" type="description">
<paragraph id="0CC2142D1FEC25447F5AC75C27C2D5FB" pageId="null" pageNumber="590">
15-40 cm hoch. Mit langem, unterirdisch verzweigtem Rhizom. Stengel mit 0-2 
<normalizedToken id="C5EBA503BB3ABCB11B39746FFFB20AFE" originalValue="Stengelblättern" pageId="null" pageNumber="590">Stengelblaettern</normalizedToken>
, einfach oder meist im obern Teil verzweigt, 1-5 
<normalizedToken id="3C65B4FE16190515968E54E73405B8DE" originalValue="köpfig" pageId="null" pageNumber="590">koepfig</normalizedToken>
, 
<emphasis id="BA4FCEE5144AF23983E93C48FB849709" italics="true" pageId="null" pageNumber="590">
im obern Teil zerstreut 
<normalizedToken id="EBB70EF0F4E6966BB0CF7B0CEC1C8634" originalValue="weißflockig" pageId="null" pageNumber="590">weissflockig</normalizedToken>
behaart
</emphasis>
(
<emphasis id="AAA01DBA573B54C41D42096DC93B0BCB" italics="true" pageId="null" pageNumber="590">krause, einfache, kaum 0,5 mm lange Haare</emphasis>
), 
<emphasis id="BA521E2FDEF036D044BAE05CF7EECE9D" italics="true" pageId="null" pageNumber="590">sonst kahl</emphasis>
(
<emphasis id="0C0AEE6F56B18D468B4CBCB8F19DC57B" italics="true" pageId="null" pageNumber="590">
ohne Sternhaare, ohne abstehende, gerade, einfache Haare und ohne 
<normalizedToken id="828275C31DE387C2711B46F58F7750F8" originalValue="Drüsenhaare" pageId="null" pageNumber="590">Druesenhaare</normalizedToken>
</emphasis>
). 
<normalizedToken id="ACF71BFA03043BAFA551DFBF71F4C97F" originalValue="Grundständige" pageId="null" pageNumber="590">Grundstaendige</normalizedToken>
<normalizedToken id="9D94F0E769CBA6DF3128205E18FE2371" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
in einer Rosette, 
<emphasis id="D2757CC7C1349672BAD873D67A962AFD" italics="true" pageId="null" pageNumber="590">schmal lanzettlich</emphasis>
, am Grunde 
<normalizedToken id="239EACC9DAEFFF0E4F690C04072581DB" originalValue="allmählich" pageId="null" pageNumber="590">allmaehlich</normalizedToken>
<normalizedToken id="CB9FD107AAF83F9239C0DC4513B5F932" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
, mit einzelnen feinen 
<normalizedToken id="EBC02BA65347FBB22C5C315B93C81A41" originalValue="Zähnen" pageId="null" pageNumber="590">Zaehnen</normalizedToken>
oder 
<emphasis id="5FEE22E524D8B8376AA5F49BE58FB08E" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="51CAC2566C8226D6ADC7A6A634B2F0C8" originalValue="±" pageId="null" pageNumber="590">+/-</normalizedToken>
</emphasis>
ganzrandig, 
<emphasis id="BD82D997775E1BC03867A426A0EC678F" italics="true" pageId="null" pageNumber="590">
die 
<normalizedToken id="0667B12D37A57B6FEBC1555FE72833CE" originalValue="größern" pageId="null" pageNumber="590">groessern</normalizedToken>
10
</emphasis>
- 
<emphasis id="CC610062585F0B5D37EF7F8CC4EE3067" italics="true" pageId="null" pageNumber="590">30mal so lang wie breit</emphasis>
, beiderseits kahl oder (die 
<normalizedToken id="6EB2894F5B38F48E706F0D47AF41994F" originalValue="jüngeren" pageId="null" pageNumber="590">juengeren</normalizedToken>
) zerstreut 
<normalizedToken id="0BA982709154F32F6527498FBF3C6863" originalValue="weißflockig" pageId="null" pageNumber="590">weissflockig</normalizedToken>
behaart, 
<normalizedToken id="583FBF5E5D0AA2A61F76B717E81C1E8E" originalValue="blaugrün" pageId="null" pageNumber="590">blaugruen</normalizedToken>
. 
<normalizedToken id="5DB25C9B2FC611E64A2063F1A37AEE11" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
9-11 mm lang, 
<emphasis id="069E8C8D248ACFCD1A18D7D541E342FE" italics="true" pageId="null" pageNumber="590">2reihig.</emphasis>
<normalizedToken id="682B060DECD0EBEB85758179F7197734" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
fein zugespitzt, zerstreut 
<normalizedToken id="DF4B7F1F02B4FC023518D5D08AA11779" originalValue="weißflockig" pageId="null" pageNumber="590">weissflockig</normalizedToken>
behaart, sonst kahl, 
<emphasis id="6D2490D0B8B81304E4D92A214E767F73" italics="true" pageId="null" pageNumber="590">
die 
<normalizedToken id="39185B3ECC8BBA7CD539B03F9EF3BAAC" originalValue="äußern" pageId="null" pageNumber="590">aeussern</normalizedToken>
nur etwa
</emphasis>
<normalizedToken id="C212433D97956B8988E2E267B85A88D1" originalValue="½" pageId="null" pageNumber="590">1/2</normalizedToken>
<emphasis id="14062D3ED537B8F7478B1A7F1F881BDA" italics="true" pageId="null" pageNumber="590">so lang wie die innern</emphasis>
(
<emphasis id="49C4AB4A3C0E580DC6FF06BE34B9A6E6" italics="true" pageId="null" pageNumber="590">
ohne 
<normalizedToken id="BE97AE44D4A07A0BEA552BFCC8711CCF" originalValue="Übergänge" pageId="null" pageNumber="590">Uebergaenge</normalizedToken>
</emphasis>
). 
<normalizedToken id="964B6CC80D2F7499BEA7AC2BB3DC8DE0" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
hellgelb. 
<normalizedToken id="AD8E5C4E07B78B7DBBC515BC87526C26" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
braun, 3-4 mm lang. 
<taxonomicName id="97D64B788448CA65D6C016FA5ACA9E45" class="Insecta" family="Miridae" genus="Pappus" kingdom="Animalia" order="Hemiptera" pageId="null" pageNumber="590" phylum="Arthropoda" rank="genus">Pappus</taxonomicName>
oft 
<normalizedToken id="0B2AE69E173A41A223478E8AAD59B0CD" originalValue="weiß" pageId="null" pageNumber="590">weiss</normalizedToken>
, 
<emphasis id="FD89320F0FEEA516982E98A60A17A677" italics="true" pageId="null" pageNumber="590">mit biegsamen Pappusborsten</emphasis>
(bei den andern Arten der Gattung 
<normalizedToken id="C2CDCF8F922140BA0A98E6C9DA0EDFCA" originalValue="brüchige" pageId="null" pageNumber="590">bruechige</normalizedToken>
Pappusborsten). - 
<normalizedToken id="AD3B3715E903727B9AA2E5D663F95303" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="0E2064C608905D549B89F4EE7BFED54E" originalValue="früher" pageId="null" pageNumber="590">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="F736E0AF86DD55DA7899358BCEB986AA" pageId="null" pageNumber="590">
<emphasis id="C8A36ECC14659CB637794B93042C89FD" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="6ADD28489F7857B2FF8BBA6830771338" italics="true" pageId="null" pageNumber="590">18:</emphasis>
Material aus dem Wallis (Favarger 1949b), aus dem Piemont (Scannerini 1967).
</paragraph>
<paragraph id="0EB63910DC595E4C7D806A3C29667D8D" pageId="null" pageNumber="590">
<emphasis id="7157FF22E0C05B0E11534723613F8C1B" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Montan und subalpin, seltener (herabgeschwemmt) kollin. Sommertrockene, sandige und steinige, meist kalkhaltige 
<normalizedToken id="ED11D33FDEB2F710744FD9B3D85E2F95" originalValue="Schüttböden" pageId="null" pageNumber="590">Schuettboeden</normalizedToken>
. 
<normalizedToken id="131A54C8CFF24156EBCA2F1A90762BB9" originalValue="Bachgeröll" pageId="null" pageNumber="590">Bachgeroell</normalizedToken>
, 
<normalizedToken id="25B9AD11108948062CC56512ADA3BFAD" originalValue="Schutthänge" pageId="null" pageNumber="590">Schutthaenge</normalizedToken>
, 
<normalizedToken id="8D7BE0647C0AE5A0CB94B40B1A930492" originalValue="Erdanriße" pageId="null" pageNumber="590">Erdanrisse</normalizedToken>
. 
<emphasis id="4F60ED6F9EAB18AC7239E06E166A0DD3" italics="true" pageId="null" pageNumber="590">Myricario-Chondrilletum</emphasis>
Br.-Bl. 1938.
</paragraph>
<paragraph id="9D2A2DFBF04CD8901F2391ED8C3BF722" pageId="null" pageNumber="590">
<emphasis id="D43B2600DD053E7C5D712E20752BF409" italics="true" pageId="null" pageNumber="590">
Verbreitung. Mittel- und 
<normalizedToken id="A2A2B08F93DA05AFBEED79F7CFA02588" originalValue="südeuropäische" pageId="null" pageNumber="590">suedeuropaeische</normalizedToken>
Gebirgspflanze
</emphasis>
(
<emphasis id="9550441A31A7DA68DF5A73BDE70E723F" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="058FDA1BE367AB54DFD78DBBC13FDDF0" originalValue="östlich" pageId="null" pageNumber="590">oestlich</normalizedToken>
</emphasis>
)
<emphasis id="3734E0170861355D9864AFA78734E583" italics="true" pageId="null" pageNumber="590">:</emphasis>
<normalizedToken id="7C277A8231F34E03B4D22B76A8F034C1" originalValue="Südlicher" pageId="null" pageNumber="590">Suedlicher</normalizedToken>
Jura, Alpen, Alpenvorland, Gebirge der Balkanhalbinsel (
<normalizedToken id="5D3D4C0F1BE804CC91A320494CD0A36F" originalValue="südwärts" pageId="null" pageNumber="590">suedwaerts</normalizedToken>
bis Albanien und Mazedonien), Ostkarpaten. - Im Gebiet: Jura (Savoyen, 
<normalizedToken id="1B79E6555DA69059F4AF9C785445C78F" originalValue="Dép" pageId="null" pageNumber="590">Dep</normalizedToken>
. Ain), Alpen und Alpenvorland; ziemlich 
<normalizedToken id="582E02F3A19C2036AC912DF9E10F92DC" originalValue="häufig" pageId="null" pageNumber="590">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
