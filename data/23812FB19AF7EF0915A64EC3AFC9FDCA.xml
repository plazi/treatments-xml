<subSubSection id="A8E95A44DB22E15BBF2950A65E9BE8BF" pageId="null" pageNumber="755" type="description">
<paragraph id="A1BD9F9CE0E741BDD7F47AF387919D64" pageId="null" pageNumber="755">
Unterscheidet sich von der Gattung 
<taxonomicName id="88DD25A6E70F45764F17F1B31EA4D21E" class="Magnoliopsida" family="Thymelaeaceae" genus="Daphne" kingdom="Plantae" order="Malvales" pageId="null" pageNumber="755" phylum="Tracheophyta" rank="genus">
<emphasis id="A61E5396E4B9867BAAC06B8B553B3D37" italics="true" pageId="null" pageNumber="755">Daphne</emphasis>
</taxonomicName>
(S. 752) durch folgende Merkmale: 
<normalizedToken id="5882D036122DD7E01A00C52C58A0BB98" originalValue="Kelchröhre" pageId="null" pageNumber="755">Kelchroehre</normalizedToken>
<normalizedToken id="3E99CE3B374A67677AC514F551017D11" originalValue="krugförmig" pageId="null" pageNumber="755">krugfoermig</normalizedToken>
; Griffel kurz, 
<emphasis id="FDAED24B11AF50704D87C1181952E392" italics="true" pageId="null" pageNumber="755">
aber 
<normalizedToken id="27690A0ED3570B6626FC83D5C27FC199" originalValue="länger" pageId="null" pageNumber="755">laenger</normalizedToken>
als der Narbendurchmesser; Frucht 
<normalizedToken id="48D415E457A3993C2F557788257A1C76" originalValue="trockenhäutig" pageId="null" pageNumber="755">trockenhaeutig</normalizedToken>
, eine 1 
<normalizedToken id="E0E8F92EB205068BE5D2FA96E106D732" originalValue="sämige" pageId="null" pageNumber="755">saemige</normalizedToken>
Kapsel.
</emphasis>
</paragraph>
<paragraph id="D80ABF4326CFE65CAEBA79672158B31D" pageId="null" pageNumber="755">
Die Gattung 
<emphasis id="152E457973DFB0C0A8FEF2FE78E7E373" italics="true" pageId="null" pageNumber="755">
<taxonomicName id="F87984E38C1985B0E8085AF5E3050983" class="Magnoliopsida" family="Thymelaeaceae" genus="Thymelaea" kingdom="Plantae" order="Malvales" pageId="null" pageNumber="755" phylum="Tracheophyta" rank="genus">Thymelaea</taxonomicName>
<normalizedToken id="D69BA89D8DF2B0EA7598D1CFC21BCF55" originalValue="umfaßt" pageId="null" pageNumber="755">umfasst</normalizedToken>
25 vorwiegend mediterrane und 
<normalizedToken id="0B4437D9CA876FAD6E9C0AEA4CA27EB9" originalValue="südwestasiatische" pageId="null" pageNumber="755">suedwestasiatische</normalizedToken>
Arten.
</emphasis>
</paragraph>
