<taxonomicName id="038C43E3D206B66DFB9E5AD0FB5E8316" authority="Zerova &amp; Klymenko, 2018" authorityName="Zerova &amp; Klymenko" authorityYear="2018" box="[1037,1155,1779,1800]" class="Insecta" family="Eurytomidae" genus="Eurytoma" kingdom="Animalia" order="Hymenoptera" pageId="2" pageNumber="231" phylum="Arthropoda" rank="species" species="trjapitzini" status="sp. n.">
<emphasis id="F6F8E472D206B66DFB9E5AD0FB5E8316" box="[1037,1155,1779,1800]" italics="true" pageId="2" pageNumber="231">E. trjapitzini</emphasis>
</taxonomicName>
, 
<taxonomicNameLabel id="EDCB5909D206B66DFB1E5AD1FB1D8316" box="[1165,1216,1778,1800]" pageId="2" pageNumber="231" rank="species">sp. n.</taxonomicNameLabel>
, male; 5 — male, flagellum; 6 — female, hind tibia.
