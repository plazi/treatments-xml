<emphasis id="A1FB239B89879E5A2EB94D889AAC806F" italics="true" pageId="0" pageNumber="1">Camponotus hagensii</emphasis>
</taxonomicName>
<emphasis id="D99F675E0B8E3E0A70BCBB43B2A0A16A" bold="true" pageId="0" pageNumber="1">A</emphasis>
lateral view 
<emphasis id="186103DA0FA150F9044E26D7CA2F605F" bold="true" pageId="0" pageNumber="1">B</emphasis>
