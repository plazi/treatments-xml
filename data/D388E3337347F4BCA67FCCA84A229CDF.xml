<subSubSection id="B55DBF782BAE60694DA3282718F872C6" pageId="null" pageNumber="139" type="description">
<paragraph id="C47F70B986C0B87FD8FAC989D0DE5721" pageId="null" pageNumber="139">
Unterscheidet sich von der Gattung 
<taxonomicName id="0313AE6F4B32E6BA29ACEBC601771EC3" class="Magnoliopsida" family="Brassicaceae" genus="Lepidium" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="139" phylum="Tracheophyta" rank="genus">
<emphasis id="F31D83F4144588F567FB49078B1AFFD0" italics="true" pageId="null" pageNumber="139">Lepidium</emphasis>
</taxonomicName>
(S. 129) durch folgende Merkmale: 
<emphasis id="4146AF5272FAA991844293D75787406E" italics="true" pageId="null" pageNumber="139">
Die nach 
<normalizedToken id="8218CDB9E6A49A5C6734AB3B45D7D57D" originalValue="außen" pageId="null" pageNumber="139">aussen</normalizedToken>
gerichteten 
<normalizedToken id="E9315B560A4266E171B48ADA3128A01A" originalValue="Kronblätter" pageId="null" pageNumber="139">Kronblaetter</normalizedToken>
wenig 
<normalizedToken id="339C99680CD370E6AE23163411E015B5" originalValue="größer" pageId="null" pageNumber="139">groesser</normalizedToken>
</emphasis>
(
<emphasis id="39B527C75829AE09C426FC289A9906D6" italics="true" pageId="null" pageNumber="139">1-1</emphasis>
<normalizedToken id="0041E12D7EE8299E172C9650FB15E8DE" originalValue="½" pageId="null" pageNumber="139">1/2</normalizedToken>
<emphasis id="ABA853F027B6E2567745D5EAA4D57F54" italics="true" pageId="null" pageNumber="139">mal</emphasis>
) 
<emphasis id="6B750306B0CDD74E730806610626019D" italics="true" pageId="null" pageNumber="139">als die nach innen</emphasis>
(
<emphasis id="4F927578B4721C86A8A76BA931CFE216" italics="true" pageId="null" pageNumber="139">
gegen die 
<normalizedToken id="FBD5FCAA6C021AE56B5F88F652A02C07" originalValue="Blütenstandsachse" pageId="null" pageNumber="139">Bluetenstandsachse</normalizedToken>
</emphasis>
) 
<emphasis id="59E304142C93B44DB1E72A8E9B9205DD" italics="true" pageId="null" pageNumber="139">gerichteten</emphasis>
(sonst nur noch bei 
<taxonomicName id="BC7AAF52DD6DE05D899C23C31E4E4595" authority="Kronblaetter" authorityName="Kronblaetter" class="Magnoliopsida" family="Brassicaceae" genus="Iberis" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="139" phylum="Tracheophyta" rank="genus">
<emphasis id="629985A955BA7AE43970103C93282D60" italics="true" pageId="null" pageNumber="139">Iberis</emphasis>
<normalizedToken id="EC37EC6B0449692BD6F54E36A6F656D5" originalValue="Kronblätter" pageId="null" pageNumber="139">Kronblaetter</normalizedToken>
</taxonomicName>
deutlich verschieden lang); 
<emphasis id="1D5A3BCD2146EF954EFCD554D45B8B43" italics="true" pageId="null" pageNumber="139">
<normalizedToken id="3FD54C27EF240D32CAA28428275CC7EC" originalValue="Staubfäden" pageId="null" pageNumber="139">Staubfaeden</normalizedToken>
am Grunde mit stumpfem Zahn; 
<normalizedToken id="8F0473A83D41F753E8CAFC998B51F554" originalValue="Früchte" pageId="null" pageNumber="139">Fruechte</normalizedToken>
4samig
</emphasis>
.
</paragraph>
<paragraph id="5C370EF473EE5B357B4F2DB86CA7E8CF" pageId="null" pageNumber="139">
Die Gattung 
<taxonomicName id="05B3D940EED8E04C568537BE88EC200C" class="Magnoliopsida" family="Brassicaceae" genus="Teesdalia" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="139" phylum="Tracheophyta" rank="genus">
<emphasis id="6D798AD8501E81D248BB6D41C1124647" italics="true" pageId="null" pageNumber="139">Teesdalia</emphasis>
</taxonomicName>
<normalizedToken id="58346F28C36ABA8B7EE2D2CFA30AFB53" originalValue="umfaßt" pageId="null" pageNumber="139">umfasst</normalizedToken>
nur 2 
<emphasis id="0001E5B1DDF12A01728FA48328F284B8" italics="true" pageId="null" pageNumber="139">Arten</emphasis>
und ist 
<emphasis id="31F30B8CE52F4E92FCEF1748DD990988" italics="true" pageId="null" pageNumber="139">
im 
<normalizedToken id="80841D55CBB32C15516BC1DD2F0FB9AD" originalValue="südlichen" pageId="null" pageNumber="139">suedlichen</normalizedToken>
Europa und im Mittelmeergebiet verbreitet.
</emphasis>
</paragraph>
