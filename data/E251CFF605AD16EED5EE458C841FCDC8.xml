<subSubSection id="DC4D131927CADFD58C7194E8B1531BAD" pageId="null" pageNumber="217" type="description">
<paragraph id="D70A8E53A9CFA60E2EDE2F9476AAAAEA" pageId="null" pageNumber="217">
Unterscheidet sich von 
<taxonomicName id="74E96E3FDD3A497955B8DF5A9D5BCB49" class="Magnoliopsida" family="Brassicaceae" genus="Barbarea" kingdom="Plantae" order="Brassicales" pageId="null" pageNumber="217" phylum="Tracheophyta" rank="species" species="verna">
<emphasis id="9EEFFFECFCD5EE1AA70EFCEBCAD50BB3" italics="true" pageId="null" pageNumber="217">B. verna</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 
<normalizedToken id="C49339C1994DDA170331A1FBD65DB5C9" originalValue="Grundständige" pageId="null" pageNumber="217">Grundstaendige</normalizedToken>
<normalizedToken id="B90A51F15708E35A3A2449221F8D7594" originalValue="Blätter" pageId="null" pageNumber="217">Blaetter</normalizedToken>
jederseits mit 1-6 Abschnitten; 
<emphasis id="C8ABC240723DCE66947EF673ACD24A7A" italics="true" pageId="null" pageNumber="217">
<normalizedToken id="670C9D7453041EA9B11D715CFD36D2E1" originalValue="Kelchblätter" pageId="null" pageNumber="217">Kelchblaetter</normalizedToken>
2,5
</emphasis>
- 
<emphasis id="81CB8523385DECB3582FE671CA0D1C03" italics="true" pageId="null" pageNumber="217">
3,5 mm lang; 
<normalizedToken id="572500AC2668B300AB549E412E6FFFD4" originalValue="Kronblätter" pageId="null" pageNumber="217">Kronblaetter</normalizedToken>
4
</emphasis>
- 
<emphasis id="AACC7091D13CA65189EE546ACB87C2F6" italics="true" pageId="null" pageNumber="217">6 mm lang; Fruchtstiele</emphasis>
⅕-1/9 
<emphasis id="56A15B8433291AC117E5206A8A201529" italics="true" pageId="null" pageNumber="217">
so lang wie die 
<normalizedToken id="80415CD4DA54AB04145ECFFD8B00CEAB" originalValue="Früchte" pageId="null" pageNumber="217">Fruechte</normalizedToken>
; 
<normalizedToken id="2F848E13BEE8538A154908F9B0ECC577" originalValue="Früchte" pageId="null" pageNumber="217">Fruechte</normalizedToken>
15
</emphasis>
- 
<emphasis id="9D68E020A0567774CBB086F9F076DD5B" italics="true" pageId="null" pageNumber="217">40 mm lang.</emphasis>
- 
<normalizedToken id="560A79F07D66D18A2C284F4E3AE9064E" originalValue="Blüte" pageId="null" pageNumber="217">Bluete</normalizedToken>
: 
<normalizedToken id="338CDDBAB802A7A9B5EAC4036AEB3482" originalValue="Später" pageId="null" pageNumber="217">Spaeter</normalizedToken>
<normalizedToken id="4B2C476BDB0C335B1A5414E612B77E19" originalValue="Frühling" pageId="null" pageNumber="217">Fruehling</normalizedToken>
und 
<normalizedToken id="20DC7182C59C168435E7ABEB6D027280" originalValue="früher" pageId="null" pageNumber="217">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="D910AFB13483DF60A305D859FAE76FC6" pageId="null" pageNumber="217">
<emphasis id="ABB618EB3FEA133D2E022A968A743286" italics="true" pageId="null" pageNumber="217">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="8E6B4CC96863F3A51941A87F7AB41D30" italics="true" pageId="null" pageNumber="217">16:</emphasis>
Material aus botanischem Garten (Manton 1932).
</paragraph>
<paragraph id="E76A3A4B3BD035EA6F7F409C134EBBC3" pageId="null" pageNumber="217">
<emphasis id="1DDD30816FF23146997BA8B6AF12D94F" italics="true" pageId="null" pageNumber="217">Standort.</emphasis>
Kollin, montan und subalpin. Ziemlich feuchte, 
<normalizedToken id="07696B958D7A9C030BA1227C4A1014CE" originalValue="nährstoffreiche" pageId="null" pageNumber="217">naehrstoffreiche</normalizedToken>
<normalizedToken id="863D4336EBFCCC5827667753BD124325" originalValue="Böden" pageId="null" pageNumber="217">Boeden</normalizedToken>
in 
<normalizedToken id="25EC1976CC1B95F25B77DA7D91961461" originalValue="wärmeren" pageId="null" pageNumber="217">waermeren</normalizedToken>
Lagen. 
<normalizedToken id="28DC2B82D2BF495724F8472CE298627E" originalValue="Schuttplätze" pageId="null" pageNumber="217">Schuttplaetze</normalizedToken>
, Ufer, 
<normalizedToken id="43156FD705440E9DD35C5E2F2FD94851" originalValue="Äcker" pageId="null" pageNumber="217">Aecker</normalizedToken>
.
</paragraph>
<paragraph id="32B9BFD3ABE3D117D7A9BD5162669F61" pageId="null" pageNumber="217">
<emphasis id="8177A4C32CC735FEF72B48938288CBC5" italics="true" pageId="null" pageNumber="217">Verbreitung. Westmediterrane Pflanze:</emphasis>
<normalizedToken id="FDAB42DD0791A439F0DFE3E0C87ACD54" originalValue="Südwesteuropa" pageId="null" pageNumber="217">Suedwesteuropa</normalizedToken>
(nord- und 
<normalizedToken id="E51E06AD963A37BA0428A9E0C26B65BF" originalValue="ostwärts" pageId="null" pageNumber="217">ostwaerts</normalizedToken>
bis Nordfrankreich, Westalpen, Montenegro); Nordwestafrika (Algerien). - Im Gebiet: Von Westen her vereinzelt bis in den Solothurner Jura, ins Oberwallis und ins Aostatal; auch sonst 
<normalizedToken id="4E7DEBF91D9897274E8FC30443C2C35F" originalValue="öfters" pageId="null" pageNumber="217">oefters</normalizedToken>
eingeschleppt und sich ausbreitend.
</paragraph>
</subSubSection>
