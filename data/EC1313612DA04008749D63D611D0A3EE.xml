<subSubSection id="49F5CC6DE980D551DA5C21A626FFCDCD" pageId="null" pageNumber="663" type="vernacular_names">
<paragraph id="0472F39964D39FC867B149B0207F8E69" pageId="null" pageNumber="663">Sand-Weide</paragraph>
</subSubSection>
</title>
<subSubSection id="704BB63AB8DAD56C44A3BDCD1D74B4A3" pageId="null" pageNumber="663" type="description">
<paragraph id="B8F25D82254DB6EC5EDDE4630AE402AC" pageId="null" pageNumber="663">
Habitus und Behaarung der Zweige wie 
<taxonomicName id="67FF37619DB01A239EEBBBA5B194F881" class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="663" phylum="Chordata" rank="species" species="repens">
<emphasis id="6C8B43F00041D23A67F698E770E0D368" italics="true" pageId="null" pageNumber="663">S. repens</emphasis>
</taxonomicName>
(Nr. 12). 
<normalizedToken id="AF444BF1C43532EB98D81F1540AF842B" originalValue="Blätter" pageId="null" pageNumber="663">Blaetter</normalizedToken>
2-3 cm lang, etwa doppelt so lang wie breit, 
<emphasis id="B839340EC724D048B8059813E81022C4" italics="true" pageId="null" pageNumber="663">
oval, mit stumpfer Spitze, seitliche Nerven 4-6, beiderseits dicht anliegend behaart und silberig 
<normalizedToken id="DE7D72B626F598CADB22D2FBAF6DE628" originalValue="glänzend" pageId="null" pageNumber="663">glaenzend</normalizedToken>
</emphasis>
, sonst wie bei 
<taxonomicName id="950DA8B5C2B6AB916A45278B1659EF64" class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="663" phylum="Chordata" rank="species" species="repens">
<emphasis id="ABA57EF31221D906163B453E3E684744" italics="true" pageId="null" pageNumber="663">S. repens</emphasis>
</taxonomicName>
(Nr. 12). 
<normalizedToken id="C56F15F380C19052384702CACD964627" originalValue="Nebenblätter" pageId="null" pageNumber="663">Nebenblaetter</normalizedToken>
(an Langtrieben fast immer vorhanden) 
<emphasis id="DAAD85FA5EF91862593A791304273DCE" italics="true" pageId="null" pageNumber="663">lanzettlich, bis 1 cm lang.</emphasis>
<normalizedToken id="55D928FBC8655760CCD752CEA314A52D" originalValue="Tragblätter" pageId="null" pageNumber="663">Tragblaetter</normalizedToken>
wie bei 
<emphasis id="3FCFA9AE944617DB25EC6054095E36A3" italics="true" pageId="null" pageNumber="663">
<taxonomicName id="FA011D748202AF0CC6842D6C9FE2691C" class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="663" phylum="Chordata" rank="species" species="repens">S. repens</taxonomicName>
. 
<normalizedToken id="38CFC0E558E623EBF7218D0A448B6CF4" originalValue="Staubfäden" pageId="null" pageNumber="663">Staubfaeden</normalizedToken>
am Grunde behaart.
</emphasis>
<normalizedToken id="4B7549309FA97B04BEE9CD47E6F55DB1" originalValue="Früchte" pageId="null" pageNumber="663">Fruechte</normalizedToken>
wie bei 
<emphasis id="42381EADE56D97492E298C13F1E5A9DA" italics="true" pageId="null" pageNumber="663">
<taxonomicName id="2EB43F43532C343CEBA4F3676E23CA8F" class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="663" phylum="Chordata" rank="species" species="repens">S. repens</taxonomicName>
, jedoch dicht behaart
</emphasis>
, Haare 
<normalizedToken id="8D88F97C61DEDA3B9C8679EE04A044A4" originalValue="±" pageId="null" pageNumber="663">+/-</normalizedToken>
gerade.
</paragraph>
<paragraph id="E3B02B801EBC51D72E01237A26EF9554" pageId="null" pageNumber="663">
<emphasis id="BD52333A5C72075D1ED4A2ACAE821CEE" italics="true" pageId="null" pageNumber="663">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="86CE475E8D1E041AA65CABB4342951F0" pageId="null" pageNumber="663">
<emphasis id="2C538334C6779EF5FDE13E043ACD877F" italics="true" pageId="null" pageNumber="663">Standort.</emphasis>
Im Gebiet nicht untersucht.
</paragraph>
<paragraph id="075089379E73CA5E2038A95809635A41" pageId="null" pageNumber="663">
<emphasis id="647942FA2443F1C70AFE9887B98366E5" italics="true" pageId="null" pageNumber="663">Verbreitung</emphasis>
(nicht genau bekannt, da mit 
<taxonomicName id="D83EEEF53691AD07EBFF7ADE913B45F8" authority="Nr." authorityName="Nr." class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="663" phylum="Chordata" rank="species" species="repens">
<emphasis id="AAE55F11DD382C72AC7E3B0537F1E8D5" italics="true" pageId="null" pageNumber="663">S. repens</emphasis>
Nr.
</taxonomicName>
12 und 
<taxonomicName id="E0B8051F19F72481FB8750C3B7765BB9" authority="Nr." authorityName="Nr." class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="663" phylum="Chordata" rank="species" species="rosmarinifolia">
<emphasis id="C5D92C98D8DB2C4B4F71E103839CA158" italics="true" pageId="null" pageNumber="663">S. rosmarinifolia</emphasis>
Nr.
</taxonomicName>
11 
<normalizedToken id="70C78B49464DF63D563ECDFCF3F3D485" originalValue="zusammengefaßt" pageId="null" pageNumber="663">zusammengefasst</normalizedToken>
). 
<emphasis id="619D24CAD60B86BEF3884F66B47AFCB0" italics="true" pageId="null" pageNumber="663">
<normalizedToken id="3F9656E8B37F90B83A0FE90CB36D0A67" originalValue="Westeuropäische" pageId="null" pageNumber="663">Westeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="B95BC76229376C34C6395C38FB7E410A" originalValue="Küstengebiete" pageId="null" pageNumber="663">Kuestengebiete</normalizedToken>
des Atlantik, der Nord- und Ostsee; vereinzelt tiefer in den Kontinent eindringend. - Im Gebiet: Angeblich im Riet bei 
<normalizedToken id="B82AD58FCA67AF7F7DFC7EBBBB17EB65" originalValue="Trüllikon" pageId="null" pageNumber="663">Truellikon</normalizedToken>
und am Egelsee bei Thayngen (Schaffhausen) und Rhonedelta 2 km westlich von Villeneuve (Waadt) (vgl. Bemerkungen bei 
<taxonomicName id="68E824EACEBF4F80020FB894728198ED" authority="Nr." authorityName="Nr." class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="663" phylum="Chordata" rank="species" species="repens">
<emphasis id="1989CF871E0C503E0B654778E40749B4" italics="true" pageId="null" pageNumber="663">S. repens</emphasis>
, Nr.
</taxonomicName>
12)
</paragraph>
<paragraph id="8C8BD1E9FE557AC587314DBAEA72DF73" pageId="null" pageNumber="663">
<emphasis id="2F534BD3347841CE8310205ACB75E22E" italics="true" pageId="null" pageNumber="663">Bemerkungen.</emphasis>
Siehe 
<taxonomicName id="93AE43F4AC7FFAF1E2193E3CF4E52746" class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="663" phylum="Chordata" rank="species" species="repens">
<emphasis id="A7D1B6966C1FD64762D8D8C454D53215" italics="true" pageId="null" pageNumber="663">S. repens</emphasis>
</taxonomicName>
(Nr. 12).
</paragraph>
</subSubSection>
