<taxonomicName id="59D4669555A5C73EDBF096A1CE68276B" authority="L." class="Ascidiacea" family="Polycitoridae" genus="Salix" kingdom="Animalia" order="Aplousobranchia" pageId="null" pageNumber="663" phylum="Chordata" rank="species" species="arenaria">
Salix 
<normalizedToken id="9582C9D81988B8B6AE09134A0BF36A45" originalValue="arenária" pageId="null" pageNumber="663">arenaria</normalizedToken>
<authorityName id="3F56EE933085104D4127315F2F8F9775" pageId="null" pageNumber="663">L.</authorityName>
