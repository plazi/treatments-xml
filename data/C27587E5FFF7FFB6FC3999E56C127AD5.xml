1927. 
<taxonomicName id="8DDC4D70FFF7FFB6FC289A456DBB7B74" authority="PLUMMER" authorityName="PLUMMER" box="[898,1206,1537,1559]" class="Globothalamea" family="Cibicididae" genus="Truncatulina" kingdom="Chromista" order="Rotaliida" pageId="26" pageNumber="40" phylum="Foraminifera" rank="species" species="vulgaris">
