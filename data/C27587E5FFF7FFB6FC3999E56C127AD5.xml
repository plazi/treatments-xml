PLUMMER
</taxonomicName>
, p. 145, pl. 10, fig. 3; pl. 3, fig. 15.
</paragraph>
<paragraph id="4A6336F3FFF7FFB6FC959A786D347B0E" blockId="26.[831,1437,1537,1647]" pageId="26" pageNumber="40">
1986. 
<taxonomicName id="8DDC4D70FFF7FFB6FC289A786DC67B30" authority="(PLUMMER)" baseAuthorityName="PLUMMER" baseAuthorityYear="1927" box="[898,1227,1596,1617]" class="Globothalamea" family="Cibicididae" genus="Cibicidoides" kingdom="Chromista" order="Rotaliida" pageId="26" pageNumber="40" phylum="Foraminifera" rank="species" species="vulgaris">
