<paragraph blockId="58.[1465,2670,723,1342]" box="[1465,2527,919,948]" pageId="58" pageNumber="766">
<emphasis bold="true" box="[1465,1700,919,948]" pageId="58" pageNumber="766">Activity patterns.</emphasis>
