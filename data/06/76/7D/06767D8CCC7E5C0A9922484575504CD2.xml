<subSubSection pageId="0" pageNumber="119" type="type species">
<paragraph pageId="0" pageNumber="119">
<emphasis italics="true" pageId="0" pageNumber="119">Type species.</emphasis>
-
</paragraph>
<paragraph pageId="0" pageNumber="119">
<taxonomicName baseAuthorityName="Brunner von Wattenwyl" baseAuthorityYear="1895" class="Insecta" family="Tettigoniidae" genus="Sanaa" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Sanaa regalis" order="Orthoptera" pageId="0" pageNumber="119" phylum="Arthropoda" rank="species" species="regalis">
