<subSubSection id="64AF72E542AB892162E439B6EB314F6A" pageId="null" pageNumber="528" type="nomenclature">
<paragraph id="9101566BDEA0AEF5CD23AD2957C5E0B2" pageId="null" pageNumber="528">
<taxonomicName id="6EB3C14C7D97E6A6C1BD7D4E778F064C" authority="Thuill." class="Magnoliopsida" family="Fabaceae" genus="Melilotus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="528" phylum="Tracheophyta" rank="species" species="altissimus">
<pageBreakToken id="098DC956DE4DB1A896E4C0AFFDCE3347" pageId="null" pageNumber="528">Melilotus</pageBreakToken>
<normalizedToken id="781A81EFB6D90D261FF2D64F199A4415" originalValue="altíssimus" pageId="null" pageNumber="528">altissimus</normalizedToken>
Thuill.
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="E5FBB55A38342513408D506D672F509E" pageId="null" pageNumber="528" type="vernacular_names">
<paragraph id="07895018B7F7A51A600D224B10A8A5B3" pageId="null" pageNumber="528">Hoher Honigklee</paragraph>
</subSubSection>
</title>
<subSubSection id="466C25E2D10722941D648C918083A24C" pageId="null" pageNumber="528" type="description">
<paragraph id="820F81C0E9328F07A30971FE3983AD08" pageId="null" pageNumber="528">
2 
<normalizedToken id="F228C5360EF55EC8A1CA747580D1B6D9" originalValue="jährig" pageId="null" pageNumber="528">jaehrig</normalizedToken>
, selten ausdauernd; 50-150 cm hoch. 
<normalizedToken id="94A534A18FD913C9486F78A18870C7D9" originalValue="Blütenstand" pageId="null" pageNumber="528">Bluetenstand</normalizedToken>
2-6 cm lang (ohne Stiel), 25-60 
<normalizedToken id="93C1F1207D3328B48596F4ADB15EE3AF" originalValue="blütig" pageId="null" pageNumber="528">bluetig</normalizedToken>
. 
<emphasis id="3C200AB49235ECD48035BCE64E062AFF" italics="true" pageId="null" pageNumber="528">Krone 5-8 mm lang</emphasis>
, gelb; 
<emphasis id="6E198778938DBD6D7AAAD72E06CC7FCF" italics="true" pageId="null" pageNumber="528">
Fahne, 
<normalizedToken id="F09D370A4E0C2D8443473C96A3DE1ADC" originalValue="Flügel" pageId="null" pageNumber="528">Fluegel</normalizedToken>
und Schiffchen etwa gleich lang.
</emphasis>
Frucht 3-5 mm lang, 
<normalizedToken id="AF662B94CF121943ECB9569E88967044" originalValue="hängend" pageId="null" pageNumber="528">haengend</normalizedToken>
, 
<emphasis id="B956BC0E4EB35669C7C873D19E137A0F" italics="true" pageId="null" pageNumber="528">zerstreut und kurz anliegend behaart</emphasis>
, mit netzartigen Rippen, 
<emphasis id="C729059C88D3AF7A7F4065CEC3D6FF60" italics="true" pageId="null" pageNumber="528">meist 2samig. -</emphasis>
<normalizedToken id="2DF7FC2DEFB51BA0C607F8F71E91B777" originalValue="Blüte" pageId="null" pageNumber="528">Bluete</normalizedToken>
: Sommer und 
<normalizedToken id="64153CBD37B0B1763EB4FC4BC66637BA" originalValue="früher" pageId="null" pageNumber="528">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="AA5CFDDA390FA72323261E2F67497470" pageId="null" pageNumber="528">
<emphasis id="FEEBAD490A44CE7DB9E8F91F5F533BEE" italics="true" pageId="null" pageNumber="528">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="39CF03FE8201602BD6774997C8237C57" italics="true" pageId="null" pageNumber="528">16:</emphasis>
Material aus Schleswig-Holstein (Scheerer 1939), aus botanischem Garten (Wipf 1939), Skandinavien (
<normalizedToken id="174F9BB205D994EF789E6CACA1A3542A" originalValue="Löve" pageId="null" pageNumber="528">Loeve</normalizedToken>
und 
<normalizedToken id="FEAC5BCBA772808D1E8DF51705D5E655" originalValue="Löve" pageId="null" pageNumber="528">Loeve</normalizedToken>
1944b).
</paragraph>
<paragraph id="878C6570177CDE0984575AB7E671AA71" pageId="null" pageNumber="528">
<emphasis id="1B8480ECE2E6011D5AFF86D356857A69" italics="true" pageId="null" pageNumber="528">Standort.</emphasis>
Kollin, selten montan. Wechselfeuchte, meist kalkreiche 
<normalizedToken id="944D70C6C417ED2CF84A458ACB5AEEAF" originalValue="Böden" pageId="null" pageNumber="528">Boeden</normalizedToken>
in 
<normalizedToken id="62B2F9238F0CA6161FE2734B1145B2BB" originalValue="wärmeren" pageId="null" pageNumber="528">waermeren</normalizedToken>
Lagen. Riedwiesen (Molinieten), Ufer, Schuttstellen.
</paragraph>
<paragraph id="9D47DC6E64B02BA6CD9F1343EA405B88" pageId="null" pageNumber="528">
<emphasis id="515E884366DB348857F35A136D5BF230" italics="true" pageId="null" pageNumber="528">Verbreitung. Eurasiatische Pflanze:</emphasis>
Europa und Asien (ohne arktische, subarktische und tropische Gebiete); in Nordamerika eingeschleppt. - Im Gebiet verbreitet und ziemlich 
<normalizedToken id="93E1B0281BACA9FF58CE1E424765D4F2" originalValue="häufig" pageId="null" pageNumber="528">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="1AFD9D920C4819C48A790E3AEE68C93F" pageId="null" pageNumber="528">
<emphasis id="9CC58F2FF02DCFC92D3E81C2B2CF198C" italics="true" pageId="null" pageNumber="528">
<pageBreakToken id="CA3B1B8EE38E0DCF99DABB4C5A556213" pageId="null" pageNumber="528">Bemerkungen</pageBreakToken>
.
</emphasis>
Von 
<taxonomicName id="81682D8ABC88E2F95C11F3889A0C3FC0" class="Magnoliopsida" family="Fabaceae" genus="Melilotus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="528" phylum="Tracheophyta" rank="species" species="altissimus">
<emphasis id="BC65DB16900979DF8FE0980156246CE9" italics="true" pageId="null" pageNumber="528">M. altissimus</emphasis>
</taxonomicName>
wird gelegentlich eine Sippe 
<taxonomicName id="D68D094FDCC84FBF4326BBCB0742F7A1" authority="Waldst. et Kit." authorityName="Waldst. et Kit." class="Magnoliopsida" family="Fabaceae" genus="Melilotus" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="528" phylum="Tracheophyta" rank="species" species="macrorrhizus">
<emphasis id="FC3A8AF89FA5ABD14CBAD784068625B3" italics="true" pageId="null" pageNumber="528">M. macrorrhizus</emphasis>
Waldst. et Kit.
</taxonomicName>
abgetrennt. Sie soll sich durch 
<normalizedToken id="FCB128BDCA48D9E261519C27CA984A99" originalValue="Mehrjährigkeit" pageId="null" pageNumber="528">Mehrjaehrigkeit</normalizedToken>
(bis 2,5 cm dicke Wurzeln), kleinere 
<normalizedToken id="4138CCE131E31FAC2DA8CA6D51524C04" originalValue="Blüten" pageId="null" pageNumber="528">Blueten</normalizedToken>
und kleineren Kelch auszeichnen. Eingehendere Untersuchungen 
<normalizedToken id="5F70DE3F116220A3E4C6B6CD0AEFD1CA" originalValue="müssen" pageId="null" pageNumber="528">muessen</normalizedToken>
zeigen, ob diese Sippe abgetrennt werden kann und ob sie im Gebiet auch auftritt.
</paragraph>
</subSubSection>
</treatment>
