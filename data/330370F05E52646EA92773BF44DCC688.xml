<subSubSection id="DCCE9022CB9C55A1C210535BBF1BBF2C" pageId="null" pageNumber="740" type="description">
<paragraph id="F2AFEF2221A58D31AA246D67365F0F07" pageId="null" pageNumber="740">
Unterscheidet sich von 
<taxonomicName id="E99EA1C05C52ED8F105411956D4CE9E1" class="Magnoliopsida" family="Polygonaceae" genus="Polygonum" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="740" phylum="Tracheophyta" rank="species" species="alpinum">
<emphasis id="8A061B93CE71D8F0C458854D30B3D2AF" italics="true" pageId="null" pageNumber="740">P. alpinum</emphasis>
</taxonomicName>
(Nr.8) durch folgende Merkmale: 
<emphasis id="D35F57CE380AEDB78AAAE0025D978DE0" italics="true" pageId="null" pageNumber="740">
1-2m hoch; 
<normalizedToken id="B5BF80BA97A270F5E0B26FBBECCCF107" originalValue="Blätter" pageId="null" pageNumber="740">Blaetter</normalizedToken>
bis 30 cm lang, am Grunde pfeil- oder 
<normalizedToken id="525E4024B1F4DBB9750770C2FE7F3A1F" originalValue="herzförmig" pageId="null" pageNumber="740">herzfoermig</normalizedToken>
;
</emphasis>
Nebenblattscheiden 
<emphasis id="A337E6ACE56A30DECCA602785491FD3D" italics="true" pageId="null" pageNumber="740">
<normalizedToken id="8522B20E8BB905491D07C194EBD1FFCD" originalValue="±" pageId="null" pageNumber="740">+/-</normalizedToken>
</emphasis>
kahl, die obern oft 
<normalizedToken id="632B9CD44173B0D39A7D764A8D7B689B" originalValue="länger" pageId="null" pageNumber="740">laenger</normalizedToken>
als die Internodien, bis 5 cm lang. - 
<normalizedToken id="2CF04C0AE878F23F5952D31F438B844B" originalValue="Blüte" pageId="null" pageNumber="740">Bluete</normalizedToken>
: 
<normalizedToken id="D550E1D11F846D026775576F93C9FE06" originalValue="Später" pageId="null" pageNumber="740">Spaeter</normalizedToken>
Sommer und Herbst.
</paragraph>
<paragraph id="51BFB6003657CBBAF3BE06DE469BD474" pageId="null" pageNumber="740">
<emphasis id="F5EB38305B34FE9C2F19CD414806834D" italics="true" pageId="null" pageNumber="740">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="12AB88CBDBA4013A131A14B6E26CD223" pageId="null" pageNumber="740">
<emphasis id="F250A912D7C2CF5860CC49F72BE57929" italics="true" pageId="null" pageNumber="740">Standort.</emphasis>
Kollin. Verwildert auf 
<normalizedToken id="A7CE7C2FB48CB4C8F9B8C926004F5505" originalValue="Schuttplätzen" pageId="null" pageNumber="740">Schuttplaetzen</normalizedToken>
und in Hecken.
</paragraph>
<paragraph id="A95E35B5EEECF0752C85F38F4B6D3316" pageId="null" pageNumber="740">
<emphasis id="DA923C39AE6EB718AD9EFD29B7B057A3" italics="true" pageId="null" pageNumber="740">
Verbreitung. 
<normalizedToken id="7CEDF8DC9BEFFE45BBC356D90F81BFDD" originalValue="Ursprünglich" pageId="null" pageNumber="740">Urspruenglich</normalizedToken>
Himalajapflanze:
</emphasis>
Als Gartenpflanze besonders im 
<normalizedToken id="798186F20DAF1CBB5F7A78ADC027C9B8" originalValue="Süden" pageId="null" pageNumber="740">Sueden</normalizedToken>
des Gebiets (Tessin) 
<normalizedToken id="992EB91D8F88393DCBB535A6F6AF5BF0" originalValue="häufig" pageId="null" pageNumber="740">haeufig</normalizedToken>
verwildert, sonst selten, z. B. bei Zug, Trogen, Wangs bei Sargans, Malans.
</paragraph>
</subSubSection>
