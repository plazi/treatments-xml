<subSubSection id="82AA347B222F5A684081768B8DB3EA20" pageId="null" pageNumber="152" type="description">
<paragraph id="10C59BD8FAF93DC1365284D136B778EF" pageId="null" pageNumber="152">
Unterscheidet sich von 
<taxonomicName id="7DFDDE797A98425FBCCC0FA924023778" class="Arachnida" family="Thomisidae" genus="Lycopus" kingdom="Animalia" order="Araneae" pageId="null" pageNumber="152" phylum="Arthropoda" rank="species" species="europaeus">
<emphasis id="F3BDD3F2CDBB7D963DAE815D77746903" italics="true" pageId="null" pageNumber="152">
<authorityName id="53EC9D8A2320627EF0BD17E11AA25B44" pageId="null" pageNumber="152">L.</authorityName>
europaeus
</emphasis>
</taxonomicName>
(Nr. 1) durch folgende Merkmale: 60-150 cm hoch; 
<normalizedToken id="604973C23694A1A256D0055BE18E2CE4" originalValue="Blätter" pageId="null" pageNumber="152">Blaetter</normalizedToken>
oval, 
<emphasis id="8A27601BE7D82BE36BDB5CEC3316F500" italics="true" pageId="null" pageNumber="152">
auch in der 
<normalizedToken id="C379FAB6795D5E114D6D7B7D58B0F624" originalValue="Blütenregion" pageId="null" pageNumber="152">Bluetenregion</normalizedToken>
bis nahe an den Mittelnerv fiederteilig, 6
</emphasis>
- 
<emphasis id="1D61D5AED81FD6E07A7C129570588798" italics="true" pageId="null" pageNumber="152">18 cm lang und 3</emphasis>
- 
<emphasis id="9B95DA537B053D2FE07CF971BCC1280F" italics="true" pageId="null" pageNumber="152">7 cm breit;</emphasis>
Einschnitte spitz; untere Blattabschnitte 
<normalizedToken id="675E7EACFD9748D3A1146EEFB91FBD0D" originalValue="schräg" pageId="null" pageNumber="152">schraeg</normalizedToken>
nach vorn gerichtet. Kelch 2,5-3,5 mm lang; 
<emphasis id="780763D596EFB45DDAF98503E7335A90" italics="true" pageId="null" pageNumber="152">
<normalizedToken id="D9EFA026F32C5A7FC7B404B4C7670ED6" originalValue="Kelchzähne" pageId="null" pageNumber="152">Kelchzaehne</normalizedToken>
1,3
</emphasis>
- 
<emphasis id="F8ACB242C2DFA6132F6637F5CC18164F" italics="true" pageId="null" pageNumber="152">
2 mm lang, etwa so lang wie die 
<normalizedToken id="B3E0DC6E892AA7E98AC7ACC362648C07" originalValue="Kelchröhre" pageId="null" pageNumber="152">Kelchroehre</normalizedToken>
;
</emphasis>
Krone 3-4 mm lang. - 
<normalizedToken id="91A871D8CE8399D82AFB33685C1B2321" originalValue="Blüte" pageId="null" pageNumber="152">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="14E271A2E36E52BA65F60FC41FB1B639" pageId="null" pageNumber="152">
<emphasis id="189BA5E6CB86334C158893FA043D81AE" italics="true" pageId="null" pageNumber="152">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="15625F09BEA96025AE4A20F228E9AE3C" italics="true" pageId="null" pageNumber="152">22:</emphasis>
Material aus botanischen 
<normalizedToken id="605ECDFFEB3CB12CD30DD77AE8726965" originalValue="Gärten" pageId="null" pageNumber="152">Gaerten</normalizedToken>
(Ruttle 1932).
</paragraph>
<paragraph id="C757F267C9B19B4F907C1B05C2832988" pageId="null" pageNumber="152">
<emphasis id="68220B9D5EE47D5D5C0B65483610E3B0" italics="true" pageId="null" pageNumber="152">Standort.</emphasis>
Kollin. Zeitweise 
<normalizedToken id="45037E273FEF253F887DD042910CE974" originalValue="überschwemmte" pageId="null" pageNumber="152">ueberschwemmte</normalizedToken>
, 
<normalizedToken id="E312291E077D16FF217F2A5A2B0ADD6D" originalValue="nährstoffreiche" pageId="null" pageNumber="152">naehrstoffreiche</normalizedToken>
, basenreiche, tonige 
<normalizedToken id="32A8397131D91B4D07305EB2D9B0AD2E" originalValue="Böden" pageId="null" pageNumber="152">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="1D5EA32C0228DF7CB19879DBAF09C7AA" originalValue="Auenwälder" pageId="null" pageNumber="152">Auenwaelder</normalizedToken>
(vor allem Weidenauen).
</paragraph>
<paragraph id="58308B1E288BFD1A3B5899773B1AD77F" pageId="null" pageNumber="152">
<emphasis id="83BF15835E2B93A53222A37F9B5320A3" italics="true" pageId="null" pageNumber="152">
Verbreitung. 
<normalizedToken id="37CF40951162BB0732BBB8489BA84149" originalValue="Osteuropäisch-asiatische" pageId="null" pageNumber="152">Osteuropaeisch-asiatische</normalizedToken>
Pflanze:
</emphasis>
Nord- und 
<normalizedToken id="5273AC22897B79C8859DF0670E897E0E" originalValue="westwärts" pageId="null" pageNumber="152">westwaerts</normalizedToken>
bis Ostgalizien, Main, Bodenseegebiet, Piemont; 
<normalizedToken id="C68F718B9EC19634C8761E1449EFF1CD" originalValue="ostwärts" pageId="null" pageNumber="152">ostwaerts</normalizedToken>
bis Altai und Himalaja. - Im Gebiet: Badisches Bodenseegebiet (alte, zu 
<normalizedToken id="309F79D640E48DD53013F7BB6938F199" originalValue="überprüfende" pageId="null" pageNumber="152">ueberpruefende</normalizedToken>
Angaben) und am 
<normalizedToken id="ABD911A28AD73B03158A47C48C97B5BB" originalValue="Südfuß" pageId="null" pageNumber="152">Suedfuss</normalizedToken>
der Alpen, z. B. Domodossola, Val Caleppio, Tagliuno in den Bergamasker Alpen.
</paragraph>
</subSubSection>
