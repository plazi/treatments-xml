<geoCoordinate id="A1A05039FFD46A6BF60D9C391625B19A" degrees="136" direction="east" minutes="47" orientation="longitude" pageId="47" pageNumber="805" precision="925" value="136.78334">136° 47' E</geoCoordinate>
