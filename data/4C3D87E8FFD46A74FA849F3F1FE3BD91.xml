<geoCoordinate id="A1A05039FFD46A6BF6FB9C391787B1B3" box="[2311,2439,2656,2689]" degrees="12" direction="south" minutes="16" orientation="latitude" pageId="47" pageNumber="805" precision="925" value="-12.266666">12° 16’ S</geoCoordinate>
