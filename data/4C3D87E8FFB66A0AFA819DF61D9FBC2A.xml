<paragraph id="C42B36FEFFB66A09FA869ADC19BDB7FB" blockId="77.[1399,2607,3161,3481]" pageId="77" pageNumber="835">
Subgenus 
<taxonomicName id="03944D7DFFB66A09F9F09ADC18D2B790" box="[1548,1746,3205,3234]" class="Mammalia" family="Vespertilionidae" genus="Hesperoptenus" kingdom="Animalia" order="Chiroptera" pageId="77" pageNumber="835" phylum="Chordata" rank="subGenus" subGenus="Milithronycteris">Milithronycteris</taxonomicName>
