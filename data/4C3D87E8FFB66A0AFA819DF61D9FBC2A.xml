<collectingRegion id="0650F81CFFB66A09F7B49A8D16A3B7C3" box="[2120,2211,3284,3313]" country="Malaysia" name="Sabah" pageId="77" pageNumber="835">Sabah</collectingRegion>
); recently recorded from S 
<collectingCountry id="BC83766EFFB66A09FA859AAE1BF8B62A" box="[1401,1528,3319,3352]" name="Thailand" pageId="77" pageNumber="835">Thailand</collectingCountry>
(Kaeng Krachan National Park in 
<collectingRegion id="0650F81CFFB66A09F80C9AAE1724B62A" box="[2032,2340,3319,3352]" country="Thailand" name="Phetchaburi" pageId="77" pageNumber="835">Phetchaburi Province</collectingRegion>
