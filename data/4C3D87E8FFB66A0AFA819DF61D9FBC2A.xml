<taxonomicName id="03944D7DFFB66A09F6F89ADC17B9B790" authorityName="Dobson" authorityYear="1875" box="[2308,2489,3205,3234]" class="Mammalia" family="Vespertilionidae" genus="Glauconycteris" kingdom="Animalia" order="Chiroptera" pageId="77" pageNumber="835" phylum="Chordata" rank="genus">Glauconycteris</taxonomicName>
orsister to 
<taxonomicName id="03944D7DFFB66A09FA629AE91812B7FB" box="[1438,1554,3248,3273]" class="Mammalia" family="Vespertilionidae" genus="Arielulus" kingdom="Animalia" order="Chiroptera" pageId="77" pageNumber="835" phylum="Chordata" rank="genus">Arielulus</taxonomicName>
and 
<taxonomicName id="03944D7DFFB66A09F9A09AE91912B7FB" authorityName="Dobson" authorityYear="1875" box="[1628,1810,3248,3273]" class="Mammalia" family="Vespertilionidae" genus="Glauconycteris" kingdom="Animalia" order="Chiroptera" pageId="77" pageNumber="835" phylum="Chordata" rank="genus">Glauconycteris</taxonomicName>
. Monotypic.
</paragraph>
</subSubSection>
