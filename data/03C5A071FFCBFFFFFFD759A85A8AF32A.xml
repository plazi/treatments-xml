</paragraph>
</subSubSection>
<subSubSection id="C37642ECFFCBFFFFFFD05BF55988FBD1" pageId="38" pageNumber="590" type="multiple">
<paragraph id="8BD31167FFCBFFFFFFD05BF55988FBD1" blockId="38.[108,1321,1020,3262]" pageId="38" pageNumber="590">
<taxonomicName id="4C6C6AE4FFCBFFFFFFD05BF55861FB89" authority="Goldman, 1912" authorityName="Goldman" authorityYear="1912" box="[108,512,1020,1053]" class="Mammalia" family="Echimyidae" genus="Diplomys" kingdom="Animalia" order="Rodentia" pageId="38" pageNumber="590" phylum="Chordata" rank="subSpecies" species="labilis" subSpecies="darlingi">D. l. darlingi Goldman, 1912</taxonomicName>
