<subSubSection id="04D9EFABD260F47BFF4CF969FCBDF88D" box="[151,776,1770,1794]" pageId="4" pageNumber="148" type="type_taxon">
<paragraph id="4C7CBC20D260F47BFF4CF969FCBDF88D" blockId="4.[151,776,1770,1794]" box="[151,776,1770,1794]" pageId="4" pageNumber="148">
<typeStatus id="93780282D260F47BFF4CF969FF7CF88D" box="[151,201,1770,1794]" pageId="4" pageNumber="148">Type</typeStatus>
species: 
<taxonomicName id="8BC3C7A3D260F47BFEFDF969FDC2F88D" authority="(Walker)" baseAuthorityName="Walker" box="[294,631,1770,1794]" class="Insecta" family="Gryllidae" genus="Acanthogryllus" kingdom="Animalia" order="Orthoptera" pageId="4" pageNumber="148" phylum="Arthropoda" rank="species" species="fortipes">
<emphasis id="7EB76032D260F47BFEFDF969FDA1F88D" box="[294,532,1770,1794]" italics="true" pageId="4" pageNumber="148">Acanthogryllus fortipes</emphasis>
(Walker)
</taxonomicName>
