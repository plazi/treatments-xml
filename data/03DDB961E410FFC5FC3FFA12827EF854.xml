<paragraph id="8BCB0877E410FFC2FCC0F98685BEF95A" blockId="18.[811,1456,1553,1762]" pageId="18" pageNumber="107">
<taxonomicName id="4C7473F4E410FFC2FCC0F98684D2F991" authority="Yooprasert, Culham &amp; Utteridge" authorityName="Yooprasert, Culham &amp; Utteridge" authorityYear="2022" box="[813,1451,1553,1577]" class="Magnoliopsida" family="Rubiaceae" genus="Urophyllum" kingdom="Plantae" order="Gentianales" pageId="18" pageNumber="107" phylum="Tracheophyta" rank="species" species="pulchristipulum" status="sp. nov.">
<emphasis id="B900D465E410FFC2FCC0F9868530F991" box="[813,1097,1553,1577]" italics="true" pageId="18" pageNumber="107">Urophyllum pulchristipulum</emphasis>
Yooprasert, Culham &amp; Utteridge
</taxonomicName>
, 
<taxonomicNameLabel id="A233691EE410FFC2FCC2F9BB8201F9FB" box="[815,888,1580,1603]" pageId="18" pageNumber="107" rank="species">sp. nov.</taxonomicNameLabel>
is similar 
<taxonomicName id="4C7473F4E410FFC2FC07F9BB85A8F9FB" authority="C. B. Clarke" authorityName="C. B. Clarke" box="[1002,1233,1579,1603]" class="Magnoliopsida" family="Rubiaceae" genus="Urophyllum" kingdom="Plantae" order="Gentianales" pageId="18" pageNumber="107" phylum="Tracheophyta" rank="species" species="schmidtii">
<emphasis id="B900D465E410FFC2FC07F9BB8524F9FB" box="[1002,1117,1579,1603]" italics="true" pageId="18" pageNumber="107">toU. schmidtii</emphasis>
C.B.Clarke
</taxonomicName>
and 
<taxonomicName id="4C7473F4E410FFC2FB10F9BB8581F9E6" authority="Yooprasert, Culham, Yahara,Tagane &amp; Utteridge" authorityName="Yooprasert, Culham, Yahara, Tagane &amp; Utteridge" authorityYear="2022" class="Magnoliopsida" family="Rubiaceae" genus="Urophyllum" kingdom="Plantae" order="Gentianales" pageId="18" pageNumber="107" phylum="Tracheophyta" rank="species" species="pseudoschmidtii" status="sp. nov.">
<emphasis id="B900D465E410FFC2FB10F9BB84D7F9FB" box="[1277,1454,1579,1603]" italics="true" pageId="18" pageNumber="107">U. pseudoschmidtii</emphasis>
Yooprasert, Culham, Yahara,Tagane &amp; Utteridge
</taxonomicName>
, 
<taxonomicNameLabel id="A233691EE410FFC2FAEDF9D18430F9E5" box="[1280,1353,1606,1629]" pageId="18" pageNumber="107" rank="species">sp. nov.</taxonomicNameLabel>
, but differs in its stipules, which are broadly subcordate, with conspicuous netted veins and abaxially glabrous, whereas in 
<taxonomicName id="4C7473F4E410FFC2FB49F9EB846FF92B" box="[1188,1302,1659,1683]" class="Magnoliopsida" family="Rubiaceae" genus="Urophyllum" kingdom="Plantae" order="Gentianales" pageId="18" pageNumber="107" phylum="Tracheophyta" rank="species" species="schmidtii">
<emphasis id="B900D465E410FFC2FB49F9EB846FF92B" box="[1188,1302,1659,1683]" italics="true" pageId="18" pageNumber="107">U. schmidtii</emphasis>
</taxonomicName>
, they arelinearoblong, have only inconspicuous netted veins and abaxially densely hairy. Its inflorescences are sessile umbellate rather than pedunculate umbellate as always found in 
<taxonomicName id="4C7473F4E410FFC2FBA1F95C85B8F95A" box="[1100,1217,1738,1762]" class="Magnoliopsida" family="Rubiaceae" genus="Urophyllum" kingdom="Plantae" order="Gentianales" pageId="18" pageNumber="107" phylum="Tracheophyta" rank="species" species="schmidtii">
<emphasis id="B900D465E410FFC2FBA1F95C85B8F95A" box="[1100,1217,1738,1762]" italics="true" pageId="18" pageNumber="107">U. schmidtii</emphasis>
</taxonomicName>
.
</paragraph>
</subSubSection>
