<subSubSection id="A14584453210EB3B11B4FDD2103BCF0C" pageId="null" pageNumber="590" type="description">
<paragraph id="3043FDE7573E291A64810A2B624E3ACC" pageId="null" pageNumber="590">
<emphasis id="5ED8EC60BC4599D36BECDDEB059D0AB8" italics="true" pageId="null" pageNumber="590">Stengel meist 6</emphasis>
- 
<emphasis id="1D90E470E7877052CADD5C1BBAA97674" italics="true" pageId="null" pageNumber="590">
20 
<normalizedToken id="64BC7C241E65058566A648083E2296BF" originalValue="köpfig" pageId="null" pageNumber="590">koepfig</normalizedToken>
. 
<normalizedToken id="C044D5F1F9EC515D62C77742383998E9" originalValue="Blätter" pageId="null" pageNumber="590">Blaetter</normalizedToken>
grasartig, meist ganzrandig, 20
</emphasis>
- 
<emphasis id="47D02543C4CBCFB0E6977FF7D62476EB" italics="true" pageId="null" pageNumber="590">
50mal so lang wie breit, zwischen Spreite und Blattgrund kaum 
<normalizedToken id="EA32BA0C7C9C3C88D85869984D5AA4A7" originalValue="verschmälert" pageId="null" pageNumber="590">verschmaelert</normalizedToken>
</emphasis>
(
<emphasis id="263F7346D5B2CF76E0881BA42169E335" italics="true" pageId="null" pageNumber="590">3</emphasis>
- 
<emphasis id="A66ED28A8DE621EAD76904F5868CF335" italics="true" pageId="null" pageNumber="590">6 mm breit</emphasis>
)
<emphasis id="B8034D0DB01EB8C4361BBC02A4482F93" italics="true" pageId="null" pageNumber="590">
. 
<normalizedToken id="419BE0BB27893D8443CA26E5CCB03239" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
9
</emphasis>
- 
<emphasis id="B04C664026CACFD97EB81016F634848D" italics="true" pageId="null" pageNumber="590">
11 mm lang. 
<normalizedToken id="4DBB932F748C7C733031EB2DE70B05CD" originalValue="Hüllblätter" pageId="null" pageNumber="590">Huellblaetter</normalizedToken>
0,8 bis 1,5 mm breit. 
<normalizedToken id="94E4219CA436D25831B5F3278A8F2192" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
gelbbraun.
</emphasis>
- 
<normalizedToken id="66631CD89EBBC41EA8D8B9E9DA312917" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: 
<normalizedToken id="7084E525A4C47ED3E6B0B7139CD52211" originalValue="Später" pageId="null" pageNumber="590">Spaeter</normalizedToken>
Sommer und 
<normalizedToken id="BA6D168F20A7A468A6D1625200B32625" originalValue="früher" pageId="null" pageNumber="590">frueher</normalizedToken>
Herbst.
</paragraph>
<paragraph id="051D214033E963E8A11FEBC6BD1BFE5B" pageId="null" pageNumber="590">
<emphasis id="A01C0BFDE9473DE8C10FB32AFAACFE0F" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="63158BA95975DFD55C0F34D6B9E34143" italics="true" pageId="null" pageNumber="590">18:</emphasis>
Material aus den Julischen Alpen (Favarger 1965).
</paragraph>
<paragraph id="B8B354E9DE246526702541C9D1195A59" pageId="null" pageNumber="590">
<emphasis id="0A7A4F59A3EA79964B1CFE46E4412B87" italics="true" pageId="null" pageNumber="590">Standort.</emphasis>
Kollin und montan, seltener subalpin. Steinige, kalkreiche 
<normalizedToken id="687F1BE789214BDAF9B250CEEA1020A0" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
. Felsspalten, 
<normalizedToken id="FB2532423CEBFC8A859F2165EB583DF7" originalValue="Moränen" pageId="null" pageNumber="590">Moraenen</normalizedToken>
, 
<normalizedToken id="A857B36FFED0392E58860778AAC08180" originalValue="Bachgeröll" pageId="null" pageNumber="590">Bachgeroell</normalizedToken>
.
</paragraph>
<paragraph id="58D4F1FB34BFFF971104CADACC26E366" pageId="null" pageNumber="590">
<emphasis id="758F9A564A5C1A08B67E6A9EE44CDBCB" italics="true" pageId="null" pageNumber="590">Verbreitung. Ostalpen- Pflanze:</emphasis>
Von Piemont 
<normalizedToken id="8838584AF1E4C0D17F6532CF92A9B35D" originalValue="ostwärts" pageId="null" pageNumber="590">ostwaerts</normalizedToken>
bis Kroatien, Nieder- und 
<normalizedToken id="6563D0A9EC0FF2544D0CC84C68760CFA" originalValue="Oberösterreich" pageId="null" pageNumber="590">Oberoesterreich</normalizedToken>
. - Im Gebiet: Valsesia (Varallo), Comerseegebiet, Bergamasker Alpen, Veltlin (Val Malenco, Monte Giumellino), Vintschgau (z. B. 
<normalizedToken id="E9F7C891F1BD7EAB9749F840E9550690" originalValue="Göflan" pageId="null" pageNumber="590">Goeflan</normalizedToken>
); Angaben von Schuls sind 
<normalizedToken id="20CC5DF1375E7854C17A8707632307E7" originalValue="irrtümlich" pageId="null" pageNumber="590">irrtuemlich</normalizedToken>
(vgl. Huber-Morath 1963; dort auch 
<normalizedToken id="989F4724474BB7A6B9A63070B3DFD618" originalValue="Aufzählung" pageId="null" pageNumber="590">Aufzaehlung</normalizedToken>
einzelner Fundstellen im Comerseegebiet).
</paragraph>
</subSubSection>
