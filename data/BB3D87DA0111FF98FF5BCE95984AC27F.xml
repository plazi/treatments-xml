<emphasis id="01E0EADE0111FF9BFF1FCC459CDBC569" bold="true" box="[204,409,1604,1631]" italics="true" pageId="1" pageNumber="215">Celsia tomentosa</emphasis>
<bibRefCitation id="57054B3D0111FF9BFE7BCC459FEFC569" author="Zuccarini, J. G." box="[424,685,1604,1630]" pageId="1" pageNumber="215" pagination="309 - 380" refId="ref4192" refString="Zuccarini, J. G. (1837) Plantarum novarum vel minus cognitarum, quae in horto botanico herbarioque regio Monacensi servantur, fasc. II. Abhandlungen der Mathematisch-Physikalischen Klasse der Koniglich Bayerischen Akademie der Wissenschaften 2: 309 - 380." type="journal article" year="1837">Zuccarini (1837: 330)</bibRefCitation>
</taxonomicName>
.— 
<taxonomicName id="F4944D4F0111FF9BFD1CCC459837C568" authority="Boissier (1879: 336)" authorityName="Boissier" authorityPageNumber="336" authorityYear="1879" box="[719,1397,1604,1631]" class="Magnoliopsida" family="Scrophulariaceae" genus="Verbascum" kingdom="Plantae" order="Lamiales" pageId="1" pageNumber="215" phylum="Tracheophyta" rank="variety" species="graecum" variety="zuccarinii">
<emphasis id="01E0EADE0111FF9BFD1CCC459EF9C569" box="[719,955,1604,1630]" italics="true" pageId="1" pageNumber="215">Verbascum graecum</emphasis>
var. 
<emphasis id="01E0EADE0111FF9BFBD2CC449933C569" box="[1025,1137,1605,1630]" italics="true" pageId="1" pageNumber="215">zuccarinii</emphasis>
<bibRefCitation id="57054B3D0111FF9BFBACCC459837C568" author="Boissier, P. E." box="[1151,1397,1604,1631]" pageId="1" pageNumber="215" pagination="281 - 1276" refId="ref2849" refString="Boissier, P. E. (1879) Flora Orientalis 4 (2). H. Georg, Genevae [Geneve], Basileae [Basel] &amp; Lugduni [Lyon], pp. 281 - 1276." type="book chapter" year="1879">Boissier (1879: 336)</bibRefCitation>
</taxonomicName>
.— 
<taxonomicName id="F4944D4F0111FF9BFA44CC449F08C5B4" authority="(Zucc.) Kuntze (1891: 469)" authorityName="Kuntze" authorityPageNumber="469" authorityYear="1891" baseAuthorityName="Zucc." class="Magnoliopsida" family="Scrophulariaceae" genus="Verbascum" kingdom="Plantae" order="Lamiales" pageId="1" pageNumber="215" phylum="Tracheophyta" rank="species" species="tomentosum">
<emphasis id="01E0EADE0111FF9BFA44CC449C4DC5B5" italics="true" pageId="1" pageNumber="215">V. tomentosum</emphasis>
(Zucc.) 
<bibRefCitation id="57054B3D0111FF9BFEBDCC689F08C5B4" author="Kuntze, O." box="[366,586,1640,1667]" pageId="1" pageNumber="215" pagination="375 - 1011" refId="ref3538" refString="Kuntze, O. (1891) Revisio generum plantarum 2. A. Felix, Leipzig [etc.], pp. 375 - 1011." type="book chapter" year="1891">Kuntze (1891: 469)</bibRefCitation>
</taxonomicName>
, 
<emphasis id="01E0EADE0111FF9BFD86CC689F87C5B5" box="[597,709,1640,1666]" italics="true" pageId="1" pageNumber="215">nom. illeg</emphasis>
., non 
<bibRefCitation id="57054B3D0111FF9BFCD9CC699EB5C5B4" author="Lamarck, J. B. P. A. M." box="[778,1015,1640,1667]" pageId="1" pageNumber="215" refId="ref3566" refString="Lamarck, J. B. P. A. M. (1779) [&quot; 1778 &quot;] Flore francoise 2. L'Imprimerie Royale, Paris, 684 pp." type="book" year="1779">Lamarck (1779: 260)</bibRefCitation>
.— 
<taxonomicName id="F4944D4F0111FF9BFBCACC689DFFC590" authority="(Boiss.) Nyman (1881: 531)" authorityName="Nyman" authorityPageNumber="531" authorityYear="1881" baseAuthorityName="Boiss." class="Magnoliopsida" family="Scrophulariaceae" genus="Verbascum" kingdom="Plantae" order="Lamiales" pageId="1" pageNumber="215" phylum="Tracheophyta" rank="species" species="zuccarinii">
<emphasis id="01E0EADE0111FF9BFBCACC6899E6C5B5" box="[1049,1188,1641,1666]" italics="true" pageId="1" pageNumber="215">V. zuccarinii</emphasis>
(Boiss.) 
<bibRefCitation id="57054B3D0111FF9BFADACC689DFFC590" author="Nyman, C. F." pageId="1" pageNumber="215" pagination="493 - 677" refId="ref3701" refString="Nyman, C. F. (1881) Conspectus Florae Europaeae. 3. Typis Officinae Bohlinianae, Orebro Sueciae, pp. 493 - 677." type="book chapter" year="1881">Nyman (1881: 531)</bibRefCitation>
</taxonomicName>
, 
<emphasis id="01E0EADE0111FF9BFF19CC8C9C26C590" box="[202,356,1676,1703]" italics="true" pageId="1" pageNumber="215">nom. inval.—</emphasis>
<taxonomicName id="F4944D4F0111FF9BFEB7CC8C9E0CC591" authority="(Boiss.) Ferguson (1971: 230)" authorityName="Ferguson" authorityPageNumber="230" authorityYear="1971" baseAuthorityName="Boiss." box="[356,846,1676,1703]" class="Magnoliopsida" family="Scrophulariaceae" genus="Verbascum" kingdom="Plantae" order="Lamiales" pageId="1" pageNumber="215" phylum="Tracheophyta" rank="species" species="zuccarinii">
<emphasis id="01E0EADE0111FF9BFEB7CC8C9CB2C591" box="[356,496,1677,1702]" italics="true" pageId="1" pageNumber="215">V. zuccarinii</emphasis>
(Boiss.) 
<bibRefCitation id="57054B3D0111FF9BFD8BCC8C9E0CC591" author="Ferguson, I. K." box="[600,846,1676,1703]" pageId="1" pageNumber="215" pagination="229 - 233" refId="ref2959" refString="Ferguson, I. K. (1971) Notes on the genus Verbascum (Scrophulariaceae). Flora Europaea Notulae Systematicae ad Floram Europaeam spectantes No. 9. Botanical Journal of the Linnean Society 64: 229 - 233. https: // doi. org / 10.1111 / j. 1095 - 8339.1971. tb 02145. x" type="journal article" year="1971">Ferguson (1971: 230)</bibRefCitation>
</taxonomicName>
, 
<emphasis id="01E0EADE0111FF9BFC89CC8C9E90C591" box="[858,978,1676,1702]" italics="true" pageId="1" pageNumber="215">nom. illeg.</emphasis>
<typeStatus id="EC2F886E0111FF9BFC09CC8C9908C590" box="[986,1098,1677,1703]" pageId="1" pageNumber="215">Lectotype</typeStatus>
(designated here):— 
<collectingCountry id="4B83765C0111FF9BFAE5CC8D98EAC590" box="[1334,1448,1676,1703]" name="Greece" pageId="1" pageNumber="215">GREECE</collectingCountry>
. Lokridos: ‚Zweite Tagesreise v. Negrop. nach Zeitun‘, 
<date id="472A100C0111FF9BFD31CCB09E14C5FD" box="[738,854,1712,1739]" pageId="1" pageNumber="215" value="1833-06">June 1833</date>
, 
<emphasis id="01E0EADE0111FF9BFC8CCCB09E9AC5FD" box="[863,984,1713,1738]" italics="true" pageId="1" pageNumber="215">Berger s.n.</emphasis>
(M-0244375!; isolectotype M-0244376!). 
<figureCitation id="ABAF2A490111FF9BFF5BCCD59D8EC5D9" box="[136,204,1748,1774]" captionStart="FIGURE 2" captionStartId="3.[136,229,2059,2081]" captionTargetBox="[219,1368,281,2035]" captionTargetId="figure-74@3.[219,1368,281,2035]" captionTargetPageId="3" captionText="FIGURE 2. Lectotype of Celsia tomentosa Zucc. kept in M (M-0244375)." figureDoi="http://doi.org/10.5281/zenodo.6418045" httpUri="https://zenodo.org/record/6418045/files/figure.png" pageId="1" pageNumber="215">Fig. 2</figureCitation>
.
</paragraph>
</subSubSection>
<subSubSection id="7B8E65470111FF98FF6ECCF9984AC27F" lastPageId="2" lastPageNumber="216" pageId="1" pageNumber="215" type="discussion">
<paragraph id="332B36CC0111FF98FF6ECCF9984AC27F" blockId="1.[136,1452,1172,2063]" lastBlockId="2.[136,1451,158,329]" lastPageId="2" lastPageNumber="216" pageId="1" pageNumber="215">
<emphasis id="01E0EADE0111FF9BFF6ECCF99C42C425" bold="true" box="[189,256,1784,1810]" pageId="1" pageNumber="215">Notes</emphasis>
:—The original material of 
<taxonomicName id="F4944D4F0111FF9BFDFDCCF99FACC425" authorityName="Zuccarini" authorityYear="1837" box="[558,750,1784,1810]" class="Magnoliopsida" family="Scrophulariaceae" genus="Celsia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Lamiales" pageId="1" pageNumber="215" phylum="Tracheophyta" rank="species" species="tomentosa">
<emphasis id="01E0EADE0111FF9BFDFDCCF99FACC425" box="[558,750,1784,1810]" italics="true" pageId="1" pageNumber="215">Celsia tomentosa</emphasis>
</taxonomicName>
in M consists of 
<specimenCount id="2592FD450111FF9BFC74CCF89909C425" box="[935,1099,1784,1811]" pageId="1" pageNumber="215" type="generic">two specimens</specimenCount>
collected in 
<date id="472A100C0111FF9BFB06CCF89807C425" box="[1237,1349,1784,1811]" pageId="1" pageNumber="215" value="1833-06">
<collectingDate id="576EE9E40111FF9BFB06CCF89807C425" box="[1237,1349,1784,1811]" pageId="1" pageNumber="215" value="1833-06">June 1833</collectingDate>
</date>
by 
<collectingCounty id="DA4A4E400111FF9BFAB8CCF89C5DC400" pageId="1" pageNumber="215">Franz Xaver Berger</collectingCounty>
during his journey to 
<collectingCountry id="4B83765C0111FF9BFDC6CD1D9F26C401" box="[533,612,1820,1846]" name="Greece" pageId="1" pageNumber="215">Greece</collectingCountry>
as a field chaplain of the 
<collectingMunicipality id="D34FACB60111FF9BFC52CD1D9904C401" box="[897,1094,1820,1846]" pageId="1" pageNumber="215">Bavarian Brigade</collectingMunicipality>
(
<bibRefCitation id="57054B3D0111FF9BFB80CD1D9842C400" author="Kalheber, H." box="[1107,1280,1820,1847]" pageId="1" pageNumber="215" pagination="565 - 578" refId="ref3493" refString="Kalheber, H. (2006) Bavarian plant collectors in Greece. 1. Franz Xaver Berger, Franz Zuccarini and Carl Nikolaus Fraas. Willdenowia 36: 565 - 578. https: // doi. org / 10.3372 / wi. 36.36153" type="journal article" year="2006">Kalheber 2006</bibRefCitation>
). 
<location id="364B60170111FF9BFAC2CD1D987FC401" LSID="urn:lsid:plazi:treatment:BB3D87DA0111FF98FF5BCE95984AC27F:364B60170111FF9BFAC2CD1D987FC401" box="[1297,1341,1820,1846]" country="Greece" county="Franz Xaver Berger" municipality="Bavarian Brigade" name="The" pageId="1" pageNumber="215" stateProvince="Voreio Aigaio">The</location>
indistinct handwriting of 
<location id="364B60170111FF9BFEE4CD409CC1C46C" LSID="urn:lsid:plazi:treatment:BB3D87DA0111FF98FF5BCE95984AC27F:364B60170111FF9BFEE4CD409CC1C46C" box="[311,387,1857,1883]" country="Greece" county="Franz Xaver Berger" municipality="Bavarian Brigade" name="Berger" pageId="1" pageNumber="215" stateProvince="Voreio Aigaio">Berger</location>
on the label of the designated 
<typeStatus id="EC2F886E0111FF9BFD33CD419E05C46D" box="[736,839,1856,1882]" pageId="1" pageNumber="215">lectotype</typeStatus>
(
<figureCitation id="ABAF2A490111FF9BFC85CD419ED9C46D" box="[854,923,1856,1882]" captionStart="FIGURE 2" captionStartId="3.[136,229,2059,2081]" captionTargetBox="[219,1368,281,2035]" captionTargetId="figure-74@3.[219,1368,281,2035]" captionTargetPageId="3" captionText="FIGURE 2. Lectotype of Celsia tomentosa Zucc. kept in M (M-0244375)." figureDoi="http://doi.org/10.5281/zenodo.6418045" httpUri="https://zenodo.org/record/6418045/files/figure.png" pageId="1" pageNumber="215">Fig. 2</figureCitation>
) was not fully deciphered by 
<bibRefCitation id="57054B3D0111FF9BFB3DCD4198E9C46D" author="Zuccarini, J. G." box="[1262,1451,1856,1882]" pageId="1" pageNumber="215" pagination="309 - 380" refId="ref4192" refString="Zuccarini, J. G. (1837) Plantarum novarum vel minus cognitarum, quae in horto botanico herbarioque regio Monacensi servantur, fasc. II. Abhandlungen der Mathematisch-Physikalischen Klasse der Koniglich Bayerischen Akademie der Wissenschaften 2: 309 - 380." type="journal article" year="1837">Zuccarini (1837)</bibRefCitation>
who, in the protologue, cited “inter Megaram et Zeitun”. 
<collectorName id="9E61531A0111FF9BFCD3CD649E55C448" box="[768,791,1893,1919]" pageId="1" pageNumber="215">In</collectorName>
fact, 
<collectorName id="9E61531A0111FF9BFC86CD649EE3C448" box="[853,929,1893,1919]" pageId="1" pageNumber="215">Berger</collectorName>
wrote “Negrop.” instead of “Megaram”, hence the 
<emphasis id="01E0EADE0111FF9BFF61CD899C19C495" box="[178,347,1928,1954]" italics="true" pageId="1" pageNumber="215">locus classicus</emphasis>
of the species is between 
<collectorName id="9E61531A0111FF9BFD55CD889FBCC494" box="[646,766,1929,1955]" pageId="1" pageNumber="215">Negropont</collectorName>
(Chalkida) and 
<collectorName id="9E61531A0111FF9BFC65CD899EBDC495" box="[950,1023,1928,1954]" pageId="1" pageNumber="215">Zeitun</collectorName>
(Lamia) in the general vicinity of the ancient city of 
<collectorName id="9E61531A0111FF9BFEFCCDAD9C2FC4F1" box="[303,365,1964,1990]" pageId="1" pageNumber="215">Opus</collectorName>
, what is today the 
<collectingRegion id="F150F82E0111FF9BFDE8CDAD9FD3C4F1" box="[571,657,1964,1990]" country="Greece" name="Voreio Aigaio" pageId="1" pageNumber="215">Aegean</collectingRegion>
coast of 
<collectorName id="9E61531A0111FF9BFD26CDAC9EFDC4F1" box="[757,959,1964,1991]" pageId="1" pageNumber="215">Nomos Fthiotidos</collectorName>
by the town of 
<collectorName id="9E61531A0111FF9BFBBECDAD9988C4F1" box="[1133,1226,1964,1990]" pageId="1" pageNumber="215">Atalanti</collectorName>
, opposite the city of 
<collectorName id="9E61531A0111FF9BFF5BCDD19D8EC4DD" box="[136,204,2000,2026]" pageId="1" pageNumber="215">Limni</collectorName>
on the island of 
<collectorName id="9E61531A0111FF9BFE54CDD19C8AC4DD" box="[391,456,2000,2026]" pageId="1" pageNumber="215">Evvia</collectorName>
(Euboea). 
<collectorName id="9E61531A0111FF9BFD97CDD19F38C4DD" box="[580,634,2000,2026]" pageId="1" pageNumber="215">Both</collectorName>
the words “Negropont” and “Opus” in 
<collectorName id="9E61531A0111FF9BFBE7CDD199D1C4DD" box="[1076,1171,2000,2026]" pageId="1" pageNumber="215">Berger’s</collectorName>
hand are readable on the label of another duplicate (
<emphasis id="01E0EADE0111FF9BFE60CDF49F6ECB39" box="[435,556,2037,2062]" italics="true" pageId="1" pageNumber="215">Berger s.n.</emphasis>
, M-0244374!) which became available to 
<collectorName id="9E61531A0111FF9BFBD7CDF5992DCB39" box="[1028,1135,2036,2062]" pageId="1" pageNumber="215">Zuccarini</collectorName>
only after the publication of 
<taxonomicName id="F4944D4F0112FF98FF5BCA9E9C5EC38F" authorityName="Zuccarini" authorityYear="1837" box="[136,284,159,185]" class="Magnoliopsida" family="Scrophulariaceae" genus="Celsia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Lamiales" pageId="2" pageNumber="216" phylum="Tracheophyta" rank="species" species="tomentosa">
<emphasis id="01E0EADE0112FF98FF5BCA9E9C5EC38F" box="[136,284,159,185]" italics="true" pageId="2" pageNumber="216">C. tomentosa</emphasis>
</taxonomicName>
; it was part of the herbarium of 
<collectorName id="9E61531A0112FF98FD5ACA9F99A0C38F" box="[649,1250,158,185]" pageId="2" pageNumber="216">Philipp Franz Wilhelm Ritter von Zwack-Holzhausen</collectorName>
(1825–1903) that was transferred to M in 1845. 
<collectorName id="9E61531A0112FF98FE0ECAC29CB6C3EA" box="[477,500,195,221]" pageId="2" pageNumber="216">In</collectorName>
his 
<taxonomicName id="F4944D4F0112FF98FDF7CAC39F2EC3EB" box="[548,620,194,220]" class="Magnoliopsida" family="Scrophulariaceae" genus="Celsia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Lamiales" pageId="2" pageNumber="216" phylum="Tracheophyta" rank="genus">
<emphasis id="01E0EADE0112FF98FDF7CAC39F2EC3EB" box="[548,620,194,220]" italics="true" pageId="2" pageNumber="216">Celsia</emphasis>
</taxonomicName>
monograph, however, 
<bibRefCitation id="57054B3D0112FF98FCBCCAC39964C3EA" author="Murbeck, S. S." box="[879,1062,194,221]" pageId="2" pageNumber="216" refId="ref3620" refString="Murbeck, S. S. (1925) Monographie der Gattung Celsia. C. W. K. Gleerup, Lund, 238 pp." type="book" year="1925">Murbeck (1925)</bibRefCitation>
overlooked the citation of “Opus” on the label of the latter specimen and suggested that the plant was collected by 
<location id="364B60170112FF98FBF1CAE69999C237" LSID="urn:lsid:plazi:treatment:BB3D87DA0111FF98FF5BCE95984AC27F:364B60170112FF98FBF1CAE69999C237" box="[1058,1243,230,257]" country="Greece" county="Franz Xaver Berger" municipality="Bavarian Brigade" name="Berger on Evvia" pageId="2" pageNumber="216" stateProvince="Voreio Aigaio">Berger on Evvia</location>
(Euboea). 
<collectorName id="9E61531A0112FF98FA88CAE69830C236" box="[1371,1394,231,257]" pageId="2" pageNumber="216">In</collectorName>
fact, 
<taxonomicName id="F4944D4F0112FF98FF5BCB0A9C4AC213" authorityName="Fraas" authorityYear="1845" box="[136,264,266,292]" class="Magnoliopsida" family="Scrophulariaceae" genus="Verbascum" kingdom="Plantae" order="Lamiales" pageId="2" pageNumber="216" phylum="Tracheophyta" rank="species" species="limnense">
<emphasis id="01E0EADE0112FF98FF5BCB0A9C4AC213" box="[136,264,266,292]" italics="true" pageId="2" pageNumber="216">V. limnense</emphasis>
</taxonomicName>
(= 
<taxonomicName id="F4944D4F0112FF98FEE3CB0A9C87C213" authorityName="Zuccarini" authorityYear="1837" box="[304,453,267,293]" class="Magnoliopsida" family="Scrophulariaceae" genus="Celsia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Lamiales" pageId="2" pageNumber="216" phylum="Tracheophyta" rank="species" species="tomentosa">
<emphasis id="01E0EADE0112FF98FEE3CB0A9C87C213" box="[304,453,267,293]" italics="true" pageId="2" pageNumber="216">C. tomentosa</emphasis>
</taxonomicName>
) was long thought to be an 
<collectorName id="9E61531A0112FF98FCD2CB0B9E21C213" box="[769,867,266,292]" pageId="2" pageNumber="216">Euboean</collectorName>
endemic until corroborative records from mainland 
<collectingCountry id="4B83765C0112FF98FF5BCB2F9D95C27F" box="[136,215,302,328]" name="Greece" pageId="2" pageNumber="216">Greece</collectingCountry>
in the general vicinity of the 
<emphasis id="01E0EADE0112FF98FDF1CB2F9F8BC27F" box="[546,713,302,328]" italics="true" pageId="2" pageNumber="216">locus classicus</emphasis>
of 
<taxonomicName id="F4944D4F0112FF98FD3DCB2E9EC0C27F" authorityName="Zuccarini" authorityYear="1837" box="[750,898,303,329]" class="Magnoliopsida" family="Scrophulariaceae" genus="Celsia" higherTaxonomySource="GBIF" kingdom="Plantae" order="Lamiales" pageId="2" pageNumber="216" phylum="Tracheophyta" rank="species" species="tomentosa">
<emphasis id="01E0EADE0112FF98FD3DCB2E9EC0C27F" box="[750,898,303,329]" italics="true" pageId="2" pageNumber="216">C. tomentosa</emphasis>
</taxonomicName>
were published (
<bibRefCitation id="57054B3D0112FF98FB91CB2F99BEC27F" author="Zografidis, A." box="[1090,1276,302,328]" pageId="2" pageNumber="216" pagination="61 - 66" refId="ref4171" refString="Zografidis, A. (2017) New floristic records in Greece. Parnassiana Archives 5: 61 - 66." type="journal article" year="2017">Zografidis 2017</bibRefCitation>
).
</paragraph>
</subSubSection>
</treatment>
