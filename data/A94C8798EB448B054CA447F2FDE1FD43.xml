<bibRefCitation id="45744B7FEB448B024CFA482EFEF9F7E6" author="Tics, A." box="[214,338,2070,2092]" pageId="3" pageNumber="297" refId="ref5823" refString="Tics, A. (2000) Ziemelu citrons Cido. Jauna auglu kultura. [author's edition], [Pure], 257 pp." type="book" year="2000">Tīcs 2000: 6</bibRefCitation>
