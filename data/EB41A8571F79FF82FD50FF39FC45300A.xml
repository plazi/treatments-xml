Groupe de 
<taxonomicName id="A4E862C21F79FF82FCDEFF39FB3E33F5" authority="Mez" authorityName="Mez" box="[836,1172,215,242]" class="Magnoliopsida" family="Primulaceae" genus="Tapeinosperma" kingdom="Plantae" order="Ericales" pageId="50" pageNumber="329" phylum="Tracheophyta" rank="species" species="ellipticum">
<emphasis id="519CC5531F79FF82FCDEFF39FBF533F5" bold="true" box="[836,1119,215,242]" italics="true" pageId="50" pageNumber="329">Tapeinosperma ellipticum</emphasis>
Mez
</taxonomicName>
