<quantity id="2E379B383F7CFFEBFE65FEA4FE30FEDD" box="[388,464,290,316]" metricMagnitude="-2" metricUnit="m" metricValue="3.2" pageId="73" pageNumber="74" unit="cm" value="3.2">3.2 cm</quantity>
total length (Miller 1986).
