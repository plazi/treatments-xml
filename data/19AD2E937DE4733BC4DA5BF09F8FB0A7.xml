<subSubSection id="0C29BFF932FDE6791933F8661A9F5288" pageId="null" pageNumber="870" type="vernacular_names">
<paragraph id="C39441C500FD8E30F203098A9F94A109" pageId="null" pageNumber="870">Strahlen-Hohlsame</paragraph>
</subSubSection>
</title>
<subSubSection id="CD7FBF96B013DEDD0BC547E4A269505F" pageId="null" pageNumber="870" type="description">
<paragraph id="3B2AF44B5706D7A3FF02C8A729752396" pageId="null" pageNumber="870">
Zipfel der obersten 
<normalizedToken id="15498BEAC614A407009A8A3A0342E849" originalValue="Blätter" pageId="null" pageNumber="870">Blaetter</normalizedToken>
<normalizedToken id="DF54218229554127D99B50F9B533C3EF" originalValue="fadenförmig" pageId="null" pageNumber="870">fadenfoermig</normalizedToken>
. 
<emphasis id="5F09C77BFDC74C88593DF23A1D023F48" italics="true" pageId="null" pageNumber="870">Dolden 1. Ordnung mit 4-7 Dolden 2. Ordnung.</emphasis>
Frucht 3-4 mm hoch und 6-7 mm breit, 
<emphasis id="65D59791C7C03D99EF57BF112580F239" italics="true" pageId="null" pageNumber="870">
unter der Griffelbasis nicht 
<normalizedToken id="A513522B56B77F5FDCC8AE97E01EEA9B" originalValue="erhöht" pageId="null" pageNumber="870">erhoeht</normalizedToken>
, mit fast glatter, undeutlich buckliger 
<normalizedToken id="093CA6FE27A65C0DCEB15DC02E22E8ED" originalValue="Oberfläche" pageId="null" pageNumber="870">Oberflaeche</normalizedToken>
</emphasis>
(10fache 
<normalizedToken id="B3805AFBA47E7065C87AF8EBE5A455D9" originalValue="Vergrößerung" pageId="null" pageNumber="870">Vergroesserung</normalizedToken>
!); 
<emphasis id="6C6D220B945E691FF7EDA9CE07AA63F7" italics="true" pageId="null" pageNumber="870">Griffel 1,5-2 mm lang, 4-5mal so lang wie das flache Griffelpolster.</emphasis>
- 
<normalizedToken id="558AAD330D9C20CA6E0232602DFB2954" originalValue="Blüte" pageId="null" pageNumber="870">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="B31D1FEB9FBCD0CEBE10F3D9D0899C95" pageId="null" pageNumber="870">
<emphasis id="E26CD9F438ECEC903479BF00638649BE" italics="true" pageId="null" pageNumber="870">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="F44644E37FAD69DAAD1D714F987C4300" italics="true" pageId="null" pageNumber="870">22:</emphasis>
Material aus botanischen 
<normalizedToken id="EEA41F26F6A6AE08111390A73E124A0D" originalValue="Gärten" pageId="null" pageNumber="870">Gaerten</normalizedToken>
(Wanscher 1934).
</paragraph>
<paragraph id="6B8D904D45E413A32A7ECD9A533F6ED5" pageId="null" pageNumber="870">
<emphasis id="26BB2CCC71F60059CC829295E41C68AE" italics="true" pageId="null" pageNumber="870">Standort.</emphasis>
Kollin. Trockene, 
<normalizedToken id="0E95F1819E9ECF9244A28C5F2FA1BF47" originalValue="nährstoffreiche" pageId="null" pageNumber="870">naehrstoffreiche</normalizedToken>
<normalizedToken id="987329BF38276A04AA1266B066EA70F0" originalValue="Böden" pageId="null" pageNumber="870">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="6B55249E03743F02E6CDCDF20FE5240C" originalValue="Äcker" pageId="null" pageNumber="870">Aecker</normalizedToken>
, Ruderalstellen.
</paragraph>
<paragraph id="EF7198CCA267787345702559B67619BC" pageId="null" pageNumber="870">
<emphasis id="F45198378F45AEABE62446E220790819" italics="true" pageId="null" pageNumber="870">
Verbreitung. 
<normalizedToken id="6A55FF306F151586BC2E10F5AA31BA8C" originalValue="Südeuropäisch-westasiatische" pageId="null" pageNumber="870">Suedeuropaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
Als Ackerunkraut mit Kulturpflanzen weithin verschleppt. - Im Gebiet in den 
<normalizedToken id="1FD75CECE03718959CDF7BAECA02D719" originalValue="wärmeren" pageId="null" pageNumber="870">waermeren</normalizedToken>
Gegenden; selten und meist 
<normalizedToken id="8D4E6D8497ADA02877F76E10FB966FA9" originalValue="unbeständig" pageId="null" pageNumber="870">unbestaendig</normalizedToken>
.
</paragraph>
</subSubSection>
