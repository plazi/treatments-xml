<subSubSection id="77E3F3662AEBE415D12F634F21288115" pageId="null" pageNumber="458" type="description">
<paragraph id="02F0A43AE311E8B5050AA8B0A9406ADB" pageId="null" pageNumber="458">
<emphasis id="2CD4AD59C8C2804CC55BF78C76380629" italics="true" pageId="null" pageNumber="458">
<normalizedToken id="CE4A3DFD8FD52049A44A7F72EBB1A663" originalValue="Blätter" pageId="null" pageNumber="458">Blaetter</normalizedToken>
beiderseits kahl
</emphasis>
, 1fach oder doppelt 
<normalizedToken id="25E057EBA77E1E3B8482403E25A16729" originalValue="gezähnt" pageId="null" pageNumber="458">gezaehnt</normalizedToken>
; Blattstiele meist ohne Haare, mit 
<normalizedToken id="A4EE18A01EE3950C7C0DDAB6688F427C" originalValue="Stieldrüsen" pageId="null" pageNumber="458">Stieldruesen</normalizedToken>
und oft auch mit 
<normalizedToken id="A963E5488A95582514BD794AD8C7E9C1" originalValue="sichelförmigen" pageId="null" pageNumber="458">sichelfoermigen</normalizedToken>
Stacheln. 
<normalizedToken id="25BC4FA8A3651C755844A71FFEA4D6BA" originalValue="Blütenstiele" pageId="null" pageNumber="458">Bluetenstiele</normalizedToken>
kahl. 
<normalizedToken id="3BDD6C5B2C584B8E0D27B1FD874BD9C5" originalValue="Kelchblätter" pageId="null" pageNumber="458">Kelchblaetter</normalizedToken>
nach der 
<normalizedToken id="FAAF3CF9EAB0894A293481D7826E02ED" originalValue="Blüte" pageId="null" pageNumber="458">Bluete</normalizedToken>
<emphasis id="C1B8C3202040D0A1C52EA6F216F123A8" italics="true" pageId="null" pageNumber="458">aufgerichtet</emphasis>
, bis zur Fruchtreife bleibend.
</paragraph>
<paragraph id="49014B6D058A30B0CCC5BDED49904F51" pageId="null" pageNumber="458">
<emphasis id="EF0F81CF365F9F1B3D1E2F29F9D7B0AC" italics="true" pageId="null" pageNumber="458">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="B9C6EAD8E0FA09380380BD59AB11C30B" italics="true" pageId="null" pageNumber="458">35:</emphasis>
Material aus der Tschechoslowakei (
<normalizedToken id="6A636FEDCCD6C9C274D94D3707FD7DE2" originalValue="Klášterská" pageId="null" pageNumber="458">Klasterska</normalizedToken>
1969).
</paragraph>
<paragraph id="1FFEC66EFBAFECF4E645CE9F516F49E4" pageId="null" pageNumber="458">
<emphasis id="473E9C49BC70395525C2359D1128A6E8" italics="true" pageId="null" pageNumber="458">Standort.</emphasis>
Montan und subalpin. Wie 
<taxonomicName id="01179E8A8501C78E71B2001C7B8D4249" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="458" phylum="Tracheophyta" rank="species" species="canina">
<emphasis id="BDD9A0D2CD3F100C14E6DB4AE411DD68" italics="true" pageId="null" pageNumber="458">R. canina</emphasis>
</taxonomicName>
(Nr. 12a).
</paragraph>
<paragraph id="84E166DA727BB962FC4299F0896ACC90" pageId="null" pageNumber="458">
<emphasis id="44A7D357E05B1E8F724BD334C7EE0663" italics="true" pageId="null" pageNumber="458">Verbreitung.</emphasis>
Wie 
<taxonomicName id="920189F3590178A3AC192F9671B4B483" class="Magnoliopsida" family="Rosaceae" genus="Rosa" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="458" phylum="Tracheophyta" rank="species" species="canina">
<emphasis id="70DE642C3BB1D37BFA82A020A54CF638" italics="true" pageId="null" pageNumber="458">R. canina</emphasis>
</taxonomicName>
(Nr. 12a). - Im Gebiet in den 
<normalizedToken id="1BC8734616897977418C7A13FD2E0E27" originalValue="Gebirgswäldern" pageId="null" pageNumber="458">Gebirgswaeldern</normalizedToken>
<normalizedToken id="42EEABAFA4DF4E67CF5FB7895B3D8474" originalValue="häufig" pageId="null" pageNumber="458">haeufig</normalizedToken>
.
</paragraph>
