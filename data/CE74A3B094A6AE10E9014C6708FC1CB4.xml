<tr id="92F0E0C0FE36D00461AE840D4ACB7BFB" pageId="null" pageNumber="160">
<td id="57A299ABD9E23B370E066390F7E820A3" align="left" pageId="null" pageNumber="160" valign="top">
1. Alle 
<normalizedToken id="40A4120CA9FDF56D211BD1F8E1876293" originalValue="Blätter" pageId="null" pageNumber="160">Blaetter</normalizedToken>
lanzettlich, spitz, mit wenigen, fransenartigen, etwa 0,1 mm langen 
<normalizedToken id="825091060EBCC5CDA64CFAE66DFCDEE3" originalValue="Zähnen" pageId="null" pageNumber="160">Zaehnen</normalizedToken>
</td>
<td id="7F00ADD7A4257C1DA802CD97B4B7E31C" align="left" pageId="null" pageNumber="160" valign="bottom">
<taxonomicName id="47ADD296E76E333358537F17BA8E37CE" class="Lycopodiopsida" family="Selaginellaceae" genus="Selaginella" kingdom="Plantae" order="Selaginellales" pageId="null" pageNumber="160" phylum="Tracheophyta" rank="species" species="selaginoides">
<italic id="C1A42EF7C13BA882C6738F291AE0419C" pageId="null" pageNumber="160">S. Selaginoides</italic>
</taxonomicName>
(Nr. 1)
