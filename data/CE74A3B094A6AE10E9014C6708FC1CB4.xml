</tr>
<tr id="EE7F21F2AEFF4F6C06B1A2DC41749874" pageId="null" pageNumber="160">
<td id="8ECB5B70D2F62B53E20E260B3A1B9D1B" align="left" pageId="null" pageNumber="160" valign="top">
1*. Die 
<normalizedToken id="3B003969E76F278AF9B2CB54E47DC552" originalValue="Blätter" pageId="null" pageNumber="160">Blaetter</normalizedToken>
der beiden 
<normalizedToken id="19BB2E042F6098B5C9D8B0470BAA4F2B" originalValue="äußern" pageId="null" pageNumber="160">aeussern</normalizedToken>
Reihen an den niederliegenden Stengeln oval; alle 
<normalizedToken id="8D624EA90389CF291EE321C37A44CC5E" originalValue="Blätter" pageId="null" pageNumber="160">Blaetter</normalizedToken>
ganzrandig oder mit sehr feinen, 0,03-0,05 mm langen, 
<normalizedToken id="8E9E8626888C265B5EBFBAD0A55C7EB3" originalValue="regelmäßigen" pageId="null" pageNumber="160">regelmaessigen</normalizedToken>
<normalizedToken id="EC4C46406FC8C9787FC9DE79F163CED1" originalValue="Zähnen" pageId="null" pageNumber="160">Zaehnen</normalizedToken>
</td>
<td id="54DEFF5861E279ADA5CD5B56E5C23F02" align="left" pageId="null" pageNumber="160" valign="bottom">
