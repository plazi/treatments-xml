<collectingCountry id="BC83766EFF616ADEFF61953F1EDFB8B5" box="[157,223,870,903]" name="Laos" pageId="154" pageNumber="915">Laos</collectingCountry>
, and EC 
<collectingCountry id="BC83766EFF616ADEFE9D953F1FF3B8B5" box="[353,499,870,903]" name="Cambodia" pageId="154" pageNumber="915">Cambodia</collectingCountry>
