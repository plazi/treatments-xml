<subSubSection id="F2A68E9DC177AF95CD5F7C0E01AC0931" pageId="null" pageNumber="276" type="description">
<paragraph id="0AD2EC401563AF7D20B0CC0B76475328" pageId="null" pageNumber="276">
Unterscheidet sich von 
<taxonomicName id="631276D47772CA525FE90E9D7E549176" class="Magnoliopsida" family="Plantaginaceae" genus="Plantago" kingdom="Plantae" order="Lamiales" pageId="null" pageNumber="276" phylum="Tracheophyta" rank="species" species="atrata">
<emphasis id="D57DD0917757B5460805F2C2250B0CDE" italics="true" pageId="null" pageNumber="276">P. atrata</emphasis>
</taxonomicName>
(Nr. 7) durch folgende Merkmale: In allen Teilen 
<normalizedToken id="151E8E7F4997E400F5F4E546514E71EE" originalValue="größer" pageId="null" pageNumber="276">groesser</normalizedToken>
, 
<emphasis id="ADD44FDE688F88032198A5782F3312E0" italics="true" pageId="null" pageNumber="276">
10 bis 40 cm hoch; Stiel der 
<normalizedToken id="F0684E34467F6ED17EA34F2F147F4388" originalValue="Blütenähre" pageId="null" pageNumber="276">Bluetenaehre</normalizedToken>
, 
<normalizedToken id="0C07E0E96ED5F970ED25E115A7F7C310" originalValue="Blätter" pageId="null" pageNumber="276">Blaetter</normalizedToken>
und 
<normalizedToken id="D18C297C422A4C51D2D6648E74A20FAC" originalValue="Tragblätter" pageId="null" pageNumber="276">Tragblaetter</normalizedToken>
auf dem Mittelnerv anliegend bis abstehend behaart
</emphasis>
(
<emphasis id="0031DFCCADBA02B64D5B82A65B503082" italics="true" pageId="null" pageNumber="276">Haare 0,7</emphasis>
- 
<emphasis id="86B50009DC412526ED1F7FDC85FDFA63" italics="true" pageId="null" pageNumber="276">1,5 mm lang</emphasis>
)
<emphasis id="D6FAEE35E383DE858F834EC099FA1428" italics="true" pageId="null" pageNumber="276">;</emphasis>
<normalizedToken id="459C7D4DDEEF6FD43E65A7AAE6E007C1" originalValue="Tragblätter" pageId="null" pageNumber="276">Tragblaetter</normalizedToken>
farblos; 
<emphasis id="722F2A90BD262EC0F260DA0B39BD7D43" italics="true" pageId="null" pageNumber="276">Krone 3</emphasis>
- 
<emphasis id="DFF7C76E434AEF82B4385A1BCD015598" italics="true" pageId="null" pageNumber="276">5 mm lang;</emphasis>
Samen 3-4 mm lang. - 
<normalizedToken id="3A57BF126E6716A4E144E3E88715BA90" originalValue="Blüte" pageId="null" pageNumber="276">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="3B631EA46859B3C845E46B025AA9626E" pageId="null" pageNumber="276">
<emphasis id="CE2A89A5BAFE7275584EF44A25233544" italics="true" pageId="null" pageNumber="276">
<pageBreakToken id="D1BF4E0049A0E27F1D2DE5A6D8B43AAF" pageId="null" pageNumber="276">Zytologische</pageBreakToken>
Angaben. 2n
</emphasis>
= 
<emphasis id="D50EDDC2DDD595AF26F04DA018FE36C1" italics="true" pageId="null" pageNumber="276">12:</emphasis>
Material aus botanischen 
<normalizedToken id="3EFE0E89C24FD493AFC52325B263A531" originalValue="Gärten" pageId="null" pageNumber="276">Gaerten</normalizedToken>
(Cartier 1970). 
<emphasis id="997DA11FFB5A38BF059283F57D4CD21C" italics="true" pageId="null" pageNumber="276">2n</emphasis>
= 
<emphasis id="2165BDCA29F94EDA5E71867E500CA7F2" italics="true" pageId="null" pageNumber="276">15</emphasis>
+0-1 B-Chromosomen: Material aus den Basses Alpes (Delay 1970). 
<emphasis id="506344510BE57F39B37B4A279B3A6A59" italics="true" pageId="null" pageNumber="276">2n</emphasis>
= 
<emphasis id="D14608BCD7E5DFF26EEC8F452D90FE1B" italics="true" pageId="null" pageNumber="276">24:</emphasis>
Material aus botanischem Garten (McCullagh 1934). 
<emphasis id="326E58486B333F9891E8464C65BE8E74" italics="true" pageId="null" pageNumber="276">2n</emphasis>
= 
<emphasis id="B52B6C1C59F4AC1D757133EDC9AF5849" italics="true" pageId="null" pageNumber="276">36:</emphasis>
Material von 5 Populationen aus den Westalpen (Cartier 1963 1970).
</paragraph>
<paragraph id="CC56C1B479F1F57D7150FE309436242B" pageId="null" pageNumber="276">
<emphasis id="3772AB1A6C14302B8301B4C24B2B801C" italics="true" pageId="null" pageNumber="276">Standort.</emphasis>
Subalpin, selten montan. Trockene, steinige 
<normalizedToken id="2B14CB4AFE5F077785E92D02D9551A8E" originalValue="Böden" pageId="null" pageNumber="276">Boeden</normalizedToken>
. 
<normalizedToken id="A2689D76FD53C458AD5F5884F8C3B805" originalValue="Schutthänge" pageId="null" pageNumber="276">Schutthaenge</normalizedToken>
, grasige 
<normalizedToken id="C91297F03109494BB857131EF3641D51" originalValue="Hänge" pageId="null" pageNumber="276">Haenge</normalizedToken>
.
</paragraph>
<paragraph id="67C6F5FBCF77E840C5B6C3A5E0FEF05A" pageId="null" pageNumber="276">
<emphasis id="6147B5CBA28CE3C3C79390FD92DD01E1" italics="true" pageId="null" pageNumber="276">Verbreitung. Westalpin-apenninische Pflanze:</emphasis>
Nordapennin, Westalpen (
<normalizedToken id="98B5E2637E37A0CC52FEDB264ECFAAB3" originalValue="nordwärts" pageId="null" pageNumber="276">nordwaerts</normalizedToken>
bis Savoyen), Judikarien. - Im Gebiet: Savoyen (Tarentaise, Maurienne).
</paragraph>
</subSubSection>
