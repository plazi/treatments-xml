<taxonomicName id="03944D7DFFC26A7DF76E90D91727BDAB" authorityName="Hill &amp; Harrison" authorityYear="1987" box="[2194,2343,1664,1689]" class="Mammalia" family="Vespertilionidae" genus="Nycticeinops" kingdom="Animalia" order="Chiroptera" pageId="57" pageNumber="815" phylum="Chordata" rank="genus">Nycticeinops</taxonomicName>
