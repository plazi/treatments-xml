<subSubSection id="8C360C8C6DD3CBCDAAD9B38912B098D8" pageId="null" pageNumber="842" type="description">
<paragraph id="13BDF37780AD9CD77ACC65C9ECF5F8F1" pageId="null" pageNumber="842">
Unterscheidet sich von 
<taxonomicName id="B7F31E677316124E1D1B97E826F5D1F4" class="Magnoliopsida" family="Caryophyllaceae" genus="Spergula" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="842" phylum="Tracheophyta" rank="species" species="arvensis">
<emphasis id="61C96225267AF850E4E8089148AA307C" italics="true" pageId="null" pageNumber="842">S. arvensis</emphasis>
</taxonomicName>
(Nr. 1). durch folgende Merkmale: 5-30 cm hoch; Stengel und 
<normalizedToken id="F5015ABC52A6371D288714F0AE8C6F5D" originalValue="Blätter" pageId="null" pageNumber="842">Blaetter</normalizedToken>
kahl oder zerstreut 
<normalizedToken id="359CDACBF177127DC2CE70C89624B416" originalValue="drüsig" pageId="null" pageNumber="842">druesig</normalizedToken>
behaart; 
<normalizedToken id="23492DB00E97D240188B287E21234E37" originalValue="Blätter" pageId="null" pageNumber="842">Blaetter</normalizedToken>
1-2 cm lang, 10-30mal so lang wie breit, 
<emphasis id="7CFEC44FB285F39B0CFAE111FFCF227F" italics="true" pageId="null" pageNumber="842">ohne Furche;</emphasis>
<normalizedToken id="7A2B3EB78D5287391F39085DF4EDD2DB" originalValue="Staubblätter" pageId="null" pageNumber="842">Staubblaetter</normalizedToken>
5; 
<emphasis id="4A1D26F05AE22C486205EE02CE71A47A" italics="true" pageId="null" pageNumber="842">Samen</emphasis>
(
<emphasis id="95981BA4B79F2CEF1E4C8BDEBF9F3DA8" italics="true" pageId="null" pageNumber="842">inkl. Rand</emphasis>
) 
<emphasis id="11B89B7441D69CCEB85D1AF3426B3524" italics="true" pageId="null" pageNumber="842">
2-3 mm im Durchmesser, mit 0,5-0,8 mm breitem, 
<normalizedToken id="2E951C2D7145FE9BDEC97018C7391519" originalValue="weiβ" pageId="null" pageNumber="842">weiβ</normalizedToken>
durchsichtigem, 
<normalizedToken id="0F469B338381E1EC212881EC8353E406" originalValue="häutigem" pageId="null" pageNumber="842">haeutigem</normalizedToken>
Rand.
</emphasis>
- 
<normalizedToken id="44395EC739411EB7CC6867C79FAC7E1A" originalValue="Blüte" pageId="null" pageNumber="842">Bluete</normalizedToken>
: 
<normalizedToken id="3405320CE5B8D02E515E97BCE2D909F2" originalValue="Später" pageId="null" pageNumber="842">Spaeter</normalizedToken>
<normalizedToken id="BA1AFFED7E89F4F089A527D7B2469BA7" originalValue="Frühling" pageId="null" pageNumber="842">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="4607533EEFF7A6BCE61B5D30F00DA9A2" pageId="null" pageNumber="842">
<emphasis id="B130ECCAF66A301DF185E187CC054EAB" italics="true" pageId="null" pageNumber="842">Zytologische Angaben.</emphasis>
Keine Untersuchungen.
</paragraph>
<paragraph id="142E52202364E2BA991D8E6D17EB751A" pageId="null" pageNumber="842">
<emphasis id="2031F246817975415C19DB3E0FADEF29" italics="true" pageId="null" pageNumber="842">Standort.</emphasis>
Kollin. Offene, trockene, kalkarme, sandige 
<normalizedToken id="E41F3FC07FEFDC20DA7CA172D04730CE" originalValue="Böden" pageId="null" pageNumber="842">Boeden</normalizedToken>
in warmen Lagen. Trockenrasen.
</paragraph>
<paragraph id="7055E9756C16047F3AA918FAE8BAD79D" pageId="null" pageNumber="842">
<emphasis id="7F262E6AC37A95208496A4BD8A036D8C" italics="true" pageId="null" pageNumber="842">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="239B226C1782DD2A609B4565DC26DBAF" originalValue="Südeuropa" pageId="null" pageNumber="842">Suedeuropa</normalizedToken>
(
<normalizedToken id="830C9C0A101D65079F2C4F0FE7A5D22E" originalValue="nordwärts" pageId="null" pageNumber="842">nordwaerts</normalizedToken>
vereinzelt bis Belgien, Norddeutschland, 
<normalizedToken id="C97C6E7F588E29C48E0A4C9054030321" originalValue="Südpolen" pageId="null" pageNumber="842">Suedpolen</normalizedToken>
); Kleinasien; Algerien. -Im Gebiet: 
<normalizedToken id="DBED847BE67D67AC66B2D15DF5306E08" originalValue="Dép" pageId="null" pageNumber="842">Dep</normalizedToken>
. Ain und 
<normalizedToken id="C70E6AD718D8FD0D11135953C2E52205" originalValue="Dép" pageId="null" pageNumber="842">Dep</normalizedToken>
. Doubs (
<normalizedToken id="8BEFDCB2A132DA580CD93BDE5E64CD21" originalValue="Montbéliard" pageId="null" pageNumber="842">Montbeliard</normalizedToken>
), 
<normalizedToken id="B7A4EC79079FA91192D4264CBC232732" originalValue="Elsaß" pageId="null" pageNumber="842">Elsass</normalizedToken>
(
<normalizedToken id="260077D8DE49CF3CE747873EE044C72E" originalValue="Härtlein-Rothleible" pageId="null" pageNumber="842">Haertlein-Rothleible</normalizedToken>
); selten.
</paragraph>
</subSubSection>
