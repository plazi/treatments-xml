<taxonomicName id="03944D7DFF856A3AF76693BE1681BD1D" authority="Sody, 1936" authorityName="Sody" authorityYear="1936" class="Mammalia" family="Vespertilionidae" genus="Scotophilus" kingdom="Animalia" order="Chiroptera" pageId="126" pageNumber="885" phylum="Chordata" rank="subSpecies" species="temmincki" subSpecies="collinus">Scotophilus temmincki collinus Sody, 1936</taxonomicName>
