NW &amp; C Borneo, W 
<collectingRegion id="0650F81CFF856A3AF6139123142DBCA1" box="[2543,2605,1914,1939]" country="Indonesia" name="Jawa Timur" pageId="126" pageNumber="885">Java</collectingRegion>
