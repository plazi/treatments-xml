Anteon hirashimai Olmi 1993b: 84 (new name); Xu et al. 
<quantity id="C731ABA48E21FFAF4AD35477FC87FC81" box="[739,802,859,881]" metricMagnitude="0" metricUnit="kg" metricValue="2.011" pageId="111" pageNumber="112" unit="g" value="2011.0">2011g</quantity>
