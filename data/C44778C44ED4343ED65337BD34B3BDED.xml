<subSubSection id="10BAAED4F6B8AD86FEDF97ED5BD5E3D5" pageId="null" pageNumber="248" type="description">
<paragraph id="F2863EB073A4A9F9DF937F1698B0897C" pageId="null" pageNumber="248">
2 
<normalizedToken id="8F566E34AFB1AD81A0945C4ADBC02ECA" originalValue="jährig" pageId="null" pageNumber="248">jaehrig</normalizedToken>
, mit Pfahlwurzel; 50-150 cm hoch. Stengel aufrecht verzweigt, kahl. 
<normalizedToken id="254E6EC4A06150599C4AD0A5322CA724" originalValue="Blätter" pageId="null" pageNumber="248">Blaetter</normalizedToken>
mit 
<normalizedToken id="C87F0C5F9005E04119EF889E446EC4DF" originalValue="allmählich" pageId="null" pageNumber="248">allmaehlich</normalizedToken>
<normalizedToken id="DDAB9CEA1620E6A715026942419C39E2" originalValue="verschmälertem" pageId="null" pageNumber="248">verschmaelertem</normalizedToken>
Grunde sitzend, 
<emphasis id="B115D7233058C1397FE9992DB6B8497A" italics="true" pageId="null" pageNumber="248">ungeteilt, schmal lanzettlich</emphasis>
, ohne knorpelige 
<normalizedToken id="8D96F306354046943EA3C34B24F4EE45" originalValue="Zähne" pageId="null" pageNumber="248">Zaehne</normalizedToken>
, kahl. 
<normalizedToken id="534B0FDD877935132588EFA5EAF9DF43" originalValue="Blütentrauben" pageId="null" pageNumber="248">Bluetentrauben</normalizedToken>
40- bis 
<normalizedToken id="50957E4784D535D0FF5ED4B4BE866F54" originalValue="über" pageId="null" pageNumber="248">ueber</normalizedToken>
200 
<normalizedToken id="0B5036E72A80926AFD63920585179AC6" originalValue="blütig" pageId="null" pageNumber="248">bluetig</normalizedToken>
. Tragblatt 2-3 mm lang. 
<emphasis id="BB71789E4C6D5828FAEE5B28D350B6B4" italics="true" pageId="null" pageNumber="248">
<normalizedToken id="736543610B768781ADE2B82FBC5F1E57" originalValue="Blütenstiel" pageId="null" pageNumber="248">Bluetenstiel</normalizedToken>
0,5
</emphasis>
- 
<emphasis id="55F027226AEE1B223410A744E3A4EA8D" italics="true" pageId="null" pageNumber="248">
1 mm lang. 
<normalizedToken id="C466A86283A226046D2F1912F4363838" originalValue="Kelchblätter" pageId="null" pageNumber="248">Kelchblaetter</normalizedToken>
4, 1,5
</emphasis>
- 
<emphasis id="23734E4ED77F041F382BF800BB27C234" italics="true" pageId="null" pageNumber="248">2 mm lang und fast 1 mm breit</emphasis>
, zur Fruchtzeit kaum 
<normalizedToken id="AFCE4890B6599DCFF9D3288A229C9C09" originalValue="länger" pageId="null" pageNumber="248">laenger</normalizedToken>
. 
<normalizedToken id="DF947D2C798D0A01CA31B7333518AA9C" originalValue="Kronblätter" pageId="null" pageNumber="248">Kronblaetter</normalizedToken>
4, hellgelb, 
<emphasis id="F825B91699716FB04518B6D321881079" italics="true" pageId="null" pageNumber="248">das oberste 3,5</emphasis>
- 
<emphasis id="D3B2B05C44DEE35341B02842F1FB2386" italics="true" pageId="null" pageNumber="248">5 mm lang, mit 4</emphasis>
- 
<emphasis id="4CEB7504303A2137A40EA2A94812AA35" italics="true" pageId="null" pageNumber="248">5 Zipfeln</emphasis>
, die seitlichen mit 3 Zipfeln, das unterste meist ungeteilt. 
<normalizedToken id="6A700E08C6C071F9131959EEFB8A0E7A" originalValue="Staubblätter" pageId="null" pageNumber="248">Staubblaetter</normalizedToken>
zahlreich, mit 
<normalizedToken id="2EF2E20DC616BA849C518F0BE876ED29" originalValue="fadenförmigen" pageId="null" pageNumber="248">fadenfoermigen</normalizedToken>
<normalizedToken id="E62EBBB49141B55E36396C499404E87F" originalValue="Staubfäden" pageId="null" pageNumber="248">Staubfaeden</normalizedToken>
. Frucht aufrecht, 3-4 mm lang und 1- 
<normalizedToken id="E22E47AF35A09719A177CDA28FE8ECF5" originalValue="1½" pageId="null" pageNumber="248">11/2</normalizedToken>
mal so dick, 3 
<normalizedToken id="DF710EF53182EC305FE87BCFADC7279C" originalValue="blättrig" pageId="null" pageNumber="248">blaettrig</normalizedToken>
(3 Narben). Samen 
<normalizedToken id="B1F619BA896852B5583EEEC7253CC5B0" originalValue="glänzend" pageId="null" pageNumber="248">glaenzend</normalizedToken>
, glatt, 0,8-1 mm lang. - 
<normalizedToken id="703D9A0D9E21CE9043EBC2A1C8493517" originalValue="Blüte" pageId="null" pageNumber="248">Bluete</normalizedToken>
: Sommer und Herbst.
</paragraph>
<paragraph id="0CBE373D8341DB2C3465A834436305F0" pageId="null" pageNumber="248">
<emphasis id="316DD5694AAD09D9540CC0E32F58BD81" italics="true" pageId="null" pageNumber="248">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="3C43FED8D729F048863E03586CBEE30E" italics="true" pageId="null" pageNumber="248">24:</emphasis>
Material aus Osteuropa (Oksijuk aus 
<normalizedToken id="6EF267054D3966DBB1627D44D9BA4F7A" originalValue="Löve" pageId="null" pageNumber="248">Loeve</normalizedToken>
und 
<normalizedToken id="BF27597226BA9AAF4CF10448F44050B3" originalValue="Löve" pageId="null" pageNumber="248">Loeve</normalizedToken>
1961), aus botanischen 
<normalizedToken id="381048B542F943A544D02EA4641A8247" originalValue="Gärten" pageId="null" pageNumber="248">Gaerten</normalizedToken>
(Eigsti 1936), von den Kanaren (Larsen 1960a). 
<emphasis id="89061C500A3D62C662763A5DB96754AD" italics="true" pageId="null" pageNumber="248">2n</emphasis>
= 
<emphasis id="308A4E4BE0FD49CB33B9DFE1E54B1D1D" italics="true" pageId="null" pageNumber="248">26:</emphasis>
Material aus botanischen 
<normalizedToken id="ADFD6393B44550A0D63FEB71140B2FFD" originalValue="Gärten" pageId="null" pageNumber="248">Gaerten</normalizedToken>
(Eigsti 1936). 
<emphasis id="47C2CCA95DF68A3525E3DEC598DCF83E" italics="true" pageId="null" pageNumber="248">2n</emphasis>
= 
<emphasis id="3EA8C619FCE6FDEC8B9ACABF8CFE3636" italics="true" pageId="null" pageNumber="248">28:</emphasis>
Material aus Skandinavien (
<normalizedToken id="BAD362B8221767731196071C9D0A90CE" originalValue="Löve" pageId="null" pageNumber="248">Loeve</normalizedToken>
und 
<normalizedToken id="598B83C2E17A42EA70C66C6F407F6C13" originalValue="Löve" pageId="null" pageNumber="248">Loeve</normalizedToken>
1944b).
</paragraph>
<paragraph id="069425366A04F78E82E53AEB40F68877" pageId="null" pageNumber="248">
<emphasis id="B6FE0F19C5FE475EE3B8E6B70785465F" italics="true" pageId="null" pageNumber="248">Standort.</emphasis>
Kollin, seltener montan. Ziemlich trockene, kalkhaltige, 
<normalizedToken id="AE9AAE79C9DBC664933498CEA03F89C7" originalValue="nährstoffreiche" pageId="null" pageNumber="248">naehrstoffreiche</normalizedToken>
<normalizedToken id="347B936105030095199C51B3C4DB2212" originalValue="Böden" pageId="null" pageNumber="248">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="FE27D30BBD4D218605EC417588E54A58" originalValue="Schuttplätze" pageId="null" pageNumber="248">Schuttplaetze</normalizedToken>
, 
<normalizedToken id="247158089B2F65599E0216CD73104EC0" originalValue="Lägerstellen" pageId="null" pageNumber="248">Laegerstellen</normalizedToken>
, 
<normalizedToken id="2811FC2DB1C956993F68BD4BE883A3BE" originalValue="Wegränder" pageId="null" pageNumber="248">Wegraender</normalizedToken>
, Bahnareale. Besonders im 
<emphasis id="677F2278FB58E0FD3EC140DED03DC442" italics="true" pageId="null" pageNumber="248">Onopordetum acanthii</emphasis>
Br.-Bl. 1922.
</paragraph>
<paragraph id="6A9A693E37C18D3C0B13533B3DE2FC2F" pageId="null" pageNumber="248">
<emphasis id="9428F754582ECE63F9953DDDC49DDCA6" italics="true" pageId="null" pageNumber="248">Verbreitung. Mediterrane Pflanze:</emphasis>
<normalizedToken id="1C3CD90747FE256F65B5E1A0CBD977FA" originalValue="Südeuropa" pageId="null" pageNumber="248">Suedeuropa</normalizedToken>
(
<normalizedToken id="B1FDDC12F07B0404C065C345E0FDAB65" originalValue="nordwärts" pageId="null" pageNumber="248">nordwaerts</normalizedToken>
teilweise verschleppt bis England und 
<normalizedToken id="C66F5BE9CA0EC385C1000A518A82ACBF" originalValue="Südskandinavien" pageId="null" pageNumber="248">Suedskandinavien</normalizedToken>
, 
<normalizedToken id="4D3379FF2AF7BA022948C61591F5CADE" originalValue="früher" pageId="null" pageNumber="248">frueher</normalizedToken>
auch als 
<normalizedToken id="B3584FF0C8B972937549C2D913C8CF64" originalValue="Färberpflanze" pageId="null" pageNumber="248">Faerberpflanze</normalizedToken>
kultiviert); Westasien; Nordafrika; in Amerika eingeschleppt. Verbreitungskarte von Meusel et al. (1965). - Im Gebiet besonders in den 
<normalizedToken id="E7B8C3A28EB0533C5F36B773E506B90E" originalValue="wärmeren" pageId="null" pageNumber="248">waermeren</normalizedToken>
Gegenden; zerstreut, nicht 
<normalizedToken id="9379C7CD019B8664567399CA084795D9" originalValue="häufig" pageId="null" pageNumber="248">haeufig</normalizedToken>
.
</paragraph>
</subSubSection>
