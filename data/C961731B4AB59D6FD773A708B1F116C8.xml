<subSubSection id="17FC5EE8FFD5CDEDAE2735DE4BCDE7EF" pageId="null" pageNumber="158" type="description">
<paragraph id="E6D61BEB4647E691E6967E50463C0E4C" pageId="null" pageNumber="158">
<emphasis id="347D4C702B814BFC267AB721ED26E972" italics="true" pageId="null" pageNumber="158">1</emphasis>
- 
<emphasis id="E1F618CF57C2C8EBB0B49E71A41B41EB" italics="true" pageId="null" pageNumber="158">
3 m hohe 
<normalizedToken id="F30858D02ED92CF82892BB273BAAF916" originalValue="Sträucher" pageId="null" pageNumber="158">Straeucher</normalizedToken>
, mit 
<normalizedToken id="5AF2B172DFE7721619A944FB127FD213" originalValue="zurückgebogenen" pageId="null" pageNumber="158">zurueckgebogenen</normalizedToken>
, meist dornigen Zweigen. 
<normalizedToken id="4ED8B9FA66D5BEDA98EA94D32F0D5E21" originalValue="Blätter" pageId="null" pageNumber="158">Blaetter</normalizedToken>
klein
</emphasis>
, einzeln oder in 
<normalizedToken id="D0D091EF0573ECFEB6933F35FD597917" originalValue="Büscheln" pageId="null" pageNumber="158">Buescheln</normalizedToken>
, 
<emphasis id="D9B823E2BF85F7DA1FA8B0D075BC02B9" italics="true" pageId="null" pageNumber="158">ungeteilt, ganzrandig.</emphasis>
Kelch mit 3-5 oft ungleichen 
<normalizedToken id="63422B29D229BABC9D15635A72C289FD" originalValue="Zähnen" pageId="null" pageNumber="158">Zaehnen</normalizedToken>
, zur Fruchtzeit nicht ver- 
<pageBreakToken id="96DAF4E7F45AB35515BB8752E56D6F9A" pageId="null" pageNumber="158">
<normalizedToken id="9158BF096B8710A857EE4D5368909D6C" originalValue="größert" pageId="null" pageNumber="158">groessert</normalizedToken>
</pageBreakToken>
. Krone mit eng 
<normalizedToken id="7EA48A1DA47833383633D00C6CFE5080" originalValue="glockenförmiger" pageId="null" pageNumber="158">glockenfoermiger</normalizedToken>
<normalizedToken id="4BAF2D180DFDE75C7248FE17D9C59BE0" originalValue="Röhre" pageId="null" pageNumber="158">Roehre</normalizedToken>
und 5teiligem, ausgebreitetem Rand. 
<normalizedToken id="D0777C7D681F0EED88BFC93784B03A65" originalValue="Staubblätter" pageId="null" pageNumber="158">Staubblaetter</normalizedToken>
5 (seltener 4), alle gleich lang. Fruchtknoten 2 
<normalizedToken id="1F01607F97C923C8AEB64EAE58CEFE29" originalValue="fächerig" pageId="null" pageNumber="158">faecherig</normalizedToken>
. Frucht eine saftige Beere.
</paragraph>
<paragraph id="975EC7F8542DF8CA3A70A2CB59B0AC75" pageId="null" pageNumber="158">
Die Gattung 
<taxonomicName id="7C40806FB05763443EEA67D3F39B5D1F" class="Magnoliopsida" family="Solanaceae" genus="Lycium" kingdom="Plantae" order="Solanales" pageId="null" pageNumber="158" phylum="Tracheophyta" rank="genus">
<emphasis id="06B91D6D98AA030B59A05ED831F384D2" italics="true" pageId="null" pageNumber="158">Lycium</emphasis>
</taxonomicName>
<normalizedToken id="631043E8D94333A9911DAF428683A9A9" originalValue="umfaßt" pageId="null" pageNumber="158">umfasst</normalizedToken>
<emphasis id="93DBE08527754D49AA19B7FEC56F6214" italics="true" pageId="null" pageNumber="158">
etwa 110 Arten und ist 
<normalizedToken id="F3C309E8F5E5C06B882CDBA5DB04A5FD" originalValue="hauptsächlich" pageId="null" pageNumber="158">hauptsaechlich</normalizedToken>
in 
<normalizedToken id="F19D92708FF543770669DF0F899EAA8F" originalValue="Südamerika" pageId="null" pageNumber="158">Suedamerika</normalizedToken>
beheimatet.
</emphasis>
</paragraph>
<paragraph id="ADC596F916783DB9336320232F57792C" pageId="null" pageNumber="158">
