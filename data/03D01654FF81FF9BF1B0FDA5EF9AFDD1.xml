<emphasis id="B90D7B50FF81FF9AF21CF910ED09F934" box="[778,825,1722,1743]" italics="true" pageId="4" pageNumber="391">6–10</emphasis>
): 
<emphasis id="B90D7B50FF81FF9AF25AF910ED5DF934" box="[844,877,1722,1743]" italics="true" pageId="4" pageNumber="391">1, 6</emphasis>
— antenna; 
<emphasis id="B90D7B50FF81FF9AF2F1F910EA39F92B" box="[999,1033,1722,1744]" italics="true" pageId="4" pageNumber="391">2, 7</emphasis>
