Piti, April 28, Bryan; Piti, April 30, from 
<taxonomicName id="78C24D70FFAA1B1DFAEAF8DD017041A4" authority="," authorityName=", Swezey" box="[1328,1654,1896,1938]" class="Magnoliopsida" family="Malvaceae" genus="Hibiscus" kingdom="Plantae" order="Malvales" pageId="20" pageNumber="170" phylum="Tracheophyta" rank="species" species="tiliaceus">
