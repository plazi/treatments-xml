<paragraph id="156F570EFFB8FFC6B1FD54EEFBA4FD6C" blockId="55.[151,1032,651,675]" box="[151,1032,651,675]" pageId="55" pageNumber="56">
<taxonomicName id="D2D02C8DFFB8FFC6B1FD54EEFE68FD6C" authority="Ferris, 1950 b: 81" authorityName="Ferris" authorityPageNumber="81" authorityYear="1950" box="[151,452,651,675]" class="Insecta" family="Pseudococcidae" genus="Eurycoccus" kingdom="Animalia" order="Hemiptera" pageId="55" pageNumber="56" phylum="Arthropoda" rank="genus">
<emphasis id="27A48B1CFFB8FFC6B1FD54EEFEA1FD6C" box="[151,269,652,675]" italics="true" pageId="55" pageNumber="56">Eurycoccus</emphasis>
<bibRefCitation id="71412AFFFFB8FFC6B07E54E9FE3DFD6C" author="Ferris, G. F." box="[276,401,651,675]" pageId="55" pageNumber="56" refId="ref89493" refString="Ferris, G. F. (1950) Atlas of the Scale Insects of North America. Series 5. Vol. 5. The Pseudococcidae (Part I). Stanford University Press, Palo Alto, California, 278 pp." type="book" year="1950">Ferris, 1950</bibRefCitation>
