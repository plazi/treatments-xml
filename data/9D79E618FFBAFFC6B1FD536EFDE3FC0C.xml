. 2016
</bibRefCitation>
)
</taxonomicName>
; in 
<collectingCountry id="6DC7179EFFB8FFC6B3F75745FD61FE8E" box="[669,717,295,321]" name="Iran" pageId="55" pageNumber="56">Iran</collectingCountry>
, it has been found on 
<taxonomicName id="D2D02C8DFFB8FFC6B2D65745FBCAFE8E" box="[956,1126,295,321]" class="Magnoliopsida" family="Fabaceae" genus="Prosopis" kingdom="Plantae" order="Fabales" pageId="55" pageNumber="56" phylum="Tracheophyta" rank="species" species="farcta">
