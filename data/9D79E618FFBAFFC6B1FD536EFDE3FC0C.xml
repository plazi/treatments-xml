<taxonomicName id="D2D02C8DFFB8FFC6B51E5745FB4CFE8D" box="[1140,1248,295,322]" class="Magnoliopsida" family="Fabaceae" kingdom="Plantae" order="Fabales" pageId="55" pageNumber="56" phylum="Tracheophyta" rank="family">Fabaceae</taxonomicName>
