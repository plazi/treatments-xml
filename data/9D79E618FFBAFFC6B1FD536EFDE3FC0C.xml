<taxonomicName id="D2D02C8DFFB8FFC6B4715745FA30FE8E" baseAuthorityName="Moghaddam" baseAuthorityYear="2013" box="[1307,1436,295,321]" class="Magnoliopsida" family="Moraceae" genus="Morus" kingdom="Plantae" order="Rosales" pageId="55" pageNumber="56" phylum="Tracheophyta" rank="species" species="alba">
<emphasis id="27A48B1CFFB8FFC6B4715745FA30FE8E" box="[1307,1436,295,321]" italics="true" pageId="55" pageNumber="56">Morus alba</emphasis>
