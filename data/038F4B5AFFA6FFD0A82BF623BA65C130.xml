<subSubSection id="C33CA9C7FFA6FFD1AA8EF4FFB7D0C9E0" pageId="2" pageNumber="367" type="distribution">
<caption id="DF59AAC4FFA6FFD1AA8EF4FFB7D0C9E0" ID-DOI="http://doi.org/10.5281/zenodo.6584704" ID-Zenodo-Dep="6584704" httpUri="https://zenodo.org/record/6584704/files/figure.png" inLine="true" pageId="2" pageNumber="367" targetBox="[1382,1972,2740,3154]" targetPageId="2">
<paragraph id="8B99FA4CFFA6FFD1AA8EF4FFB7D0C9E0" blockId="2.[1995,2588,2729,3156]" pageId="2" pageNumber="367">
<emphasis id="B952265EFFA6FFD1AA8EF4FFB773C916" bold="true" box="[1996,2171,2851,2880]" pageId="2" pageNumber="367">Distribution.</emphasis>
