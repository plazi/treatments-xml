<emphasis id="FDDAEABCFFE7FFFDFF3E5322FEBD2AB3" bold="true" box="[234,325,366,392]" pageId="24" pageNumber="190">Female</emphasis>
(
<typeStatus id="1015880CFFE7FFFDFE815322FE462AB3" box="[341,446,366,392]" pageId="24" pageNumber="190">paratype</typeStatus>
