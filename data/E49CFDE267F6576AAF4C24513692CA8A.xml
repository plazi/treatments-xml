<subSubSection id="FF685CEE1BF2F66079845673EFE52CF5" pageId="0" pageNumber="1" type="etymology">
<paragraph id="C17626605ABE9D36B796226AC5FEF6C6" pageId="0" pageNumber="1">Etymology.</paragraph>
<paragraph id="C9F9917718AC111D87F0AF8F392C1A54" pageId="0" pageNumber="1">
The species name 
<taxonomicName id="5401E7AE3A1C436EFBA44F782A2585BD" authorityName="Rakotonirina &amp; Fisher" authorityYear="2022" class="Insecta" family="Formicidae" genus="Camponotus" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Camponotus joany" order="Hymenoptera" pageId="0" pageNumber="1" phylum="Arthropoda" rank="species" species="joany">
<emphasis id="1BE54865B952D929D28F2BAAE8C76E18" italics="true" pageId="0" pageNumber="1">Camponotus joany</emphasis>
</taxonomicName>
is a non-Latin singular noun used in apposition.
</paragraph>
