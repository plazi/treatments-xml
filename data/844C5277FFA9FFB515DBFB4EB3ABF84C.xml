<figureCitation id="94DEFFE4FFA9FFB51054F9C1B363F982" box="[1304,1364,1600,1622]" captionStart="FIGURES 9" captionStartId="17.[151,264,1943,1967]" captionTargetBox="[174,1417,187,1904]" captionTargetId="figure-18@17.[157,1430,181,1919]" captionTargetPageId="17" captionText="FIGURES 9 A–G. Drabescus limbaticeps (Stål), male genitalia.A. pygofer and anal tube, lateral view; B, pygofer, lateral view; C,, valve and subgenital plates, dorsal view; D, styles, connective and aedeagus, dorsal view; E, aedeagus, lateral view; F, style, connective, and aedeagus, lateral view; G, aedeagus, dorsal view." figureDoi="http://doi.org/10.5281/zenodo.6479838" httpUri="https://zenodo.org/record/6479838/files/figure.png" pageId="2" pageNumber="227">Figs 9</figureCitation>
DE)...................................................................................... 
<taxonomicName id="CBE598E2FFA9FFB51199F9DFB3ABF9A7" authority="(Stal)" baseAuthorityName="Stal" baseAuthorityYear="1858" box="[1237,1436,1629,1651]" class="Insecta" family="Cicadellidae" genus="Drabescus" kingdom="Animalia" order="Hemiptera" pageId="2" pageNumber="227" phylum="Arthropoda" rank="species" species="limbaticeps">
<emphasis id="3E913F73FFA9FFB51199F9DFB358F9A6" box="[1237,1391,1629,1651]" italics="true" pageId="2" pageNumber="227">D. limbaticeps (</emphasis>
Stål)
</taxonomicName>
</keyLead>
</paragraph>
</keyStep>
<keyStep id="B711FBC4FFA9FFB515DBF9FBB3AAF93C" pageId="2" pageNumber="227">
