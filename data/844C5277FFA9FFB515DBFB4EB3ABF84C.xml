<figureCitation id="94DEFFE4FFA9FFB51154F984B269F9CF" box="[1048,1118,1541,1563]" captionStart="FIGURES 10" captionStartId="18.[151,264,1836,1860]" captionTargetBox="[163,1426,190,1799]" captionTargetId="figure-28@18.[151,1436,181,1812]" captionTargetPageId="18" captionText="FIGURES 10 A–H. Drabescus nervosopunctatus Signoret, male genitalia. A, pygofer, anal tube and subgenital plates, lateral view; B, pygofer, lateral view; C, distal half of pygofer, ventral view; D, valve subgenital plates and style, dorsal view; E, styles, connective and aedeagus, dorsal view; F, aedeagus, lateral view; G–H, connective and aedeagus, dorsal and ventral views." figureDoi="http://doi.org/10.5281/zenodo.6479842" httpUri="https://zenodo.org/record/6479842/files/figure.png" pageId="2" pageNumber="227">Figs 10</figureCitation>
EGH)................................................................................................. 
<taxonomicName id="CBE598E2FFA9FFB51132F9A2B3ABF9EC" authority="Signoret" authorityName="Signoret" authorityYear="1880" box="[1150,1436,1570,1592]" class="Insecta" family="Cicadellidae" genus="Drabescus" kingdom="Animalia" order="Hemiptera" pageId="2" pageNumber="227" phylum="Arthropoda" rank="species" species="nervosopunctatus">
<emphasis id="3E913F73FFA9FFB51132F9A2B372F9EC" box="[1150,1349,1571,1592]" italics="true" pageId="2" pageNumber="227">D. nervosopunctatus</emphasis>
Signoret
</taxonomicName>
</keyLead>
</paragraph>
<paragraph id="0C5AE361FFA9FFB515DBF9C1B3ABF9A7" blockId="2.[151,1437,1336,1944]" pageId="2" pageNumber="227">
<keyLead id="B7144054FFA9FFB515DBF9C1B3ABF9A7" pageId="2" pageNumber="227">
