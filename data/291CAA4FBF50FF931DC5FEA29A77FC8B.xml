. MW: 
<quantity id="664DB6BCBF53FF931FF4FEA39B1BFEDF" box="[678,813,295,321]" metricMagnitude="-3" metricUnit="m" metricValue="2.3" metricValueMax="2.4" metricValueMin="2.2" pageId="14" pageNumber="265" unit="mm" value="2.3" valueMax="2.4" valueMin="2.2">2.2–2.4 mm</quantity>
