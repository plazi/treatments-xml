(mean value: 4.8 ± 
<quantity id="664DB6BCBF53FF931E7FFE879BBFFE83" box="[813,905,259,285]" metricMagnitude="-4" metricUnit="m" metricValue="2.0" pageId="14" pageNumber="265" unit="mm" value="0.2">0.2 mm</quantity>
