<taxonomicName id="A2EA84A9FFFCFFC3FF71FBC8FDD4FB9A" authority="(Robinson, 1968)" baseAuthorityName="Robinson" baseAuthorityYear="1968" box="[151,553,1050,1077]" class="Insecta" family="Noctuidae" genus="Eudocima" kingdom="Animalia" order="Lepidoptera" pageId="20" pageNumber="21" phylum="Arthropoda" rank="species" species="paulii">
<emphasis id="579E2338FFFCFFC3FF71FBC8FDD4FB9A" bold="true" box="[151,553,1050,1077]" pageId="20" pageNumber="21">
<emphasis id="579E2338FFFCFFC3FF71FBC8FEAAFB9B" bold="true" box="[151,343,1050,1077]" italics="true" pageId="20" pageNumber="21">Eudocima paulii</emphasis>
(
<bibRefCitation id="017B82DBFFFCFFC3FE80FBC8FDDDFB9A" author="Robinson, G. S." box="[358,544,1050,1076]" pageId="20" pageNumber="21" pagination="249 - 255" refId="ref39724" refString="Robinson, G. S. (1968) Some new species of Lepidoptera from the Fiji Islands. The Entomologist's Record and Journal of Variation, 80, 249 - 255, pl. 14." type="journal article" year="1968">Robinson, 1968</bibRefCitation>
