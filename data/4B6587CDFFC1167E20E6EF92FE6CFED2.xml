<typeStatus id="1C778879FFC5167E245CEAE8FF20FE97" pageId="7" pageNumber="198">holotype</typeStatus>
from &quot;Mumbug O Makalu 
<quantity id="04349B3EFFC5167E2253EACBFDA7FE97" box="[519,601,248,270]" metricMagnitude="3" metricUnit="m" metricValue="3.5" pageId="7" pageNumber="198" unit="m" value="3500.0">3500 m</quantity>
