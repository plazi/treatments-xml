<taxonomicName id="8DDC4D70FFF7FFB6FF709D2568F67C14" authority="CARSEY" authorityName="CARSEY" box="[218,507,353,374]" class="Globothalamea" family="Globorotaliidae" genus="Globorotalia" kingdom="Chromista" order="Rotaliida" pageId="26" pageNumber="40" phylum="Foraminifera" rank="species" species="conicus">
<emphasis id="78A8EAE1FFF7FFB6FF709D2568A87C17" box="[218,421,353,374]" italics="true" pageId="26" pageNumber="40">Globorotalia conicus</emphasis>
CARSEY
</taxonomicName>
, p. 156, pl. 1-8.
</paragraph>
<paragraph id="4A6336F3FFF7FFB6FF3D9D3A68887CD1" blockId="26.[151,756,353,433]" pageId="26" pageNumber="40">
1956. 
<taxonomicName id="8DDC4D70FFF7FFB6FF709D3A6B167CF2" authority="(CARSEY)" baseAuthorityName="CARSEY" baseAuthorityYear="1840" box="[218,539,382,404]" class="Globothalamea" family="Globorotalitidae" genus="Globorotalites" kingdom="Chromista" order="Rotaliida" pageId="26" pageNumber="40" phylum="Foraminifera" rank="species" species="conicus">
