<subSubSection id="38E482BD03A13F5CF8D206401FFC61DB" pageId="null" pageNumber="590" type="description">
<paragraph id="F2C6A55479D4385DE3B18380B577BC7F" pageId="null" pageNumber="590">
<emphasis id="943BE5635F1922D58E2DA0E764D49222" italics="true" pageId="null" pageNumber="590">
<normalizedToken id="4716A85D33D15FD09067407F462D070D" originalValue="Köpfe" pageId="null" pageNumber="590">Koepfe</normalizedToken>
im Durchmesser bis 4 cm
</emphasis>
. 
<normalizedToken id="3AB8880C24655BCD6E2EB5A22FDC5695" originalValue="Blüten" pageId="null" pageNumber="590">Blueten</normalizedToken>
hellgelb, ⅓-⅔ 
<emphasis id="B78D6828C18DBE2A985A0D9019C1E8A5" italics="true" pageId="null" pageNumber="590">
so lang wie die 
<normalizedToken id="233C556D788092EDE454DEEE3C222BBC" originalValue="Hülle" pageId="null" pageNumber="590">Huelle</normalizedToken>
. Staubbeutel braun. 
<normalizedToken id="CA2E7672A8B7F32AAF06CC8BA97788AB" originalValue="Früchte" pageId="null" pageNumber="590">Fruechte</normalizedToken>
</emphasis>
(
<emphasis id="6E6940FC724B44647FBD3655F3C35DAE" italics="true" pageId="null" pageNumber="590">mit Schnabel</emphasis>
) 
<emphasis id="EED118A7FD2003AC46C9695C274E4EAE" italics="true" pageId="null" pageNumber="590">1,2</emphasis>
- 
<emphasis id="D54D76050652356D42F0FE4505DA60BF" italics="true" pageId="null" pageNumber="590">1,8 cm lang.</emphasis>
- 
<normalizedToken id="3D6BB794F6ACFF0E2FE5FB92F6B84725" originalValue="Blüte" pageId="null" pageNumber="590">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="507BC833A21AA3E59F65BF9791400081" pageId="null" pageNumber="590">
<emphasis id="873DD8F5154B1B2A45BBAC1400A562E6" italics="true" pageId="null" pageNumber="590">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="FC998670840DB8DA91B10BB4C1207DF9" italics="true" pageId="null" pageNumber="590">12:</emphasis>
Material aus Skandinavien (Winge 1938), aus Nordamerika (Ownbey und McCollum 1954), aus Frankreich (Delay 1969b).
</paragraph>
<paragraph id="5FFFE3F1800CEFC51F3CAFFB5FE3CA62" pageId="null" pageNumber="590">
<emphasis id="816511301CF707257371545DF862F623" italics="true" pageId="null" pageNumber="590">Standort</emphasis>
. Kollin, selten montan. Trockene, 
<normalizedToken id="040031708C44BA8DF787E98922CEBDAC" originalValue="nährstoffreiche" pageId="null" pageNumber="590">naehrstoffreiche</normalizedToken>
<normalizedToken id="802ED51D080F1F0357EB8A1DE8E5A9B7" originalValue="Böden" pageId="null" pageNumber="590">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="4034295E99C5D49343C3004F1F5ABA40" originalValue="Straßenränder" pageId="null" pageNumber="590">Strassenraender</normalizedToken>
, 
<normalizedToken id="CEBC8B2A66A27FB7085672553392FF31" originalValue="Waldschläge" pageId="null" pageNumber="590">Waldschlaege</normalizedToken>
.
</paragraph>
<paragraph id="C13B6DCEB130C252AB29016D166ADF88" pageId="null" pageNumber="590">
<emphasis id="83B0DF05AC48702EF4E5E5F86E40581B" italics="true" pageId="null" pageNumber="590">
Verbreitung. 
<normalizedToken id="6E5954FE9152872E563FD8FAA383CB30" originalValue="Mitteleuropäische" pageId="null" pageNumber="590">Mitteleuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="1958DCF528AF87A4AF7C69E4AC6E12A2" originalValue="Nordwärts" pageId="null" pageNumber="590">Nordwaerts</normalizedToken>
bis 
<normalizedToken id="B5653345189D2581CA4F3594B5CB6637" originalValue="Großbritannien" pageId="null" pageNumber="590">Grossbritannien</normalizedToken>
und 
<normalizedToken id="2BF9C810DBFBEF50C51FD1DCE7CD5067" originalValue="Südnorwegen" pageId="null" pageNumber="590">Suednorwegen</normalizedToken>
; 
<normalizedToken id="ECA935E037B37429C609A70A8F645BC3" originalValue="ostwärts" pageId="null" pageNumber="590">ostwaerts</normalizedToken>
bis 
<normalizedToken id="988539E362BDA6160B0FDF2FE5A45B9B" originalValue="Ostpreußen" pageId="null" pageNumber="590">Ostpreussen</normalizedToken>
, Schlesien, 
<normalizedToken id="2FB9CFA8D9FFB298D4600936881332BF" originalValue="Süddeutschland" pageId="null" pageNumber="590">Sueddeutschland</normalizedToken>
; 
<normalizedToken id="00CDAC7406754F39B4A00BFC7602C357" originalValue="südwärts" pageId="null" pageNumber="590">suedwaerts</normalizedToken>
bis 
<normalizedToken id="5C38F8A4716B846A8A978BF3103F4339" originalValue="Südfrankreich" pageId="null" pageNumber="590">Suedfrankreich</normalizedToken>
und Ligurien; 
<normalizedToken id="FA25CFA83FB45511C6C1F41929C88840" originalValue="westwärts" pageId="null" pageNumber="590">westwaerts</normalizedToken>
bis 
<normalizedToken id="139DC18A12253D81A686E935B1480083" originalValue="Pyrenäen" pageId="null" pageNumber="590">Pyrenaeen</normalizedToken>
und Nordspanien. Verbreitungskarte von Regel (1955). - Im Gebiet: Oberrheinische Tiefebene, Baar, Hochrhein, Schaffhausen, 
<normalizedToken id="6B7C4B1836C768CABE3A0CA8DC88F26C" originalValue="südwestliche" pageId="null" pageNumber="590">suedwestliche</normalizedToken>
Alb, Hegau, Aostatal; selten und zum Teil wohl nur adventiv, auch sonst selten adventiv.
</paragraph>
</subSubSection>
