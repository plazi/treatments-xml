<subSubSection id="139B8CF892A786BFCBEEFEEC75CED439" pageId="null" pageNumber="95" type="vernacular_names">
<paragraph id="3850764914E0DF49C6400DEFC27CA942" pageId="null" pageNumber="95">Berg-Gamander</paragraph>
</subSubSection>
</title>
<subSubSection id="DEDD69C82479140563D5D40D4A320CDB" pageId="null" pageNumber="95" type="description">
<paragraph id="428B6A00C911728CD284E8D3FDC34E77" pageId="null" pageNumber="95">
Ausdauernd, mit 
<emphasis id="8FF30EB45A51E5A9E64A8C0A499D68D7" italics="true" pageId="null" pageNumber="95">im untern Teil verholzten, niederliegenden</emphasis>
, bis 20 cm langen, verzweigten, kurz und kraus behaarten Stengeln, aromatisch riechend. 
<emphasis id="AC948F19FCEF6DA425184FD1D96E306E" italics="true" pageId="null" pageNumber="95">
<normalizedToken id="6ED713EBEEFEF87680C1BB4C3907F0FC" originalValue="Blätter" pageId="null" pageNumber="95">Blaetter</normalizedToken>
schmal lanzettlich
</emphasis>
, 0,5-2 cm lang und 0,2-0,5 cm breit, 
<emphasis id="CFC2745089B8BCAB70DA14DA224CD651" italics="true" pageId="null" pageNumber="95">ganzrandig</emphasis>
, mit nach unten eingerolltem Rand, 
<emphasis id="DAA63A9EAC401DE4CD9AA125A9586434" italics="true" pageId="null" pageNumber="95">
<normalizedToken id="8296906778184E1623EA4A7EC126F1C5" originalValue="immergrün" pageId="null" pageNumber="95">immergruen</normalizedToken>
</emphasis>
, lederig, oberseits zerstreut, 
<emphasis id="106A7B77E546531A3A59D24BC45894F2" italics="true" pageId="null" pageNumber="95">
unterseits dicht und 
<normalizedToken id="8F9FA79FB957D41B25936494C7002ACE" originalValue="weißfilzig" pageId="null" pageNumber="95">weissfilzig</normalizedToken>
behaart
</emphasis>
(Haare kraus, 0,1-0,3 mm lang). 
<normalizedToken id="7B5BD369D9CD16F39A86A3E4777631D8" originalValue="Blüten" pageId="null" pageNumber="95">Blueten</normalizedToken>
am Ende der Zweige in wenigen, dicht (kopfig) 
<normalizedToken id="F057D825C79CE196236B0A023DA5FB86" originalValue="übereinanderstehenden" pageId="null" pageNumber="95">uebereinanderstehenden</normalizedToken>
, 2-6 
<normalizedToken id="D3902FE94EC688037C47C84A195E52AB" originalValue="blütigen" pageId="null" pageNumber="95">bluetigen</normalizedToken>
, 
<normalizedToken id="B0EACE5D1A3E4B71A2A828A6798A1486" originalValue="quirlähnlichen" pageId="null" pageNumber="95">quirlaehnlichen</normalizedToken>
<normalizedToken id="902A1B8DE99853A213ACCE62E7666287" originalValue="Teilblütenständen" pageId="null" pageNumber="95">Teilbluetenstaenden</normalizedToken>
. 
<normalizedToken id="A1FEE20C9B37F7934A9F1C68EA060327" originalValue="Blütenstiel" pageId="null" pageNumber="95">Bluetenstiel</normalizedToken>
bedeutend 
<normalizedToken id="71EC0C0F1AF7BEFDD1AE749FF7D44058" originalValue="kürzer" pageId="null" pageNumber="95">kuerzer</normalizedToken>
als der Kelch. Kelch 6-9 mm lang, fast 
<normalizedToken id="3D631D718A9882521D87FA6FA4DB1272" originalValue="regelmäßig" pageId="null" pageNumber="95">regelmaessig</normalizedToken>
5 
<normalizedToken id="2B4B72ADA646532DFBE500AD7DECAE95" originalValue="zähnig" pageId="null" pageNumber="95">zaehnig</normalizedToken>
, zerstreut und kurz behaart; 
<normalizedToken id="62C16F3A7D206368945F51772A159FE9" originalValue="Zähne" pageId="null" pageNumber="95">Zaehne</normalizedToken>
3eckig, kurz begrannt. Krone 0,8-1,3 cm lang, 
<emphasis id="6AF3EFF41296F546D9F00CB57CDC6B42" italics="true" pageId="null" pageNumber="95">gelblich</emphasis>
. 
<normalizedToken id="D132885D62E47B6AD318F04F1D3F5D00" originalValue="Teilfrüchte" pageId="null" pageNumber="95">Teilfruechte</normalizedToken>
1,5-2 mm lang und 0,8-1,2 mm dick, grubig. - 
<normalizedToken id="CDBB4BF09235737C4D917B4F46788934" originalValue="Blüte" pageId="null" pageNumber="95">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="82D226D9C30232CA69E68377F0E9366A" pageId="null" pageNumber="95">
<emphasis id="7D1613B92DD3D03BEA7C831062CDE39B" italics="true" pageId="null" pageNumber="95">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="4F4ACE599975935758CB1AE6C181DA22" italics="true" pageId="null" pageNumber="95">16:</emphasis>
Material aus 
<normalizedToken id="7EEAFD6B403AD450E2DE02C6BD83C4CA" originalValue="Südfrankreich" pageId="null" pageNumber="95">Suedfrankreich</normalizedToken>
(Caussols) (Guinochet und Logeois 1962). 
<emphasis id="7A432FBD83F3053F4A59E8F1DC821537" italics="true" pageId="null" pageNumber="95">2n</emphasis>
= 
<emphasis id="FBED737E8F97B10C5D958F4D3617194E" italics="true" pageId="null" pageNumber="95">26</emphasis>
Material aus den Alpes Maritimes und den 
<normalizedToken id="12D9C07F2AE498A03A9FCB57B0FB8262" originalValue="Pyrenäen" pageId="null" pageNumber="95">Pyrenaeen</normalizedToken>
(
<normalizedToken id="0162E881915DBB730B19EC10EFE6C83E" originalValue="Küpfer" pageId="null" pageNumber="95">Kuepfer</normalizedToken>
1969), aus dem Dep. Jura (Parreaux 1971). 
<emphasis id="48F74308136F048CFF536F72265E425B" italics="true" pageId="null" pageNumber="95">2n</emphasis>
= 
<emphasis id="835FD440A5B6896C0E20DF28FF1409D6" italics="true" pageId="null" pageNumber="95">30:</emphasis>
Material aus Ungarn (Baksay 1956), aus Jugoslawien (Nilsson und Lassen 1971).
</paragraph>
<paragraph id="1DB040E34791C4A4662C228A96B4B6F4" pageId="null" pageNumber="95">
<emphasis id="A4727B43578DF9F18CEF92254F38D550" italics="true" pageId="null" pageNumber="95">Standort</emphasis>
. Kollin, montan und subalpin, sehr selten alpin. Trockene, kalkhaltige, steinige 
<normalizedToken id="1387B7CE8155FE27DE6E9F4DE91579F6" originalValue="Böden" pageId="null" pageNumber="95">Boeden</normalizedToken>
in 
<normalizedToken id="87CEE1BCEE2AF1498068F079E0EBBF0B" originalValue="wärmeren" pageId="null" pageNumber="95">waermeren</normalizedToken>
Lagen. Fels- und Felsschuttvegetation, Trockenwiesen.
</paragraph>
<paragraph id="C3AC7ABCC617158FE2B0696E897E08C7" pageId="null" pageNumber="95">
<emphasis id="32DA8AD1DD5FD24395BFB480BB23DFE7" italics="true" pageId="null" pageNumber="95">
Verbreitung. 
<normalizedToken id="7D2E07B19EDE1DAC97CD885E3AF4DDCD" originalValue="Südeuropäische" pageId="null" pageNumber="95">Suedeuropaeische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="4341E551E150FD7637EF14392D639EF7" originalValue="Nordwärts" pageId="null" pageNumber="95">Nordwaerts</normalizedToken>
vereinzelt bis 
<normalizedToken id="5320D3845ACA89495614B2390106F098" originalValue="Südbelgien" pageId="null" pageNumber="95">Suedbelgien</normalizedToken>
, Hessen, Saalegebiet und 
<normalizedToken id="7E7086C2D2C7DF8415DD3E983FC17664" originalValue="Südmähren" pageId="null" pageNumber="95">Suedmaehren</normalizedToken>
; 
<normalizedToken id="3EB24C880897C84D11A337C99D96D5D8" originalValue="ostwärts" pageId="null" pageNumber="95">ostwaerts</normalizedToken>
bis zur Krim. In nahe verwandten Arten auch im Kaukasus und in Kleinasien. - Im Gebiet: Savoyen, Gegend von Belfort, Oberrheinische Tiefebene, Hegau, Alpen und Jura (ziemlich verbreitet, nicht 
<normalizedToken id="7F8B95E381215763BA311A846DC00CA6" originalValue="häufig" pageId="null" pageNumber="95">haeufig</normalizedToken>
); im Mittelland zerstreut und selten, im Schwarzwald und in den Vogesen nicht vorhanden.
</paragraph>
</subSubSection>
