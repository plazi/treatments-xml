</taxonomicName>
<taxonomicNameLabel box="[542,597,215,238]" pageId="35" pageNumber="368" rank="species">n. sp.</taxonomicNameLabel>
at the 
<collectingRegion box="[668,775,215,238]" country="French Polynesia" name="Iles Marquises" pageId="35" pageNumber="368">Marquesas</collectingRegion>
