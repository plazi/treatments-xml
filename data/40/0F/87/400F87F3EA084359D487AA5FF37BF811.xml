<taxonomicName authorityName="Amati &amp; Giulio &amp; Oliverio" authorityYear="2022" baseAuthorityName="Thiele" baseAuthorityYear="1925" box="[915,1031,1905,1931]" class="Gastropoda" family="Rissoidae" genus="Benthonellania" kingdom="Animalia" order="Littorinimorpha" pageId="18" pageNumber="351" phylum="Mollusca" rank="species" species="africana" status="n. comb.">
