<emphasis box="[1254,1455,1196,1220]" italics="true" pageId="37" pageNumber="370">Benthonellania megan</emphasis>
</taxonomicName>
<taxonomicNameLabel box="[811,864,1223,1246]" pageId="37" pageNumber="370" rank="species">n. sp.</taxonomicNameLabel>
at the 
<collectingRegion box="[932,1035,1223,1246]" country="French Polynesia" name="Iles Marquises" pageId="37" pageNumber="370">Marquesas</collectingRegion>
