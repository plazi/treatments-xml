</taxonomicName>
and 
<taxonomicName authorityName="Lozouet" authorityYear="1990" box="[974,1116,1339,1363]" class="Gastropoda" family="Rissoidae" genus="Benthonellania" kingdom="Animalia" order="Littorinimorpha" pageId="37" pageNumber="370" phylum="Mollusca" rank="genus">
<emphasis box="[974,1116,1339,1363]" italics="true" pageId="37" pageNumber="370">Benthonellania</emphasis>
</taxonomicName>
.
</paragraph>
