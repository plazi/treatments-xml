<subSubSection id="6015724C60A344FE896E7551F824B79A" pageId="null" pageNumber="465" type="nomenclature">
<paragraph id="2C4A1F0332DF66E584445B420BCE5B45" pageId="null" pageNumber="465">
<taxonomicName id="CE8F1633398B8C0686DC9BA238E5F1DE" authority="Juslen" class="Magnoliopsida" family="Rosaceae" genus="Prunus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="465" phylum="Tracheophyta" rank="species" species="insititia">
<pageBreakToken id="F5B8059D40BB9A87629BA3C36E917EBF" pageId="null" pageNumber="465">Prunus</pageBreakToken>
<normalizedToken id="0C07F741812C896CBB173511E60AD84A" originalValue="insitítia" pageId="null" pageNumber="465">insititia</normalizedToken>
Juslen
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="902F8B883CF30038AC24DF7D5B1AC99D" pageId="null" pageNumber="465" type="vernacular_names">
<paragraph id="F6BEB2CB3343F06348A4279D5A6E7F31" pageId="null" pageNumber="465">Pflaume</paragraph>
</subSubSection>
</title>
<subSubSection id="2E91FC9B7EF52AD0CD7A33247AFDF1A7" pageId="null" pageNumber="465" type="description">
<paragraph id="CE443D7470DE47BBC320E45EE92F5A66" pageId="null" pageNumber="465">
Strauch oder bis 6 m hoher Baum. Zweige von wilden Sippen mit Dornen. 
<emphasis id="03BDFDA95C18D3D14FA6E3C32396DDC3" italics="true" pageId="null" pageNumber="465">1 Jahr alte Triebe weich behaart.</emphasis>
<normalizedToken id="9A4DDEC217CD995EAA3834D22A507EE4" originalValue="Blätter" pageId="null" pageNumber="465">Blaetter</normalizedToken>
oval, 4-8 cm lang, 1,2-1,5mal so lang wie breit, beiderseits 
<normalizedToken id="CEFDE69E2F3108C8F85499C4AB742196" originalValue="dunkelgrün" pageId="null" pageNumber="465">dunkelgruen</normalizedToken>
und locker behaart (
<normalizedToken id="35FE6A0555A437CDDC5E37D2E823D6B5" originalValue="ältere" pageId="null" pageNumber="465">aeltere</normalizedToken>
<normalizedToken id="A76A2284BA44AB29A43FA410270DEFF5" originalValue="Blätter" pageId="null" pageNumber="465">Blaetter</normalizedToken>
nicht kahl werdend), am Rande mit 
<emphasis id="04AAD5B6435322A6562CBF258A94601F" italics="true" pageId="null" pageNumber="465">
stumpfen 
<normalizedToken id="AB4AD6688F45EBBAD0D08C5709D4BD10" originalValue="Zähnen" pageId="null" pageNumber="465">Zaehnen</normalizedToken>
</emphasis>
, in der Knospenlage eingerollt, ohne oder am Blattstiel mit 1-2 
<normalizedToken id="95079227D654D32DD3787EBC1D40D114" originalValue="Drüsen" pageId="null" pageNumber="465">Druesen</normalizedToken>
; 
<emphasis id="785950296CEEAA7909ED8D7E68970964" italics="true" pageId="null" pageNumber="465">
zur 
<normalizedToken id="B7D440A9B46779D12727BE8E4D5F37E6" originalValue="Blütezeit" pageId="null" pageNumber="465">Bluetezeit</normalizedToken>
voll entwickelt.
</emphasis>
<normalizedToken id="920DFE22BCA9E40AB103BD2CDA350E74" originalValue="Blüten" pageId="null" pageNumber="465">Blueten</normalizedToken>
oft in Paaren, sonst einzeln. 
<normalizedToken id="CEF6AC04B6E9F5C55EA8801DFC897243" originalValue="Blütenstiele" pageId="null" pageNumber="465">Bluetenstiele</normalizedToken>
abstehend; Fruchtstiele 
<normalizedToken id="1ACBF0C29E8B95AAD23FF98133AE4640" originalValue="hängend" pageId="null" pageNumber="465">haengend</normalizedToken>
; 
<emphasis id="5A0723652ABA0F89062C48994549936C" italics="true" pageId="null" pageNumber="465">
<normalizedToken id="850C26FE306AC0A4FCFAEBEF9C7E0689" originalValue="Blüten-" pageId="null" pageNumber="465">Blueten-</normalizedToken>
und Fruchtstiele behaart
</emphasis>
, 8-20 mm lang. 
<emphasis id="0558989E19BCBF8C228C00AE0E8292BA" italics="true" pageId="null" pageNumber="465">
<normalizedToken id="218326B0FD027649545FB22FB850A8CF" originalValue="Kelchblätter" pageId="null" pageNumber="465">Kelchblaetter</normalizedToken>
am Rande abstehend behaart, sonst kahl.
</emphasis>
<normalizedToken id="C06922DC2ADD89BFB5E59AED8AB5DB62" originalValue="Kronblätter" pageId="null" pageNumber="465">Kronblaetter</normalizedToken>
oval, 1-1,5 cm lang, 
<emphasis id="AF26A1D5C02C15724D40FE6CE305F816" italics="true" pageId="null" pageNumber="465">
rundlich, 
<normalizedToken id="A0D4C6B1E5C2373AE3EC71E14008967B" originalValue="weiß" pageId="null" pageNumber="465">weiss</normalizedToken>
.
</emphasis>
<normalizedToken id="523629AFED2D227ACE20BF7DBC0FDD78" originalValue="Staubblätter" pageId="null" pageNumber="465">Staubblaetter</normalizedToken>
etwa 20, 
<normalizedToken id="96AEA48D66F776DE0AED8EC57632C84D" originalValue="kürzer" pageId="null" pageNumber="465">kuerzer</normalizedToken>
als die 
<normalizedToken id="973C30CEA41C62CCA66FA2537E23846D" originalValue="Kronblätter" pageId="null" pageNumber="465">Kronblaetter</normalizedToken>
; Staubbeutel gelb. Fruchtknoten und Frucht kahl. Frucht 
<emphasis id="3758EE95D1C12DFC668749E0272E99E0" italics="true" pageId="null" pageNumber="465">kugelig</emphasis>
, violett, rot oder gelb, 
<emphasis id="66EFDCF8034F24E69201FD83E0346FDF" italics="true" pageId="null" pageNumber="465">mit am Stein haftendem Fruchtfleisch und</emphasis>
<normalizedToken id="23C846E20C7C81FF1118F57DCFCC67D4" originalValue="±" pageId="null" pageNumber="465">+/-</normalizedToken>
<emphasis id="101E69FB01F0DDEB3DB2F7F67CD33902" italics="true" pageId="null" pageNumber="465">glattem Stein.</emphasis>
- 
<normalizedToken id="CF426720948EE42178DB8493BD136F74" originalValue="Blüte" pageId="null" pageNumber="465">Bluete</normalizedToken>
: 
<normalizedToken id="CC7D1E61408F85B0023FFBBFFCD3F0EE" originalValue="Frühling" pageId="null" pageNumber="465">Fruehling</normalizedToken>
.
</paragraph>
<paragraph id="AB8B329676EEA8179DBF5E09B36F3316" pageId="null" pageNumber="465">
<emphasis id="657413017CDE5A584A57C60E824A5DFC" italics="true" pageId="null" pageNumber="465">Zytologische Angaben.</emphasis>
<normalizedToken id="FF8A938ABA44EECFACEECDA10CC1EEBC" originalValue="Übereinstimmend" pageId="null" pageNumber="465">Uebereinstimmend</normalizedToken>
mit 
<taxonomicName id="DDDA4E829570F466D8D9A55310E78DEC" class="Magnoliopsida" family="Rosaceae" genus="Persica" higherTaxonomySource="GBIF" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="465" phylum="Tracheophyta" rank="species" species="domestica">
<emphasis id="ED5EC513C792EE29CF0AC382AA38B5F9" italics="true" pageId="null" pageNumber="465">P. domestica</emphasis>
</taxonomicName>
(Nr. 12) (s. dort).
</paragraph>
<paragraph id="45A7F5B44A98D4626450B67AF09275C6" pageId="null" pageNumber="465">
<emphasis id="6CECEA4A9E80DEB73E1CD36F57041414" italics="true" pageId="null" pageNumber="465">Standort.</emphasis>
Kollin und montan. Selten und nur in den 
<normalizedToken id="1C9991D62950D2F53C9B324E476D988C" originalValue="wärmeren" pageId="null" pageNumber="465">waermeren</normalizedToken>
Gegenden verwilderte Kulturpflanze.
</paragraph>
<paragraph id="3FDD13D9E22B187EF839A49D78D8477D" pageId="null" pageNumber="465">
<emphasis id="E8CDADBD4D431C8FEFC71C04681FEDA1" italics="true" pageId="null" pageNumber="465">Verbreitung.</emphasis>
<normalizedToken id="241214FD0B9A27C2A3DB43282B457176" originalValue="Ursprünglich" pageId="null" pageNumber="465">Urspruenglich</normalizedToken>
<emphasis id="E64C4ADDE6DCA195232AE1E7917C8001" italics="true" pageId="null" pageNumber="465">
<normalizedToken id="C98BC8DB4EB5E2CF7AEE043622E7530E" originalValue="südwestasiatische" pageId="null" pageNumber="465">suedwestasiatische</normalizedToken>
Pflanze:
</emphasis>
In zahlreichen Kultursorten in den subtropischen und 
<normalizedToken id="F490EF3AB274240B15A0C1241C737F37" originalValue="gemäßigten" pageId="null" pageNumber="465">gemaessigten</normalizedToken>
Zonen verbreitet.
</paragraph>
<paragraph id="50C0A946FEE0C9C8518CEDB8F5637053" pageId="null" pageNumber="465">
<emphasis id="26F24D3BCD8E4BC4800DFDC25562BB12" italics="true" pageId="null" pageNumber="465">
Bemerkungen. 
<taxonomicName id="5676D7E3801E397D0D78D2CDA340B2D6" authority="Juslen" authorityName="Juslen" class="Magnoliopsida" family="Rosaceae" genus="Prunus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="465" phylum="Tracheophyta" rank="species" species="insititia">P. insititia Juslen</taxonomicName>
</emphasis>
(sensu 
<normalizedToken id="9D1AC66097296A1EC9063FBC7DADC32C" originalValue="Kárpáti" pageId="null" pageNumber="465">Karpati</normalizedToken>
1967) ist der Bastard, den Endlich und Murawski (1962) aus der Kreuzung 
<taxonomicName id="D1FBFAB111CF3A3F234095D2808DE464" class="Magnoliopsida" family="Rosaceae" genus="Prunus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="465" phylum="Tracheophyta" rank="species" species="spinosa">
<emphasis id="885A49DF8826D632C0B7A635B2B92326" italics="true" pageId="null" pageNumber="465">P. spinosa</emphasis>
</taxonomicName>
<normalizedToken id="4AE38CF60000F3BFEE1D410AD95D9B10" originalValue="×" pageId="null" pageNumber="465">x</normalizedToken>
<taxonomicName id="8300502030C20A9B59F761E0B72C74B2" class="Magnoliopsida" family="Rosaceae" genus="Prunus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="465" phylum="Tracheophyta" rank="species" species="cerasifera">
<emphasis id="2B338592084D0EEDF783E6F4EF1D6F79" italics="true" pageId="null" pageNumber="465">P. cerasifera</emphasis>
</taxonomicName>
(mit Verdoppelung des Chromosomensatzes) erhalten und als 
<taxonomicName id="9E98F423C824EDB21592E782DB88405C" class="Magnoliopsida" family="Rosaceae" genus="Persica" higherTaxonomySource="GBIF" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="465" phylum="Tracheophyta" rank="species" species="domestica">
<emphasis id="32FB73B2FF5B8ED883637B3E2BB19658" italics="true" pageId="null" pageNumber="465">P. domestica</emphasis>
</taxonomicName>
bezeichnet haben. 
<taxonomicName id="CE2A6BC4FAFDED5514C90B968321E619" class="Magnoliopsida" family="Rosaceae" genus="Prunus" kingdom="Plantae" order="Rosales" pageId="null" pageNumber="465" phylum="Tracheophyta" rank="species" species="insititia">
<emphasis id="527072EB03E3E99BF6261563A772364F" italics="true" pageId="null" pageNumber="465">P. insititia</emphasis>
</taxonomicName>
ist seit der Pfahlbauzeit bei uns nachgewiesen.
</paragraph>
</subSubSection>
