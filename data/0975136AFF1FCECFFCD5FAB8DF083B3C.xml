<emphasis id="B3A87E6EFF1FCECFFCD5FAB8D8AE39AA" bold="true" box="[810,1021,1385,1412]" pageId="146" pageNumber="147">
Group 
<taxonomicName id="46DCD9FFFF1FCECFFC7BFAB8D8AE39AA" authority="Perty, 1833" authorityName="Perty" authorityYear="1833" box="[900,1021,1385,1412]" class="Arachnida" family="Actinopodidae" genus="Actinopus" kingdom="Animalia" order="Araneae" pageId="146" pageNumber="147" phylum="Arthropoda" rank="genus">
<emphasis id="B3A87E6EFF1FCECFFC7BFAB8D8AE39AA" bold="true" box="[900,1021,1385,1412]" italics="true" pageId="146" pageNumber="147">osbournei</emphasis>
