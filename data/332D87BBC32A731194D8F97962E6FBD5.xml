</paragraph>
</subSubSection>
<caption id="EFFB6625C32B731694D8F90D6258F8D1" ID-DOI="http://doi.org/10.5281/zenodo.6610178" ID-Zenodo-Dep="6610178" httpUri="https://zenodo.org/record/6610178/files/figure.png" pageId="11" pageNumber="140" startId="11.[151,264,1789,1813]" targetBox="[180,1416,273,1763]" targetPageId="11">
<paragraph id="BB3B36ADC32B731694D8F90D6258F8D1" blockId="11.[151,1436,1789,1885]" pageId="11" pageNumber="140">
<emphasis id="89F0EABFC32B731694D8F90D612EF899" bold="true" box="[151,340,1789,1813]" pageId="11" pageNumber="140">FIGURES 32–39.</emphasis>
<taxonomicName id="7C844D2EC32B73169515F90E625CF899" authority="Richardson, 2022" authorityName="Richardson" authorityYear="2022" box="[346,550,1790,1813]" class="Arachnida" family="Salticidae" genus="Papuaneon" kingdom="Animalia" order="Araneae" pageId="11" pageNumber="140" phylum="Arthropoda" rank="species" species="ewingar" status="n. sp.">
<emphasis id="89F0EABFC32B73169515F90E625CF899" box="[346,550,1790,1813]" italics="true" pageId="11" pageNumber="140">Papuaneon ewingar</emphasis>
</taxonomicName>
