<subSubSection id="28E01C5AF61F7F95406F39BC8AA6ABF3" pageId="null" pageNumber="789" type="nomenclature">
<paragraph id="F8135F1166F71591DA38AD0C9874BB57" pageId="null" pageNumber="789">
<taxonomicName id="B7C86A02312044468E77F781096B9042" authority="L." class="Magnoliopsida" family="Caryophyllaceae" genus="Gypsophila" kingdom="Plantae" order="Caryophyllales" pageId="null" pageNumber="789" phylum="Tracheophyta" rank="species" species="paniculata">
<pageBreakToken id="BD2873AFC19F69D22EB9C26F8BF7CA2F" pageId="null" pageNumber="789">Gypsophila</pageBreakToken>
<normalizedToken id="26D92398396BDD44726FF86C0DB98BF2" originalValue="paniculáta" pageId="null" pageNumber="789">paniculata</normalizedToken>
<authorityName id="18743CA0888303AC70CCB5D532CD3BBC" pageId="null" pageNumber="789">L.</authorityName>
</taxonomicName>
</paragraph>
</subSubSection>
<subSubSection id="1726509386D65EBD582E4ACAB5A2C9C5" pageId="null" pageNumber="789" type="vernacular_names">
<paragraph id="FA1A0B30B6B6CF331667214A1CA7E8EC" pageId="null" pageNumber="789">Rispiges Gipskraut</paragraph>
</subSubSection>
</title>
<subSubSection id="CC9F4D5159D0996F04656808C478FCDC" pageId="null" pageNumber="789" type="description">
<paragraph id="132B031FE6DD56F7AF10F91DB65BA18A" pageId="null" pageNumber="789">
Ausdauernd, 
<emphasis id="1FAE5A66BB94E3DD865A11C2242A981F" italics="true" pageId="null" pageNumber="789">mit dickem Rhizom, ohne sterile Triebe; 60-90 cm hoch;</emphasis>
kahl oder gelegentlich im untern Teil sehr kurz behaart. Stengel aufrecht, mehrfach verzweigt. 
<normalizedToken id="84D8C07D1B88831E92D6169EAC0895A0" originalValue="Blätter" pageId="null" pageNumber="789">Blaetter</normalizedToken>
schmal lanzettlich, 
<pageBreakToken id="433FD94C29F0E993515ACE71B774E7E3" pageId="null" pageNumber="789">bis</pageBreakToken>
8 cm lang, 
<emphasis id="FE94736E91A09B057B783305629625A6" italics="true" pageId="null" pageNumber="789">5-12mal so lang wie breit.</emphasis>
<normalizedToken id="64415778FB960968D2DA36C959E526D8" originalValue="Blüten" pageId="null" pageNumber="789">Blueten</normalizedToken>
in rispenartigen 
<normalizedToken id="F031B2D449EA326AFCC5A378057D526D" originalValue="Blütenständen" pageId="null" pageNumber="789">Bluetenstaenden</normalizedToken>
. 
<emphasis id="6797C8D4CA0D0BC71A5484AA2AB8E73B" italics="true" pageId="null" pageNumber="789">Kelch 1,5-2 mm lang</emphasis>
, kahl; 
<normalizedToken id="B4EB86D4369AEB14112F6738E5F045D4" originalValue="Kelchzähne" pageId="null" pageNumber="789">Kelchzaehne</normalizedToken>
etwa 
<normalizedToken id="4B82929B6E2F39F767CE14C67F7F6946" originalValue="½" pageId="null" pageNumber="789">1/2</normalizedToken>
so lang wie der verwachsene Kelchteil. 
<emphasis id="DC6B6C4B3A0133FC2F8E58F02850AD3D" italics="true" pageId="null" pageNumber="789">
<normalizedToken id="F17B479A5C3B1F6FB61FCBDC1BA7B7EE" originalValue="Kronblätter" pageId="null" pageNumber="789">Kronblaetter</normalizedToken>
3-4 mm lang
</emphasis>
, 
<normalizedToken id="F6B8521D63466F049F20942CFCF4DEC9" originalValue="weiß" pageId="null" pageNumber="789">weiss</normalizedToken>
, selten rosa. Kapsel 1,5-2,5 mm lang, sehr kurz gestielt. Samen etwa 1,5 mm im Durchmesser. - 
<normalizedToken id="558136D86C837E2695E290A389C8A4DC" originalValue="Blüte" pageId="null" pageNumber="789">Bluete</normalizedToken>
: Sommer.
</paragraph>
<paragraph id="8828D16F163B262DFEB15FEDE14D0256" pageId="null" pageNumber="789">
<emphasis id="77E12D9A5DA03EEEEE1B4B54B3D4FCAD" italics="true" pageId="null" pageNumber="789">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="0A3621BF0B42394C34042F68A658B73F" italics="true" pageId="null" pageNumber="789">28:</emphasis>
Material aus Ungarn (Baksay 1962). 
<emphasis id="7E660DD39D4766CA77991BD4170E8C7B" italics="true" pageId="null" pageNumber="789">2n = 34:</emphasis>
Material aus botanischem Garten (Reese aus 
<normalizedToken id="1E5889E554472D48386289E5395FEFE9" originalValue="Löve" pageId="null" pageNumber="789">Loeve</normalizedToken>
und 
<normalizedToken id="D20C19F624A95A560802B78A30DED1A1" originalValue="Löve" pageId="null" pageNumber="789">Loeve</normalizedToken>
1961).
</paragraph>
<paragraph id="57C04EF8D3CD05E2776BEAC46C1CFC06" pageId="null" pageNumber="789">
<emphasis id="3E1A17287571F82201981FD401756CCA" italics="true" pageId="null" pageNumber="789">Standort.</emphasis>
Kollin. Lockere, steinige und sandige 
<normalizedToken id="411B6210D31252F3B50EEAA23924FAA7" originalValue="Böden" pageId="null" pageNumber="789">Boeden</normalizedToken>
in warmen Lagen. Felsige 
<normalizedToken id="55B6A6DE0448531F7CB3221FC147B140" originalValue="Hänge" pageId="null" pageNumber="789">Haenge</normalizedToken>
, 
<normalizedToken id="83394DF6A4425A39AFC242A941A62D12" originalValue="Dämme" pageId="null" pageNumber="789">Daemme</normalizedToken>
, 
<normalizedToken id="A4EF78D49DFA1608FFEB52A92654E981" originalValue="Schuttplätze" pageId="null" pageNumber="789">Schuttplaetze</normalizedToken>
.
</paragraph>
<paragraph id="51B125AF7DC186A5F3E67AFE818AE351" pageId="null" pageNumber="789">
<emphasis id="72373672942AD8D2DBFD72E1D6502A1A" italics="true" pageId="null" pageNumber="789">
Verbreitung. 
<normalizedToken id="827674F3FB8D862A9561555676D5FB94" originalValue="Osteuropäisch-westasiatische" pageId="null" pageNumber="789">Osteuropaeisch-westasiatische</normalizedToken>
Pflanze:
</emphasis>
<normalizedToken id="1551488FBE96F1238057746AE28ECBC0" originalValue="Südosteuropa" pageId="null" pageNumber="789">Suedosteuropa</normalizedToken>
(
<normalizedToken id="F5617381F3A9BF16C46D44AD396B2D4A" originalValue="nordwärts" pageId="null" pageNumber="789">nordwaerts</normalizedToken>
bis 
<normalizedToken id="28B4D89E9DF786C25D6889CB6AD2E5B1" originalValue="Nordrußland" pageId="null" pageNumber="789">Nordrussland</normalizedToken>
, 
<normalizedToken id="30ABFC5B8AA805EA7297832240229907" originalValue="westwärts" pageId="null" pageNumber="789">westwaerts</normalizedToken>
bis Polen, 
<normalizedToken id="1A66AE362D6DF51B299BF5B9C3E9615D" originalValue="Mähren" pageId="null" pageNumber="789">Maehren</normalizedToken>
und 
<normalizedToken id="576409E7B547BCB67CFB96F9D025562A" originalValue="Niederösterreich" pageId="null" pageNumber="789">Niederoesterreich</normalizedToken>
); Kaukasus; Westsibirien, Zentralasien. - Im Gebiet im untern Rhonetal (Waadt) und Genferseegebiet 
<normalizedToken id="E144CA052F85C2B99E028A0ABF1B8047" originalValue="eingebürgert" pageId="null" pageNumber="789">eingebuergert</normalizedToken>
; sonst selten aus 
<normalizedToken id="DED1B7ED9417C4FC10AC57BB53B5F745" originalValue="Gärten" pageId="null" pageNumber="789">Gaerten</normalizedToken>
verwildert.
</paragraph>
</subSubSection>
