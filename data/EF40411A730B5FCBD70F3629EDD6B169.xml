<subSubSection id="608C31440A355A5CE16F133F12A74965" pageId="null" pageNumber="493" type="description">
<paragraph id="1D3202A7C2777758258B8C77F4A9FC23" pageId="null" pageNumber="493">
8-30 cm hoch; mit niederliegenden Stengeln und aufsteigenden Zweigen, am Grunde verholzt. Stengel und 
<normalizedToken id="9D634B4924DAEC21E5CF10F0E3AA8B97" originalValue="Blätter" pageId="null" pageNumber="493">Blaetter</normalizedToken>
dicht anliegend und seidig behaart (Haare 0,5-1 mm lang). 
<emphasis id="860E8ACDF9EC9AC738A68259621873E3" italics="true" pageId="null" pageNumber="493">
<normalizedToken id="58260DD1C53AE1AF98C5DAB81847AF25" originalValue="Teilblätter" pageId="null" pageNumber="493">Teilblaetter</normalizedToken>
oval bis lanzettlich
</emphasis>
, 0,5-1,5 cm lang und 
<normalizedToken id="44AB8711D5023237B636F5CBAFF73E31" originalValue="¼-¾" pageId="null" pageNumber="493">1/4-3/4</normalizedToken>
so breit. 
<emphasis id="E90E07F188F68129802BE633259FDC2E" italics="true" pageId="null" pageNumber="493">
<normalizedToken id="0EA56EC763CB933042EDB0DF64DE9064" originalValue="Blüten" pageId="null" pageNumber="493">Blueten</normalizedToken>
in 1-4 
<normalizedToken id="731F0B8978847BCB14745797969729D6" originalValue="blütigen" pageId="null" pageNumber="493">bluetigen</normalizedToken>
Trauben am Ende der Zweige.
</emphasis>
Kelch seidig behaart, 
<emphasis id="B30EEDBF29C54160D169B18000B1D06F" italics="true" pageId="null" pageNumber="493">bis auf etwa</emphasis>
⅓ 
<emphasis id="AB0508DDFE997D6E9BA5AF02B877BFE4" italics="true" pageId="null" pageNumber="493">2lippig</emphasis>
, mit bis auf etwa ⅓ 2teiliger Oberlippe und bis auf ⅔ 3teiliger Unterlippe. Krone 1-1,2 cm lang, gelb; Schiffchen kahl; Fahne 
<normalizedToken id="06E71E65856BFC04226D4C75B204F086" originalValue="länger" pageId="null" pageNumber="493">laenger</normalizedToken>
als das Schiffchen, 
<emphasis id="425A277CDB2ED201FC04A569E857EAB0" italics="true" pageId="null" pageNumber="493">behaart;</emphasis>
<normalizedToken id="107FC9C071E71DBCFF4A508472D5418C" originalValue="Flügel" pageId="null" pageNumber="493">Fluegel</normalizedToken>
<normalizedToken id="FC663D9B1F1BAA11DB816A325E6A3A4F" originalValue="länger" pageId="null" pageNumber="493">laenger</normalizedToken>
als das Schiffchen. Frucht 2-3,5 cm lang und 0,4-0,5 cm breit, dicht anliegend behaart (Haare 1-2 mm lang), 4-10samig. - 
<normalizedToken id="16D3EE5C4FD3F7FE237D7ABB099AF53E" originalValue="Blüte" pageId="null" pageNumber="493">Bluete</normalizedToken>
: 
<normalizedToken id="B15606CC7D3DC74DA0C9B26C94120600" originalValue="Später" pageId="null" pageNumber="493">Spaeter</normalizedToken>
<normalizedToken id="79D40F15A20F12F40A85CCDEABA8C927" originalValue="Frühling" pageId="null" pageNumber="493">Fruehling</normalizedToken>
und 
<normalizedToken id="C4E0BB1D7E3C9A162B164AABA1CEECE5" originalValue="früher" pageId="null" pageNumber="493">frueher</normalizedToken>
Sommer.
</paragraph>
<paragraph id="78AE0AC4EBAA7AF116E396F33DE59359" pageId="null" pageNumber="493">
<emphasis id="D55FE79463DC190955AF1C9031FB2CF7" italics="true" pageId="null" pageNumber="493">Zytologische Angaben. 2n</emphasis>
= 
<emphasis id="4AFB7DD61BE08460C75A44F670D6A9E2" italics="true" pageId="null" pageNumber="493">48:</emphasis>
Material aus Spanien (Lorenzo-Andreu 1951) und Jugoslawien (Larsen 1956a), aus botanischem Garten (Gilot 1965).
</paragraph>
<paragraph id="A861A91CC8E2DB989C19D8EAE569E947" pageId="null" pageNumber="493">
<emphasis id="31EDEEBE352EAF3BEF5B41B734FE5E10" italics="true" pageId="null" pageNumber="493">Standort.</emphasis>
Kollin.Trockene, steinige, kalkhaltige 
<normalizedToken id="99AEAAC64A95409D7403B78046C4B87B" originalValue="Böden" pageId="null" pageNumber="493">Boeden</normalizedToken>
in warmen Lagen. 
<normalizedToken id="666A46551C73930027A57FCF448C0470" originalValue="Felshänge" pageId="null" pageNumber="493">Felshaenge</normalizedToken>
, steinige Felder, 
<normalizedToken id="11BD887CC8CBA9F831E2FD83A9D11497" originalValue="Föhrenwälder" pageId="null" pageNumber="493">Foehrenwaelder</normalizedToken>
.
</paragraph>
<paragraph id="091E5514BD31FC35EC2179C5BF694297" pageId="null" pageNumber="493">
<emphasis id="C89C770E098C162F8D3E3B9D937C84FF" italics="true" pageId="null" pageNumber="493">
Verbreitung. 
<normalizedToken id="7983663DEFD2A4641BE6BA4E168E9BAC" originalValue="Südwesteuropäische" pageId="null" pageNumber="493">Suedwesteuropaeische</normalizedToken>
Pflanze:
</emphasis>
Nord- und 
<normalizedToken id="DA5852AACD4DA11119BB74A587C29BC9" originalValue="ostwärts" pageId="null" pageNumber="493">ostwaerts</normalizedToken>
bis Nantes, Ain, 
<normalizedToken id="B8D521DDCF122DA6D07D3DBBC3B274B3" originalValue="Alpensüdseite" pageId="null" pageNumber="493">Alpensuedseite</normalizedToken>
, Kroatien, Dalmatien. - Im Gebiet: 
<normalizedToken id="F1C674B4A0B7B45D49CE9E005A651F4D" originalValue="Südlicher" pageId="null" pageNumber="493">Suedlicher</normalizedToken>
Jura (
<normalizedToken id="BE033EB8696F4AA8C14F3D7D8A5109A6" originalValue="Dép" pageId="null" pageNumber="493">Dep</normalizedToken>
. Ain, Savoyen), Aostatal (St-Vincent), Bergamasker Alpen (unterer Teil des Iseosees, Adrara, Monte Canto); nicht 
<normalizedToken id="0ED4F202F90EF16CD02A2A985F7BF8F6" originalValue="häufig" pageId="null" pageNumber="493">haeufig</normalizedToken>
.
</paragraph>
<paragraph id="DF90C51BFBB63C38A84D36DC3F020C47" pageId="null" pageNumber="493">
<emphasis id="AD3B227E681C1CE574E1918318CEC25F" italics="true" pageId="null" pageNumber="493">Bemerkungen.</emphasis>
In der Flora Europaea 
<emphasis id="B867E38D21A10D5D5CCB3DC8521DE5BB" italics="true" pageId="null" pageNumber="493">2</emphasis>
(1968) wird der Name 
<taxonomicName id="50B6932DF4C0956DB33801443D1409AC" authority="(Turra) P. W. Ball" authorityName="P. W. Ball" baseAuthorityName="Turra" class="Magnoliopsida" family="Fabaceae" genus="Argyrolobium" kingdom="Plantae" order="Fabales" pageId="null" pageNumber="493" phylum="Tracheophyta" rank="species" species="zanonii">
<emphasis id="2CA79663A98536E5998CECD09ABED3E9" italics="true" pageId="null" pageNumber="493">A. Zanonii</emphasis>
(Turra) P. W. Ball
</taxonomicName>
verwendet.
</paragraph>
</subSubSection>
