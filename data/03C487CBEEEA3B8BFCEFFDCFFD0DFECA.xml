<subSubSection id="C3776556EEEC3B8BFC9AF948FD0DFECA" lastPageId="446" lastPageNumber="447" pageId="445" pageNumber="446" type="discussion">
<paragraph id="8BD236DDEEEC3B88FC9AF948FA9CF871" blockId="445.[810,1452,1669,2070]" pageId="445" pageNumber="446">
<emphasis id="B919EACFEEEC3B88FC9AF948FC09F961" bold="true" box="[863,972,1670,1696]" pageId="445" pageNumber="446">Remarks</emphasis>
. 
<taxonomicName id="4C6D4D5EEEEC3B88FC1AF948FB41F95E" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[991,1156,1669,1695]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="445" pageNumber="446" phylum="Arthropoda" rank="species" species="bidens" status="sp. nov.">
<emphasis id="B919EACFEEEC3B88FC1AF948FB41F95E" box="[991,1156,1669,1695]" italics="true" pageId="445" pageNumber="446">Bysone bidens</emphasis>
</taxonomicName>
<emphasis id="B919EACFEEEC3B88FB55F948FB2BF961" bold="true" box="[1168,1262,1670,1696]" pageId="445" pageNumber="446">
<taxonomicNameLabel id="A22A57B4EEEC3B88FB55F948FB2BF961" box="[1168,1262,1670,1696]" pageId="445" pageNumber="446" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
is more similar to 
<taxonomicName id="4C6D4D5EEEEC3B88FC8DF966FBC3F900" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[840,1030,1703,1730]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="445" pageNumber="446" phylum="Arthropoda" rank="species" species="brevicaudatus" status="sp. nov.">
<emphasis id="B919EACFEEEC3B88FC8DF966FC9CF900" box="[840,857,1704,1729]" italics="true" pageId="445" pageNumber="446">B</emphasis>
. 
<emphasis id="B919EACFEEEC3B88FCADF969FBC3F900" box="[872,1030,1703,1729]" italics="true" pageId="445" pageNumber="446">brevicaudatus</emphasis>
</taxonomicName>
<emphasis id="B919EACFEEEC3B88FBC8F966FBADF903" bold="true" box="[1037,1128,1704,1730]" pageId="445" pageNumber="446">
<taxonomicNameLabel id="A22A57B4EEEC3B88FBC8F966FBADF903" box="[1037,1128,1704,1730]" pageId="445" pageNumber="446" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
than to 
<taxonomicName id="4C6D4D5EEEEC3B88FB03F966FAAFF900" authorityName="Stock &amp; Humes" authorityYear="1970" box="[1222,1386,1703,1730]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="445" pageNumber="446" phylum="Arthropoda" rank="species" species="operculatus">
<emphasis id="B919EACFEEEC3B88FB03F966FB12F900" box="[1222,1239,1704,1729]" italics="true" pageId="445" pageNumber="446">B</emphasis>
. 
<emphasis id="B919EACFEEEC3B88FB22F969FAAFF900" box="[1255,1386,1703,1729]" italics="true" pageId="445" pageNumber="446">operculatus</emphasis>
</taxonomicName>
; both share several character states including the 3-segmented endopod of the maxilla (2-segmented in 
<taxonomicName id="4C6D4D5EEEEC3B88FB32F922FA5EF8C4" authorityName="Stock &amp; Humes" authorityYear="1970" box="[1271,1435,1771,1798]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="445" pageNumber="446" phylum="Arthropoda" rank="species" species="operculatus">
<emphasis id="B919EACFEEEC3B88FB32F922FACDF8C4" box="[1271,1288,1772,1797]" italics="true" pageId="445" pageNumber="446">B</emphasis>
. 
<emphasis id="B919EACFEEEC3B88FADDF925FA5EF8C4" box="[1304,1435,1771,1797]" italics="true" pageId="445" pageNumber="446">operculatus</emphasis>
</taxonomicName>
), the presence of a claw on the maxillary basis (only setae present in 
<taxonomicName id="4C6D4D5EEEEC3B88FC5FF8FEFBFFF88B" authorityName="Stock &amp; Humes" authorityYear="1970" box="[922,1082,1840,1866]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="445" pageNumber="446" phylum="Arthropoda" rank="species" species="operculatus">
<emphasis id="B919EACFEEEC3B88FC5FF8FEFC6EF888" box="[922,939,1840,1865]" italics="true" pageId="445" pageNumber="446">B</emphasis>
. 
<emphasis id="B919EACFEEEC3B88FC72F8FEFBFFF88B" box="[951,1082,1840,1866]" italics="true" pageId="445" pageNumber="446">operculatus</emphasis>
</taxonomicName>
), the inner coxalseta is present in allswimming legs (present onlyin leg 
<quantity id="4C959B38EEEC3B88FB0BF89CFB32F8AD" box="[1230,1271,1874,1900]" metricMagnitude="-2" metricUnit="m" metricValue="2.54" pageId="445" pageNumber="446" unit="in" value="1.0">1 in</quantity>
<taxonomicName id="4C6D4D5EEEEC3B88FB3EF89CFA5EF8AD" authorityName="Stock &amp; Humes" authorityYear="1970" box="[1275,1435,1874,1900]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="445" pageNumber="446" phylum="Arthropoda" rank="species" species="operculatus">
<emphasis id="B919EACFEEEC3B88FB3EF89CFAC9F8AA" box="[1275,1292,1874,1899]" italics="true" pageId="445" pageNumber="446">B</emphasis>
. 
<emphasis id="B919EACFEEEC3B88FADDF89CFA5EF8AD" box="[1304,1435,1874,1900]" italics="true" pageId="445" pageNumber="446">operculatus</emphasis>
</taxonomicName>
), and the second endopodal segment of leg 1 is armed with 7 setae (compared with 6 setaein 
<taxonomicName id="4C6D4D5EEEEC3B88FB63F858FA8DF871" authorityName="Stock &amp; Humes" authorityYear="1970" box="[1190,1352,1942,1968]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="445" pageNumber="446" phylum="Arthropoda" rank="species" species="operculatus">
<emphasis id="B919EACFEEEC3B88FB63F858FB72F86E" box="[1190,1207,1942,1967]" italics="true" pageId="445" pageNumber="446">B</emphasis>
. 
<emphasis id="B919EACFEEEC3B88FB00F858FA8DF871" box="[1221,1352,1942,1968]" italics="true" pageId="445" pageNumber="446">operculatus</emphasis>
</taxonomicName>
).
</paragraph>
<paragraph id="8BD236DDEEEC3B8BFC9AF876FD0DFECA" blockId="445.[810,1452,1669,2070]" lastBlockId="446.[136,778,173,268]" lastPageId="446" lastPageNumber="447" pageId="445" pageNumber="446">
The salient differences between 
<taxonomicName id="4C6D4D5EEEEC3B88FB02F876FA41F813" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[1223,1412,1976,2002]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="445" pageNumber="446" phylum="Arthropoda" rank="species" species="brevicaudatus" status="sp. nov.">
<emphasis id="B919EACFEEEC3B88FB02F876FB1DF810" box="[1223,1240,1976,2001]" italics="true" pageId="445" pageNumber="446">B</emphasis>
. 
<emphasis id="B919EACFEEEC3B88FB23F876FA41F813" box="[1254,1412,1976,2002]" italics="true" pageId="445" pageNumber="446">brevicaudatus</emphasis>
</taxonomicName>
<emphasis id="B919EACFEEEC3B88FA4FF876FC9EF835" bold="true" pageId="445" pageNumber="446">
<taxonomicNameLabel id="A22A57B4EEEC3B88FA4FF876FC9EF835" pageId="445" pageNumber="446" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
and 
<taxonomicName id="4C6D4D5EEEEC3B88FC56F814FC39F835" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[915,1020,2010,2036]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="445" pageNumber="446" phylum="Arthropoda" rank="species" species="bidens" status="sp. nov.">
<emphasis id="B919EACFEEEC3B88FC56F814FC61F832" box="[915,932,2010,2035]" italics="true" pageId="445" pageNumber="446">B</emphasis>
. 
<emphasis id="B919EACFEEEC3B88FC76F814FC39F835" box="[947,1020,2010,2036]" italics="true" pageId="445" pageNumber="446">bidens</emphasis>
</taxonomicName>
<emphasis id="B919EACFEEEC3B88FBC1F814FB9BF835" bold="true" box="[1028,1118,2010,2036]" pageId="445" pageNumber="446">
<taxonomicNameLabel id="A22A57B4EEEC3B88FBC1F814FB9BF835" box="[1028,1118,2010,2036]" pageId="445" pageNumber="446" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
are 7 setae on the maxilliped in the latter (vs. 9 setae in 
<taxonomicName id="4C6D4D5EEEEC3B88FBA5F832FADAF7D7" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[1120,1311,2044,2070]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="445" pageNumber="446" phylum="Arthropoda" rank="species" species="brevicaudatus" status="sp. nov.">
<emphasis id="B919EACFEEEC3B88FBA5F832FBB4F7D4" box="[1120,1137,2044,2069]" italics="true" pageId="445" pageNumber="446">B</emphasis>
. 
<emphasis id="B919EACFEEEC3B88FB44F832FADAF7D7" box="[1153,1311,2044,2070]" italics="true" pageId="445" pageNumber="446">brevicaudatus</emphasis>
</taxonomicName>
<emphasis id="B919EACFEEEC3B88FAEDF832FA41F7D7" bold="true" box="[1320,1412,2044,2070]" pageId="445" pageNumber="446">
<taxonomicNameLabel id="A22A57B4EEEC3B88FAEDF832FA41F7D7" box="[1320,1412,2044,2070]" pageId="445" pageNumber="446" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
), 4 setae on the second exopodal segment of leg 1 (vs. 3 setae in 
<taxonomicName id="4C6D4D5EEEEF3B8BFF61FF1EFEA4FF28" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[164,353,207,233]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="446" pageNumber="447" phylum="Arthropoda" rank="species" species="brevicaudatus" status="sp. nov.">
<emphasis id="B919EACFEEEF3B8BFF61FF1EFF70FF28" box="[164,181,208,233]" italics="true" pageId="446" pageNumber="447">B</emphasis>
. 
<emphasis id="B919EACFEEEF3B8BFF06FF01FEA4FF28" box="[195,353,207,233]" italics="true" pageId="446" pageNumber="447">brevicaudatus</emphasis>
</taxonomicName>
<emphasis id="B919EACFEEEF3B8BFEA2FF01FE05FF28" bold="true" box="[359,448,207,233]" pageId="446" pageNumber="447">
<taxonomicNameLabel id="A22A57B4EEEF3B8BFEA2FF01FE05FF28" box="[359,448,207,233]" pageId="446" pageNumber="447" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
), and a protopodal seta in leg 5 (vs. this seta absent in 
<taxonomicName id="4C6D4D5EEEEF3B8BFE5EFF3CFD9DFECA" authority="Kim &amp; Boxshall, 2020" authorityName="Kim &amp; Boxshall" authorityYear="2020" box="[411,600,241,267]" class="Maxillopoda" family="Notodelphyidae" genus="Bysone" higherTaxonomySource="GBIF" kingdom="Animalia" order="Cyclopoida" pageId="446" pageNumber="447" phylum="Arthropoda" rank="species" species="brevicaudatus" status="sp. nov.">
<emphasis id="B919EACFEEEF3B8BFE5EFF3CFE69FECA" box="[411,428,242,267]" italics="true" pageId="446" pageNumber="447">B</emphasis>
. 
<emphasis id="B919EACFEEEF3B8BFE7FFF3FFD9DFECA" box="[442,600,241,267]" italics="true" pageId="446" pageNumber="447">brevicaudatus</emphasis>
</taxonomicName>
<emphasis id="B919EACFEEEF3B8BFD9BFF3FFD7DFECA" bold="true" box="[606,696,241,267]" pageId="446" pageNumber="447">
<taxonomicNameLabel id="A22A57B4EEEF3B8BFD9BFF3FFD7DFECA" box="[606,696,241,267]" pageId="446" pageNumber="447" rank="species">sp. nov.</taxonomicNameLabel>
</emphasis>
).
</paragraph>
