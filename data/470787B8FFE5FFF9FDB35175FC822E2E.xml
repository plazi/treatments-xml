<subSubSection id="87B46525FFE5FFFFFF695189FAE92F6C" pageId="26" pageNumber="192" type="diagnosis">
<paragraph id="CF1136AEFFE5FFFFFF695189FECE28E4" blockId="26.[189,310,965,991]" box="[189,310,965,991]" pageId="26" pageNumber="192">
<heading id="945981C2FFE5FFFFFF695189FECE28E4" bold="true" box="[189,310,965,991]" fontSize="11" level="3" pageId="26" pageNumber="192" reason="3">
<emphasis id="FDDAEABCFFE5FFFFFF695189FECE28E4" bold="true" box="[189,310,965,991]" pageId="26" pageNumber="192">Diagnosis</emphasis>
</heading>
</paragraph>
<paragraph id="CF1136AEFFE5FFFFFF6951B8FAE92F6C" blockId="26.[188,1398,1012,1112]" pageId="26" pageNumber="192">
Females of 
<taxonomicName id="08AE4D2DFFE5FFFFFE9351B9FE252F35" authority="Rheims &amp; Alayón, 2022" authorityName="Rheims &amp; Alayón" authorityYear="2022" box="[327,477,1013,1038]" class="Arachnida" family="Sparassidae" genus="Neostasina" kingdom="Animalia" order="Araneae" pageId="26" pageNumber="192" phylum="Arthropoda" rank="species" species="toronegro" status="sp. nov.">
<emphasis id="FDDAEABCFFE5FFFFFE9351B9FE252F35" box="[327,477,1013,1038]" italics="true" pageId="26" pageNumber="192">N. toronegro</emphasis>
</taxonomicName>
<taxonomicNameLabel id="E6E957C7FFE5FFFFFE3151B9FDB82F34" box="[485,576,1013,1039]" pageId="26" pageNumber="192" rank="species">sp. nov.</taxonomicNameLabel>
resemble those of 
<taxonomicName id="08AE4D2DFFE5FFFFFCCB51B9FC6D2F35" authority="Rheims &amp; Alayón, 2022" authorityName="Rheims &amp; Alayón" authorityYear="2022" box="[799,917,1013,1038]" class="Arachnida" family="Sparassidae" genus="Neostasina" kingdom="Animalia" order="Araneae" pageId="26" pageNumber="192" phylum="Arthropoda" rank="species" species="juanita" status="sp. nov.">
<emphasis id="FDDAEABCFFE5FFFFFCCB51B9FC6D2F35" box="[799,917,1013,1038]" italics="true" pageId="26" pageNumber="192">N. juanita</emphasis>
</taxonomicName>
<taxonomicNameLabel id="E6E957C7FFE5FFFFFC4851B9FC0F2F34" box="[924,1015,1013,1039]" pageId="26" pageNumber="192" rank="species">sp. nov.</taxonomicNameLabel>
and 
<taxonomicName id="08AE4D2DFFE5FFFFFBE551B9FB682F35" authorityName="Rheims &amp; Alayon" authorityYear="2016" box="[1073,1168,1013,1038]" class="Arachnida" family="Sparassidae" genus="Neostasina" kingdom="Animalia" order="Araneae" pageId="26" pageNumber="192" phylum="Arthropoda" rank="species" species="taino">
<emphasis id="FDDAEABCFFE5FFFFFBE551B9FB682F35" box="[1073,1168,1013,1038]" italics="true" pageId="26" pageNumber="192">N. taino</emphasis>
</taxonomicName>
(
<bibRefCitation id="AB3F4B5FFFE5FFFFFB7651B8FF0E2F08" author="Rheims C. A. &amp; Alayon G." pageId="26" pageNumber="192" pagination="301 - 344" refId="ref12419" refString="Rheims C. A. &amp; Alayon G. 2016. Neostasina gen. nov., a new genus of huntsman spiders from the Neotropical region (Araneae, Sparassidae, Sparianthinae). Zootaxa 4079: 301 - 344. https: // doi. org / 10.11646 / zootaxa. 4079.3.1" type="journal article" year="2016">Rheims &amp; Alayón 2016</bibRefCitation>
: figs 140−142) by the subpentagonal shape of the MS. They are distinguished from the latter species by the ar evenly curved (
<figureCitation id="57952A2BFFE5FFFFFE345671FDB32F63" box="[480,587,1085,1112]" captionStart="Fig" captionStartId="28.[189,233,849,875]" captionTargetBox="[204,1376,310,784]" captionTargetId="figure-134@28.[189,1399,286,785]" captionTargetPageId="28" captionText="Fig. 16. Neostasina toronegro sp. nov., A−B: holotype, ♀ (MCZ 30719). A. Epigyne, ventral view. B. Vulva, dorsal view. C. Schematic course of internal duct system. Abbreviations: ar = anterior rim; CD = copulatory duct; FD = fertilization duct; GP = glandular projection; LL = lateral lobe; MS = median septum. Scale bars = 0.5 mm." figureDoi="http://doi.org/10.5281/zenodo.6607956" httpUri="https://zenodo.org/record/6607956/files/figure.png" pageId="26" pageNumber="192">Fig. 16A</figureCitation>
) (medially angled in the other species). Males are unknown.
</paragraph>
</subSubSection>
