recorded 11 species in the 
<taxonomicName id="145A3F825A148B71B020B4B331E7711D" baseAuthorityName="Moore" baseAuthorityYear="1867" class="Insecta" family="Drepanidae" genus="Ditrigona" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Ditrigona quinaria" order="Lepidoptera" pageId="0" pageNumber="57" phylum="Arthropoda" rank="species" species="quinaria">
<emphasis id="9CC977944EA983F3774F0E1C8A72C750" italics="true" pageId="0" pageNumber="57">Ditrigona quinaria</emphasis>
</taxonomicName>
species group: 
<taxonomicName id="F507969574107E5193296ED7183254EA" authorityName="Wilkinson" authorityYear="1968" class="Insecta" family="Drepanidae" genus="Ditrigona" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Ditrigona spilota" order="Lepidoptera" pageId="0" pageNumber="57" phylum="Arthropoda" rank="species" species="spilota">
<emphasis id="815919677DD7641ED0B573656973E441" italics="true" pageId="0" pageNumber="57">Ditrigona spilota</emphasis>
</taxonomicName>
Wilkinson, 
<taxonomicName id="3B3EFD05E146D69090069B2B5907F2E9" baseAuthorityName="Leech" baseAuthorityYear="1898" class="Insecta" family="Drepanidae" genus="Ditrigona" higherTaxonomySource="CoL" kingdom="Animalia" lsidName="Ditrigona inconspicua" order="Lepidoptera" pageId="0" pageNumber="57" phylum="Arthropoda" rank="species" species="inconspicua">
<emphasis id="A4F85CE73B8D0B37B45B3A6109BA0DF1" italics="true" pageId="0" pageNumber="57">Ditrigona inconspicua</emphasis>
</taxonomicName>
